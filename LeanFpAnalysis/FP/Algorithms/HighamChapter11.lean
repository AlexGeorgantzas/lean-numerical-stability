/-- Index embedding for placing a local tridiagonal branch block into a larger
ambient matrix starting at row/column `start`. -/
def higham11_7_tridiagonalLocalBlockIndex
    (n start m : ‚Ąē) (i : Fin m) (hi : start + i.val < n) : Fin n :=
  ‚ü®start + i.val, hi‚ü©

@[simp] theorem higham11_7_tridiagonalLocalBlockIndex_val
    (n start m : ‚Ąē) (i : Fin m) (hi : start + i.val < n) :
    (higham11_7_tridiagonalLocalBlockIndex n start m i hi).val =
      start + i.val :=
  rfl

/-- The generic local block index embedding is injective. -/
theorem higham11_7_tridiagonalLocalBlockIndex_injective
    (n start m : ‚Ąē) (h : ‚ąÄ i : Fin m, start + i.val < n) :
    Function.Injective
      (fun i : Fin m => higham11_7_tridiagonalLocalBlockIndex n start m i (h i)) := by
  intro i j hij
  apply Fin.ext
  have hval : start + i.val = start + j.val := by
    simpa using congrArg Fin.val hij
  omega

/-- A natural number is the value of a local block index exactly when it lies in
the half-open interval `[start, start + m)`. -/
theorem higham11_7_tridiagonalLocalBlockIndex_val_exists_iff
    (start m j : ‚Ąē) :
    (‚ąÉ a : Fin m, start + a.val = j) ‚ÜĒ start ‚Č§ j ‚ąß j < start + m := by
  constructor
  ¬∑ rintro ‚ü®a, ha‚ü©
    constructor <;> omega
  ¬∑ rintro ‚ü®hjlo, hjhi‚ü©
    refine ‚ü®‚ü®j - start, by omega‚ü©, ?_‚ü©
    change start + (j - start) = j
    omega

/-- The ambient range of the local block embedding is exactly the half-open
interval `[start, start + m)`. -/
theorem higham11_7_tridiagonalLocalBlockIndex_mem_range_iff
    (n start m : ‚Ąē) (h : ‚ąÄ i : Fin m, start + i.val < n)
    (j : Fin n) :
    (‚ąÉ a : Fin m,
      higham11_7_tridiagonalLocalBlockIndex n start m a (h a) = j) ‚ÜĒ
      start ‚Č§ j.val ‚ąß j.val < start + m := by
  constructor
  ¬∑ rintro ‚ü®a, ha‚ü©
    have hval : start + a.val = j.val := by
      simpa using congrArg Fin.val ha
    constructor <;> omega
  ¬∑ rintro ‚ü®hjlo, hjhi‚ü©
    obtain ‚ü®a, ha‚ü© :=
      (higham11_7_tridiagonalLocalBlockIndex_val_exists_iff start m j.val).2
        ‚ü®hjlo, hjhi‚ü©
    refine ‚ü®a, ?_‚ü©
    apply Fin.ext
    simpa [higham11_7_tridiagonalLocalBlockIndex_val] using ha

/-- Lift a local branch perturbation into a shared ambient matrix by placing it
at offset `start` and filling all non-embedded entries with zero. -/
noncomputable def higham11_7_tridiagonalLiftLocalBlockPerturbation
    (n start m : ‚Ąē) (E : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ) :
    Fin n ‚Üí Fin n ‚Üí ‚ĄĚ :=
  fun i j =>
    if hi : ‚ąÉ a : Fin m, start + a.val = i.val then
      if hj : ‚ąÉ b : Fin m, start + b.val = j.val then
        E (Classical.choose hi) (Classical.choose hj)
      else 0
    else 0

/-- The ambient lift agrees with the local perturbation on embedded local
indices. -/
@[simp] theorem higham11_7_tridiagonalLiftLocalBlockPerturbation_apply_embedded
    (n start m : ‚Ąē) (E : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ)
    (i j : Fin m) (hi : start + i.val < n) (hj : start + j.val < n) :
    higham11_7_tridiagonalLiftLocalBlockPerturbation n start m E
        (higham11_7_tridiagonalLocalBlockIndex n start m i hi)
        (higham11_7_tridiagonalLocalBlockIndex n start m j hj) =
      E i j := by
  classical
  have hi_ex : ‚ąÉ a : Fin m,
      start + a.val =
        (higham11_7_tridiagonalLocalBlockIndex n start m i hi).val :=
    ‚ü®i, rfl‚ü©
  have hj_ex : ‚ąÉ b : Fin m,
      start + b.val =
        (higham11_7_tridiagonalLocalBlockIndex n start m j hj).val :=
    ‚ü®j, rfl‚ü©
  have hci : Classical.choose hi_ex = i := by
    apply Fin.ext
    have hval := Classical.choose_spec hi_ex
    simpa using Nat.add_left_cancel hval
  have hcj : Classical.choose hj_ex = j := by
    apply Fin.ext
    have hval := Classical.choose_spec hj_ex
    simpa using Nat.add_left_cancel hval
  rw [higham11_7_tridiagonalLiftLocalBlockPerturbation, dif_pos hi_ex,
    dif_pos hj_ex, hci, hcj]

/-- Reindexing an embedded row dot product of a lifted local perturbation gives
the corresponding local row dot product. -/
theorem higham11_7_tridiagonalLiftLocalBlockPerturbation_embedded_row_dot_eq_local
    (n start m : ‚Ąē) (E : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ)
    (hcol : ‚ąÄ j : Fin m, start + j.val < n)
    (i : Fin m) (hi : start + i.val < n) (x : Fin n ‚Üí ‚ĄĚ) :
    (‚ąĎ j : Fin n,
      higham11_7_tridiagonalLiftLocalBlockPerturbation n start m E
        (higham11_7_tridiagonalLocalBlockIndex n start m i hi) j * x j) =
      ‚ąĎ j : Fin m, E i j *
        x (higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)) := by
  classical
  let emb : Fin m ‚Üí Fin n := fun j =>
    higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)
  let f : Fin n ‚Üí ‚ĄĚ := fun j =>
    higham11_7_tridiagonalLiftLocalBlockPerturbation n start m E
      (higham11_7_tridiagonalLocalBlockIndex n start m i hi) j * x j
  have hemb : Function.Injective emb :=
    higham11_7_tridiagonalLocalBlockIndex_injective n start m hcol
  have hsum_image :
      (‚ąĎ j ‚ąą Finset.univ.image emb, f j) = ‚ąĎ j : Fin n, f j := by
    refine Finset.sum_subset (Finset.subset_univ _) ?_
    intro j _hj hnot
    have hj_not : ¬¨ ‚ąÉ b : Fin m, start + b.val = j.val := by
      intro hj_ex
      rcases hj_ex with ‚ü®b, hb‚ü©
      apply hnot
      refine Finset.mem_image.mpr ‚ü®b, Finset.mem_univ b, ?_‚ü©
      apply Fin.ext
      simpa [emb, higham11_7_tridiagonalLocalBlockIndex_val] using hb
    simp [f, higham11_7_tridiagonalLiftLocalBlockPerturbation, hj_not]
  calc
    (‚ąĎ j : Fin n,
      higham11_7_tridiagonalLiftLocalBlockPerturbation n start m E
        (higham11_7_tridiagonalLocalBlockIndex n start m i hi) j * x j)
        = ‚ąĎ j : Fin n, f j := rfl
    _ = ‚ąĎ j ‚ąą Finset.univ.image emb, f j := hsum_image.symm
    _ = ‚ąĎ j : Fin m, f (emb j) := by
      rw [Finset.sum_image]
      intro a _ha b _hb hab
      exact hemb hab
    _ = ‚ąĎ j : Fin m, E i j *
        x (higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)) := by
      apply Finset.sum_congr rfl
      intro j _hj
      simp [f, emb]

/-- Reindex a full row dot product to a local block when the row is zero
outside that block.  This is the generic form used to turn branch-local row
equations into full ambient solve-row equations. -/
theorem higham11_7_tridiagonalRowDot_eq_localBlock_rowDot_of_zero_outside
    (n start m : ‚Ąē) (B : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (x : Fin n ‚Üí ‚ĄĚ)
    (hcol : ‚ąÄ j : Fin m, start + j.val < n)
    (i : Fin m) (hi : start + i.val < n)
    (hzero : ‚ąÄ j : Fin n,
      (¬¨ ‚ąÉ b : Fin m,
        higham11_7_tridiagonalLocalBlockIndex n start m b (hcol b) = j) ‚Üí
      B (higham11_7_tridiagonalLocalBlockIndex n start m i hi) j = 0) :
    (‚ąĎ j : Fin n,
      B (higham11_7_tridiagonalLocalBlockIndex n start m i hi) j * x j) =
      ‚ąĎ j : Fin m,
        B (higham11_7_tridiagonalLocalBlockIndex n start m i hi)
          (higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)) *
        x (higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)) := by
  classical
  let emb : Fin m ‚Üí Fin n := fun j =>
    higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)
  let row : Fin n :=
    higham11_7_tridiagonalLocalBlockIndex n start m i hi
  let f : Fin n ‚Üí ‚ĄĚ := fun j => B row j * x j
  have hemb : Function.Injective emb :=
    higham11_7_tridiagonalLocalBlockIndex_injective n start m hcol
  have hsum_image :
      (‚ąĎ j ‚ąą Finset.univ.image emb, f j) = ‚ąĎ j : Fin n, f j := by
    refine Finset.sum_subset (Finset.subset_univ _) ?_
    intro j _hj hnot
    have hj_not : ¬¨ ‚ąÉ b : Fin m, emb b = j := by
      intro hj_ex
      rcases hj_ex with ‚ü®b, hb‚ü©
      exact hnot (Finset.mem_image.mpr ‚ü®b, Finset.mem_univ b, hb‚ü©)
    have hB : B row j = 0 := by
      simpa [row, emb] using hzero j hj_not
    simp [f, hB]
  calc
    (‚ąĎ j : Fin n,
      B (higham11_7_tridiagonalLocalBlockIndex n start m i hi) j * x j)
        = ‚ąĎ j : Fin n, f j := by
          simp [f, row]
    _ = ‚ąĎ j ‚ąą Finset.univ.image emb, f j := hsum_image.symm
    _ = ‚ąĎ j : Fin m, f (emb j) := by
      rw [Finset.sum_image]
      intro a _ha b _hb hab
      exact hemb hab
    _ = ‚ąĎ j : Fin m,
        B (higham11_7_tridiagonalLocalBlockIndex n start m i hi)
          (higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)) *
        x (higham11_7_tridiagonalLocalBlockIndex n start m j (hcol j)) := by
      apply Finset.sum_congr rfl
      intro j _hj
      simp [f, emb, row]

/-- A lifted local perturbation is zero on rows strictly before the embedded
block start. -/
@[simp] theorem higham11_7_tridiagonalLiftLocalBlockPerturbation_apply_of_row_lt_start
    (n start m : ‚Ąē) (E : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ) (i j : Fin n)
    (hi : i.val < start) :
