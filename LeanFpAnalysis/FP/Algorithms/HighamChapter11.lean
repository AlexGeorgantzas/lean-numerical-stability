theorem
    higham11_4_product_entries_of_first_stage_recursive_uniform_six_row_sum_normalized_prefix_growth_D_bound
    (n s : ℕ) (hn : 0 < n) (hs_pos : 0 < s) (hs_le : s ≤ n)
