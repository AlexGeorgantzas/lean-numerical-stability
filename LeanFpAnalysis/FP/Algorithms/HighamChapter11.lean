  higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound n L_hat D_hat i j
    Dmax Lrow
    (higham11_4_nonneg_of_uniform_abs_entry_bound n hn D_hat Dmax hD)
    hD hrows

/-- Uniform entry product-entry bridge deriving `0‚Č§Dmax` from the nonempty
absolute `DŐā` entry cap. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_entry_bounds_entry_nonneg
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lmax : ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hL : ‚ąÄ r k : Fin n, |L_hat r k| ‚Č§ Lmax) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      ((n : ‚ĄĚ) * Lmax) * Dmax * ((n : ‚ĄĚ) * Lmax) :=
  higham11_4_bunchKaufmanProductEntry_le_uniform_entry_bounds n L_hat D_hat i j
    Dmax Lmax
    (higham11_4_nonneg_of_uniform_abs_entry_bound n hn D_hat Dmax hD)
    hD hL

/-- Row-dependent entry product-entry bridge deriving `0‚Č§Dmax` from the
nonempty absolute `DŐā` entry cap. -/
theorem higham11_4_bunchKaufmanProductEntry_le_row_entry_bounds_entry_nonneg
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax : ‚ĄĚ) (Lcap : Fin n ‚Üí ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hL : ‚ąÄ r k : Fin n, |L_hat r k| ‚Č§ Lcap r) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
