/-- **Theorem 11.4 block-recursion exact-constant handoff**
(Higham [608, 1997], eqs. (4.11)--(4.14)): if the local first-stage and
recursive Schur-complement contributions are bounded with Higham's exact
coefficient `(3+őĪ¬≤)(3+őĪ)/(1‚ąíőĪ¬≤)^2`, the proved eq-(4.13) inequality still
places their sum inside the printed `36nŌĀ‚āô‚ÄĖA‚ÄĖ_M` product budget. -/
theorem higham11_4_first_stage_recursive_product_bound_of_higham_const
    (n s : ‚Ąē) (hs_pos : 0 < s) (hs_le : s ‚Č§ n)
    (ŌĀ_n Amax localB recB : ‚ĄĚ) (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax)
    (hlocal :
      localB ‚Č§
        ((3 + higham11_1_bunchParlettAlpha ^ 2) *
            (3 + higham11_1_bunchParlettAlpha) /
            (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2) *
          ŌĀ_n * Amax)
    (hrec :
      recB ‚Č§
        ((3 + higham11_1_bunchParlettAlpha ^ 2) *
            (3 + higham11_1_bunchParlettAlpha) /
            (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2) *
          ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax) :
    localB + recB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
  let C : ‚ĄĚ :=
    (3 + higham11_1_bunchParlettAlpha ^ 2) *
      (3 + higham11_1_bunchParlettAlpha) /
      (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2
  have hC : C ‚Č§ 36 := by
    simpa [C] using higham11_4_bound_const_le_36
  have hŌĀA : 0 ‚Č§ ŌĀ_n * Amax := mul_nonneg hŌĀ hAmax
  have hlocal36 : localB ‚Č§ 36 * ŌĀ_n * Amax := by
    calc
      localB ‚Č§ C * ŌĀ_n * Amax := by simpa [C] using hlocal
      _ = C * (ŌĀ_n * Amax) := by ring
      _ ‚Č§ 36 * (ŌĀ_n * Amax) := mul_le_mul_of_nonneg_right hC hŌĀA
      _ = 36 * ŌĀ_n * Amax := by ring
  have htail :
      0 ‚Č§ ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax :=
    mul_nonneg (mul_nonneg (Nat.cast_nonneg _) hŌĀ) hAmax
  have hrec36 : recB ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := by
    calc
      recB ‚Č§ C * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := by
        simpa [C] using hrec
      _ = C * (((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax) := by ring
      _ ‚Č§ 36 * (((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax) :=
        mul_le_mul_of_nonneg_right hC htail
      _ = 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := by ring
  exact
    higham11_4_first_stage_recursive_product_bound n s hs_pos hs_le
      ŌĀ_n Amax localB recB hŌĀ hAmax hlocal36 hrec36

/-- Exact-coefficient first-stage plus recursive Schur-complement product-entry
bounds imply the printed pointwise `36nŌĀ‚āô‚ÄĖA‚ÄĖ_M` estimate for every entry of
`|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_product_entries_of_first_stage_recursive_higham_const_bounds
    (n s : ‚Ąē) (hs_pos : 0 < s) (hs_le : s ‚Č§ n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌĀ_n Amax localB recB : ‚ĄĚ)
    (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax)
    (hlocal_budget :
      localB ‚Č§
        ((3 + higham11_1_bunchParlettAlpha ^ 2) *
            (3 + higham11_1_bunchParlettAlpha) /
            (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2) *
          ŌĀ_n * Amax)
    (hrec_budget :
      recB ‚Č§
        ((3 + higham11_1_bunchParlettAlpha ^ 2) *
            (3 + higham11_1_bunchParlettAlpha) /
            (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2) *
          ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax)
    (hfirst : ‚ąÄ i j : Fin n, i.val < s ‚ą® j.val < s ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB)
    (htrail : ‚ąÄ i j : Fin n, s ‚Č§ i.val ‚Üí s ‚Č§ j.val ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB + recB) :
    ‚ąÄ i j : Fin n,
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
        36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
  let C : ‚ĄĚ :=
    (3 + higham11_1_bunchParlettAlpha ^ 2) *
      (3 + higham11_1_bunchParlettAlpha) /
      (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2
  have hC : C ‚Č§ 36 := by
    simpa [C] using higham11_4_bound_const_le_36
  have hŌĀA : 0 ‚Č§ ŌĀ_n * Amax := mul_nonneg hŌĀ hAmax
  have hn_one : (1 : ‚ĄĚ) ‚Č§ (n : ‚ĄĚ) := by
    have hs_one : 1 ‚Č§ s := Nat.succ_le_of_lt hs_pos
    exact_mod_cast hs_one.trans hs_le
  have hlocal_final :
      localB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
    calc
      localB ‚Č§ C * ŌĀ_n * Amax := by simpa [C] using hlocal_budget
      _ = C * (ŌĀ_n * Amax) := by ring
      _ ‚Č§ 36 * (ŌĀ_n * Amax) := mul_le_mul_of_nonneg_right hC hŌĀA
      _ = (1 : ‚ĄĚ) * (36 * ŌĀ_n * Amax) := by ring
      _ ‚Č§ (n : ‚ĄĚ) * (36 * ŌĀ_n * Amax) := by
        have hscale : 0 ‚Č§ 36 * ŌĀ_n * Amax :=
          mul_nonneg (mul_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 36) hŌĀ) hAmax
        exact mul_le_mul_of_nonneg_right hn_one hscale
      _ = 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by ring
  have htrail_final :
      localB + recB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax :=
    higham11_4_first_stage_recursive_product_bound_of_higham_const
      n s hs_pos hs_le ŌĀ_n Amax localB recB hŌĀ hAmax hlocal_budget hrec_budget
  intro i j
  by_cases hi : i.val < s
  ¬∑ exact (hfirst i j (Or.inl hi)).trans hlocal_final
  ¬∑ by_cases hj : j.val < s
    ¬∑ exact (hfirst i j (Or.inr hj)).trans hlocal_final
    ¬∑ have hi_ge : s ‚Č§ i.val := by omega
      have hj_ge : s ‚Č§ j.val := by omega
      exact (htrail i j hi_ge hj_ge).trans htrail_final

