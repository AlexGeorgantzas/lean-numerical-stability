theorem higham11_3_infNorm_le_of_componentwise_bound_nonneg (n : ‚Ąē)
    (őĒA B : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hB_nonneg : ‚ąÄ i j : Fin n, 0 ‚Č§ B i j)
    (hőĒ : ‚ąÄ i j : Fin n, |őĒA i j| ‚Č§ B i j) :
