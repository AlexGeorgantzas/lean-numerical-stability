/-- The symmetric `2 √ó 2` pivot block used by Algorithm 11.2 case-(4),
written as a concrete `Fin 2` matrix. -/
def higham11_4_twoByTwoPivotBlock (a11 a1r arr : ‚ĄĚ) :
    Fin 2 ‚Üí Fin 2 ‚Üí ‚ĄĚ :=
  fun i j =>
    if i = 0 then
