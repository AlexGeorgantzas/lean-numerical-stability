        (fun i j => higham11_3_fl_allOneByOneBound_nonneg fp hval n A i j)
        hΔA1
  · exact
      higham11_3_infNorm_le_of_componentwise_bound_nonneg n ΔA2
        (higham11_3_fl_allOneByOneBound fp n A)
        (fun i j => higham11_3_fl_allOneByOneBound_nonneg fp hval n A i j)
