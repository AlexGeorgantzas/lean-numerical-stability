/-- **Equation (11.15) source backward-error algebra**.  If the three rounded
solve-chain components satisfy perturbed equations and the unperturbed product
is `A = L T U`, then the collapsed product perturbation gives a single source
equation `(A+őĒA)w = rhs`.  The componentwise bound is kept explicit so later
work can plug in the detailed Aasen scalar budget. -/
theorem higham11_15_aasen_chain_source_backward_error_of_components
    (n : ‚Ąē) (A L T U DeltaL DeltaT DeltaU : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (rhs z y w : Fin n ‚Üí ‚ĄĚ) (bound : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hprod : ‚ąÄ i j : Fin n,
      (‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L i p * T p q * U q j) = A i j)
    (hLz : ‚ąÄ i : Fin n,
      ‚ąĎ j : Fin n, (L i j + DeltaL i j) * z j = rhs i)
    (hTy : ‚ąÄ i : Fin n,
      ‚ąĎ j : Fin n, (T i j + DeltaT i j) * y j = z i)
    (hUw : ‚ąÄ i : Fin n,
      ‚ąĎ j : Fin n, (U i j + DeltaU i j) * w j = y i)
    (hbound : ‚ąÄ i j : Fin n,
      |higham11_15_aasenChainDeltaA n L T U DeltaL DeltaT DeltaU i j| ‚Č§
        bound i j) :
    ‚ąÉ DeltaA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |DeltaA i j| ‚Č§ bound i j) ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + DeltaA i j) * w j = rhs i) := by
  let DeltaA := higham11_15_aasenChainDeltaA n L T U DeltaL DeltaT DeltaU
  refine ‚ü®DeltaA, hbound, ?_‚ü©
  intro i
  calc
    ‚ąĎ j : Fin n, (A i j + DeltaA i j) * w j
        = ‚ąĎ j : Fin n,
            (‚ąĎ p : Fin n, ‚ąĎ q : Fin n,
              (L i p + DeltaL i p) * (T p q + DeltaT p q) *
                (U q j + DeltaU q j)) * w j := by
          apply Finset.sum_congr rfl
          intro j _
          congr 1
          unfold DeltaA higham11_15_aasenChainDeltaA
          rw [‚Üź hprod i j]
          ring
    _ = ‚ąĎ p : Fin n,
          (L i p + DeltaL i p) *
            (‚ąĎ q : Fin n, (T p q + DeltaT p q) *
              (‚ąĎ j : Fin n, (U q j + DeltaU q j) * w j)) := by
          simp_rw [Finset.sum_mul, Finset.mul_sum]
          rw [Finset.sum_comm]
          apply Finset.sum_congr rfl
          intro p _
          rw [Finset.sum_comm]
          apply Finset.sum_congr rfl
          intro q _
          ring_nf
    _ = ‚ąĎ p : Fin n,
          (L i p + DeltaL i p) *
            (‚ąĎ q : Fin n, (T p q + DeltaT p q) * y q) := by
          apply Finset.sum_congr rfl
          intro p _
          congr 1
          apply Finset.sum_congr rfl
          intro q _
          rw [hUw q]
    _ = ‚ąĎ p : Fin n, (L i p + DeltaL i p) * z p := by
          apply Finset.sum_congr rfl
          intro p _
          rw [hTy p]
    _ = rhs i := hLz i

/-- **Equation (11.15) rounded source backward-error wrapper**.  This
instantiates the rounded solve-chain component package and the algebraic
collapse theorem.  The only remaining hypothesis is the componentwise budget
for the collapsed chain perturbation `higham11_15_aasenChainDeltaA`; proving
that budget is the next scalar-error aggregation step toward Theorem 11.8. -/
theorem higham11_15_fl_aasen_solve_chain_source_backward_error_of_delta_bound
    (fp : FPModel) (n : ‚Ąē)
    (A Pmat L T L_T_hat U_T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (b : Fin n ‚Üí ‚ĄĚ) (DeltaT_LU bound : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (h20 : higham9_20_tridiag_lu_perturbation_model n T L_T_hat U_T_hat
      DeltaT_LU (gamma fp n))
    (hL_diag : ‚ąÄ i : Fin n, L i i ‚Č† 0)
    (hL_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hT_L_diag : ‚ąÄ i : Fin n, L_T_hat i i ‚Č† 0)
    (hT_U_diag : ‚ąÄ i : Fin n, U_T_hat i i ‚Č† 0)
    (hT_L_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L_T_hat i j = 0)
    (hT_U_upper : ‚ąÄ i j : Fin n, j.val < i.val ‚Üí U_T_hat i j = 0)
    (hn : gammaValid fp n)
    (hprod : ‚ąÄ i j : Fin n,
      (‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L i p * T p q * L j q) = A i j)
    (hbound : ‚ąÄ DeltaL_outer DeltaU_outer DeltaT : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |DeltaL_outer i j| ‚Č§ gamma fp n * |L i j|) ‚Üí
      (‚ąÄ i j : Fin n, |DeltaU_outer i j| ‚Č§ gamma fp n * |L j i|) ‚Üí
      (‚ąÄ i j : Fin n, |DeltaT i j| ‚Č§
        higham9_14_f (gamma fp n) *
          ‚ąĎ k : Fin n, |L_T_hat i k| * |U_T_hat k j|) ‚Üí
      ‚ąÄ i j : Fin n,
        |higham11_15_aasenChainDeltaA n L T (fun r c => L c r)
            DeltaL_outer DeltaT DeltaU_outer i j| ‚Č§ bound i j) :
    let rhs : Fin n ‚Üí ‚ĄĚ := fun i => ‚ąĎ j : Fin n, Pmat i j * b j
    let z_hat := fl_forwardSub fp n L rhs
    let q_hat := fl_forwardSub fp n L_T_hat z_hat
    let y_hat := fl_backSub fp n U_T_hat q_hat
    let U_outer : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun i j => L j i
    let w_hat := fl_backSub fp n U_outer y_hat
    ‚ąÉ DeltaA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |DeltaA i j| ‚Č§ bound i j) ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + DeltaA i j) * w_hat j = rhs i) := by
  intro rhs z_hat q_hat y_hat U_outer w_hat
  obtain ‚ü®DeltaL_outer, DeltaU_outer, _DeltaL_mid, _DeltaU_mid, DeltaT,
      hDeltaL_outer, hDeltaU_outer, hForward_outer, _hMiddle_model,
      hDeltaT_bound, hMiddle_backward, hBack_outer, _hx‚ü© :=
    higham11_15_fl_aasen_solve_chain_backward_error_components
      fp n Pmat L T L_T_hat U_T_hat b DeltaT_LU h20
      hL_diag hL_lower hT_L_diag hT_U_diag hT_L_lower hT_U_upper hn
  exact higham11_15_aasen_chain_source_backward_error_of_components
    n A L T U_outer DeltaL_outer DeltaT DeltaU_outer
    rhs z_hat y_hat w_hat bound
    (by
      intro i j
      simpa [U_outer] using hprod i j)
    hForward_outer hMiddle_backward hBack_outer
    (hbound DeltaL_outer DeltaU_outer DeltaT
      hDeltaL_outer (by simpa [U_outer] using hDeltaU_outer) hDeltaT_bound)

/-- **Equation (11.15) rounded source backward-error theorem**, solve-chain
part.  This instantiates the rounded component package, algebraic collapse,
and closed componentwise `higham11_15_aasenChainDeltaABound` budget.  It is the
solve-chain side of the Aasen Theorem 11.8 backward-error proof; the remaining
global work is to combine this with the factorization/recurrence perturbation
budget and simplify the bound to the printed normwise form. -/
theorem higham11_15_fl_aasen_solve_chain_source_backward_error
    (fp : FPModel) (n : ‚Ąē)
    (A Pmat L T L_T_hat U_T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (b : Fin n ‚Üí ‚ĄĚ) (DeltaT_LU : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (h20 : higham9_20_tridiag_lu_perturbation_model n T L_T_hat U_T_hat
      DeltaT_LU (gamma fp n))
    (hL_diag : ‚ąÄ i : Fin n, L i i ‚Č† 0)
    (hL_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hT_L_diag : ‚ąÄ i : Fin n, L_T_hat i i ‚Č† 0)
    (hT_U_diag : ‚ąÄ i : Fin n, U_T_hat i i ‚Č† 0)
    (hT_L_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L_T_hat i j = 0)
    (hT_U_upper : ‚ąÄ i j : Fin n, j.val < i.val ‚Üí U_T_hat i j = 0)
    (hn : gammaValid fp n)
    (hprod : ‚ąÄ i j : Fin n,
      (‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L i p * T p q * L j q) = A i j) :
    let rhs : Fin n ‚Üí ‚ĄĚ := fun i => ‚ąĎ j : Fin n, Pmat i j * b j
    let z_hat := fl_forwardSub fp n L rhs
    let q_hat := fl_forwardSub fp n L_T_hat z_hat
    let y_hat := fl_backSub fp n U_T_hat q_hat
    let U_outer : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun i j => L j i
    let w_hat := fl_backSub fp n U_outer y_hat
    let BT := higham11_15_aasenMiddleSolveBudget fp n L_T_hat U_T_hat
    let bound := higham11_15_aasenChainDeltaABound n (gamma fp n) BT L T U_outer
    ‚ąÉ DeltaA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |DeltaA i j| ‚Č§ bound i j) ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + DeltaA i j) * w_hat j = rhs i) := by
  intro rhs z_hat q_hat y_hat U_outer w_hat BT bound
  apply higham11_15_fl_aasen_solve_chain_source_backward_error_of_delta_bound
    fp n A Pmat L T L_T_hat U_T_hat b DeltaT_LU bound h20
    hL_diag hL_lower hT_L_diag hT_U_diag hT_L_lower hT_U_upper hn hprod
  intro DeltaL_outer DeltaU_outer DeltaT hDeltaL_outer hDeltaU_outer hDeltaT
  have hBT_nonneg :
      ‚ąÄ p q : Fin n, 0 ‚Č§ higham11_15_aasenMiddleSolveBudget fp n L_T_hat U_T_hat p q := by
    intro p q
    exact mul_nonneg (higham9_14_f_nonneg (gamma_nonneg fp hn))
      (Finset.sum_nonneg
        (fun k _ => mul_nonneg (abs_nonneg _) (abs_nonneg _)))
  have hDeltaT' :
      ‚ąÄ i j : Fin n, |DeltaT i j| ‚Č§
        higham11_15_aasenMiddleSolveBudget fp n L_T_hat U_T_hat i j := by
    intro i j
    simpa [higham11_15_aasenMiddleSolveBudget] using hDeltaT i j
  have hDeltaU' :
      ‚ąÄ i j : Fin n, |DeltaU_outer i j| ‚Č§ gamma fp n * |U_outer i j| := by
    intro i j
    simpa [U_outer] using hDeltaU_outer i j
  intro i j
  simpa [bound, BT, U_outer] using
    higham11_15_aasenChainDeltaA_abs_bound_gamma n L T U_outer
      DeltaL_outer DeltaT DeltaU_outer
      (higham11_15_aasenMiddleSolveBudget fp n L_T_hat U_T_hat)
      (gamma fp n) (gamma_nonneg fp hn) hBT_nonneg
      hDeltaL_outer hDeltaT' hDeltaU' i j

/-- Rounded Aasen source backward-error wrapper that combines factorization
and solve-chain residuals.  The first budget controls the residual
`L_hat*T_hat*L_hatŠĶÄ - A` from relative factor perturbations; the second is the
closed solve-chain budget for solving with the computed factors. -/
theorem higham11_8_fl_aasen_factor_solve_source_backward_error
    (fp : FPModel) (n : ‚Ąē)
    (A Pmat L T L_hat T_hat L_T_hat U_T_hat BT_factor : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (b : Fin n ‚Üí ‚ĄĚ) (DeltaT_LU : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (ő≥_factor : ‚ĄĚ) (hő≥_factor : 0 ‚Č§ ő≥_factor)
    (hBT_factor : ‚ąÄ i j : Fin n, 0 ‚Č§ BT_factor i j)
    (h20 : higham9_20_tridiag_lu_perturbation_model n T_hat L_T_hat U_T_hat
      DeltaT_LU (gamma fp n))
    (hLhat_diag : ‚ąÄ i : Fin n, L_hat i i ‚Č† 0)
    (hLhat_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L_hat i j = 0)
    (hT_L_diag : ‚ąÄ i : Fin n, L_T_hat i i ‚Č† 0)
    (hT_U_diag : ‚ąÄ i : Fin n, U_T_hat i i ‚Č† 0)
    (hT_L_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L_T_hat i j = 0)
    (hT_U_upper : ‚ąÄ i j : Fin n, j.val < i.val ‚Üí U_T_hat i j = 0)
    (hn : gammaValid fp n)
    (hprod : ‚ąÄ i j : Fin n,
      (‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L i p * T p q * L j q) = A i j)
    (hLhat : ‚ąÄ i j : Fin n, |L_hat i j - L i j| ‚Č§ ő≥_factor * |L i j|)
    (hThat : ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ BT_factor i j) :
    let rhs : Fin n ‚Üí ‚ĄĚ := fun i => ‚ąĎ j : Fin n, Pmat i j * b j
    let z_hat := fl_forwardSub fp n L_hat rhs
    let q_hat := fl_forwardSub fp n L_T_hat z_hat
    let y_hat := fl_backSub fp n U_T_hat q_hat
    let U_outer : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun i j => L_hat j i
    let w_hat := fl_backSub fp n U_outer y_hat
    let BT_solve := higham11_15_aasenMiddleSolveBudget fp n L_T_hat U_T_hat
    let B_factor :=
      higham11_15_aasenChainDeltaABound n ő≥_factor BT_factor L T (fun r c => L c r)
    let B_solve :=
      higham11_15_aasenChainDeltaABound n (gamma fp n) BT_solve L_hat T_hat U_outer
    ‚ąÉ DeltaA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |DeltaA i j| ‚Č§ B_factor i j + B_solve i j) ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + DeltaA i j) * w_hat j = rhs i) := by
  intro rhs z_hat q_hat y_hat U_outer w_hat BT_solve B_factor B_solve
  let A_fact : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ :=
    fun i j => ‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L_hat i p * T_hat p q * L_hat j q
  have hprod_fact : ‚ąÄ i j : Fin n,
      (‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L_hat i p * T_hat p q * L_hat j q) =
        A_fact i j := by
    intro i j
    rfl
  obtain ‚ü®DeltaS, hDeltaS, hsource‚ü© :=
    higham11_15_fl_aasen_solve_chain_source_backward_error
      fp n A_fact Pmat L_hat T_hat L_T_hat U_T_hat b DeltaT_LU h20
      hLhat_diag hLhat_lower hT_L_diag hT_U_diag hT_L_lower hT_U_upper hn
      hprod_fact
  apply higham11_8_aasen_source_backward_error_of_factor_and_solve_residuals
    n A A_fact DeltaS B_factor B_solve rhs w_hat
  ¬∑ intro i j
    simpa [A_fact, B_factor] using
      higham11_8_aasen_factorization_product_abs_bound_gamma
        n A L T L_hat T_hat BT_factor ő≥_factor hő≥_factor hBT_factor
        hprod hLhat hThat i j
  ¬∑ exact hDeltaS
  ¬∑ exact hsource

/-- Rounded Aasen source backward-error wrapper from source-prefix recurrence
updates.  This removes the standalone relative `L_hat` hypothesis from
`higham11_8_fl_aasen_factor_solve_source_backward_error`: the factorization
residual is supplied directly by the rounded source-prefix next-column update
bridge, while the concrete middle-factor budget for `T_hat` remains explicit. -/
theorem higham11_8_fl_aasen_factor_solve_source_backward_error_of_source_prefix_updates
    (fp : FPModel) (n : ‚Ąē)
    (A Pmat L H T L_hat T_hat L_T_hat U_T_hat BT_factor :
      Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (b : Fin n ‚Üí ‚ĄĚ) (DeltaT_LU : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (ő≥_factor : ‚ĄĚ) (hő≥_factor : 0 ‚Č§ ő≥_factor)
    (hBT_factor : ‚ąÄ i j : Fin n, 0 ‚Č§ BT_factor i j)
    (hrec : higham11_14_aasenNextColumnEquation n A L H)
    (hHnz : ‚ąÄ i next : Fin n, next.val = i.val + 1 ‚Üí H next i ‚Č† 0)
    (hvalSum : ‚ąÄ i next : Fin n, next.val = i.val + 1 ‚Üí
      gammaValid fp next.val)
    (hvalUpdate : gammaValid fp 2)
    (hLhat_update : ‚ąÄ i next k : Fin n, next.val = i.val + 1 ‚Üí
      i.val + 2 ‚Č§ k.val ‚Üí
      L_hat k next =
        fp.fl_div
          (fp.fl_sub (A k i)
            (higham11_14_fl_aasenSourcePrefixDot n fp L H i next k))
          (H next i))
    (hLhat_fixed_successor : ‚ąÄ i next k : Fin n, next.val = i.val + 1 ‚Üí
      ¬¨ i.val + 2 ‚Č§ k.val ‚Üí L_hat k next = L k next)
    (hLhat_fixed_other : ‚ąÄ k j : Fin n,
      (‚ąÄ i : Fin n, j.val ‚Č† i.val + 1) ‚Üí L_hat k j = L k j)
    (hbudget_rel : ‚ąÄ i next : Fin n, next.val = i.val + 1 ‚Üí
      ‚ąÄ k : Fin n, i.val + 2 ‚Č§ k.val ‚Üí
      let Bsum : ‚ĄĚ :=
        gamma fp next.val *
          ‚ąĎ j : Fin next.val,
            |L k ‚ü®j.val, Nat.lt_trans j.isLt next.isLt‚ü©| *
              |H ‚ü®j.val, Nat.lt_trans j.isLt next.isLt‚ü© i|
      Bsum / |H next i| +
          gamma fp 2 * (|L k next| + Bsum / |H next i|)
        ‚Č§ ő≥_factor * |L k next|)
    (h20 : higham9_20_tridiag_lu_perturbation_model n T_hat L_T_hat U_T_hat
      DeltaT_LU (gamma fp n))
    (hLhat_diag : ‚ąÄ i : Fin n, L_hat i i ‚Č† 0)
    (hLhat_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L_hat i j = 0)
    (hT_L_diag : ‚ąÄ i : Fin n, L_T_hat i i ‚Č† 0)
    (hT_U_diag : ‚ąÄ i : Fin n, U_T_hat i i ‚Č† 0)
    (hT_L_lower : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L_T_hat i j = 0)
    (hT_U_upper : ‚ąÄ i j : Fin n, j.val < i.val ‚Üí U_T_hat i j = 0)
    (hn : gammaValid fp n)
    (hprod : ‚ąÄ i j : Fin n,
      (‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L i p * T p q * L j q) = A i j)
    (hThat : ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ BT_factor i j) :
    let rhs : Fin n ‚Üí ‚ĄĚ := fun i => ‚ąĎ j : Fin n, Pmat i j * b j
    let z_hat := fl_forwardSub fp n L_hat rhs
    let q_hat := fl_forwardSub fp n L_T_hat z_hat
    let y_hat := fl_backSub fp n U_T_hat q_hat
    let U_outer : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun i j => L_hat j i
    let w_hat := fl_backSub fp n U_outer y_hat
    let BT_solve := higham11_15_aasenMiddleSolveBudget fp n L_T_hat U_T_hat
    let B_factor :=
      higham11_15_aasenChainDeltaABound n ő≥_factor BT_factor L T (fun r c => L c r)
    let B_solve :=
      higham11_15_aasenChainDeltaABound n (gamma fp n) BT_solve L_hat T_hat U_outer
    ‚ąÉ DeltaA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |DeltaA i j| ‚Č§ B_factor i j + B_solve i j) ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + DeltaA i j) * w_hat j = rhs i) := by
  intro rhs z_hat q_hat y_hat U_outer w_hat BT_solve B_factor B_solve
  let A_fact : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ :=
    fun i j => ‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L_hat i p * T_hat p q * L_hat j q
  have hprod_fact : ‚ąÄ i j : Fin n,
      (‚ąĎ p : Fin n, ‚ąĎ q : Fin n, L_hat i p * T_hat p q * L_hat j q) =
        A_fact i j := by
    intro i j
    rfl
  obtain ‚ü®DeltaS, hDeltaS, hsource‚ü© :=
    higham11_15_fl_aasen_solve_chain_source_backward_error
      fp n A_fact Pmat L_hat T_hat L_T_hat U_T_hat b DeltaT_LU h20
      hLhat_diag hLhat_lower hT_L_diag hT_U_diag hT_L_lower hT_U_upper hn
      hprod_fact
  apply higham11_8_aasen_source_backward_error_of_factor_and_solve_residuals
    n A A_fact DeltaS B_factor B_solve rhs w_hat
  ¬∑ intro i j
    simpa [A_fact, B_factor] using
      higham11_8_aasen_factorization_product_abs_bound_of_source_prefix_updates
        n fp A L H T L_hat T_hat BT_factor ő≥_factor hő≥_factor hBT_factor
        hrec hHnz hvalSum hvalUpdate hLhat_update hLhat_fixed_successor
        hLhat_fixed_other hbudget_rel hprod hThat i j
  ¬∑ exact hDeltaS
  ¬∑ exact hsource

/-- **Equation (11.15) exact solve-chain bridge**, unpermuted case.  If the
exact Aasen product is `A = L T LŠĶÄ` and the three exact solves in the chain are
satisfied with identity permutation, then the resulting `x` solves `A x = b`.
This is the algebraic base that the later rounded solve-chain perturbation must
approximate. -/
theorem higham11_15_aasenSolveChain_identity_solve_of_product (n : ‚Ąē)
    (A L T : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (b z y w x : Fin n ‚Üí ‚ĄĚ)
    (hprod : ‚ąÄ i j : Fin n,
      (‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n, L i k‚āĀ * T k‚āĀ k‚āā * L j k‚āā) = A i j)
    (hchain : higham11_15_aasenSolveChain n (fun i j => if i = j then 1 else 0)
      L T b z y w x) :
    ‚ąÄ i : Fin n, ‚ąĎ j : Fin n, A i j * x j = b i := by
  rcases hchain with ‚ü®hLz, hTy, hLtw, hx‚ü©
  have hLz' : ‚ąÄ i : Fin n, ‚ąĎ j : Fin n, L i j * z j = b i := by
    intro i
    simpa using hLz i
  have hx' : ‚ąÄ i : Fin n, x i = w i := by
    intro i
    simpa using hx i
  intro i
  calc
    ‚ąĎ j : Fin n, A i j * x j
        = ‚ąĎ j : Fin n,
            (‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n, L i k‚āĀ * T k‚āĀ k‚āā * L j k‚āā) * w j := by
          apply Finset.sum_congr rfl
          intro j _
          rw [‚Üź hprod i j, hx' j]
    _ = ‚ąĎ k‚āĀ : Fin n,
          L i k‚āĀ * (‚ąĎ k‚āā : Fin n, T k‚āĀ k‚āā * (‚ąĎ j : Fin n, L j k‚āā * w j)) := by
          simp_rw [Finset.sum_mul, Finset.mul_sum]
          rw [Finset.sum_comm]
          apply Finset.sum_congr rfl
          intro k‚āĀ _
          rw [Finset.sum_comm]
          apply Finset.sum_congr rfl
          intro k‚āā _
          ring_nf
    _ = ‚ąĎ k‚āĀ : Fin n, L i k‚āĀ * (‚ąĎ k‚āā : Fin n, T k‚āĀ k‚āā * y k‚āā) := by
          apply Finset.sum_congr rfl
          intro k‚āĀ _
          congr 1
          apply Finset.sum_congr rfl
          intro k‚āā _
          rw [hLtw k‚āā]
    _ = ‚ąĎ k‚āĀ : Fin n, L i k‚āĀ * z k‚āĀ := by
          apply Finset.sum_congr rfl
          intro k‚āĀ _
          rw [hTy k‚āĀ]
    _ = b i := hLz' i

/-- **Theorem 11.8** componentwise Aasen backward-error target shape. -/
theorem higham11_8_aasen_backward_error_interface (n : ‚Ąē)
    (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (b x_hat : Fin n ‚Üí ‚ĄĚ)
    (bound : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hsolve : ‚ąÉ őĒA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |őĒA i j| ‚Č§ bound i j) ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + őĒA i j) * x_hat j = b i)) :
    ‚ąÉ őĒA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |őĒA i j| ‚Č§ bound i j) ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + őĒA i j) * x_hat j = b i) :=
  hsolve

/-- **Theorem 11.8** normwise Aasen bound
`||Delta A||_inf <= (n-1)^2 gamma_(15n+25) ||T_hat||_inf`. -/
def higham11_8_aasenNormwiseBackwardBound
    (n : ‚Ąē) (őĒA_inf ő≥15n25 T_inf : ‚ĄĚ) : Prop :=
  őĒA_inf ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 * ő≥15n25 * T_inf

/-- Uniform componentwise perturbation bounds imply an infinity-norm bound.
This is the row-sum bridge used when converting componentwise backward-error
estimates into the normwise shape of Theorem 11.8. -/
theorem higham11_8_infNorm_le_card_mul_of_uniform_componentwise_bound (n : ‚Ąē)
    (őĒA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≤ : ‚ĄĚ) (hő≤ : 0 ‚Č§ ő≤)
    (hőĒ : ‚ąÄ i j : Fin n, |őĒA i j| ‚Č§ ő≤) :
    infNorm őĒA ‚Č§ (n : ‚ĄĚ) * ő≤ := by
  apply infNorm_le_of_row_sum_le
  ¬∑ intro i
    calc (‚ąĎ j : Fin n, |őĒA i j|)
        ‚Č§ ‚ąĎ _j : Fin n, ő≤ := Finset.sum_le_sum (fun j _ => hőĒ i j)
      _ = (n : ‚ĄĚ) * ő≤ := by
        simp [Finset.sum_const, nsmul_eq_mul]
  ¬∑ exact mul_nonneg (Nat.cast_nonneg n) hő≤

/-- Direct bridge into the printed Theorem 11.8 normwise predicate from a
uniform componentwise perturbation bound and a scalar row-sum budget. -/
theorem higham11_8_aasenNormwiseBackwardBound_of_uniform_componentwise_bound
    (n : ‚Ąē) (őĒA : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≤ ő≥15n25 T_inf : ‚ĄĚ)
    (hő≤ : 0 ‚Č§ ő≤) (hőĒ : ‚ąÄ i j : Fin n, |őĒA i j| ‚Č§ ő≤)
    (hbudget : (n : ‚ĄĚ) * ő≤ ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 * ő≥15n25 * T_inf) :
    higham11_8_aasenNormwiseBackwardBound n (infNorm őĒA) ő≥15n25 T_inf :=
  (higham11_8_infNorm_le_card_mul_of_uniform_componentwise_bound n őĒA ő≤ hő≤ hőĒ).trans
    hbudget

/-- Relative componentwise perturbation bounds against the computed Aasen
tridiagonal factor imply the corresponding infinity-norm relative bound. -/
theorem higham11_8_infNorm_le_mul_of_componentwise_T_bound (n : ‚Ąē)
    (őĒA T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő∑ : ‚ĄĚ) (hő∑ : 0 ‚Č§ ő∑)
    (hőĒ : ‚ąÄ i j : Fin n, |őĒA i j| ‚Č§ ő∑ * |T_hat i j|) :
    infNorm őĒA ‚Č§ ő∑ * infNorm T_hat :=
  by
    apply infNorm_le_of_row_sum_le
    ¬∑ intro i
      calc ‚ąĎ j : Fin n, |őĒA i j|
          ‚Č§ ‚ąĎ j : Fin n, ő∑ * |T_hat i j| :=
            Finset.sum_le_sum (fun j _ => hőĒ i j)
        _ = ő∑ * ‚ąĎ j : Fin n, |T_hat i j| := (Finset.mul_sum ..).symm
        _ ‚Č§ ő∑ * infNorm T_hat :=
            mul_le_mul_of_nonneg_left (row_sum_le_infNorm T_hat i) hő∑
    ¬∑ exact mul_nonneg hő∑ (infNorm_nonneg T_hat)

/-- The source-style relative `T_hat - T` comparison gives the corresponding
infinity-norm perturbation budget for the actual middle-factor difference. -/
theorem higham11_8_infNorm_T_hat_sub_T_le_mul_of_relative_error (n : ‚Ąē)
    (T T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥)
    (hThat : ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ ő≥ * |T_hat i j|) :
    infNorm (fun i j : Fin n => T_hat i j - T i j) ‚Č§ ő≥ * infNorm T_hat :=
  higham11_8_infNorm_le_mul_of_componentwise_T_bound n
    (fun i j : Fin n => T_hat i j - T i j) T_hat ő≥ hő≥ hThat

/-- A relative componentwise `T_hat - T` comparison gives the entrywise
`(1+ő≥)` domination of the exact middle factor by the computed one.  This is the
entrywise diagnostic behind the weaker norm cap below. -/
theorem higham11_8_abs_T_le_one_plus_gamma_T_hat_of_relative_error (n : ‚Ąē)
    (T T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ : ‚ĄĚ) (_hő≥ : 0 ‚Č§ ő≥)
    (hThat : ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ ő≥ * |T_hat i j|) :
    ‚ąÄ i j : Fin n, |T i j| ‚Č§ (1 + ő≥) * |T_hat i j| := by
  intro i j
  have hrewrite : T i j = T_hat i j + (-(T_hat i j - T i j)) := by ring
  calc
    |T i j| = |T_hat i j + (-(T_hat i j - T i j))| :=
      congrArg (fun x : ‚ĄĚ => |x|) hrewrite
    _ ‚Č§ |T_hat i j| + |-(T_hat i j - T i j)| := abs_add_le _ _
    _ = |T_hat i j| + |T_hat i j - T i j| := by rw [abs_neg]
    _ ‚Č§ |T_hat i j| + ő≥ * |T_hat i j| := by linarith [hThat i j]
    _ = (1 + ő≥) * |T_hat i j| := by ring

/-- The concrete envelope `ő≥ |T_hat|` used as a middle-factor budget has
infinity norm at most `ő≥ ‚ÄĖT_hat‚ÄĖ‚ąě` when `ő≥` is nonnegative. -/
theorem higham11_8_infNorm_scaled_abs_T_hat_le (n : ‚Ąē)
    (T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥) :
    infNorm (fun i j : Fin n => ő≥ * |T_hat i j|) ‚Č§ ő≥ * infNorm T_hat := by
  apply higham11_8_infNorm_le_mul_of_componentwise_T_bound n
    (fun i j : Fin n => ő≥ * |T_hat i j|) T_hat ő≥ hő≥
  intro i j
  have hnonneg : 0 ‚Č§ ő≥ * |T_hat i j| := mul_nonneg hő≥ (abs_nonneg _)
  rw [abs_of_nonneg hnonneg]

/-- A relative componentwise `T_hat - T` comparison also bounds the exact
middle-factor norm by `(1+ő≥) ‚ÄĖT_hat‚ÄĖ‚ąě`.  This is weaker than the direct
`‚ÄĖT‚ÄĖ‚ąě ‚Č§ ‚ÄĖT_hat‚ÄĖ‚ąě` cap needed by the exact-radius source endpoint, but records
the norm consequence available from the relative error statement alone. -/
theorem higham11_8_infNorm_T_le_one_plus_gamma_T_hat_of_relative_error (n : ‚Ąē)
    (T T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥)
    (hThat : ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ ő≥ * |T_hat i j|) :
    infNorm T ‚Č§ (1 + ő≥) * infNorm T_hat := by
  have hscale : 0 ‚Č§ 1 + ő≥ := by linarith
  exact higham11_8_infNorm_le_mul_of_componentwise_T_bound n T T_hat
    (1 + ő≥) hscale
    (higham11_8_abs_T_le_one_plus_gamma_T_hat_of_relative_error
      n T T_hat ő≥ hő≥ hThat)

/-- Zero relative `T_hat - T` error recovers the coefficient-one componentwise
domination of the exact middle factor by the computed one. -/
theorem higham11_8_abs_T_le_T_hat_of_zero_relative_error (n : ‚Ąē)
    (T T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hThat : ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ 0 * |T_hat i j|) :
    ‚ąÄ i j : Fin n, |T i j| ‚Č§ |T_hat i j| := by
  simpa using
    higham11_8_abs_T_le_one_plus_gamma_T_hat_of_relative_error
      n T T_hat 0 (by norm_num) hThat

/-- Zero relative `T_hat - T` error also gives the coefficient-one infinity-norm
cap `‚ÄĖT‚ÄĖ‚ąě ‚Č§ ‚ÄĖT_hat‚ÄĖ‚ąě`. -/
theorem higham11_8_infNorm_T_le_T_hat_of_zero_relative_error (n : ‚Ąē)
    (T T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hThat : ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ 0 * |T_hat i j|) :
    infNorm T ‚Č§ infNorm T_hat := by
  simpa using
    higham11_8_infNorm_T_le_one_plus_gamma_T_hat_of_relative_error
      n T T_hat 0 (by norm_num) hThat

/-- Componentwise absolute domination transfers directly to the matrix
infinity norm. -/
theorem higham11_8_infNorm_le_of_componentwise_abs_bound (n : ‚Ąē)
    (A B : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hAB : ‚ąÄ i j : Fin n, |A i j| ‚Č§ |B i j|) :
    infNorm A ‚Č§ infNorm B := by
  simpa using
    higham11_8_infNorm_le_mul_of_componentwise_T_bound n A B 1
      (by norm_num) (fun i j => by simpa using hAB i j)

/-- A relative `(1+ő≥)` infinity-norm cap implies the corresponding unscaled
cap when `ő≥ ‚Č• 0`. -/
theorem higham11_8_infNorm_cap_of_relative_infNorm_cap (n : ‚Ąē)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ cap : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥)
    (hrel : (1 + ő≥) * infNorm M ‚Č§ cap) :
    infNorm M ‚Č§ cap := by
  have hscale : infNorm M ‚Č§ (1 + ő≥) * infNorm M := by
    have h1ő≥ : 1 ‚Č§ 1 + ő≥ := by linarith
    calc
      infNorm M = 1 * infNorm M := by ring
      _ ‚Č§ (1 + ő≥) * infNorm M :=
        mul_le_mul_of_nonneg_right h1ő≥ (infNorm_nonneg M)
  exact hscale.trans hrel

/-- Per-row scaled row-sum caps imply the corresponding relative
`(1+ő≥)` infinity-norm cap. -/
theorem higham11_8_relative_infNorm_cap_of_row_sum_caps (n : ‚Ąē)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ cap : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥) (hcap : 0 ‚Č§ cap)
    (hrows : ‚ąÄ i : Fin n, (1 + ő≥) * (‚ąĎ j : Fin n, |M i j|) ‚Č§ cap) :
    (1 + ő≥) * infNorm M ‚Č§ cap := by
  have hscale_pos : 0 < 1 + ő≥ := by linarith
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := le_of_lt hscale_pos
  have hrows_div : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |M i j|) ‚Č§ cap / (1 + ő≥) := by
    intro i
    exact (le_div_iff‚āÄ hscale_pos).mpr (by simpa [mul_comm] using hrows i)
  have hinf : infNorm M ‚Č§ cap / (1 + ő≥) := by
    apply infNorm_le_of_row_sum_le
    ¬∑ intro i
      exact hrows_div i
    ¬∑ exact div_nonneg hcap hscale_nonneg
  calc
    (1 + ő≥) * infNorm M ‚Č§ (1 + ő≥) * (cap / (1 + ő≥)) :=
      mul_le_mul_of_nonneg_left hinf hscale_nonneg
    _ = cap := by
      field_simp [ne_of_gt hscale_pos]

/-- Unscaled row-sum majorants plus a scalar scale comparison imply the
relative `(1+ő≥)` infinity-norm cap used by the Aasen exact-radius route. -/
theorem higham11_8_relative_infNorm_cap_of_row_sum_majorant (n : ‚Ąē)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hcap : 0 ‚Č§ cap)
    (hőļcap : (1 + ő≥) * őļ ‚Č§ cap)
    (hrows : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |M i j|) ‚Č§ őļ) :
    (1 + ő≥) * infNorm M ‚Č§ cap := by
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := by linarith
  apply higham11_8_relative_infNorm_cap_of_row_sum_caps n M ő≥ cap hő≥ hcap
  intro i
  exact (mul_le_mul_of_nonneg_left (hrows i) hscale_nonneg).trans hőļcap

/-- Row and column sum majorants for the exact Aasen outer factor feed the two
relative norm caps required for the source-prefix exact-radius wrappers. -/
theorem higham11_8_relative_outer_factor_caps_of_row_col_sum_majorants (n : ‚Ąē)
    (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļrow őļcol cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hcap : 0 ‚Č§ cap)
    (hőļrow : (1 + ő≥) * őļrow ‚Č§ cap)
    (hőļcol : (1 + ő≥) * őļcol ‚Č§ cap)
    (hrows : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |L i j|) ‚Č§ őļrow)
    (hcols : ‚ąÄ j : Fin n, (‚ąĎ i : Fin n, |L i j|) ‚Č§ őļcol) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap := by
  constructor
  ¬∑ exact
      higham11_8_relative_infNorm_cap_of_row_sum_majorant
        n L ő≥ őļrow cap hő≥ hcap hőļrow hrows
  ¬∑ exact
      higham11_8_relative_infNorm_cap_of_row_sum_majorant
        n (fun r c => L c r) ő≥ őļcol cap hő≥ hcap hőļcol
        (fun r => by simpa using hcols r)

/-- Uniform entrywise majorants for the exact Aasen outer factor imply the
row/column majorants, and hence the two relative norm caps, after one scalar
scale comparison. -/
theorem higham11_8_relative_outer_factor_caps_of_entrywise_majorant (n : ‚Ąē)
    (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : 0 ‚Č§ őļ)
    (hőļcap : (1 + ő≥) * ((n : ‚ĄĚ) * őļ) ‚Č§ cap)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap := by
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := by linarith
  have hrow_majorant_nonneg : 0 ‚Č§ (n : ‚ĄĚ) * őļ :=
    mul_nonneg (Nat.cast_nonneg n) hőļ
  have hcap : 0 ‚Č§ cap :=
    (mul_nonneg hscale_nonneg hrow_majorant_nonneg).trans hőļcap
  have hrows : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |L i j|) ‚Č§ (n : ‚ĄĚ) * őļ := by
    intro i
    calc
      (‚ąĎ j : Fin n, |L i j|) ‚Č§ ‚ąĎ _j : Fin n, őļ :=
        Finset.sum_le_sum (fun j _ => hentry i j)
      _ = (n : ‚ĄĚ) * őļ := by simp [Finset.sum_const, nsmul_eq_mul]
  have hcols : ‚ąÄ j : Fin n, (‚ąĎ i : Fin n, |L i j|) ‚Č§ (n : ‚ĄĚ) * őļ := by
    intro j
    calc
      (‚ąĎ i : Fin n, |L i j|) ‚Č§ ‚ąĎ _i : Fin n, őļ :=
        Finset.sum_le_sum (fun i _ => hentry i j)
      _ = (n : ‚ĄĚ) * őļ := by simp [Finset.sum_const, nsmul_eq_mul]
  exact
    higham11_8_relative_outer_factor_caps_of_row_col_sum_majorants
      n L ő≥ ((n : ‚ĄĚ) * őļ) ((n : ‚ĄĚ) * őļ) cap
      hő≥ hcap hőļcap hőļcap hrows hcols

/-- If one entry of a uniformly bounded `Fin n` family is known to vanish, the
full absolute sum is bounded by `(n-1)` copies of the uniform entry bound. -/
theorem higham11_8_sum_abs_le_card_pred_mul_of_one_zero {n : ‚Ąē}
    (v : Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ k : Fin n, |v k| ‚Č§ őļ) (z : Fin n) (hz : v z = 0) :
    (‚ąĎ k : Fin n, |v k|) ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ := by
  calc
    (‚ąĎ k : Fin n, |v k|) =
        Finset.sum (Finset.univ.erase z) (fun k => |v k|) := by
      rw [‚Üź Finset.sum_erase_add (s := (Finset.univ : Finset (Fin n)))
        (a := z) (f := fun k => |v k|) (Finset.mem_univ z)]
      simp [hz]
    _ ‚Č§ Finset.sum (Finset.univ.erase z) (fun _k : Fin n => őļ) := by
      apply Finset.sum_le_sum
      intro k _hk
      exact hentry k
    _ = ((Finset.univ.erase z).card : ‚ĄĚ) * őļ := by
      simp [Finset.sum_const, nsmul_eq_mul]
    _ = ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ := by
      rw [Finset.card_erase_of_mem (Finset.mem_univ z), Finset.card_univ,
        Fintype.card_fin]

/-- Aasen's exact outer factor structure upgrades a uniform entry majorant to
`(n-1)` row and column sum majorants: every row and every column has at least
one forced zero entry. -/
theorem higham11_8_aasen_outer_factor_row_col_sum_majorants_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |L i j|) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚ąß
      (‚ąÄ j : Fin n, (‚ąĎ i : Fin n, |L i j|) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) := by
  constructor
  ¬∑ intro i
    by_cases hi0 : i.val = 0
    ¬∑ let z : Fin n := ‚ü®1, hn‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun j => L i j) őļ (fun j => hentry i j) z
          (hstrictUpperZero i z (by dsimp [z]; omega))
    ¬∑ let z : Fin n := ‚ü®0, by omega‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun j => L i j) őļ (fun j => hentry i j) z
          (hfirstColZero i z (by dsimp [z]) hi0)
  ¬∑ intro j
    by_cases hj0 : j.val = 0
    ¬∑ let z : Fin n := ‚ü®1, hn‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun i => L i j) őļ (fun i => hentry i j) z
          (hfirstColZero z j hj0 (by dsimp [z]; omega))
    ¬∑ let z : Fin n := ‚ü®0, by omega‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun i => L i j) őļ (fun i => hentry i j) z
          (hstrictUpperZero z j (by dsimp [z]; omega))

/-- Source-specific Aasen outer-factor structure feeds the exact-radius relative
factor norm caps with `(n-1)` copies of a uniform exact-factor entry bound,
rather than the fallback `n` copies. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound (n : ‚Ąē)
    (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : 0 ‚Č§ őļ)
    (hőļcap : (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ cap)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap := by
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := by linarith
  have hmajor_nonneg : 0 ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ :=
    mul_nonneg (Nat.cast_nonneg (n - 1)) hőļ
  have hcap : 0 ‚Č§ cap :=
    (mul_nonneg hscale_nonneg hmajor_nonneg).trans hőļcap
  rcases
    higham11_8_aasen_outer_factor_row_col_sum_majorants_of_entry_bound
      n hn L őļ hentry hstrictUpperZero hfirstColZero with
    ‚ü®hrows, hcols‚ü©
  exact
    higham11_8_relative_outer_factor_caps_of_row_col_sum_majorants
      n L ő≥ (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) cap
      hő≥ hcap hőļcap hőļcap hrows hcols

/-- Scalar scale comparison for the Aasen `(n-1)` outer-factor route.  A
normalized entry bound `(1+ő≥)őļ‚Č§1` implies the row/column cap
`(1+ő≥)((n-1)őļ)‚Č§n-1` consumed by the exact-radius wrappers. -/
theorem higham11_8_aasen_outer_factor_scaled_entry_cap (n : ‚Ąē) (ő≥ őļ : ‚ĄĚ)
    (hőļunit : (1 + ő≥) * őļ ‚Č§ 1) :
    (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) := by
  have hcard : 0 ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) := Nat.cast_nonneg (n - 1)
  calc
    (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ)
        = ((n - 1 : ‚Ąē) : ‚ĄĚ) * ((1 + ő≥) * őļ) := by ring
    _ ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) * 1 :=
      mul_le_mul_of_nonneg_left hőļunit hcard
    _ = ((n - 1 : ‚Ąē) : ‚ĄĚ) := by ring

/-- Scalar bridge from the common source-style inverse scale hypothesis to the
normalized Aasen exact-factor entry cap. -/
theorem higham11_8_one_plus_mul_le_one_of_le_inv_one_plus (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : őļ ‚Č§ 1 / (1 + ő≥)) :
    (1 + ő≥) * őļ ‚Č§ 1 := by
  have hpos : 0 < 1 + ő≥ := by linarith
  calc
    (1 + ő≥) * őļ ‚Č§ (1 + ő≥) * (1 / (1 + ő≥)) :=
      mul_le_mul_of_nonneg_left hőļ (le_of_lt hpos)
    _ = 1 := by field_simp [ne_of_gt hpos]

/-- Aasen `(n-1)` outer-factor scale cap from the source-style bound
`őļ‚Č§1/(1+ő≥)`. -/
theorem higham11_8_aasen_outer_factor_scaled_entry_cap_of_le_inv_one_plus
    (n : ‚Ąē) (ő≥ őļ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥)
    (hőļ : őļ ‚Č§ 1 / (1 + ő≥)) :
    (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) :=
  higham11_8_aasen_outer_factor_scaled_entry_cap n ő≥ őļ
    (higham11_8_one_plus_mul_le_one_of_le_inv_one_plus ő≥ őļ hő≥ hőļ)

/-- Aasen outer-factor relative caps from a normalized uniform entry bound.
This factors the remaining source scalar comparison for the exact-radius route:
after proving `(1+ő≥)őļ‚Č§1` for the concrete Aasen factor entries, the strict
upper-zero and first-column-zero structure supplies both relative norm caps with
the printed `(n-1)` radius. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : 0 ‚Č§ őļ)
    (hőļunit : (1 + ő≥) * őļ ‚Č§ 1)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) := by
  exact
    higham11_8_relative_outer_factor_caps_of_aasen_entry_bound
      n hn L ő≥ őļ ((n - 1 : ‚Ąē) : ‚ĄĚ) hő≥ hőļ
      (higham11_8_aasen_outer_factor_scaled_entry_cap n ő≥ őļ hőļunit)
      hentry hstrictUpperZero hfirstColZero

/-- Aasen outer-factor relative caps from a source-style inverse-scale uniform
entry bound.  This is the same result as the normalized route, with
`őļ‚Č§1/(1+ő≥)` supplying the normalized scalar cap. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_inv_one_plus
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļnonneg : 0 ‚Č§ őļ) (hőļ : őļ ‚Č§ 1 / (1 + ő≥))
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) :=
  higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit
    n hn L ő≥ őļ hő≥ hőļnonneg
    (higham11_8_one_plus_mul_le_one_of_le_inv_one_plus ő≥ őļ hő≥ hőļ)
    hentry hstrictUpperZero hfirstColZero

/-- A uniform absolute entry bound over a nonempty matrix supplies
nonnegativity of the bound. -/
theorem higham11_8_nonneg_of_uniform_abs_entry_bound (n : ‚Ąē) (hn : 0 < n)
    (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ) :
    0 ‚Č§ őļ :=
  (abs_nonneg (L ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)).trans
    (hentry ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)

/-- Generic entrywise-majorant outer-factor caps, deriving `0‚Č§őļ` from the
nonempty uniform absolute entry bound itself. -/
theorem higham11_8_relative_outer_factor_caps_of_entrywise_majorant_of_entry_bound
    (n : ‚Ąē) (hn : 0 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥)
    (hőļcap : (1 + ő≥) * ((n : ‚ĄĚ) * őļ) ‚Č§ cap)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap :=
  higham11_8_relative_outer_factor_caps_of_entrywise_majorant
    n L ő≥ őļ cap hő≥
    (higham11_8_nonneg_of_uniform_abs_entry_bound n hn L őļ hentry)
    hőļcap hentry

/-- Aasen-structure outer-factor caps with an arbitrary scalar cap, deriving
`0‚Č§őļ` from the nonempty uniform absolute entry bound itself. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥)
    (hőļcap : (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ cap)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap :=
  higham11_8_relative_outer_factor_caps_of_aasen_entry_bound
    n hn L ő≥ őļ cap hő≥
    (higham11_8_nonneg_of_uniform_abs_entry_bound n
      (Nat.lt_trans Nat.zero_lt_one hn) L őļ hentry)
    hőļcap hentry hstrictUpperZero hfirstColZero

/-- Aasen outer-factor relative caps from a normalized uniform entry bound,
deriving `0‚Č§őļ` from the absolute entry bound itself. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļunit : (1 + ő≥) * őļ ‚Č§ 1)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) :=
  higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit
    n hn L ő≥ őļ hő≥
    (higham11_8_nonneg_of_uniform_abs_entry_bound n
      (Nat.lt_trans Nat.zero_lt_one hn) L őļ hentry)
    hőļunit hentry hstrictUpperZero hfirstColZero

/-- Unscaled exact outer-factor norm caps from a normalized uniform entry bound,
deriving `0‚Č§őļ` from the absolute entry bound itself. -/
theorem higham11_8_outer_factor_caps_of_aasen_entry_bound_scaled_unit_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļunit : (1 + ő≥) * őļ ‚Č§ 1)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    infNorm L ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ‚ąß
      infNorm (fun r c => L c r) ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) := by
  rcases
      higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit_of_entry_bound
        n hn L ő≥ őļ hő≥ hőļunit hentry hstrictUpperZero hfirstColZero with
    ‚ü®hrelL, hrelLT‚ü©
  exact
    ‚ü®higham11_8_infNorm_cap_of_relative_infNorm_cap n L ő≥
        ((n - 1 : ‚Ąē) : ‚ĄĚ) hő≥ hrelL,
