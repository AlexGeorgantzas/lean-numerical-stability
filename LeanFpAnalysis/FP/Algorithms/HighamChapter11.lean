/-- **Theorem 11.4 regional `|LŐā|` entry-to-row-sum split**.  If the
first-stage and recursive trailing regions provide entry caps, their
cardinality-scaled versions supply the row-sum split used by the product
pipeline. -/
theorem higham11_4_L_row_sum_bound_of_first_stage_recursive_split_entry_bounds
    (n s : ‚Ąē) (L_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (Lmax localL recL : ‚ĄĚ)
    (hlocal_le : (n : ‚ĄĚ) * localL ‚Č§ Lmax)
    (hrec_le : (n : ‚ĄĚ) * recL ‚Č§ Lmax)
    (hfirst : ‚ąÄ r k : Fin n, r.val < s ‚Üí |L_hat r k| ‚Č§ localL)
    (htrail : ‚ąÄ r k : Fin n, s ‚Č§ r.val ‚Üí |L_hat r k| ‚Č§ recL) :
    ‚ąÄ r : Fin n, (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ Lmax := by
  intro r
  by_cases hr : r.val < s
  ¬∑ calc
      (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ ‚ąĎ _k : Fin n, localL := by
        exact Finset.sum_le_sum (fun k _ => hfirst r k hr)
      _ = (n : ‚ĄĚ) * localL := by
        simp
      _ ‚Č§ Lmax := hlocal_le
  ¬∑ calc
      (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ ‚ąĎ _k : Fin n, recL := by
        exact Finset.sum_le_sum (fun k _ =>
          htrail r k (Nat.le_of_not_gt hr))
      _ = (n : ‚ĄĚ) * recL := by
        simp
      _ ‚Č§ Lmax := hrec_le

