/-- **Theorem 11.7 finite supported solve-delta aggregation, coefficient
majorant form**.  After the supported residuals are summed with coefficient
`‚ąĎ t, c t`, a scalar comparison `‚ąĎ t, c t ‚Č§ C` upgrades the source-facing
interface to the printed coefficient `C`. -/
theorem higham11_7_tridiagonal_backward_error_interface_of_supported_sum_solve_delta_infNorm_of_coeff_sum_le
    (n offset k : ‚Ąē) (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (b x_hat : Fin n ‚Üí ‚ĄĚ)
    (E : Fin k ‚Üí Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (c : Fin k ‚Üí ‚ĄĚ) (C u : ‚ĄĚ)
    (hc : ‚ąÄ t : Fin k, 0 ‚Č§ c t) (hu : 0 ‚Č§ u)
    (hC : (‚ąĎ t : Fin k, c t) ‚Č§ C)
    (hbound : ‚ąÄ t : Fin k, ‚ąÄ i j : Fin n,
      |E t i j| ‚Č§ c t * u * infNorm A)
    (hsupp : ‚ąÄ t : Fin k,
      higham11_7_TridiagonalLeadingBlockSupport n offset (E t))
    (hsolve : ‚ąÄ i : Fin n,
      ‚ąĎ j : Fin n, (A i j + (‚ąĎ t : Fin k, E t i j)) * x_hat j = b i) :
    ‚ąÉ őĒA1 őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |őĒA1 i j| ‚Č§ C * u * infNorm A) ‚ąß
      (‚ąÄ i j : Fin n, |őĒA2 i j| ‚Č§ C * u * infNorm A) ‚ąß
      infNorm őĒA1 ‚Č§ (n : ‚ĄĚ) * C * u * infNorm A ‚ąß
      infNorm őĒA2 ‚Č§ (n : ‚ĄĚ) * C * u * infNorm A ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + őĒA2 i j) * x_hat j = b i) := by
  obtain ‚ü®őĒA2, hőĒA2, _hőĒA2supp, _hőĒA2norm, hőĒA2sum‚ü© :=
    higham11_7_tridiagonalLeadingBlockSupport_sum_printed_bound_with_norm_nonneg
      n offset k E c u (infNorm A) hc hu (infNorm_nonneg A)
      hbound hsupp
