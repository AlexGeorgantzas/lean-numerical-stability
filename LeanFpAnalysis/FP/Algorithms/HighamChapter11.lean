theorem higham11_4_product_entries_of_first_stage_recursive_bounds
    (n s : ‚Ąē) (hs_pos : 0 < s) (hs_le : s ‚Č§ n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌĀ_n Amax localB recB : ‚ĄĚ)
    (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax)
    (hlocal_budget : localB ‚Č§ 36 * ŌĀ_n * Amax)
    (hrec_budget : recB ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax)
    (hfirst : ‚ąÄ i j : Fin n, i.val < s ‚ą® j.val < s ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB)
    (htrail : ‚ąÄ i j : Fin n, s ‚Č§ i.val ‚Üí s ‚Č§ j.val ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB + recB) :
    ‚ąÄ i j : Fin n,
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
        36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
  have hzero_rec :
      (0 : ‚ĄĚ) ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := by
    have h36n : 0 ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) :=
      mul_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 36) (Nat.cast_nonneg _)
    exact mul_nonneg (mul_nonneg h36n hŌĀ) hAmax
  have hlocal_final :
      localB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
    simpa using
      higham11_4_first_stage_recursive_product_bound n s hs_pos hs_le
        ŌĀ_n Amax localB 0 hŌĀ hAmax hlocal_budget hzero_rec
  have htrail_final :
      localB + recB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax :=
    higham11_4_first_stage_recursive_product_bound n s hs_pos hs_le
      ŌĀ_n Amax localB recB hŌĀ hAmax hlocal_budget hrec_budget
  intro i j
  by_cases hi : i.val < s
  ¬∑ exact (hfirst i j (Or.inl hi)).trans hlocal_final
  ¬∑ by_cases hj : j.val < s
    ¬∑ exact (hfirst i j (Or.inr hj)).trans hlocal_final
    ¬∑ have hi_ge : s ‚Č§ i.val := by omega
      have hj_ge : s ‚Č§ j.val := by omega
      exact (htrail i j hi_ge hj_ge).trans htrail_final

