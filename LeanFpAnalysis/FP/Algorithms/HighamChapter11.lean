  by_cases hEq : t = u
  ¬∑ subst u
    exact le_rfl
  ¬∑ have hval_ne : t.val ‚Č† u.val := by
      intro hval
      exact hEq (Fin.ext hval)
    have hlt : t.val < u.val := lt_of_le_of_ne htu hval_ne
