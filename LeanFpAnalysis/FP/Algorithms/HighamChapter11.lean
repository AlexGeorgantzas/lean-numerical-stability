theorem higham11_7_tridiagonal_backward_error_interface_of_solve_delta_infNorm
    (n : ‚Ąē) (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (b x_hat : Fin n ‚Üí ‚ĄĚ)
