/-- Concrete gamma/product-square discharge for the exact-product Aasen
coefficient route.  The four terms are allocated to
`ő≥_{2n}, ő≥_{3n}, ő≥_{2n}, ő≥_{6n}` and then absorbed into the printed
`ő≥_{15n+25}` radius. -/
theorem higham11_8_aasen_relative_coeff_le_of_gamma_product_square_bounds
    (fp : FPModel) (n : ‚Ąē)
    (ő≥_factor ő≥15n25 őļL őļLT őļT őļBT őļmidLU : ‚ĄĚ)
    (hval : gammaValid fp (15 * n + 25))
    (hő≥15 : gamma fp (15 * n + 25) ‚Č§ ő≥15n25)
    (hőļBT : 0 ‚Č§ őļBT) (hőļBT_le : őļBT ‚Č§ gamma fp n)
    (hprodFT : őļL * őļT * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprodFB_base : őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprodST : ((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
      ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprodSB : ((1 + ő≥_factor) * őļL) * őļmidLU * ((1 + ő≥_factor) * őļLT) ‚Č§
      ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) :
    (2 * gamma fp n + (gamma fp n) ^ 2) * (őļL * őļT * őļLT) +
      (1 + 2 * gamma fp n + (gamma fp n) ^ 2) * (őļL * őļBT * őļLT) +
      (2 * gamma fp n + (gamma fp n) ^ 2) *
        (((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT)) +
      (1 + 2 * gamma fp n + (gamma fp n) ^ 2) *
        (((1 + ő≥_factor) * őļL) *
          (higham9_14_f (gamma fp n) * őļmidLU) *
          ((1 + ő≥_factor) * őļLT)) ‚Č§
      ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 * ő≥15n25 := by
  let őĪ : ‚ĄĚ := ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2
  let ő≥n : ‚ĄĚ := gamma fp n
  let ő≥2n : ‚ĄĚ := gamma fp (2 * n)
  let ő≥3n : ‚ĄĚ := gamma fp (3 * n)
  let ő≥6n : ‚ĄĚ := gamma fp (6 * n)
  let fő≥ : ‚ĄĚ := higham9_14_f ő≥n
  have hn : gammaValid fp n := gammaValid_mono fp (by omega) hval
  have h2n : gammaValid fp (2 * n) := gammaValid_mono fp (by omega) hval
  have h3n : gammaValid fp (3 * n) := gammaValid_mono fp (by omega) hval
  have h6n : gammaValid fp (6 * n) := gammaValid_mono fp (by omega) hval
  have hőĪ : 0 ‚Č§ őĪ := by
    dsimp [őĪ]
    exact sq_nonneg _
  have hő≥n : 0 ‚Č§ ő≥n := by
    dsimp [ő≥n]
    exact gamma_nonneg fp hn
  have hfő≥ : 0 ‚Č§ fő≥ := by
    dsimp [fő≥, ő≥n]
    exact higham9_14_f_nonneg (gamma_nonneg fp hn)
  have h2 : 2 * ő≥n + ő≥n ^ 2 ‚Č§ ő≥2n := by
    simpa [ő≥n, ő≥2n] using higham11_8_two_gamma_plus_sq_le_gamma_2n fp n h2n
  have h3 : (1 + 2 * ő≥n + ő≥n ^ 2) * ő≥n ‚Č§ ő≥3n := by
    simpa [ő≥n, ő≥3n] using
      higham11_8_one_plus_two_gamma_plus_sq_mul_gamma_le_gamma_3n fp n h3n
  have h6 : (1 + 2 * ő≥n + ő≥n ^ 2) * fő≥ ‚Č§ ő≥6n := by
