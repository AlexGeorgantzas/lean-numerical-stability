    let q_hat := fl_forwardSub fp n L_T_hat z_hat
    let y_hat := fl_backSub fp n U_T_hat q_hat
    let U_outer : Fin n → Fin n → ℝ := fun i j => L_hat j i
    let w_hat := fl_backSub fp n U_outer y_hat
