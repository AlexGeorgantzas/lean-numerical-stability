      (‚ąÄ i j : Fin n,
        |őĒA2 i j| ‚Č§
          higham11_3_blockLDLTBackwardErrorBound n L_hat D_hat őĶ i j) ‚ąß
      (‚ąÄ i j : Fin n,
        ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
          L_hat i k‚āĀ * D_hat k‚āĀ k‚āā * L_hat j k‚āā =
        A (ŌÉ i) (ŌÉ j) + őĒA1 i j) :=
  higham11_3_block_ldlt_backward_error_interface n A L_hat D_hat ŌÉ
    (higham11_3_blockLDLTBackwardErrorBound n L_hat D_hat őĶ) (by
      let őĒA1 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun i j =>
        (‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
          L_hat i k‚āĀ * D_hat k‚āĀ k‚āā * L_hat j k‚āā) - A (ŌÉ i) (ŌÉ j)
      let őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun _ _ => 0
      refine ‚ü®őĒA1, őĒA2, ?_, ?_, ?_‚ü©
      ¬∑ intro i j
        simpa [őĒA1, higham11_3_blockLDLTBackwardErrorBound] using
          hbe.backward_bound i j
      ¬∑ intro i j
        simpa [őĒA2] using
          higham11_3_blockLDLTBackwardErrorBound_nonneg n L_hat D_hat őĶ hőĶ i j
      ¬∑ intro i j
