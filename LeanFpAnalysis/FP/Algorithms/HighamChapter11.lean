/-- **Theorem 11.7 scalar local-to-global budget comparison**.  A local
branch budget `(c_bound+c_rec) u_loc ‚ÄĖA_loc‚ÄĖ‚ąě` is dominated by the global
budget `c u ‚ÄĖA‚ÄĖ‚ąě` when the coefficient, roundoff, and matrix-norm factors are
separately dominated. -/
theorem higham11_7_tridiagonal_local_budget_le_global_of_coeff_roundoff_norm
    (m n : ‚Ąē) (Aloc : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ) (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (c_bound c_rec c u_loc u : ‚ĄĚ)
    (_hc_bound : 0 ‚Č§ c_bound) (_hc_rec : 0 ‚Č§ c_rec) (hc : 0 ‚Č§ c)
    (hu_loc : 0 ‚Č§ u_loc) (hu_le : u_loc ‚Č§ u)
    (hcoeff : c_bound + c_rec ‚Č§ c)
    (hAnorm : infNorm Aloc ‚Č§ infNorm A) :
    (c_bound + c_rec) * u_loc * infNorm Aloc ‚Č§ c * u * infNorm A := by
  have hcu : (c_bound + c_rec) * u_loc ‚Č§ c * u := by
    exact mul_le_mul hcoeff hu_le hu_loc hc
  have hcu_nonneg : 0 ‚Č§ c * u :=
    mul_nonneg hc (hu_loc.trans hu_le)
  calc
    (c_bound + c_rec) * u_loc * infNorm Aloc
        ‚Č§ c * u * infNorm Aloc :=
          mul_le_mul_of_nonneg_right hcu (infNorm_nonneg Aloc)
    _ ‚Č§ c * u * infNorm A :=
          mul_le_mul_of_nonneg_left hAnorm hcu_nonneg

