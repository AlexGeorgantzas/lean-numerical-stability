/-- A finite path prefix sum splits into branches before `t` and the current
branch `t`. -/
theorem higham11_7_fin_sum_prefix_eq_before_add_current
    (k : ‚Ąē) (t : Fin k) (F : Fin k ‚Üí ‚ĄĚ) :
    (‚ąĎ u ‚ąą Finset.univ.filter (fun u : Fin k => u.val ‚Č§ t.val), F u) =
      (‚ąĎ u ‚ąą Finset.univ.filter (fun u : Fin k => u.val < t.val), F u) +
        F t := by
  classical
  have hsplit := Finset.sum_filter_add_sum_filter_not
    (Finset.univ.filter (fun u : Fin k => u.val ‚Č§ t.val))
    (fun u : Fin k => u.val < t.val) F
  rw [‚Üź hsplit]
  congr 1
  ¬∑ apply Finset.sum_congr
    ¬∑ ext u
      simp only [Finset.mem_filter, Finset.mem_univ, true_and]
      constructor
      ¬∑ intro h
        exact h.2
      ¬∑ intro h
        exact ‚ü®le_of_lt h, h‚ü©
    ¬∑ intro u _hu
      rfl
  ¬∑ have hsingle : (Finset.univ.filter
          (fun u : Fin k => u.val ‚Č§ t.val)).filter
          (fun u : Fin k => ¬¨u.val < t.val) = {t} := by
      ext u
      simp only [Finset.mem_filter, Finset.mem_univ, true_and,
        Finset.mem_singleton]
      constructor
      ¬∑ intro h
        apply Fin.ext
        omega
      ¬∑ intro h
        subst u
