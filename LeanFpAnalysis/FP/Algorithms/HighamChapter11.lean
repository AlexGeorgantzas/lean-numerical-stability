  rcases
      higham11_8_aasen_product_square_bounds_of_base_le_one
        n ő≥_factor őļL őļLT őļT őļmidLU hőļT hőļT_le_one hőļmidLU
        hőļmidLU_le_one hprod_base hprod_rel with
    ‚ü®hprodFT, hprodFB_base, hprodST, hprodSB‚ü©
  exact
