    (higham11_8_nonneg_of_uniform_abs_entry_bound n hn L őļ hentry)
    hőļcap hentry

/-- Aasen-structure outer-factor caps with an arbitrary scalar cap, deriving
`0‚Č§őļ` from the nonempty uniform absolute entry bound itself. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥)
    (hőļcap : (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ cap)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
