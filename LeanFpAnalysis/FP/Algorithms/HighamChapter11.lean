    (hőļBT : 0 ‚Č§ őļBT) (hőļBT_le : őļBT ‚Č§ gamma fp n)
    (hőļmidLU : 0 ‚Č§ őļmidLU) (hőļmidLU_le_one : őļmidLU ‚Č§ 1)
    (hprod_base : őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
