        (Atwo (higham11_7_tridiagonalBranchFirstTrailingIndex
            (higham11_7_tridiagonalPathTailDim k step t) PivotSize.two)
          (higham11_7_tridiagonalBranchFirstTrailingIndex
            (higham11_7_tridiagonalPathTailDim k step t) PivotSize.two))
