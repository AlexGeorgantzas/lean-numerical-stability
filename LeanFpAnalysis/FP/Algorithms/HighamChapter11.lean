/-- Insert a nonnegative middle factor bounded by `1` into a product already
bounded by the printed Aasen `(n-1)^2` square. -/
theorem higham11_8_triple_product_square_bound_of_middle_le_one
    (n : ‚Ąē) (őļLeft őļMid őļRight : ‚ĄĚ)
    (hőļMid : 0 ‚Č§ őļMid) (hőļMid_le_one : őļMid ‚Č§ 1)
    (hprod : őļLeft * őļRight ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) :
    őļLeft * őļMid * őļRight ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 := by
  let őĪ : ‚ĄĚ := ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2
  have hőĪ : 0 ‚Č§ őĪ := by
    dsimp [őĪ]
    exact sq_nonneg _
  have hmul : (őļLeft * őļRight) * őļMid ‚Č§ őĪ * 1 :=
    mul_le_mul (by simpa [őĪ] using hprod) hőļMid_le_one hőļMid hőĪ
  calc
    őļLeft * őļMid * őļRight = (őļLeft * őļRight) * őļMid := by ring
    _ ‚Č§ őĪ * 1 := hmul
    _ = ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 := by simp [őĪ]

/-- Reduce the four exact-product square caps for the concrete Aasen `T_hat`
route to two square caps, when the middle factors `őļT` and `őļmidLU` are each
bounded by `1`. -/
theorem higham11_8_aasen_product_square_bounds_of_base_le_one
    (n : ‚Ąē) (ő≥_factor őļL őļLT őļT őļmidLU : ‚ĄĚ)
    (hőļT : 0 ‚Č§ őļT) (hőļT_le_one : őļT ‚Č§ 1)
    (hőļmidLU : 0 ‚Č§ őļmidLU) (hőļmidLU_le_one : őļmidLU ‚Č§ 1)
    (hprod_base : őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprod_rel :
      ((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) :
    (őļL * őļT * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) ‚ąß
      (őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) ‚ąß
      (((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) ‚ąß
      (((1 + ő≥_factor) * őļL) * őļmidLU * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) := by
  refine ‚ü®?_, hprod_base, hprod_rel, ?_‚ü©
  ¬∑ exact
      higham11_8_triple_product_square_bound_of_middle_le_one
        n őļL őļT őļLT hőļT hőļT_le_one hprod_base
  ¬∑ exact
      higham11_8_triple_product_square_bound_of_middle_le_one
        n ((1 + ő≥_factor) * őļL) őļmidLU ((1 + ő≥_factor) * őļLT)
        hőļmidLU hőļmidLU_le_one hprod_rel

/-- Monotonicity helper for coefficient terms with multiplier `2ő≥+ő≥^2`. -/
theorem higham11_8_two_gamma_plus_sq_mul_le_of_le
    (ő≥ x y ő∑ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥) (hxy : x ‚Č§ y)
    (hyő∑ : (2 * ő≥ + ő≥ ^ 2) * y ‚Č§ ő∑) :
    (2 * ő≥ + ő≥ ^ 2) * x ‚Č§ ő∑ := by
  have hcoeff : 0 ‚Č§ 2 * ő≥ + ő≥ ^ 2 := by
    nlinarith [mul_nonneg (by norm_num : 0 ‚Č§ (2 : ‚ĄĚ)) hő≥, sq_nonneg ő≥]
  exact (mul_le_mul_of_nonneg_left hxy hcoeff).trans hyő∑

/-- Monotonicity helper for coefficient terms with multiplier `1+2ő≥+ő≥^2`. -/
theorem higham11_8_one_plus_two_gamma_plus_sq_mul_le_of_le
    (ő≥ x y ő∑ : ‚ĄĚ) (hxy : x ‚Č§ y)
    (hyő∑ : (1 + 2 * ő≥ + ő≥ ^ 2) * y ‚Č§ ő∑) :
    (1 + 2 * ő≥ + ő≥ ^ 2) * x ‚Č§ ő∑ := by
  have hcoeff : 0 ‚Č§ 1 + 2 * ő≥ + ő≥ ^ 2 := by
    nlinarith [sq_nonneg (ő≥ + 1)]
  exact (mul_le_mul_of_nonneg_left hxy hcoeff).trans hyő∑

/-- Transport a `2ő≥+ő≥^2` coefficient bound through a larger gamma radius and
a larger nonnegative product cap. -/
theorem higham11_8_two_gamma_plus_sq_mul_le_of_majorants
    (ő≥ ő≥b x y ő∑ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥) (hő≥le : ő≥ ‚Č§ ő≥b)
    (hx : 0 ‚Č§ x) (hxy : x ‚Č§ y)
    (hyő∑ : (2 * ő≥b + ő≥b ^ 2) * y ‚Č§ ő∑) :
    (2 * ő≥ + ő≥ ^ 2) * x ‚Č§ ő∑ := by
  have hő≥b : 0 ‚Č§ ő≥b := hő≥.trans hő≥le
  have hsquares : ő≥ ^ 2 ‚Č§ ő≥b ^ 2 := by
    nlinarith [mul_nonneg (sub_nonneg.mpr hő≥le) (add_nonneg hő≥b hő≥)]
  have hcoeff_le : 2 * ő≥ + ő≥ ^ 2 ‚Č§ 2 * ő≥b + ő≥b ^ 2 := by
    nlinarith
  have hő≥bcoeff_nonneg : 0 ‚Č§ 2 * ő≥b + ő≥b ^ 2 := by
    nlinarith [mul_nonneg (by norm_num : 0 ‚Č§ (2 : ‚ĄĚ)) hő≥b, sq_nonneg ő≥b]
  have hleft :
      (2 * ő≥ + ő≥ ^ 2) * x ‚Č§ (2 * ő≥b + ő≥b ^ 2) * y := by
    exact mul_le_mul hcoeff_le hxy hx hő≥bcoeff_nonneg
  exact hleft.trans hyő∑

/-- Transport a `1+2ő≥+ő≥^2` coefficient bound through a larger gamma radius and
a larger nonnegative product cap. -/
theorem higham11_8_one_plus_two_gamma_plus_sq_mul_le_of_majorants
    (ő≥ ő≥b x y ő∑ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥) (hő≥le : ő≥ ‚Č§ ő≥b)
    (hx : 0 ‚Č§ x) (hxy : x ‚Č§ y)
    (hyő∑ : (1 + 2 * ő≥b + ő≥b ^ 2) * y ‚Č§ ő∑) :
    (1 + 2 * ő≥ + ő≥ ^ 2) * x ‚Č§ ő∑ := by
  have hő≥b : 0 ‚Č§ ő≥b := hő≥.trans hő≥le
  have hsquares : ő≥ ^ 2 ‚Č§ ő≥b ^ 2 := by
    nlinarith [mul_nonneg (sub_nonneg.mpr hő≥le) (add_nonneg hő≥b hő≥)]
  have hcoeff_le : 1 + 2 * ő≥ + ő≥ ^ 2 ‚Č§ 1 + 2 * ő≥b + ő≥b ^ 2 := by
    nlinarith
  have hő≥bcoeff_nonneg : 0 ‚Č§ 1 + 2 * ő≥b + ő≥b ^ 2 := by
    nlinarith [sq_nonneg (ő≥b + 1)]
  have hleft :
      (1 + 2 * ő≥ + ő≥ ^ 2) * x ‚Č§ (1 + 2 * ő≥b + ő≥b ^ 2) * y := by
    exact mul_le_mul hcoeff_le hxy hx hő≥bcoeff_nonneg
  exact hleft.trans hyő∑

/-- Absorb Chapter 9's tridiagonal-LU source polynomial
`f(ő≥_n)=4ő≥_n+3ő≥_n^2+ő≥_n^3` into a single accumulated gamma radius. -/
theorem higham11_8_higham9_14_f_gamma_le_gamma_4n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (4 * n)) :
    higham9_14_f (gamma fp n) ‚Č§ gamma fp (4 * n) := by
  let ő≥n : ‚ĄĚ := gamma fp n
  let ő≥3n : ‚ĄĚ := gamma fp (3 * n)
  have hn : gammaValid fp n := gammaValid_mono fp (by omega) hval
  have h3n : gammaValid fp (3 * n) := gammaValid_mono fp (by omega) hval
  have hő≥n : 0 ‚Č§ ő≥n := by
    dsimp [ő≥n]
    exact gamma_nonneg fp hn
  have h3 :
      3 * ő≥n + ő≥n ^ 2 ‚Č§ ő≥3n := by
    simpa [ő≥n, ő≥3n] using three_gamma_plus_sq_le_gamma fp n h3n
  have h3mul :
      (3 * ő≥n + ő≥n ^ 2) * ő≥n ‚Č§ ő≥3n * ő≥n :=
    mul_le_mul_of_nonneg_right h3 hő≥n
  have hpoly :
      higham9_14_f ő≥n ‚Č§ ő≥3n + ő≥n + ő≥3n * ő≥n := by
    unfold higham9_14_f
    nlinarith
  have h4 :
      ő≥3n + ő≥n + ő≥3n * ő≥n ‚Č§ gamma fp (4 * n) := by
    have hsum :
        gamma fp (3 * n) + gamma fp n +
            gamma fp (3 * n) * gamma fp n ‚Č§ gamma fp (3 * n + n) :=
      gamma_sum_le fp (3 * n) n (by
        simpa [show 3 * n + n = 4 * n by omega] using hval)
    simpa [ő≥n, ő≥3n, show 3 * n + n = 4 * n by omega] using hsum
  exact hpoly.trans h4

/-- Column/row-dominant Aasen middle solves use the coefficient
`3f(ő≥_n)`; this helper absorbs that term into `ő≥_{12n}`. -/
theorem higham11_8_three_higham9_14_f_gamma_le_gamma_12n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (12 * n)) :
    3 * higham9_14_f (gamma fp n) ‚Č§ gamma fp (12 * n) := by
  have h4valid : gammaValid fp (4 * n) :=
    gammaValid_mono fp (by omega) hval
  have hf :
      higham9_14_f (gamma fp n) ‚Č§ gamma fp (4 * n) :=
    higham11_8_higham9_14_f_gamma_le_gamma_4n fp n h4valid
  have htriple :
      (3 : ‚ĄĚ) * gamma fp (4 * n) ‚Č§ gamma fp (3 * (4 * n)) :=
    gamma_nsmul_le fp 3 (4 * n) (by norm_num) (by
      simpa [show 3 * (4 * n) = 12 * n by omega] using hval)
  calc
    3 * higham9_14_f (gamma fp n)
        ‚Č§ (3 : ‚ĄĚ) * gamma fp (4 * n) :=
          mul_le_mul_of_nonneg_left hf (by norm_num)
    _ ‚Č§ gamma fp (12 * n) := by
      simpa [show 3 * (4 * n) = 12 * n by omega] using htriple

/-- Absorb `2ő≥_n+ő≥_n^2` into `ő≥_{2n}`. -/
theorem higham11_8_two_gamma_plus_sq_le_gamma_2n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (2 * n)) :
    2 * gamma fp n + (gamma fp n) ^ 2 ‚Č§ gamma fp (2 * n) := by
  have hsum :
      gamma fp n + gamma fp n + gamma fp n * gamma fp n ‚Č§
        gamma fp (n + n) :=
    gamma_sum_le fp n n (by
      simpa [show n + n = 2 * n by omega] using hval)
  rw [show n + n = 2 * n by omega] at hsum
  nlinarith

/-- Absorb `(1+2ő≥_n+ő≥_n^2)ő≥_n` into `ő≥_{3n}`. -/
theorem higham11_8_one_plus_two_gamma_plus_sq_mul_gamma_le_gamma_3n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (3 * n)) :
    (1 + 2 * gamma fp n + (gamma fp n) ^ 2) * gamma fp n ‚Č§
      gamma fp (3 * n) := by
  let ő≥n : ‚ĄĚ := gamma fp n
  let ő≥2n : ‚ĄĚ := gamma fp (2 * n)
  have hn : gammaValid fp n := gammaValid_mono fp (by omega) hval
  have h2n : gammaValid fp (2 * n) := gammaValid_mono fp (by omega) hval
  have hő≥n : 0 ‚Č§ ő≥n := by
    dsimp [ő≥n]
    exact gamma_nonneg fp hn
  have hő≥2n : 0 ‚Č§ ő≥2n := by
    dsimp [ő≥2n]
    exact gamma_nonneg fp h2n
  have h2 :
      2 * ő≥n + ő≥n ^ 2 ‚Č§ ő≥2n := by
    simpa [ő≥n, ő≥2n] using
      higham11_8_two_gamma_plus_sq_le_gamma_2n fp n h2n
  have h2mul :
      (2 * ő≥n + ő≥n ^ 2) * ő≥n ‚Č§ ő≥2n * ő≥n :=
    mul_le_mul_of_nonneg_right h2 hő≥n
  have hpoly :
      (1 + 2 * ő≥n + ő≥n ^ 2) * ő≥n ‚Č§ ő≥2n + ő≥n + ő≥2n * ő≥n := by
    nlinarith
  have h3 :
      ő≥2n + ő≥n + ő≥2n * ő≥n ‚Č§ gamma fp (3 * n) := by
    have hsum :
        gamma fp (2 * n) + gamma fp n +
            gamma fp (2 * n) * gamma fp n ‚Č§ gamma fp (2 * n + n) :=
      gamma_sum_le fp (2 * n) n (by
        simpa [show 2 * n + n = 3 * n by omega] using hval)
    simpa [ő≥n, ő≥2n, show 2 * n + n = 3 * n by omega] using hsum
  exact hpoly.trans h3

/-- Absorb `(1+2ő≥_n+ő≥_n^2)f(ő≥_n)` into `ő≥_{6n}`. -/
theorem higham11_8_one_plus_two_gamma_plus_sq_mul_higham9_14_f_gamma_le_gamma_6n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (6 * n)) :
    (1 + 2 * gamma fp n + (gamma fp n) ^ 2) *
        higham9_14_f (gamma fp n) ‚Č§
      gamma fp (6 * n) := by
  let ő≥n : ‚ĄĚ := gamma fp n
  let ő≥2n : ‚ĄĚ := gamma fp (2 * n)
  let ő≥4n : ‚ĄĚ := gamma fp (4 * n)
  let fő≥ : ‚ĄĚ := higham9_14_f ő≥n
  have hn : gammaValid fp n := gammaValid_mono fp (by omega) hval
  have h2n : gammaValid fp (2 * n) := gammaValid_mono fp (by omega) hval
  have h4n : gammaValid fp (4 * n) := gammaValid_mono fp (by omega) hval
  have hő≥n : 0 ‚Č§ ő≥n := by
    dsimp [ő≥n]
    exact gamma_nonneg fp hn
  have hő≥2n : 0 ‚Č§ ő≥2n := by
    dsimp [ő≥2n]
    exact gamma_nonneg fp h2n
  have hő≥4n : 0 ‚Č§ ő≥4n := by
    dsimp [ő≥4n]
    exact gamma_nonneg fp h4n
  have hf_nonneg : 0 ‚Č§ fő≥ := by
    dsimp [fő≥]
    exact higham9_14_f_nonneg hő≥n
  have h2 :
      2 * ő≥n + ő≥n ^ 2 ‚Č§ ő≥2n := by
    simpa [ő≥n, ő≥2n] using
      higham11_8_two_gamma_plus_sq_le_gamma_2n fp n h2n
  have hf :
      fő≥ ‚Č§ ő≥4n := by
    simpa [ő≥n, ő≥4n, fő≥] using
      higham11_8_higham9_14_f_gamma_le_gamma_4n fp n h4n
  have hmul :
      (2 * ő≥n + ő≥n ^ 2) * fő≥ ‚Č§ ő≥2n * ő≥4n :=
    mul_le_mul h2 hf hf_nonneg hő≥2n
  have hpoly :
      (1 + 2 * ő≥n + ő≥n ^ 2) * fő≥ ‚Č§ ő≥4n + ő≥2n + ő≥4n * ő≥2n := by
    nlinarith
  have h6 :
      ő≥4n + ő≥2n + ő≥4n * ő≥2n ‚Č§ gamma fp (6 * n) := by
    have hsum :
        gamma fp (4 * n) + gamma fp (2 * n) +
            gamma fp (4 * n) * gamma fp (2 * n) ‚Č§
          gamma fp (4 * n + 2 * n) :=
      gamma_sum_le fp (4 * n) (2 * n) (by
        simpa [show 4 * n + 2 * n = 6 * n by omega] using hval)
    simpa [ő≥2n, ő≥4n, show 4 * n + 2 * n = 6 * n by omega] using hsum
  exact hpoly.trans h6

/-- Absorb `(1+2ő≥_n+ő≥_n^2) * 3f(ő≥_n)` into `ő≥_{14n}` for the
column/row-dominant Aasen middle-solve specializations. -/
theorem higham11_8_one_plus_two_gamma_plus_sq_mul_three_higham9_14_f_gamma_le_gamma_14n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (14 * n)) :
    (1 + 2 * gamma fp n + (gamma fp n) ^ 2) *
        (3 * higham9_14_f (gamma fp n)) ‚Č§
      gamma fp (14 * n) := by
  let ő≥n : ‚ĄĚ := gamma fp n
  let ő≥2n : ‚ĄĚ := gamma fp (2 * n)
  let ő≥12n : ‚ĄĚ := gamma fp (12 * n)
  let f3ő≥ : ‚ĄĚ := 3 * higham9_14_f ő≥n
  have hn : gammaValid fp n := gammaValid_mono fp (by omega) hval
  have h2n : gammaValid fp (2 * n) := gammaValid_mono fp (by omega) hval
  have h12n : gammaValid fp (12 * n) := gammaValid_mono fp (by omega) hval
  have hő≥n : 0 ‚Č§ ő≥n := by
    dsimp [ő≥n]
    exact gamma_nonneg fp hn
  have hő≥2n : 0 ‚Č§ ő≥2n := by
    dsimp [ő≥2n]
    exact gamma_nonneg fp h2n
  have hő≥12n : 0 ‚Č§ ő≥12n := by
    dsimp [ő≥12n]
    exact gamma_nonneg fp h12n
  have hf3_nonneg : 0 ‚Č§ f3ő≥ := by
    dsimp [f3ő≥]
    exact mul_nonneg (by norm_num) (higham9_14_f_nonneg hő≥n)
  have h2 :
      2 * ő≥n + ő≥n ^ 2 ‚Č§ ő≥2n := by
    simpa [ő≥n, ő≥2n] using
      higham11_8_two_gamma_plus_sq_le_gamma_2n fp n h2n
  have hf3 :
      f3ő≥ ‚Č§ ő≥12n := by
    simpa [ő≥n, ő≥12n, f3ő≥] using
      higham11_8_three_higham9_14_f_gamma_le_gamma_12n fp n h12n
  have hmul :
      (2 * ő≥n + ő≥n ^ 2) * f3ő≥ ‚Č§ ő≥2n * ő≥12n :=
    mul_le_mul h2 hf3 hf3_nonneg hő≥2n
  have hpoly :
      (1 + 2 * ő≥n + ő≥n ^ 2) * f3ő≥ ‚Č§ ő≥12n + ő≥2n + ő≥12n * ő≥2n := by
    nlinarith
  have h14 :
      ő≥12n + ő≥2n + ő≥12n * ő≥2n ‚Č§ gamma fp (14 * n) := by
    have hsum :
        gamma fp (12 * n) + gamma fp (2 * n) +
            gamma fp (12 * n) * gamma fp (2 * n) ‚Č§
          gamma fp (12 * n + 2 * n) :=
      gamma_sum_le fp (12 * n) (2 * n) (by
        simpa [show 12 * n + 2 * n = 14 * n by omega] using hval)
    simpa [ő≥2n, ő≥12n, show 12 * n + 2 * n = 14 * n by omega] using hsum
  exact hpoly.trans h14

/-- Pairwise gamma sums are bounded by the accumulated gamma radius. -/
theorem higham11_gamma_add_le
    (fp : FPModel) (a b : ‚Ąē) (hvalid : gammaValid fp (a + b)) :
    gamma fp a + gamma fp b ‚Č§ gamma fp (a + b) := by
  have ha : gammaValid fp a := gammaValid_mono fp (by omega) hvalid
  have hb : gammaValid fp b := gammaValid_mono fp (by omega) hvalid
  have hsum := gamma_sum_le fp a b hvalid
  have hprod_nonneg : 0 ‚Č§ gamma fp a * gamma fp b :=
    mul_nonneg (gamma_nonneg fp ha) (gamma_nonneg fp hb)
  nlinarith

/-- The four Aasen coefficient shares used by the concrete `T_hat` route fit
inside the printed `ő≥_{15n+25}` radius. -/
theorem higham11_8_gamma_2n_plus_3n_plus_2n_plus_6n_le_gamma_15n25
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (15 * n + 25)) :
    gamma fp (2 * n) + gamma fp (3 * n) + gamma fp (2 * n) +
        gamma fp (6 * n) ‚Č§ gamma fp (15 * n + 25) := by
  have h5valid : gammaValid fp (5 * n) := gammaValid_mono fp (by omega) hval
  have h8valid : gammaValid fp (8 * n) := gammaValid_mono fp (by omega) hval
  have h13valid : gammaValid fp (13 * n) := gammaValid_mono fp (by omega) hval
  have h23 : gamma fp (2 * n) + gamma fp (3 * n) ‚Č§ gamma fp (5 * n) := by
    have h := higham11_gamma_add_le fp (2 * n) (3 * n) (by
      simpa [show 2 * n + 3 * n = 5 * n by omega] using h5valid)
    simpa [show 2 * n + 3 * n = 5 * n by omega] using h
  have h26 : gamma fp (2 * n) + gamma fp (6 * n) ‚Č§ gamma fp (8 * n) := by
    have h := higham11_gamma_add_le fp (2 * n) (6 * n) (by
      simpa [show 2 * n + 6 * n = 8 * n by omega] using h8valid)
    simpa [show 2 * n + 6 * n = 8 * n by omega] using h
  have h58 : gamma fp (5 * n) + gamma fp (8 * n) ‚Č§ gamma fp (13 * n) := by
    have h := higham11_gamma_add_le fp (5 * n) (8 * n) (by
      simpa [show 5 * n + 8 * n = 13 * n by omega] using h13valid)
    simpa [show 5 * n + 8 * n = 13 * n by omega] using h
  have h13mono : gamma fp (13 * n) ‚Č§ gamma fp (15 * n + 25) :=
    gamma_mono fp (by omega) hval
  nlinarith

/-- Concrete gamma/product-square discharge for the exact-product Aasen
coefficient route.  The four terms are allocated to
`ő≥_{2n}, ő≥_{3n}, ő≥_{2n}, ő≥_{6n}` and then absorbed into the printed
`ő≥_{15n+25}` radius. -/
theorem higham11_8_aasen_relative_coeff_le_of_gamma_product_square_bounds
    (fp : FPModel) (n : ‚Ąē)
    (ő≥_factor ő≥15n25 őļL őļLT őļT őļBT őļmidLU : ‚ĄĚ)
    (hval : gammaValid fp (15 * n + 25))
    (hő≥15 : gamma fp (15 * n + 25) ‚Č§ ő≥15n25)
    (hőļBT : 0 ‚Č§ őļBT) (hőļBT_le : őļBT ‚Č§ gamma fp n)
    (hprodFT : őļL * őļT * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprodFB_base : őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprodST : ((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
      ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprodSB : ((1 + ő≥_factor) * őļL) * őļmidLU * ((1 + ő≥_factor) * őļLT) ‚Č§
      ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) :
    (2 * gamma fp n + (gamma fp n) ^ 2) * (őļL * őļT * őļLT) +
      (1 + 2 * gamma fp n + (gamma fp n) ^ 2) * (őļL * őļBT * őļLT) +
      (2 * gamma fp n + (gamma fp n) ^ 2) *
        (((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT)) +
      (1 + 2 * gamma fp n + (gamma fp n) ^ 2) *
        (((1 + ő≥_factor) * őļL) *
          (higham9_14_f (gamma fp n) * őļmidLU) *
          ((1 + ő≥_factor) * őļLT)) ‚Č§
      ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 * ő≥15n25 := by
  let őĪ : ‚ĄĚ := ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2
  let ő≥n : ‚ĄĚ := gamma fp n
  let ő≥2n : ‚ĄĚ := gamma fp (2 * n)
  let ő≥3n : ‚ĄĚ := gamma fp (3 * n)
  let ő≥6n : ‚ĄĚ := gamma fp (6 * n)
  let fő≥ : ‚ĄĚ := higham9_14_f ő≥n
  have hn : gammaValid fp n := gammaValid_mono fp (by omega) hval
  have h2n : gammaValid fp (2 * n) := gammaValid_mono fp (by omega) hval
  have h3n : gammaValid fp (3 * n) := gammaValid_mono fp (by omega) hval
  have h6n : gammaValid fp (6 * n) := gammaValid_mono fp (by omega) hval
  have hőĪ : 0 ‚Č§ őĪ := by
    dsimp [őĪ]
    exact sq_nonneg _
  have hő≥n : 0 ‚Č§ ő≥n := by
    dsimp [ő≥n]
    exact gamma_nonneg fp hn
  have hfő≥ : 0 ‚Č§ fő≥ := by
    dsimp [fő≥, ő≥n]
    exact higham9_14_f_nonneg (gamma_nonneg fp hn)
  have h2 : 2 * ő≥n + ő≥n ^ 2 ‚Č§ ő≥2n := by
    simpa [ő≥n, ő≥2n] using higham11_8_two_gamma_plus_sq_le_gamma_2n fp n h2n
  have h3 : (1 + 2 * ő≥n + ő≥n ^ 2) * ő≥n ‚Č§ ő≥3n := by
    simpa [ő≥n, ő≥3n] using
      higham11_8_one_plus_two_gamma_plus_sq_mul_gamma_le_gamma_3n fp n h3n
  have h6 : (1 + 2 * ő≥n + ő≥n ^ 2) * fő≥ ‚Č§ ő≥6n := by
    simpa [ő≥n, ő≥6n, fő≥] using
      higham11_8_one_plus_two_gamma_plus_sq_mul_higham9_14_f_gamma_le_gamma_6n
        fp n h6n
  have hFTcap : (2 * ő≥n + ő≥n ^ 2) * őĪ ‚Č§ őĪ * ő≥2n := by
    simpa [mul_comm] using mul_le_mul_of_nonneg_left h2 hőĪ
  have hSTcap : (2 * ő≥n + ő≥n ^ 2) * őĪ ‚Č§ őĪ * ő≥2n := hFTcap
  have hFBprod : őļL * őļBT * őļLT ‚Č§ őĪ * ő≥n := by
    have hmul := mul_le_mul hprodFB_base (by simpa [ő≥n] using hőļBT_le) hőļBT hőĪ
    calc
      őļL * őļBT * őļLT = (őļL * őļLT) * őļBT := by ring
      _ ‚Č§ őĪ * ő≥n := hmul
  have hFBcap : (1 + 2 * ő≥n + ő≥n ^ 2) * (őĪ * ő≥n) ‚Č§ őĪ * ő≥3n := by
    calc
      (1 + 2 * ő≥n + ő≥n ^ 2) * (őĪ * ő≥n)
          = őĪ * ((1 + 2 * ő≥n + ő≥n ^ 2) * ő≥n) := by ring
      _ ‚Č§ őĪ * ő≥3n := mul_le_mul_of_nonneg_left h3 hőĪ
  have hSBprod :
      ((1 + ő≥_factor) * őļL) * (fő≥ * őļmidLU) * ((1 + ő≥_factor) * őļLT) ‚Č§
        őĪ * fő≥ := by
    have hmul := mul_le_mul_of_nonneg_right hprodSB hfő≥
    calc
      ((1 + ő≥_factor) * őļL) * (fő≥ * őļmidLU) * ((1 + ő≥_factor) * őļLT)
          = (((1 + ő≥_factor) * őļL) * őļmidLU * ((1 + ő≥_factor) * őļLT)) * fő≥ := by
            ring
      _ ‚Č§ őĪ * fő≥ := hmul
  have hSBcap : (1 + 2 * ő≥n + ő≥n ^ 2) * (őĪ * fő≥) ‚Č§ őĪ * ő≥6n := by
    calc
      (1 + 2 * ő≥n + ő≥n ^ 2) * (őĪ * fő≥)
          = őĪ * ((1 + 2 * ő≥n + ő≥n ^ 2) * fő≥) := by ring
      _ ‚Č§ őĪ * ő≥6n := mul_le_mul_of_nonneg_left h6 hőĪ
  have hshares : ő≥2n + ő≥3n + ő≥2n + ő≥6n ‚Č§ ő≥15n25 := by
    have hraw : ő≥2n + ő≥3n + ő≥2n + ő≥6n ‚Č§ gamma fp (15 * n + 25) := by
      simpa [ő≥2n, ő≥3n, ő≥6n] using
        higham11_8_gamma_2n_plus_3n_plus_2n_plus_6n_le_gamma_15n25 fp n hval
    exact hraw.trans hő≥15
  have hparts : őĪ * ő≥2n + őĪ * ő≥3n + őĪ * ő≥2n + őĪ * ő≥6n ‚Č§ őĪ * ő≥15n25 := by
    calc
      őĪ * ő≥2n + őĪ * ő≥3n + őĪ * ő≥2n + őĪ * ő≥6n
          = őĪ * (ő≥2n + ő≥3n + ő≥2n + ő≥6n) := by ring
      _ ‚Č§ őĪ * ő≥15n25 := mul_le_mul_of_nonneg_left hshares hőĪ
  exact
    higham11_8_aasen_factor_solve_coeff_le_of_parts
      n ő≥n ő≥n ő≥15n25 őļL őļLT ((1 + ő≥_factor) * őļL)
      ((1 + ő≥_factor) * őļLT) őļT őļBT (fő≥ * őļmidLU)
      (őĪ * ő≥2n) (őĪ * ő≥3n) (őĪ * ő≥2n) (őĪ * ő≥6n)
      (higham11_8_two_gamma_plus_sq_mul_le_of_le ő≥n
        (őļL * őļT * őļLT) őĪ (őĪ * ő≥2n) hő≥n
        (by simpa [őĪ] using hprodFT) hFTcap)
      (higham11_8_one_plus_two_gamma_plus_sq_mul_le_of_le ő≥n
        (őļL * őļBT * őļLT) (őĪ * ő≥n) (őĪ * ő≥3n) hFBprod hFBcap)
      (higham11_8_two_gamma_plus_sq_mul_le_of_le ő≥n
        (((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT)) őĪ
        (őĪ * ő≥2n) hő≥n (by simpa [őĪ] using hprodST) hSTcap)
      (higham11_8_one_plus_two_gamma_plus_sq_mul_le_of_le ő≥n
        (((1 + ő≥_factor) * őļL) * (fő≥ * őļmidLU) * ((1 + ő≥_factor) * őļLT))
        (őĪ * fő≥) (őĪ * ő≥6n) hSBprod hSBcap)
      (by simpa [őĪ] using hparts)

/-- Concrete gamma/product-square discharge for the exact-product Aasen
coefficient route, with the four product caps reduced to source/computed
two-factor square caps plus `őļT‚Č§1` and `őļmidLU‚Č§1`. -/
theorem higham11_8_aasen_relative_coeff_le_of_gamma_base_square_bounds
    (fp : FPModel) (n : ‚Ąē)
    (ő≥_factor ő≥15n25 őļL őļLT őļT őļBT őļmidLU : ‚ĄĚ)
    (hval : gammaValid fp (15 * n + 25))
    (hő≥15 : gamma fp (15 * n + 25) ‚Č§ ő≥15n25)
    (hőļT : 0 ‚Č§ őļT) (hőļT_le_one : őļT ‚Č§ 1)
    (hőļBT : 0 ‚Č§ őļBT) (hőļBT_le : őļBT ‚Č§ gamma fp n)
    (hőļmidLU : 0 ‚Č§ őļmidLU) (hőļmidLU_le_one : őļmidLU ‚Č§ 1)
    (hprod_base : őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprod_rel :
      ((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) :
    (2 * gamma fp n + (gamma fp n) ^ 2) * (őļL * őļT * őļLT) +
      (1 + 2 * gamma fp n + (gamma fp n) ^ 2) * (őļL * őļBT * őļLT) +
      (2 * gamma fp n + (gamma fp n) ^ 2) *
        (((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT)) +
      (1 + 2 * gamma fp n + (gamma fp n) ^ 2) *
        (((1 + ő≥_factor) * őļL) *
          (higham9_14_f (gamma fp n) * őļmidLU) *
          ((1 + ő≥_factor) * őļLT)) ‚Č§
      ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 * ő≥15n25 := by
  rcases
      higham11_8_aasen_product_square_bounds_of_base_le_one
        n ő≥_factor őļL őļLT őļT őļmidLU hőļT hőļT_le_one hőļmidLU
        hőļmidLU_le_one hprod_base hprod_rel with
    ‚ü®hprodFT, hprodFB_base, hprodST, hprodSB‚ü©
  exact
    higham11_8_aasen_relative_coeff_le_of_gamma_product_square_bounds
      fp n ő≥_factor ő≥15n25 őļL őļLT őļT őļBT őļmidLU hval hő≥15
      hőļBT hőļBT_le hprodFT hprodFB_base hprodST hprodSB

/-- Exact-radius specialization of
`higham11_8_aasen_relative_coeff_le_of_gamma_base_square_bounds`, using the
printed `ő≥_{15n+25}` radius directly. -/
theorem higham11_8_aasen_relative_coeff_le_of_gamma_base_square_exact_radius
    (fp : FPModel) (n : ‚Ąē)
    (ő≥_factor őļL őļLT őļT őļBT őļmidLU : ‚ĄĚ)
    (hval : gammaValid fp (15 * n + 25))
    (hőļT : 0 ‚Č§ őļT) (hőļT_le_one : őļT ‚Č§ 1)
