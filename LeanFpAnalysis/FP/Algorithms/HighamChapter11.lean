        P i) :
    ‚ąÄ i : Fin (higham11_7_tridiagonalPathPivotSpan k step + 1), P i := by
  intro i
  by_cases hmem :
      ‚ąÉ t : Fin k, i = higham11_7_tridiagonalPathFirstTrailingIndex k step t
  ¬∑ rcases hmem with ‚ü®t, rfl‚ü©
    exact hend t
  ¬∑ exact hcomp i (by
      intro t hit
      exact hmem ‚ü®t, hit‚ü©)

/-- A predicate over concrete path rows is proved everywhere once it is proved
on the first-trailing endpoints, separately at the leading row, and on all
