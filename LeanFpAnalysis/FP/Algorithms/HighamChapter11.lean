  classical
  intro i j hlead
  by_cases hi : ‚ąÉ a : Fin m, start + a.val = i.val
  ¬∑ by_cases hj : ‚ąÉ b : Fin m, start + b.val = j.val
    ¬∑ rw [higham11_7_tridiagonalLiftLocalBlockPerturbation, dif_pos hi,
        dif_pos hj]
