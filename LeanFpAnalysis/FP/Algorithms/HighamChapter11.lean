/-- **Theorem 11.7 finite support-sum combiner with norm bound**.  In addition
to accumulating the componentwise budgets, the summed perturbation inherits the
row-sum `‚ąě`-norm bound generated by that accumulated componentwise budget. -/
theorem higham11_7_tridiagonalLeadingBlockSupport_sum_bound_with_norm
    (m offset k : ‚Ąē) (E : Fin k ‚Üí Fin m ‚Üí Fin m ‚Üí ‚ĄĚ) (ő≤ : Fin k ‚Üí ‚ĄĚ)
    (hő≤ : ‚ąÄ t : Fin k, 0 ‚Č§ ő≤ t)
    (hbound : ‚ąÄ t : Fin k, ‚ąÄ i j : Fin m, |E t i j| ‚Č§ ő≤ t)
    (hsupp : ‚ąÄ t : Fin k, higham11_7_TridiagonalLeadingBlockSupport m offset (E t)) :
    ‚ąÉ G : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin m, |G i j| ‚Č§ ‚ąĎ t : Fin k, ő≤ t) ‚ąß
      higham11_7_TridiagonalLeadingBlockSupport m offset G ‚ąß
      infNorm G ‚Č§ (m : ‚ĄĚ) * (‚ąĎ t : Fin k, ő≤ t) ‚ąß
      (‚ąÄ i j : Fin m, G i j = ‚ąĎ t : Fin k, E t i j) := by
  obtain ‚ü®G, hGbound, hGsupp, hGsum‚ü© :=
    higham11_7_tridiagonalLeadingBlockSupport_sum_bound m offset k E ő≤
      hbound hsupp
  refine ‚ü®G, hGbound, hGsupp, ?_, hGsum‚ü©
  apply infNorm_le_of_row_sum_le
  ¬∑ intro i
    calc (‚ąĎ j : Fin m, |G i j|)
        ‚Č§ ‚ąĎ _j : Fin m, ‚ąĎ t : Fin k, ő≤ t :=
          Finset.sum_le_sum (fun j _ => hGbound i j)
      _ = (m : ‚ĄĚ) * (‚ąĎ t : Fin k, ő≤ t) := by
        simp [Finset.sum_const, nsmul_eq_mul]
  ¬∑ exact mul_nonneg (Nat.cast_nonneg m)
      (Finset.sum_nonneg (fun t _ => hő≤ t))

/-- **Theorem 11.7 finite support-sum combiner with norm bound, uniform form**.
If every same-ambient supported perturbation is bounded by the same nonnegative
