/-- Unscaled exact outer-factor norm caps from a normalized uniform entry bound,
deriving `0‚Č§őļ` from the absolute entry bound itself. -/
theorem higham11_8_outer_factor_caps_of_aasen_entry_bound_scaled_unit_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļunit : (1 + ő≥) * őļ ‚Č§ 1)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
