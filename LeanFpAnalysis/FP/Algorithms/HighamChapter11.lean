      (k + 1) step P (by
        intro t
        by_cases ht : t = Fin.last k
        ¬∑ subst t
          simpa [higham11_7_tridiagonalPathFirstTrailingIndex_last_eq_finLast]
            using hlast
        ¬∑ exact hend t ht) hcomp

