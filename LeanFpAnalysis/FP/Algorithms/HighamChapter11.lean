    higham11_8_infNorm_le_mul_of_componentwise_T_bound n A B 1
      (by norm_num) (fun i j => by simpa using hAB i j)

/-- A relative `(1+ő≥)` infinity-norm cap implies the corresponding unscaled
cap when `ő≥ ‚Č• 0`. -/
theorem higham11_8_infNorm_cap_of_relative_infNorm_cap (n : ‚Ąē)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ cap : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥)
    (hrel : (1 + ő≥) * infNorm M ‚Č§ cap) :
    infNorm M ‚Č§ cap := by
  have hscale : infNorm M ‚Č§ (1 + ő≥) * infNorm M := by
    have h1ő≥ : 1 ‚Č§ 1 + ő≥ := by linarith
    calc
      infNorm M = 1 * infNorm M := by ring
      _ ‚Č§ (1 + ő≥) * infNorm M :=
        mul_le_mul_of_nonneg_right h1ő≥ (infNorm_nonneg M)
  exact hscale.trans hrel

/-- Per-row scaled row-sum caps imply the corresponding relative
`(1+ő≥)` infinity-norm cap. -/
theorem higham11_8_relative_infNorm_cap_of_row_sum_caps (n : ‚Ąē)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ cap : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥) (hcap : 0 ‚Č§ cap)
    (hrows : ‚ąÄ i : Fin n, (1 + ő≥) * (‚ąĎ j : Fin n, |M i j|) ‚Č§ cap) :
    (1 + ő≥) * infNorm M ‚Č§ cap := by
  have hscale_pos : 0 < 1 + ő≥ := by linarith
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := le_of_lt hscale_pos
  have hrows_div : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |M i j|) ‚Č§ cap / (1 + ő≥) := by
    intro i
    exact (le_div_iff‚āÄ hscale_pos).mpr (by simpa [mul_comm] using hrows i)
  have hinf : infNorm M ‚Č§ cap / (1 + ő≥) := by
    apply infNorm_le_of_row_sum_le
    ¬∑ intro i
      exact hrows_div i
    ¬∑ exact div_nonneg hcap hscale_nonneg
  calc
    (1 + ő≥) * infNorm M ‚Č§ (1 + ő≥) * (cap / (1 + ő≥)) :=
      mul_le_mul_of_nonneg_left hinf hscale_nonneg
    _ = cap := by
      field_simp [ne_of_gt hscale_pos]

/-- Unscaled row-sum majorants plus a scalar scale comparison imply the
relative `(1+ő≥)` infinity-norm cap used by the Aasen exact-radius route. -/
theorem higham11_8_relative_infNorm_cap_of_row_sum_majorant (n : ‚Ąē)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hcap : 0 ‚Č§ cap)
    (hőļcap : (1 + ő≥) * őļ ‚Č§ cap)
    (hrows : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |M i j|) ‚Č§ őļ) :
    (1 + ő≥) * infNorm M ‚Č§ cap := by
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := by linarith
  apply higham11_8_relative_infNorm_cap_of_row_sum_caps n M ő≥ cap hő≥ hcap
  intro i
  exact (mul_le_mul_of_nonneg_left (hrows i) hscale_nonneg).trans hőļcap

/-- Row and column sum majorants for the exact Aasen outer factor feed the two
relative norm caps required for the source-prefix exact-radius wrappers. -/
theorem higham11_8_relative_outer_factor_caps_of_row_col_sum_majorants (n : ‚Ąē)
    (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļrow őļcol cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hcap : 0 ‚Č§ cap)
    (hőļrow : (1 + ő≥) * őļrow ‚Č§ cap)
    (hőļcol : (1 + ő≥) * őļcol ‚Č§ cap)
    (hrows : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |L i j|) ‚Č§ őļrow)
    (hcols : ‚ąÄ j : Fin n, (‚ąĎ i : Fin n, |L i j|) ‚Č§ őļcol) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap := by
  constructor
  ¬∑ exact
      higham11_8_relative_infNorm_cap_of_row_sum_majorant
        n L ő≥ őļrow cap hő≥ hcap hőļrow hrows
  ¬∑ exact
      higham11_8_relative_infNorm_cap_of_row_sum_majorant
        n (fun r c => L c r) ő≥ őļcol cap hő≥ hcap hőļcol
        (fun r => by simpa using hcols r)

/-- Uniform entrywise majorants for the exact Aasen outer factor imply the
row/column majorants, and hence the two relative norm caps, after one scalar
scale comparison. -/
theorem higham11_8_relative_outer_factor_caps_of_entrywise_majorant (n : ‚Ąē)
    (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : 0 ‚Č§ őļ)
    (hőļcap : (1 + ő≥) * ((n : ‚ĄĚ) * őļ) ‚Č§ cap)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap := by
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := by linarith
  have hrow_majorant_nonneg : 0 ‚Č§ (n : ‚ĄĚ) * őļ :=
    mul_nonneg (Nat.cast_nonneg n) hőļ
  have hcap : 0 ‚Č§ cap :=
    (mul_nonneg hscale_nonneg hrow_majorant_nonneg).trans hőļcap
  have hrows : ‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |L i j|) ‚Č§ (n : ‚ĄĚ) * őļ := by
    intro i
    calc
      (‚ąĎ j : Fin n, |L i j|) ‚Č§ ‚ąĎ _j : Fin n, őļ :=
        Finset.sum_le_sum (fun j _ => hentry i j)
      _ = (n : ‚ĄĚ) * őļ := by simp [Finset.sum_const, nsmul_eq_mul]
  have hcols : ‚ąÄ j : Fin n, (‚ąĎ i : Fin n, |L i j|) ‚Č§ (n : ‚ĄĚ) * őļ := by
    intro j
    calc
      (‚ąĎ i : Fin n, |L i j|) ‚Č§ ‚ąĎ _i : Fin n, őļ :=
        Finset.sum_le_sum (fun i _ => hentry i j)
      _ = (n : ‚ĄĚ) * őļ := by simp [Finset.sum_const, nsmul_eq_mul]
  exact
    higham11_8_relative_outer_factor_caps_of_row_col_sum_majorants
      n L ő≥ ((n : ‚ĄĚ) * őļ) ((n : ‚ĄĚ) * őļ) cap
      hő≥ hcap hőļcap hőļcap hrows hcols

/-- If one entry of a uniformly bounded `Fin n` family is known to vanish, the
full absolute sum is bounded by `(n-1)` copies of the uniform entry bound. -/
theorem higham11_8_sum_abs_le_card_pred_mul_of_one_zero {n : ‚Ąē}
    (v : Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ k : Fin n, |v k| ‚Č§ őļ) (z : Fin n) (hz : v z = 0) :
    (‚ąĎ k : Fin n, |v k|) ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ := by
  calc
    (‚ąĎ k : Fin n, |v k|) =
        Finset.sum (Finset.univ.erase z) (fun k => |v k|) := by
      rw [‚Üź Finset.sum_erase_add (s := (Finset.univ : Finset (Fin n)))
        (a := z) (f := fun k => |v k|) (Finset.mem_univ z)]
      simp [hz]
    _ ‚Č§ Finset.sum (Finset.univ.erase z) (fun _k : Fin n => őļ) := by
      apply Finset.sum_le_sum
      intro k _hk
      exact hentry k
    _ = ((Finset.univ.erase z).card : ‚ĄĚ) * őļ := by
      simp [Finset.sum_const, nsmul_eq_mul]
    _ = ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ := by
      rw [Finset.card_erase_of_mem (Finset.mem_univ z), Finset.card_univ,
        Fintype.card_fin]

/-- Aasen's exact outer factor structure upgrades a uniform entry majorant to
`(n-1)` row and column sum majorants: every row and every column has at least
one forced zero entry. -/
theorem higham11_8_aasen_outer_factor_row_col_sum_majorants_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (‚ąÄ i : Fin n, (‚ąĎ j : Fin n, |L i j|) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚ąß
      (‚ąÄ j : Fin n, (‚ąĎ i : Fin n, |L i j|) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) := by
  constructor
  ¬∑ intro i
    by_cases hi0 : i.val = 0
    ¬∑ let z : Fin n := ‚ü®1, hn‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun j => L i j) őļ (fun j => hentry i j) z
          (hstrictUpperZero i z (by dsimp [z]; omega))
    ¬∑ let z : Fin n := ‚ü®0, by omega‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun j => L i j) őļ (fun j => hentry i j) z
          (hfirstColZero i z (by dsimp [z]) hi0)
  ¬∑ intro j
    by_cases hj0 : j.val = 0
    ¬∑ let z : Fin n := ‚ü®1, hn‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun i => L i j) őļ (fun i => hentry i j) z
          (hfirstColZero z j hj0 (by dsimp [z]; omega))
    ¬∑ let z : Fin n := ‚ü®0, by omega‚ü©
      exact
        higham11_8_sum_abs_le_card_pred_mul_of_one_zero
          (v := fun i => L i j) őļ (fun i => hentry i j) z
          (hstrictUpperZero z j (by dsimp [z]; omega))

/-- Source-specific Aasen outer-factor structure feeds the exact-radius relative
factor norm caps with `(n-1)` copies of a uniform exact-factor entry bound,
rather than the fallback `n` copies. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound (n : ‚Ąē)
    (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : 0 ‚Č§ őļ)
    (hőļcap : (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ cap)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ cap ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§ cap := by
  have hscale_nonneg : 0 ‚Č§ 1 + ő≥ := by linarith
  have hmajor_nonneg : 0 ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ :=
    mul_nonneg (Nat.cast_nonneg (n - 1)) hőļ
  have hcap : 0 ‚Č§ cap :=
    (mul_nonneg hscale_nonneg hmajor_nonneg).trans hőļcap
  rcases
    higham11_8_aasen_outer_factor_row_col_sum_majorants_of_entry_bound
      n hn L őļ hentry hstrictUpperZero hfirstColZero with
    ‚ü®hrows, hcols‚ü©
  exact
    higham11_8_relative_outer_factor_caps_of_row_col_sum_majorants
      n L ő≥ (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) cap
      hő≥ hcap hőļcap hőļcap hrows hcols

/-- Scalar scale comparison for the Aasen `(n-1)` outer-factor route.  A
normalized entry bound `(1+ő≥)őļ‚Č§1` implies the row/column cap
`(1+ő≥)((n-1)őļ)‚Č§n-1` consumed by the exact-radius wrappers. -/
theorem higham11_8_aasen_outer_factor_scaled_entry_cap (n : ‚Ąē) (ő≥ őļ : ‚ĄĚ)
    (hőļunit : (1 + ő≥) * őļ ‚Č§ 1) :
    (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) := by
  have hcard : 0 ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) := Nat.cast_nonneg (n - 1)
  calc
    (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ)
        = ((n - 1 : ‚Ąē) : ‚ĄĚ) * ((1 + ő≥) * őļ) := by ring
    _ ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) * 1 :=
      mul_le_mul_of_nonneg_left hőļunit hcard
    _ = ((n - 1 : ‚Ąē) : ‚ĄĚ) := by ring

/-- Scalar bridge from the common source-style inverse scale hypothesis to the
normalized Aasen exact-factor entry cap. -/
theorem higham11_8_one_plus_mul_le_one_of_le_inv_one_plus (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : őļ ‚Č§ 1 / (1 + ő≥)) :
    (1 + ő≥) * őļ ‚Č§ 1 := by
  have hpos : 0 < 1 + ő≥ := by linarith
  calc
    (1 + ő≥) * őļ ‚Č§ (1 + ő≥) * (1 / (1 + ő≥)) :=
      mul_le_mul_of_nonneg_left hőļ (le_of_lt hpos)
    _ = 1 := by field_simp [ne_of_gt hpos]

/-- Aasen `(n-1)` outer-factor scale cap from the source-style bound
`őļ‚Č§1/(1+ő≥)`. -/
theorem higham11_8_aasen_outer_factor_scaled_entry_cap_of_le_inv_one_plus
    (n : ‚Ąē) (ő≥ őļ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥)
    (hőļ : őļ ‚Č§ 1 / (1 + ő≥)) :
    (1 + ő≥) * (((n - 1 : ‚Ąē) : ‚ĄĚ) * őļ) ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) :=
  higham11_8_aasen_outer_factor_scaled_entry_cap n ő≥ őļ
    (higham11_8_one_plus_mul_le_one_of_le_inv_one_plus ő≥ őļ hő≥ hőļ)

/-- Aasen outer-factor relative caps from a normalized uniform entry bound.
This factors the remaining source scalar comparison for the exact-radius route:
after proving `(1+ő≥)őļ‚Č§1` for the concrete Aasen factor entries, the strict
upper-zero and first-column-zero structure supplies both relative norm caps with
the printed `(n-1)` radius. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļ : 0 ‚Č§ őļ)
    (hőļunit : (1 + ő≥) * őļ ‚Č§ 1)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) := by
  exact
    higham11_8_relative_outer_factor_caps_of_aasen_entry_bound
      n hn L ő≥ őļ ((n - 1 : ‚Ąē) : ‚ĄĚ) hő≥ hőļ
      (higham11_8_aasen_outer_factor_scaled_entry_cap n ő≥ őļ hőļunit)
      hentry hstrictUpperZero hfirstColZero

/-- Aasen outer-factor relative caps from a source-style inverse-scale uniform
entry bound.  This is the same result as the normalized route, with
`őļ‚Č§1/(1+ő≥)` supplying the normalized scalar cap. -/
theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_inv_one_plus
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļnonneg : 0 ‚Č§ őļ) (hőļ : őļ ‚Č§ 1 / (1 + ő≥))
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ)
    (hstrictUpperZero : ‚ąÄ i j : Fin n, i.val < j.val ‚Üí L i j = 0)
    (hfirstColZero : ‚ąÄ i j : Fin n,
      j.val = 0 ‚Üí i.val ‚Č† 0 ‚Üí L i j = 0) :
    (1 + ő≥) * infNorm L ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ‚ąß
      (1 + ő≥) * infNorm (fun r c => L c r) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) :=
  higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit
    n hn L ő≥ őļ hő≥ hőļnonneg
    (higham11_8_one_plus_mul_le_one_of_le_inv_one_plus ő≥ őļ hő≥ hőļ)
    hentry hstrictUpperZero hfirstColZero

/-- A uniform absolute entry bound over a nonempty matrix supplies
nonnegativity of the bound. -/
theorem higham11_8_nonneg_of_uniform_abs_entry_bound (n : ‚Ąē) (hn : 0 < n)
    (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ i j : Fin n, |L i j| ‚Č§ őļ) :
    0 ‚Č§ őļ :=
  (abs_nonneg (L ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)).trans
    (hentry ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)

/-- Generic entrywise-majorant outer-factor caps, deriving `0‚Č§őļ` from the
nonempty uniform absolute entry bound itself. -/
theorem higham11_8_relative_outer_factor_caps_of_entrywise_majorant_of_entry_bound
    (n : ‚Ąē) (hn : 0 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ cap : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥)
    (hőļcap : (1 + ő≥) * ((n : ‚ĄĚ) * őļ) ‚Č§ cap)
