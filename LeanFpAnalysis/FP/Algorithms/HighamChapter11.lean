theorem higham11_8_aasen_product_square_bounds_of_base_le_one
    (n : ‚Ąē) (ő≥_factor őļL őļLT őļT őļmidLU : ‚ĄĚ)
    (hőļT : 0 ‚Č§ őļT) (hőļT_le_one : őļT ‚Č§ 1)
    (hőļmidLU : 0 ‚Č§ őļmidLU) (hőļmidLU_le_one : őļmidLU ‚Č§ 1)
    (hprod_base : őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2)
    (hprod_rel :
      ((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) :
    (őļL * őļT * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) ‚ąß
      (őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) ‚ąß
      (((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) ‚ąß
      (((1 + ő≥_factor) * őļL) * őļmidLU * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) := by
  refine ‚ü®?_, hprod_base, hprod_rel, ?_‚ü©
  ¬∑ exact
      higham11_8_triple_product_square_bound_of_middle_le_one
        n őļL őļT őļLT hőļT hőļT_le_one hprod_base
  ¬∑ exact
      higham11_8_triple_product_square_bound_of_middle_le_one
        n ((1 + ő≥_factor) * őļL) őļmidLU ((1 + ő≥_factor) * őļLT)
        hőļmidLU hőļmidLU_le_one hprod_rel

/-- Monotonicity helper for coefficient terms with multiplier `2ő≥+ő≥^2`. -/
theorem higham11_8_two_gamma_plus_sq_mul_le_of_le
    (ő≥ x y ő∑ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥) (hxy : x ‚Č§ y)
    (hyő∑ : (2 * ő≥ + ő≥ ^ 2) * y ‚Č§ ő∑) :
    (2 * ő≥ + ő≥ ^ 2) * x ‚Č§ ő∑ := by
  have hcoeff : 0 ‚Č§ 2 * ő≥ + ő≥ ^ 2 := by
    nlinarith [mul_nonneg (by norm_num : 0 ‚Č§ (2 : ‚ĄĚ)) hő≥, sq_nonneg ő≥]
  exact (mul_le_mul_of_nonneg_left hxy hcoeff).trans hyő∑

/-- Monotonicity helper for coefficient terms with multiplier `1+2ő≥+ő≥^2`. -/
theorem higham11_8_one_plus_two_gamma_plus_sq_mul_le_of_le
    (ő≥ x y ő∑ : ‚ĄĚ) (hxy : x ‚Č§ y)
