  ¬∑ intro i
    calc (‚ąĎ j : Fin n, |őĒA i j|)
        ‚Č§ ‚ąĎ _j : Fin n, ő≤ := Finset.sum_le_sum (fun j _ => hőĒ i j)
      _ = (n : ‚ĄĚ) * ő≤ := by
        simp [Finset.sum_const, nsmul_eq_mul]
  ¬∑ exact mul_nonneg (Nat.cast_nonneg n) hő≤

