      (6 : ‚ĄĚ) * (ŌĀ_n * Amax) * 6 ‚Č§
        36 * ŌĀ_n * Amax + 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := by
  have hrec_nonneg :
      0 ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := by
    exact mul_nonneg
      (mul_nonneg
        (mul_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 36) (Nat.cast_nonneg _)) hŌĀ)
      hAmax
  constructor
  ¬∑ calc
      (6 : ‚ĄĚ) * (ŌĀ_n * Amax) * 6 = 36 * ŌĀ_n * Amax := by ring
      _ ‚Č§ 36 * ŌĀ_n * Amax := le_rfl
  ¬∑ have h :
        36 * ŌĀ_n * Amax ‚Č§
