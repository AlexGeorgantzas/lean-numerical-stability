/-- **Theorem 11.4 global `DŐā` cap split**.  First-stage and recursive trailing
absolute-entry caps cover every entry of `DŐā`, using the same leading/trailing
index split as the product-entry aggregation. -/
theorem higham11_4_D_bound_of_first_stage_recursive_split
    (n s : ‚Ąē) (D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (Dmax localD recD : ‚ĄĚ)
    (hlocal_le : localD ‚Č§ Dmax) (hrec_le : recD ‚Č§ Dmax)
    (hfirst : ‚ąÄ i j : Fin n, i.val < s ‚ą® j.val < s ‚Üí
      |D_hat i j| ‚Č§ localD)
    (htrail : ‚ąÄ i j : Fin n, s ‚Č§ i.val ‚Üí s ‚Č§ j.val ‚Üí
      |D_hat i j| ‚Č§ recD) :
    ‚ąÄ i j : Fin n, |D_hat i j| ‚Č§ Dmax := by
  intro i j
  by_cases hi : i.val < s
  ¬∑ exact (hfirst i j (Or.inl hi)).trans hlocal_le
  ¬∑ by_cases hj : j.val < s
    ¬∑ exact (hfirst i j (Or.inr hj)).trans hlocal_le
    ¬∑ exact (htrail i j (Nat.le_of_not_gt hi) (Nat.le_of_not_gt hj)).trans hrec_le

