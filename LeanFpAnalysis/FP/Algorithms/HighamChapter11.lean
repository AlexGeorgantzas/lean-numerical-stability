      (∑ k : Fin n, |L_hat r k|) ≤ recL) :
    ∀ r : Fin n, (∑ k : Fin n, |L_hat r k|) ≤ Lmax := by
  intro r
  by_cases hr : r.val < s
  · exact (hfirst r hr).trans hlocal_le
  · exact (htrail r (Nat.le_of_not_gt hr)).trans hrec_le

