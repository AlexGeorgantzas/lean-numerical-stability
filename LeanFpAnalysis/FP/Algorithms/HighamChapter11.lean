theorem higham11_4_bound_const_le_36 :
    (3 + higham11_1_bunchParlettAlpha ^ 2) * (3 + higham11_1_bunchParlettAlpha)
      / (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2 ‚Č§ 36 :=
  bunch_kaufman_bound_const_le_36

/-- **Theorem 11.4 constant handoff**: pointwise eq-(4.14) estimates with
Higham's exact coefficient `(3+őĪ¬≤)(3+őĪ)/(1‚ąíőĪ¬≤)¬≤` imply the source-facing
`36 n ŌĀ‚āô ‚ÄĖA‚ÄĖ_M` max-entry norm bound for `|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_maxEntryNorm_absLDLTProduct_le_of_higham_const_entries
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (ŌĀ_n Amax : ‚ĄĚ) (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax)
    (hentries : ‚ąÄ i j : Fin n,
      higham11_4_absLDLTProduct n L_hat D_hat i j ‚Č§
        ((3 + higham11_1_bunchParlettAlpha ^ 2) *
            (3 + higham11_1_bunchParlettAlpha) /
            (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2) *
          (n : ‚ĄĚ) * ŌĀ_n * Amax) :
    maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) ‚Č§
      36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
  let C : ‚ĄĚ :=
    (3 + higham11_1_bunchParlettAlpha ^ 2) *
      (3 + higham11_1_bunchParlettAlpha) /
      (1 - higham11_1_bunchParlettAlpha ^ 2) ^ 2
  have hC : C ‚Č§ 36 := by
    simpa [C] using higham11_4_bound_const_le_36
  have htail_nonneg : 0 ‚Č§ (n : ‚ĄĚ) * ŌĀ_n * Amax :=
    mul_nonneg (mul_nonneg (Nat.cast_nonneg n) hŌĀ) hAmax
  calc
    maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat)
        ‚Č§ C * (n : ‚ĄĚ) * ŌĀ_n * Amax :=
      higham11_4_maxEntryNorm_absLDLTProduct_le_of_absLDLTProduct_entries
        n hn L_hat D_hat (C * (n : ‚ĄĚ) * ŌĀ_n * Amax) (by
          intro i j
          simpa [C] using hentries i j)
    _ = C * ((n : ‚ĄĚ) * ŌĀ_n * Amax) := by ring
    _ ‚Č§ 36 * ((n : ‚ĄĚ) * ŌĀ_n * Amax) :=
      mul_le_mul_of_nonneg_right hC htail_nonneg
    _ = 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by ring

