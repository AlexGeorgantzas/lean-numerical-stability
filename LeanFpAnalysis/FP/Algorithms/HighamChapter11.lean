      ¬∑ right
        have hval := Classical.choose_spec hj
        omega
    ¬∑ rw [higham11_7_tridiagonalLiftLocalBlockPerturbation, dif_pos hi,
        dif_neg hj]
  ¬∑ rw [higham11_7_tridiagonalLiftLocalBlockPerturbation, dif_neg hi]

