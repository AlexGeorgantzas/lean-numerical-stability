theorem higham11_8_infNorm_le_of_componentwise_abs_bound (n : ‚Ąē)
    (A B : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hAB : ‚ąÄ i j : Fin n, |A i j| ‚Č§ |B i j|) :
