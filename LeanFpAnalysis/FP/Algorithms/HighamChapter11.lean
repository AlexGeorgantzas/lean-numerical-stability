/-- **Theorem 11.4 block-recursion scalar handoff** (Higham [608, 1997],
eqs. (4.11)--(4.14)): a first-stage contribution bounded by one
`36ŌĀ‚āô‚ÄĖA‚ÄĖ_M` share, plus a recursive Schur-complement contribution bounded by
`36(n-s)ŌĀ‚āô‚ÄĖA‚ÄĖ_M`, fits inside the printed `36nŌĀ‚āô‚ÄĖA‚ÄĖ_M` product budget. -/
theorem higham11_4_first_stage_recursive_product_bound
    (n s : ‚Ąē) (hs_pos : 0 < s) (hs_le : s ‚Č§ n)
    (ŌĀ_n Amax localB recB : ‚ĄĚ) (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax)
    (hlocal : localB ‚Č§ 36 * ŌĀ_n * Amax)
    (hrec : recB ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax) :
    localB + recB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
  let q : ‚ĄĚ := 36 * ŌĀ_n * Amax
  have hq : 0 ‚Č§ q := by
    dsimp [q]
    exact mul_nonneg (mul_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 36) hŌĀ) hAmax
  have hrec' : recB ‚Č§ ((n - s : ‚Ąē) : ‚ĄĚ) * q := by
    calc
      recB ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := hrec
      _ = ((n - s : ‚Ąē) : ‚ĄĚ) * q := by ring
  have hcoef_nat : 1 + (n - s) ‚Č§ n := by omega
  have hcoef : (1 : ‚ĄĚ) + ((n - s : ‚Ąē) : ‚ĄĚ) ‚Č§ (n : ‚ĄĚ) := by
    exact_mod_cast hcoef_nat
  calc
    localB + recB
        ‚Č§ q + ((n - s : ‚Ąē) : ‚ĄĚ) * q := by
          exact add_le_add (by simpa [q] using hlocal) hrec'
    _ = (1 + ((n - s : ‚Ąē) : ‚ĄĚ)) * q := by ring
    _ ‚Č§ (n : ‚ĄĚ) * q := mul_le_mul_of_nonneg_right hcoef hq
    _ = 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by ring

/-- **Theorem 11.4 block-recursion entry handoff**: if entries touching the
first pivot block are bounded by the local Higham [608, 1997] first-stage
budget, while trailing entries split into the same local share plus a recursive
Schur-complement share, then all source product entries satisfy the printed
`36nŌĀ‚āô‚ÄĖA‚ÄĖ_M` estimate. -/
theorem higham11_4_product_entries_of_first_stage_recursive_bounds
    (n s : ‚Ąē) (hs_pos : 0 < s) (hs_le : s ‚Č§ n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌĀ_n Amax localB recB : ‚ĄĚ)
    (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax)
    (hlocal_budget : localB ‚Č§ 36 * ŌĀ_n * Amax)
    (hrec_budget : recB ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax)
    (hfirst : ‚ąÄ i j : Fin n, i.val < s ‚ą® j.val < s ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB)
    (htrail : ‚ąÄ i j : Fin n, s ‚Č§ i.val ‚Üí s ‚Č§ j.val ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB + recB) :
    ‚ąÄ i j : Fin n,
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
        36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
  have hzero_rec :
      (0 : ‚ĄĚ) ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax := by
    have h36n : 0 ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) :=
      mul_nonneg (by norm_num : (0 : ‚ĄĚ) ‚Č§ 36) (Nat.cast_nonneg _)
    exact mul_nonneg (mul_nonneg h36n hŌĀ) hAmax
  have hlocal_final :
      localB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax := by
    simpa using
      higham11_4_first_stage_recursive_product_bound n s hs_pos hs_le
        ŌĀ_n Amax localB 0 hŌĀ hAmax hlocal_budget hzero_rec
  have htrail_final :
      localB + recB ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax :=
    higham11_4_first_stage_recursive_product_bound n s hs_pos hs_le
      ŌĀ_n Amax localB recB hŌĀ hAmax hlocal_budget hrec_budget
  intro i j
  by_cases hi : i.val < s
  ¬∑ exact (hfirst i j (Or.inl hi)).trans hlocal_final
  ¬∑ by_cases hj : j.val < s
    ¬∑ exact (hfirst i j (Or.inr hj)).trans hlocal_final
    ¬∑ have hi_ge : s ‚Č§ i.val := by omega
      have hj_ge : s ‚Č§ j.val := by omega
      exact (htrail i j hi_ge hj_ge).trans htrail_final

/-- First-stage plus recursive Schur-complement product-entry bounds package
directly into the source-shaped max-entry norm target for `|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_maxEntryNorm_absLDLTProduct_le_of_first_stage_recursive_bounds
    (n s : ‚Ąē) (hn : 0 < n) (hs_pos : 0 < s) (hs_le : s ‚Č§ n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌĀ_n Amax localB recB : ‚ĄĚ)
    (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax)
    (hlocal_budget : localB ‚Č§ 36 * ŌĀ_n * Amax)
    (hrec_budget : recB ‚Č§ 36 * ((n - s : ‚Ąē) : ‚ĄĚ) * ŌĀ_n * Amax)
    (hfirst : ‚ąÄ i j : Fin n, i.val < s ‚ą® j.val < s ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB)
    (htrail : ‚ąÄ i j : Fin n, s ‚Č§ i.val ‚Üí s ‚Č§ j.val ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB + recB) :
    maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) ‚Č§
      36 * (n : ‚ĄĚ) * ŌĀ_n * Amax :=
  higham11_4_maxEntryNorm_absLDLTProduct_le_of_product_entries
    n hn L_hat D_hat (36 * (n : ‚ĄĚ) * ŌĀ_n * Amax)
