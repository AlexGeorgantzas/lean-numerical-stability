/-- **Equation (11.6)**, the partial-pivoting example matrix. -/
noncomputable def higham11_6_partialPivotExampleA
    (őĶ : ‚ĄĚ) : Fin 3 ‚Üí Fin 3 ‚Üí ‚ĄĚ :=
  fun i j =>
    if i.val = 0 ‚ąß j.val = 1 then őĶ
    else if i.val = 1 ‚ąß j.val = 0 then őĶ
    else if i.val = 1 ‚ąß j.val = 2 then 1
    else if i.val = 2 ‚ąß j.val = 1 then 1
    else if i.val = 2 ‚ąß j.val = 2 then 1
    else 0

/-- **Equation (11.6)**, the displayed lower triangular factor. -/
noncomputable def higham11_6_partialPivotExampleL
    (őĶ : ‚ĄĚ) : Fin 3 ‚Üí Fin 3 ‚Üí ‚ĄĚ :=
  fun i j =>
    if i.val = j.val then 1
    else if i.val = 2 ‚ąß j.val = 0 then 1 / őĶ
    else 0

/-- **Equation (11.6)**, the displayed block diagonal factor. -/
noncomputable def higham11_6_partialPivotExampleD
    (őĶ : ‚ĄĚ) : Fin 3 ‚Üí Fin 3 ‚Üí ‚ĄĚ :=
  fun i j =>
    if i.val = 0 ‚ąß j.val = 1 then őĶ
    else if i.val = 1 ‚ąß j.val = 0 then őĶ
    else if i.val = 2 ‚ąß j.val = 2 then 1
    else 0

/-- **Equation (11.6)** verified algebraically:
`A = L D L^T` for `őĶ ‚Č† 0`. -/
theorem higham11_6_partialPivotExample_factorization
    (őĶ : ‚ĄĚ) (hőĶ : őĶ ‚Č† 0) :
    ‚ąÄ i j : Fin 3,
      ‚ąĎ k‚āĀ : Fin 3, ‚ąĎ k‚āā : Fin 3,
        higham11_6_partialPivotExampleL őĶ i k‚āĀ *
          higham11_6_partialPivotExampleD őĶ k‚āĀ k‚āā *
          higham11_6_partialPivotExampleL őĶ j k‚āā =
      higham11_6_partialPivotExampleA őĶ i j := by
  intro i j
  fin_cases i <;> fin_cases j <;>
    simp [Fin.sum_univ_three, higham11_6_partialPivotExampleA, higham11_6_partialPivotExampleL,
      higham11_6_partialPivotExampleD, hőĶ]

/-- The Higham [1997] max-entry bound used in the proof of Theorem 11.4:
`|| |L||D||L^T| ||_M <= 36 n rho_n ||A||_M`. -/
def higham11_4_bunchKaufmanMaxEntryProductBound
    (n : ‚Ąē) (productMax ŌĀ_n Amax : ‚ĄĚ) : Prop :=
  productMax ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax

/-- The `(i,j)` entry of the nonnegative product `|LŐā||DŐā||LŐāŠĶÄ|` used in
Theorem 11.4. -/
noncomputable def higham11_4_bunchKaufmanProductEntry (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) : ‚ĄĚ :=
  ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
    |L_hat i k‚āĀ| * |D_hat k‚āĀ k‚āā| * |L_hat j k‚āā|

/-- The structured Theorem 11.3 envelope is `őĶ` times the named
`|LŐā||DŐā||LŐāŠĶÄ|` product entry used by the Theorem 11.4 infrastructure. -/
theorem higham11_3_blockLDLTBackwardErrorBound_eq_epsilon_mul_productEntry
    (n : ‚Ąē) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őĶ : ‚ĄĚ) (i j : Fin n) :
    higham11_3_blockLDLTBackwardErrorBound n L_hat D_hat őĶ i j =
      őĶ * higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j := by
  rfl

/-- A pointwise bound on the named `|LŐā||DŐā||LŐāŠĶÄ|` product entry bounds the
structured Theorem 11.3 envelope. -/
theorem higham11_3_blockLDLTBackwardErrorBound_le_of_productEntry_le
    (n : ‚Ąē) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őĶ B : ‚ĄĚ)
    (i j : Fin n) (hőĶ : 0 ‚Č§ őĶ)
    (hB : higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ B) :
    higham11_3_blockLDLTBackwardErrorBound n L_hat D_hat őĶ i j ‚Č§ őĶ * B := by
  rw [higham11_3_blockLDLTBackwardErrorBound_eq_epsilon_mul_productEntry]
  exact mul_le_mul_of_nonneg_left hB hőĶ

/-- The matrix product `|LŐā||DŐā||LŐāŠĶÄ|` from Higham [608, 1997], eq. (4.14),
written with the project matrix product primitives. -/
noncomputable def higham11_4_absLDLTProduct (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ :=
  matMul n (matMul n (absMatrix n L_hat) (absMatrix n D_hat))
    (absMatrix n (fun r c => L_hat c r))

/-- The expanded double-sum product entry is exactly the `(i,j)` entry of
`|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j =
      higham11_4_absLDLTProduct n L_hat D_hat i j := by
  unfold higham11_4_bunchKaufmanProductEntry higham11_4_absLDLTProduct
  dsimp [matMul, absMatrix]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro k‚āā _
  rw [Finset.sum_mul]

/-- Each entry of `|LŐā||DŐā||LŐāŠĶÄ|` is nonnegative. -/
theorem higham11_4_bunchKaufmanProductEntry_nonneg (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) :
    0 ‚Č§ higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j := by
  unfold higham11_4_bunchKaufmanProductEntry
  exact Finset.sum_nonneg (fun k‚āĀ _ =>
    Finset.sum_nonneg (fun k‚āā _ =>
      mul_nonneg (mul_nonneg (abs_nonneg _) (abs_nonneg _)) (abs_nonneg _)))

/-- **Theorem 11.3 printed first-order envelope**:
`p u (|A| + |LŐā||DŐā||LŐāŠĶÄ|)`, indexed in the permuted coordinates used by the
factorization interface.  This is the source first-order part of (11.5), with
the higher-order `O(u^2)` term intentionally not modeled here. -/
noncomputable def higham11_3_printedFirstOrderBound (n : ‚Ąē)
    (A L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌÉ : Fin n ‚Üí Fin n) (p u : ‚ĄĚ) :
    Fin n ‚Üí Fin n ‚Üí ‚ĄĚ :=
  fun i j =>
    p * u *
      (|A (ŌÉ i) (ŌÉ j)| + higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j)

/-- The printed first-order Theorem 11.3 envelope is nonnegative when
`p u ‚Č• 0`. -/
theorem higham11_3_printedFirstOrderBound_nonneg (n : ‚Ąē)
    (A L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌÉ : Fin n ‚Üí Fin n) (p u : ‚ĄĚ)
    (hpu : 0 ‚Č§ p * u) :
    ‚ąÄ i j : Fin n,
      0 ‚Č§ higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u i j := by
  intro i j
  exact mul_nonneg hpu
    (add_nonneg (abs_nonneg _) (higham11_4_bunchKaufmanProductEntry_nonneg
      n L_hat D_hat i j))

/-- The structured `őĶ |LŐā||DŐā||LŐāŠĶÄ|` factorization envelope is dominated by the
printed first-order source envelope whenever `őĶ ‚Č§ p u`. -/
theorem higham11_3_blockLDLTBackwardErrorBound_le_printedFirstOrderBound
    (n : ‚Ąē) (A L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌÉ : Fin n ‚Üí Fin n)
    (őĶ p u : ‚ĄĚ) (i j : Fin n)
    (hscale : őĶ ‚Č§ p * u) (hpu : 0 ‚Č§ p * u) :
    higham11_3_blockLDLTBackwardErrorBound n L_hat D_hat őĶ i j ‚Č§
      higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u i j := by
  rw [higham11_3_blockLDLTBackwardErrorBound_eq_epsilon_mul_productEntry]
  have hprod_nonneg :
      0 ‚Č§ higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j :=
    higham11_4_bunchKaufmanProductEntry_nonneg n L_hat D_hat i j
  have hprod_le_source :
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
        |A (ŌÉ i) (ŌÉ j)| +
          higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j :=
    le_add_of_nonneg_left (abs_nonneg _)
  calc
    őĶ * higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j
        ‚Č§ (p * u) * higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j :=
          mul_le_mul_of_nonneg_right hscale hprod_nonneg
    _ ‚Č§ (p * u) *
          (|A (ŌÉ i) (ŌÉ j)| +
            higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j) :=
          mul_le_mul_of_nonneg_left hprod_le_source hpu
    _ = higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u i j := by
          rfl

/-- **Theorem 11.3 printed first-order bridge with norm aggregation**: a
structured `BlockLDLTBackwardError` certificate whose coefficient is bounded by
`p u` supplies source-facing perturbation witnesses bounded componentwise and
in `‚ąě`-norm by the printed first-order envelope. -/
theorem higham11_3_block_ldlt_backward_error_interface_of_BlockLDLTBackwardError_of_printed_first_order_bound_with_norm_bounds
    (n : ‚Ąē) (A L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (ŌÉ : Fin n ‚Üí Fin n) (őĶ p u : ‚ĄĚ) (hőĶ : 0 ‚Č§ őĶ)
    (hscale : őĶ ‚Č§ p * u) (hpu : 0 ‚Č§ p * u)
    (hbe : BlockLDLTBackwardError n A L_hat D_hat ŌÉ őĶ) :
    ‚ąÉ őĒA1 őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n,
        |őĒA1 i j| ‚Č§
          higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u i j) ‚ąß
      (‚ąÄ i j : Fin n,
        |őĒA2 i j| ‚Č§
          higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u i j) ‚ąß
      infNorm őĒA1 ‚Č§
        infNorm (higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u) ‚ąß
      infNorm őĒA2 ‚Č§
        infNorm (higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u) ‚ąß
      (‚ąÄ i j : Fin n,
        ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
          L_hat i k‚āĀ * D_hat k‚āĀ k‚āā * L_hat j k‚āā =
        A (ŌÉ i) (ŌÉ j) + őĒA1 i j) := by
  obtain ‚ü®őĒA1, őĒA2, hőĒA1, hőĒA2, hLD‚ü© :=
    higham11_3_block_ldlt_backward_error_interface_of_BlockLDLTBackwardError
      n A L_hat D_hat ŌÉ őĶ hőĶ hbe
  have hőĒA1_printed : ‚ąÄ i j : Fin n,
      |őĒA1 i j| ‚Č§
        higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u i j := fun i j =>
    (hőĒA1 i j).trans
      (higham11_3_blockLDLTBackwardErrorBound_le_printedFirstOrderBound
        n A L_hat D_hat ŌÉ őĶ p u i j hscale hpu)
  have hőĒA2_printed : ‚ąÄ i j : Fin n,
      |őĒA2 i j| ‚Č§
        higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u i j := fun i j =>
    (hőĒA2 i j).trans
      (higham11_3_blockLDLTBackwardErrorBound_le_printedFirstOrderBound
        n A L_hat D_hat ŌÉ őĶ p u i j hscale hpu)
  refine ‚ü®őĒA1, őĒA2, hőĒA1_printed, hőĒA2_printed, ?_, ?_, hLD‚ü©
  ¬∑ exact
      higham11_3_infNorm_le_of_componentwise_bound_nonneg n őĒA1
        (higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u)
        (higham11_3_printedFirstOrderBound_nonneg n A L_hat D_hat ŌÉ p u hpu)
        hőĒA1_printed
  ¬∑ exact
      higham11_3_infNorm_le_of_componentwise_bound_nonneg n őĒA2
        (higham11_3_printedFirstOrderBound n A L_hat D_hat ŌÉ p u)
        (higham11_3_printedFirstOrderBound_nonneg n A L_hat D_hat ŌÉ p u hpu)
        hőĒA2_printed

/-- Entrywise row-sum majorants for `|LŐā|`, together with a uniform entry bound
for `|DŐā|`, bound one source product entry of `|LŐā||DŐā||LŐāŠĶÄ|`.  This is the
algebraic handoff used when the remaining Theorem 11.4 proof turns pivot-local
bounds into eq. (4.14)'s product-entry estimate. -/
theorem higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow_i Lrow_j : ‚ĄĚ) (hDmax : 0 ‚Č§ Dmax)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrow_i : (‚ąĎ k : Fin n, |L_hat i k|) ‚Č§ Lrow_i)
    (hrow_j : (‚ąĎ k : Fin n, |L_hat j k|) ‚Č§ Lrow_j) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      Lrow_i * Dmax * Lrow_j := by
  have hLrow_j : 0 ‚Č§ Lrow_j :=
    (Finset.sum_nonneg (fun k _ => abs_nonneg (L_hat j k))).trans hrow_j
  unfold higham11_4_bunchKaufmanProductEntry
  calc
    ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
        |L_hat i k‚āĀ| * |D_hat k‚āĀ k‚āā| * |L_hat j k‚āā|
        ‚Č§ ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
            |L_hat i k‚āĀ| * Dmax * |L_hat j k‚āā| := by
          apply Finset.sum_le_sum
          intro k‚āĀ _
          apply Finset.sum_le_sum
          intro k‚āā _
          have hleft :
              |L_hat i k‚āĀ| * |D_hat k‚āĀ k‚āā| ‚Č§ |L_hat i k‚āĀ| * Dmax :=
            mul_le_mul_of_nonneg_left (hD k‚āĀ k‚āā) (abs_nonneg (L_hat i k‚āĀ))
          exact mul_le_mul_of_nonneg_right hleft (abs_nonneg (L_hat j k‚āā))
    _ ‚Č§ ‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ| * Dmax * Lrow_j := by
          apply Finset.sum_le_sum
          intro k‚āĀ _
          have hscale : 0 ‚Č§ |L_hat i k‚āĀ| * Dmax :=
            mul_nonneg (abs_nonneg _) hDmax
          calc
            ‚ąĎ k‚āā : Fin n, |L_hat i k‚āĀ| * Dmax * |L_hat j k‚āā|
                = (|L_hat i k‚āĀ| * Dmax) * ‚ąĎ k‚āā : Fin n, |L_hat j k‚āā| := by
                  rw [Finset.mul_sum]
            _ ‚Č§ (|L_hat i k‚āĀ| * Dmax) * Lrow_j :=
                mul_le_mul_of_nonneg_left hrow_j hscale
            _ = |L_hat i k‚āĀ| * Dmax * Lrow_j := by ring
    _ = (‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ|) * Dmax * Lrow_j := by
          rw [‚Üź Finset.sum_mul]
          rw [‚Üź Finset.sum_mul]
    _ ‚Č§ Lrow_i * Dmax * Lrow_j := by
          have hscale : 0 ‚Č§ Dmax * Lrow_j := mul_nonneg hDmax hLrow_j
          calc
            (‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ|) * Dmax * Lrow_j
                = (‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ|) * (Dmax * Lrow_j) := by ring
            _ ‚Č§ Lrow_i * (Dmax * Lrow_j) :=
                mul_le_mul_of_nonneg_right hrow_i hscale
            _ = Lrow_i * Dmax * Lrow_j := by ring

/-- Uniform row-sum specialization of
`higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds`. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow : ‚ĄĚ) (hDmax : 0 ‚Č§ Dmax)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrows : ‚ąÄ r : Fin n, (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ Lrow) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      Lrow * Dmax * Lrow :=
  higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds n L_hat D_hat i j
    Dmax Lrow Lrow hDmax hD (hrows i) (hrows j)

/-- Uniform entry bounds for `|LŐā|` imply the row-sum caps consumed by the
Theorem 11.4 product-entry bridge. -/
theorem higham11_4_abs_row_sum_le_card_mul_of_uniform_entry_bound (n : ‚Ąē)
    (L_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (Lmax : ‚ĄĚ)
    (hL : ‚ąÄ i k : Fin n, |L_hat i k| ‚Č§ Lmax) (i : Fin n) :
    (‚ąĎ k : Fin n, |L_hat i k|) ‚Č§ (n : ‚ĄĚ) * Lmax := by
  calc
    (‚ąĎ k : Fin n, |L_hat i k|)
        ‚Č§ ‚ąĎ _k : Fin n, Lmax := by
          exact Finset.sum_le_sum (fun k _ => hL i k)
    _ = (n : ‚ĄĚ) * Lmax := by
          simp

/-- Row-dependent entry bounds for `|LŐā|` imply the row-sum caps consumed by
the Theorem 11.4 product-entry bridge.  This keeps the remaining pivot-path
proof free to derive row-local entry estimates before any uniformization. -/
theorem higham11_4_abs_row_sum_le_card_mul_of_row_entry_bound (n : ‚Ąē)
    (L_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (Lcap : Fin n ‚Üí ‚ĄĚ)
    (hL : ‚ąÄ i k : Fin n, |L_hat i k| ‚Č§ Lcap i) (i : Fin n) :
    (‚ąĎ k : Fin n, |L_hat i k|) ‚Č§ (n : ‚ĄĚ) * Lcap i := by
  calc
    (‚ąĎ k : Fin n, |L_hat i k|)
        ‚Č§ ‚ąĎ _k : Fin n, Lcap i := by
          exact Finset.sum_le_sum (fun k _ => hL i k)
    _ = (n : ‚ĄĚ) * Lcap i := by
          simp

/-- A uniform absolute entry bound over a nonempty matrix supplies
nonnegativity of the bound. -/
theorem higham11_4_nonneg_of_uniform_abs_entry_bound (n : ‚Ąē) (hn : 0 < n)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ i j : Fin n, |M i j| ‚Č§ őļ) :
    0 ‚Č§ őļ :=
  (abs_nonneg (M ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)).trans
    (hentry ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)

/-- Uniform entry caps for `|LŐā|` and `|DŐā|` bound a source product entry of
`|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_entry_bounds (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lmax : ‚ĄĚ) (hDmax : 0 ‚Č§ Dmax)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hL : ‚ąÄ r k : Fin n, |L_hat r k| ‚Č§ Lmax) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      ((n : ‚ĄĚ) * Lmax) * Dmax * ((n : ‚ĄĚ) * Lmax) :=
  higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound n L_hat D_hat i j
    Dmax ((n : ‚ĄĚ) * Lmax) hDmax hD
    (fun r => higham11_4_abs_row_sum_le_card_mul_of_uniform_entry_bound n
      L_hat Lmax hL r)

/-- Row-dependent entry caps for `|LŐā|` and a uniform `DŐā` entry cap bound a
source product entry of `|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductEntry_le_row_entry_bounds (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax : ‚ĄĚ) (Lcap : Fin n ‚Üí ‚ĄĚ) (hDmax : 0 ‚Č§ Dmax)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hL : ‚ąÄ r k : Fin n, |L_hat r k| ‚Č§ Lcap r) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      ((n : ‚ĄĚ) * Lcap i) * Dmax * ((n : ‚ĄĚ) * Lcap j) :=
  higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds n L_hat D_hat i j
    Dmax ((n : ‚ĄĚ) * Lcap i) ((n : ‚ĄĚ) * Lcap j) hDmax hD
    (higham11_4_abs_row_sum_le_card_mul_of_row_entry_bound n L_hat Lcap hL i)
    (higham11_4_abs_row_sum_le_card_mul_of_row_entry_bound n L_hat Lcap hL j)

/-- Row-sum product-entry bridge deriving `0‚Č§Dmax` from the nonempty absolute
`DŐā` entry cap. -/
theorem higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds_entry_nonneg
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow_i Lrow_j : ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrow_i : (‚ąĎ k : Fin n, |L_hat i k|) ‚Č§ Lrow_i)
    (hrow_j : (‚ąĎ k : Fin n, |L_hat j k|) ‚Č§ Lrow_j) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      Lrow_i * Dmax * Lrow_j :=
  higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds n L_hat D_hat i j
    Dmax Lrow_i Lrow_j
    (higham11_4_nonneg_of_uniform_abs_entry_bound n hn D_hat Dmax hD)
    hD hrow_i hrow_j

/-- Region-specific row-sum and `DŐā` entry caps produce the first-stage/trailing
product-entry split consumed by the Higham [608, 1997] eqs. (4.11)--(4.14)
aggregation. -/
theorem higham11_4_first_stage_recursive_product_split_of_row_sum_bounds
    (n s : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (Dmax : ‚ĄĚ) (Lrow : Fin n ‚Üí ‚ĄĚ) (localB recB : ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrows : ‚ąÄ r : Fin n, (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ Lrow r)
    (hfirst_budget : ‚ąÄ i j : Fin n, i.val < s ‚ą® j.val < s ‚Üí
      Lrow i * Dmax * Lrow j ‚Č§ localB)
    (htrail_budget : ‚ąÄ i j : Fin n, s ‚Č§ i.val ‚Üí s ‚Č§ j.val ‚Üí
      Lrow i * Dmax * Lrow j ‚Č§ localB + recB) :
    (‚ąÄ i j : Fin n, i.val < s ‚ą® j.val < s ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB) ‚ąß
    (‚ąÄ i j : Fin n, s ‚Č§ i.val ‚Üí s ‚Č§ j.val ‚Üí
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ localB + recB) := by
  refine ‚ü®?_, ?_‚ü©
  ¬∑ intro i j hij
    exact
      (higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds_entry_nonneg
        n hn L_hat D_hat i j Dmax (Lrow i) (Lrow j) hD (hrows i) (hrows j)).trans
        (hfirst_budget i j hij)
  ¬∑ intro i j hi hj
    exact
      (higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds_entry_nonneg
        n hn L_hat D_hat i j Dmax (Lrow i) (Lrow j) hD (hrows i) (hrows j)).trans
        (htrail_budget i j hi hj)

/-- Uniform row-sum product-entry bridge deriving `0‚Č§Dmax` from the nonempty
absolute `DŐā` entry cap. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound_entry_nonneg
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow : ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrows : ‚ąÄ r : Fin n, (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ Lrow) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
