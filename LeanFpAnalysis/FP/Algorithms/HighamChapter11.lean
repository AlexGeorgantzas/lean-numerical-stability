/-- To prove a row predicate at every generic first-trailing endpoint, it
suffices to prove it at the pivot-specific `1 √ó 1` and `2 √ó 2` endpoint forms.
-/
theorem higham11_7_tridiagonalPath_firstTrailingIndex_rows_of_one_two
    (k : ‚Ąē) (step : Fin k ‚Üí PivotSize)
    (P : Fin (higham11_7_tridiagonalPathPivotSpan k step + 1) ‚Üí Prop)
    (hone :
      ‚ąÄ t : Fin k, ‚ąÄ hstep : step t = PivotSize.one,
        P (higham11_7_tridiagonalPathFirstTrailingIndex_one k step t hstep))
