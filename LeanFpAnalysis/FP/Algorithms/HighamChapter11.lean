/-- **Theorem 11.3 row-sum bridge**: a nonnegative entrywise perturbation
envelope bounds the corresponding infinity norm. -/
theorem higham11_3_infNorm_le_of_componentwise_bound_nonneg (n : ‚Ąē)
    (őĒA B : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hB_nonneg : ‚ąÄ i j : Fin n, 0 ‚Č§ B i j)
    (hőĒ : ‚ąÄ i j : Fin n, |őĒA i j| ‚Č§ B i j) :
    infNorm őĒA ‚Č§ infNorm B := by
  apply infNorm_le_of_row_sum_le
  ¬∑ intro i
    calc
      (‚ąĎ j : Fin n, |őĒA i j|)
          ‚Č§ ‚ąĎ j : Fin n, B i j := Finset.sum_le_sum (fun j _ => hőĒ i j)
      _ = ‚ąĎ j : Fin n, |B i j| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_of_nonneg (hB_nonneg i j)]
      _ ‚Č§ infNorm B := row_sum_le_infNorm B i
  ¬∑ exact infNorm_nonneg B

