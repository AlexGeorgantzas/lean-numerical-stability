/-- Aasen growth factor `rho_n = max_ij |t_ij| / max_ij |a_ij|`. -/
noncomputable def higham11_8_aasenGrowthFactor
    (Tmax Amax : ‚ĄĚ) : ‚ĄĚ :=
  Tmax / Amax

/-- The printed Aasen growth-factor bound `rho_n <= 4^(n-2)`. -/
