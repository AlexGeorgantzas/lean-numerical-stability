      (2 * γ_solve + γ_solve ^ 2) * (κLhat * κLhatT) +
      (1 + 2 * γ_solve + γ_solve ^ 2) *
        (κLhat * κmid * κLhatT) ≤
      ((n - 1 : ℕ) : ℝ) ^ 2 * γ15n25 := by
  let α : ℝ := ((n - 1 : ℕ) : ℝ) ^ 2
  have hα : 0 ≤ α := by
    dsimp [α]
