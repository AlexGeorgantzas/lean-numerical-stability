    (hLhat_lower : ∀ i j : Fin n, i.val < j.val → L_hat i j = 0)
    (hT_L_diag : ∀ i : Fin n, L_T_hat i i ≠ 0)
    (hT_U_diag : ∀ i : Fin n, U_T_hat i i ≠ 0)
