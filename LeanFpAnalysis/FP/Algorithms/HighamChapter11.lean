/-- **Equation (11.6)**, the partial-pivoting example matrix. -/
noncomputable def higham11_6_partialPivotExampleA
    (őĶ : ‚ĄĚ) : Fin 3 ‚Üí Fin 3 ‚Üí ‚ĄĚ :=
  fun i j =>
    if i.val = 0 ‚ąß j.val = 1 then őĶ
    else if i.val = 1 ‚ąß j.val = 0 then őĶ
    else if i.val = 1 ‚ąß j.val = 2 then 1
    else if i.val = 2 ‚ąß j.val = 1 then 1
    else if i.val = 2 ‚ąß j.val = 2 then 1
    else 0

/-- **Equation (11.6)**, the displayed lower triangular factor. -/
noncomputable def higham11_6_partialPivotExampleL
    (őĶ : ‚ĄĚ) : Fin 3 ‚Üí Fin 3 ‚Üí ‚ĄĚ :=
  fun i j =>
    if i.val = j.val then 1
    else if i.val = 2 ‚ąß j.val = 0 then 1 / őĶ
    else 0

/-- **Equation (11.6)**, the displayed block diagonal factor. -/
noncomputable def higham11_6_partialPivotExampleD
    (őĶ : ‚ĄĚ) : Fin 3 ‚Üí Fin 3 ‚Üí ‚ĄĚ :=
  fun i j =>
    if i.val = 0 ‚ąß j.val = 1 then őĶ
    else if i.val = 1 ‚ąß j.val = 0 then őĶ
    else if i.val = 2 ‚ąß j.val = 2 then 1
    else 0

/-- **Equation (11.6)** verified algebraically:
`A = L D L^T` for `őĶ ‚Č† 0`. -/
theorem higham11_6_partialPivotExample_factorization
    (őĶ : ‚ĄĚ) (hőĶ : őĶ ‚Č† 0) :
    ‚ąÄ i j : Fin 3,
      ‚ąĎ k‚āĀ : Fin 3, ‚ąĎ k‚āā : Fin 3,
        higham11_6_partialPivotExampleL őĶ i k‚āĀ *
          higham11_6_partialPivotExampleD őĶ k‚āĀ k‚āā *
          higham11_6_partialPivotExampleL őĶ j k‚āā =
      higham11_6_partialPivotExampleA őĶ i j := by
  intro i j
  fin_cases i <;> fin_cases j <;>
    simp [Fin.sum_univ_three, higham11_6_partialPivotExampleA, higham11_6_partialPivotExampleL,
      higham11_6_partialPivotExampleD, hőĶ]

/-- The Higham [1997] max-entry bound used in the proof of Theorem 11.4:
`|| |L||D||L^T| ||_M <= 36 n rho_n ||A||_M`. -/
def higham11_4_bunchKaufmanMaxEntryProductBound
    (n : ‚Ąē) (productMax ŌĀ_n Amax : ‚ĄĚ) : Prop :=
  productMax ‚Č§ 36 * (n : ‚ĄĚ) * ŌĀ_n * Amax

/-- The `(i,j)` entry of the nonnegative product `|LŐā||DŐā||LŐāŠĶÄ|` used in
Theorem 11.4. -/
noncomputable def higham11_4_bunchKaufmanProductEntry (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) : ‚ĄĚ :=
  ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
    |L_hat i k‚āĀ| * |D_hat k‚āĀ k‚āā| * |L_hat j k‚āā|

/-- The matrix product `|LŐā||DŐā||LŐāŠĶÄ|` from Higham [608, 1997], eq. (4.14),
written with the project matrix product primitives. -/
noncomputable def higham11_4_absLDLTProduct (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ :=
  matMul n (matMul n (absMatrix n L_hat) (absMatrix n D_hat))
    (absMatrix n (fun r c => L_hat c r))

/-- The expanded double-sum product entry is exactly the `(i,j)` entry of
`|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j =
      higham11_4_absLDLTProduct n L_hat D_hat i j := by
  unfold higham11_4_bunchKaufmanProductEntry higham11_4_absLDLTProduct
  dsimp [matMul, absMatrix]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro k‚āā _
  rw [Finset.sum_mul]

/-- Each entry of `|LŐā||DŐā||LŐāŠĶÄ|` is nonnegative. -/
theorem higham11_4_bunchKaufmanProductEntry_nonneg (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) :
    0 ‚Č§ higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j := by
  unfold higham11_4_bunchKaufmanProductEntry
  exact Finset.sum_nonneg (fun k‚āĀ _ =>
    Finset.sum_nonneg (fun k‚āā _ =>
      mul_nonneg (mul_nonneg (abs_nonneg _) (abs_nonneg _)) (abs_nonneg _)))

/-- Entrywise row-sum majorants for `|LŐā|`, together with a uniform entry bound
for `|DŐā|`, bound one source product entry of `|LŐā||DŐā||LŐāŠĶÄ|`.  This is the
algebraic handoff used when the remaining Theorem 11.4 proof turns pivot-local
bounds into eq. (4.14)'s product-entry estimate. -/
theorem higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow_i Lrow_j : ‚ĄĚ) (hDmax : 0 ‚Č§ Dmax)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrow_i : (‚ąĎ k : Fin n, |L_hat i k|) ‚Č§ Lrow_i)
    (hrow_j : (‚ąĎ k : Fin n, |L_hat j k|) ‚Č§ Lrow_j) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      Lrow_i * Dmax * Lrow_j := by
  have hLrow_j : 0 ‚Č§ Lrow_j :=
    (Finset.sum_nonneg (fun k _ => abs_nonneg (L_hat j k))).trans hrow_j
  unfold higham11_4_bunchKaufmanProductEntry
  calc
    ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
        |L_hat i k‚āĀ| * |D_hat k‚āĀ k‚āā| * |L_hat j k‚āā|
        ‚Č§ ‚ąĎ k‚āĀ : Fin n, ‚ąĎ k‚āā : Fin n,
            |L_hat i k‚āĀ| * Dmax * |L_hat j k‚āā| := by
          apply Finset.sum_le_sum
          intro k‚āĀ _
          apply Finset.sum_le_sum
          intro k‚āā _
          have hleft :
              |L_hat i k‚āĀ| * |D_hat k‚āĀ k‚āā| ‚Č§ |L_hat i k‚āĀ| * Dmax :=
            mul_le_mul_of_nonneg_left (hD k‚āĀ k‚āā) (abs_nonneg (L_hat i k‚āĀ))
          exact mul_le_mul_of_nonneg_right hleft (abs_nonneg (L_hat j k‚āā))
    _ ‚Č§ ‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ| * Dmax * Lrow_j := by
          apply Finset.sum_le_sum
          intro k‚āĀ _
          have hscale : 0 ‚Č§ |L_hat i k‚āĀ| * Dmax :=
            mul_nonneg (abs_nonneg _) hDmax
          calc
            ‚ąĎ k‚āā : Fin n, |L_hat i k‚āĀ| * Dmax * |L_hat j k‚āā|
                = (|L_hat i k‚āĀ| * Dmax) * ‚ąĎ k‚āā : Fin n, |L_hat j k‚āā| := by
                  rw [Finset.mul_sum]
            _ ‚Č§ (|L_hat i k‚āĀ| * Dmax) * Lrow_j :=
                mul_le_mul_of_nonneg_left hrow_j hscale
            _ = |L_hat i k‚āĀ| * Dmax * Lrow_j := by ring
    _ = (‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ|) * Dmax * Lrow_j := by
          rw [‚Üź Finset.sum_mul]
          rw [‚Üź Finset.sum_mul]
    _ ‚Č§ Lrow_i * Dmax * Lrow_j := by
          have hscale : 0 ‚Č§ Dmax * Lrow_j := mul_nonneg hDmax hLrow_j
          calc
            (‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ|) * Dmax * Lrow_j
                = (‚ąĎ k‚āĀ : Fin n, |L_hat i k‚āĀ|) * (Dmax * Lrow_j) := by ring
            _ ‚Č§ Lrow_i * (Dmax * Lrow_j) :=
                mul_le_mul_of_nonneg_right hrow_i hscale
            _ = Lrow_i * Dmax * Lrow_j := by ring

/-- Uniform row-sum specialization of
`higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds`. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow : ‚ĄĚ) (hDmax : 0 ‚Č§ Dmax)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrows : ‚ąÄ r : Fin n, (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ Lrow) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      Lrow * Dmax * Lrow :=
  higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds n L_hat D_hat i j
    Dmax Lrow Lrow hDmax hD (hrows i) (hrows j)

/-- Uniform entry bounds for `|LŐā|` imply the row-sum caps consumed by the
Theorem 11.4 product-entry bridge. -/
theorem higham11_4_abs_row_sum_le_card_mul_of_uniform_entry_bound (n : ‚Ąē)
    (L_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (Lmax : ‚ĄĚ)
    (hL : ‚ąÄ i k : Fin n, |L_hat i k| ‚Č§ Lmax) (i : Fin n) :
    (‚ąĎ k : Fin n, |L_hat i k|) ‚Č§ (n : ‚ĄĚ) * Lmax := by
  calc
    (‚ąĎ k : Fin n, |L_hat i k|)
        ‚Č§ ‚ąĎ _k : Fin n, Lmax := by
          exact Finset.sum_le_sum (fun k _ => hL i k)
    _ = (n : ‚ĄĚ) * Lmax := by
          simp

/-- A uniform absolute entry bound over a nonempty matrix supplies
nonnegativity of the bound. -/
theorem higham11_4_nonneg_of_uniform_abs_entry_bound (n : ‚Ąē) (hn : 0 < n)
    (M : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (őļ : ‚ĄĚ)
    (hentry : ‚ąÄ i j : Fin n, |M i j| ‚Č§ őļ) :
    0 ‚Č§ őļ :=
  (abs_nonneg (M ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)).trans
    (hentry ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)

/-- Uniform entry caps for `|LŐā|` and `|DŐā|` bound a source product entry of
`|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_entry_bounds (n : ‚Ąē)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lmax : ‚ĄĚ) (hDmax : 0 ‚Č§ Dmax)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hL : ‚ąÄ r k : Fin n, |L_hat r k| ‚Č§ Lmax) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      ((n : ‚ĄĚ) * Lmax) * Dmax * ((n : ‚ĄĚ) * Lmax) :=
  higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound n L_hat D_hat i j
    Dmax ((n : ‚ĄĚ) * Lmax) hDmax hD
    (fun r => higham11_4_abs_row_sum_le_card_mul_of_uniform_entry_bound n
      L_hat Lmax hL r)

/-- Row-sum product-entry bridge deriving `0‚Č§Dmax` from the nonempty absolute
`DŐā` entry cap. -/
theorem higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds_entry_nonneg
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow_i Lrow_j : ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrow_i : (‚ąĎ k : Fin n, |L_hat i k|) ‚Č§ Lrow_i)
    (hrow_j : (‚ąĎ k : Fin n, |L_hat j k|) ‚Č§ Lrow_j) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      Lrow_i * Dmax * Lrow_j :=
  higham11_4_bunchKaufmanProductEntry_le_row_sum_bounds n L_hat D_hat i j
    Dmax Lrow_i Lrow_j
    (higham11_4_nonneg_of_uniform_abs_entry_bound n hn D_hat Dmax hD)
    hD hrow_i hrow_j

/-- Uniform row-sum product-entry bridge deriving `0‚Č§Dmax` from the nonempty
absolute `DŐā` entry cap. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound_entry_nonneg
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lrow : ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hrows : ‚ąÄ r : Fin n, (‚ąĎ k : Fin n, |L_hat r k|) ‚Č§ Lrow) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      Lrow * Dmax * Lrow :=
  higham11_4_bunchKaufmanProductEntry_le_uniform_row_sum_bound n L_hat D_hat i j
    Dmax Lrow
    (higham11_4_nonneg_of_uniform_abs_entry_bound n hn D_hat Dmax hD)
    hD hrows

/-- Uniform entry product-entry bridge deriving `0‚Č§Dmax` from the nonempty
absolute `DŐā` entry cap. -/
theorem higham11_4_bunchKaufmanProductEntry_le_uniform_entry_bounds_entry_nonneg
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n)
    (Dmax Lmax : ‚ĄĚ)
    (hD : ‚ąÄ k‚āĀ k‚āā : Fin n, |D_hat k‚āĀ k‚āā| ‚Č§ Dmax)
    (hL : ‚ąÄ r k : Fin n, |L_hat r k| ‚Č§ Lmax) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      ((n : ‚ĄĚ) * Lmax) * Dmax * ((n : ‚ĄĚ) * Lmax) :=
  higham11_4_bunchKaufmanProductEntry_le_uniform_entry_bounds n L_hat D_hat i j
    Dmax Lmax
    (higham11_4_nonneg_of_uniform_abs_entry_bound n hn D_hat Dmax hD)
    hD hL

/-- **Theorem 11.4 max-entry norm target**: the finite max-entry norm of
`|LŐā||DŐā||LŐāŠĶÄ|`, written as a finite supremum over entry pairs.  The positive
dimension hypothesis supplies the nonempty finite set for `Finset.sup'`. -/
noncomputable def higham11_4_bunchKaufmanProductMax (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) : ‚ĄĚ :=
  Finset.sup' (Finset.univ : Finset (Fin n √ó Fin n))
    (by exact ‚ü®(‚ü®0, hn‚ü©, ‚ü®0, hn‚ü©), Finset.mem_univ _‚ü©)
    (fun p => higham11_4_bunchKaufmanProductEntry n L_hat D_hat p.1 p.2)

/-- Every entry of `|LŐā||DŐā||LŐāŠĶÄ|` is bounded by its finite max-entry norm. -/
theorem higham11_4_bunchKaufmanProductEntry_le_productMax (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) :
    higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§
      higham11_4_bunchKaufmanProductMax n hn L_hat D_hat := by
  unfold higham11_4_bunchKaufmanProductMax
  exact Finset.le_sup'
    (fun p : Fin n √ó Fin n => higham11_4_bunchKaufmanProductEntry n L_hat D_hat p.1 p.2)
    (Finset.mem_univ (i, j))

/-- Every matrix-product entry of `|LŐā||DŐā||LŐāŠĶÄ|` is bounded by the same finite
max-entry norm. -/
theorem higham11_4_absLDLTProduct_entry_le_productMax (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) :
    higham11_4_absLDLTProduct n L_hat D_hat i j ‚Č§
      higham11_4_bunchKaufmanProductMax n hn L_hat D_hat := by
  rw [‚Üź higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
  exact higham11_4_bunchKaufmanProductEntry_le_productMax n hn L_hat D_hat i j

/-- The finite max-entry norm of `|LŐā||DŐā||LŐāŠĶÄ|` is nonnegative. -/
theorem higham11_4_bunchKaufmanProductMax_nonneg (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) :
    0 ‚Č§ higham11_4_bunchKaufmanProductMax n hn L_hat D_hat :=
  (higham11_4_bunchKaufmanProductEntry_nonneg n L_hat D_hat ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©).trans
    (higham11_4_bunchKaufmanProductEntry_le_productMax n hn L_hat D_hat ‚ü®0, hn‚ü© ‚ü®0, hn‚ü©)

/-- The finite max-entry product is the least scalar that bounds every entry of
`|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductMax_le_iff (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (B : ‚ĄĚ) :
    higham11_4_bunchKaufmanProductMax n hn L_hat D_hat ‚Č§ B ‚ÜĒ
      ‚ąÄ i j : Fin n, higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ B := by
  constructor
  ¬∑ intro hB i j
    exact (higham11_4_bunchKaufmanProductEntry_le_productMax n hn L_hat D_hat i j).trans hB
  ¬∑ intro hentries
    unfold higham11_4_bunchKaufmanProductMax
    exact Finset.sup'_le _ _ (fun p _ => hentries p.1 p.2)

/-- The finite max-entry product is equivalently the least scalar that bounds
the project matrix-product entries of `|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductMax_le_iff_absLDLTProduct (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (B : ‚ĄĚ) :
    higham11_4_bunchKaufmanProductMax n hn L_hat D_hat ‚Č§ B ‚ÜĒ
      ‚ąÄ i j : Fin n, higham11_4_absLDLTProduct n L_hat D_hat i j ‚Č§ B := by
  rw [higham11_4_bunchKaufmanProductMax_le_iff n hn L_hat D_hat B]
  constructor
  ¬∑ intro hentries i j
    simpa [higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
      using hentries i j
  ¬∑ intro hentries i j
    simpa [higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
      using hentries i j

/-- The specialized finite maximum used for Theorem 11.4 is exactly the
repository max-entry norm of the matrix product `|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_bunchKaufmanProductMax_eq_maxEntryNorm_absLDLTProduct
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) :
    higham11_4_bunchKaufmanProductMax n hn L_hat D_hat =
      maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) := by
  apply le_antisymm
  ¬∑ rw [higham11_4_bunchKaufmanProductMax_le_iff_absLDLTProduct n hn L_hat D_hat]
    intro i j
    have hnonneg : 0 ‚Č§ higham11_4_absLDLTProduct n L_hat D_hat i j := by
      rw [‚Üź higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
      exact higham11_4_bunchKaufmanProductEntry_nonneg n L_hat D_hat i j
    calc
      higham11_4_absLDLTProduct n L_hat D_hat i j
          = |higham11_4_absLDLTProduct n L_hat D_hat i j| := by
            rw [abs_of_nonneg hnonneg]
      _ ‚Č§ maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) :=
          entry_le_maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) i j
  ¬∑ apply maxEntryNorm_le_of_entry_le_bound
    intro i j
    have hnonneg : 0 ‚Č§ higham11_4_absLDLTProduct n L_hat D_hat i j := by
      rw [‚Üź higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
      exact higham11_4_bunchKaufmanProductEntry_nonneg n L_hat D_hat i j
    calc
      |higham11_4_absLDLTProduct n L_hat D_hat i j|
          = higham11_4_absLDLTProduct n L_hat D_hat i j := abs_of_nonneg hnonneg
      _ ‚Č§ higham11_4_bunchKaufmanProductMax n hn L_hat D_hat :=
          higham11_4_absLDLTProduct_entry_le_productMax n hn L_hat D_hat i j

/-- Pointwise matrix-product estimates package directly into the source-style
max-entry norm estimate for `|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_maxEntryNorm_absLDLTProduct_le_of_absLDLTProduct_entries
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (B : ‚ĄĚ)
    (hentries : ‚ąÄ i j : Fin n, higham11_4_absLDLTProduct n L_hat D_hat i j ‚Č§ B) :
    maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) ‚Č§ B := by
  apply maxEntryNorm_le_of_entry_le_bound
  intro i j
  have hnonneg : 0 ‚Č§ higham11_4_absLDLTProduct n L_hat D_hat i j := by
    rw [‚Üź higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
    exact higham11_4_bunchKaufmanProductEntry_nonneg n L_hat D_hat i j
  calc
    |higham11_4_absLDLTProduct n L_hat D_hat i j|
        = higham11_4_absLDLTProduct n L_hat D_hat i j := abs_of_nonneg hnonneg
    _ ‚Č§ B := hentries i j

/-- Each matrix-product entry of `|LŐā||DŐā||LŐāŠĶÄ|` is bounded by the specialized
source max-entry norm. -/
theorem higham11_4_absLDLTProduct_entry_le_maxEntryNorm (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (i j : Fin n) :
    higham11_4_absLDLTProduct n L_hat D_hat i j ‚Č§
      maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) := by
  have hnonneg : 0 ‚Č§ higham11_4_absLDLTProduct n L_hat D_hat i j := by
    rw [‚Üź higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
    exact higham11_4_bunchKaufmanProductEntry_nonneg n L_hat D_hat i j
  calc
    higham11_4_absLDLTProduct n L_hat D_hat i j
        = |higham11_4_absLDLTProduct n L_hat D_hat i j| := by
          rw [abs_of_nonneg hnonneg]
    _ ‚Č§ maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) :=
        entry_le_maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) i j

/-- For the nonnegative product matrix `|LŐā||DŐā||LŐāŠĶÄ|`, the max-entry norm
bound is equivalent to the pointwise source product-entry bounds. -/
theorem higham11_4_maxEntryNorm_absLDLTProduct_le_iff (n : ‚Ąē) (hn : 0 < n)
    (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (B : ‚ĄĚ) :
    maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) ‚Č§ B ‚ÜĒ
      ‚ąÄ i j : Fin n, higham11_4_absLDLTProduct n L_hat D_hat i j ‚Č§ B := by
  constructor
  ¬∑ intro hB i j
    exact
      (higham11_4_absLDLTProduct_entry_le_maxEntryNorm n hn L_hat D_hat i j).trans hB
  ¬∑ intro hentries
    exact
      higham11_4_maxEntryNorm_absLDLTProduct_le_of_absLDLTProduct_entries
        n hn L_hat D_hat B hentries

/-- Expanded double-sum form of
`higham11_4_maxEntryNorm_absLDLTProduct_le_iff`. -/
theorem higham11_4_maxEntryNorm_absLDLTProduct_le_iff_product_entries
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (B : ‚ĄĚ) :
    maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) ‚Č§ B ‚ÜĒ
      ‚ąÄ i j : Fin n, higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ B := by
  rw [higham11_4_maxEntryNorm_absLDLTProduct_le_iff n hn L_hat D_hat B]
  constructor
  ¬∑ intro hentries i j
    simpa [higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
      using hentries i j
  ¬∑ intro hentries i j
    simpa [‚Üź higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
      using hentries i j

/-- Pointwise expanded double-sum estimates package directly into the
source-style max-entry norm estimate for `|LŐā||DŐā||LŐāŠĶÄ|`. -/
theorem higham11_4_maxEntryNorm_absLDLTProduct_le_of_product_entries
    (n : ‚Ąē) (hn : 0 < n) (L_hat D_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (B : ‚ĄĚ)
    (hentries : ‚ąÄ i j : Fin n,
      higham11_4_bunchKaufmanProductEntry n L_hat D_hat i j ‚Č§ B) :
    maxEntryNorm hn (higham11_4_absLDLTProduct n L_hat D_hat) ‚Č§ B :=
  higham11_4_maxEntryNorm_absLDLTProduct_le_of_absLDLTProduct_entries
    n hn L_hat D_hat B (fun i j => by
      simpa [‚Üź higham11_4_bunchKaufmanProductEntry_eq_absLDLTProduct n L_hat D_hat i j]
        using hentries i j)

/-- Uniform row-sum and `DŐā` entry caps package into the source max-entry norm
