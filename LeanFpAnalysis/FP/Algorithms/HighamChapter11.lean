  apply infNorm_le_of_row_sum_le
  ¬∑ intro i
    calc
      (‚ąĎ j : Fin n, |őĒA i j|)
          ‚Č§ ‚ąĎ j : Fin n, B i j := Finset.sum_le_sum (fun j _ => hőĒ i j)
      _ = ‚ąĎ j : Fin n, |B i j| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_of_nonneg (hB_nonneg i j)]
      _ ‚Č§ infNorm B := row_sum_le_infNorm B i
  ¬∑ exact infNorm_nonneg B

