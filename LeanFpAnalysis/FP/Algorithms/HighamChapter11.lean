    (htrail : ∀ i j : Fin n, s ≤ i.val → s ≤ j.val →
      |D_hat i j| ≤ ρ_rec * Amax) :
    ∀ i j : Fin n, |D_hat i j| ≤ ρ_n * Amax :=
