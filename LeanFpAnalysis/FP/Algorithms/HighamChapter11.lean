/-- Product-size helper: two factor caps by the same nonnegative scalar imply
the corresponding square cap. -/
theorem higham11_8_product_square_bound_of_factor_caps
    (m őļLeft őļRight : ‚ĄĚ) (hm : 0 ‚Č§ m)
    (hőļRight : 0 ‚Č§ őļRight) (hleft : őļLeft ‚Č§ m) (hright : őļRight ‚Č§ m) :
    őļLeft * őļRight ‚Č§ m ^ 2 := by
  have hmul : őļLeft * őļRight ‚Č§ m * m :=
    mul_le_mul hleft hright hőļRight hm
  simpa [pow_two] using hmul

/-- Product-size helper for the exact-product Aasen route.  Individual caps on
the exact and computed-relative outer factors imply the two base square caps
consumed by the `T_hat` exact-radius wrappers. -/
theorem higham11_8_aasen_base_square_bounds_of_factor_caps
    (n : ‚Ąē) (ő≥_factor őļL őļLT : ‚ĄĚ)
    (hő≥_factor : 0 ‚Č§ ő≥_factor)
    (hőļL : 0 ‚Č§ őļL) (hőļLT : 0 ‚Č§ őļLT)
    (hőļL_cap : őļL ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ))
    (hőļLT_cap : őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ))
    (hrelL_cap : (1 + ő≥_factor) * őļL ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ))
    (hrelLT_cap : (1 + ő≥_factor) * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ)) :
    (őļL * őļLT ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) ‚ąß
      (((1 + ő≥_factor) * őļL) * ((1 + ő≥_factor) * őļLT) ‚Č§
        ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) := by
  let m : ‚ĄĚ := ((n - 1 : ‚Ąē) : ‚ĄĚ)
  have hm : 0 ‚Č§ m := by
    dsimp [m]
    exact Nat.cast_nonneg _
  have h1ő≥ : 0 ‚Č§ 1 + ő≥_factor := by nlinarith
  have hrelL_nonneg : 0 ‚Č§ (1 + ő≥_factor) * őļL :=
    mul_nonneg h1ő≥ hőļL
  have hrelLT_nonneg : 0 ‚Č§ (1 + ő≥_factor) * őļLT :=
    mul_nonneg h1ő≥ hőļLT
  refine ‚ü®?_, ?_‚ü©
  ¬∑ exact
      higham11_8_product_square_bound_of_factor_caps m őļL őļLT hm hőļLT
        (by simpa [m] using hőļL_cap) (by simpa [m] using hőļLT_cap)
  ¬∑ exact
      higham11_8_product_square_bound_of_factor_caps m
        ((1 + ő≥_factor) * őļL) ((1 + ő≥_factor) * őļLT) hm hrelLT_nonneg
        (by simpa [m] using hrelL_cap) (by simpa [m] using hrelLT_cap)

