theorem higham11_4_first_stage_recursive_uniform_six_rho_budget
    (n s : ‚Ąē) (ŌĀ_n Amax : ‚ĄĚ) (hŌĀ : 0 ‚Č§ ŌĀ_n) (hAmax : 0 ‚Č§ Amax) :
