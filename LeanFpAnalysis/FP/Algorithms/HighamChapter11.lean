/-- **Theorem 11.7 finite solve-delta sum aggregation**.  A finite family of
solve-side residual matrices with printed per-term coefficients can be summed
directly into the source-facing perturbation interface once the final summed
solve equation is available.  This support-free form is useful after all
path-local residuals have already been embedded into one ambient system. -/
theorem higham11_7_tridiagonal_backward_error_interface_of_sum_solve_delta_infNorm
    (n k : ‚Ąē) (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (b x_hat : Fin n ‚Üí ‚ĄĚ)
    (E : Fin k ‚Üí Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (c : Fin k ‚Üí ‚ĄĚ) (u : ‚ĄĚ)
    (hc : ‚ąÄ t : Fin k, 0 ‚Č§ c t) (hu : 0 ‚Č§ u)
    (hbound : ‚ąÄ t : Fin k, ‚ąÄ i j : Fin n,
      |E t i j| ‚Č§ c t * u * infNorm A)
    (hsolve : ‚ąÄ i : Fin n,
      ‚ąĎ j : Fin n, (A i j + (‚ąĎ t : Fin k, E t i j)) * x_hat j = b i) :
    ‚ąÉ őĒA1 őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |őĒA1 i j| ‚Č§ (‚ąĎ t : Fin k, c t) * u * infNorm A) ‚ąß
      (‚ąÄ i j : Fin n, |őĒA2 i j| ‚Č§ (‚ąĎ t : Fin k, c t) * u * infNorm A) ‚ąß
      infNorm őĒA1 ‚Č§ (n : ‚ĄĚ) * (‚ąĎ t : Fin k, c t) * u * infNorm A ‚ąß
      infNorm őĒA2 ‚Č§ (n : ‚ĄĚ) * (‚ąĎ t : Fin k, c t) * u * infNorm A ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + őĒA2 i j) * x_hat j = b i) := by
  let őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun i j => ‚ąĎ t : Fin k, E t i j
  have hsum :
      (‚ąĎ t : Fin k, c t * u * infNorm A) =
        (‚ąĎ t : Fin k, c t) * u * infNorm A := by
    simp [Finset.sum_mul, mul_assoc]
  have hőĒA2bound : ‚ąÄ i j : Fin n,
      |őĒA2 i j| ‚Č§ (‚ąĎ t : Fin k, c t) * u * infNorm A := by
    intro i j
    calc
      |őĒA2 i j| = |‚ąĎ t : Fin k, E t i j| := rfl
      _ ‚Č§ ‚ąĎ t : Fin k, |E t i j| := Finset.abs_sum_le_sum_abs _ _
      _ ‚Č§ ‚ąĎ t : Fin k, c t * u * infNorm A :=
        Finset.sum_le_sum (fun t _ => hbound t i j)
      _ = (‚ąĎ t : Fin k, c t) * u * infNorm A := hsum
  exact
    higham11_7_tridiagonal_backward_error_interface_of_solve_delta_infNorm_with_norm_bounds
      n A b x_hat (‚ąĎ t : Fin k, c t) u
      (Finset.sum_nonneg (fun t _ => hc t)) hu
      ‚ü®őĒA2, hőĒA2bound, hsolve‚ü©

/-- **Theorem 11.7 finite solve-delta sum aggregation, coefficient majorant
form**.  This support-free endpoint replaces the accumulated coefficient
`‚ąĎ t, c t` by a supplied printed constant `C`. -/
theorem higham11_7_tridiagonal_backward_error_interface_of_sum_solve_delta_infNorm_of_coeff_sum_le
    (n k : ‚Ąē) (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (b x_hat : Fin n ‚Üí ‚ĄĚ)
    (E : Fin k ‚Üí Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (c : Fin k ‚Üí ‚ĄĚ) (C u : ‚ĄĚ)
    (hc : ‚ąÄ t : Fin k, 0 ‚Č§ c t) (hu : 0 ‚Č§ u)
    (hC : (‚ąĎ t : Fin k, c t) ‚Č§ C)
    (hbound : ‚ąÄ t : Fin k, ‚ąÄ i j : Fin n,
      |E t i j| ‚Č§ c t * u * infNorm A)
    (hsolve : ‚ąÄ i : Fin n,
      ‚ąĎ j : Fin n, (A i j + (‚ąĎ t : Fin k, E t i j)) * x_hat j = b i) :
    ‚ąÉ őĒA1 őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |őĒA1 i j| ‚Č§ C * u * infNorm A) ‚ąß
      (‚ąÄ i j : Fin n, |őĒA2 i j| ‚Č§ C * u * infNorm A) ‚ąß
      infNorm őĒA1 ‚Č§ (n : ‚ĄĚ) * C * u * infNorm A ‚ąß
      infNorm őĒA2 ‚Č§ (n : ‚ĄĚ) * C * u * infNorm A ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + őĒA2 i j) * x_hat j = b i) := by
  let őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ := fun i j => ‚ąĎ t : Fin k, E t i j
  have hC_nonneg : 0 ‚Č§ C :=
    (Finset.sum_nonneg (fun t _ => hc t)).trans hC
  have hbudget :
      (‚ąĎ t : Fin k, c t) * u * infNorm A ‚Č§ C * u * infNorm A := by
    exact mul_le_mul_of_nonneg_right
      (mul_le_mul_of_nonneg_right hC hu) (infNorm_nonneg A)
  have hsum :
      (‚ąĎ t : Fin k, c t * u * infNorm A) =
        (‚ąĎ t : Fin k, c t) * u * infNorm A := by
    simp [Finset.sum_mul, mul_assoc]
  have hőĒA2bound : ‚ąÄ i j : Fin n, |őĒA2 i j| ‚Č§ C * u * infNorm A := by
    intro i j
    calc
      |őĒA2 i j| = |‚ąĎ t : Fin k, E t i j| := rfl
      _ ‚Č§ ‚ąĎ t : Fin k, |E t i j| := Finset.abs_sum_le_sum_abs _ _
      _ ‚Č§ ‚ąĎ t : Fin k, c t * u * infNorm A :=
        Finset.sum_le_sum (fun t _ => hbound t i j)
      _ = (‚ąĎ t : Fin k, c t) * u * infNorm A := hsum
      _ ‚Č§ C * u * infNorm A := hbudget
  exact
    higham11_7_tridiagonal_backward_error_interface_of_solve_delta_infNorm_with_norm_bounds
      n A b x_hat C u hC_nonneg hu ‚ü®őĒA2, hőĒA2bound, hsolve‚ü©

/-- **Theorem 11.7 finite solve-delta sum aggregation, uniform coefficient
form**.  This support-free endpoint packages a common per-residual coefficient
as the budget `k*c*u*||A||_‚ąě`. -/
theorem higham11_7_tridiagonal_backward_error_interface_of_uniform_sum_solve_delta_infNorm
    (n k : ‚Ąē) (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (b x_hat : Fin n ‚Üí ‚ĄĚ)
    (E : Fin k ‚Üí Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (c u : ‚ĄĚ)
    (hc : 0 ‚Č§ c) (hu : 0 ‚Č§ u)
    (hbound : ‚ąÄ t : Fin k, ‚ąÄ i j : Fin n,
      |E t i j| ‚Č§ c * u * infNorm A)
    (hsolve : ‚ąÄ i : Fin n,
      ‚ąĎ j : Fin n, (A i j + (‚ąĎ t : Fin k, E t i j)) * x_hat j = b i) :
    ‚ąÉ őĒA1 őĒA2 : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      (‚ąÄ i j : Fin n, |őĒA1 i j| ‚Č§ (k : ‚ĄĚ) * c * u * infNorm A) ‚ąß
      (‚ąÄ i j : Fin n, |őĒA2 i j| ‚Č§ (k : ‚ĄĚ) * c * u * infNorm A) ‚ąß
      infNorm őĒA1 ‚Č§ (n : ‚ĄĚ) * ((k : ‚ĄĚ) * c) * u * infNorm A ‚ąß
      infNorm őĒA2 ‚Č§ (n : ‚ĄĚ) * ((k : ‚ĄĚ) * c) * u * infNorm A ‚ąß
      (‚ąÄ i : Fin n, ‚ąĎ j : Fin n, (A i j + őĒA2 i j) * x_hat j = b i) := by
  have hC : (‚ąĎ _t : Fin k, c) ‚Č§ (k : ‚ĄĚ) * c := by
    simp [Finset.sum_const, nsmul_eq_mul]
  simpa [Finset.sum_const, nsmul_eq_mul, mul_assoc] using
    higham11_7_tridiagonal_backward_error_interface_of_sum_solve_delta_infNorm_of_coeff_sum_le
      n k A b x_hat E (fun _ => c) ((k : ‚ĄĚ) * c) u
      (fun _ => hc) hu hC hbound hsolve

/-- **Theorem 11.7 finite supported solve-delta aggregation**.  A same-ambient
family of supported residual matrices with printed coefficients can be summed
