/-- Insert a nonnegative middle factor bounded by `1` into a product already
bounded by the printed Aasen `(n-1)^2` square. -/
theorem higham11_8_triple_product_square_bound_of_middle_le_one
    (n : ‚Ąē) (őļLeft őļMid őļRight : ‚ĄĚ)
    (hőļMid : 0 ‚Č§ őļMid) (hőļMid_le_one : őļMid ‚Č§ 1)
    (hprod : őļLeft * őļRight ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2) :
    őļLeft * őļMid * őļRight ‚Č§ ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 := by
  let őĪ : ‚ĄĚ := ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2
  have hőĪ : 0 ‚Č§ őĪ := by
    dsimp [őĪ]
    exact sq_nonneg _
  have hmul : (őļLeft * őļRight) * őļMid ‚Č§ őĪ * 1 :=
    mul_le_mul (by simpa [őĪ] using hprod) hőļMid_le_one hőļMid hőĪ
  calc
    őļLeft * őļMid * őļRight = (őļLeft * őļRight) * őļMid := by ring
    _ ‚Č§ őĪ * 1 := hmul
    _ = ((n - 1 : ‚Ąē) : ‚ĄĚ) ^ 2 := by simp [őĪ]

/-- Reduce the four exact-product square caps for the concrete Aasen `T_hat`
route to two square caps, when the middle factors `őļT` and `őļmidLU` are each
