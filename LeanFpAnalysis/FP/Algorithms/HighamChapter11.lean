/-! ## Chapter 11 intro and ¬ß11.1 block LDL^T factorization -/

/-- **Equation (11.1)** source predicate:
`P A P^T = L D L^T`, with unit lower triangular `L` and symmetric block
diagonal `D` with diagonal blocks of size one or two. -/
abbrev higham11_1_BlockLDLTSpec (n : ‚Ąē)
    (A L D : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ŌÉ : Fin n ‚Üí Fin n) : Prop :=
  BlockLDLTSpec n A L D ŌÉ

/-- **Equation (11.2)** nonsingularity condition for the first pivot block. -/
def higham11_2_NonsingularPivotBlock
    (s : ‚Ąē) (E E_inv : Fin s ‚Üí Fin s ‚Üí ‚ĄĚ) : Prop :=
  (‚ąÄ i j : Fin s, ‚ąĎ k : Fin s, E i k * E_inv k j = if i = j then 1 else 0) ‚ąß
  (‚ąÄ i j : Fin s, ‚ąĎ k : Fin s, E_inv i k * E k j = if i = j then 1 else 0)

/-- **Equation (11.3)** symmetric Schur complement
`B - C E^{-1} C^T` from the first block LDL^T step. -/
noncomputable def higham11_3_symmetricSchurComplement (m s : ‚Ąē)
    (B : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ)
    (C : Fin m ‚Üí Fin s ‚Üí ‚ĄĚ)
    (E_inv : Fin s ‚Üí Fin s ‚Üí ‚ĄĚ) : Fin m ‚Üí Fin m ‚Üí ‚ĄĚ :=
  fun i j => B i j - ‚ąĎ p : Fin s, ‚ąĎ q : Fin s, C i p * E_inv p q * C j q

/-- **Equation (11.3), `s = 1` exact factorization step**: with pivot `A 0 0 ‚Č† 0`,
the 1√ó1-pivot unit-lower-triangular `L` and block-diagonal `D` (pivot + trailing
Schur complement) reproduce `A` exactly, `‚ąĎ L¬∑D¬∑LŠĶÄ = A`.  The exact base of the
diagonal-pivoting recursion behind Theorem 11.3. -/
theorem higham11_3_oneByOne_step_factorization (m : ‚Ąē)
    (A : Fin (m + 1) ‚Üí Fin (m + 1) ‚Üí ‚ĄĚ)
    (ha : A 0 0 ‚Č† 0) (hsym : ‚ąÄ i : Fin m, A 0 i.succ = A i.succ 0)
    (L D : Fin (m + 1) ‚Üí Fin (m + 1) ‚Üí ‚ĄĚ)
    (hL0 : L 0 0 = 1)
    (hLcol : ‚ąÄ i : Fin m, L i.succ 0 = A i.succ 0 / A 0 0)
    (hL0s : ‚ąÄ j : Fin m, L 0 j.succ = 0)
    (hLtr : ‚ąÄ i j : Fin m, L i.succ j.succ = if i = j then 1 else 0)
    (hD00 : D 0 0 = A 0 0)
    (hD0s : ‚ąÄ j : Fin m, D 0 j.succ = 0)
    (hDs0 : ‚ąÄ i : Fin m, D i.succ 0 = 0)
    (hDtr : ‚ąÄ i j : Fin m, D i.succ j.succ
      = A i.succ j.succ - A i.succ 0 * A 0 j.succ / A 0 0) :
    ‚ąÄ I J : Fin (m + 1),
      (‚ąĎ k‚āĀ, ‚ąĎ k‚āā, L I k‚āĀ * D k‚āĀ k‚āā * L J k‚āā) = A I J :=
  oneByOne_step_factorization m A ha hsym L D hL0 hLcol hL0s hLtr
    hD00 hD0s hDs0 hDtr

/-- **Eq (11.1)/(11.3) inductive step** for the exact block-LDLŠĶÄ recursion: with
the trailing block factorized recursively (`hIH : L_S¬∑D_S¬∑L_SŠĶÄ = S`, the Schur
complement) and first-stage 1√ó1-pivot multipliers, the assembled `L,D` reproduce
`A` exactly.  Iterating gives the exact `PAPŠĶÄ = LDLŠĶÄ` behind Theorem 11.3. -/
theorem higham11_3_blockLDLT_assemble_step (n : ‚Ąē)
    (A : Fin (n + 1) ‚Üí Fin (n + 1) ‚Üí ‚ĄĚ)
    (ha : A 0 0 ‚Č† 0) (hsym : ‚ąÄ i : Fin n, A 0 i.succ = A i.succ 0)
    (S L_S D_S : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hS : ‚ąÄ i j : Fin n, S i j = A i.succ j.succ - A i.succ 0 * A 0 j.succ / A 0 0)
    (hIH : ‚ąÄ i j : Fin n, (‚ąĎ k‚āĀ, ‚ąĎ k‚āā, L_S i k‚āĀ * D_S k‚āĀ k‚āā * L_S j k‚āā) = S i j)
    (L D : Fin (n + 1) ‚Üí Fin (n + 1) ‚Üí ‚ĄĚ)
    (hL0 : L 0 0 = 1)
    (hLcol : ‚ąÄ i : Fin n, L i.succ 0 = A i.succ 0 / A 0 0)
    (hL0s : ‚ąÄ j : Fin n, L 0 j.succ = 0)
    (hLtr : ‚ąÄ i j : Fin n, L i.succ j.succ = L_S i j)
    (hD00 : D 0 0 = A 0 0)
    (hD0s : ‚ąÄ j : Fin n, D 0 j.succ = 0)
    (hDs0 : ‚ąÄ i : Fin n, D i.succ 0 = 0)
    (hDtr : ‚ąÄ i j : Fin n, D i.succ j.succ = D_S i j) :
    ‚ąÄ I J : Fin (n + 1),
      (‚ąĎ k‚āĀ, ‚ąĎ k‚āā, L I k‚āĀ * D k‚āĀ k‚āā * L J k‚āā) = A I J :=
  blockLDLT_assemble_step n A ha hsym S L_S D_S hS hIH L D
    hL0 hLcol hL0s hLtr hD00 hD0s hDs0 hDtr

/-- **Eq (11.1)/(11.2) exact factorization existence** (no-2√ó2-pivot case): a
symmetric `A` all of whose successive Schur-complement pivots are nonzero
(`AllOnePivots`) has an exact `LDLŠĶÄ` factorization `‚ąĎ L¬∑D¬∑LŠĶÄ = A`.  The exact
`PAPŠĶÄ = LDLŠĶÄ` recursion (P = I) underlying Theorem 11.3. -/
theorem higham11_1_exact_blockLDLT_all_oneByOne (n : ‚Ąē) (A : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (hsym : ‚ąÄ i j, A i j = A j i) (hp : AllOnePivots n A) :
    ‚ąÉ L D : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ,
      ‚ąÄ I J, (‚ąĎ k‚āĀ, ‚ąĎ k‚āā, L I k‚āĀ * D k‚āĀ k‚āā * L J k‚āā) = A I J :=
  exact_blockLDLT_all_oneByOne n A hsym hp

/-! ## ¬ß11.1.1 Complete pivoting -/

/-- **Algorithm 11.1** pivoting parameter
`alpha = (1 + sqrt 17) / 8`. -/
noncomputable def higham11_1_bunchParlettAlpha : ‚ĄĚ :=
  bunchParlettAlpha

/-- **Algorithm 11.1** source decision predicate for the first
Bunch-Parlett complete-pivoting step. -/
abbrev higham11_1_BunchParlettCompletePivotChoice
    (őĪ őľ0 őľ1 : ‚ĄĚ) (s : PivotSize) : Prop :=
  BunchParlettCompletePivotChoice őĪ őľ0 őľ1 s

/-- The Bunch-Parlett parameter is the positive root selected from
`4 alpha^2 - alpha - 1 = 0`. -/
theorem higham11_1_bunch_parlett_alpha_root :
    4 * higham11_1_bunchParlettAlpha ^ 2 -
      higham11_1_bunchParlettAlpha - 1 = 0 :=
  bunch_parlett_alpha_root

/-- **¬ß11.1.1 őĪ-derivation**: `őĪ = (1+‚ąö17)/8` is exactly the value balancing the
two single-step growth bounds `(1 + 1/őĪ)¬≤` (two 1√ó1 steps) and `1 + 2/(1‚ąíőĪ)`
(one 2√ó2 step).  Connects `higham11_1_oneByOne_schur_growth` and
`higham11_4_twoByTwo_schur_growth`. -/
theorem higham11_1_growth_balance :
    (1 + 1 / higham11_1_bunchParlettAlpha) ^ 2 =
      1 + 2 / (1 - higham11_1_bunchParlettAlpha) :=
  bunch_parlett_growth_balance

/-- **¬ß11.1.1 growth-factor recursion**: a stage-maximum sequence `r` obeying the
single-step ratio bound `r(k+1) ‚Č§ (1 + 1/őĪ)¬∑r k` (supplied for each stage by
`higham11_1_oneByOne_schur_growth` / `higham11_4_twoByTwo_schur_growth`) satisfies
`r n ‚Č§ (1 + 1/őĪ)^n ¬∑ ŌĀ‚āÄ`, the derivation of the printed `ŌĀ‚āô ‚Č§ (1 + őĪ‚ĀĽ¬Ļ)^{n‚ąí1}`. -/
theorem higham11_1_growth_factor_recursion (őĪ ŌĀ0 : ‚ĄĚ) (r : ‚Ąē ‚Üí ‚ĄĚ)
    (hőĪ : 0 < őĪ) (h0 : r 0 = ŌĀ0)
    (hstep : ‚ąÄ k, r (k + 1) ‚Č§ (1 + 1 / őĪ) * r k) :
    ‚ąÄ n, r n ‚Č§ (1 + 1 / őĪ) ^ n * ŌĀ0 :=
  geom_growth_iterate őĪ ŌĀ0 r hőĪ h0 hstep

/-- **¬ß11.1.1 finite-prefix growth recursion**: the same growth-factor
iteration as `higham11_1_growth_factor_recursion`, but with one-step bounds
available only for the finite active prefix `k < m`.  This is the shape needed
when a concrete pivot path supplies stage bounds only up to the final Schur
complement. -/
theorem higham11_1_growth_factor_recursion_prefix (őĪ ŌĀ0 : ‚ĄĚ) (r : ‚Ąē ‚Üí ‚ĄĚ)
    (m : ‚Ąē) (hőĪ : 0 < őĪ) (h0 : r 0 = ŌĀ0)
    (hstep : ‚ąÄ k, k < m ‚Üí r (k + 1) ‚Č§ (1 + 1 / őĪ) * r k) :
    ‚ąÄ n, n ‚Č§ m ‚Üí r n ‚Č§ (1 + 1 / őĪ) ^ n * ŌĀ0 := by
  have hfactor_nonneg : 0 ‚Č§ 1 + 1 / őĪ := by
    have hdiv_nonneg : 0 ‚Č§ 1 / őĪ := div_nonneg zero_le_one (le_of_lt hőĪ)
    linarith
  intro n
  induction n with
  | zero =>
      intro _hm
      simp [h0]
  | succ k ih =>
      intro hk_succ
      have hk_lt : k < m := Nat.lt_of_succ_le hk_succ
      have hk_le : k ‚Č§ m := Nat.le_of_lt hk_lt
      calc
        r (k + 1) ‚Č§ (1 + 1 / őĪ) * r k := hstep k hk_lt
        _ ‚Č§ (1 + 1 / őĪ) * ((1 + 1 / őĪ) ^ k * ŌĀ0) :=
          mul_le_mul_of_nonneg_left (ih hk_le) hfactor_nonneg
        _ = (1 + 1 / őĪ) ^ (k + 1) * ŌĀ0 := by ring

/-- **¬ß11.1.1 printed-alpha finite-prefix growth recursion**: specialization
of `higham11_1_growth_factor_recursion_prefix` to the Bunch-Parlett value of
`őĪ` and the final active stage `n-1`. -/
theorem higham11_1_growth_factor_bound_of_prefix_steps
    (n : ‚Ąē) (ŌĀ0 : ‚ĄĚ) (r : ‚Ąē ‚Üí ‚ĄĚ)
    (h0 : r 0 = ŌĀ0)
    (hstep : ‚ąÄ k, k < n - 1 ‚Üí
      r (k + 1) ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) * r k) :
    r (n - 1) ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1) * ŌĀ0 := by
  have hőĪ : 0 < higham11_1_bunchParlettAlpha := by
    simpa [higham11_1_bunchParlettAlpha] using bunch_parlett_alpha_pos
  have hstep' : ‚ąÄ k, k < n - 1 ‚Üí
      r (k + 1) ‚Č§ (1 + 1 / higham11_1_bunchParlettAlpha) * r k := by
    intro k hk
    simpa [one_div] using hstep k hk
  have h :=
    higham11_1_growth_factor_recursion_prefix
      higham11_1_bunchParlettAlpha ŌĀ0 r (n - 1) hőĪ h0 hstep' (n - 1)
      (le_refl _)
  simpa [one_div] using h

/-- **¬ß11.1.1 normalized growth-factor bound**: if a concrete active pivot
path has normalized initial maximum `ŌĀ‚āÄ ‚Č§ 1`, each prefix stage grows by at
most `1+őĪ‚ĀĽ¬Ļ`, and the advertised growth factor `ŌĀ‚āô` is bounded by the final
stage maximum, then `ŌĀ‚āô ‚Č§ (1+őĪ‚ĀĽ¬Ļ)^(n-1)`. -/
theorem higham11_1_bunch_parlett_growth_bound_of_prefix_steps
    (n : ‚Ąē) (ŌĀ_n ŌĀ0 : ‚ĄĚ) (r : ‚Ąē ‚Üí ‚ĄĚ)
    (h0 : r 0 = ŌĀ0) (hŌĀ0 : ŌĀ0 ‚Č§ 1)
    (hŌĀn : ŌĀ_n ‚Č§ r (n - 1))
    (hstep : ‚ąÄ k, k < n - 1 ‚Üí
      r (k + 1) ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) * r k) :
    ŌĀ_n ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1) := by
  have hőĪ : 0 < higham11_1_bunchParlettAlpha := by
    simpa [higham11_1_bunchParlettAlpha] using bunch_parlett_alpha_pos
  have hfactor_nonneg :
      0 ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1) := by
    have hinv_nonneg : 0 ‚Č§ higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ :=
      inv_nonneg.mpr (le_of_lt hőĪ)
    exact pow_nonneg (by linarith) _
  calc
    ŌĀ_n ‚Č§ r (n - 1) := hŌĀn
    _ ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1) * ŌĀ0 :=
      higham11_1_growth_factor_bound_of_prefix_steps n ŌĀ0 r h0 hstep
    _ ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1) * 1 :=
      mul_le_mul_of_nonneg_left hŌĀ0 hfactor_nonneg
    _ = (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1) := by ring

/-- **Equation (11.4)**, the scalar entry of the 2 by 2 Schur complement
`b_ij - [c_i1 c_i2] E^{-1} [c_j1, c_j2]^T`. -/
noncomputable def higham11_4_twoByTwoSchurEntry
    (bij ci1 ci2 cj1 cj2 e11 e12 e21 e22 : ‚ĄĚ) : ‚ĄĚ :=
  bij - (ci1 * (e11 * cj1 + e12 * cj2) +
    ci2 * (e21 * cj1 + e22 * cj2))

/-- Complete-pivoting growth-bound interface:
`rho_n <= (1 + alpha^{-1})^(n-1)`. -/
theorem higham11_1_bunch_parlett_growth_bound (n : ‚Ąē) (hn : 0 < n)
    (ŌĀ_n : ‚ĄĚ)
    (hŌĀ : ŌĀ_n ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1)) :
    ŌĀ_n ‚Č§ (1 + higham11_1_bunchParlettAlpha‚ĀĽ¬Ļ) ^ (n - 1) :=
  bunch_parlett_growth_bound n hn ŌĀ_n hŌĀ

/-- Complete-pivoting multiplier bound interface:
`|L_ij| <= max {1/alpha, 1/(1-alpha)}`. -/
theorem higham11_1_bunch_parlett_L_bound (n : ‚Ąē)
    (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ)
    (c_bound : ‚ĄĚ)
    (hc : c_bound =
      max (1 / higham11_1_bunchParlettAlpha)
          (1 / (1 - higham11_1_bunchParlettAlpha)))
    (hL : ‚ąÄ i j : Fin n, |L i j| ‚Č§ c_bound) :
    ‚ąÄ i j : Fin n, |L i j| ‚Č§ c_bound :=
  bunch_parlett_L_bound n L c_bound hc hL

/-- **¬ß11.1.1 multiplier bound**, proved from the pivot-acceptance test: a 1√ó1
pivot `e` with `őĪ¬∑ŌČ ‚Č§ |e|` and off-pivot entries bounded by `ŌČ` gives
multipliers `|c/e| ‚Č§ 1/őĪ`.  This is the honest derivation behind the
`bunch_parlett_L_bound` interface (`|L_ij| ‚Č§ max{1/őĪ, 1/(1-őĪ)}`). -/
theorem higham11_1_oneByOne_multiplier_bound (c e ŌČ őĪ : ‚ĄĚ)
    (hőĪ : 0 < őĪ) (hŌČ : 0 < ŌČ) (hc : |c| ‚Č§ ŌČ) (he : őĪ * ŌČ ‚Č§ |e|) :
    |c / e| ‚Č§ 1 / őĪ :=
  oneByOne_multiplier_bound c e ŌČ őĪ hőĪ hŌČ hc he

/-- For the Bunch-Parlett/Bunch-Kaufman value `őĪ=(1+‚ąö17)/8`, the scalar
one-pivot multiplier-row constant `1/őĪ` is bounded by the source row-sum
constant `6`. -/
theorem higham11_4_oneByOne_multiplier_row_sum_const_le_six :
    1 / higham11_1_bunchParlettAlpha ‚Č§ 6 := by
  have hlt : 1 / higham11_1_bunchParlettAlpha < 2 := by
    simpa [higham11_1_bunchParlettAlpha] using bunch_kaufman_recip_alpha_lt_two
  linarith

/-- **Theorem 11.4 local 1√ó1 multiplier row-sum cap**: a scalar accepted pivot
with `őĪŌČ‚Č§|e|` gives the source-shaped one-entry row-sum cap `‚Č§6`. -/
theorem higham11_4_oneByOne_multiplier_row_sum_le_six
    (c e ŌČ : ‚ĄĚ) (hŌČ : 0 < ŌČ)
    (he : higham11_1_bunchParlettAlpha * ŌČ ‚Č§ |e|)
    (hc : |c| ‚Č§ ŌČ) :
    |c / e| ‚Č§ 6 := by
  have hőĪ : 0 < higham11_1_bunchParlettAlpha := by
    simpa [higham11_1_bunchParlettAlpha] using bunch_parlett_alpha_pos
  exact
    (higham11_1_oneByOne_multiplier_bound
      c e ŌČ higham11_1_bunchParlettAlpha hőĪ hŌČ hc he).trans
      higham11_4_oneByOne_multiplier_row_sum_const_le_six

/-- **¬ß11.1.1 single-step element growth for a 1√ó1 pivot**:
`|b ‚ąí c‚āĀc‚āā/e| ‚Č§ (1 + 1/őĪ)¬∑őľ‚āÄ` when `őĪ¬∑őľ‚āÄ ‚Č§ |e|` and all active entries are
bounded by `őľ‚āÄ`.  This is the printed bound `|√£_ij| ‚Č§ őľ‚āÄ + őľ‚āÄ¬≤/őľ‚āĀ ‚Č§ (1+1/őĪ)őľ‚āÄ`
and the mechanism behind the growth-factor bound `ŌĀ‚āô ‚Č§ (1+őĪ‚ĀĽ¬Ļ)^{n‚ąí1}`. -/
theorem higham11_1_oneByOne_schur_growth (b c1 c2 e őľ0 őĪ : ‚ĄĚ)
    (hőĪ : 0 < őĪ) (hőľ : 0 < őľ0)
    (hb : |b| ‚Č§ őľ0) (hc1 : |c1| ‚Č§ őľ0) (hc2 : |c2| ‚Č§ őľ0)
    (he : őĪ * őľ0 ‚Č§ |e|) :
    |b - c1 * c2 / e| ‚Č§ (1 + 1 / őĪ) * őľ0 :=
  oneByOne_schur_growth b c1 c2 e őľ0 őĪ hőĪ hőľ hb hc1 hc2 he

/-- **¬ß11.1.1 2√ó2 pivot determinant bound**:
`det E = e‚āĀ‚āĀe‚āā‚āā ‚ąí e‚āā‚āĀ¬≤ ‚Č§ (őĪ¬≤ ‚ąí 1)őľ‚āÄ¬≤` for a complete-pivoting 2√ó2 block, and,
for `őĪ ‚ąą [0,1)`, `|det E| ‚Č• (1 ‚ąí őĪ¬≤)őľ‚āÄ¬≤`. -/
theorem higham11_4_twoByTwo_det_bound (e11 e22 e21 őľ0 őľ1 őĪ : ‚ĄĚ)
    (hőľ1 : 0 ‚Č§ őľ1)
    (he11 : |e11| ‚Č§ őľ1) (he22 : |e22| ‚Č§ őľ1)
    (he21 : e21 ^ 2 = őľ0 ^ 2) (hőľ1őĪ : őľ1 ‚Č§ őĪ * őľ0) :
    e11 * e22 - e21 ^ 2 ‚Č§ (őĪ ^ 2 - 1) * őľ0 ^ 2 :=
  twoByTwo_completePivot_det_bound e11 e22 e21 őľ0 őľ1 őĪ hőľ1 he11 he22 he21 hőľ1őĪ

/-- **¬ß11.1.1 2√ó2 pivot nonsingularity magnitude bound**:
`|det E| ‚Č• (1 ‚ąí őĪ¬≤)őľ‚āÄ¬≤` for `őĪ ‚ąą [0,1)`, the printed estimate used to bound
`E‚ĀĽ¬Ļ` and hence the 2√ó2-step element growth `(1 + 2/(1‚ąíőĪ))őľ‚āÄ`. -/
theorem higham11_4_twoByTwo_absdet_lower (e11 e22 e21 őľ0 őľ1 őĪ : ‚ĄĚ)
    (hőľ1 : 0 ‚Č§ őľ1) (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1)
    (he11 : |e11| ‚Č§ őľ1) (he22 : |e22| ‚Č§ őľ1)
    (he21 : e21 ^ 2 = őľ0 ^ 2) (hőľ1őĪ : őľ1 ‚Č§ őĪ * őľ0) :
    (1 - őĪ ^ 2) * őľ0 ^ 2 ‚Č§ |e11 * e22 - e21 ^ 2| :=
  twoByTwo_completePivot_absdet_lower e11 e22 e21 őľ0 őľ1 őĪ
    hőľ1 hőĪ0 hőĪ1 he11 he22 he21 hőľ1őĪ

/-- **Eq (11.4) element growth for a 2√ó2 complete-pivoting step**:
the Schur entry `higham11_4_twoByTwoSchurEntry` built from inverse-block entries
`e‚āĀ‚āĀ,e‚āĀ‚āā,e‚āā‚āĀ,e‚āā‚āā` bounded by `|e‚āĀ‚āĀ|,|e‚āā‚āā| ‚Č§ őĪK`, `|e‚āĀ‚āā|,|e‚āā‚āĀ| ‚Č§ K` with
`K = 1/((1‚ąíőĪ¬≤)őľ‚āÄ)`, and active entries `‚Č§ őľ‚āÄ`, satisfies
`|√£| ‚Č§ (1 + 2/(1‚ąíőĪ))¬∑őľ‚āÄ`.  This is the printed ¬ß11.1.1 bound and, with
`higham11_1_oneByOne_schur_growth`, completes both single-step growth bounds. -/
theorem higham11_4_twoByTwo_schur_growth
    (bij ci1 ci2 cj1 cj2 e11 e12 e21 e22 őľ0 őĪ K : ‚ĄĚ)
    (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1) (hőľ : 0 < őľ0)
    (hK : (1 - őĪ ^ 2) * őľ0 * K = 1)
    (hb : |bij| ‚Č§ őľ0)
    (hci1 : |ci1| ‚Č§ őľ0) (hci2 : |ci2| ‚Č§ őľ0)
    (hcj1 : |cj1| ‚Č§ őľ0) (hcj2 : |cj2| ‚Č§ őľ0)
    (he11 : |e11| ‚Č§ őĪ * K) (he12 : |e12| ‚Č§ K)
    (he21 : |e21| ‚Č§ K) (he22 : |e22| ‚Č§ őĪ * K) :
    |higham11_4_twoByTwoSchurEntry bij ci1 ci2 cj1 cj2 e11 e12 e21 e22|
      ‚Č§ (1 + 2 / (1 - őĪ)) * őľ0 := by
  unfold higham11_4_twoByTwoSchurEntry
  exact twoByTwo_schur_growth bij ci1 ci2 cj1 cj2 e11 e12 e21 e22 őľ0 őĪ K
    hőĪ0 hőĪ1 hőľ hK hb hci1 hci2 hcj1 hcj2 he11 he12 he21 he22

/-- **¬ß11.1.1 printed inverse bound** `|E‚ĀĽ¬Ļ| ‚Č§ K¬∑[[őĪ,1],[1,őĪ]]`, `K = 1/((1‚ąíőĪ¬≤)őľ‚āÄ)`:
the entrywise bounds on `E‚ĀĽ¬Ļ = d‚ĀĽ¬Ļ[[e‚āā‚āā,‚ąíe‚āā‚āĀ],[‚ąíe‚āā‚āĀ,e‚āĀ‚āĀ]]` for a complete-pivoting
2√ó2 block, derived from the determinant magnitude bound. -/
theorem higham11_4_twoByTwo_inverse_entry_bounds (e11 e22 e21 őľ0 őľ1 őĪ K : ‚ĄĚ)
    (hőľ1 : 0 ‚Č§ őľ1) (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1) (hőľ : 0 < őľ0)
    (he11 : |e11| ‚Č§ őľ1) (he22 : |e22| ‚Č§ őľ1)
    (he21 : e21 ^ 2 = őľ0 ^ 2) (hőľ1őĪ : őľ1 ‚Č§ őĪ * őľ0)
    (hK : (1 - őĪ ^ 2) * őľ0 * K = 1) :
    |e22 / (e11 * e22 - e21 ^ 2)| ‚Č§ őĪ * K
      ‚ąß |e11 / (e11 * e22 - e21 ^ 2)| ‚Č§ őĪ * K
      ‚ąß |e21 / (e11 * e22 - e21 ^ 2)| ‚Č§ K :=
  twoByTwo_inverse_entry_bounds e11 e22 e21 őľ0 őľ1 őĪ K
    hőľ1 hőĪ0 hőĪ1 hőľ he11 he22 he21 hőľ1őĪ hK

/-- **Theorem 11.4 local 2√ó2 multiplier row cap**, inverse-entry form:
if `|E‚ĀĽ¬Ļ| ‚Č§ K[[őĪ,1],[1,őĪ]]`, `K=1/((1‚ąíőĪ¬≤)őľ‚āÄ)`, and the two entries of a
trailing row `C` are bounded by `őľ‚āÄ`, then each component of `C E‚ĀĽ¬Ļ` is bounded
by `1/(1‚ąíőĪ)`.  This is the local 2√ó2 branch companion to the case-(1)/(3)
scalar multiplier caps from Algorithm 11.2. -/
theorem higham11_4_twoByTwo_multiplier_row_bound_of_inverse_entries
    (c1 c2 f11 f12 f21 f22 őľ0 őĪ K : ‚ĄĚ)
    (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1) (hőľ : 0 < őľ0)
    (hK : (1 - őĪ ^ 2) * őľ0 * K = 1)
    (hc1 : |c1| ‚Č§ őľ0) (hc2 : |c2| ‚Č§ őľ0)
    (hf11 : |f11| ‚Č§ őĪ * K) (hf12 : |f12| ‚Č§ K)
    (hf21 : |f21| ‚Č§ K) (hf22 : |f22| ‚Č§ őĪ * K) :
    |c1 * f11 + c2 * f21| ‚Č§ 1 / (1 - őĪ) ‚ąß
      |c1 * f12 + c2 * f22| ‚Č§ 1 / (1 - őĪ) := by
  have hőľ0 : 0 ‚Č§ őľ0 := le_of_lt hőľ
  have hőĪ2 : őĪ ^ 2 < 1 := by nlinarith [hőĪ0, hőĪ1]
  have hden : 0 < (1 - őĪ ^ 2) * őľ0 := mul_pos (by linarith [hőĪ2]) hőľ
  have hK0 : 0 ‚Č§ K := by nlinarith [hK, hden]
  have hőĪK : 0 ‚Č§ őĪ * K := mul_nonneg hőĪ0 hK0
  have h1őĪ : (0 : ‚ĄĚ) < 1 - őĪ := by linarith
  have hdiag :
      őľ0 * (őĪ * K) + őľ0 * K = 1 / (1 - őĪ) := by
    rw [eq_div_iff (ne_of_gt h1őĪ)]
    nlinarith [hK]
  have hoff :
      őľ0 * K + őľ0 * (őĪ * K) = 1 / (1 - őĪ) := by
    rw [eq_div_iff (ne_of_gt h1őĪ)]
    nlinarith [hK]
  have hc1f11 : |c1 * f11| ‚Č§ őľ0 * (őĪ * K) := by
    rw [abs_mul]
    exact mul_le_mul hc1 hf11 (abs_nonneg _) hőľ0
  have hc2f21 : |c2 * f21| ‚Č§ őľ0 * K := by
    rw [abs_mul]
    exact mul_le_mul hc2 hf21 (abs_nonneg _) hőľ0
  have hc1f12 : |c1 * f12| ‚Č§ őľ0 * K := by
    rw [abs_mul]
    exact mul_le_mul hc1 hf12 (abs_nonneg _) hőľ0
  have hc2f22 : |c2 * f22| ‚Č§ őľ0 * (őĪ * K) := by
    rw [abs_mul]
    exact mul_le_mul hc2 hf22 (abs_nonneg _) hőľ0
  refine ‚ü®?_, ?_‚ü©
  ¬∑ calc
      |c1 * f11 + c2 * f21| ‚Č§ |c1 * f11| + |c2 * f21| := abs_add_le _ _
      _ ‚Č§ őľ0 * (őĪ * K) + őľ0 * K := add_le_add hc1f11 hc2f21
      _ = 1 / (1 - őĪ) := hdiag
  ¬∑ calc
      |c1 * f12 + c2 * f22| ‚Č§ |c1 * f12| + |c2 * f22| := abs_add_le _ _
      _ ‚Č§ őľ0 * K + őľ0 * (őĪ * K) := add_le_add hc1f12 hc2f22
      _ = 1 / (1 - őĪ) := hoff

/-- **Theorem 11.4 local 2√ó2 multiplier row-sum cap**, inverse-entry form:
the two-component absolute row sum of `C E‚ĀĽ¬Ļ` is bounded by `2/(1‚ąíőĪ)`. -/
theorem higham11_4_twoByTwo_multiplier_row_sum_bound_of_inverse_entries
    (c1 c2 f11 f12 f21 f22 őľ0 őĪ K : ‚ĄĚ)
    (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1) (hőľ : 0 < őľ0)
    (hK : (1 - őĪ ^ 2) * őľ0 * K = 1)
    (hc1 : |c1| ‚Č§ őľ0) (hc2 : |c2| ‚Č§ őľ0)
    (hf11 : |f11| ‚Č§ őĪ * K) (hf12 : |f12| ‚Č§ K)
    (hf21 : |f21| ‚Č§ K) (hf22 : |f22| ‚Č§ őĪ * K) :
    |c1 * f11 + c2 * f21| + |c1 * f12 + c2 * f22| ‚Č§
      2 / (1 - őĪ) := by
  obtain ‚ü®hcol1, hcol2‚ü© :=
    higham11_4_twoByTwo_multiplier_row_bound_of_inverse_entries
      c1 c2 f11 f12 f21 f22 őľ0 őĪ K hőĪ0 hőĪ1 hőľ hK
      hc1 hc2 hf11 hf12 hf21 hf22
  have h1őĪ : (0 : ‚ĄĚ) < 1 - őĪ := by linarith
  calc
    |c1 * f11 + c2 * f21| + |c1 * f12 + c2 * f22|
        ‚Č§ 1 / (1 - őĪ) + 1 / (1 - őĪ) := add_le_add hcol1 hcol2
    _ = 2 / (1 - őĪ) := by
          field_simp [ne_of_gt h1őĪ]
          ring

/-- **Theorem 11.4 local 2√ó2 multiplier row cap**, pivot-block form:
instantiates the inverse-entry row cap with the actual inverse of
`E = [[e‚āĀ‚āĀ,e‚āā‚āĀ],[e‚āā‚āĀ,e‚āā‚āā]]`. -/
theorem higham11_4_twoByTwo_multiplier_row_bound_of_block
    (c1 c2 e11 e22 e21 őľ0 őľ1 őĪ K : ‚ĄĚ)
    (hőľ1 : 0 ‚Č§ őľ1) (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1) (hőľ : 0 < őľ0)
    (he11 : |e11| ‚Č§ őľ1) (he22 : |e22| ‚Č§ őľ1)
    (he21 : e21 ^ 2 = őľ0 ^ 2) (hőľ1őĪ : őľ1 ‚Č§ őĪ * őľ0)
    (hK : (1 - őĪ ^ 2) * őľ0 * K = 1)
    (hc1 : |c1| ‚Č§ őľ0) (hc2 : |c2| ‚Č§ őľ0) :
    |c1 * (e22 / (e11 * e22 - e21 ^ 2)) +
        c2 * (-(e21 / (e11 * e22 - e21 ^ 2)))| ‚Č§ 1 / (1 - őĪ) ‚ąß
      |c1 * (-(e21 / (e11 * e22 - e21 ^ 2))) +
        c2 * (e11 / (e11 * e22 - e21 ^ 2))| ‚Č§ 1 / (1 - őĪ) := by
  obtain ‚ü®hInv22, hInv11, hInv21‚ü© :=
    higham11_4_twoByTwo_inverse_entry_bounds e11 e22 e21 őľ0 őľ1 őĪ K
      hőľ1 hőĪ0 hőĪ1 hőľ he11 he22 he21 hőľ1őĪ hK
  exact
    higham11_4_twoByTwo_multiplier_row_bound_of_inverse_entries c1 c2
      (e22 / (e11 * e22 - e21 ^ 2))
      (-(e21 / (e11 * e22 - e21 ^ 2)))
      (-(e21 / (e11 * e22 - e21 ^ 2)))
      (e11 / (e11 * e22 - e21 ^ 2)) őľ0 őĪ K
      hőĪ0 hőĪ1 hőľ hK hc1 hc2 hInv22
      (by rw [abs_neg]; exact hInv21)
      (by rw [abs_neg]; exact hInv21) hInv11

/-- **Theorem 11.4 local 2√ó2 multiplier row-sum cap**, pivot-block form. -/
theorem higham11_4_twoByTwo_multiplier_row_sum_bound_of_block
    (c1 c2 e11 e22 e21 őľ0 őľ1 őĪ K : ‚ĄĚ)
    (hőľ1 : 0 ‚Č§ őľ1) (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1) (hőľ : 0 < őľ0)
    (he11 : |e11| ‚Č§ őľ1) (he22 : |e22| ‚Č§ őľ1)
    (he21 : e21 ^ 2 = őľ0 ^ 2) (hőľ1őĪ : őľ1 ‚Č§ őĪ * őľ0)
    (hK : (1 - őĪ ^ 2) * őľ0 * K = 1)
    (hc1 : |c1| ‚Č§ őľ0) (hc2 : |c2| ‚Č§ őľ0) :
    |c1 * (e22 / (e11 * e22 - e21 ^ 2)) +
        c2 * (-(e21 / (e11 * e22 - e21 ^ 2)))| +
      |c1 * (-(e21 / (e11 * e22 - e21 ^ 2))) +
        c2 * (e11 / (e11 * e22 - e21 ^ 2))| ‚Č§ 2 / (1 - őĪ) := by
  obtain ‚ü®hcol1, hcol2‚ü© :=
    higham11_4_twoByTwo_multiplier_row_bound_of_block c1 c2 e11 e22 e21
      őľ0 őľ1 őĪ K hőľ1 hőĪ0 hőĪ1 hőľ he11 he22 he21 hőľ1őĪ hK hc1 hc2
  have h1őĪ : (0 : ‚ĄĚ) < 1 - őĪ := by linarith
  calc
    |c1 * (e22 / (e11 * e22 - e21 ^ 2)) +
        c2 * (-(e21 / (e11 * e22 - e21 ^ 2)))| +
      |c1 * (-(e21 / (e11 * e22 - e21 ^ 2))) +
        c2 * (e11 / (e11 * e22 - e21 ^ 2))|
        ‚Č§ 1 / (1 - őĪ) + 1 / (1 - őĪ) := add_le_add hcol1 hcol2
    _ = 2 / (1 - őĪ) := by
          field_simp [ne_of_gt h1őĪ]
          ring

/-- The local 2√ó2 multiplier row-sum constant `2/(1‚ąíőĪ)` is at most `6` when
`őĪ‚Č§2/3`. -/
theorem higham11_4_twoByTwo_multiplier_row_sum_const_le_six_of_alpha_le_two_thirds
    (őĪ : ‚ĄĚ) (hőĪ : őĪ ‚Č§ 2 / 3) :
    2 / (1 - őĪ) ‚Č§ 6 := by
  have hden : (0 : ‚ĄĚ) < 1 - őĪ := by nlinarith
  rw [div_le_iff‚āÄ hden]
  nlinarith

/-- For the Bunch-Parlett/Bunch-Kaufman value `őĪ=(1+‚ąö17)/8`, the local 2√ó2
multiplier row-sum constant satisfies `2/(1‚ąíőĪ)‚Č§6`. -/
theorem higham11_4_twoByTwo_multiplier_row_sum_const_le_six :
    2 / (1 - higham11_1_bunchParlettAlpha) ‚Č§ 6 := by
  have hőĪ : higham11_1_bunchParlettAlpha ‚Č§ 2 / 3 := by
    unfold higham11_1_bunchParlettAlpha bunchParlettAlpha
    have hsqrt : Real.sqrt 17 ‚Č§ 13 / 3 := by
      rw [show (13 : ‚ĄĚ) / 3 = Real.sqrt ((13 / 3) ^ 2) from
        (Real.sqrt_sq (by norm_num : (0 : ‚ĄĚ) ‚Č§ 13 / 3)).symm]
      exact Real.sqrt_le_sqrt (by norm_num : (17 : ‚ĄĚ) ‚Č§ (13 / 3) ^ 2)
    linarith
  exact higham11_4_twoByTwo_multiplier_row_sum_const_le_six_of_alpha_le_two_thirds
    higham11_1_bunchParlettAlpha hőĪ

/-- **Theorem 11.4 local 2√ó2 multiplier row-sum cap**, source-alpha form:
with `őĪ=(1+‚ąö17)/8`, the row sum of `C E‚ĀĽ¬Ļ` is bounded by the source-shaped
constant `6`. -/
theorem higham11_4_twoByTwo_multiplier_row_sum_le_six_of_inverse_entries
    (c1 c2 f11 f12 f21 f22 őľ0 K : ‚ĄĚ)
    (hőľ : 0 < őľ0)
    (hK : (1 - higham11_1_bunchParlettAlpha ^ 2) * őľ0 * K = 1)
    (hc1 : |c1| ‚Č§ őľ0) (hc2 : |c2| ‚Č§ őľ0)
    (hf11 : |f11| ‚Č§ higham11_1_bunchParlettAlpha * K) (hf12 : |f12| ‚Č§ K)
    (hf21 : |f21| ‚Č§ K) (hf22 : |f22| ‚Č§ higham11_1_bunchParlettAlpha * K) :
    |c1 * f11 + c2 * f21| + |c1 * f12 + c2 * f22| ‚Č§ 6 := by
  have hőĪ0 : 0 ‚Č§ higham11_1_bunchParlettAlpha := by
    exact le_of_lt (by simpa [higham11_1_bunchParlettAlpha] using bunch_parlett_alpha_pos)
  have hőĪ1 : higham11_1_bunchParlettAlpha < 1 := by
    simpa [higham11_1_bunchParlettAlpha] using bunch_parlett_alpha_lt_one
  exact
    (higham11_4_twoByTwo_multiplier_row_sum_bound_of_inverse_entries
      c1 c2 f11 f12 f21 f22 őľ0 higham11_1_bunchParlettAlpha K
      hőĪ0 hőĪ1 hőľ hK hc1 hc2 hf11 hf12 hf21 hf22).trans
      higham11_4_twoByTwo_multiplier_row_sum_const_le_six

/-- **Theorem 11.4 local 2√ó2 multiplier row-sum cap**, source-alpha pivot-block
form: the actual symmetric pivot block inverse gives row sum at most `6`. -/
theorem higham11_4_twoByTwo_multiplier_row_sum_le_six_of_block
    (c1 c2 e11 e22 e21 őľ0 őľ1 K : ‚ĄĚ)
    (hőľ1 : 0 ‚Č§ őľ1) (hőľ : 0 < őľ0)
    (he11 : |e11| ‚Č§ őľ1) (he22 : |e22| ‚Č§ őľ1)
    (he21 : e21 ^ 2 = őľ0 ^ 2)
    (hőľ1őĪ : őľ1 ‚Č§ higham11_1_bunchParlettAlpha * őľ0)
    (hK : (1 - higham11_1_bunchParlettAlpha ^ 2) * őľ0 * K = 1)
    (hc1 : |c1| ‚Č§ őľ0) (hc2 : |c2| ‚Č§ őľ0) :
    |c1 * (e22 / (e11 * e22 - e21 ^ 2)) +
        c2 * (-(e21 / (e11 * e22 - e21 ^ 2)))| +
      |c1 * (-(e21 / (e11 * e22 - e21 ^ 2))) +
        c2 * (e11 / (e11 * e22 - e21 ^ 2))| ‚Č§ 6 := by
  have hőĪ0 : 0 ‚Č§ higham11_1_bunchParlettAlpha := by
    exact le_of_lt (by simpa [higham11_1_bunchParlettAlpha] using bunch_parlett_alpha_pos)
  have hőĪ1 : higham11_1_bunchParlettAlpha < 1 := by
    simpa [higham11_1_bunchParlettAlpha] using bunch_parlett_alpha_lt_one
  exact
    (higham11_4_twoByTwo_multiplier_row_sum_bound_of_block c1 c2 e11 e22 e21
      őľ0 őľ1 higham11_1_bunchParlettAlpha K hőľ1 hőĪ0 hőĪ1 hőľ he11 he22 he21
      hőľ1őĪ hK hc1 hc2).trans higham11_4_twoByTwo_multiplier_row_sum_const_le_six

/-- **¬ß11.1.1 self-contained 2√ó2 growth**: substituting the actual inverse block
`E‚ĀĽ¬Ļ` into the eq-(11.4) Schur entry, `|√£| ‚Č§ (1 + 2/(1‚ąíőĪ))őľ‚āÄ` holds using only the
pivot-block data (no assumed inverse-entry bounds). -/
theorem higham11_4_twoByTwo_schur_growth_of_block
    (bij ci1 ci2 cj1 cj2 e11 e22 e21 őľ0 őľ1 őĪ K : ‚ĄĚ)
    (hőľ1 : 0 ‚Č§ őľ1) (hőĪ0 : 0 ‚Č§ őĪ) (hőĪ1 : őĪ < 1) (hőľ : 0 < őľ0)
    (he11 : |e11| ‚Č§ őľ1) (he22 : |e22| ‚Č§ őľ1)
    (he21 : e21 ^ 2 = őľ0 ^ 2) (hőľ1őĪ : őľ1 ‚Č§ őĪ * őľ0)
    (hK : (1 - őĪ ^ 2) * őľ0 * K = 1)
    (hb : |bij| ‚Č§ őľ0)
    (hci1 : |ci1| ‚Č§ őľ0) (hci2 : |ci2| ‚Č§ őľ0)
    (hcj1 : |cj1| ‚Č§ őľ0) (hcj2 : |cj2| ‚Č§ őľ0) :
    |higham11_4_twoByTwoSchurEntry bij ci1 ci2 cj1 cj2
        (e22 / (e11 * e22 - e21 ^ 2)) (-(e21 / (e11 * e22 - e21 ^ 2)))
        (-(e21 / (e11 * e22 - e21 ^ 2))) (e11 / (e11 * e22 - e21 ^ 2))|
      ‚Č§ (1 + 2 / (1 - őĪ)) * őľ0 := by
  unfold higham11_4_twoByTwoSchurEntry
  exact twoByTwo_schur_growth_of_block bij ci1 ci2 cj1 cj2 e11 e22 e21 őľ0 őľ1 őĪ K
    hőľ1 hőĪ0 hőĪ1 hőľ he11 he22 he21 hőľ1őĪ hK hb hci1 hci2 hcj1 hcj2

/-! ## ¬ß11.1.2 Partial pivoting -/

/-- **Algorithm 11.2** branch predicate for the Bunch-Kaufman partial
pivoting tests. -/
abbrev higham11_2_BunchKaufmanPartialPivotCase
    (őĪ a11 arr ŌČ1 ŌČr : ‚ĄĚ) (branch : BunchKaufmanCase) : Prop :=
  BunchKaufmanPartialPivotCase őĪ a11 arr ŌČ1 ŌČr branch

/-- **Algorithm 11.2**, no-action branch test extraction. -/
theorem higham11_2_bunch_kaufman_noAction_eq_zero
    (őĪ a11 arr ŌČ1 ŌČr : ‚ĄĚ)
    (hcase : higham11_2_BunchKaufmanPartialPivotCase
      őĪ a11 arr ŌČ1 ŌČr BunchKaufmanCase.noAction) :
    ŌČ1 = 0 :=
  hcase

/-- **Algorithm 11.2**, case-(1) branch test extraction. -/
theorem higham11_2_bunch_kaufman_case1_tests
    (őĪ a11 arr ŌČ1 ŌČr : ‚ĄĚ)
    (hcase : higham11_2_BunchKaufmanPartialPivotCase
      őĪ a11 arr ŌČ1 ŌČr BunchKaufmanCase.case1) :
    ŌČ1 ‚Č† 0 ‚ąß |a11| ‚Č• őĪ * ŌČ1 :=
  hcase

/-- **Algorithm 11.2**, case-(2) branch test extraction. -/
theorem higham11_2_bunch_kaufman_case2_tests
    (őĪ a11 arr ŌČ1 ŌČr : ‚ĄĚ)
    (hcase : higham11_2_BunchKaufmanPartialPivotCase
      őĪ a11 arr ŌČ1 ŌČr BunchKaufmanCase.case2) :
    ŌČ1 ‚Č† 0 ‚ąß |a11| < őĪ * ŌČ1 ‚ąß |a11| * ŌČr ‚Č• őĪ * ŌČ1 ^ 2 :=
  hcase

/-- **Algorithm 11.2**, case-(2) nonsingularity from the printed product
test.  Unlike the later multiplier cap, this does not require a row-maximum
dominance side condition: `őĪŌČ1¬≤ ‚Č§ |a11|ŌČr` and `0<őĪ,ŌČ1` already force
`a11 ‚Č† 0`. -/
theorem higham11_2_bunch_kaufman_case2_pivot_ne_zero
    (őĪ a11 arr ŌČ1 ŌČr : ‚ĄĚ) (hőĪ : 0 < őĪ) (hŌČ1 : 0 < ŌČ1)
    (hcase : higham11_2_BunchKaufmanPartialPivotCase
      őĪ a11 arr ŌČ1 ŌČr BunchKaufmanCase.case2) :
    a11 ‚Č† 0 := by
  rcases higham11_2_bunch_kaufman_case2_tests őĪ a11 arr ŌČ1 ŌČr hcase with
    ‚ü®_, _, hprod_ge‚ü©
  have hŌČsq_pos : 0 < ŌČ1 ^ 2 := sq_pos_of_ne_zero (ne_of_gt hŌČ1)
  have hprod_pos : 0 < |a11| * ŌČr := lt_of_lt_of_le (mul_pos hőĪ hŌČsq_pos) hprod_ge
  have ha_abs_ne : |a11| ‚Č† 0 := by
    intro hzero
    rw [hzero, zero_mul] at hprod_pos
    exact (lt_irrefl (0 : ‚ĄĚ)) hprod_pos
  exact abs_ne_zero.mp ha_abs_ne

/-- **Algorithm 11.2**, case-(3) branch test extraction. -/
