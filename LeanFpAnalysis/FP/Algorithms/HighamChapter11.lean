theorem higham11_8_relative_outer_factor_caps_of_aasen_entry_bound_scaled_unit_of_entry_bound
    (n : ‚Ąē) (hn : 1 < n) (L : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ őļ : ‚ĄĚ)
    (hő≥ : 0 ‚Č§ ő≥) (hőļunit : (1 + ő≥) * őļ ‚Č§ 1)
