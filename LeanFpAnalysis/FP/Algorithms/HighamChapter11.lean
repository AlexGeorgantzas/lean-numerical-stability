/-- Absorb Chapter 9's tridiagonal-LU source polynomial
`f(ő≥_n)=4ő≥_n+3ő≥_n^2+ő≥_n^3` into a single accumulated gamma radius. -/
theorem higham11_8_higham9_14_f_gamma_le_gamma_4n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (4 * n)) :
    higham9_14_f (gamma fp n) ‚Č§ gamma fp (4 * n) := by
  let ő≥n : ‚ĄĚ := gamma fp n
  let ő≥3n : ‚ĄĚ := gamma fp (3 * n)
  have hn : gammaValid fp n := gammaValid_mono fp (by omega) hval
  have h3n : gammaValid fp (3 * n) := gammaValid_mono fp (by omega) hval
  have hő≥n : 0 ‚Č§ ő≥n := by
    dsimp [ő≥n]
    exact gamma_nonneg fp hn
  have h3 :
      3 * ő≥n + ő≥n ^ 2 ‚Č§ ő≥3n := by
    simpa [ő≥n, ő≥3n] using three_gamma_plus_sq_le_gamma fp n h3n
  have h3mul :
      (3 * ő≥n + ő≥n ^ 2) * ő≥n ‚Č§ ő≥3n * ő≥n :=
    mul_le_mul_of_nonneg_right h3 hő≥n
  have hpoly :
      higham9_14_f ő≥n ‚Č§ ő≥3n + ő≥n + ő≥3n * ő≥n := by
    unfold higham9_14_f
    nlinarith
  have h4 :
      ő≥3n + ő≥n + ő≥3n * ő≥n ‚Č§ gamma fp (4 * n) := by
    have hsum :
        gamma fp (3 * n) + gamma fp n +
            gamma fp (3 * n) * gamma fp n ‚Č§ gamma fp (3 * n + n) :=
      gamma_sum_le fp (3 * n) n (by
        simpa [show 3 * n + n = 4 * n by omega] using hval)
    simpa [ő≥n, ő≥3n, show 3 * n + n = 4 * n by omega] using hsum
  exact hpoly.trans h4

/-- Column/row-dominant Aasen middle solves use the coefficient
`3f(ő≥_n)`; this helper absorbs that term into `ő≥_{12n}`. -/
theorem higham11_8_three_higham9_14_f_gamma_le_gamma_12n
    (fp : FPModel) (n : ‚Ąē) (hval : gammaValid fp (12 * n)) :
    3 * higham9_14_f (gamma fp n) ‚Č§ gamma fp (12 * n) := by
  have h4valid : gammaValid fp (4 * n) :=
    gammaValid_mono fp (by omega) hval
  have hf :
      higham9_14_f (gamma fp n) ‚Č§ gamma fp (4 * n) :=
    higham11_8_higham9_14_f_gamma_le_gamma_4n fp n h4valid
  have htriple :
      (3 : ‚ĄĚ) * gamma fp (4 * n) ‚Č§ gamma fp (3 * (4 * n)) :=
    gamma_nsmul_le fp 3 (4 * n) (by norm_num) (by
      simpa [show 3 * (4 * n) = 12 * n by omega] using hval)
  calc
    3 * higham9_14_f (gamma fp n)
        ‚Č§ (3 : ‚ĄĚ) * gamma fp (4 * n) :=
          mul_le_mul_of_nonneg_left hf (by norm_num)
    _ ‚Č§ gamma fp (12 * n) := by
      simpa [show 3 * (4 * n) = 12 * n by omega] using htriple

/-- Absorb `2ő≥_n+ő≥_n^2` into `ő≥_{2n}`. -/
theorem higham11_8_two_gamma_plus_sq_le_gamma_2n
