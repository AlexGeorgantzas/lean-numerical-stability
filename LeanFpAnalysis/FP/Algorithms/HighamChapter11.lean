theorem higham11_8_relative_T_hat_error_of_eq (n : ‚Ąē)
    (T T_hat : Fin n ‚Üí Fin n ‚Üí ‚ĄĚ) (ő≥ : ‚ĄĚ) (hő≥ : 0 ‚Č§ ő≥)
    (hEq : ‚ąÄ i j : Fin n, T_hat i j = T i j) :
    ‚ąÄ i j : Fin n, |T_hat i j - T i j| ‚Č§ ő≥ * |T_hat i j| :=
