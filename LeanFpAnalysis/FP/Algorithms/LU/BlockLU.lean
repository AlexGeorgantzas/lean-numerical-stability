    in the local finite quadratic-form sense. -/
theorem finitePSD_of_isSymPosDef {n : ℕ}
    (A : Fin n → Fin n → ℝ)
    (hSPD : IsSymPosDef n A) :
    finitePSD A := by
  intro x
  rw [finiteQuadraticForm_eq_sum_sum]
  by_cases hx : ∃ i : Fin n, x i ≠ 0
  · exact le_of_lt (hSPD.2 x hx)
  · push_neg at hx
    simp [hx]

