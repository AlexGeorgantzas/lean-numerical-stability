        Matrix.det (blockMatrixFlatFin Ablk :
          Matrix (Fin ((m + 1) * r)) (Fin ((m + 1) * r)) ℝ) ≠ 0 := by
  intro m Ablk pivotInv hcert
  cases hcert with
  | one hdet _ =>
      simpa using hdet
  | succ _ hdetFlat _ _ _ _ =>
      simpa using hdetFlat

/-- Higham, 2nd ed., Chapter 13, equation (13.22):
