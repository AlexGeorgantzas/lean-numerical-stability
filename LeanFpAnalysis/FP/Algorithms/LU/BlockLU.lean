    Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ :=
  fun i j =>
    if i.val РЅц j.val then
      higham13_algorithm13_3_schurStageMatrixBlock A pivotInv i.val i j
    else 0

/-- Lower block factor assembled from the matrix-product Algorithm 13.3
