theorem higham13_problem13_6_residualRankOnePerturbation_opNorm2Le (n : ℕ)
    (rsolve xhat : Fin n → ℝ) (hx : vecNorm2 xhat ≠ 0) :
    opNorm2Le (residualRankOnePerturbation n rsolve xhat)
