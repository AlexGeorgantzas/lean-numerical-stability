/-- Higham, 2nd ed., Chapter 13, equation (13.18):
    abstract subordinate-norm lower-bound half.

    If `invDiag` is a left inverse for the action of a diagonal block and its
    action is bounded by `normInv`, then every unit vector satisfies
    `normInvРЂ╗┬╣ <= Рђќdiag xРђќ`.  This is the normed-space analogue of rewriting
    a nonsingular block's lower norm as the reciprocal of an inverse norm. -/
theorem higham13_eq13_18_unit_lower_bound_of_inverse_action_bound
    {E : Type*} [SeminormedAddCommGroup E]
    (diag invDiag : E Рєњ E) (normInv : РёЮ)
    (hNormInvPos : 0 < normInv)
    (hInvBound : Рѕђ y : E, РђќinvDiag yРђќ РЅц normInv * РђќyРђќ)
    (hLeft : Рѕђ x : E, invDiag (diag x) = x) :
    Рѕђ x : E, РђќxРђќ = 1 Рєњ normInvРЂ╗┬╣ РЅц Рђќdiag xРђќ := by
  intro x hx
  have hInvNonneg : 0 РЅц normInvРЂ╗┬╣ :=
    inv_nonneg.mpr (le_of_lt hNormInvPos)
  have hone_le : 1 РЅц normInv * Рђќdiag xРђќ := by
    calc
      1 = РђќxРђќ := by rw [hx]
      _ = РђќinvDiag (diag x)Рђќ := by rw [hLeft x]
      _ РЅц normInv * Рђќdiag xРђќ := hInvBound (diag x)
  calc
    normInvРЂ╗┬╣ = normInvРЂ╗┬╣ * 1 := by ring
    _ РЅц normInvРЂ╗┬╣ * (normInv * Рђќdiag xРђќ) :=
      mul_le_mul_of_nonneg_left hone_le hInvNonneg
    _ = (normInvРЂ╗┬╣ * normInv) * Рђќdiag xРђќ := by ring
    _ = Рђќdiag xРђќ := by
      rw [inv_mul_cancelРѓђ hNormInvPos.ne']
      ring

