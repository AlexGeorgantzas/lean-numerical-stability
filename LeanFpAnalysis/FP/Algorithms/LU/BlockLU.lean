    le_trans hLnorm_one hBudget
  have hU_le_G : blockMaxNorm hm hr U0 РЅц maxEntryNorm hN G := by
    rw [Рєљ maxEntryNorm_blockMatrixFlatFin_eq_blockMaxNorm hm hr U0]
