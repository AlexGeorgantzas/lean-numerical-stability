/-- The matrix-`Рѕъ` stage-history bound contains the assembled upper factor. -/
theorem higham13_algorithm13_3_matrixStageHistoryInfBound_contains_upperFromMatrixStages
    {m r : РёЋ} (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
