theorem higham13_problem13_4_A21A11inv_maxEntryNormRect_from_displayed_inverse_entry_bound
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s)
    (A : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    (A21 : Fin s Рєњ Fin r Рєњ РёЮ) (A11inv : Fin r Рєњ Fin r Рєњ РёЮ)
    {normA normAinv rho kappaA : РёЮ} (n : РёЋ)
    (hRho_ge_one : 1 РЅц rho) (hKappa : 0 РЅц kappaA)
    (hrn : (r : РёЮ) РЅц (n : РёЮ))
    (hA_entry : Рѕђ i j : Fin r РіЋ Fin s, |A i j| РЅц normA)
    (hA21 : A21 = fun (i : Fin s) (j : Fin r) =>
      A (Sum.inr i) (Sum.inl j))
    (hA11inv_entry : Рѕђ i : Fin r, Рѕђ j : Fin r, |A11inv i j| РЅц normAinv)
    (hkappa : normA * normAinv РЅц kappaA) :
