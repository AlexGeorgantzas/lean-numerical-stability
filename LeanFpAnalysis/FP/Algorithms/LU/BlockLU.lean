      ((A22 - A21 * A11⁻¹ * A21ᵀ)⁻¹ :
        Matrix (Fin s) (Fin s) ℝ) i j
  have hFull_eq :
      Matrix.fromBlocks A11 A21ᵀ A21 A22 =
        (fun i j : Fin r ⊕ Fin s =>
          A (finSumFinEquiv i) (finSumFinEquiv j)) := by
    ext i j
    cases i with
    | inl i =>
        cases j with
        | inl j =>
            have h := congr_fun (congr_fun hA11_block i) j
            simpa [Matrix.fromBlocks] using h
        | inr j =>
