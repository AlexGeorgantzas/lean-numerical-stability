/-- **Block LU backward error** (Higham, 2nd ed., ┬Д┬Д13.2--13.3).
    Computed block factors L╠ѓ, ├Џ satisfy L╠ѓ├Џ = A + ╬ћA
    with entrywise bound ╬х on the error. -/
structure BlockLUBackwardError (m r : РёЋ) (hm : 0 < m) (hr : 0 < r)
    (A L_hat U_hat : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) (╬х : РёЮ) : Prop where
  L_diag : Рѕђ i : Fin m, L_hat i i = idBlock r
  L_upper_zero : Рѕђ i j : Fin m, i.val < j.val Рєњ L_hat i j = zeroBlock r
  U_lower_zero : Рѕђ i j : Fin m, j.val < i.val Рєњ U_hat i j = zeroBlock r
  backward_bound : Рѕђ (i j : Fin m) (s t : Fin r),
    |РѕЉ k : Fin m, РѕЉ l : Fin r, L_hat i k s l * U_hat k j l t - A i j s t| РЅц ╬х

