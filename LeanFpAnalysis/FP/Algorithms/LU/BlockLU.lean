noncomputable def higham13_algorithm13_3_stageHistoryGrowthMatrix
    {N m r : РёЋ} (_hN : 0 < N) (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
