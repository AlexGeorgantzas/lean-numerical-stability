/-- **Theorem 13.5 scalar one-step aggregation** (Demmel--Higham).
    Given per-block backward errors from BLAS-3 assumptions (13.4)--(13.6),
    the overall backward error satisfies the recurrence bound. -/
theorem partitioned_lu_backward_error_step
    (norm╬ћAРѓЂРѓЂ norm╬ћAРѓЂРѓѓ norm╬ћAРѓѓРѓЂ norm╬ћAРѓѓРѓѓ : РёЮ)
    (normA normL normU u : РёЮ)
    (cРѓЂ cРѓѓ cРѓЃ ╬┤_prev ╬И_prev : РёЮ)
    (hu : 0 РЅц u) (_hcРѓЂ : 0 РЅц cРѓЂ) (_hcРѓѓ : 0 РЅц cРѓѓ) (hcРѓЃ : 0 РЅц cРѓЃ)
    (h╬┤ : 0 РЅц ╬┤_prev) (_h╬И : 0 РЅц ╬И_prev)
    (hA : 0 РЅц normA) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    -- Per-block error bounds (eqs. 13.6, 13.8, 13.9, 13.13):
    (hРѓЂРѓЂ : norm╬ћAРѓЂРѓЂ РЅц cРѓЃ * u * normL * normU)
    (hРѓЂРѓѓ : norm╬ћAРѓЂРѓѓ РЅц cРѓѓ * u * normL * normU)
    (hРѓѓРѓЂ : norm╬ћAРѓѓРѓЂ РЅц cРѓѓ * u * normL * normU)
    (hРѓѓРѓѓ : norm╬ћAРѓѓРѓѓ РЅц u * ((1 + ╬┤_prev) * normA +
        (1 + cРѓЂ + ╬┤_prev + ╬И_prev) * normL * normU)) :
    max (max norm╬ћAРѓЂРѓЂ norm╬ћAРѓЂРѓѓ) (max norm╬ћAРѓѓРѓЂ norm╬ћAРѓѓРѓѓ) РЅц
      u * ((1 + ╬┤_prev) * normA +
        max (max cРѓЃ cРѓѓ) (1 + cРѓЂ + ╬┤_prev + ╬И_prev) * normL * normU) := by
  have hLU : 0 РЅц normL * normU := mul_nonneg hL hU
  have h╬И_max : cРѓЃ РЅц max (max cРѓЃ cРѓѓ) (1 + cРѓЂ + ╬┤_prev + ╬И_prev) :=
    le_trans (le_max_left cРѓЃ cРѓѓ) (le_max_left _ _)
  have h╬И_max2 : cРѓѓ РЅц max (max cРѓЃ cРѓѓ) (1 + cРѓЂ + ╬┤_prev + ╬И_prev) :=
    le_trans (le_max_right cРѓЃ cРѓѓ) (le_max_left _ _)
  have h╬И_max3 : 1 + cРѓЂ + ╬┤_prev + ╬И_prev РЅц
      max (max cРѓЃ cРѓѓ) (1 + cРѓЂ + ╬┤_prev + ╬И_prev) := le_max_right _ _
  set M := max (max cРѓЃ cРѓѓ) (1 + cРѓЂ + ╬┤_prev + ╬И_prev)
  have hM_nonneg : 0 РЅц M := le_trans hcРѓЃ h╬И_max
  have hRHS_nonneg : 0 РЅц (1 + ╬┤_prev) * normA := by nlinarith
  -- Helper: if x РЅц c * u * normL * normU and c РЅц M, then x РЅц RHS
  have haux : Рѕђ c, c РЅц M Рєњ c * u * normL * normU РЅц
      u * ((1 + ╬┤_prev) * normA + M * normL * normU) := by
    intro c hc
    have h1 : c * (u * (normL * normU)) РЅц M * (u * (normL * normU)) :=
      mul_le_mul_of_nonneg_right hc (mul_nonneg hu hLU)
    nlinarith
  apply max_le <;> apply max_le
  ┬и exact le_trans hРѓЂРѓЂ (haux cРѓЃ h╬И_max)
  ┬и exact le_trans hРѓЂРѓѓ (haux cРѓѓ h╬И_max2)
  ┬и exact le_trans hРѓѓРѓЂ (haux cРѓѓ h╬И_max2)
  ┬и calc norm╬ћAРѓѓРѓѓ
        РЅц u * ((1 + ╬┤_prev) * normA + (1 + cРѓЂ + ╬┤_prev + ╬И_prev) * normL * normU) := hРѓѓРѓѓ
      _ РЅц u * ((1 + ╬┤_prev) * normA + M * normL * normU) := by
          apply mul_le_mul_of_nonneg_left _ hu
          linarith [mul_le_mul_of_nonneg_right h╬И_max3 hLU]

/-- **Theorem 13.5 recurrence step**, scalar norm-level form.

    This is the previous aggregation lemma specialized to Higham's recurrence
    constants `╬┤` and `╬И`: if the leading, off-diagonal, and trailing block
    errors satisfy the source first-order bounds for one partitioned-LU step,
    the combined block error satisfies the next `╬┤`/`╬И` bound.  It is still a
    scalar proof-step theorem, not the full implementation-facing theorem with
    computed block matrices and `O(u^2)` witnesses. -/
theorem higham13_theorem13_5_recurrence_step
    (m : РёЋ)
    (norm╬ћAРѓЂРѓЂ norm╬ћAРѓЂРѓѓ norm╬ћAРѓѓРѓЂ norm╬ћAРѓѓРѓѓ : РёЮ)
    (normA normL normU u cРѓЂ cРѓѓ cРѓЃ : РёЮ)
    (hu : 0 РЅц u) (hcРѓЂ : 0 РЅц cРѓЂ) (hcРѓѓ : 0 РЅц cРѓѓ) (hcРѓЃ : 0 РЅц cРѓЃ)
    (hA : 0 РЅц normA) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    (hРѓЂРѓЂ : norm╬ћAРѓЂРѓЂ РЅц cРѓЃ * u * normL * normU)
    (hРѓЂРѓѓ : norm╬ћAРѓЂРѓѓ РЅц cРѓѓ * u * normL * normU)
    (hРѓѓРѓЂ : norm╬ћAРѓѓРѓЂ РЅц cРѓѓ * u * normL * normU)
    (hРѓѓРѓѓ : norm╬ћAРѓѓРѓѓ РЅц
      u * ((1 + blockErrorDelta (m + 1)) * normA +
        (1 + cРѓЂ + blockErrorDelta (m + 1) +
          blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1)) * normL * normU)) :
    max (max norm╬ћAРѓЂРѓЂ norm╬ћAРѓЂРѓѓ) (max norm╬ћAРѓѓРѓЂ norm╬ћAРѓѓРѓѓ) РЅц
      u * (blockErrorDelta (m + 2) * normA +
        blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 2) * normL * normU) := by
  rw [blockErrorDelta_succ_succ, blockErrorTheta_succ_succ]
  exact partitioned_lu_backward_error_step
    norm╬ћAРѓЂРѓЂ norm╬ћAРѓЂРѓѓ norm╬ћAРѓѓРѓЂ norm╬ћAРѓѓРѓѓ normA normL normU u cРѓЂ cРѓѓ cРѓЃ
    (blockErrorDelta (m + 1)) (blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1))
    hu hcРѓЂ hcРѓѓ hcРѓЃ (blockErrorDelta_nonneg (m + 1))
    (blockErrorTheta_nonneg_of_c3_nonneg cРѓЂ cРѓѓ cРѓЃ hcРѓЃ (m + 1))
    hA hL hU hРѓЂРѓЂ hРѓЂРѓѓ hРѓѓРѓЂ hРѓѓРѓѓ

/-- **Theorem 13.5 recurrence step with `+ O(u^2)` terms**, scalar norm-level
    form.

    This lifts `higham13_theorem13_5_recurrence_step` to the repository's
    explicit `FirstOrderLe` interpretation of Higham's displayed first-order
    bounds.  If all four block errors satisfy their first-order source bounds,
    then the combined block error satisfies the next recurrence bound with its
    own explicit second-order witness.  The theorem is still scalar recurrence
    infrastructure: it does not yet model the computed block factors in
    equations (13.8)--(13.13). -/
theorem higham13_theorem13_5_recurrence_step_firstOrder
    (m : РёЋ)
    (norm╬ћAРѓЂРѓЂ norm╬ћAРѓЂРѓѓ norm╬ћAРѓѓРѓЂ norm╬ћAРѓѓРѓѓ : РёЮ)
    (normA normL normU u cРѓЂ cРѓѓ cРѓЃ : РёЮ)
    (hu : 0 РЅц u) (_hcРѓЂ : 0 РЅц cРѓЂ) (_hcРѓѓ : 0 РЅц cРѓѓ) (_hcРѓЃ : 0 РЅц cРѓЃ)
    (hA : 0 РЅц normA) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    (hРѓЂРѓЂ : FirstOrderLe u (cРѓЃ * u * normL * normU) norm╬ћAРѓЂРѓЂ)
    (hРѓЂРѓѓ : FirstOrderLe u (cРѓѓ * u * normL * normU) norm╬ћAРѓЂРѓѓ)
    (hРѓѓРѓЂ : FirstOrderLe u (cРѓѓ * u * normL * normU) norm╬ћAРѓѓРѓЂ)
    (hРѓѓРѓѓ : FirstOrderLe u
      (u * ((1 + blockErrorDelta (m + 1)) * normA +
        (1 + cРѓЂ + blockErrorDelta (m + 1) +
          blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1)) * normL * normU))
      norm╬ћAРѓѓРѓѓ) :
    FirstOrderLe u
      (u * (blockErrorDelta (m + 2) * normA +
        blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 2) * normL * normU))
      (max (max norm╬ћAРѓЂРѓЂ norm╬ћAРѓЂРѓѓ) (max norm╬ћAРѓѓРѓЂ norm╬ћAРѓѓРѓѓ)) := by
  rw [blockErrorDelta_succ_succ, blockErrorTheta_succ_succ]
  have hLU : 0 РЅц normL * normU := mul_nonneg hL hU
  set ╬┤_prev := blockErrorDelta (m + 1)
  set ╬И_prev := blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1)
  set M := max (max cРѓЃ cРѓѓ) (1 + cРѓЂ + ╬┤_prev + ╬И_prev)
  have h╬И_max : cРѓЃ РЅц M := by
    exact le_trans (le_max_left cРѓЃ cРѓѓ) (le_max_left _ _)
  have h╬И_max2 : cРѓѓ РЅц M := by
    exact le_trans (le_max_right cРѓЃ cРѓѓ) (le_max_left _ _)
  have h╬И_max3 : 1 + cРѓЂ + ╬┤_prev + ╬И_prev РЅц M := le_max_right _ _
  have haux : Рѕђ c, c РЅц M Рєњ c * u * normL * normU РЅц
      u * ((1 + ╬┤_prev) * normA + M * normL * normU) := by
    intro c hc
    have h1 : c * (u * (normL * normU)) РЅц M * (u * (normL * normU)) :=
      mul_le_mul_of_nonneg_right hc (mul_nonneg hu hLU)
    have h╬┤ : 0 РЅц ╬┤_prev := by
      dsimp [╬┤_prev]
      exact blockErrorDelta_nonneg (m + 1)
    have hAterm : 0 РЅц u * ((1 + ╬┤_prev) * normA) :=
      mul_nonneg hu (mul_nonneg (by linarith) hA)
    nlinarith
  have hРѓЂРѓЂ' : FirstOrderLe u (u * ((1 + ╬┤_prev) * normA + M * normL * normU))
      norm╬ћAРѓЂРѓЂ :=
    hРѓЂРѓЂ.mono_leading (by
      dsimp [╬┤_prev, ╬И_prev, M]
      exact haux cРѓЃ h╬И_max)
  have hРѓЂРѓѓ' : FirstOrderLe u (u * ((1 + ╬┤_prev) * normA + M * normL * normU))
      norm╬ћAРѓЂРѓѓ :=
    hРѓЂРѓѓ.mono_leading (by
      dsimp [╬┤_prev, ╬И_prev, M]
      exact haux cРѓѓ h╬И_max2)
  have hРѓѓРѓЂ' : FirstOrderLe u (u * ((1 + ╬┤_prev) * normA + M * normL * normU))
      norm╬ћAРѓѓРѓЂ :=
    hРѓѓРѓЂ.mono_leading (by
      dsimp [╬┤_prev, ╬И_prev, M]
      exact haux cРѓѓ h╬И_max2)
  have hРѓѓРѓѓ' : FirstOrderLe u (u * ((1 + ╬┤_prev) * normA + M * normL * normU))
      norm╬ћAРѓѓРѓѓ := by
    apply hРѓѓРѓѓ.mono_leading
    apply mul_le_mul_of_nonneg_left _ hu
    nlinarith [mul_le_mul_of_nonneg_right h╬И_max3 hLU]
  exact FirstOrderLe.max_same
    (FirstOrderLe.max_same hРѓЂРѓЂ' hРѓЂРѓѓ')
    (FirstOrderLe.max_same hРѓѓРѓЂ' hРѓѓРѓѓ')

/-- Higham, 2nd ed., Chapter 13, Section 13.2, Theorem 13.5 proof step:
    packaged exact residual identity and first-order recurrence bound.

    This combines the source-facing residual specs for (13.6), (13.8), and
    (13.9), an already-proved trailing-block residual equation for (13.13), and
