    R (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
      (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s))
  let R22 : Fin s Рєњ Fin s Рєњ РёЮ := fun i j =>
    R (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
      (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s))
  let A11inv : Fin r Рєњ Fin r Рєњ РёЮ :=
    rectMatMul (nonsingInv r R11) (finiteTranspose (nonsingInv r R11))
  refine РЪеR, R11, R12, R22, A11inv, hChol, ?_, ?_, ?_, rfl, ?_РЪЕ
  ┬и intro i j
    rfl
  ┬и intro i j
    rfl
  ┬и intro i j
    rfl
  ┬и exact
      higham13_lemma13_9_cholesky_route_rectOpNorm2Le_from_cholesky_fact_fin_sum_spd_kappa2_nonsingInv
        A R A22 A21 A11inv R11 R12 R22
        hA22_block hA21_block
        (by intro i j; rfl)
        (by intro i j; rfl)
        (by intro i j; rfl)
        hChol rfl hSPD

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
