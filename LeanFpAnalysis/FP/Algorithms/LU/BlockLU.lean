    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    (hFull : (Matrix.fromBlocks A11 A21рхђ A21 A22).PosDef)
    (hA11_block : A11 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)))
    (hA12_block : A21рхђ =
      fun (i : Fin r) (j : Fin s) =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)))
    (hA21_block : A21 =
      fun (i : Fin s) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)))
    (hA22_block : A22 =
      fun i j : Fin s =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s))) :
    kappa2
      (fun i j : Fin s => (A22 - A21 * A11РЂ╗┬╣ * A21рхђ) i j)
      (fun i j : Fin s =>
        ((A22 - A21 * A11РЂ╗┬╣ * A21рхђ)РЂ╗┬╣ :
