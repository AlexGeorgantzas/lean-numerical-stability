theorem higham13_lemma13_9_leading_nonsingInv_eq_cholesky_fact_fin_sum
    {r s : РёЋ}
    (A R : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
    (R11 : Fin r Рєњ Fin r Рєњ РёЮ)
    (hR11 : Рѕђ i j,
