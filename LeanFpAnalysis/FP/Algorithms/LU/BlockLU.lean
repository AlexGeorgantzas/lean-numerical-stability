    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ) :
    Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ :=
  fun i j =>
    if j.val < i.val then
      higham13_algorithm13_3_schurStageMatrixBlock A pivotInv j.val i j *
        pivotInv j.val
    else if i = j then idBlock r else zeroBlock r

