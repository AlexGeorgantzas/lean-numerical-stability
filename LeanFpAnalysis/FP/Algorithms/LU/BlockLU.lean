theorem higham13_lemma13_9_cholesky_route_rectOpNorm2Le_from_sum_cholesky_product
    {r s : РёЋ} [Nonempty (Fin r РіЋ Fin s)]
    (A Ainv R : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    (A22 : Fin s Рєњ Fin s Рєњ РёЮ)
