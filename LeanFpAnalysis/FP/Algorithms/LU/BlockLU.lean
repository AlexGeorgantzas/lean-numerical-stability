theorem SchurStageActiveDiagLowerUpdate13_7.of_inverse_action_bounds {m : РёЋ}
    {E : Type*} [SeminormedAddCommGroup E]
    (stageNorm : РёЋ Рєњ Fin m Рєњ Fin m Рєњ РёЮ)
