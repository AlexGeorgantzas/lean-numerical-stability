/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    the lower-left block `AРѓѓРѓЂ` inherits a max-entry certificate from a full
    partitioned-matrix entrywise bound.  The source growth factor only weakens
    the entrywise max bound when `rho_n >= 1`. -/
theorem higham13_problem13_4_A21_maxEntryNormRect_of_full_entry_bound
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s)
    (A : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    (A21 : Fin s Рєњ Fin r Рєњ РёЮ)
    {normA rho : РёЮ}
    (hRho_ge_one : 1 РЅц rho)
    (hA_entry : Рѕђ i j : Fin r РіЋ Fin s, |A i j| РЅц normA)
    (hA21 : A21 = fun (i : Fin s) (j : Fin r) =>
      A (Sum.inr i) (Sum.inl j)) :
    maxEntryNormRect hs hr A21 РЅц rho * normA := by
  let i0 : Fin r := РЪе0, hrРЪЕ
  have hNormA_nonneg : 0 РЅц normA :=
    le_trans (abs_nonneg (A (Sum.inl i0) (Sum.inl i0)))
      (hA_entry (Sum.inl i0) (Sum.inl i0))
  have hA21_entry : Рѕђ i : Fin s, Рѕђ j : Fin r, |A21 i j| РЅц normA := by
    intro i j
    calc
      |A21 i j| = |A (Sum.inr i) (Sum.inl j)| := by rw [hA21]
      _ РЅц normA := hA_entry (Sum.inr i) (Sum.inl j)
  have hA21_norm : maxEntryNormRect hs hr A21 РЅц normA :=
    maxEntryNormRect_le_of_entry_abs_le hs hr A21 normA hA21_entry
  have hscale : normA РЅц rho * normA := by
    calc
      normA = (1 : РёЮ) * normA := by ring
      _ РЅц rho * normA :=
        mul_le_mul_of_nonneg_right hRho_ge_one hNormA_nonneg
  exact le_trans hA21_norm hscale

