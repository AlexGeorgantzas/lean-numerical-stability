/-- Reindexing a matrix by an equivalence transports entrywise bounds on its
    constructive inverse.

    This is a max-entry analogue of the operator-norm reindexing bridges used
    elsewhere in the Chapter 13 Schur-complement route. -/
theorem invOf_entry_bound_of_reindex_eq
    {╬╣ ╬║ : Type*} [Fintype ╬╣] [Fintype ╬║] [DecidableEq ╬╣] [DecidableEq ╬║]
    (e : ╬╣ РЅЃ ╬║) (A : Matrix ╬║ ╬║ РёЮ) (M : Matrix ╬╣ ╬╣ РёЮ)
    [Invertible A] [Invertible M]
    (hM : M = fun i j : ╬╣ => A (e i) (e j))
    {bound : РёЮ}
    (hA_entry : Рѕђ i j : ╬║, |(РЁЪA : Matrix ╬║ ╬║ РёЮ) i j| РЅц bound) :
    Рѕђ i j : ╬╣, |(РЁЪM : Matrix ╬╣ ╬╣ РёЮ) i j| РЅц bound := by
  classical
  intro i j
  have h1 : РЁЪM = MРЂ╗┬╣ :=
    Matrix.invOf_eq_nonsing_inv M
  have h2 :
      MРЂ╗┬╣ =
        ((AРЂ╗┬╣ : Matrix ╬║ ╬║ РёЮ).submatrix e e) := by
    rw [hM]
    exact Matrix.inv_submatrix_equiv A e e
  have hAinv : РЁЪA = AРЂ╗┬╣ :=
    Matrix.invOf_eq_nonsing_inv A
  have hentry :
      (РЁЪM : Matrix ╬╣ ╬╣ РёЮ) i j = (РЁЪA : Matrix ╬║ ╬║ РёЮ) (e i) (e j) := by
    calc
      (РЁЪM : Matrix ╬╣ ╬╣ РёЮ) i j = MРЂ╗┬╣ i j := by rw [h1]
      _ = AРЂ╗┬╣ (e i) (e j) := by
            rw [h2]
            rfl
      _ = (РЁЪA : Matrix ╬║ ╬║ РёЮ) (e i) (e j) := by rw [hAinv]
  rw [hentry]
  exact hA_entry (e i) (e j)

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    recursive Schur-tail inverse-entry handoff from the parent block inverse.

    If the current first-split parent block inverse is entrywise bounded by the
    ambient inverse certificate, then the first-split inverse of its Schur tail
    inherits the same entrywise bound.  This combines the Problem 13.8
    lower-right block-inverse formula with the first-split/uniform-flat
    reindexing bridge, and is the direct inverse-entry propagation step needed
    by recursive Eq.13.22/Eq.13.23 source chains. -/
theorem
    higham13_problem13_4_firstSplit_schurTail_inverse_entry_bound_from_block_inverse
    {m r : РёЋ}
    (Ablk : Fin ((m + 1) + 1) Рєњ Fin ((m + 1) + 1) Рєњ
      Matrix (Fin r) (Fin r) РёЮ)
    (A11_inv : Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (blockMatrixFirstSplitA11 Ablk)]
    [Invertible (blockMatrixFirstSplitA22 Ablk -
      blockMatrixFirstSplitA21 Ablk * РЁЪ(blockMatrixFirstSplitA11 Ablk) *
        blockMatrixFirstSplitA12 Ablk)]
    [Invertible (Matrix.fromBlocks
      (blockMatrixFirstSplitA11 Ablk)
      (blockMatrixFirstSplitA12 Ablk)
      (blockMatrixFirstSplitA21 Ablk)
      (blockMatrixFirstSplitA22 Ablk))]
    [Invertible (Matrix.fromBlocks
      (blockMatrixFirstSplitA11
        (blockSchur Ablk A11_inv))
      (blockMatrixFirstSplitA12
        (blockSchur Ablk A11_inv))
      (blockMatrixFirstSplitA21
        (blockSchur Ablk A11_inv))
      (blockMatrixFirstSplitA22
        (blockSchur Ablk A11_inv)))]
    (hA11_inv : A11_inv = РЁЪ(blockMatrixFirstSplitA11 Ablk))
    {normAinv : РёЮ}
    (hAinv_entry :
      Рѕђ i j : Fin r РіЋ Fin ((m + 1) * r),
        |(РЁЪ(Matrix.fromBlocks
            (blockMatrixFirstSplitA11 Ablk)
            (blockMatrixFirstSplitA12 Ablk)
            (blockMatrixFirstSplitA21 Ablk)
            (blockMatrixFirstSplitA22 Ablk)) :
          Matrix (Fin r РіЋ Fin ((m + 1) * r))
            (Fin r РіЋ Fin ((m + 1) * r)) РёЮ) i j| РЅц normAinv) :
    Рѕђ i j : Fin r РіЋ Fin (m * r),
      |(РЁЪ(Matrix.fromBlocks
          (blockMatrixFirstSplitA11
            (blockSchur Ablk A11_inv))
          (blockMatrixFirstSplitA12
            (blockSchur Ablk A11_inv))
          (blockMatrixFirstSplitA21
            (blockSchur Ablk A11_inv))
          (blockMatrixFirstSplitA22
            (blockSchur Ablk A11_inv)))) i j| РЅц
        normAinv := by
  classical
  let Tail : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ :=
    blockSchur Ablk A11_inv
  let S : Matrix (Fin ((m + 1) * r)) (Fin ((m + 1) * r)) РёЮ :=
    blockMatrixFirstSplitA22 Ablk -
      blockMatrixFirstSplitA21 Ablk * РЁЪ(blockMatrixFirstSplitA11 Ablk) *
        blockMatrixFirstSplitA12 Ablk
  let Mtail : Matrix (Fin r РіЋ Fin (m * r)) (Fin r РіЋ Fin (m * r)) РёЮ :=
    Matrix.fromBlocks
      (blockMatrixFirstSplitA11 Tail)
      (blockMatrixFirstSplitA12 Tail)
      (blockMatrixFirstSplitA21 Tail)
      (blockMatrixFirstSplitA22 Tail)
  let e : (Fin r РіЋ Fin (m * r)) РЅЃ Fin ((m + 1) * r) :=
    (finSumFinEquiv : (Fin r РіЋ Fin (m * r)) РЅЃ Fin (r + m * r)).trans
      (blockMatrixFirstSplitToFlatFinEquiv :
        Fin (r + m * r) РЅЃ Fin ((m + 1) * r))
  have hSinv_entry :
      Рѕђ i j : Fin ((m + 1) * r),
        |(РЁЪS : Matrix (Fin ((m + 1) * r)) (Fin ((m + 1) * r)) РёЮ) i j| РЅц
          normAinv := by
    simpa [S] using
      (higham13_problem13_4_firstSplit_Sinv_entry_bound_from_block_inverse
        (Ablk := Ablk) hAinv_entry)
  have hMtail :
      Mtail = fun i j : Fin r РіЋ Fin (m * r) => S (e i) (e j) := by
    ext i j
    have hFrom :
        Mtail i j =
          blockMatrixFirstSplitFlat Tail (finSumFinEquiv i) (finSumFinEquiv j) := by
      cases i with
      | inl i =>
          cases j with
          | inl j =>
              simp [Mtail, Tail, Matrix.fromBlocks, blockMatrixFirstSplitFlat,
                blockMatrixFirstSplitA11]
          | inr j =>
              simp [Mtail, Tail, Matrix.fromBlocks, blockMatrixFirstSplitFlat,
                blockMatrixFirstSplitA12]
      | inr i =>
          cases j with
          | inl j =>
              simp [Mtail, Tail, Matrix.fromBlocks, blockMatrixFirstSplitFlat,
                blockMatrixFirstSplitA21]
          | inr j =>
              simp [Mtail, Tail, Matrix.fromBlocks, blockMatrixFirstSplitFlat,
                blockMatrixFirstSplitA22, blockMatrixFlatFin]
    have hFlat := congr_fun (congr_fun
      (blockMatrixFirstSplitFlat_eq_blockMatrixFlatFin_reindex Tail)
      (finSumFinEquiv i)) (finSumFinEquiv j)
    have hS :
        S = blockMatrixFlatFin Tail := by
      simpa [S, Tail, hA11_inv] using
        (blockMatrixFirstSplit_schur_eq_blockMatrixFlatFin_blockSchur
          Ablk (РЁЪ(blockMatrixFirstSplitA11 Ablk)))
    calc
      Mtail i j =
          blockMatrixFirstSplitFlat Tail (finSumFinEquiv i) (finSumFinEquiv j) := hFrom
      _ = blockMatrixFlatFin Tail
          (blockMatrixFirstSplitToFlatFinEquiv (finSumFinEquiv i))
          (blockMatrixFirstSplitToFlatFinEquiv (finSumFinEquiv j)) := hFlat
      _ = S (e i) (e j) := by simp [e, hS]
  simpa [Mtail, Tail] using
    (invOf_entry_bound_of_reindex_eq e S Mtail hMtail hSinv_entry)

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    source max-entry lower-left solve bound from the Problem 13.8 block-inverse
    formula.

    The lower-left block of the full inverse is
    `-SРЂ╗┬╣ AРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣`; multiplying by `S` gives
    `AРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣ = -S (AРЂ╗┬╣)РѓѓРѓЂ`.  Thus the growth certificate
    `||S|| <= ¤Ђ ||A||`, the full-inverse max-entry certificate, and the
    condition-number product imply the first inequality in Problem 13.4. -/
theorem higham13_problem13_4_A21A11inv_maxEntryNormRect_from_block_inverse_growth
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s)
    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A12 : Matrix (Fin r) (Fin s) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    {normA normAinv rho kappaA : РёЮ} (n : РёЋ)
    (hRho : 0 РЅц rho) (hKappa : 0 РЅц kappaA)
    (hsn : (s : РёЮ) РЅц (n : РёЮ))
    (hS_entry : Рѕђ i : Fin s, Рѕђ j : Fin s,
      |(A22 - A21 * РЁЪA11 * A12) i j| РЅц rho * normA)
    (hAinv_entry : Рѕђ i j : Fin r РіЋ Fin s,
      |(РЁЪ(Matrix.fromBlocks A11 A12 A21 A22) :
          Matrix (Fin r РіЋ Fin s) (Fin r РіЋ Fin s) РёЮ) i j| РЅц normAinv)
    (hkappa : normA * normAinv РЅц kappaA) :
    maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
      (n : РёЮ) * rho * kappaA := by
  classical
  let S : Matrix (Fin s) (Fin s) РёЮ := A22 - A21 * РЁЪA11 * A12
  let Ainv21 : Matrix (Fin s) (Fin r) РёЮ :=
    fun i j => (РЁЪ(Matrix.fromBlocks A11 A12 A21 A22) :
      Matrix (Fin r РіЋ Fin s) (Fin r РіЋ Fin s) РёЮ) (Sum.inr i) (Sum.inl j)
  have hAinv21_formula :
      Ainv21 = (-(РЁЪS * A21 * РЁЪA11) : Matrix (Fin s) (Fin r) РёЮ) := by
    ext i j
    have h := congr_fun (congr_fun
      (higham13_problem13_8_block_inverse A11 A12 A21 A22)
      (Sum.inr i)) (Sum.inl j)
    simpa [S, Ainv21, Matrix.fromBlocks] using h
  have hprod_formula :
      (A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ) =
        (-(S * Ainv21) : Matrix (Fin s) (Fin r) РёЮ) := by
    have hS_mul :
        S * Ainv21 =
          (-(A21 * РЁЪA11) : Matrix (Fin s) (Fin r) РёЮ) := by
      rw [hAinv21_formula]
      simp [Matrix.mul_assoc]
    rw [hS_mul]
    simp
  have hAbsBridge : Рѕђ i : Fin s, Рѕђ j : Fin r,
      |(A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ) i j| =
        |rectMatMul S Ainv21 i j| := by
    intro i j
    have h := congr_fun (congr_fun hprod_formula i) j
    calc
      |(A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ) i j|
          = |(-(S * Ainv21 : Matrix (Fin s) (Fin r) РёЮ)) i j| := by
              rw [h]
      _ = |(S * Ainv21 : Matrix (Fin s) (Fin r) РёЮ) i j| := by
              change |-((S * Ainv21 : Matrix (Fin s) (Fin r) РёЮ) i j)| =
                |(S * Ainv21 : Matrix (Fin s) (Fin r) РёЮ) i j|
              rw [abs_neg]
      _ = |rectMatMul S Ainv21 i j| := by
              simp [rectMatMul, Matrix.mul_apply]
  have hBridgeNorm :
      maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
        maxEntryNormRect hs hr (rectMatMul S Ainv21) := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro i j
    rw [hAbsBridge i j]
    exact entry_le_maxEntryNormRect hs hr (rectMatMul S Ainv21) i j
  have hProduct :
      maxEntryNormRect hs hr (rectMatMul S Ainv21) РЅц
        (s : РёЮ) * maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21 :=
    maxEntryNormRect_rectMatMul_le hs hs hr S Ainv21
  have hS_bound :
      maxEntryNormRect hs hs S РЅц rho * normA := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro i j
    exact hS_entry i j
  have hAinv21_bound :
      maxEntryNormRect hs hr Ainv21 РЅц normAinv := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro i j
    exact hAinv_entry (Sum.inr i) (Sum.inl j)
  have hAinv21_nonneg : 0 РЅц maxEntryNormRect hs hr Ainv21 :=
    maxEntryNormRect_nonneg hs hr Ainv21
  have hSupper_nonneg : 0 РЅц rho * normA :=
    le_trans (maxEntryNormRect_nonneg hs hs S) hS_bound
  have hNormProduct :
      maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21 РЅц
        rho * kappaA := by
    have hmul :
        maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21 РЅц
          (rho * normA) * normAinv :=
      mul_le_mul hS_bound hAinv21_bound hAinv21_nonneg hSupper_nonneg
    calc
      maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21
          РЅц (rho * normA) * normAinv := hmul
      _ = rho * (normA * normAinv) := by ring
      _ РЅц rho * kappaA := mul_le_mul_of_nonneg_left hkappa hRho
  have hScaleS :
      (s : РёЮ) * maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21 РЅц
        (s : РёЮ) * (rho * kappaA) := by
    calc
      (s : РёЮ) * maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21 =
          (s : РёЮ) *
            (maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21) := by ring
      _ РЅц (s : РёЮ) * (rho * kappaA) :=
          mul_le_mul_of_nonneg_left hNormProduct (Nat.cast_nonneg s)
  have hScaleN :
      (s : РёЮ) * (rho * kappaA) РЅц (n : РёЮ) * (rho * kappaA) :=
    mul_le_mul_of_nonneg_right hsn (mul_nonneg hRho hKappa)
  calc
    maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ))
        РЅц maxEntryNormRect hs hr (rectMatMul S Ainv21) := hBridgeNorm
    _ РЅц (s : РёЮ) * maxEntryNormRect hs hs S * maxEntryNormRect hs hr Ainv21 :=
        hProduct
    _ РЅц (s : РёЮ) * (rho * kappaA) := hScaleS
    _ РЅц (n : РёЮ) * (rho * kappaA) := hScaleN
    _ = (n : РёЮ) * rho * kappaA := by ring

/-- Higham, 2nd ed., Chapter 13, Problem 13.4 feeding equation (13.22):
    ambient lower-left block budget from the block-inverse proof route.

    The source proof of Problem 13.4 first gives
    `РђќAРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣Рђќ_max <= n ¤Ђ ╬║(A)` from the Schur-growth certificate and a
    full-inverse entry certificate.  Since the Gaussian-elimination growth
    factor is at least one in the ambient source history, this immediately
    supplies the Eq.13.22 lower-factor budget `n ¤Ђ┬▓ ╬║(A)`.

    In recursive uses, `A11,A12,A21,A22` may be the current Schur tail.  The
    hypothesis `hAinv_entry` is deliberately explicit: it is the remaining
    source certificate identifying the current tail inverse entries with
    entries bounded by the original inverse. -/
theorem higham13_problem13_4_L21_eq13_22_premise_from_ambient_block_inverse_growth
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s)
    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A12 : Matrix (Fin r) (Fin s) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    {normA normAinv rho kappaA : РёЮ} (n : РёЋ)
    (hRho_ge_one : 1 РЅц rho) (hKappa : 0 РЅц kappaA)
    (hsn : (s : РёЮ) РЅц (n : РёЮ))
    (hS_entry : Рѕђ i : Fin s, Рѕђ j : Fin s,
      |(A22 - A21 * РЁЪA11 * A12) i j| РЅц rho * normA)
    (hAinv_entry : Рѕђ i j : Fin r РіЋ Fin s,
      |(РЁЪ(Matrix.fromBlocks A11 A12 A21 A22) :
          Matrix (Fin r РіЋ Fin s) (Fin r РіЋ Fin s) РёЮ) i j| РЅц normAinv)
    (hkappa : normA * normAinv РЅц kappaA) :
    maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
      (n : РёЮ) * rho ^ 2 * kappaA := by
  have hRho_nonneg : 0 РЅц rho := le_trans zero_le_one hRho_ge_one
  have hBase :
      maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
        (n : РёЮ) * rho * kappaA :=
    higham13_problem13_4_A21A11inv_maxEntryNormRect_from_block_inverse_growth
      hr hs A11 A12 A21 A22 n hRho_nonneg hKappa hsn hS_entry
      hAinv_entry hkappa
  have hrho_le_sq : rho РЅц rho ^ 2 := by
    have hmul := mul_le_mul_of_nonneg_left hRho_ge_one hRho_nonneg
    simpa [pow_two] using hmul
  have hscale :
      (n : РёЮ) * rho * kappaA РЅц (n : РёЮ) * rho ^ 2 * kappaA := by
    have hn_nonneg : 0 РЅц (n : РёЮ) := Nat.cast_nonneg n
    exact mul_le_mul_of_nonneg_right
      (mul_le_mul_of_nonneg_left hrho_le_sq hn_nonneg) hKappa
  exact le_trans hBase hscale

/-- Higham, 2nd ed., Chapter 13, Problem 13.4 feeding equation (13.22):
    global-growth-tableau form of the ambient lower-left block budget.

    This is the recursive source shape suggested by the printed argument:
    `rho` is the growth factor of one ambient GE history, `hS_le_G` says the
    next Schur complement is contained in that global history, and
    `hAinv_entry` says the current tail inverse entries are bounded by the
    ambient inverse norm.  No local Schur-complement growth factor appears in
    the conclusion. -/
theorem
    higham13_problem13_4_L21_eq13_22_premise_from_global_growth_tableau_exact_kappa
    {r s N : РёЋ} (hr : 0 < r) (hs : 0 < s) (hN : 0 < N)
    (Aglob Gglob AinvGlob : Fin N Рєњ Fin N Рєњ РёЮ)
    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A12 : Matrix (Fin r) (Fin s) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    (hApos : 0 < maxEntryNorm hN Aglob)
    (n : РёЋ) (hsn : (s : РёЮ) РЅц (n : РёЮ))
    (hA_le_G : maxEntryNorm hN Aglob РЅц maxEntryNorm hN Gglob)
    (hS_le_G :
      maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) РЅц
        maxEntryNorm hN Gglob)
    (hAinv_entry : Рѕђ i j : Fin r РіЋ Fin s,
      |(РЁЪ(Matrix.fromBlocks A11 A12 A21 A22) :
          Matrix (Fin r РіЋ Fin s) (Fin r РіЋ Fin s) РёЮ) i j| РЅц
        maxEntryNormRect hN hN AinvGlob) :
    maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
      (n : РёЮ) *
        (growthFactorEntry hN Aglob Gglob hApos) ^ 2 *
        (maxEntryNormRect hN hN Aglob *
          maxEntryNormRect hN hN AinvGlob) := by
  let rho : РёЮ := growthFactorEntry hN Aglob Gglob hApos
  let kappaA : РёЮ :=
    maxEntryNormRect hN hN Aglob * maxEntryNormRect hN hN AinvGlob
  have hRho_ge_one : 1 РЅц rho := by
    simpa [rho] using
      growthFactorEntry_ge_one_of_maxEntryNorm_le hN Aglob Gglob hApos hA_le_G
  have hKappa : 0 РЅц kappaA := by
    exact mul_nonneg (maxEntryNormRect_nonneg hN hN Aglob)
      (maxEntryNormRect_nonneg hN hN AinvGlob)
  have hS_growth :
      maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) РЅц
        rho * maxEntryNormRect hN hN Aglob := by
    calc
      maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12)
          РЅц maxEntryNorm hN Gglob := hS_le_G
      _ = rho * maxEntryNormRect hN hN Aglob := by
          rw [maxEntryNormRect_eq_maxEntryNorm hN Aglob]
          unfold rho growthFactorEntry
          exact (div_mul_cancelРѓђ (maxEntryNorm hN Gglob) (ne_of_gt hApos)).symm
  have hS_entry : Рѕђ i : Fin s, Рѕђ j : Fin s,
      |(A22 - A21 * РЁЪA11 * A12) i j| РЅц
        rho * maxEntryNormRect hN hN Aglob := by
    intro i j
    exact le_trans
      (entry_le_maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) i j)
      hS_growth
  simpa [rho, kappaA] using
    higham13_problem13_4_L21_eq13_22_premise_from_ambient_block_inverse_growth
      hr hs A11 A12 A21 A22 n hRho_ge_one hKappa hsn hS_entry
      hAinv_entry (le_rfl :
        maxEntryNormRect hN hN Aglob * maxEntryNormRect hN hN AinvGlob РЅц
          kappaA)

/-- Higham, 2nd ed., Chapter 13, Problem 13.4 feeding equation (13.22):
    source-indexed global-growth-tableau lower-left block budget.

    This specializes
    `higham13_problem13_4_L21_eq13_22_premise_from_global_growth_tableau_exact_kappa`
    to a source `Fin (r+s)` matrix and the repository canonical inverse
    `nonsingInv`.  The block-identification hypotheses provide the exact
    reindexing certificate, so the only remaining mathematical assumptions are
    the ambient growth-tableau containments for the initial matrix and the
    current Schur complement. -/
theorem
    higham13_problem13_4_L21_eq13_22_premise_from_source_global_growth_tableau_exact_kappa
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s) (hN : 0 < r + s)
    (A G : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A12 : Matrix (Fin r) (Fin s) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
