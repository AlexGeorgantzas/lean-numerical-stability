    (hApos : 0 < maxEntryNorm hN A)
    (n : ℕ)
    (hsn : (s : ℝ) ≤ (n : ℝ))
    (hA_le_G : maxEntryNorm hN A ≤ maxEntryNorm hN G)
    (hS_le_G :
      maxEntryNormRect hs hs (A22 - A21 * ⅟A11 * A12) ≤
