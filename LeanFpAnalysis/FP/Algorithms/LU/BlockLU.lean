  have hAinv_entry :
      ∀ i j : Fin r ⊕ Fin s,
        |(⅟(Matrix.fromBlocks A11 A12 A21 A22) :
          Matrix (Fin r ⊕ Fin s) (Fin r ⊕ Fin s) ℝ) i j| ≤
