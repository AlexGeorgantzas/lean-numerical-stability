    the same CLM diagonal-inverse reciprocal data supplies the initial
    diagonal comparison `invDiagBound j <= РђќA_jjРђќ`. -/
theorem higham13_algorithm13_3_clm_initial_diag_bound_of_diag_inverse
    {m : РёЋ} {E : Type*}
    [NormedAddCommGroup E] [NormedSpace РёЮ E] [ProperSpace E]
    (hunit : ({x : E | РђќxРђќ = 1} : Set E).Nonempty)
    (invDiagBound : Fin m Рєњ РёЮ)
    (A : Fin m Рєњ Fin m Рєњ E РєњL[РёЮ] E)
    (diagInv : Fin m Рєњ E РєњL[РёЮ] E)
    (hInvBound : Рѕђ j : Fin m, invDiagBound j РЅц (РђќdiagInv jРђќ)РЂ╗┬╣)
    (hLeftDiag : Рѕђ j : Fin m, Рѕђ x : E, diagInv j (A j j x) = x)
    (hRightDiag : Рѕђ j : Fin m, Рѕђ y : E, A j j (diagInv j y) = y) :
    Рѕђ j : Fin m, invDiagBound j РЅц РђќA j jРђќ := by
  intro j
  have hunitCopy := hunit
  obtain РЪеx, hxРЪЕ := hunitCopy
  have hLower_eq :
      continuousLinearMapLowerNorm (A j j) hunit = (РђќdiagInv jРђќ)РЂ╗┬╣ :=
    continuousLinearMapLowerNorm_eq_inv_opNorm_of_inverse
      (A j j) (diagInv j) hunit (hLeftDiag j) (hRightDiag j)
  have hLower_le_norm :
      continuousLinearMapLowerNorm (A j j) hunit РЅц РђќA j jРђќ := by
    calc
      continuousLinearMapLowerNorm (A j j) hunit РЅц РђќA j j xРђќ :=
        continuousLinearMapLowerNorm_le (A j j) hunit x hx
      _ РЅц РђќA j jРђќ * РђќxРђќ :=
        ContinuousLinearMap.le_opNorm (A j j) x
      _ = РђќA j jРђќ := by rw [hx, mul_one]
  calc
    invDiagBound j РЅц (РђќdiagInv jРђќ)РЂ╗┬╣ := hInvBound j
    _ = continuousLinearMapLowerNorm (A j j) hunit := hLower_eq.symm
    _ РЅц РђќA j jРђќ := hLower_le_norm

