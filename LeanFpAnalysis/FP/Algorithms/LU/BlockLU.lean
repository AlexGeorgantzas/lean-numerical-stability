theorem higham13_algorithm13_3_matrix_active_stage_bound_of_mixed_column_mass
    {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ)
