theorem higham13_problem13_4_all_tail_inverse_entry_bound_counterexample :
    РѕЃ A Ainv : Fin 2 Рєњ Fin 2 Рєњ РёЮ,
    РѕЃ P Pinv : Fin 1 Рєњ Fin 1 Рєњ РёЮ,
      IsRightInverse 2 A Ainv РѕД IsLeftInverse 2 A Ainv РѕД
