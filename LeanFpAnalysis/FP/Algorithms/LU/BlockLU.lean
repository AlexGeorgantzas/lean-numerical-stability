        maxEntryNormRect (by norm_num : 0 < 2) (by norm_num : 0 < 2) S РЅц
          maxEntryNormRect (by norm_num : 0 < 3) (by norm_num : 0 < 3) A РѕД
        maxEntryNormRect (by norm_num : 0 < 2) (by norm_num : 0 < 2) Sinv РЅц
          maxEntryNormRect (by norm_num : 0 < 3) (by norm_num : 0 < 3) Ainv РѕД
        ┬г maxEntryNormRect (by norm_num : 0 < 2) (by norm_num : 0 < 2) Sinv *
            maxEntryNormRect (by norm_num : 0 < 3) (by norm_num : 0 < 3) A РЅц
