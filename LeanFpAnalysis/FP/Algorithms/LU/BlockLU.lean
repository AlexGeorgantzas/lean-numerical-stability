      _ ≤ dn * (u * (normA + normL * normU)) :=
          mul_le_mul_of_nonneg_right hd_solve hscale
      _ = dn * u * (normA + normL * normU) := by ring
  have hFactDn := hFact.mono_leading hFactLeading
