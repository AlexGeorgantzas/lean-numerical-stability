    (hkM : k < M)
    (tailFull : Fin 2 → Fin M)
    (tailSucc : Fin 1 → Fin M)
    (h0 : tailFull 0 = ⟨k, hkM⟩)
    (hsucc : ∀ i : Fin 1, tailFull (Fin.succ i) = tailSucc i)
