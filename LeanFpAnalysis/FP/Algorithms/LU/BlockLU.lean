                higham13_algorithm13_3_schurStageNorm A pivotInv k j ⟨k, hk⟩ *
                  higham13_algorithm13_3_pivotInvNorm pivotInv k *
                  higham13_algorithm13_3_schurStageNorm A pivotInv k ⟨k, hk⟩ j := hcert_eq
