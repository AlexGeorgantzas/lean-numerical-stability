    omitted Demmel--Higham--Schreiber implementation analysis. -/
theorem higham13_theorem13_6_eq13_16_from_factor_solve_estimates
    (norm╬ћA_fact norm╬ћA_solve : РёЮ)
    (normA normL normU u d_fact d_solve dn : РёЮ)
    (hu : 0 РЅц u) (hA : 0 РЅц normA) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    (hd_fact : d_fact РЅц dn) (hd_solve : d_solve РЅц dn)
    (hFact : norm╬ћA_fact РЅц d_fact * u * (normA + normL * normU))
    (hSolve : norm╬ћA_solve РЅц d_solve * u * (normA + normL * normU)) :
    norm╬ћA_fact РЅц dn * u * (normA + normL * normU) РѕД
      norm╬ћA_solve РЅц dn * u * (normA + normL * normU) РѕД
      max norm╬ћA_fact norm╬ћA_solve РЅц
        dn * u * (normA + normL * normU) := by
  have hsum : 0 РЅц normA + normL * normU := by
    linarith [mul_nonneg hL hU]
  have hscale : 0 РЅц u * (normA + normL * normU) :=
    mul_nonneg hu hsum
  have hFactLeading :
      d_fact * u * (normA + normL * normU) РЅц
        dn * u * (normA + normL * normU) := by
    calc
      d_fact * u * (normA + normL * normU)
          = d_fact * (u * (normA + normL * normU)) := by ring
      _ РЅц dn * (u * (normA + normL * normU)) :=
          mul_le_mul_of_nonneg_right hd_fact hscale
      _ = dn * u * (normA + normL * normU) := by ring
  have hSolveLeading :
      d_solve * u * (normA + normL * normU) РЅц
        dn * u * (normA + normL * normU) := by
    calc
      d_solve * u * (normA + normL * normU)
          = d_solve * (u * (normA + normL * normU)) := by ring
      _ РЅц dn * (u * (normA + normL * normU)) :=
          mul_le_mul_of_nonneg_right hd_solve hscale
      _ = dn * u * (normA + normL * normU) := by ring
  have hFactDn :
      norm╬ћA_fact РЅц dn * u * (normA + normL * normU) :=
    le_trans hFact hFactLeading
  have hSolveDn :
      norm╬ћA_solve РЅц dn * u * (normA + normL * normU) :=
    le_trans hSolve hSolveLeading
  exact РЪеhFactDn, hSolveDn, max_le hFactDn hSolveDnРЪЕ

