theorem higham13_algorithm13_3_source_lowerNorm_table_of_active_schur_pivots
    {m : РёЋ} {E : Type*}
    [NormedAddCommGroup E] [NormedSpace РёЮ E] [ProperSpace E]
    (hunit : ({x : E | РђќxРђќ = 1} : Set E).Nonempty)
    (A : Fin m Рєњ Fin m Рєњ E РєњL[РёЮ] E)
    (pivotInv : РёЋ Рєњ E РєњL[РёЮ] E)
    (hLeft : Рѕђ k : РёЋ, Рѕђ hk : k < m, Рѕђ x : E,
      pivotInv k
        (higham13_algorithm13_3_schurStageBlock
          A pivotInv k РЪеk, hkРЪЕ РЪеk, hkРЪЕ x) = x)
    (hRight : Рѕђ k : РёЋ, Рѕђ hk : k < m, Рѕђ y : E,
      higham13_algorithm13_3_schurStageBlock
          A pivotInv k РЪеk, hkРЪЕ РЪеk, hkРЪЕ
        (pivotInv k y) = y) :
    SchurStageActiveDiagLowerUpdate13_7
        (higham13_algorithm13_3_schurStageNorm A pivotInv)
        (fun k j =>
          continuousLinearMapLowerNorm
            (higham13_algorithm13_3_schurStageBlock A pivotInv k j j)
            hunit)
        (fun k => РђќpivotInv kРђќ) РѕД
      SchurStageActivePivotInvReciprocal13_7
        (fun k j =>
          continuousLinearMapLowerNorm
            (higham13_algorithm13_3_schurStageBlock A pivotInv k j j)
            hunit)
        (fun k => РђќpivotInv kРђќ) := by
  have hSchur : Рѕђ k : РёЋ, Рѕђ hk : k < m, Рѕђ j : Fin m,
      k + 1 РЅц j.val Рєњ Рѕђ x : E,
        higham13_algorithm13_3_schurStageBlock A pivotInv (k + 1) j j x =
          higham13_algorithm13_3_schurStageBlock A pivotInv k j j x -
            higham13_algorithm13_3_schurStageBlock A pivotInv k j РЪеk, hkРЪЕ
              (pivotInv k
                (higham13_algorithm13_3_schurStageBlock A pivotInv k РЪеk, hkРЪЕ j x)) := by
