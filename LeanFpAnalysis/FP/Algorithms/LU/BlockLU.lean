-- ┬Д13.2  Error recurrence constants for Theorem 13.5
-- ============================================================

/-- ╬┤(m) for the partitioned LU backward error recurrence in Theorem 13.5.
    ╬┤ counts block elimination steps minus one: ╬┤(m) = mРѕњ1 for m РЅЦ 1.
    In the book: ╬┤(n,r) with n = m┬иr gives ╬┤ = mРѕњ1. -/
noncomputable def blockErrorDelta : РёЋ Рєњ РёЮ
  | 0 => 0
  | m + 1 => (m : РёЮ)

/-- ╬И(m) for the partitioned LU backward error recurrence in Theorem 13.5.
    Recurrence: ╬И(0) = 0, ╬И(1) = cРѓЃ, ╬И(m+2) = max{cРѓЃ, cРѓѓ, 1 + cРѓЂ + ╬┤(m+1) + ╬И(m+1)}.
    cРѓЂ, cРѓѓ, cРѓЃ are BLAS-3 error constants (scalar parameters).
    For conventional BLAS3: cРѓЂ(m,n,p) = n┬▓, cРѓѓ(m,p) = m┬▓, cРѓЃ(r) = r. -/
noncomputable def blockErrorTheta (cРѓЂ cРѓѓ cРѓЃ : РёЮ) : РёЋ Рєњ РёЮ
  | 0 => 0
  | 1 => cРѓЃ
  | m + 2 => max (max cРѓЃ cРѓѓ)
    (1 + cРѓЂ + blockErrorDelta (m + 1) + blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1))

lemma blockErrorDelta_nonneg (m : РёЋ) : 0 РЅц blockErrorDelta m := by
  cases m with
  | zero => simp [blockErrorDelta]
  | succ m => simp [blockErrorDelta]

lemma blockErrorTheta_nonneg_of_c3_nonneg (cРѓЂ cРѓѓ cРѓЃ : РёЮ) (hcРѓЃ : 0 РЅц cРѓЃ)
    (m : РёЋ) :
    0 РЅц blockErrorTheta cРѓЂ cРѓѓ cРѓЃ m := by
  cases m with
  | zero => simp [blockErrorTheta]
  | succ m =>
      cases m with
      | zero => simpa [blockErrorTheta] using hcРѓЃ
      | succ m =>
          have hmaxРѓЂ : 0 РЅц max cРѓЃ cРѓѓ := le_trans hcРѓЃ (le_max_left cРѓЃ cРѓѓ)
          exact le_trans hmaxРѓЂ
            (le_max_left (max cРѓЃ cРѓѓ)
              (1 + cРѓЂ + blockErrorDelta (m + 1) +
                blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1)))

/-- Source-form recurrence for Theorem 13.5's `╬┤`: after the base one-block
    case, adding one more block increments the constant by one. -/
theorem blockErrorDelta_succ_succ (m : РёЋ) :
    blockErrorDelta (m + 2) = 1 + blockErrorDelta (m + 1) := by
  cases m with
  | zero => simp [blockErrorDelta]
  | succ m =>
      simp [blockErrorDelta]
      ring

/-- Source-form recurrence for Theorem 13.5's `╬И`, in block-count notation. -/
theorem blockErrorTheta_succ_succ (cРѓЂ cРѓѓ cРѓЃ : РёЮ) (m : РёЋ) :
    blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 2) =
      max (max cРѓЃ cРѓѓ)
        (1 + cРѓЂ + blockErrorDelta (m + 1) +
          blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1)) := by
  rfl

lemma blockErrorDelta_le_self (m : РёЋ) :
    blockErrorDelta m РЅц (m : РёЮ) := by
  cases m with
  | zero => simp [blockErrorDelta]
  | succ m => simp [blockErrorDelta]

/-- Higham, 2nd ed., Chapter 13, Section 13.2, p.250:
    recurrence-bound dependency for the `╬И(n,r)=O(n^3)` statement.

    If every local increment in the `╬И` recurrence is bounded by a common
    budget `K`, then `╬И(k)` is bounded by `kK` through block count `m`. -/
theorem blockErrorTheta_le_linear_of_step_bound
    (cРѓЂ cРѓѓ cРѓЃ K : РёЮ) (m : РёЋ)
    (hK : 0 РЅц K)
    (hcРѓѓ : cРѓѓ РЅц K) (hcРѓЃ : cРѓЃ РЅц K)
    (hstep : Рѕђ q : РёЋ, q < m Рєњ 1 + cРѓЂ + blockErrorDelta q РЅц K) :
    Рѕђ k : РёЋ, k РЅц m Рєњ blockErrorTheta cРѓЂ cРѓѓ cРѓЃ k РЅц (k : РёЮ) * K := by
  intro k hk
  induction k with
  | zero =>
      simp [blockErrorTheta]
  | succ k ih =>
      cases k with
      | zero =>
          simpa [blockErrorTheta] using hcРѓЃ
      | succ k =>
          rw [blockErrorTheta_succ_succ]
          apply max_le
          ┬и apply max_le
            ┬и calc
                cРѓЃ РЅц K := hcРѓЃ
                _ РЅц ((k + 2 : РёЋ) : РёЮ) * K := by
                  have hfactor : (1 : РёЮ) РЅц ((k + 2 : РёЋ) : РёЮ) := by
                    have hk0 : 0 РЅц (k : РёЮ) := by exact_mod_cast Nat.zero_le k
                    have hcast : ((k + 2 : РёЋ) : РёЮ) = (k : РёЮ) + 2 := by norm_num
                    rw [hcast]
                    linarith
                  nlinarith [mul_le_mul_of_nonneg_right hfactor hK]
            ┬и calc
                cРѓѓ РЅц K := hcРѓѓ
                _ РЅц ((k + 2 : РёЋ) : РёЮ) * K := by
                  have hfactor : (1 : РёЮ) РЅц ((k + 2 : РёЋ) : РёЮ) := by
                    have hk0 : 0 РЅц (k : РёЮ) := by exact_mod_cast Nat.zero_le k
                    have hcast : ((k + 2 : РёЋ) : РёЮ) = (k : РёЮ) + 2 := by norm_num
                    rw [hcast]
                    linarith
                  nlinarith [mul_le_mul_of_nonneg_right hfactor hK]
          ┬и have hkpred : k + 1 РЅц m := Nat.le_of_succ_le hk
            have hq : k + 1 < m := Nat.lt_of_succ_le hk
            have htheta :
                blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (k + 1) РЅц ((k + 1 : РёЋ) : РёЮ) * K :=
              ih hkpred
            have hlocal : 1 + cРѓЂ + blockErrorDelta (k + 1) РЅц K :=
              hstep (k + 1) hq
            calc
              1 + cРѓЂ + blockErrorDelta (k + 1) +
                  blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (k + 1)
                  РЅц K + ((k + 1 : РёЋ) : РёЮ) * K := by linarith
              _ = ((k + 2 : РёЋ) : РёЮ) * K := by
                have hleft : ((k + 1 : РёЋ) : РёЮ) = (k : РёЮ) + 1 := by norm_num
                have hright : ((k + 2 : РёЋ) : РёЮ) = (k : РёЮ) + 2 := by norm_num
                rw [hleft, hright]
                ring

/-- Higham, 2nd ed., Chapter 13, Section 13.2, p.250:
    cubic envelope for `╬И` when the BLAS3 constants supplied at size `m` are
    bounded quadratically in `m`.

    This is the finite bound behind the source's conventional
    `╬И(n,r)=O(n^3)` sentence. -/
theorem blockErrorTheta_le_cubic_of_quadratic_constants
    (C cРѓЂ cРѓѓ cРѓЃ : РёЮ) (m : РёЋ)
    (hC : 0 РЅц C) (hcРѓЂ : cРѓЂ РЅц C * ((m : РёЮ) + 1) ^ 2)
    (hcРѓѓ : cРѓѓ РЅц C * ((m : РёЮ) + 1) ^ 2)
    (hcРѓЃ : cРѓЃ РЅц C * ((m : РёЮ) + 1) ^ 2) :
    blockErrorTheta cРѓЂ cРѓѓ cРѓЃ m РЅц
      (C + 2) * ((m : РёЮ) + 1) ^ 3 := by
  let M : РёЮ := (m : РёЮ) + 1
  let K : РёЮ := (C + 2) * M ^ 2
  have hK : 0 РЅц K := by
    dsimp [K]
    nlinarith [sq_nonneg M, hC]
  have hC_sq_le_K : C * M ^ 2 РЅц K := by
    dsimp [K]
    nlinarith [sq_nonneg M]
  have hcРѓѓK : cРѓѓ РЅц K := le_trans (by simpa [M] using hcРѓѓ) hC_sq_le_K
  have hcРѓЃK : cРѓЃ РЅц K := le_trans (by simpa [M] using hcРѓЃ) hC_sq_le_K
  have hstep : Рѕђ q : РёЋ, q < m Рєњ 1 + cРѓЂ + blockErrorDelta q РЅц K := by
    intro q hq
    have h╬┤ : blockErrorDelta q РЅц M ^ 2 := by
      have hqle : (q : РёЮ) РЅц (m : РёЮ) := by exact_mod_cast Nat.le_of_lt hq
      have h╬┤self : blockErrorDelta q РЅц (q : РёЮ) := blockErrorDelta_le_self q
      have hm_le_sq : (m : РёЮ) РЅц M ^ 2 := by
        dsimp [M]
        nlinarith [sq_nonneg ((m : РёЮ))]
      linarith
    have h1 : (1 : РёЮ) РЅц M ^ 2 := by
      have hM_ge_one : (1 : РёЮ) РЅц M := by
        dsimp [M]
        have hm0 : 0 РЅц (m : РёЮ) := by exact_mod_cast Nat.zero_le m
        linarith
      nlinarith [sq_nonneg (M - 1)]
    have hcРѓЂK : cРѓЂ РЅц C * M ^ 2 := by simpa [M] using hcРѓЂ
    dsimp [K]
    nlinarith
  have hlin := blockErrorTheta_le_linear_of_step_bound
    cРѓЂ cРѓѓ cРѓЃ K m hK hcРѓѓK hcРѓЃK hstep m (Nat.le_refl m)
  have hmM : (m : РёЮ) РЅц M := by
    dsimp [M]
    linarith
  calc
    blockErrorTheta cРѓЂ cРѓѓ cРѓЃ m РЅц (m : РёЮ) * K := hlin
    _ РЅц M * K := by exact mul_le_mul_of_nonneg_right hmM hK
    _ = (C + 2) * ((m : РёЮ) + 1) ^ 3 := by
      dsimp [K, M]
      ring

/-- Higham, 2nd ed., Chapter 13, Section 13.2, p.250:
    asymptotic `╬И(n,r)=O(n^3)` envelope from the scalar recurrence.

    The hypotheses say that the size-indexed BLAS3 constants used to instantiate
    the recurrence are bounded by a common quadratic envelope in the block
    count.  This is the source-faithful asymptotic content of the conventional
    BLAS3 sentence, separated from the larger computed-factor theorem. -/
theorem higham13_theta_isBigO_cubic_of_quadratic_constants
    (C : РёЮ) (cРѓЂ cРѓѓ cРѓЃ : РёЋ Рєњ РёЮ)
    (hC : 0 РЅц C)
    (hcРѓЃ_nonneg : Рѕђ n : РёЋ, 0 РЅц cРѓЃ n)
    (hcРѓЂ : Рѕђ n : РёЋ, cРѓЂ n РЅц C * ((n : РёЮ) + 1) ^ 2)
    (hcРѓѓ : Рѕђ n : РёЋ, cРѓѓ n РЅц C * ((n : РёЮ) + 1) ^ 2)
    (hcРѓЃ : Рѕђ n : РёЋ, cРѓЃ n РЅц C * ((n : РёЮ) + 1) ^ 2) :
    (fun n : РёЋ => blockErrorTheta (cРѓЂ n) (cРѓѓ n) (cРѓЃ n) n)
      =O[atTop] (fun n : РёЋ => ((n : РёЮ) + 1) ^ 3) := by
  refine IsBigO.of_bound (C + 2) ?_
  exact Filter.Eventually.of_forall fun n => by
    have hbound := blockErrorTheta_le_cubic_of_quadratic_constants
      C (cРѓЂ n) (cРѓѓ n) (cРѓЃ n) n hC (hcРѓЂ n) (hcРѓѓ n) (hcРѓЃ n)
    have hnonneg : 0 РЅц blockErrorTheta (cРѓЂ n) (cРѓѓ n) (cРѓЃ n) n := by
      exact blockErrorTheta_nonneg_of_c3_nonneg (cРѓЂ n) (cРѓѓ n) (cРѓЃ n)
        (hcРѓЃ_nonneg n) n
    simpa [Real.norm_eq_abs, abs_of_nonneg hnonneg,
      abs_of_nonneg (by positivity : 0 РЅц (n : РёЮ) + 1)] using hbound

/-- Higham, 2nd ed., Chapter 13, Section 13.2, p.250:
    conventional BLAS3 constants give the displayed cubic growth of `╬И`.

    This corollary instantiates the preceding theorem with the quadratic
    matrix-size envelope for the matrix-multiply and triangular-solve constants,
    and with a fixed nonnegative diagonal-block LU constant `r`.  The shifted
    cubic `(n+1)^3` is the repository's concrete asymptotic representative for
    the source's `O(n^3)` claim. -/
theorem higham13_theta_conventional_isBigO_cubic (r : РёЮ) (hr : 0 РЅц r) :
    (fun n : РёЋ =>
        blockErrorTheta (((n : РёЮ) + 1) ^ 2) (((n : РёЮ) + 1) ^ 2) r n)
      =O[atTop] (fun n : РёЋ => ((n : РёЮ) + 1) ^ 3) := by
  refine higham13_theta_isBigO_cubic_of_quadratic_constants (max 1 r)
    (fun n : РёЋ => ((n : РёЮ) + 1) ^ 2)
    (fun n : РёЋ => ((n : РёЮ) + 1) ^ 2)
    (fun _n : РёЋ => r)
    ?_ ?_ ?_ ?_ ?_
  ┬и exact le_trans (by norm_num : (0 : РёЮ) РЅц 1) (le_max_left 1 r)
  ┬и intro _n
    exact hr
  ┬и intro n
    simpa using
      mul_le_mul_of_nonneg_right (le_max_left 1 r) (sq_nonneg ((n : РёЮ) + 1))
  ┬и intro n
    simpa using
      mul_le_mul_of_nonneg_right (le_max_left 1 r) (sq_nonneg ((n : РёЮ) + 1))
  ┬и intro n
    have hM_sq : (1 : РёЮ) РЅц ((n : РёЮ) + 1) ^ 2 := by
      have hM_ge_one : (1 : РёЮ) РЅц (n : РёЮ) + 1 := by
        have hn0 : 0 РЅц (n : РёЮ) := by exact_mod_cast Nat.zero_le n
        linarith
      nlinarith [sq_nonneg ((n : РёЮ) + 1 - 1)]
    calc
      r РЅц max 1 r := le_max_right 1 r
      _ РЅц max 1 r * ((n : РёЮ) + 1) ^ 2 := by
        have hC : 0 РЅц max 1 r :=
          le_trans (by norm_num : (0 : РёЮ) РЅц 1) (le_max_left 1 r)
        nlinarith [mul_le_mul_of_nonneg_left hM_sq hC]

