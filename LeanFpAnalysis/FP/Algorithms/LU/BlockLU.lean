          using congr_fun (congr_fun hstage.symm s) t
      ┬и have hcond : ┬г i.val РЅц j.val - 1 + 1 := by
          have hjpos : 0 < j.val :=
            Nat.pos_of_ne_zero (fun h => hj (Fin.ext h))
          have hsub : j.val - 1 + 1 = j.val :=
            Nat.sub_add_cancel hjpos
          simpa [hsub] using hij
