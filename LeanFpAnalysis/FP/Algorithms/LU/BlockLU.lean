theorem higham13_table13_1_col_bdd_backward_error
    (err u c_n normA normL normU : РёЮ) (m : РёЋ)
    (hu : 0 РЅц u) (hc : 0 РЅц c_n) (hU : 0 РЅц normU)
    (hErr : FirstOrderLe u (c_n * u * (normA + normL * normU)) err)
    (hNormL : normL РЅц (m : РёЮ))
    (hNormU : normU РЅц (m : РёЮ) ^ 2 * normA) :
    FirstOrderLe u (c_n * u * ((1 + (m : РёЮ) ^ 3) * normA)) err := by
  have hm : 0 РЅц (m : РёЮ) := Nat.cast_nonneg m
  have hLU : normL * normU РЅц (m : РёЮ) ^ 3 * normA := by
    calc
      normL * normU РЅц (m : РёЮ) * normU :=
        mul_le_mul_of_nonneg_right hNormL hU
      _ РЅц (m : РёЮ) * ((m : РёЮ) ^ 2 * normA) :=
        mul_le_mul_of_nonneg_left hNormU hm
      _ = (m : РёЮ) ^ 3 * normA := by ring
  exact higham13_table13_1_backward_error_from_product_bound
    err u c_n normA (normL * normU) ((m : РёЮ) ^ 3) hu hc hErr hLU

