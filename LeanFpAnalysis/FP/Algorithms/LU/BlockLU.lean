      rw [Finset.insert_erase]
      simpa [tail, activeBlockIndices13_8, hj]
    rw [htail_insert_j]
    have hj_not_erase : j ∉ tail.erase j := by simp
    rw [Finset.sum_insert hj_not_erase]
    simp [hp_ne_j.symm]
    apply Finset.sum_congr rfl
    intro i hi
    have hij : i ≠ j := by
      intro h
      have : i ∉ tail.erase j := by simp [h]
      exact this hi
    have hip : i ≠ p := by
