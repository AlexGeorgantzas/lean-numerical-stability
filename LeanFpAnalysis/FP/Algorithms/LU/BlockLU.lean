    (hInvBound : Рѕђ k : РёЋ, k < m Рєњ Рѕђ j : Fin m,
      k + 1 РЅц j.val Рєњ Рѕђ y : E,
        РђќinvDiag k j yРђќ РЅц normInv k j * РђќyРђќ)
    (hLeft : Рѕђ k : РёЋ, k < m Рєњ Рѕђ j : Fin m,
      k + 1 РЅц j.val Рєњ Рѕђ x : E, invDiag k j (diag k j x) = x) :
    Рѕђ k : РёЋ, k < m Рєњ Рѕђ j : Fin m,
