    (hNormInvPos : Рѕђ k : РёЋ, k < m Рєњ Рѕђ j : Fin m,
      k + 1 РЅц j.val Рєњ 0 < normInv k j)
    (hInvBound : Рѕђ k : РёЋ, k < m Рєњ Рѕђ j : Fin m,
