    ((РЁЪ(A22 - A21 * РЁЪA11 * A12)) : Matrix (Fin s) (Fin s) РёЮ)
    normAinv
    (higham13_problem13_4_Sinv_entry_bound_from_block_inverse
      A11 A12 A21 A22 hAinv_entry)

