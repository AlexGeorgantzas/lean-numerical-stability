-- ┬Д13.3.2  SPD conditional adapters (Lemmas 13.9 and 13.10)
-- ============================================================

/-- Conditional adapter for **Lemma 13.9** (Higham): if the Cholesky/operator-norm
    route supplies `РђќAРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣РђќРѓѓ РЅц ╬║Рѓѓ(A)^{1/2}`, expose that bound under the
    chapter's name.
    From the Cholesky factorization A = RрхђR: AРѓѓРѓЂAРѓЂРѓЂРЂ╗┬╣ = RРѓЂРѓѓрхђRРѓЂРѓЂРЂ╗рхђ,
    so РђќAРѓѓРѓЂAРѓЂРѓЂРЂ╗┬╣РђќРѓѓ РЅц РђќRРѓЂРѓѓРђќРѓѓ ┬и РђќRРѓЂРѓЂРЂ╗┬╣РђќРѓѓ РЅц ╬║Рѓѓ(R) = ╬║Рѓѓ(A)^{1/2}. -/
theorem higham13_lemma13_9_conditional_bound
    (norm2_A21_A11inv kappa2_A : РёЮ)
    (_hkappa : 0 РЅц kappa2_A)
    (hBound : norm2_A21_A11inv РЅц Real.sqrt kappa2_A) :
    norm2_A21_A11inv РЅц Real.sqrt kappa2_A := hBound

/-- Conditional adapter for **Lemma 13.10** (Higham): if the SPD Schur-complement
    condition-number route supplies the bound, expose the source-facing result.
    If A is SPD, the Schur complement
    S = AРѓѓРѓѓ Рѕњ AРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣ AРѓѓРѓЂрхђ satisfies ╬║Рѓѓ(S) РЅц ╬║Рѓѓ(A). -/
theorem higham13_lemma13_10_conditional_bound
    (kappa2_S kappa2_A : РёЮ) (hBound : kappa2_S РЅц kappa2_A) :
    kappa2_S РЅц kappa2_A := hBound

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    scalar bridge from squared Cholesky norm bounds to the product bound.

    The Cholesky proof uses estimates of the form
    `РђќRРѓЂРѓѓРђќРѓѓ┬▓ РЅц РђќAРђќРѓѓ`, `РђќRРѓЂРѓЂРЂ╗┬╣РђќРѓѓ┬▓ РЅц РђќAРЂ╗┬╣РђќРѓѓ`, and
    `РђќAРђќРѓѓ РђќAРЂ╗┬╣РђќРѓѓ РЅц ╬║Рѓѓ(A)`.  This lemma packages just the real-arithmetic
    consequence `РђќRРѓЂРѓѓРђќРѓѓ РђќRРѓЂРѓЂРЂ╗┬╣РђќРѓѓ РЅц ╬║Рѓѓ(A)^{1/2}`. -/
theorem higham13_lemma13_9_product_majorant_from_square_bounds
    {normR12 normR11inv normA normAinv kappa2A : РёЮ}
    (hNormA_nonneg : 0 РЅц normA)
    (hR12sq : normR12 ^ 2 РЅц normA)
    (hR11invsq : normR11inv ^ 2 РЅц normAinv)
    (hkappa : normA * normAinv РЅц kappa2A) :
    normR12 * normR11inv РЅц Real.sqrt kappa2A := by
  apply Real.le_sqrt_of_sq_le
  calc
    (normR12 * normR11inv) ^ 2 = normR12 ^ 2 * normR11inv ^ 2 := by ring
    _ РЅц normA * normAinv := by
        exact mul_le_mul hR12sq hR11invsq
          (sq_nonneg normR11inv) hNormA_nonneg
    _ РЅц kappa2A := hkappa

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    the Cholesky diagonal block equation gives the `RРѓЂРѓѓ` square-bound
    operator certificate.

    If `AРѓѓРѓѓ = RРѓЂРѓѓрхђRРѓЂРѓѓ + RРѓѓРѓѓрхђRРѓѓРѓѓ` and `AРѓѓРѓѓ` has operator-2 bound `normA`,
    then `РђќRРѓЂРѓѓРђќРѓѓ РЅц sqrt(normA)`.  The remaining source-level step is relating
    the principal block bound `РђќAРѓѓРѓѓРђќРѓѓ РЅц РђќAРђќРѓѓ` to the full SPD matrix. -/
theorem higham13_lemma13_9_R12_rectOpNorm2Le_of_A22_cholesky_block
    {r s : РёЋ}
    (A22 : Fin s Рєњ Fin s Рєњ РёЮ)
    (R12 : Fin r Рєњ Fin s Рєњ РёЮ)
    (R22 : Fin s Рєњ Fin s Рєњ РёЮ)
    {normA : РёЮ}
    (hNormA_nonneg : 0 РЅц normA)
    (hA22 : A22 =
      fun j k =>
        (РѕЉ i : Fin r, R12 i j * R12 i k) +
          (РѕЉ l : Fin s, R22 l j * R22 l k))
    (hA22_op : opNorm2Le A22 normA) :
    rectOpNorm2Le R12 (Real.sqrt normA) := by
  apply rectOpNorm2Le_sqrt_of_vecNorm2Sq_le R12 hNormA_nonneg
  intro x
  let y12 : Fin r Рєњ РёЮ := rectMatMulVec R12 x
  let y22 : Fin s Рєњ РёЮ := rectMatMulVec R22 x
  have hquad :
      (РѕЉ j : Fin s, x j * matMulVec s A22 x j) =
        vecNorm2Sq y12 + vecNorm2Sq y22 := by
    rw [hA22]
    dsimp [matMulVec, vecNorm2Sq, rectMatMulVec, y12, y22]
    have h12 :
        (РѕЉ j : Fin s,
            x j *
              (РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k))
          =
        РѕЉ i : Fin r, (РѕЉ j : Fin s, R12 i j * x j) ^ 2 := by
      calc
        (РѕЉ j : Fin s,
            x j *
              (РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k))
            =
          РѕЉ j : Fin s,
            x j *
              (РѕЉ i : Fin r, R12 i j * РѕЉ k : Fin s, R12 i k * x k) := by
              apply Finset.sum_congr rfl
              intro j _hj
              congr 1
              calc
                (РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k)
                    =
                  РѕЉ k : Fin s, РѕЉ i : Fin r, (R12 i j * R12 i k) * x k := by
                    apply Finset.sum_congr rfl
                    intro k _hk
                    rw [Finset.sum_mul]
                _ = РѕЉ i : Fin r, РѕЉ k : Fin s, (R12 i j * R12 i k) * x k := by
                    rw [Finset.sum_comm]
                _ = РѕЉ i : Fin r, R12 i j * РѕЉ k : Fin s, R12 i k * x k := by
                    apply Finset.sum_congr rfl
                    intro i _hi
                    rw [Finset.mul_sum]
                    apply Finset.sum_congr rfl
                    intro k _hk
                    ring
        _ = РѕЉ i : Fin r, (РѕЉ j : Fin s, R12 i j * x j) ^ 2 := by
              calc
                (РѕЉ j : Fin s,
                    x j *
                      (РѕЉ i : Fin r, R12 i j *
                        РѕЉ k : Fin s, R12 i k * x k))
                    =
                  РѕЉ j : Fin s, РѕЉ i : Fin r,
                    x j * (R12 i j * РѕЉ k : Fin s, R12 i k * x k) := by
                    apply Finset.sum_congr rfl
                    intro j _hj
                    rw [Finset.mul_sum]
                _ = РѕЉ i : Fin r, РѕЉ j : Fin s,
                    x j * (R12 i j * РѕЉ k : Fin s, R12 i k * x k) := by
                    rw [Finset.sum_comm]
                _ = РѕЉ i : Fin r, (РѕЉ j : Fin s, R12 i j * x j) ^ 2 := by
                    apply Finset.sum_congr rfl
                    intro i _hi
                    rw [sq, Finset.sum_mul]
                    apply Finset.sum_congr rfl
                    intro j _hj
                    ring
    have h22 :
        (РѕЉ j : Fin s,
            x j *
              (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k))
          =
        РѕЉ l : Fin s, (РѕЉ j : Fin s, R22 l j * x j) ^ 2 := by
      calc
        (РѕЉ j : Fin s,
            x j *
              (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k))
            =
          РѕЉ j : Fin s,
            x j *
              (РѕЉ l : Fin s, R22 l j * РѕЉ k : Fin s, R22 l k * x k) := by
              apply Finset.sum_congr rfl
              intro j _hj
              congr 1
              calc
                (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k)
                    =
                  РѕЉ k : Fin s, РѕЉ l : Fin s, (R22 l j * R22 l k) * x k := by
                    apply Finset.sum_congr rfl
                    intro k _hk
                    rw [Finset.sum_mul]
                _ = РѕЉ l : Fin s, РѕЉ k : Fin s, (R22 l j * R22 l k) * x k := by
                    rw [Finset.sum_comm]
                _ = РѕЉ l : Fin s, R22 l j * РѕЉ k : Fin s, R22 l k * x k := by
                    apply Finset.sum_congr rfl
                    intro l _hl
                    rw [Finset.mul_sum]
                    apply Finset.sum_congr rfl
                    intro k _hk
                    ring
        _ = РѕЉ l : Fin s, (РѕЉ j : Fin s, R22 l j * x j) ^ 2 := by
              calc
                (РѕЉ j : Fin s,
                    x j *
                      (РѕЉ l : Fin s, R22 l j *
                        РѕЉ k : Fin s, R22 l k * x k))
                    =
                  РѕЉ j : Fin s, РѕЉ l : Fin s,
                    x j * (R22 l j * РѕЉ k : Fin s, R22 l k * x k) := by
                    apply Finset.sum_congr rfl
                    intro j _hj
                    rw [Finset.mul_sum]
                _ = РѕЉ l : Fin s, РѕЉ j : Fin s,
                    x j * (R22 l j * РѕЉ k : Fin s, R22 l k * x k) := by
                    rw [Finset.sum_comm]
                _ = РѕЉ l : Fin s, (РѕЉ j : Fin s, R22 l j * x j) ^ 2 := by
                    apply Finset.sum_congr rfl
                    intro l _hl
                    rw [sq, Finset.sum_mul]
                    apply Finset.sum_congr rfl
                    intro j _hj
                    ring
    calc
      (РѕЉ j : Fin s,
          x j *
            (РѕЉ k : Fin s,
              ((РѕЉ i : Fin r, R12 i j * R12 i k) +
                (РѕЉ l : Fin s, R22 l j * R22 l k)) * x k))
          =
        (РѕЉ j : Fin s,
            x j *
              (РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k)) +
          (РѕЉ j : Fin s,
            x j *
              (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k)) := by
          calc
            (РѕЉ j : Fin s,
                x j *
                  (РѕЉ k : Fin s,
                    ((РѕЉ i : Fin r, R12 i j * R12 i k) +
                      (РѕЉ l : Fin s, R22 l j * R22 l k)) * x k))
                =
              РѕЉ j : Fin s,
                (x j *
                    (РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k) +
                  x j *
                    (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k)) := by
                apply Finset.sum_congr rfl
                intro j _hj
                calc
                  x j *
                      (РѕЉ k : Fin s,
                        ((РѕЉ i : Fin r, R12 i j * R12 i k) +
                          (РѕЉ l : Fin s, R22 l j * R22 l k)) * x k)
                      =
                    x j *
                      ((РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k) +
                        (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k)) := by
                      congr 1
                      rw [Рєљ Finset.sum_add_distrib]
                      apply Finset.sum_congr rfl
                      intro k _hk
                      ring
                  _ =
                    x j * (РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k) +
                      x j * (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k) := by
                      ring
            _ =
              (РѕЉ j : Fin s,
                  x j *
                    (РѕЉ k : Fin s, (РѕЉ i : Fin r, R12 i j * R12 i k) * x k)) +
                (РѕЉ j : Fin s,
                  x j *
                    (РѕЉ k : Fin s, (РѕЉ l : Fin s, R22 l j * R22 l k) * x k)) := by
                rw [Finset.sum_add_distrib]
      _ = (РѕЉ i : Fin r, (РѕЉ j : Fin s, R12 i j * x j) ^ 2) +
          (РѕЉ l : Fin s, (РѕЉ j : Fin s, R22 l j * x j) ^ 2) := by
          rw [h12, h22]
  have hR12_le_quad :
      vecNorm2Sq y12 РЅц РѕЉ j : Fin s, x j * matMulVec s A22 x j := by
    rw [hquad]
    exact le_add_of_nonneg_right (vecNorm2Sq_nonneg y22)
  have hquad_bound :
      РѕЉ j : Fin s, x j * matMulVec s A22 x j РЅц normA * vecNorm2Sq x := by
    exact le_trans (le_abs_self _)
      (abs_vecInnerProduct_matMulVec_le_of_opNorm2Le A22 hA22_op x)
  exact le_trans hR12_le_quad hquad_bound

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    the lower-right principal block inherits an operator-2 bound from the full
    two-by-two block matrix.

    This is the source step `РђќAРѓѓРѓѓРђќРѓѓ РЅц РђќAРђќРѓѓ`, stated with the repository's
    finite vector-action operator certificate for the full block matrix. -/
theorem higham13_lemma13_9_A22_opNorm2Le_of_full_block
    {r s : РёЋ}
    (A : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    {normA : РёЮ}
    (hA : finiteOpNorm2Le A normA) :
    opNorm2Le (fun i j : Fin s => A (Sum.inr i) (Sum.inr j)) normA :=
  opNorm2Le_of_finiteOpNorm2Le _
    (finiteOpNorm2Le_sumInr_principal A hA)

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    source-facing equality wrapper for the lower-right principal block
    operator-2 bound. -/
theorem higham13_lemma13_9_A22_opNorm2Le_of_full_block_eq
    {r s : РёЋ}
    (A : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    (A22 : Fin s Рєњ Fin s Рєњ РёЮ)
    {normA : РёЮ}
    (hA22 : A22 = fun i j : Fin s => A (Sum.inr i) (Sum.inr j))
    (hA : finiteOpNorm2Le A normA) :
    opNorm2Le A22 normA := by
  rw [hA22]
  exact higham13_lemma13_9_A22_opNorm2Le_of_full_block A hA

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    combine the lower-right principal-block operator bound with the Cholesky
    diagonal block equation to bound `RРѓЂРѓѓ`.

    This closes the `RРѓЂРѓѓ` square-bound branch once the full block matrix has
    the advertised operator-2 certificate. -/
theorem higham13_lemma13_9_R12_rectOpNorm2Le_of_full_cholesky_block
    {r s : РёЋ}
    (A : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    (A22 : Fin s Рєњ Fin s Рєњ РёЮ)
    (R12 : Fin r Рєњ Fin s Рєњ РёЮ)
    (R22 : Fin s Рєњ Fin s Рєњ РёЮ)
    {normA : РёЮ}
    (hNormA_nonneg : 0 РЅц normA)
    (hA22_block : A22 = fun i j : Fin s => A (Sum.inr i) (Sum.inr j))
    (hA22_chol : A22 =
      fun j k =>
        (РѕЉ i : Fin r, R12 i j * R12 i k) +
          (РѕЉ l : Fin s, R22 l j * R22 l k))
    (hA : finiteOpNorm2Le A normA) :
    rectOpNorm2Le R12 (Real.sqrt normA) :=
  higham13_lemma13_9_R12_rectOpNorm2Le_of_A22_cholesky_block
    A22 R12 R22 hNormA_nonneg hA22_chol
    (higham13_lemma13_9_A22_opNorm2Le_of_full_block_eq A A22 hA22_block hA)

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    the upper-left principal block of the inverse matrix inherits an
    operator-2 bound from the full inverse.

    This is the source step `РђќAРѓЂРѓЂРЂ╗┬╣РђќРѓѓ РЅц РђќAРЂ╗┬╣РђќРѓѓ` in certificate form. -/
theorem higham13_lemma13_9_A11inv_opNorm2Le_of_full_inverse_block
    {r s : РёЋ}
    (Ainv : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    {normAinv : РёЮ}
    (hAinv : finiteOpNorm2Le Ainv normAinv) :
    opNorm2Le (fun i j : Fin r => Ainv (Sum.inl i) (Sum.inl j)) normAinv :=
  opNorm2Le_of_finiteOpNorm2Le _
    (finiteOpNorm2Le_sumInl_principal Ainv hAinv)

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    source-facing equality wrapper for the upper-left inverse principal-block
    operator-2 bound. -/
theorem higham13_lemma13_9_A11inv_opNorm2Le_of_full_inverse_block_eq
    {r s : РёЋ}
    (Ainv : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    (A11inv : Fin r Рєњ Fin r Рєњ РёЮ)
    {normAinv : РёЮ}
    (hA11inv : A11inv = fun i j : Fin r => Ainv (Sum.inl i) (Sum.inl j))
    (hAinv : finiteOpNorm2Le Ainv normAinv) :
    opNorm2Le A11inv normAinv := by
  rw [hA11inv]
  exact higham13_lemma13_9_A11inv_opNorm2Le_of_full_inverse_block Ainv hAinv

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    the inverse Cholesky block equation gives the `RРѓЂРѓЂРЂ╗┬╣` square-bound
    operator certificate.

    The equation `AРѓЂРѓЂРЂ╗┬╣ = RРѓЂРѓЂРЂ╗┬╣ RРѓЂРѓЂРЂ╗рхђ` first bounds `RРѓЂРѓЂРЂ╗рхђ`; the repository
    transpose norm bridge then gives the same bound for `RРѓЂРѓЂРЂ╗┬╣`. -/
theorem higham13_lemma13_9_R11inv_rectOpNorm2Le_of_A11inv_cholesky_block
    {r : РёЋ}
    (A11inv R11inv : Fin r Рєњ Fin r Рєњ РёЮ)
    {normAinv : РёЮ}
    (hNormAinv_nonneg : 0 РЅц normAinv)
    (hA11inv : A11inv =
      fun j k => РѕЉ i : Fin r, R11inv j i * R11inv k i)
    (hA11inv_op : opNorm2Le A11inv normAinv) :
    rectOpNorm2Le R11inv (Real.sqrt normAinv) := by
  have hT :
      rectOpNorm2Le (finiteTranspose R11inv) (Real.sqrt normAinv) := by
    refine higham13_lemma13_9_R12_rectOpNorm2Le_of_A22_cholesky_block
      A11inv (finiteTranspose R11inv) (fun _ _ : Fin r => 0)
      hNormAinv_nonneg ?_ hA11inv_op
    rw [hA11inv]
    ext j k
    simp [finiteTranspose]
  have hTT :=
    rectOpNorm2Le_finiteTranspose_of_rectOpNorm2Le
      (finiteTranspose R11inv) (Real.sqrt_nonneg normAinv) hT
  simpa [finiteTranspose] using hTT

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    combine the full inverse principal-block bound with the inverse Cholesky
    block equation to bound `RРѓЂРѓЂРЂ╗┬╣`. -/
theorem higham13_lemma13_9_R11inv_rectOpNorm2Le_of_full_inverse_cholesky_block
    {r s : РёЋ}
    (Ainv : (Fin r РіЋ Fin s) Рєњ (Fin r РіЋ Fin s) Рєњ РёЮ)
    (A11inv R11inv : Fin r Рєњ Fin r Рєњ РёЮ)
    {normAinv : РёЮ}
    (hNormAinv_nonneg : 0 РЅц normAinv)
    (hA11inv_block :
      A11inv = fun i j : Fin r => Ainv (Sum.inl i) (Sum.inl j))
    (hA11inv_chol : A11inv =
      fun j k => РѕЉ i : Fin r, R11inv j i * R11inv k i)
    (hAinv : finiteOpNorm2Le Ainv normAinv) :
    rectOpNorm2Le R11inv (Real.sqrt normAinv) :=
  higham13_lemma13_9_R11inv_rectOpNorm2Le_of_A11inv_cholesky_block
    A11inv R11inv hNormAinv_nonneg hA11inv_chol
    (higham13_lemma13_9_A11inv_opNorm2Le_of_full_inverse_block_eq
      Ainv A11inv hA11inv_block hAinv)

/-- Higham, 2nd ed., Chapter 13, Lemma 13.9 proof route:
    Cholesky block product route for the bound
    `РђќAРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣РђќРѓѓ РЅц ╬║Рѓѓ(A)^{1/2}`.

    If `RРѓЂРѓѓ` and `RРѓЂРѓЂРЂ╗┬╣` have operator-2 certificates and the Cholesky
    condition-number comparison supplies
    `РђќRРѓЂРѓѓРђќРѓѓ РђќRРѓЂРѓЂРЂ╗┬╣РђќРѓѓ РЅц ╬║Рѓѓ(A)^{1/2}`, then the product
    `RРѓЂРѓѓрхђ RРѓЂРѓЂРЂ╗рхђ` has the desired operator-2 certificate.  The remaining
    Lemma 13.9 source obligations are the Cholesky block identity
    `AРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣ = RРѓЂРѓѓрхђ RРѓЂРѓЂРЂ╗рхђ` and the two condition-number comparisons. -/
theorem higham13_lemma13_9_cholesky_route_transpose_rectOpNorm2Le
    {r s : РёЋ}
    (R12 : Fin r Рєњ Fin s Рєњ РёЮ)
    (R11inv : Fin r Рєњ Fin r Рєњ РёЮ)
    {normR12 normR11inv kappa2A : РёЮ}
    (hR12_nonneg : 0 РЅц normR12)
    (hR11inv_nonneg : 0 РЅц normR11inv)
    (hR12 : rectOpNorm2Le R12 normR12)
    (hR11inv : rectOpNorm2Le R11inv normR11inv)
    (hProd : normR12 * normR11inv РЅц Real.sqrt kappa2A) :
    rectOpNorm2Le
