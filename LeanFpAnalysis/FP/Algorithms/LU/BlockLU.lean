theorem higham13_algorithm13_3_diagLowerCertGeneric_active_le_of_diag_update
    {m : ℕ} {α : Type*} [Norm α] [Sub α] [Mul α]
    (invDiagBound : Fin m → ℝ)
    (A : Fin m → Fin m → α) (pivotInv : ℕ → α)
