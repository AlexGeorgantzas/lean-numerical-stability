  simp [higham13_algorithm13_3_lowerFromMatrixStages, hji]

/-- The assembled matrix-stage lower factor has identity diagonal blocks. -/
theorem higham13_algorithm13_3_lowerFromMatrixStages_diag {m r : ℕ}
