theorem higham13_problem13_4_maxEntry_bounds_from_source_block_inverse_growth
    {r s : ℕ} (hr : 0 < r) (hs : 0 < s) (hN : 0 < r + s)
    (A : Fin (r + s) → Fin (r + s) → ℝ)
