/-- Higham, 2nd ed., Chapter 13, Lemma 13.10:
    if the source block matrix `A` is symmetric positive definite, then the
    Schur complement
    `S = AРѓѓРѓѓ - AРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣ AРѓѓРѓЂрхђ` satisfies `╬║Рѓѓ(S) РЅц ╬║Рѓѓ(A)`.

    The blocks are the standard leading/trailing blocks induced by
    `finSumFinEquiv`, and both condition numbers use the repository's
    source-facing exact 2-norm product with the canonical `nonsingInv`. -/
theorem higham13_lemma13_10_schur_kappa_bound_of_spd
    {r s : РёЋ} [Nonempty (Fin s)]
    (A : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
    (hSPD : IsSymPosDef (r + s) A) :
    let A11 : Matrix (Fin r) (Fin r) РёЮ :=
      fun i j =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s))
    let A21 : Matrix (Fin s) (Fin r) РёЮ :=
      fun i j =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s))
    let A22 : Matrix (Fin s) (Fin s) РёЮ :=
      fun i j =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s))
    let S : Fin s Рєњ Fin s Рєњ РёЮ :=
      fun i j => (A22 - A21 * A11РЂ╗┬╣ * A21рхђ) i j
    kappa2 S (nonsingInv s S) РЅц kappa2 A (nonsingInv (r + s) A) := by
  classical
  let A11 : Matrix (Fin r) (Fin r) РёЮ :=
    fun i j =>
      A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
        (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s))
  let A21 : Matrix (Fin s) (Fin r) РёЮ :=
    fun i j =>
      A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
        (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s))
  let A22 : Matrix (Fin s) (Fin s) РёЮ :=
    fun i j =>
      A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
        (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s))
  let S : Fin s Рєњ Fin s Рєњ РёЮ :=
    fun i j => (A22 - A21 * A11РЂ╗┬╣ * A21рхђ) i j
  change kappa2 S (nonsingInv s S) РЅц
    kappa2 A (nonsingInv (r + s) A)
  have hFull_eq :
      Matrix.fromBlocks A11 A21рхђ A21 A22 =
        (fun i j : Fin r РіЋ Fin s =>
          A (finSumFinEquiv i) (finSumFinEquiv j)) := by
    ext i j
    cases i with
    | inl i =>
        cases j with
        | inl j =>
            rfl
        | inr j =>
            exact hSPD.1
              (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s))
              (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
    | inr i =>
        cases j with
        | inl j =>
            rfl
        | inr j =>
            rfl
  have hFull : (Matrix.fromBlocks A11 A21рхђ A21 A22).PosDef := by
    rw [hFull_eq]
    exact
      matrix_posDef_submatrix_of_injective
        (isSymPosDef_to_matrix_posDef A hSPD)
        (fun i : Fin r РіЋ Fin s => finSumFinEquiv i)
        finSumFinEquiv.injective
  have hA11_block : A11 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)) := rfl
  have hA12_block : A21рхђ =
      fun (i : Fin r) (j : Fin s) =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)) := by
    ext i j
    exact hSPD.1
      (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s))
      (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
  have hA21_block : A21 =
      fun (i : Fin s) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)) := rfl
  have hA22_block : A22 =
      fun i j : Fin s =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)) := rfl
  have hmain :=
    higham13_lemma13_10_schur_kappa_bound_of_source_posDef_block
      A A11 A21 A22 hFull
      hA11_block hA12_block hA21_block hA22_block
  simpa [S, nonsingInv] using hmain

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    Schur-complement max-entry condition-product bridge with the `SРЂ╗┬╣`
    certificate derived from the Problem 13.8 block inverse formula. -/
theorem higham13_problem13_4_schur_kappa_maxEntryNormRect_from_block_inverse
    {r s : РёЋ} (hs : 0 < s)
    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A12 : Matrix (Fin r) (Fin s) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    {normA normAinv rho kappaA : РёЮ}
    (hRho : 0 РЅц rho)
    (hS_entry : Рѕђ i : Fin s, Рѕђ j : Fin s,
      |(A22 - A21 * РЁЪA11 * A12) i j| РЅц rho * normA)
    (hAinv_entry : Рѕђ i j : Fin r РіЋ Fin s,
      |(РЁЪ(Matrix.fromBlocks A11 A12 A21 A22) :
          Matrix (Fin r РіЋ Fin s) (Fin r РіЋ Fin s) РёЮ) i j| РЅц normAinv)
    (hkappa : normA * normAinv РЅц kappaA) :
    maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) *
        maxEntryNormRect hs hs
          ((РЁЪ(A22 - A21 * РЁЪA11 * A12)) : Matrix (Fin s) (Fin s) РёЮ) РЅц
      rho * kappaA :=
