theorem higham13_eq13_22_blockLUBudgetChain_one_from_matrix_stage_history_exact_kappa
    {r : ℕ} (hr : 0 < r)
    (Ablk : Fin 1 → Fin 1 → Matrix (Fin r) (Fin r) ℝ)
