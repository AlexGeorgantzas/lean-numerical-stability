theorem higham13_theorem13_5_residual_and_recurrence_from_specs
    {r s : Type*} [Fintype r] [Fintype s]
    (m : РёЋ)
    (u cРѓЂ cРѓѓ cРѓЃ normA normL normU
      normDeltaA11 normDeltaA12 normDeltaA21 normDeltaA22 : РёЮ)
    (Lhat11 Uhat11 A11 DeltaA11 : Matrix r r РёЮ)
    (Uhat12 A12 DeltaA12 : Matrix r s РёЮ)
    (Lhat21 A21 DeltaA21 : Matrix s r РёЮ)
    (Lhat22 Uhat22 A22 DeltaA22 : Matrix s s РёЮ)
    (hu : 0 РЅц u) (hcРѓЂ : 0 РЅц cРѓЂ) (hcРѓѓ : 0 РЅц cРѓѓ) (hcРѓЃ : 0 РЅц cРѓЃ)
    (hA : 0 РЅц normA) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    (h11 : LocalLUFirstOrderSpec u cРѓЃ normL normU normDeltaA11
      A11 DeltaA11 Lhat11 Uhat11)
    (h12 : TriangularSolveFirstOrderSpec u cРѓѓ normL normU normDeltaA12
      Lhat11 A12 DeltaA12 Uhat12)
    (h21 : RightTriangularSolveFirstOrderSpec u cРѓѓ normU normL normDeltaA21
      Uhat11 A21 DeltaA21 Lhat21)
    (h22_residual : Lhat21 * Uhat12 + Lhat22 * Uhat22 = A22 + DeltaA22)
    (h22_bound : FirstOrderLe u
      (u * ((1 + blockErrorDelta (m + 1)) * normA +
        (1 + cРѓЂ + blockErrorDelta (m + 1) +
          blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 1)) * normL * normU))
      normDeltaA22) :
    (Matrix.fromBlocks Lhat11 0 Lhat21 Lhat22 *
        Matrix.fromBlocks Uhat11 Uhat12 0 Uhat22 =
      Matrix.fromBlocks A11 A12 A21 A22 +
        Matrix.fromBlocks DeltaA11 DeltaA12 DeltaA21 DeltaA22) РѕД
      FirstOrderLe u
        (u * (blockErrorDelta (m + 2) * normA +
          blockErrorTheta cРѓЂ cРѓѓ cРѓЃ (m + 2) * normL * normU))
        (max (max normDeltaA11 normDeltaA12)
          (max normDeltaA21 normDeltaA22)) := by
  refine РЪе?_, ?_РЪЕ
  ┬и exact higham13_theorem13_5_block_residual_identity_from_specs
      u cРѓѓ cРѓЃ normL normU normDeltaA11 normU normDeltaA12 normL
      normDeltaA21 Lhat11 Uhat11 A11 DeltaA11 Uhat12 A12 DeltaA12
      Lhat21 A21 DeltaA21 Lhat22 Uhat22 A22 DeltaA22 h11 h12 h21
      h22_residual
  ┬и have h11_bound : FirstOrderLe u (cРѓЃ * u * normL * normU) normDeltaA11 := by
      simpa [LocalLUFirstOrderBound] using h11.norm_bound
    have h12_bound : FirstOrderLe u (cРѓѓ * u * normL * normU) normDeltaA12 := by
      simpa [TriangularSolveFirstOrderBound] using h12.norm_bound
    have h21_bound : FirstOrderLe u (cРѓѓ * u * normL * normU) normDeltaA21 := by
      simpa [TriangularSolveFirstOrderBound, mul_assoc, mul_left_comm, mul_comm]
        using h21.norm_bound
    exact higham13_theorem13_5_recurrence_step_firstOrder
      m normDeltaA11 normDeltaA12 normDeltaA21 normDeltaA22 normA normL normU
      u cРѓЂ cРѓѓ cРѓЃ hu hcРѓЂ hcРѓѓ hcРѓЃ hA hL hU h11_bound h12_bound h21_bound
      h22_bound

/-- Higham, 2nd ed., Chapter 13, Section 13.2, Theorem 13.5 induction step:
