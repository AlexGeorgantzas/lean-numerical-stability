noncomputable def higham13_algorithm13_3_activeSuffixTail
    (M k b : РёЋ) (hkb : k + b РЅц M) : Fin b Рєњ Fin M :=
  fun i => РЪеk + i.val, by
    have hi : i.val < b := i.isLt
