            (blockMatrixFirstSplitA11
              (higham13_algorithm13_3_activeSuffixStageTailBlock A pivotInv k m hkm))
            (blockMatrixFirstSplitA12
              (higham13_algorithm13_3_activeSuffixStageTailBlock A pivotInv k m hkm))
