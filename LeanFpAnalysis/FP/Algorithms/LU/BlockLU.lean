  ext i j s t
  by_cases hi : i = 0
  ┬и subst i
    simp [blockLUOneStepU,
      higham13_algorithm13_3_upperFromMatrixStages_first_row]
  ┬и by_cases hj : j = 0
    ┬и subst j
      have hji : (0 : Fin (m + 1)).val < i.val := by
        have hival : i.val РЅа 0 := fun h => hi (Fin.ext h)
        simpa using Nat.pos_of_ne_zero hival
