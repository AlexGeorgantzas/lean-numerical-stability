    (stageInvDiagBound : РёЋ Рєњ Fin ((m + 1) + 1) Рєњ РёЮ)
    (hDom :
      IsBlockDiagDomCol ((m + 1) + 1)
        (fun i j => maxEntryNorm hr (Ablk i j)) invDiagBound)
    (hDiagBound : Рѕђ j : Fin ((m + 1) + 1),
      invDiagBound j РЅц maxEntryNorm hr (Ablk j j))
    (hInitInv : Рѕђ j : Fin ((m + 1) + 1),
      stageInvDiagBound 0 j = invDiagBound j)
    (hPivotInvBound : Рѕђ k : РёЋ, Рѕђ hk : k < (m + 1) + 1,
      maxEntryNorm hr (pivotInv k) * stageInvDiagBound k РЪеk, hkРЪЕ РЅц 1)
