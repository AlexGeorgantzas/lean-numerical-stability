      (hsn : (((m + 1) * r : РёЋ) : РёЮ) РЅц (n : РёЮ))
      (hNn : ((((m + 1) + 1) * r : РёЋ) : РёЮ) РЅц (n : РёЮ)) :
      (let hmTail : 0 < m + 1 := Nat.succ_pos m
