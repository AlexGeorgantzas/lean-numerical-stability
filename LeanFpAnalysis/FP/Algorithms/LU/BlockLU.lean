    `РђќAРђќ + РђќLhatРђќРђќUhatРђќ`. -/
theorem dhs_block_forward_residual_leading_term_le_of_coeff_bounds
    (u cРѓё cForward normA normL normU normLhat21 normA11 : РёЮ)
    (hu : 0 РЅц u) (hcРѓё_nonneg : 0 РЅц cРѓё)
    (hA : 0 РЅц normA) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    (hcРѓё_le : cРѓё РЅц cForward)
    (hLocalScale : normLhat21 * normA11 РЅц normA + normL * normU) :
    cРѓё * u * normLhat21 * normA11 РЅц
      cForward * u * (normA + normL * normU) := by
  have hsum : 0 РЅц normA + normL * normU := by
    linarith [mul_nonneg hL hU]
  have hcРѓёu : 0 РЅц cРѓё * u := mul_nonneg hcРѓё_nonneg hu
  have hscale : 0 РЅц u * (normA + normL * normU) :=
    mul_nonneg hu hsum
  calc
    cРѓё * u * normLhat21 * normA11
        = (cРѓё * u) * (normLhat21 * normA11) := by ring
    _ РЅц (cРѓё * u) * (normA + normL * normU) :=
        mul_le_mul_of_nonneg_left hLocalScale hcРѓёu
    _ = cРѓё * (u * (normA + normL * normU)) := by ring
    _ РЅц cForward * (u * (normA + normL * normU)) :=
        mul_le_mul_of_nonneg_right hcРѓё_le hscale
    _ = cForward * u * (normA + normL * normU) := by ring

