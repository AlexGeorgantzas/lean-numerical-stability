              (higham13_algorithm13_3_schurStageMatrixTailBlock A pivotInv k tailFull))
            (blockMatrixFirstSplitA21
              (higham13_algorithm13_3_schurStageMatrixTailBlock A pivotInv k tailFull))
            (blockMatrixFirstSplitA22
              (higham13_algorithm13_3_schurStageMatrixTailBlock A pivotInv k tailFull))) :
