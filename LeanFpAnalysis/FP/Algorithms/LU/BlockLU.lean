    exact
      higham13_theorem13_8_active_stage_block_bound_of_exact_update
        (fun i j : Fin m => ‖A i j‖) invDiagBound hDom hDiagBound
        (higham13_algorithm13_3_schurStageBlock A pivotInv) pivotInv
