-- ┬Д13.3.1  Theorem 13.8 one-step growth bound
-- ============================================================

/-- **Theorem 13.8 one-step growth bound** (Demmel--Higham--Schreiber).
    For a block diag dom matrix, the Schur complement block column sums
    are bounded by the original column sums. Combined with РѕЉ_i РђќA_{ij}Рђќ РЅц 2max РђќA_{ij}Рђќ
    (eq. 13.19), this gives max_{kРЅцi,jРЅцm} РђќA^(k)_{ij}Рђќ РЅц 2 max_{i,j} РђќA_{ij}Рђќ. -/
theorem block_diag_dom_growth_bound_step {m : РёЋ}
    (blockNorm : Fin (m + 1) Рєњ Fin (m + 1) Рєњ РёЮ)
    (hNorm : Рѕђ i j, 0 РЅц blockNorm i j)
    (invDiagBound : Fin (m + 1) Рєњ РёЮ)
    (normInv : РёЮ) (hNormInv : 0 РЅц normInv)
    (hDom : IsBlockDiagDomCol (m + 1) blockNorm invDiagBound)
    (hNormInvBound : normInv * invDiagBound 0 РЅц 1)
    (schurNorm : Fin m Рєњ Fin m Рєњ РёЮ)
    (hSchurBound : Рѕђ i j : Fin m,
      schurNorm i j РЅц blockNorm i.succ j.succ +
        blockNorm i.succ 0 * normInv * blockNorm 0 j.succ) :
    Рѕђ j : Fin m, РѕЉ i : Fin m, schurNorm i j РЅц
      РѕЉ i : Fin (m + 1), blockNorm i j.succ := by
  intro j
  have h_sum_le : РѕЉ i : Fin m, blockNorm i.succ 0 РЅц invDiagBound 0 := by
    have hdom_0 := hDom 0
    rw [Fin.sum_univ_succ] at hdom_0
    simp only [ite_true] at hdom_0
    simp_rw [show Рѕђ k : Fin m, (if k.succ = (0 : Fin (m + 1)) then (0 : РёЮ)
      else blockNorm k.succ 0) = blockNorm k.succ 0 from
      fun k => by simp [Fin.succ_ne_zero]] at hdom_0
    linarith
  calc РѕЉ i : Fin m, schurNorm i j
      РЅц РѕЉ i : Fin m, (blockNorm i.succ j.succ +
          blockNorm i.succ 0 * normInv * blockNorm 0 j.succ) :=
        Finset.sum_le_sum (fun i _ => hSchurBound i j)
    _ = РѕЉ i : Fin m, blockNorm i.succ j.succ +
        (РѕЉ i : Fin m, blockNorm i.succ 0) * normInv * blockNorm 0 j.succ := by
        rw [Finset.sum_add_distrib]; congr 1
        rw [Finset.sum_mul, Finset.sum_mul]
    _ РЅц РѕЉ i : Fin m, blockNorm i.succ j.succ + blockNorm 0 j.succ := by
        nlinarith [hNorm 0 j.succ, hNormInvBound,
          mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_right h_sum_le hNormInv) (hNorm 0 j.succ)]
    _ = РѕЉ i : Fin (m + 1), blockNorm i j.succ := by
        rw [Fin.sum_univ_succ]; ring

