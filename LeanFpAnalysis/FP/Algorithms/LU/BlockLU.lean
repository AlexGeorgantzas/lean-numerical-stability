theorem higham13_eq13_22_tail_upper_budget_le_full_matrix_stage_history_exact_kappa
    {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (hTailPos :
