  let pivotInv : РёЋ Рєњ Matrix (Fin 2) (Fin 2) РёЮ := fun _ => J
  have hineq :=
    h A pivotInv 0 (by norm_num) РЪе1, by norm_numРЪЕ РЪе1, by norm_numРЪЕ
