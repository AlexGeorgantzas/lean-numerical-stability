    {r s : ℕ} [Nonempty (Fin s)] [Nonempty (Fin r)]
    (A21 : Fin s → Fin r → ℝ)
    (A11inv R11 R11inv : Fin r → Fin r → ℝ)
    (R12 : Fin r → Fin s → ℝ)
    {normR12 normR11inv normA normAinv kappa2A : ℝ}
