    (A : Fin m Рєњ Fin m Рєњ ╬▒) (pivotInv : РёЋ Рєњ ╬▒)
    (stageBlock : РёЋ Рєњ Fin m Рєњ Fin m Рєњ E РєњL[РёЮ] E)
    (pivotInvCLM : РёЋ Рєњ E РєњL[РёЮ] E)
    (hInit : Рѕђ j : Fin m,
