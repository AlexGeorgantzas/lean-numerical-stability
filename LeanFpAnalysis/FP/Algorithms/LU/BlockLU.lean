  ┬и calc norm╬ћA_fact РЅц d_fact * u * (normA + normL * normU) := hFact
      _ РЅц max d_fact d_solve * u * (normA + normL * normU) := by
          nlinarith [mul_le_mul_of_nonneg_right (le_max_left d_fact d_solve) husum]
  ┬и calc norm╬ћA_solve РЅц d_solve * u * (normA + normL * normU) := hSolve
      _ РЅц max d_fact d_solve * u * (normA + normL * normU) := by
          nlinarith [mul_le_mul_of_nonneg_right (le_max_right d_fact d_solve) husum]

