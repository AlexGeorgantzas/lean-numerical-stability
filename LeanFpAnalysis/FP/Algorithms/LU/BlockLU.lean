theorem block_lu_solve_backward_error
    (norm╬ћA_fact norm╬ћA_solve : РёЮ)
    (normA normL normU u d_fact d_solve : РёЮ)
    (hu : 0 РЅц u) (_hd_f : 0 РЅц d_fact) (_hd_s : 0 РЅц d_solve)
    (hA : 0 РЅц normA) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    (hFact : norm╬ћA_fact РЅц d_fact * u * (normA + normL * normU))
    (hSolve : norm╬ћA_solve РЅц d_solve * u * (normA + normL * normU)) :
    max norm╬ћA_fact norm╬ћA_solve РЅц
      max d_fact d_solve * u * (normA + normL * normU) := by
  have hsum : 0 РЅц normA + normL * normU := by linarith [mul_nonneg hL hU]
  have husum : 0 РЅц u * (normA + normL * normU) := mul_nonneg hu hsum
