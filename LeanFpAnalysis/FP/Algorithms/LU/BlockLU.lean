    `higham13_lemma13_9_cholesky_route_rectOpNorm2Le_from_cholesky_fact_fin_sum_spd_kappa2_nonsingInv`:
    the remaining non-existential source step is to identify the displayed
    `AРѓЂРѓЂРЂ╗┬╣` used in the chapter with this Cholesky-derived inverse expression. -/
theorem
    higham13_lemma13_9_exists_cholesky_route_rectOpNorm2Le_from_spd_kappa2_nonsingInv
    {r s : РёЋ} [Nonempty (Fin r)]
    (A : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
    (A22 : Fin s Рєњ Fin s Рєњ РёЮ)
    (A21 : Fin s Рєњ Fin r Рєњ РёЮ)
    (hA22_block : A22 =
      fun i j : Fin s =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)))
    (hA21_block : A21 =
      fun (i : Fin s) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)))
    (hSPD : IsSymPosDef (r + s) A) :
    РѕЃ (R : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
      (R11 : Fin r Рєњ Fin r Рєњ РёЮ)
      (R12 : Fin r Рєњ Fin s Рєњ РёЮ)
      (R22 : Fin s Рєњ Fin s Рєњ РёЮ)
      (A11inv : Fin r Рєњ Fin r Рєњ РёЮ),
      CholeskyFactSpec (r + s) A R РѕД
      (Рѕђ i j,
        R (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)) = R11 i j) РѕД
      (Рѕђ i j,
        R (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)) = R12 i j) РѕД
      (Рѕђ i j,
        R (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)) = R22 i j) РѕД
      A11inv =
        rectMatMul (nonsingInv r R11) (finiteTranspose (nonsingInv r R11)) РѕД
      rectOpNorm2Le (rectMatMul A21 A11inv)
        (Real.sqrt (kappa2 A (nonsingInv (r + s) A))) := by
  obtain РЪеR, hCholРЪЕ := cholesky_existence (r + s) A hSPD
  let R11 : Fin r Рєњ Fin r Рєњ РёЮ := fun i j =>
    R (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
      (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s))
