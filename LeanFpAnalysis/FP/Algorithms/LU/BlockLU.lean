/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    certificate-level bridge for the Schur-complement condition-number bound
    `╬║(S) РЅц ¤ЂРѓЎ ╬║(A)`.

    Once operator certificates have supplied `РђќSРђќ РЅц ¤ЂРѓЎ РђќAРђќ`,
    `РђќSРЂ╗┬╣Рђќ РЅц РђќAРЂ╗┬╣Рђќ`, and `РђќAРђќРђќAРЂ╗┬╣Рђќ РЅц ╬║(A)`, the displayed condition-number
    product follows by scalar monotonicity.  The hard source obligation is
    still deriving those certificates from the Schur-complement and growth
    assumptions. -/
theorem higham13_problem13_4_schur_kappa_bound_from_operator_certificates
    {s : РёЋ} [Nonempty (Fin s)]
    (S Sinv : Fin s Рєњ Fin s Рєњ РёЮ)
    {normS normSinv normA normAinv rho kappaA : РёЮ}
    (hRho : 0 РЅц rho)
    (hS : finiteOpNorm2Le S normS)
    (hSinv : finiteOpNorm2Le Sinv normSinv)
    (hS_bound : normS РЅц rho * normA)
    (hSinv_bound : normSinv РЅц normAinv)
    (hkappa : normA * normAinv РЅц kappaA) :
    normS * normSinv РЅц rho * kappaA := by
  have hNormSinv_nonneg : 0 РЅц normSinv :=
    finiteOpNorm2Le_radius_nonneg Sinv hSinv
  have hSupper_nonneg : 0 РЅц rho * normA :=
    le_trans (finiteOpNorm2Le_radius_nonneg S hS) hS_bound
  have hmul :
      normS * normSinv РЅц (rho * normA) * normAinv :=
    mul_le_mul hS_bound hSinv_bound hNormSinv_nonneg
      hSupper_nonneg
  calc
    normS * normSinv РЅц (rho * normA) * normAinv := hmul
    _ = rho * (normA * normAinv) := by ring
    _ РЅц rho * kappaA := mul_le_mul_of_nonneg_left hkappa hRho

/-- **Eq. 13.22**: РђќLРђќ ┬и РђќUРђќ РЅц n ┬и ¤Ђ_n┬│ ┬и ╬║(A) ┬и РђќAРђќ for general matrices.
    From РђќLРђќ РЅц n ┬и ¤Ђ_n┬▓ ┬и ╬║(A) and РђќUРђќ РЅц ¤Ђ_n ┬и РђќAРђќ. -/
theorem block_lu_normLU_bound_general
    (normL normU _normA : РёЮ) (hL : 0 РЅц normL) (hU : 0 РЅц normU)
    (normL_bound normU_bound : РёЮ)
    (hNormL : normL РЅц normL_bound) (hNormU : normU РЅц normU_bound) :
    normL * normU РЅц normL_bound * normU_bound :=
  mul_le_mul hNormL hNormU hU (le_trans hL hNormL)

/-- Source-shaped scalar consequence for Higham eq. (13.22):
    if `РђќLРђќ РЅц n ¤Ђ_n^2 ╬║(A)` and `РђќUРђќ РЅц ¤Ђ_n РђќAРђќ`, then
    `РђќLРђќРђќUРђќ РЅц n ¤Ђ_n^3 ╬║(A) РђќAРђќ`.  The hard source work is proving the two
    displayed premises from growth-factor and Schur-complement analysis
    (Problem 13.4); this theorem records the exact algebraic combination. -/
theorem block_lu_normLU_bound_general_higham_13_22
    (normL normU normA rho kappa : РёЮ) (n : РёЋ)
    (hU : 0 РЅц normU) (_hRho : 0 РЅц rho) (hKappa : 0 РЅц kappa)
    (hNormL : normL РЅц (n : РёЮ) * rho ^ 2 * kappa)
    (hNormU : normU РЅц rho * normA) :
    normL * normU РЅц (n : РёЮ) * rho ^ 3 * kappa * normA := by
  have hLbound_nonneg : 0 РЅц (n : РёЮ) * rho ^ 2 * kappa := by positivity
  have hmul := mul_le_mul hNormL hNormU hU hLbound_nonneg
  calc normL * normU
      РЅц ((n : РёЮ) * rho ^ 2 * kappa) * (rho * normA) := hmul
    _ = (n : РёЮ) * rho ^ 3 * kappa * normA := by ring

/-- Source-shaped scalar bridge for Higham eq. (13.23): specializing the
    general growth-factor product bound (13.22) with `¤Ђ_n РЅц 2` gives
    `РђќLРђќРђќUРђќ РЅц 8 n ╬║(A) РђќAРђќ`.  The premises `РђќLРђќ РЅц n¤Ђ_n^2╬║(A)` and
    `РђќUРђќ РЅц ¤Ђ_nРђќAРђќ` are still the source obligations supplied by Problem 13.4
    and (13.21). -/
theorem higham13_eq13_23_point_row_from_growth
    (normL normU normA rho kappa : РёЮ) (n : РёЋ)
    (hU : 0 РЅц normU) (hA : 0 РЅц normA)
    (hRho_nonneg : 0 РЅц rho) (hRho_le_two : rho РЅц 2) (hKappa : 0 РЅц kappa)
    (hNormL : normL РЅц (n : РёЮ) * rho ^ 2 * kappa)
    (hNormU : normU РЅц rho * normA) :
    normL * normU РЅц 8 * (n : РёЮ) * kappa * normA := by
  have h22 :
      normL * normU РЅц (n : РёЮ) * rho ^ 3 * kappa * normA :=
    block_lu_normLU_bound_general_higham_13_22
      normL normU normA rho kappa n hU hRho_nonneg hKappa hNormL hNormU
  have hrho3 : rho ^ 3 РЅц 8 := by
    have hpow : rho ^ 3 РЅц (2 : РёЮ) ^ 3 :=
      pow_le_pow_leftРѓђ hRho_nonneg hRho_le_two 3
    norm_num at hpow
    exact hpow
  have hn : 0 РЅц (n : РёЮ) := Nat.cast_nonneg n
  have hcoef_left : (n : РёЮ) * rho ^ 3 РЅц (n : РёЮ) * 8 :=
    mul_le_mul_of_nonneg_left hrho3 hn
  have hcoef : (n : РёЮ) * rho ^ 3 * kappa РЅц (n : РёЮ) * 8 * kappa :=
    mul_le_mul_of_nonneg_right hcoef_left hKappa
  have hprod :
      (n : РёЮ) * rho ^ 3 * kappa * normA РЅц
        (n : РёЮ) * 8 * kappa * normA :=
    mul_le_mul_of_nonneg_right hcoef hA
  calc
    normL * normU РЅц (n : РёЮ) * rho ^ 3 * kappa * normA := h22
    _ РЅц (n : РёЮ) * 8 * kappa * normA := hprod
    _ = 8 * (n : РёЮ) * kappa * normA := by ring

/-- Higham, 2nd ed., Chapter 13, equation (13.22):
    source-shaped product bound from an instantiated ambient-budget chain.

    If the recursive Schur chain has already been instantiated with the source
    lower budget `n rho^2 kappa(A)` and upper budget `rho ||A||`, then the
    concrete factors produced by the chain satisfy the displayed Eq.13.22
    product bound.  The theorem still leaves the source work of proving the
    chain itself visible. -/
theorem Higham13BlockLUBudgetChain.exists_blockLUFact_eq13_22_product {r : РёЋ}
    (hr : 0 < r) {rho kappa normA : РёЮ} (n : РёЋ) :
    Рѕђ {m : РёЋ}
      {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ}
      {pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ},
      Higham13BlockLUBudgetChain hr ((n : РёЮ) * rho ^ 2 * kappa) (rho * normA)
        m A pivotInv Рєњ
      0 РЅц rho Рєњ
      0 РЅц kappa Рєњ
        РѕЃ L U : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ,
          BlockLUFactSpec (m + 1) r A L U РѕД
            blockMaxNorm (Nat.succ_pos m) hr L *
              blockMaxNorm (Nat.succ_pos m) hr U РЅц
                (n : РёЮ) * rho ^ 3 * kappa * normA := by
  intro m A pivotInv hchain hRho hKappa
  rcases Higham13BlockLUBudgetChain.exists_blockLUFact_norms
      (r := r) hr
      (C_L := (n : РёЮ) * rho ^ 2 * kappa)
      (C_U := rho * normA) hchain with
    РЪеL, U, hFact, hL, hUРЪЕ
  refine РЪеL, U, hFact, ?_РЪЕ
  exact block_lu_normLU_bound_general_higham_13_22
    (blockMaxNorm (Nat.succ_pos m) hr L)
    (blockMaxNorm (Nat.succ_pos m) hr U)
    normA rho kappa n
    (blockMaxNorm_nonneg (Nat.succ_pos m) hr U)
    hRho hKappa hL hU

/-- Higham, 2nd ed., Chapter 13, equation (13.23):
    point-row product specialization from an instantiated ambient-budget chain.

    This is the chain-level analogue of `higham13_eq13_23_point_row_from_growth`:
    an Eq.13.22-budget chain plus the source-side `rho <= 2` hypothesis gives
    concrete block LU factors satisfying `8 n kappa(A) ||A||`.  Proving the
    chain and the final point-row `rho <= 2` condition remains the source
    obligation. -/
theorem Higham13BlockLUBudgetChain.exists_blockLUFact_eq13_23_product {r : РёЋ}
    (hr : 0 < r) {rho kappa normA : РёЮ} (n : РёЋ) :
    Рѕђ {m : РёЋ}
      {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ}
      {pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ},
      Higham13BlockLUBudgetChain hr ((n : РёЮ) * rho ^ 2 * kappa) (rho * normA)
        m A pivotInv Рєњ
      0 РЅц normA Рєњ
      0 РЅц rho Рєњ
      rho РЅц 2 Рєњ
      0 РЅц kappa Рєњ
        РѕЃ L U : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ,
          BlockLUFactSpec (m + 1) r A L U РѕД
            blockMaxNorm (Nat.succ_pos m) hr L *
              blockMaxNorm (Nat.succ_pos m) hr U РЅц
                8 * (n : РёЮ) * kappa * normA := by
  intro m A pivotInv hchain hA hRho hRho_le_two hKappa
  rcases Higham13BlockLUBudgetChain.exists_blockLUFact_norms
      (r := r) hr
      (C_L := (n : РёЮ) * rho ^ 2 * kappa)
      (C_U := rho * normA) hchain with
    РЪеL, U, hFact, hL, hUРЪЕ
  refine РЪеL, U, hFact, ?_РЪЕ
  exact higham13_eq13_23_point_row_from_growth
    (blockMaxNorm (Nat.succ_pos m) hr L)
    (blockMaxNorm (Nat.succ_pos m) hr U)
    normA rho kappa n
    (blockMaxNorm_nonneg (Nat.succ_pos m) hr U)
    hA hRho hRho_le_two hKappa hL hU

/-- Higham, 2nd ed., Chapter 13, equation (13.22):
    exact-`kappa(A)` source specialization of the ambient-budget chain.

    This wrapper fixes the chain constants to the source growth factor
    `rho = growthFactorEntry A0 G` and
    `kappa(A) = РђќA0Рђќ * РђќAinvРђќ`.  The recursive proof obligation is still the
    explicit `Higham13BlockLUBudgetChain` hypothesis. -/
theorem Higham13BlockLUBudgetChain.exists_blockLUFact_eq13_22_product_exact_kappa
    {r N : РёЋ} (hr : 0 < r) (hN : 0 < N)
    (A0 G Ainv : Fin N Рєњ Fin N Рєњ РёЮ)
    (hApos : 0 < maxEntryNorm hN A0)
    (n : РёЋ) :
    Рѕђ {m : РёЋ}
      {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ}
      {pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ},
      Higham13BlockLUBudgetChain hr
        ((n : РёЮ) * (growthFactorEntry hN A0 G hApos) ^ 2 *
          (maxEntryNormRect hN hN A0 * maxEntryNormRect hN hN Ainv))
        (growthFactorEntry hN A0 G hApos * maxEntryNormRect hN hN A0)
        m A pivotInv Рєњ
        РѕЃ L U : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ,
          BlockLUFactSpec (m + 1) r A L U РѕД
            blockMaxNorm (Nat.succ_pos m) hr L *
              blockMaxNorm (Nat.succ_pos m) hr U РЅц
                (n : РёЮ) *
                  (growthFactorEntry hN A0 G hApos) ^ 3 *
                  (maxEntryNormRect hN hN A0 *
                    maxEntryNormRect hN hN Ainv) *
                  maxEntryNormRect hN hN A0 := by
  intro m A pivotInv hchain
  let rho : РёЮ := growthFactorEntry hN A0 G hApos
  let kappaA : РёЮ := maxEntryNormRect hN hN A0 * maxEntryNormRect hN hN Ainv
  let normA : РёЮ := maxEntryNormRect hN hN A0
  have hRho : 0 РЅц rho := by
    simpa [rho] using growthFactorEntry_nonneg hN A0 G hApos
  have hKappa : 0 РЅц kappaA := by
    exact mul_nonneg (maxEntryNormRect_nonneg hN hN A0)
      (maxEntryNormRect_nonneg hN hN Ainv)
  simpa [rho, kappaA, normA] using
    Higham13BlockLUBudgetChain.exists_blockLUFact_eq13_22_product
      (r := r) hr (rho := rho) (kappa := kappaA) (normA := normA) n
      hchain hRho hKappa

/-- Higham, 2nd ed., Chapter 13, equation (13.23):
    exact-`kappa(A)` source specialization of the ambient-budget chain.

    After the recursive chain has been instantiated with the exact source
    constants and the source row-growth theorem supplies `rho <= 2`, this gives
    the displayed point-row product bound. -/
theorem Higham13BlockLUBudgetChain.exists_blockLUFact_eq13_23_product_exact_kappa
    {r N : РёЋ} (hr : 0 < r) (hN : 0 < N)
    (A0 G Ainv : Fin N Рєњ Fin N Рєњ РёЮ)
    (hApos : 0 < maxEntryNorm hN A0)
    (n : РёЋ) :
    Рѕђ {m : РёЋ}
      {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ}
      {pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ},
      Higham13BlockLUBudgetChain hr
        ((n : РёЮ) * (growthFactorEntry hN A0 G hApos) ^ 2 *
          (maxEntryNormRect hN hN A0 * maxEntryNormRect hN hN Ainv))
        (growthFactorEntry hN A0 G hApos * maxEntryNormRect hN hN A0)
        m A pivotInv Рєњ
      growthFactorEntry hN A0 G hApos РЅц 2 Рєњ
        РѕЃ L U : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ,
          BlockLUFactSpec (m + 1) r A L U РѕД
            blockMaxNorm (Nat.succ_pos m) hr L *
              blockMaxNorm (Nat.succ_pos m) hr U РЅц
                8 * (n : РёЮ) *
                  (maxEntryNormRect hN hN A0 *
                    maxEntryNormRect hN hN Ainv) *
                  maxEntryNormRect hN hN A0 := by
  intro m A pivotInv hchain hRho_le_two
  let rho : РёЮ := growthFactorEntry hN A0 G hApos
  let kappaA : РёЮ := maxEntryNormRect hN hN A0 * maxEntryNormRect hN hN Ainv
  let normA : РёЮ := maxEntryNormRect hN hN A0
  have hNormA : 0 РЅц normA := by
    simpa [normA] using maxEntryNormRect_nonneg hN hN A0
  have hRho : 0 РЅц rho := by
    simpa [rho] using growthFactorEntry_nonneg hN A0 G hApos
  have hKappa : 0 РЅц kappaA := by
    exact mul_nonneg (maxEntryNormRect_nonneg hN hN A0)
      (maxEntryNormRect_nonneg hN hN Ainv)
  simpa [rho, kappaA, normA] using
    Higham13BlockLUBudgetChain.exists_blockLUFact_eq13_23_product
      (r := r) hr (rho := rho) (kappa := kappaA) (normA := normA) n
      hchain hNormA hRho (by simpa [rho] using hRho_le_two) hKappa

/-- Higham, 2nd ed., Chapter 13, Table 13.1:
    generic scalar bridge from a product bound to the first-order backward-error
    quantity tabulated in the table.

    If Theorem 13.6 has supplied
    `err РЅц c_n u (РђќAРђќ + РђќLРђќРђќUРђќ) + O(u^2)` and a matrix class has supplied
    `РђќLРђќРђќUРђќ РЅц tableValue * РђќAРђќ`, then the table entry gives the corresponding
    first-order bound with leading term
    `c_n u ((1 + tableValue) * РђќAРђќ)`.  The source's `c_n` absorbs dimension-only
    polynomial factors; this theorem keeps the exact scalar leading term visible
    instead of hiding it in prose. -/
theorem higham13_table13_1_backward_error_from_product_bound
    (err u c_n normA normLU tableValue : РёЮ)
    (hu : 0 РЅц u) (hc : 0 РЅц c_n)
    (hErr : FirstOrderLe u (c_n * u * (normA + normLU)) err)
    (hLU : normLU РЅц tableValue * normA) :
    FirstOrderLe u (c_n * u * ((1 + tableValue) * normA)) err := by
  refine hErr.mono_leading ?_
  have hinside : normA + normLU РЅц (1 + tableValue) * normA := by
    nlinarith
  have hcoef : 0 РЅц c_n * u := mul_nonneg hc hu
  exact mul_le_mul_of_nonneg_left hinside hcoef

/-- Higham, 2nd ed., Chapter 13, Table 13.1:
    column block-diagonal-dominance row.

    From a Theorem 13.6-style first-order backward-error premise and the
    source product premises `РђќLРђќ РЅц m`, `РђќUРђќ РЅц m^2 РђќAРђќ`, the table's visible
    leading term is `c_n u (1 + m^3) РђќAРђќ`.  The Schur-stage proof of those
