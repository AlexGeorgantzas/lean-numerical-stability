-- ============================================================
-- ┬Д13.1  Block matrix definitions
-- ============================================================

/-- r├Ќr identity block: I(s,t) = ╬┤_{st}. -/
noncomputable def idBlock (r : РёЋ) : Fin r Рєњ Fin r Рєњ РёЮ :=
  fun s t => if s = t then 1 else 0

/-- r├Ќr zero block. -/
noncomputable def zeroBlock (r : РёЋ) : Fin r Рєњ Fin r Рєњ РёЮ :=
  fun _ _ => 0

/-- The entrywise max norm of the zero block is zero. -/
lemma maxEntryNorm_zeroBlock {r : РёЋ} (hr : 0 < r) :
    maxEntryNorm hr (zeroBlock r) = 0 := by
  apply le_antisymm
  ┬и unfold maxEntryNorm zeroBlock
    apply Finset.sup'_le
    intro i _hi
    apply Finset.sup'_le
    intro j _hj
    simp
  ┬и exact maxEntryNorm_nonneg hr (zeroBlock r)

/-- If a block is definitionally the zero block, its entrywise max norm is
    bounded by zero.  This is the norm-level form used for strict lower `U`
    blocks in the Eq.13.21 bridges. -/
lemma maxEntryNorm_le_zero_of_eq_zeroBlock {r : РёЋ} (hr : 0 < r)
    {B : Fin r Рєњ Fin r Рєњ РёЮ} (hB : B = zeroBlock r) :
    maxEntryNorm hr B РЅц 0 := by
  rw [hB, maxEntryNorm_zeroBlock hr]

/-- For the repository's block representation `Fin r Рєњ Fin r Рєњ РёЮ`, the
    ambient Pi norm is exactly Higham's Chapter 13 entrywise max norm.  This
    lets Algorithm 13.3 Schur-stage blocks, whose norm table is defined using
    `Рђќ┬иРђќ`, feed the Eq.13.21 max-entry growth bridge. -/
theorem higham13_block_norm_eq_maxEntryNorm {r : РёЋ} (hr : 0 < r)
    (B : Fin r Рєњ Fin r Рєњ РёЮ) :
    РђќBРђќ = maxEntryNorm hr B := by
  apply le_antisymm
  ┬и rw [pi_norm_le_iff_of_nonneg (maxEntryNorm_nonneg hr B)]
    intro s
    rw [pi_norm_le_iff_of_nonneg (maxEntryNorm_nonneg hr B)]
    intro t
    simpa [Real.norm_eq_abs] using entry_le_maxEntryNorm hr B s t
  ┬и unfold maxEntryNorm
    apply Finset.sup'_le
    intro s _hs
    apply Finset.sup'_le
    intro t _ht
    have hentry_row : РђќB s tРђќ РЅц РђќB sРђќ := norm_le_pi_norm (B s) t
    have hrow_all : РђќB sРђќ РЅц РђќBРђќ := norm_le_pi_norm B s
    simpa [Real.norm_eq_abs] using le_trans hentry_row hrow_all

/-- If a Chapter 13 block has zero ambient Pi norm, then every scalar entry of
    the block is zero. -/
theorem higham13_block_entries_zero_of_norm_eq_zero {r : РёЋ}
    {B : Fin r Рєњ Fin r Рєњ РёЮ} (hB : РђќBРђќ = 0) :
    Рѕђ s t : Fin r, B s t = 0 := by
  have hzero : B = 0 := norm_eq_zero.mp hB
  intro s t
  exact congr_fun (congr_fun hzero s) t

/-- r├Ќr block multiplication: (AB)(s,t) = РѕЉ_l A(s,l) ┬и B(l,t). -/
noncomputable def blockMul {r : РёЋ} (A B : Fin r Рєњ Fin r Рєњ РёЮ) :
    Fin r Рєњ Fin r Рєњ РёЮ :=
  fun s t => РѕЉ l : Fin r, A s l * B l t

/-- Block matrix product: (AB)_{ij}(s,t) = РѕЉ_k РѕЉ_l A_{ik}(s,l) ┬и B_{kj}(l,t). -/
noncomputable def blockMatProd {m r : РёЋ}
    (A B : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ) :=
  fun i j s t => РѕЉ k : Fin m, РѕЉ l : Fin r, A i k s l * B k j l t

/-- Entrywise max norm of the full block matrix (Chapter 13's convention):
    РђќAРђќ := max_{i,j} maxEntryNorm(A_{ij}) = max_{i,j,s,t} |A_{ij}(s,t)|. -/
noncomputable def blockMaxNorm {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) : РёЮ :=
  Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
    (fun i => Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
      (fun j => maxEntryNorm hr (A i j)))

/-- Each block norm is bounded by the full block max norm. -/
lemma block_le_blockMaxNorm {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) (i j : Fin m) :
    maxEntryNorm hr (A i j) РЅц blockMaxNorm hm hr A := by
  unfold blockMaxNorm
  exact le_trans
    (Finset.le_sup' (fun j' => maxEntryNorm hr (A i j')) (Finset.mem_univ j))
    (Finset.le_sup' (fun i' => Finset.sup' Finset.univ
      (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
      (fun j' => maxEntryNorm hr (A i' j'))) (Finset.mem_univ i))

lemma blockMaxNorm_nonneg {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    0 РЅц blockMaxNorm hm hr A :=
  le_trans (maxEntryNorm_nonneg hr (A РЪе0, hmРЪЕ РЪе0, hmРЪЕ))
    (block_le_blockMaxNorm hm hr A РЪе0, hmРЪЕ РЪе0, hmРЪЕ)

/-- Blockwise matrix-`Рѕъ` norm maximum for a uniform block matrix.

    This is the source-style block norm obtained by using the matrix `Рѕъ`
    operator norm on each block and then taking the maximum over block
    indices.  It is distinct from `blockMaxNorm`, which is the chapter's
    entrywise max norm over all scalar entries. -/
noncomputable def blockInfNorm {m r : РёЋ} (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ) : РёЮ :=
  Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
    (fun i => Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
      (fun j => infNorm (A i j)))

/-- Each block matrix-`Рѕъ` norm is bounded by the blockwise matrix-`Рѕъ`
    maximum. -/
lemma block_le_blockInfNorm {m r : РёЋ} (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ) (i j : Fin m) :
    infNorm (A i j) РЅц blockInfNorm hm A := by
  unfold blockInfNorm
  exact le_trans
    (Finset.le_sup' (fun j' => infNorm (A i j')) (Finset.mem_univ j))
    (Finset.le_sup' (fun i' => Finset.sup' Finset.univ
      (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
      (fun j' => infNorm (A i' j'))) (Finset.mem_univ i))

lemma blockInfNorm_nonneg {m r : РёЋ} (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ) :
    0 РЅц blockInfNorm hm A :=
  le_trans (infNorm_nonneg (A РЪе0, hmРЪЕ РЪе0, hmРЪЕ))
    (block_le_blockInfNorm hm A РЪе0, hmРЪЕ РЪе0, hmРЪЕ)

/-- Finite block supremum for an arbitrary normed block type.

    This is the source-norm analogue of `blockMaxNorm`: it records
    `max_{i,j} РђќAрхбР▒╝Рђќ` for whichever subordinate block norm is carried by the
    block type. -/
noncomputable def higham13_blockNormSup {m : РёЋ} (hm : 0 < m)
    {╬▒ : Type*} [Norm ╬▒] (A : Fin m Рєњ Fin m Рєњ ╬▒) : РёЮ :=
  Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
    (fun i => Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
      (fun j => РђќA i jРђќ))

lemma higham13_block_norm_le_blockNormSup {m : РёЋ} (hm : 0 < m)
    {╬▒ : Type*} [Norm ╬▒] (A : Fin m Рєњ Fin m Рєњ ╬▒) (i j : Fin m) :
    РђќA i jРђќ РЅц higham13_blockNormSup hm A := by
  unfold higham13_blockNormSup
  exact le_trans
    (Finset.le_sup' (fun j' => РђќA i j'Рђќ) (Finset.mem_univ j))
    (Finset.le_sup' (fun i' =>
      Finset.sup' Finset.univ
        (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
        (fun j' => РђќA i' j'Рђќ)) (Finset.mem_univ i))

lemma higham13_blockNormSup_nonneg {m : РёЋ} (hm : 0 < m)
    {╬▒ : Type*} [SeminormedAddCommGroup ╬▒] (A : Fin m Рєњ Fin m Рєњ ╬▒) :
    0 РЅц higham13_blockNormSup hm A :=
  le_trans (norm_nonneg (A РЪе0, hmРЪЕ РЪе0, hmРЪЕ))
    (higham13_block_norm_le_blockNormSup hm A РЪе0, hmРЪЕ РЪе0, hmРЪЕ)

lemma higham13_blockNormSup_le_of_norm_le {m : РёЋ} (hm : 0 < m)
    {╬▒ : Type*} [Norm ╬▒] (A : Fin m Рєњ Fin m Рєњ ╬▒) {C : РёЮ}
    (hC : Рѕђ i j : Fin m, РђќA i jРђќ РЅц C) :
    higham13_blockNormSup hm A РЅц C := by
  unfold higham13_blockNormSup
  apply Finset.sup'_le
  intro i _hi
  apply Finset.sup'_le
  intro j _hj
  exact hC i j

/-- Bound a blockwise matrix-`Рѕъ` maximum from uniform bounds on all blocks. -/
lemma blockInfNorm_le_of_block_le {m r : РёЋ} (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ) {C : РёЮ}
    (hC : Рѕђ i j : Fin m, infNorm (A i j) РЅц C) :
    blockInfNorm hm A РЅц C := by
  unfold blockInfNorm
  apply Finset.sup'_le
  intro i _hi
  apply Finset.sup'_le
  intro j _hj
  exact hC i j

/-- The matrix-`Рѕъ` norm of a zero block is zero. -/
lemma infNorm_zeroBlock (r : РёЋ) :
    infNorm (zeroBlock r) = 0 := by
  apply le_antisymm
  ┬и apply infNorm_le_of_row_sum_le
    ┬и intro i
      simp [zeroBlock]
    ┬и norm_num
  ┬и exact infNorm_nonneg (zeroBlock r)

lemma infNorm_le_zero_of_eq_zeroBlock {r : РёЋ}
    {B : Matrix (Fin r) (Fin r) РёЮ} (hB : B = zeroBlock r) :
    infNorm B РЅц 0 := by
  rw [hB, infNorm_zeroBlock]

/-- Higham, 2nd ed., Chapter 13, ┬Д13.1 norm convention:
    the block representation's max norm is definitionally the maximum over
    block indices and within-block indices, matching the chapter's
    entrywise `max |aрхбР▒╝|` convention. -/
theorem higham13_norm_convention_blockMaxNorm_eq_entrywise_sup {m r : РёЋ}
    (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    blockMaxNorm hm hr A =
      Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
        (fun i => Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
          (fun j => Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hrРЪЕРЪЕ)
            (fun s => Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hrРЪЕРЪЕ)
              (fun t => |A i j s t|)))) := by
  rfl

/-- Every scalar entry of a block matrix is bounded by the Chapter 13
    entrywise max norm. -/
lemma block_entry_abs_le_blockMaxNorm {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (i j : Fin m) (s t : Fin r) :
    |A i j s t| РЅц blockMaxNorm hm hr A := by
  exact le_trans (entry_le_maxEntryNorm hr (A i j) s t)
    (block_le_blockMaxNorm hm hr A i j)

/-- A uniform scalar entrywise bound controls the Chapter 13 block max norm. -/
lemma blockMaxNorm_le_of_entry_abs_le {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) (C : РёЮ)
    (hEntry : Рѕђ i j : Fin m, Рѕђ s t : Fin r, |A i j s t| РЅц C) :
    blockMaxNorm hm hr A РЅц C := by
  unfold blockMaxNorm
  apply Finset.sup'_le
  intro i _hi
  apply Finset.sup'_le
  intro j _hj
  unfold maxEntryNorm
  apply Finset.sup'_le
  intro s _hs
  apply Finset.sup'_le
  intro t _ht
  exact hEntry i j s t

/-- The chapter entrywise block max norm is bounded by the blockwise
    matrix-`Рѕъ` maximum. -/
lemma blockMaxNorm_le_blockInfNorm {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ) :
    blockMaxNorm hm hr A РЅц blockInfNorm hm A := by
  apply blockMaxNorm_le_of_entry_abs_le
  intro i j s t
  exact le_trans
    (entry_le_maxEntryNorm hr (A i j) s t)
    (le_trans (maxEntryNorm_le_infNorm hr (A i j))
      (block_le_blockInfNorm hm A i j))

/-- Chapter 13 route audit for the matrix-`Рѕъ` branch.

    The reverse dimension-free comparison from the blockwise matrix-`Рѕъ`
    maximum to the chapter's entrywise block max norm is false already for one
    `2 x 2` block: the block with first row `[1, 1]` has entrywise max norm
    `1` but matrix-`Рѕъ` norm `2`.  Thus the current matrix-`Рѕъ` to entrywise
    max-norm transfer cannot remove its dimension factor without additional
    source structure. -/
theorem higham13_blockInfNorm_not_le_blockMaxNorm_counterexample :
    РѕЃ A : Fin 1 Рєњ Fin 1 Рєњ Matrix (Fin 2) (Fin 2) РёЮ,
      blockMaxNorm (Nat.succ_pos 0) (Nat.succ_pos 1) A = 1 РѕД
        blockInfNorm (Nat.succ_pos 0) A = 2 РѕД
          ┬г blockInfNorm (Nat.succ_pos 0) A РЅц
              blockMaxNorm (Nat.succ_pos 0) (Nat.succ_pos 1) A := by
  let B : Matrix (Fin 2) (Fin 2) РёЮ := fun s _ => if s = 0 then 1 else 0
  let A : Fin 1 Рєњ Fin 1 Рєњ Matrix (Fin 2) (Fin 2) РёЮ := fun _ _ => B
  have hBMax : maxEntryNorm (Nat.succ_pos 1) B = 1 := by
    apply le_antisymm
    ┬и apply maxEntryNorm_le_of_entry_le_bound
      intro s t
      by_cases hs : s = 0
      ┬и simp [B, hs]
      ┬и simp [B, hs]
    ┬и have h :=
        entry_le_maxEntryNorm (Nat.succ_pos 1) B (0 : Fin 2) (0 : Fin 2)
      norm_num [B] at h
      exact h
  have hBInf : infNorm B = 2 := by
    apply le_antisymm
    ┬и apply infNorm_le_of_row_sum_le
      ┬и intro s
        fin_cases s
        ┬и norm_num [B]
        ┬и norm_num [B]
      ┬и norm_num
    ┬и have h := row_sum_le_infNorm B (0 : Fin 2)
      norm_num [B] at h
      exact h
  have hMax : blockMaxNorm (Nat.succ_pos 0) (Nat.succ_pos 1) A = 1 := by
    apply le_antisymm
    ┬и apply blockMaxNorm_le_of_entry_abs_le
      intro i j s t
      by_cases hs : s = 0
      ┬и simp [A, B, hs]
      ┬и simp [A, B, hs]
    ┬и have h :=
        block_entry_abs_le_blockMaxNorm (Nat.succ_pos 0) (Nat.succ_pos 1)
          A (0 : Fin 1) (0 : Fin 1) (0 : Fin 2) (0 : Fin 2)
      norm_num [A, B] at h
      exact h
  have hInf : blockInfNorm (Nat.succ_pos 0) A = 2 := by
    apply le_antisymm
    ┬и apply blockInfNorm_le_of_block_le
      intro i j
      simpa [A] using le_of_eq hBInf
    ┬и have h :=
        block_le_blockInfNorm (Nat.succ_pos 0) A (0 : Fin 1) (0 : Fin 1)
      simpa [A, hBInf] using h
  refine РЪеA, hMax, hInf, ?_РЪЕ
  intro h
  rw [hInf, hMax] at h
  norm_num at h

/-- A block matrix whose scalar entries occur in a square matrix is bounded by
    that square matrix's max-entry norm.  This is the block analogue of the
    rectangular submatrix containment bridge and is used to connect the
    Algorithm 13.3 block upper factor to a common GE growth object. -/
lemma blockMaxNorm_le_maxEntryNorm_of_reindex_eq
    {N m r : РёЋ} (hN : 0 < N) (hm : 0 < m) (hr : 0 < r)
    (B : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (G : Fin N Рєњ Fin N Рєњ РёЮ)
    (row : Fin m Рєњ Fin r Рєњ Fin N) (col : Fin m Рєњ Fin r Рєњ Fin N)
    (hB : Рѕђ i j s t, B i j s t = G (row i s) (col j t)) :
    blockMaxNorm hm hr B РЅц maxEntryNorm hN G := by
  apply blockMaxNorm_le_of_entry_abs_le
  intro i j s t
  rw [hB i j s t]
  exact entry_le_maxEntryNorm hN G (row i s) (col j t)

/-- Rectangular entrywise max norm used by Chapter 13's `max |aрхбР▒╝|`
    convention for nonsquare computed kernels such as matrix multiplication. -/
noncomputable def maxEntryNormRect {m n : РёЋ} (hm : 0 < m) (hn : 0 < n)
    (A : Fin m Рєњ Fin n Рєњ РёЮ) : РёЮ :=
  Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hmРЪЕРЪЕ)
    (fun i => Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hnРЪЕРЪЕ)
      (fun j => |A i j|))

lemma maxEntryNormRect_nonneg {m n : РёЋ} (hm : 0 < m) (hn : 0 < n)
    (A : Fin m Рєњ Fin n Рєњ РёЮ) :
    0 РЅц maxEntryNormRect hm hn A := by
  have h0m : (РЪе0, hmРЪЕ : Fin m) Рѕѕ Finset.univ := Finset.mem_univ _
  have h0n : (РЪе0, hnРЪЕ : Fin n) Рѕѕ Finset.univ := Finset.mem_univ _
  have hentry : 0 РЅц |A РЪе0, hmРЪЕ РЪе0, hnРЪЕ| := abs_nonneg _
  have hcol :
      |A РЪе0, hmРЪЕ РЪе0, hnРЪЕ| РЅц
        Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hnРЪЕРЪЕ)
          (fun j => |A РЪе0, hmРЪЕ j|) :=
    Finset.le_sup' (fun j => |A РЪе0, hmРЪЕ j|) h0n
  have hrow :
      Finset.sup' Finset.univ (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hnРЪЕРЪЕ)
          (fun j => |A РЪе0, hmРЪЕ j|) РЅц
        maxEntryNormRect hm hn A :=
    Finset.le_sup' (fun i => Finset.sup' Finset.univ
      (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hnРЪЕРЪЕ) (fun j => |A i j|)) h0m
  exact le_trans hentry (le_trans hcol hrow)

lemma entry_le_maxEntryNormRect {m n : РёЋ} (hm : 0 < m) (hn : 0 < n)
    (A : Fin m Рєњ Fin n Рєњ РёЮ) (i : Fin m) (j : Fin n) :
    |A i j| РЅц maxEntryNormRect hm hn A := by
  exact le_trans
    (Finset.le_sup' (fun j' => |A i j'|) (Finset.mem_univ j))
    (Finset.le_sup' (fun i' => Finset.sup' Finset.univ
      (Finset.univ_nonempty_iff.mpr РЪеРЪе0, hnРЪЕРЪЕ) (fun j' => |A i' j'|))
      (Finset.mem_univ i))

/-- The rectangular max-entry norm specializes definitionally to the square
    max-entry norm used by the growth-factor API. -/
lemma maxEntryNormRect_eq_maxEntryNorm {n : РёЋ} (hn : 0 < n)
    (A : Fin n Рєњ Fin n Рєњ РёЮ) :
    maxEntryNormRect hn hn A = maxEntryNorm hn A := rfl

/-- The source-facing growth-factor budget `rho * ||A||_max` is exactly the
    max-entry norm of the chosen growth matrix. -/
theorem growthFactorEntry_mul_maxEntryNormRect_eq_maxEntryNorm {n : РёЋ}
    (hn : 0 < n) (A G : Fin n Рєњ Fin n Рєњ РёЮ)
    (hA : 0 < maxEntryNorm hn A) :
    growthFactorEntry hn A G hA * maxEntryNormRect hn hn A =
      maxEntryNorm hn G := by
  unfold growthFactorEntry
  rw [maxEntryNormRect_eq_maxEntryNorm hn A]
  field_simp [ne_of_gt hA]

lemma maxEntryNormRect_le_of_entry_abs_le {m n : РёЋ} (hm : 0 < m) (hn : 0 < n)
    (A : Fin m Рєњ Fin n Рєњ РёЮ) (C : РёЮ)
    (hEntry : Рѕђ i : Fin m, Рѕђ j : Fin n, |A i j| РЅц C) :
    maxEntryNormRect hm hn A РЅц C := by
  unfold maxEntryNormRect
  apply Finset.sup'_le
  intro i _hi
  apply Finset.sup'_le
  intro j _hj
  exact hEntry i j

/-- The rectangular max-entry norm of a single-column matrix is exactly the
    infinity norm of the represented vector. -/
lemma maxEntryNormRect_single_col_eq_infNormVec {r : РёЋ}
    (hr : 0 < r) (X : Matrix (Fin r) (Fin 1) РёЮ) :
    maxEntryNormRect hr (Nat.succ_pos 0) X =
      infNormVec (fun i : Fin r => X i 0) := by
  apply le_antisymm
  ┬и apply maxEntryNormRect_le_of_entry_abs_le
    intro i j
    fin_cases j
    exact abs_le_infNormVec (fun t : Fin r => X t 0) i
  ┬и apply infNormVec_le_of_abs_le
    ┬и intro i
      exact entry_le_maxEntryNormRect hr (Nat.succ_pos 0) X i 0
    ┬и exact maxEntryNormRect_nonneg hr (Nat.succ_pos 0) X

/-- Max-norm residual lifting used by the DHS block-back-substitution proof.

    If a vector residual `f` is at most `eta * РђќxРђќРѕъ`, it can be represented as
    `F x` by a rank-one coefficient perturbation with
    `РђќFРђќmax <= eta`.  The proof places the residual in a column where `x`
    attains its infinity norm.  This is the dimension-free bridge specific to
    the max-entry/max-vector norm pairing in the source analysis. -/
theorem higham13_maxNorm_vecResidual_lift {m k : РёЋ}
    (hm : 0 < m) (hk : 0 < k)
    (x : Fin k Рєњ РёЮ) (f : Fin m Рєњ РёЮ) (eta : РёЮ)
    (heta : 0 РЅц eta)
    (hres : infNormVec f РЅц eta * infNormVec x) :
    РѕЃ F : Matrix (Fin m) (Fin k) РёЮ,
      Matrix.mulVec F x = f РѕД maxEntryNormRect hm hk F РЅц eta := by
  by_cases hxzero : infNormVec x = 0
  ┬и have hfnorm : infNormVec f = 0 := by
      apply le_antisymm
      ┬и calc
          infNormVec f РЅц eta * infNormVec x := hres
          _ = 0 := by rw [hxzero, mul_zero]
      ┬и exact infNormVec_nonneg f
    have hfzero : f = 0 := by
      funext i
      apply abs_eq_zero.mp
      apply le_antisymm
      ┬и simpa [hfnorm] using abs_le_infNormVec f i
      ┬и exact abs_nonneg (f i)
    refine РЪе0, ?_, ?_РЪЕ
    ┬и simp [hfzero]
    ┬и exact le_trans
        (maxEntryNormRect_le_of_entry_abs_le hm hk 0 0 (by simp)) heta
  ┬и have hxpos : 0 < infNormVec x :=
      lt_of_le_of_ne (infNormVec_nonneg x) (Ne.symm hxzero)
    obtain РЪеj0, hj0РЪЕ := infNormVec_exists_abs_eq hk x
    have hxj0 : x j0 РЅа 0 := by
      intro hx
      rw [hx, abs_zero] at hj0
      linarith
    let F : Matrix (Fin m) (Fin k) РёЮ := fun i j =>
      if j = j0 then f i / x j0 else 0
    refine РЪеF, ?_, ?_РЪЕ
    ┬и ext i
      simp [Matrix.mulVec, dotProduct, F, hxj0]
    ┬и apply maxEntryNormRect_le_of_entry_abs_le
      intro i j
      by_cases hj : j = j0
      ┬и subst j
        have hfi : |f i| РЅц eta * infNormVec x :=
          le_trans (abs_le_infNormVec f i) hres
        simp only [F, if_pos, abs_div]
        rw [Рєљ hj0]
        exact (div_le_iffРѓђ hxpos).2 (by simpa [hj0] using hfi)
      ┬и simp [F, hj, heta]

/-- Support-preserving form of the max-norm residual lift.

    In addition to the residual equation and max-entry bound, the constructed
    rank-one perturbation has a zero column wherever the supplied vector is
    zero.  This lets a block-back-substitution row mask all diagonal and lower
    block columns before lifting its residual. -/
theorem higham13_maxNorm_vecResidual_lift_zero_columns {m k : РёЋ}
    (hm : 0 < m) (hk : 0 < k)
    (x : Fin k Рєњ РёЮ) (f : Fin m Рєњ РёЮ) (eta : РёЮ)
    (heta : 0 РЅц eta)
    (hres : infNormVec f РЅц eta * infNormVec x) :
    РѕЃ F : Matrix (Fin m) (Fin k) РёЮ,
      Matrix.mulVec F x = f РѕД
      maxEntryNormRect hm hk F РЅц eta РѕД
      Рѕђ j : Fin k, x j = 0 Рєњ Рѕђ i : Fin m, F i j = 0 := by
  by_cases hxzero : infNormVec x = 0
  ┬и have hfnorm : infNormVec f = 0 := by
      apply le_antisymm
      ┬и calc
          infNormVec f РЅц eta * infNormVec x := hres
          _ = 0 := by rw [hxzero, mul_zero]
      ┬и exact infNormVec_nonneg f
    have hfzero : f = 0 := by
      funext i
      apply abs_eq_zero.mp
      apply le_antisymm
      ┬и simpa [hfnorm] using abs_le_infNormVec f i
      ┬и exact abs_nonneg (f i)
    refine РЪе0, ?_, ?_, ?_РЪЕ
    ┬и simp [hfzero]
    ┬и exact le_trans
        (maxEntryNormRect_le_of_entry_abs_le hm hk 0 0 (by simp)) heta
    ┬и simp
  ┬и have hxpos : 0 < infNormVec x :=
      lt_of_le_of_ne (infNormVec_nonneg x) (Ne.symm hxzero)
    obtain РЪеj0, hj0РЪЕ := infNormVec_exists_abs_eq hk x
    have hxj0 : x j0 РЅа 0 := by
      intro hx
      rw [hx, abs_zero] at hj0
      linarith
    let F : Matrix (Fin m) (Fin k) РёЮ := fun i j =>
      if j = j0 then f i / x j0 else 0
    refine РЪеF, ?_, ?_, ?_РЪЕ
    ┬и ext i
      simp [Matrix.mulVec, dotProduct, F, hxj0]
    ┬и apply maxEntryNormRect_le_of_entry_abs_le
      intro i j
      by_cases hj : j = j0
      ┬и subst j
        have hfi : |f i| РЅц eta * infNormVec x :=
          le_trans (abs_le_infNormVec f i) hres
        simp only [F, if_pos, abs_div]
        rw [Рєљ hj0]
        exact (div_le_iffРѓђ hxpos).2 (by simpa [hj0] using hfi)
      ┬и simp [F, hj, heta]
    ┬и intro j hxj i
      by_cases hj : j = j0
      ┬и subst j
        exact (hxj0 hxj).elim
      ┬и simp [F, hj]

/-- Lift a residual against the stacked, already computed upper tail of one
    uniform block-back-substitution row.

    The returned block coefficients vanish at the diagonal and below, their
    full block-row product equals the supplied residual, and every scalar entry
    inherits the same dimension-free `eta` bound. -/
theorem higham13_maxNorm_upperBlockRowResidual_lift {m r : РёЋ}
    (hm : 0 < m) (hr : 0 < r)
    (i : Fin m) (X : Fin m Рєњ Matrix (Fin r) (Fin 1) РёЮ)
    (f : Fin r Рєњ РёЮ) (eta : РёЮ)
    (heta : 0 РЅц eta)
    (hres :
      infNormVec f РЅц eta * infNormVec (fun jt : Fin (m * r) =>
        if i.val < (finProdFinEquiv.symm jt).1.val then
          X (finProdFinEquiv.symm jt).1 (finProdFinEquiv.symm jt).2 0
        else 0)) :
    РѕЃ Delta : Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ,
      (РѕЉ j : Fin m, Delta j * X j) = (fun s (_k : Fin 1) => f s) РѕД
      (Рѕђ j : Fin m, ┬гi.val < j.val Рєњ Delta j = 0) РѕД
      Рѕђ j : Fin m, Рѕђ s t : Fin r, |Delta j s t| РЅц eta := by
  let xTail : Fin (m * r) Рєњ РёЮ := fun jt =>
    if i.val < (finProdFinEquiv.symm jt).1.val then
      X (finProdFinEquiv.symm jt).1 (finProdFinEquiv.symm jt).2 0
    else 0
  obtain РЪеF, hFmul, hFbound, hFzeroРЪЕ :=
    higham13_maxNorm_vecResidual_lift_zero_columns
      hr (Nat.mul_pos hm hr) xTail f eta heta hres
  let Delta : Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ := fun j s t =>
    F s (finProdFinEquiv (j, t))
  have hInactive : Рѕђ j : Fin m, ┬гi.val < j.val Рєњ Delta j = 0 := by
    intro j hj
    ext s t
    have hxzero : xTail (finProdFinEquiv (j, t)) = 0 := by
      rw [show xTail (finProdFinEquiv (j, t)) =
          if i.val < j.val then X j t 0 else 0 by
        simp only [xTail, Equiv.symm_apply_apply]]
      simp [hj]
    exact hFzero (finProdFinEquiv (j, t)) hxzero s
  have hEntry : Рѕђ j : Fin m, Рѕђ s t : Fin r, |Delta j s t| РЅц eta := by
    intro j s t
    exact le_trans
      (entry_le_maxEntryNormRect hr (Nat.mul_pos hm hr) F s
        (finProdFinEquiv (j, t))) hFbound
  refine РЪеDelta, ?_, hInactive, hEntryРЪЕ
  ext s k
  fin_cases k
  have hFmul_s := congrFun hFmul s
  have hFlat :
      (РѕЉ jt : Fin (m * r), F s jt * xTail jt) =
        РѕЉ jt : Fin m ├Ќ Fin r,
          F s (finProdFinEquiv jt) * X jt.1 jt.2 0 := by
    rw [Fintype.sum_equiv finProdFinEquiv]
    intro jt
    have hxTailApply : xTail (finProdFinEquiv jt) =
        if i.val < jt.1.val then X jt.1 jt.2 0 else 0 := by
      simp only [xTail, Equiv.symm_apply_apply]
    rw [hxTailApply]
    by_cases hj : i.val < jt.1.val
    ┬и simp [hj]
    ┬и have hxzero : xTail (finProdFinEquiv jt) = 0 := by
        rw [hxTailApply]
        simp [hj]
      have hzero := hFzero (finProdFinEquiv jt) hxzero s
      simp [hj, hzero]
  calc
    (РѕЉ j : Fin m, Delta j * X j) s 0 =
        РѕЉ j : Fin m, РѕЉ t : Fin r,
          F s (finProdFinEquiv (j, t)) * X j t 0 := by
      simp only [Matrix.sum_apply, Matrix.mul_apply, Delta]
    _ = РѕЉ jt : Fin m ├Ќ Fin r,
          F s (finProdFinEquiv jt) * X jt.1 jt.2 0 := by
      rw [Fintype.sum_prod_type]
    _ = РѕЉ jt : Fin (m * r), F s jt * xTail jt := hFlat.symm
    _ = f s := by
      simpa [Matrix.mulVec, dotProduct] using hFmul_s

/-- The stacked computed upper tail in a fixed block-back-substitution row. -/
noncomputable def dhsBlockBackUpperTailVector {m r : РёЋ}
    (i : Fin m) (X : Fin m Рєњ Matrix (Fin r) (Fin 1) РёЮ) :
    Fin (m * r) Рєњ РёЮ := fun jt =>
  if i.val < (finProdFinEquiv.symm jt).1.val then
    X (finProdFinEquiv.symm jt).1 (finProdFinEquiv.symm jt).2 0
  else 0

@[simp] theorem dhsBlockBackUpperTailVector_apply {m r : РёЋ}
    (i j : Fin m) (s : Fin r)
    (X : Fin m Рєњ Matrix (Fin r) (Fin 1) РёЮ) :
    dhsBlockBackUpperTailVector i X (finProdFinEquiv (j, s)) =
      if i.val < j.val then X j s 0 else 0 := by
  simp [dhsBlockBackUpperTailVector]

/-- Single-column matrix representation of `dhsBlockBackUpperTailVector`. -/
noncomputable def dhsBlockBackUpperTailColumn {m r : РёЋ}
    (i : Fin m) (X : Fin m Рєњ Matrix (Fin r) (Fin 1) РёЮ) :
    Matrix (Fin (m * r)) (Fin 1) РёЮ := fun jt _k =>
  dhsBlockBackUpperTailVector i X jt

@[simp] theorem dhsBlockBackUpperTailColumn_apply {m r : РёЋ}
    (i j : Fin m) (s : Fin r)
    (X : Fin m Рєњ Matrix (Fin r) (Fin 1) РёЮ) :
    dhsBlockBackUpperTailColumn i X (finProdFinEquiv (j, s)) 0 =
      if i.val < j.val then X j s 0 else 0 := by
  simp [dhsBlockBackUpperTailColumn]

/-- Flattened coefficient row containing exactly the strict upper block tail. -/
noncomputable def dhsBlockBackUpperTailRowFlat {m r : РёЋ}
    (i : Fin m) (U : Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ) :
    Matrix (Fin r) (Fin (m * r)) РёЮ := fun s jt =>
  if i.val < (finProdFinEquiv.symm jt).1.val then
    U (finProdFinEquiv.symm jt).1 s (finProdFinEquiv.symm jt).2
  else 0

@[simp] theorem dhsBlockBackUpperTailRowFlat_apply {m r : РёЋ}
    (i j : Fin m) (s t : Fin r)
    (U : Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ) :
    dhsBlockBackUpperTailRowFlat i U s (finProdFinEquiv (j, t)) =
      if i.val < j.val then U j s t else 0 := by
  simp [dhsBlockBackUpperTailRowFlat]

/-- Multiplying the flattened strict upper block row by its stacked tail is
    exactly the sum of the source block products. -/
theorem dhsBlockBackUpperTailRowFlat_mul_apply {m r : РёЋ}
    (i : Fin m)
    (U : Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (X : Fin m Рєњ Matrix (Fin r) (Fin 1) РёЮ)
    (s : Fin r) :
    (dhsBlockBackUpperTailRowFlat i U *
        dhsBlockBackUpperTailColumn i X) s 0 =
      (РѕЉ j Рѕѕ Finset.univ.filter (fun j : Fin m => i.val < j.val),
        U j * X j) s 0 := by
  calc
    (dhsBlockBackUpperTailRowFlat i U *
        dhsBlockBackUpperTailColumn i X) s 0 =
        РѕЉ jt : Fin (m * r),
          dhsBlockBackUpperTailRowFlat i U s jt *
            dhsBlockBackUpperTailColumn i X jt 0 := by
      rw [Matrix.mul_apply]
    _ = РѕЉ jt : Fin m ├Ќ Fin r,
          (if i.val < jt.1.val then U jt.1 s jt.2 else 0) *
            X jt.1 jt.2 0 := by
      rw [Fintype.sum_equiv finProdFinEquiv]
      intro jt
      rw [dhsBlockBackUpperTailRowFlat_apply,
        dhsBlockBackUpperTailColumn_apply]
      by_cases hj : i.val < jt.1.val <;> simp [hj]
    _ = РѕЉ j : Fin m, РѕЉ t : Fin r,
          (if i.val < j.val then U j s t else 0) * X j t 0 := by
      rw [Fintype.sum_prod_type]
    _ = РѕЉ j : Fin m,
          if i.val < j.val then (U j * X j) s 0 else 0 := by
      apply Finset.sum_congr rfl
      intro j _hjmem
      by_cases hj : i.val < j.val
      ┬и simp [hj, Matrix.mul_apply]
      ┬и simp [hj]
    _ = (РѕЉ j Рѕѕ Finset.univ.filter (fun j : Fin m => i.val < j.val),
          U j * X j) s 0 := by
      rw [Finset.sum_filter]
      simp only [Matrix.sum_apply]
      apply Finset.sum_congr rfl
      intro j _hjmem
      by_cases hj : i.val < j.val <;> simp [hj]

/-- Triangle inequality for the Chapter 13 block max norm under subtraction. -/
lemma maxEntryNorm_sub_le {r : РёЋ} (hr : 0 < r)
    (A B : Matrix (Fin r) (Fin r) РёЮ) :
    maxEntryNorm hr (A - B) РЅц maxEntryNorm hr A + maxEntryNorm hr B := by
  have hrect :
      maxEntryNormRect hr hr (A - B) РЅц maxEntryNorm hr A + maxEntryNorm hr B := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro s t
    exact le_trans
      (by
        simpa [sub_eq_add_neg, abs_neg] using abs_sub_le (A s t) 0 (B s t))
      (add_le_add (entry_le_maxEntryNorm hr A s t)
        (entry_le_maxEntryNorm hr B s t))
  simpa [maxEntryNormRect_eq_maxEntryNorm hr] using hrect

/-- Triangle inequality for the Chapter 13 square max-entry norm. -/
lemma maxEntryNorm_add_le {r : РёЋ} (hr : 0 < r)
    (A B : Matrix (Fin r) (Fin r) РёЮ) :
    maxEntryNorm hr (A + B) РЅц maxEntryNorm hr A + maxEntryNorm hr B := by
  have hrect :
      maxEntryNormRect hr hr (A + B) РЅц
        maxEntryNorm hr A + maxEntryNorm hr B := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro i j
    calc
      |(A + B) i j| РЅц |A i j| + |B i j| := abs_add_le _ _
      _ РЅц maxEntryNorm hr A + maxEntryNorm hr B :=
        add_le_add (entry_le_maxEntryNorm hr A i j)
          (entry_le_maxEntryNorm hr B i j)
  simpa [maxEntryNormRect_eq_maxEntryNorm hr] using hrect

/-- Four-term triangle inequality used by the concrete DHS solve perturbation
    `E + DeltaL * Uhat + Lhat * DeltaU + DeltaL * DeltaU`. -/
lemma maxEntryNorm_four_add_le {r : РёЋ} (hr : 0 < r)
    (A B C D : Matrix (Fin r) (Fin r) РёЮ) :
    maxEntryNorm hr (A + B + C + D) РЅц
      maxEntryNorm hr A + maxEntryNorm hr B +
        maxEntryNorm hr C + maxEntryNorm hr D := by
  calc
    maxEntryNorm hr (A + B + C + D) РЅц
        maxEntryNorm hr (A + B + C) + maxEntryNorm hr D :=
      maxEntryNorm_add_le hr (A + B + C) D
    _ РЅц (maxEntryNorm hr (A + B) + maxEntryNorm hr C) +
          maxEntryNorm hr D := by
      linarith [maxEntryNorm_add_le hr (A + B) C]
    _ РЅц ((maxEntryNorm hr A + maxEntryNorm hr B) + maxEntryNorm hr C) +
          maxEntryNorm hr D := by
      linarith [maxEntryNorm_add_le hr A B]

/-- An invertible square matrix has positive Chapter 13 max-entry norm. -/
lemma maxEntryNorm_pos_of_invertible {n : РёЋ} (hn : 0 < n)
    (A : Matrix (Fin n) (Fin n) РёЮ) [Invertible A] :
    0 < maxEntryNorm hn A := by
  have hnonneg : 0 РЅц maxEntryNorm hn A :=
    maxEntryNorm_nonneg hn A
  have hne : maxEntryNorm hn A РЅа 0 := by
    intro hzero
    have hentries : Рѕђ i j : Fin n, A i j = 0 := by
      intro i j
      have hle := entry_le_maxEntryNorm hn A i j
      rw [hzero] at hle
      exact abs_eq_zero.mp (le_antisymm hle (abs_nonneg (A i j)))
    let z : Fin n := РЪе0, hnРЪЕ
    have hprod0 : (A * РЁЪA) z z = 0 := by
      simp [Matrix.mul_apply, hentries]
    have hprod1 : (A * РЁЪA) z z = 1 := by
      exact congr_fun (congr_fun (mul_invOf_self A) z) z
    nlinarith
  exact lt_of_le_of_ne hnonneg (Ne.symm hne)

/-- A square matrix with nonzero determinant has positive Chapter 13
    max-entry norm. -/
lemma maxEntryNorm_pos_of_det_ne_zero {n : РёЋ} (hn : 0 < n)
    (A : Fin n Рєњ Fin n Рєњ РёЮ)
    (hdet : Matrix.det (A : Matrix (Fin n) (Fin n) РёЮ) РЅа 0) :
    0 < maxEntryNorm hn A := by
  have hnonneg : 0 РЅц maxEntryNorm hn A :=
    maxEntryNorm_nonneg hn A
  have hne : maxEntryNorm hn A РЅа 0 := by
    intro hzero
    have hentries : Рѕђ i j : Fin n, A i j = 0 := by
      intro i j
      have hle := entry_le_maxEntryNorm hn A i j
      rw [hzero] at hle
      exact abs_eq_zero.mp (le_antisymm hle (abs_nonneg (A i j)))
    apply hdet
    exact Matrix.det_eq_zero_of_row_eq_zero (РЪе0, hnРЪЕ : Fin n)
      (fun j => hentries РЪе0, hnРЪЕ j)
  exact lt_of_le_of_ne hnonneg (Ne.symm hne)

/-- A rectangular matrix whose entries occur in a square matrix is bounded by
    that square matrix's max-entry norm.  This is the max-entry submatrix
    bookkeeping bridge used when a Schur complement is identified with an
    active GE growth-factor block. -/
lemma maxEntryNormRect_le_maxEntryNorm_of_reindex_eq
    {N m n : РёЋ} (hN : 0 < N) (hm : 0 < m) (hn : 0 < n)
    (S : Fin m Рєњ Fin n Рєњ РёЮ) (U : Fin N Рєњ Fin N Рєњ РёЮ)
    (row : Fin m Рєњ Fin N) (col : Fin n Рєњ Fin N)
    (hS : Рѕђ i j, S i j = U (row i) (col j)) :
    maxEntryNormRect hm hn S РЅц maxEntryNorm hN U := by
  apply maxEntryNormRect_le_of_entry_abs_le
  intro i j
  rw [hS i j]
  exact entry_le_maxEntryNorm hN U (row i) (col j)

/-- Rectangular max-entry product bound:
    `||A B||_max <= n ||A||_max ||B||_max`.

    This is the entrywise norm submultiplicativity estimate used in the
    max-entry-norm route for Higham Chapter 13, Problem 13.4. -/
theorem maxEntryNormRect_rectMatMul_le {m n p : РёЋ}
    (hm : 0 < m) (hn : 0 < n) (hp : 0 < p)
    (A : Fin m Рєњ Fin n Рєњ РёЮ) (B : Fin n Рєњ Fin p Рєњ РёЮ) :
    maxEntryNormRect hm hp (rectMatMul A B) РЅц
      (n : РёЮ) * maxEntryNormRect hm hn A * maxEntryNormRect hn hp B := by
  let normA : РёЮ := maxEntryNormRect hm hn A
  let normB : РёЮ := maxEntryNormRect hn hp B
  have hnormA : 0 РЅц normA := maxEntryNormRect_nonneg hm hn A
  apply maxEntryNormRect_le_of_entry_abs_le
  intro i j
  have hsum :
      (РѕЉ k : Fin n, |A i k| * |B k j|) РЅц (n : РёЮ) * (normA * normB) := by
    calc
      (РѕЉ k : Fin n, |A i k| * |B k j|)
          РЅц РѕЉ _k : Fin n, normA * normB := by
              apply Finset.sum_le_sum
              intro k _hk
              exact mul_le_mul
                (entry_le_maxEntryNormRect hm hn A i k)
                (entry_le_maxEntryNormRect hn hp B k j)
                (abs_nonneg (B k j)) hnormA
      _ = (n : РёЮ) * (normA * normB) := by
        simp [nsmul_eq_mul]
  calc
    |rectMatMul A B i j|
        РЅц РѕЉ k : Fin n, |A i k * B k j| := by
          simpa [rectMatMul] using
            (Finset.abs_sum_le_sum_abs
              (s := (Finset.univ : Finset (Fin n)))
              (f := fun k => A i k * B k j))
    _ = РѕЉ k : Fin n, |A i k| * |B k j| := by
      apply Finset.sum_congr rfl
      intro k _hk
      exact abs_mul (A i k) (B k j)
    _ РЅц (n : РёЮ) * (normA * normB) := hsum
    _ = (n : РёЮ) * maxEntryNormRect hm hn A *
          maxEntryNormRect hn hp B := by
      simp [normA, normB, mul_assoc]

/-- Mixed matrix-Рѕъ/entrywise max product bound:
    `||A B||_max <= ||A||_Рѕъ ||B||_max`.

    This is the dimension-free product estimate needed by the column-BDD
    Chapter 13 route: the left factor is controlled by row mass while the
    right factor is controlled entrywise. -/
theorem maxEntryNorm_matrix_mul_le_infNorm_mul_maxEntryNorm {r : РёЋ} (hr : 0 < r)
    (A B : Matrix (Fin r) (Fin r) РёЮ) :
    maxEntryNorm hr (A * B) РЅц infNorm A * maxEntryNorm hr B := by
  change maxEntryNormRect hr hr (fun i j => (A * B) i j) РЅц
    infNorm A * maxEntryNorm hr B
  apply maxEntryNormRect_le_of_entry_abs_le
  intro i j
  have hB_nonneg : 0 РЅц maxEntryNorm hr B := maxEntryNorm_nonneg hr B
  have hsum_abs :
      |РѕЉ k : Fin r, A i k * B k j| РЅц
        РѕЉ k : Fin r, |A i k * B k j| :=
    Finset.abs_sum_le_sum_abs
      (s := (Finset.univ : Finset (Fin r)))
      (f := fun k => A i k * B k j)
  have hterms :
      (РѕЉ k : Fin r, |A i k * B k j|) РЅц
        РѕЉ k : Fin r, |A i k| * maxEntryNorm hr B := by
    apply Finset.sum_le_sum
    intro k _hk
    rw [abs_mul]
    exact mul_le_mul_of_nonneg_left
      (entry_le_maxEntryNorm hr B k j) (abs_nonneg (A i k))
  have hrow :
      (РѕЉ k : Fin r, |A i k| * maxEntryNorm hr B) РЅц
        infNorm A * maxEntryNorm hr B := by
    calc
      (РѕЉ k : Fin r, |A i k| * maxEntryNorm hr B)
          = (РѕЉ k : Fin r, |A i k|) * maxEntryNorm hr B := by
              rw [Finset.sum_mul]
      _ РЅц infNorm A * maxEntryNorm hr B :=
              mul_le_mul_of_nonneg_right (row_sum_le_infNorm A i) hB_nonneg
  calc
    |(A * B) i j|
        = |РѕЉ k : Fin r, A i k * B k j| := by
            simp [Matrix.mul_apply]
    _ РЅц РѕЉ k : Fin r, |A i k * B k j| := hsum_abs
    _ РЅц РѕЉ k : Fin r, |A i k| * maxEntryNorm hr B := hterms
    _ РЅц infNorm A * maxEntryNorm hr B := hrow

/-- Matrix-`Рѕъ` submultiplicativity for Mathlib matrix multiplication.

    The repository's base theorem is stated for the local `matMul`; this thin
    wrapper lets the Chapter 13 block-matrix route use ordinary `Matrix.mul`. -/
theorem infNorm_matrix_mul_le {r : РёЋ} (hr : 0 < r)
    (A B : Matrix (Fin r) (Fin r) РёЮ) :
    infNorm (A * B) РЅц infNorm A * infNorm B := by
  simpa [matMul, Matrix.mul_apply] using
    (infNorm_matMul_le hr (fun i j => A i j) (fun i j => B i j))

/-- Aggregate column-mass budget after multiplying every active lower block by
    the pivot inverse in the matrix-`Рѕъ` norm. -/
theorem higham13_sum_infNorm_matrix_mul_pivot_le_of_column_mass
    {m r : РёЋ} (hr : 0 < r) (tail : Finset (Fin m))
    (Acol : Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (P : Matrix (Fin r) (Fin r) РёЮ) {gamma : РёЮ}
    (hMass : РѕЉ i Рѕѕ tail, infNorm (Acol i) РЅц gamma)
    (hPivot : infNorm P * gamma РЅц 1) :
    РѕЉ i Рѕѕ tail, infNorm (Acol i * P) РЅц 1 := by
  have hterm :
      РѕЉ i Рѕѕ tail, infNorm (Acol i * P) РЅц
        РѕЉ i Рѕѕ tail, infNorm (Acol i) * infNorm P := by
    apply Finset.sum_le_sum
    intro i _hi
    exact infNorm_matrix_mul_le hr (Acol i) P
  have hsum_mul :
      РѕЉ i Рѕѕ tail, infNorm (Acol i) * infNorm P =
        (РѕЉ i Рѕѕ tail, infNorm (Acol i)) * infNorm P := by
    rw [Finset.sum_mul]
  have hscale :
      (РѕЉ i Рѕѕ tail, infNorm (Acol i)) * infNorm P РЅц
        gamma * infNorm P :=
    mul_le_mul_of_nonneg_right hMass (infNorm_nonneg P)
  have hpivot_comm : gamma * infNorm P РЅц 1 := by
    calc
      gamma * infNorm P = infNorm P * gamma := by ring
      _ РЅц 1 := hPivot
  calc
    РѕЉ i Рѕѕ tail, infNorm (Acol i * P)
        РЅц РѕЉ i Рѕѕ tail, infNorm (Acol i) * infNorm P := hterm
    _ = (РѕЉ i Рѕѕ tail, infNorm (Acol i)) * infNorm P := hsum_mul
    _ РЅц gamma * infNorm P := hscale
    _ РЅц 1 := hpivot_comm

/-- Mixed aggregate triple-product budget for the column-BDD route.

    If the active pivot-column matrix-`Рѕъ` mass is bounded by `gamma` and the
    pivot inverse satisfies `||P||Рѕъ * gamma <= 1`, then the whole active
    Schur-correction column contributes at most the pivot-row max-entry norm. -/
theorem higham13_sum_maxEntryNorm_matrix_mul_pivot_mul_le_of_column_mass
    {m r : РёЋ} (hr : 0 < r) (tail : Finset (Fin m))
    (Acol : Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (P R : Matrix (Fin r) (Fin r) РёЮ) {gamma : РёЮ}
    (hMass : РѕЉ i Рѕѕ tail, infNorm (Acol i) РЅц gamma)
    (hPivot : infNorm P * gamma РЅц 1) :
    РѕЉ i Рѕѕ tail, maxEntryNorm hr (Acol i * P * R) РЅц
      maxEntryNorm hr R := by
  have hterm :
      РѕЉ i Рѕѕ tail, maxEntryNorm hr (Acol i * P * R) РЅц
        РѕЉ i Рѕѕ tail, infNorm (Acol i * P) * maxEntryNorm hr R := by
    apply Finset.sum_le_sum
    intro i _hi
    exact maxEntryNorm_matrix_mul_le_infNorm_mul_maxEntryNorm hr (Acol i * P) R
  have hsum_mul :
      РѕЉ i Рѕѕ tail, infNorm (Acol i * P) * maxEntryNorm hr R =
        (РѕЉ i Рѕѕ tail, infNorm (Acol i * P)) * maxEntryNorm hr R := by
    rw [Finset.sum_mul]
  have hmass :
      РѕЉ i Рѕѕ tail, infNorm (Acol i * P) РЅц 1 :=
    higham13_sum_infNorm_matrix_mul_pivot_le_of_column_mass
      hr tail Acol P hMass hPivot
  have hmax_nonneg : 0 РЅц maxEntryNorm hr R := maxEntryNorm_nonneg hr R
  calc
    РѕЉ i Рѕѕ tail, maxEntryNorm hr (Acol i * P * R)
        РЅц РѕЉ i Рѕѕ tail, infNorm (Acol i * P) * maxEntryNorm hr R := hterm
    _ = (РѕЉ i Рѕѕ tail, infNorm (Acol i * P)) * maxEntryNorm hr R := hsum_mul
    _ РЅц 1 * maxEntryNorm hr R :=
        mul_le_mul_of_nonneg_right hmass hmax_nonneg
    _ = maxEntryNorm hr R := by ring

/-- Square matrix-product max-entry bound with the dimension factor exposed. -/
theorem maxEntryNorm_matrix_mul_le_dim {r : РёЋ} (hr : 0 < r)
    (A B : Matrix (Fin r) (Fin r) РёЮ) :
    maxEntryNorm hr (A * B) РЅц
      (r : РёЮ) * maxEntryNorm hr A * maxEntryNorm hr B := by
  have h :=
    maxEntryNormRect_rectMatMul_le hr hr hr
      (fun i j => A i j) (fun i j => B i j)
  simpa [rectMatMul, Matrix.mul_apply, maxEntryNormRect_eq_maxEntryNorm hr]
    using h

/-- Triple square matrix-product max-entry bound with the unavoidable
    `r^2` factor for the entrywise max norm. -/
theorem maxEntryNorm_matrix_mul_mul_le_dim_sq {r : РёЋ} (hr : 0 < r)
    (A B C : Matrix (Fin r) (Fin r) РёЮ) :
    maxEntryNorm hr (A * B * C) РЅц
      (r : РёЮ) ^ 2 * maxEntryNorm hr A * maxEntryNorm hr B *
        maxEntryNorm hr C := by
  have hAB :
      maxEntryNorm hr (A * B) РЅц
        (r : РёЮ) * maxEntryNorm hr A * maxEntryNorm hr B :=
    maxEntryNorm_matrix_mul_le_dim hr A B
  have hABC :
      maxEntryNorm hr ((A * B) * C) РЅц
        (r : РёЮ) * maxEntryNorm hr (A * B) * maxEntryNorm hr C :=
    maxEntryNorm_matrix_mul_le_dim hr (A * B) C
  have hr_nonneg : 0 РЅц (r : РёЮ) := Nat.cast_nonneg r
  have hC_nonneg : 0 РЅц maxEntryNorm hr C := maxEntryNorm_nonneg hr C
  have hstep :
      (r : РёЮ) * maxEntryNorm hr (A * B) * maxEntryNorm hr C РЅц
        (r : РёЮ) * ((r : РёЮ) * maxEntryNorm hr A * maxEntryNorm hr B) *
          maxEntryNorm hr C := by
    exact mul_le_mul_of_nonneg_right
      (mul_le_mul_of_nonneg_left hAB hr_nonneg) hC_nonneg
  calc
    maxEntryNorm hr (A * B * C)
        РЅц (r : РёЮ) * maxEntryNorm hr (A * B) * maxEntryNorm hr C := hABC
    _ РЅц (r : РёЮ) * ((r : РёЮ) * maxEntryNorm hr A * maxEntryNorm hr B) *
          maxEntryNorm hr C := hstep
    _ = (r : РёЮ) ^ 2 * maxEntryNorm hr A * maxEntryNorm hr B *
          maxEntryNorm hr C := by ring

/-- Audit for the Chapter 13 max-entry route: ordinary square matrix
    multiplication is not dimension-free submultiplicative for the entrywise
    max norm.  The all-ones `2 ├Ќ 2` matrix gives `РђќJ*JРђќmax = 2` while
    `РђќJРђќmax * РђќJРђќmax = 1`. -/
theorem maxEntryNorm_matrix_mul_dimension_free_counterexample :
    РѕЃ A B : Matrix (Fin 2) (Fin 2) РёЮ,
      ┬г maxEntryNorm (by norm_num : 0 < 2) (A * B) РЅц
        maxEntryNorm (by norm_num : 0 < 2) A *
          maxEntryNorm (by norm_num : 0 < 2) B := by
  let J : Matrix (Fin 2) (Fin 2) РёЮ := fun _ _ => 1
  refine РЪеJ, J, ?_РЪЕ
  norm_num [maxEntryNorm, J, Matrix.mul_apply, Fin.sum_univ_two]

/-- Audit for the Chapter 13 max-entry route: the corresponding
    dimension-free triple-product estimate is also false for generic square
    matrix multiplication in the entrywise max norm. -/
theorem maxEntryNorm_matrix_mul_mul_dimension_free_counterexample :
    РѕЃ A B C : Matrix (Fin 2) (Fin 2) РёЮ,
      ┬г maxEntryNorm (by norm_num : 0 < 2) (A * B * C) РЅц
        maxEntryNorm (by norm_num : 0 < 2) A *
          maxEntryNorm (by norm_num : 0 < 2) B *
            maxEntryNorm (by norm_num : 0 < 2) C := by
  let J : Matrix (Fin 2) (Fin 2) РёЮ := fun _ _ => 1
  refine РЪеJ, J, J, ?_РЪЕ
  norm_num [maxEntryNorm, J, Matrix.mul_apply, Fin.sum_univ_two]

/-- A right inverse forces the max-entry product to be large enough to cover
    the identity, up to the usual dimension factor for the entrywise max norm.

    This is the nonvacuity lemma behind the diagonal `1 <= n¤Ђ┬▓╬║(A)` side
    condition in the assembled Eq.13.22 lower-factor bound. -/
theorem one_le_dim_mul_maxEntryNormRect_mul_of_isRightInverse {n : РёЋ}
    (hn : 0 < n) (A Ainv : Fin n Рєњ Fin n Рєњ РёЮ)
    (hRight : IsRightInverse n A Ainv) :
    1 РЅц (n : РёЮ) * maxEntryNormRect hn hn A *
      maxEntryNormRect hn hn Ainv := by
  let I : Fin n Рєњ Fin n Рєњ РёЮ := fun i j => if i = j then 1 else 0
  have hI_entry :
      (1 : РёЮ) РЅц maxEntryNormRect hn hn I := by
    have hentry :=
      entry_le_maxEntryNormRect hn hn I
        (РЪе0, hnРЪЕ : Fin n) (РЪе0, hnРЪЕ : Fin n)
    simpa [I] using hentry
  have hmul_eq_I : rectMatMul A Ainv = I := by
    ext i j
    simpa [rectMatMul, I] using hRight i j
  have hmul_norm :
      maxEntryNormRect hn hn (rectMatMul A Ainv) РЅц
        (n : РёЮ) * maxEntryNormRect hn hn A *
          maxEntryNormRect hn hn Ainv := by
    exact maxEntryNormRect_rectMatMul_le hn hn hn A Ainv
  calc
    (1 : РёЮ) РЅц maxEntryNormRect hn hn I := hI_entry
    _ = maxEntryNormRect hn hn (rectMatMul A Ainv) := by
          rw [Рєљ hmul_eq_I]
    _ РЅц (n : РёЮ) * maxEntryNormRect hn hn A *
          maxEntryNormRect hn hn Ainv := hmul_norm

/-- A certified inverse gives the dimension-free mixed-norm pivot lower
    product used by the column-BDD route:
    `1 <= ||AРЂ╗┬╣||_Рѕъ ||A||_max`.

    The proof applies the mixed `Рѕъ`/max-entry product bound to the left inverse
    equation `AРЂ╗┬╣ * A = I`, which is derived from the supplied finite square
    right-inverse certificate. -/
theorem one_le_infNorm_mul_maxEntryNorm_of_isRightInverse {r : РёЋ} (hr : 0 < r)
    (A Ainv : Matrix (Fin r) (Fin r) РёЮ)
    (hRight : IsRightInverse r A Ainv) :
    1 РЅц infNorm Ainv * maxEntryNorm hr A := by
  let i0 : Fin r := РЪе0, hrРЪЕ
  have hLeft : IsLeftInverse r A Ainv :=
    isLeftInverse_of_isRightInverse A Ainv hRight
  have hdiag : (Ainv * A) i0 i0 = 1 := by
    simpa [Matrix.mul_apply] using hLeft i0 i0
  have hentry :
      (1 : РёЮ) РЅц maxEntryNorm hr (Ainv * A) := by
    have h :=
      entry_le_maxEntryNorm hr (Ainv * A) i0 i0
    simpa [hdiag] using h
  exact le_trans hentry
    (maxEntryNorm_matrix_mul_le_infNorm_mul_maxEntryNorm hr Ainv A)

/-- A certified right inverse turns the source reciprocal diagonal budget into
    a max-entry lower bound for the original diagonal block.  This is the
    mixed matrix-`Рѕъ`/max-entry bridge used in the column-BDD route for
    Theorem 13.8. -/
theorem inv_infNorm_le_maxEntryNorm_of_isRightInverse {r : РёЋ} (hr : 0 < r)
    (A Ainv : Matrix (Fin r) (Fin r) РёЮ)
    (hRight : IsRightInverse r A Ainv) :
    (infNorm Ainv)РЂ╗┬╣ РЅц maxEntryNorm hr A := by
  have hprod := one_le_infNorm_mul_maxEntryNorm_of_isRightInverse hr A Ainv hRight
  have hnorm_nonneg : 0 РЅц infNorm Ainv := infNorm_nonneg Ainv
  by_cases hzero : infNorm Ainv = 0
  ┬и have hbad : (1 : РёЮ) РЅц 0 := by
      have hprod0 : (1 : РёЮ) РЅц 0 * maxEntryNorm hr A := by
        simpa [hzero] using hprod
      simpa using hprod0
    linarith
  ┬и have hpos : 0 < infNorm Ainv := lt_of_le_of_ne hnorm_nonneg (Ne.symm hzero)
    have hinv_nonneg : 0 РЅц (infNorm Ainv)РЂ╗┬╣ := inv_nonneg.mpr hnorm_nonneg
    calc
      (infNorm Ainv)РЂ╗┬╣ = (infNorm Ainv)РЂ╗┬╣ * 1 := by ring
      _ РЅц (infNorm Ainv)РЂ╗┬╣ * (infNorm Ainv * maxEntryNorm hr A) :=
        mul_le_mul_of_nonneg_left hprod hinv_nonneg
      _ = maxEntryNorm hr A := by
        field_simp [hpos.ne']

/-- Reindexing a source `Fin n` matrix by an equivalence and taking Mathlib's
    constructive inverse gives entrywise max-entry certificates bounded by the
    repository's source-facing canonical inverse `nonsingInv`.

    This is the max-entry analogue of
    `finiteOpNorm2Le_invOf_reindex_equiv_nonsingInv` for the Chapter 13
    Problem 13.4 route. -/
theorem maxEntryNormRect_invOf_reindex_equiv_nonsingInv_entry_bound
    {n : РёЋ} (hn : 0 < n) {╬╣ : Type*} [Fintype ╬╣] [DecidableEq ╬╣]
    (e : ╬╣ РЅЃ Fin n) (A : Fin n Рєњ Fin n Рєњ РёЮ)
    (M : Matrix ╬╣ ╬╣ РёЮ) [Invertible M]
    (hM : M = fun i j : ╬╣ => A (e i) (e j)) :
    Рѕђ i j : ╬╣, |(РЁЪM) i j| РЅц
      maxEntryNormRect hn hn (nonsingInv n A) := by
  classical
  intro i j
  have h1 : РЁЪM = MРЂ╗┬╣ :=
    Matrix.invOf_eq_nonsing_inv M
  have h2 :
      MРЂ╗┬╣ =
        (((A : Matrix (Fin n) (Fin n) РёЮ)РЂ╗┬╣ :
          Matrix (Fin n) (Fin n) РёЮ).submatrix e e) := by
    rw [hM]
    exact Matrix.inv_submatrix_equiv (A : Matrix (Fin n) (Fin n) РёЮ) e e
  have hentry :
      (РЁЪM) i j = nonsingInv n A (e i) (e j) := by
    calc
      (РЁЪM) i j = MРЂ╗┬╣ i j := by rw [h1]
      _ =
          (((A : Matrix (Fin n) (Fin n) РёЮ)РЂ╗┬╣ :
            Matrix (Fin n) (Fin n) РёЮ) (e i) (e j)) := by
        rw [h2]
        rfl
      _ = nonsingInv n A (e i) (e j) := by
        unfold nonsingInv
        rfl
  rw [hentry]
  exact entry_le_maxEntryNormRect hn hn (nonsingInv n A) (e i) (e j)

-- ============================================================
-- Chapter 13 first-order error-bound vocabulary
-- ============================================================

/-- A concrete interpretation of Higham's displayed `leading term + O(u^2)` bounds:
    the bounded quantity is at most the first-order expression plus a nonnegative
    multiple of `u^2`.  This keeps the hidden second-order term explicit instead
    of silently dropping it. -/
def FirstOrderLe (u leading value : РёЮ) : Prop :=
  РѕЃ K : РёЮ, 0 РЅц K РѕД value РЅц leading + K * u ^ 2

/-- Matrix multiplication assumption (Higham, 2nd ed., Chapter 13, eq. 13.4)
    recorded at the scalar norm level. -/
def MatMulFirstOrderBound (u cРѓЂ normA normB normDelta : РёЮ) : Prop :=
  FirstOrderLe u (cРѓЂ * u * normA * normB) normDelta

/-- Full matrix residual specification for Higham's matrix-multiplication model
    (Chapter 13, eq. 13.4): `─ѕ = A B + ╬ћC`, together with the scalar
    first-order norm bound. -/
structure MatMulFirstOrderSpec {m n p : Type*} [Fintype n]
    (u cРѓЂ normA normB normDelta : РёЮ)
    (A : Matrix m n РёЮ) (B : Matrix n p РёЮ)
    (Chat DeltaC : Matrix m p РёЮ) : Prop where
  equation : Chat = A * B + DeltaC
  norm_bound : MatMulFirstOrderBound u cРѓЂ normA normB normDelta

/-- Triangular multiple-right-hand-side solve assumption (Higham, 2nd ed.,
    Chapter 13, eq. 13.5), recorded at the scalar norm level. -/
def TriangularSolveFirstOrderBound (u cРѓѓ normT normXhat normDeltaB : РёЮ) : Prop :=
  FirstOrderLe u (cРѓѓ * u * normT * normXhat) normDeltaB

/-- Full matrix residual specification for Higham's triangular-solve model
    (Chapter 13, eq. 13.5): `T X╠ѓ = B + ╬ћB`, together with the scalar
    first-order norm bound. -/
structure TriangularSolveFirstOrderSpec {m p : Type*} [Fintype m]
    (u cРѓѓ normT normXhat normDeltaB : РёЮ)
    (T : Matrix m m РёЮ) (B DeltaB Xhat : Matrix m p РёЮ) : Prop where
  equation : T * Xhat = B + DeltaB
  norm_bound : TriangularSolveFirstOrderBound u cРѓѓ normT normXhat normDeltaB

/-- Right-looking variant of the triangular-solve residual specification,
    used for proof steps such as Higham's equation (13.9):
    `X╠ѓ T = B + ╬ћB`, with the same scalar first-order norm bound as (13.5).
    This is the transpose/right-solve orientation of the model assumption. -/
structure RightTriangularSolveFirstOrderSpec {m p : Type*} [Fintype p]
    (u cРѓѓ normT normXhat normDeltaB : РёЮ)
    (T : Matrix p p РёЮ) (B DeltaB Xhat : Matrix m p РёЮ) : Prop where
  equation : Xhat * T = B + DeltaB
  norm_bound : TriangularSolveFirstOrderBound u cРѓѓ normT normXhat normDeltaB

/-- Block-level LU assumption (Higham, 2nd ed., Chapter 13, eq. 13.6), recorded
    at the scalar norm level. -/
def LocalLUFirstOrderBound (u cРѓЃ normLhat normUhat normDeltaA : РёЮ) : Prop :=
  FirstOrderLe u (cРѓЃ * u * normLhat * normUhat) normDeltaA

/-- Full matrix residual specification for the block-level LU model
    (Chapter 13, eq. 13.6): `L╠ѓ U╠ѓ = A + ╬ћA`, together with the scalar
    first-order norm bound. -/
structure LocalLUFirstOrderSpec {r : Type*} [Fintype r]
    (u cРѓЃ normLhat normUhat normDeltaA : РёЮ)
    (A DeltaA Lhat Uhat : Matrix r r РёЮ) : Prop where
  equation : Lhat * Uhat = A + DeltaA
  norm_bound : LocalLUFirstOrderBound u cРѓЃ normLhat normUhat normDeltaA

/-- Full matrix residual specification for the subtraction step in Higham's
    Theorem 13.5 proof (Chapter 13, eq. 13.10): `┼ю = AРѓѓРѓѓ - ─ѕ + F`, together
    with the first-order subtraction-error bound. -/
structure SubtractionFirstOrderSpec {m p : Type*}
    (u normA normComputed normF : РёЮ)
    (A Computed F Shat : Matrix m p РёЮ) : Prop where
  equation : Shat = A - Computed + F
  norm_bound : normF РЅц u * (normA + normComputed)

/-- Recursive partitioned-LU first-order backward-error specification used as
    the induction hypothesis in Higham's Theorem 13.5 proof (Chapter 13,
    eqs. 13.12a--13.12b): `L╠ѓ U╠ѓ = S╠ѓ + ╬ћS╠ѓ`, together with the scalar
    first-order bound from equation (13.7) at the smaller block size. -/
structure PartitionedLUFirstOrderSpec {r : Type*} [Fintype r]
    (u ╬┤ ╬И normA normLhat normUhat normDeltaA : РёЮ)
    (A DeltaA Lhat Uhat : Matrix r r РёЮ) : Prop where
  equation : Lhat * Uhat = A + DeltaA
  norm_bound : FirstOrderLe u
    (u * (╬┤ * normA + ╬И * normLhat * normUhat)) normDeltaA

/-- Block-LU step-2 assumption for Algorithm 13.3 (Higham, 2nd ed.,
    Chapter 13, eq. 13.14), recorded at the scalar norm level. -/
def BlockSolveFirstOrderBound (u cРѓё normLhat21 normA11 normE21 : РёЮ) : Prop :=
  FirstOrderLe u (cРѓё * u * normLhat21 * normA11) normE21

/-- Full matrix residual specification for Algorithm 13.3 step 2
    (Higham, 2nd ed., Chapter 13, eq. 13.14): `L╠ѓРѓѓРѓЂ AРѓЂРѓЂ = AРѓѓРѓЂ + EРѓѓРѓЂ`,
    together with the scalar first-order norm bound. -/
structure BlockSolveFirstOrderSpec {r s : Type*} [Fintype r]
    (u cРѓё normLhat21 normA11 normE21 : РёЮ)
    (Lhat21 A21 E21 : Matrix s r РёЮ) (A11 : Matrix r r РёЮ) : Prop where
  equation : Lhat21 * A11 = A21 + E21
  norm_bound : BlockSolveFirstOrderBound u cРѓё normLhat21 normA11 normE21

/-- Diagonal-block solve assumption for block back substitution (Higham, 2nd ed.,
    Chapter 13, eq. 13.15), recorded at the scalar norm level. -/
def DiagonalBlockSolveFirstOrderBound (u cРѓЁ normUii normDeltaUii : РёЮ) : Prop :=
  FirstOrderLe u (cРѓЁ * u * normUii) normDeltaUii

/-- Full residual specification for the diagonal-block solve model
    (Higham, 2nd ed., Chapter 13, eq. 13.15):
    `(Uрхбрхб + ╬ћUрхбрхб) X╠ѓ = D`, together with the scalar first-order perturbation
    bound on `╬ћUрхбрхб`.  The source states the single-RHS case; the matrix
    right-hand side keeps the same residual equation reusable. -/
structure DiagonalBlockSolveFirstOrderSpec {r p : Type*} [Fintype r]
    (u cРѓЁ normUii normDeltaUii : РёЮ)
    (Uii DeltaUii : Matrix r r РёЮ) (Xhat D : Matrix r p РёЮ) : Prop where
  equation : (Uii + DeltaUii) * Xhat = D
  norm_bound : DiagonalBlockSolveFirstOrderBound u cРѓЁ normUii normDeltaUii

/-- Source-facing local model for **Algorithm 13.3, Implementation 1**
    (Higham, 2nd ed., Chapter 13, pp.247 and 250): the block solve in step 2
    is governed by equation (13.14), and the diagonal-block systems in block
    back substitution are governed by equation (13.15).  This records the
    computed path used by Theorem 13.6 without proving the omitted
    Demmel--Higham--Schreiber implementation theorem. -/
structure Algorithm13_3Implementation1LocalSpec {r s p : Type*} [Fintype r]
    (u cРѓё cРѓЁ normLhat21 normA11 normE21 normUii normDeltaUii : РёЮ)
    (Lhat21 A21 E21 : Matrix s r РёЮ) (A11 Uii DeltaUii : Matrix r r РёЮ)
    (Xhat D : Matrix r p РёЮ) : Prop where
  step2 :
    BlockSolveFirstOrderSpec u cРѓё normLhat21 normA11 normE21
      Lhat21 A21 E21 A11
  diagonal_solve :
    DiagonalBlockSolveFirstOrderSpec u cРѓЁ normUii normDeltaUii
      Uii DeltaUii Xhat D

/-- Source-facing local model for **Algorithm 13.3, Implementation 2**
    (Higham, 2nd ed., Chapter 13, p.247): the leading diagonal block inverse
    is computed explicitly, so step 2 is represented as a matrix multiplication,
    and diagonal-block solves are represented as inverse-times-right-hand-side
    multiplications.  This is a computed-path specification only; the p.251
    scalar condition-number multiplier is handled by
    `higham13_algorithm13_3_implementation2_eq13_16_firstOrder_multiplier`. -/
structure Algorithm13_3Implementation2ExplicitInverseSpec {r s p : Type*} [Fintype r]
    (A11invHat UiiInvHat : Matrix r r РёЮ)
    (Lhat21 A21 : Matrix s r РёЮ) (Xhat D : Matrix r p РёЮ) : Prop where
  step2_as_matmul : Lhat21 = A21 * A11invHat
  diagonal_solve_as_matmul : Xhat = UiiInvHat * D

lemma FirstOrderLe.of_le {u leading value : РёЮ} (h : value РЅц leading) :
    FirstOrderLe u leading value := by
  exact РЪе0, le_rfl, by simpa using hРЪЕ

lemma FirstOrderLe.mono_leading {u leadingРѓЂ leadingРѓѓ value : РёЮ}
    (h : FirstOrderLe u leadingРѓЂ value) (hle : leadingРѓЂ РЅц leadingРѓѓ) :
    FirstOrderLe u leadingРѓѓ value := by
  rcases h with РЪеK, hK, hvalueРЪЕ
  exact РЪеK, hK, by linarithРЪЕ

lemma FirstOrderLe.mono_value {u leading valueРѓЂ valueРѓѓ : РёЮ}
    (h : FirstOrderLe u leading valueРѓѓ) (hle : valueРѓЂ РЅц valueРѓѓ) :
    FirstOrderLe u leading valueРѓЂ := by
  rcases h with РЪеK, hK, hvalueРЪЕ
  exact РЪеK, hK, by linarithРЪЕ

lemma FirstOrderLe.max_same {u leading valueРѓЂ valueРѓѓ : РёЮ}
    (hРѓЂ : FirstOrderLe u leading valueРѓЂ)
    (hРѓѓ : FirstOrderLe u leading valueРѓѓ) :
    FirstOrderLe u leading (max valueРѓЂ valueРѓѓ) := by
  rcases hРѓЂ with РЪеKРѓЂ, hKРѓЂ, hvalueРѓЂРЪЕ
  rcases hРѓѓ with РЪеKРѓѓ, hKРѓѓ, hvalueРѓѓРЪЕ
  refine РЪеKРѓЂ + KРѓѓ, add_nonneg hKРѓЂ hKРѓѓ, ?_РЪЕ
  have hu2 : 0 РЅц u ^ 2 := sq_nonneg u
  apply max_le
  ┬и calc valueРѓЂ
        РЅц leading + KРѓЂ * u ^ 2 := hvalueРѓЂ
      _ РЅц leading + (KРѓЂ + KРѓѓ) * u ^ 2 := by
        have hKРѓЂle : KРѓЂ РЅц KРѓЂ + KРѓѓ := by linarith
        nlinarith [mul_le_mul_of_nonneg_right hKРѓЂle hu2]
  ┬и calc valueРѓѓ
        РЅц leading + KРѓѓ * u ^ 2 := hvalueРѓѓ
      _ РЅц leading + (KРѓЂ + KРѓѓ) * u ^ 2 := by
        have hKРѓѓle : KРѓѓ РЅц KРѓЂ + KРѓѓ := by linarith
        nlinarith [mul_le_mul_of_nonneg_right hKРѓѓle hu2]

lemma FirstOrderLe.max {u leadingРѓЂ leadingРѓѓ valueРѓЂ valueРѓѓ : РёЮ}
    (hРѓЂ : FirstOrderLe u leadingРѓЂ valueРѓЂ)
    (hРѓѓ : FirstOrderLe u leadingРѓѓ valueРѓѓ) :
    FirstOrderLe u (max leadingРѓЂ leadingРѓѓ) (max valueРѓЂ valueРѓѓ) :=
  FirstOrderLe.max_same
    (hРѓЂ.mono_leading (le_max_left leadingРѓЂ leadingРѓѓ))
    (hРѓѓ.mono_leading (le_max_right leadingРѓЂ leadingРѓѓ))

lemma FirstOrderLe.add {u leadingРѓЂ leadingРѓѓ valueРѓЂ valueРѓѓ value : РёЮ}
    (hРѓЂ : FirstOrderLe u leadingРѓЂ valueРѓЂ)
    (hРѓѓ : FirstOrderLe u leadingРѓѓ valueРѓѓ)
    (hvalue : value РЅц valueРѓЂ + valueРѓѓ) :
    FirstOrderLe u (leadingРѓЂ + leadingРѓѓ) value := by
  rcases hРѓЂ with РЪеKРѓЂ, hKРѓЂ, hvalueРѓЂРЪЕ
  rcases hРѓѓ with РЪеKРѓѓ, hKРѓѓ, hvalueРѓѓРЪЕ
  refine РЪеKРѓЂ + KРѓѓ, add_nonneg hKРѓЂ hKРѓѓ, ?_РЪЕ
  linarith

lemma FirstOrderLe.bound_mul_nonneg_right {u leading value c target : РёЮ}
    (h : FirstOrderLe u leading value) (hc : 0 РЅц c)
    (htarget : target РЅц value * c) :
    FirstOrderLe u (leading * c) target := by
  rcases h with РЪеK, hK, hvalueРЪЕ
  refine РЪеK * c, mul_nonneg hK hc, ?_РЪЕ
  calc
    target РЅц value * c := htarget
    _ РЅц (leading + K * u ^ 2) * c := mul_le_mul_of_nonneg_right hvalue hc
    _ = leading * c + (K * c) * u ^ 2 := by ring

lemma FirstOrderLe.of_gamma_dim_mul (fp : FPModel) (d : РёЋ)
    (h╬│ : gammaValid fp d) {x y value : РёЮ} (hx : 0 РЅц x) (hy : 0 РЅц y)
    (hvalue : value РЅц gamma fp d * (d : РёЮ) * x * y) :
    FirstOrderLe fp.u (((d : РёЮ) ^ 2) * fp.u * x * y) value := by
  refine РЪе((d : РёЮ) ^ 3 * x * y) / (1 - (d : РёЮ) * fp.u), ?_, ?_РЪЕ
  ┬и have hden_pos : 0 < 1 - (d : РёЮ) * fp.u := by
      unfold gammaValid at h╬│
      linarith
    have hd_nonneg : 0 РЅц (d : РёЮ) := by exact_mod_cast d.zero_le
    have hd3_nonneg : 0 РЅц (d : РёЮ) ^ 3 := pow_nonneg hd_nonneg 3
    exact div_nonneg (mul_nonneg (mul_nonneg hd3_nonneg hx) hy)
      (le_of_lt hden_pos)
  ┬и calc
      value РЅц gamma fp d * (d : РёЮ) * x * y := hvalue
      _ = ((d : РёЮ) ^ 2) * fp.u * x * y +
            (((d : РёЮ) ^ 3 * x * y) / (1 - (d : РёЮ) * fp.u)) * fp.u ^ 2 := by
            have h╬│eq := gamma_eq_linear_plus_quadratic_remainder fp d h╬│
            have hden_ne : 1 - (d : РёЮ) * fp.u РЅа 0 := by
              unfold gammaValid at h╬│
              linarith
            rw [h╬│eq]
            field_simp [hden_ne]

/-- A product carrying two componentwise `gamma d` perturbations is purely
    second order.  This is the scalar remainder estimate used by the concrete
    DHS single-right-hand-side solve route for `DeltaL * DeltaU`. -/
lemma FirstOrderLe.of_gamma_sq_dim_mul (fp : FPModel) (d : РёЋ)
    (h╬│ : gammaValid fp d) {x y value : РёЮ} (hx : 0 РЅц x) (hy : 0 РЅц y)
    (hvalue : value РЅц (d : РёЮ) * gamma fp d ^ 2 * x * y) :
    FirstOrderLe fp.u 0 value := by
  refine РЪе((d : РёЮ) ^ 3 * x * y) /
      (1 - (d : РёЮ) * fp.u) ^ 2, ?_, ?_РЪЕ
  ┬и exact div_nonneg
      (mul_nonneg (mul_nonneg (pow_nonneg (Nat.cast_nonneg d) 3) hx) hy)
      (sq_nonneg (1 - (d : РёЮ) * fp.u))
  ┬и have hden_ne : 1 - (d : РёЮ) * fp.u РЅа 0 := by
      unfold gammaValid at h╬│
      linarith
    calc
      value РЅц (d : РёЮ) * gamma fp d ^ 2 * x * y := hvalue
      _ = 0 + (((d : РёЮ) ^ 3 * x * y) /
            (1 - (d : РёЮ) * fp.u) ^ 2) * fp.u ^ 2 := by
        unfold gamma
        field_simp [hden_ne]
        ring

/-- One rounded subtraction has an absolute error bounded by unit roundoff
    times the sum of the input magnitudes. -/
theorem higham13_fl_sub_error_le_abs_add_abs (fp : FPModel) (x y : РёЮ) :
    |fp.fl_sub x y - (x - y)| РЅц fp.u * (|x| + |y|) := by
  obtain РЪеdelta, hdelta, hflРЪЕ := fp.model_sub x y
  rw [hfl]
  have hdiff :
      (x - y) * (1 + delta) - (x - y) = (x - y) * delta := by ring
  rw [hdiff, abs_mul]
  have hsub : |x - y| РЅц |x| + |y| := by
    simpa [sub_eq_add_neg, abs_neg] using abs_sub_le x 0 y
  calc
    |x - y| * |delta| РЅц (|x| + |y|) * fp.u :=
      mul_le_mul hsub hdelta (abs_nonneg _)
        (add_nonneg (abs_nonneg _) (abs_nonneg _))
    _ = fp.u * (|x| + |y|) := by ring

/-- Entrywise rounded matrix subtraction used by the concrete Chapter 13
    subtraction model. -/
noncomputable def higham13_fl_matrixSub (fp : FPModel) {m p : РёЋ}
    (A B : Matrix (Fin m) (Fin p) РёЮ) : Matrix (Fin m) (Fin p) РёЮ :=
  fun i j => fp.fl_sub (A i j) (B i j)

/-- Residual of entrywise rounded matrix subtraction. -/
noncomputable def higham13_fl_matrixSubError (fp : FPModel) {m p : РёЋ}
    (A B : Matrix (Fin m) (Fin p) РёЮ) : Matrix (Fin m) (Fin p) РёЮ :=
  fun i j => higham13_fl_matrixSub fp A B i j - (A i j - B i j)

/-- Concrete max-entry instance of the Chapter 13 subtraction residual model.

    This supplies the ordinary rounded subtraction step needed, together with
    equation (13.4), when forming a block-back-substitution right-hand side. -/
theorem higham13_conventional_subtraction_spec_maxEntry {m p : РёЋ}
    (fp : FPModel) (hm : 0 < m) (hp : 0 < p)
    (A B : Matrix (Fin m) (Fin p) РёЮ) :
    SubtractionFirstOrderSpec fp.u
      (maxEntryNormRect hm hp A) (maxEntryNormRect hm hp B)
      (maxEntryNormRect hm hp (higham13_fl_matrixSubError fp A B))
      A B (higham13_fl_matrixSubError fp A B)
      (higham13_fl_matrixSub fp A B) := by
  refine РЪе?_, ?_РЪЕ
  ┬и ext i j
    simp only [higham13_fl_matrixSub, higham13_fl_matrixSubError,
      Matrix.sub_apply, Matrix.add_apply]
    ring
  ┬и apply maxEntryNormRect_le_of_entry_abs_le
    intro i j
    calc
      |higham13_fl_matrixSubError fp A B i j| РЅц
          fp.u * (|A i j| + |B i j|) := by
        simpa [higham13_fl_matrixSubError, higham13_fl_matrixSub] using
          higham13_fl_sub_error_le_abs_add_abs fp (A i j) (B i j)
      _ РЅц fp.u *
          (maxEntryNormRect hm hp A + maxEntryNormRect hm hp B) := by
        exact mul_le_mul_of_nonneg_left
          (add_le_add (entry_le_maxEntryNormRect hm hp A i j)
            (entry_le_maxEntryNormRect hm hp B i j)) fp.u_nonneg

/-- Higham, 2nd ed., Chapter 13, p.248: the conventional matrix product
    satisfies the first-order norm bound in (13.4) with
    `cРѓЂ(m,n,p) = n^2`, for the chapter's entrywise max norm.  This wrapper
    converts the existing componentwise `╬│_n` matrix-multiply bound to the
    displayed `n^2 u + O(u^2)` form. -/
theorem higham13_conventional_matmul_c1_maxEntry_bound {m n p : РёЋ}
    (fp : FPModel) (hm : 0 < m) (hn : 0 < n) (hp : 0 < p)
    (A : Fin m Рєњ Fin n Рєњ РёЮ) (B : Fin n Рєњ Fin p Рєњ РёЮ)
    (h╬│ : gammaValid fp n) :
    MatMulFirstOrderBound fp.u ((n : РёЮ) ^ 2)
      (maxEntryNormRect hm hn A) (maxEntryNormRect hn hp B)
      (maxEntryNormRect hm hp
        (fun i : Fin m => fun j : Fin p =>
          fl_matMul fp m n p A B i j - РѕЉ k : Fin n, A i k * B k j)) := by
  let normA : РёЮ := maxEntryNormRect hm hn A
  let normB : РёЮ := maxEntryNormRect hn hp B
  let E : Fin m Рєњ Fin p Рєњ РёЮ :=
    fun i j => fl_matMul fp m n p A B i j - РѕЉ k : Fin n, A i k * B k j
  have hnormA : 0 РЅц normA := maxEntryNormRect_nonneg hm hn A
  have hnormB : 0 РЅц normB := maxEntryNormRect_nonneg hn hp B
  have h╬│_nonneg : 0 РЅц gamma fp n := gamma_nonneg fp h╬│
  have hentry : Рѕђ i : Fin m, Рѕђ j : Fin p,
      |E i j| РЅц gamma fp n * (n : РёЮ) * normA * normB := by
    intro i j
    have hsum :
        (РѕЉ k : Fin n, |A i k| * |B k j|) РЅц (n : РёЮ) * (normA * normB) := by
      calc
        (РѕЉ k : Fin n, |A i k| * |B k j|)
            РЅц РѕЉ _k : Fin n, normA * normB := by
                apply Finset.sum_le_sum
                intro k _hk
                exact mul_le_mul
                  (entry_le_maxEntryNormRect hm hn A i k)
                  (entry_le_maxEntryNormRect hn hp B k j)
                  (abs_nonneg (B k j)) hnormA
        _ = (n : РёЮ) * (normA * normB) := by simp
    calc
      |E i j|
          РЅц gamma fp n * РѕЉ k : Fin n, |A i k| * |B k j| := by
            simpa [E] using matMul_error_bound fp m n p A B h╬│ i j
      _ РЅц gamma fp n * ((n : РёЮ) * (normA * normB)) :=
            mul_le_mul_of_nonneg_left hsum h╬│_nonneg
      _ = gamma fp n * (n : РёЮ) * normA * normB := by ring
  have hDelta :
      maxEntryNormRect hm hp E РЅц gamma fp n * (n : РёЮ) * normA * normB :=
    maxEntryNormRect_le_of_entry_abs_le hm hp E
      (gamma fp n * (n : РёЮ) * normA * normB) hentry
  unfold MatMulFirstOrderBound
  refine РЪе((n : РёЮ) ^ 3 * normA * normB) / (1 - (n : РёЮ) * fp.u), ?_, ?_РЪЕ
  ┬и have hden_pos : 0 < 1 - (n : РёЮ) * fp.u := by
      unfold gammaValid at h╬│
      linarith
    have hn_nonneg : 0 РЅц (n : РёЮ) := by exact_mod_cast n.zero_le
    have hn3_nonneg : 0 РЅц (n : РёЮ) ^ 3 := pow_nonneg hn_nonneg 3
    exact div_nonneg (mul_nonneg (mul_nonneg hn3_nonneg hnormA) hnormB)
      (le_of_lt hden_pos)
  ┬и calc
      maxEntryNormRect hm hp E
          РЅц gamma fp n * (n : РёЮ) * normA * normB := hDelta
      _ = ((n : РёЮ) ^ 2) * fp.u * normA * normB +
            (((n : РёЮ) ^ 3 * normA * normB) /
              (1 - (n : РёЮ) * fp.u)) * fp.u ^ 2 := by
            have h╬│eq := gamma_eq_linear_plus_quadratic_remainder fp n h╬│
            have hden_ne : 1 - (n : РёЮ) * fp.u РЅа 0 := by
              unfold gammaValid at h╬│
              linarith
            rw [h╬│eq]
            field_simp [hden_ne]

/-- Higham, 2nd ed., Chapter 13, equation (13.4), conventional matrix
    multiplication instance: `─ѕ = AB + ╬ћC` and the entrywise max-norm
    first-order bound holds with `cРѓЂ(m,n,p) = n^2`. -/
theorem higham13_conventional_matmul_spec_c1_maxEntry {m n p : РёЋ}
    (fp : FPModel) (hm : 0 < m) (hn : 0 < n) (hp : 0 < p)
    (A : Fin m Рєњ Fin n Рєњ РёЮ) (B : Fin n Рєњ Fin p Рєњ РёЮ)
    (h╬│ : gammaValid fp n) :
    MatMulFirstOrderSpec fp.u ((n : РёЮ) ^ 2)
      (maxEntryNormRect hm hn A) (maxEntryNormRect hn hp B)
      (maxEntryNormRect hm hp
        (fun i : Fin m => fun j : Fin p =>
          fl_matMul fp m n p A B i j - РѕЉ k : Fin n, A i k * B k j))
      A B (fl_matMul fp m n p A B)
      (fun i : Fin m => fun j : Fin p =>
        fl_matMul fp m n p A B i j - РѕЉ k : Fin n, A i k * B k j) := by
  constructor
  ┬и ext i j
    simp [Matrix.mul_apply]
  ┬и exact higham13_conventional_matmul_c1_maxEntry_bound fp hm hn hp A B h╬│

/-- Columnwise back substitution for multiple right-hand sides. -/
noncomputable def fl_backSubCols (fp : FPModel) (m p : РёЋ)
    (T : Fin m Рєњ Fin m Рєњ РёЮ) (B : Fin m Рєњ Fin p Рєњ РёЮ) :
    Fin m Рєњ Fin p Рєњ РёЮ :=
  fun i j => fl_backSub fp m T (fun r => B r j) i

/-- Columnwise forward substitution for multiple right-hand sides. -/
noncomputable def fl_forwardSubCols (fp : FPModel) (m p : РёЋ)
    (T : Fin m Рєњ Fin m Рєњ РёЮ) (B : Fin m Рєњ Fin p Рєњ РёЮ) :
    Fin m Рєњ Fin p Рєњ РёЮ :=
  fun i j => fl_forwardSub fp m T (fun r => B r j) i

/-- Higham, 2nd ed., Chapter 13, p.248: bridge from a componentwise
    triangular-matrix backward perturbation to the residual form of (13.5),
    with the chapter's entrywise max norm and `cРѓѓ(m,p) = m^2`. -/
theorem higham13_triangular_solve_c2_maxEntry_from_componentwise_backward {m p : РёЋ}
    (fp : FPModel) (hm : 0 < m) (hp : 0 < p)
    (T : Fin m Рєњ Fin m Рєњ РёЮ) (B Xhat : Fin m Рєњ Fin p Рєњ РёЮ)
    (h╬│ : gammaValid fp m)
    (hBackward : Рѕђ j : Fin p, РѕЃ DeltaT : Fin m Рєњ Fin m Рєњ РёЮ,
      (Рѕђ i k : Fin m, |DeltaT i k| РЅц gamma fp m * |T i k|) РѕД
      Рѕђ i : Fin m, РѕЉ k : Fin m, (T i k + DeltaT i k) * Xhat k j = B i j) :
    TriangularSolveFirstOrderSpec fp.u ((m : РёЮ) ^ 2)
      (maxEntryNormRect hm hm T) (maxEntryNormRect hm hp Xhat)
      (maxEntryNormRect hm hp
        (fun i : Fin m => fun j : Fin p => РѕЉ k : Fin m, T i k * Xhat k j - B i j))
      T B
      (fun i : Fin m => fun j : Fin p => РѕЉ k : Fin m, T i k * Xhat k j - B i j)
      Xhat := by
  let DeltaB : Fin m Рєњ Fin p Рєњ РёЮ :=
    fun i j => РѕЉ k : Fin m, T i k * Xhat k j - B i j
  let normT : РёЮ := maxEntryNormRect hm hm T
  let normX : РёЮ := maxEntryNormRect hm hp Xhat
  have hnormT : 0 РЅц normT := maxEntryNormRect_nonneg hm hm T
  have hnormX : 0 РЅц normX := maxEntryNormRect_nonneg hm hp Xhat
  have h╬│_nonneg : 0 РЅц gamma fp m := gamma_nonneg fp h╬│
  have hentry : Рѕђ i : Fin m, Рѕђ j : Fin p,
      |DeltaB i j| РЅц gamma fp m * (m : РёЮ) * normT * normX := by
    intro i j
    obtain РЪеDeltaT, hDeltaT_bound, hDeltaT_eqРЪЕ := hBackward j
    have hsplit :
        (РѕЉ k : Fin m, T i k * Xhat k j) +
            (РѕЉ k : Fin m, DeltaT i k * Xhat k j) = B i j := by
      simpa [Finset.sum_add_distrib, add_mul] using hDeltaT_eq i
    have hDeltaB_eq :
        DeltaB i j = -РѕЉ k : Fin m, DeltaT i k * Xhat k j := by
      dsimp [DeltaB]
      rw [Рєљ hsplit]
      ring
    calc
      |DeltaB i j|
          = |РѕЉ k : Fin m, DeltaT i k * Xhat k j| := by
            rw [hDeltaB_eq, abs_neg]
      _ РЅц РѕЉ k : Fin m, |DeltaT i k * Xhat k j| := Finset.abs_sum_le_sum_abs _ _
      _ = РѕЉ k : Fin m, |DeltaT i k| * |Xhat k j| := by
            apply Finset.sum_congr rfl
            intro k _hk
            rw [abs_mul]
      _ РЅц РѕЉ _k : Fin m, gamma fp m * normT * normX := by
            apply Finset.sum_le_sum
            intro k _hk
            calc
              |DeltaT i k| * |Xhat k j|
                  РЅц (gamma fp m * |T i k|) * |Xhat k j| :=
                    mul_le_mul_of_nonneg_right (hDeltaT_bound i k) (abs_nonneg _)
              _ РЅц (gamma fp m * normT) * normX := by
                    have hT : gamma fp m * |T i k| РЅц gamma fp m * normT :=
                      mul_le_mul_of_nonneg_left
                        (entry_le_maxEntryNormRect hm hm T i k) h╬│_nonneg
                    exact mul_le_mul hT
                      (entry_le_maxEntryNormRect hm hp Xhat k j)
                      (abs_nonneg _) (mul_nonneg h╬│_nonneg hnormT)
              _ = gamma fp m * normT * normX := by ring
      _ = (m : РёЮ) * (gamma fp m * normT * normX) := by simp
      _ = gamma fp m * (m : РёЮ) * normT * normX := by ring
  have hDeltaNorm :
      maxEntryNormRect hm hp DeltaB РЅц gamma fp m * (m : РёЮ) * normT * normX :=
    maxEntryNormRect_le_of_entry_abs_le hm hp DeltaB
      (gamma fp m * (m : РёЮ) * normT * normX) hentry
  constructor
  ┬и ext i j
    simp [Matrix.mul_apply]
  ┬и unfold TriangularSolveFirstOrderBound
    exact FirstOrderLe.of_gamma_dim_mul fp m h╬│ hnormT hnormX hDeltaNorm

/-- Higham, 2nd ed., Chapter 13, equation (13.5), conventional upper-triangular
    back substitution applied columnwise.  The residual form
    `T X╠ѓ = B + ╬ћB` satisfies the entrywise max-norm first-order bound with
    `cРѓѓ(m,p) = m^2`. -/
theorem higham13_conventional_backSub_spec_c2_maxEntry {m p : РёЋ}
    (fp : FPModel) (hm : 0 < m) (hp : 0 < p)
    (T : Fin m Рєњ Fin m Рєњ РёЮ) (B : Fin m Рєњ Fin p Рєњ РёЮ)
    (hdiag : Рѕђ i : Fin m, T i i РЅа 0)
    (hupper : Рѕђ i k : Fin m, k.val < i.val Рєњ T i k = 0)
    (h╬│ : gammaValid fp m) :
    TriangularSolveFirstOrderSpec fp.u ((m : РёЮ) ^ 2)
      (maxEntryNormRect hm hm T) (maxEntryNormRect hm hp (fl_backSubCols fp m p T B))
      (maxEntryNormRect hm hp
        (fun i : Fin m => fun j : Fin p =>
          РѕЉ k : Fin m, T i k * fl_backSubCols fp m p T B k j - B i j))
      T B
      (fun i : Fin m => fun j : Fin p =>
        РѕЉ k : Fin m, T i k * fl_backSubCols fp m p T B k j - B i j)
      (fl_backSubCols fp m p T B) := by
  exact higham13_triangular_solve_c2_maxEntry_from_componentwise_backward fp hm hp T B
    (fl_backSubCols fp m p T B) h╬│ (by
      intro j
      simpa [fl_backSubCols] using
        backSub_backward_error fp m T (fun r : Fin m => B r j) hdiag hupper h╬│)

/-- Higham, 2nd ed., Chapter 13, equation (13.5), conventional lower-triangular
    forward substitution applied columnwise.  This is the lower-triangular
    analogue of `higham13_conventional_backSub_spec_c2_maxEntry`. -/
theorem higham13_conventional_forwardSub_spec_c2_maxEntry {m p : РёЋ}
    (fp : FPModel) (hm : 0 < m) (hp : 0 < p)
    (T : Fin m Рєњ Fin m Рєњ РёЮ) (B : Fin m Рєњ Fin p Рєњ РёЮ)
    (hdiag : Рѕђ i : Fin m, T i i РЅа 0)
    (hlower : Рѕђ i k : Fin m, i.val < k.val Рєњ T i k = 0)
    (h╬│ : gammaValid fp m) :
    TriangularSolveFirstOrderSpec fp.u ((m : РёЮ) ^ 2)
      (maxEntryNormRect hm hm T) (maxEntryNormRect hm hp (fl_forwardSubCols fp m p T B))
      (maxEntryNormRect hm hp
        (fun i : Fin m => fun j : Fin p =>
          РѕЉ k : Fin m, T i k * fl_forwardSubCols fp m p T B k j - B i j))
      T B
      (fun i : Fin m => fun j : Fin p =>
        РѕЉ k : Fin m, T i k * fl_forwardSubCols fp m p T B k j - B i j)
      (fl_forwardSubCols fp m p T B) := by
  exact higham13_triangular_solve_c2_maxEntry_from_componentwise_backward fp hm hp T B
    (fl_forwardSubCols fp m p T B) h╬│ (by
      intro j
      simpa [fl_forwardSubCols] using
        forwardSub_backward_error fp m T (fun r : Fin m => B r j) hdiag hlower h╬│)

-- ============================================================
-- ┬Д13.1  Block LU specification
-- ============================================================

/-- **Block LU factorization specification** (Higham, 2nd ed., ┬Д13.1).
    A = LU where L is block unit lower triangular (identity diagonal blocks)
    and U is block upper triangular, with m blocks of uniform size r. -/
structure BlockLUFactSpec (m r : РёЋ)
    (A L U : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) : Prop where
  /-- L has identity blocks on the diagonal: L_{ii} = I_r. -/
  L_diag : Рѕђ i : Fin m, L i i = idBlock r
  /-- L is block lower triangular: L_{ij} = 0 for i < j. -/
  L_upper_zero : Рѕђ i j : Fin m, i.val < j.val Рєњ L i j = zeroBlock r
  /-- U is block upper triangular: U_{ij} = 0 for j < i. -/
  U_lower_zero : Рѕђ i j : Fin m, j.val < i.val Рєњ U i j = zeroBlock r
  /-- Block product L┬иU equals A entrywise. -/
  product_eq : Рѕђ (i j : Fin m) (s t : Fin r),
    РѕЉ k : Fin m, РѕЉ l : Fin r, L i k s l * U k j l t = A i j s t

/-- Identity block matrix at the uniform-block level.  This is the target
    matrix for the source phrase "nonsingular leading principal block
    submatrix" in Theorem 13.2. -/
noncomputable def blockMatrixIdentity (m r : РёЋ) :
    Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ) :=
  fun i j => if i = j then idBlock r else zeroBlock r

/-- A two-sided inverse for a uniform block matrix under block multiplication. -/
def BlockMatrixTwoSidedInverse {m r : РёЋ}
    (A Ainv : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) : Prop :=
  (Рѕђ i j : Fin m, Рѕђ s t : Fin r,
    РѕЉ k : Fin m, РѕЉ l : Fin r, Ainv i k s l * A k j l t =
      blockMatrixIdentity m r i j s t) РѕД
  (Рѕђ i j : Fin m, Рѕђ s t : Fin r,
    РѕЉ k : Fin m, РѕЉ l : Fin r, A i k s l * Ainv k j l t =
      blockMatrixIdentity m r i j s t)

/-- Uniform block-matrix nonsingularity, represented by an explicit two-sided
    block inverse. -/
def BlockMatrixNonsingular {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) : Prop :=
  РѕЃ Ainv : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ), BlockMatrixTwoSidedInverse A Ainv

/-- Flatten a uniform block matrix to an ordinary matrix indexed by
    block-within-block pairs.  This is the bridge between Mathlib determinant
    and positive-definite facts and the Chapter 13 block predicates. -/
noncomputable def blockMatrixFlat {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix (Fin m ├Ќ Fin r) (Fin m ├Ќ Fin r) РёЮ :=
  fun is jt => A is.1 jt.1 is.2 jt.2

/-- Flatten a uniform block matrix to the standard `Fin (m*r)` square index.

    This is the same scalar matrix as `blockMatrixFlat`, reindexed through
    Mathlib's `finProdFinEquiv`.  It is useful when a later max-entry growth
    theorem is stated with the repository's `Fin n` matrix convention. -/
noncomputable def blockMatrixFlatFin {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix (Fin (m * r)) (Fin (m * r)) РёЮ :=
  fun p q =>
    A (finProdFinEquiv.symm p).1 (finProdFinEquiv.symm q).1
      (finProdFinEquiv.symm p).2 (finProdFinEquiv.symm q).2

@[simp] theorem blockMatrixFlatFin_apply {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (i j : Fin m) (s t : Fin r) :
    blockMatrixFlatFin A (finProdFinEquiv (i, s)) (finProdFinEquiv (j, t)) =
      A i j s t := by
  simp [blockMatrixFlatFin]

/-- Flatten a uniformly blocked matrix of right-hand sides by stacking its
    block rows.  Unlike `blockMatrixFlatFin`, the column type is left generic;
    this is the representation used to turn the DHS per-block-row solve
    equations into one ordinary matrix equation. -/
noncomputable def blockMatrixRowsFlatFin {m r : РёЋ} {p : Type*}
    (X : Fin m Рєњ Matrix (Fin r) p РёЮ) : Matrix (Fin (m * r)) p РёЮ :=
  fun is k =>
    X (finProdFinEquiv.symm is).1 (finProdFinEquiv.symm is).2 k

@[simp] theorem blockMatrixRowsFlatFin_apply {m r : РёЋ} {p : Type*}
    (X : Fin m Рєњ Matrix (Fin r) p РёЮ)
    (i : Fin m) (s : Fin r) (k : p) :
    blockMatrixRowsFlatFin X (finProdFinEquiv (i, s)) k = X i s k := by
  simp [blockMatrixRowsFlatFin]

/-- A product of a flattened uniform block row with stacked right-hand sides
    is the scalar entry of the corresponding sum of block products.

    The two coefficient families are kept separate because the DHS row
    equation uses `Uhat + DeltaU`. -/
theorem blockMatrixFlatFin_add_mul_blockMatrixRowsFlatFin_apply
    {m r : РёЋ} {p : Type*}
    (A B : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (X : Fin m Рєњ Matrix (Fin r) p РёЮ)
    (i : Fin m) (s : Fin r) (k : p) :
    (РѕЉ jt : Fin (m * r),
      (blockMatrixFlatFin A (finProdFinEquiv (i, s)) jt +
          blockMatrixFlatFin B (finProdFinEquiv (i, s)) jt) *
        blockMatrixRowsFlatFin X jt k) =
      РѕЉ j : Fin m, ((A i j + B i j) * X j) s k := by
  calc
    (РѕЉ jt : Fin (m * r),
      (blockMatrixFlatFin A (finProdFinEquiv (i, s)) jt +
          blockMatrixFlatFin B (finProdFinEquiv (i, s)) jt) *
        blockMatrixRowsFlatFin X jt k) =
        РѕЉ jt : Fin m ├Ќ Fin r,
          (A i jt.1 s jt.2 + B i jt.1 s jt.2) * X jt.1 jt.2 k := by
      rw [Fintype.sum_equiv finProdFinEquiv]
      intro jt
      rw [blockMatrixFlatFin_apply, blockMatrixFlatFin_apply,
        blockMatrixRowsFlatFin_apply]
    _ = РѕЉ j : Fin m, РѕЉ t : Fin r,
          (A i j s t + B i j s t) * X j t k := by
      rw [Fintype.sum_prod_type]
    _ = РѕЉ j : Fin m, ((A i j + B i j) * X j) s k := by
      simp [Matrix.mul_apply]

/-- The product-index and `Fin (m*r)` flattenings have the same determinant,
    because they are simultaneous row/column reindexings of the same scalar
    block matrix. -/
theorem det_blockMatrixFlat_eq_blockMatrixFlatFin {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix.det (blockMatrixFlat A :
      Matrix (Fin m ├Ќ Fin r) (Fin m ├Ќ Fin r) РёЮ) =
      Matrix.det (blockMatrixFlatFin A :
        Matrix (Fin (m * r)) (Fin (m * r)) РёЮ) := by
  have hflat :
      blockMatrixFlat A =
        (blockMatrixFlatFin A).submatrix finProdFinEquiv finProdFinEquiv := by
    ext is jt
    rcases is with РЪеi, sРЪЕ
    rcases jt with РЪеj, tРЪЕ
    simp [blockMatrixFlat, blockMatrixFlatFin]
  rw [hflat]
  simpa [Matrix.submatrix] using
    (Matrix.det_submatrix_equiv_self
      (finProdFinEquiv : Fin m ├Ќ Fin r РЅЃ Fin (m * r))
      (blockMatrixFlatFin A :
        Matrix (Fin (m * r)) (Fin (m * r)) РёЮ))

lemma maxEntryNorm_blockMatrixFlatFin_le_blockMaxNorm {m r : РёЋ}
    (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    maxEntryNorm (Nat.mul_pos hm hr) (blockMatrixFlatFin A) РЅц
      blockMaxNorm hm hr A := by
  have hrect :
      maxEntryNormRect (Nat.mul_pos hm hr) (Nat.mul_pos hm hr)
          (blockMatrixFlatFin A) РЅц
        blockMaxNorm hm hr A := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro p q
    simpa [blockMatrixFlatFin] using
      block_entry_abs_le_blockMaxNorm hm hr A
        (finProdFinEquiv.symm p).1 (finProdFinEquiv.symm q).1
        (finProdFinEquiv.symm p).2 (finProdFinEquiv.symm q).2
  simpa [maxEntryNormRect_eq_maxEntryNorm (Nat.mul_pos hm hr)] using hrect

lemma blockMaxNorm_le_maxEntryNorm_blockMatrixFlatFin {m r : РёЋ}
    (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    blockMaxNorm hm hr A РЅц
      maxEntryNorm (Nat.mul_pos hm hr) (blockMatrixFlatFin A) := by
  apply blockMaxNorm_le_of_entry_abs_le
  intro i j s t
  have hentry :=
    entry_le_maxEntryNorm (Nat.mul_pos hm hr) (blockMatrixFlatFin A)
      (finProdFinEquiv (i, s)) (finProdFinEquiv (j, t))
  simpa [blockMatrixFlatFin] using hentry

/-- Reindexing a block matrix from block/product indices to `Fin (m*r)`
    preserves Higham Chapter 13's entrywise max norm. -/
theorem maxEntryNorm_blockMatrixFlatFin_eq_blockMaxNorm {m r : РёЋ}
    (hm : 0 < m) (hr : 0 < r)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    maxEntryNorm (Nat.mul_pos hm hr) (blockMatrixFlatFin A) =
      blockMaxNorm hm hr A := by
  exact le_antisymm
    (maxEntryNorm_blockMatrixFlatFin_le_blockMaxNorm hm hr A)
    (blockMaxNorm_le_maxEntryNorm_blockMatrixFlatFin hm hr A)

/-- Flatten a `(m+1) ├Ќ (m+1)` uniform block matrix along the first block
    split, producing the scalar matrix indexed by `Fin (r + m*r)`.

    The left summand is the first block row/column and the right summand is
    the remaining `m` block rows/columns, flattened through
    `finProdFinEquiv`.  This is the shape used by the local two-by-two Schur
    split in Problem 13.4. -/
noncomputable def blockMatrixFirstSplitFlat {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix (Fin (r + m * r)) (Fin (r + m * r)) РёЮ :=
  fun p q =>
    match finSumFinEquiv.symm p, finSumFinEquiv.symm q with
    | Sum.inl s, Sum.inl t => A 0 0 s t
    | Sum.inl s, Sum.inr qt =>
        let jt := finProdFinEquiv.symm qt
        A 0 (Fin.succ jt.1) s jt.2
    | Sum.inr ip, Sum.inl t =>
        let is := finProdFinEquiv.symm ip
        A (Fin.succ is.1) 0 is.2 t
    | Sum.inr ip, Sum.inr qt =>
        let is := finProdFinEquiv.symm ip
        let jt := finProdFinEquiv.symm qt
        A (Fin.succ is.1) (Fin.succ jt.1) is.2 jt.2

@[simp] theorem blockMatrixFirstSplitFlat_11 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (s t : Fin r) :
    blockMatrixFirstSplitFlat A
        (finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r)))
        (finSumFinEquiv (Sum.inl t : Fin r РіЋ Fin (m * r))) =
      A 0 0 s t := by
  simp [blockMatrixFirstSplitFlat]

@[simp] theorem blockMatrixFirstSplitFlat_12 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (s : Fin r) (j : Fin m) (t : Fin r) :
    blockMatrixFirstSplitFlat A
        (finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r)))
        (finSumFinEquiv (Sum.inr (finProdFinEquiv (j, t)) : Fin r РіЋ Fin (m * r))) =
      A 0 (Fin.succ j) s t := by
  simp [blockMatrixFirstSplitFlat]

@[simp] theorem blockMatrixFirstSplitFlat_21 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (i : Fin m) (s : Fin r) (t : Fin r) :
    blockMatrixFirstSplitFlat A
        (finSumFinEquiv (Sum.inr (finProdFinEquiv (i, s)) : Fin r РіЋ Fin (m * r)))
        (finSumFinEquiv (Sum.inl t : Fin r РіЋ Fin (m * r))) =
      A (Fin.succ i) 0 s t := by
  simp [blockMatrixFirstSplitFlat]

@[simp] theorem blockMatrixFirstSplitFlat_22 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (i j : Fin m) (s t : Fin r) :
    blockMatrixFirstSplitFlat A
        (finSumFinEquiv (Sum.inr (finProdFinEquiv (i, s)) : Fin r РіЋ Fin (m * r)))
        (finSumFinEquiv (Sum.inr (finProdFinEquiv (j, t)) : Fin r РіЋ Fin (m * r))) =
      A (Fin.succ i) (Fin.succ j) s t := by
  simp [blockMatrixFirstSplitFlat]

/-- The leading `r ├Ќ r` scalar block in the first-split flattening. -/
noncomputable def blockMatrixFirstSplitA11 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix (Fin r) (Fin r) РёЮ :=
  A 0 0

/-- The top-right scalar block row in the first-split flattening. -/
noncomputable def blockMatrixFirstSplitA12 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix (Fin r) (Fin (m * r)) РёЮ :=
  fun i q =>
    let jq := finProdFinEquiv.symm q
    A 0 (Fin.succ jq.1) i jq.2

/-- The bottom-left scalar block column in the first-split flattening. -/
noncomputable def blockMatrixFirstSplitA21 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix (Fin (m * r)) (Fin r) РёЮ :=
  fun p j =>
    let ip := finProdFinEquiv.symm p
    A (Fin.succ ip.1) 0 ip.2 j

/-- The trailing scalar block matrix in the first-split flattening. -/
noncomputable def blockMatrixFirstSplitA22 {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    Matrix (Fin (m * r)) (Fin (m * r)) РёЮ :=
  blockMatrixFlatFin (fun i j => A (Fin.succ i) (Fin.succ j))

lemma maxEntryNorm_blockMatrixFirstSplitFlat_le_blockMaxNorm {m r : РёЋ}
    (_hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    maxEntryNorm (Nat.add_pos_left hr (m * r)) (blockMatrixFirstSplitFlat A) РЅц
      blockMaxNorm (Nat.succ_pos m) hr A := by
  have hrect :
      maxEntryNormRect (Nat.add_pos_left hr (m * r)) (Nat.add_pos_left hr (m * r))
          (blockMatrixFirstSplitFlat A) РЅц
        blockMaxNorm (Nat.succ_pos m) hr A := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro p q
    cases hp : finSumFinEquiv.symm p with
    | inl s =>
        cases hq : finSumFinEquiv.symm q with
        | inl t =>
            simpa [blockMatrixFirstSplitFlat, hp, hq] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A 0 0 s t
        | inr qt =>
            let jt := finProdFinEquiv.symm qt
            simpa [blockMatrixFirstSplitFlat, hp, hq, jt] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A
                0 (Fin.succ jt.1) s jt.2
    | inr ip =>
        let is := finProdFinEquiv.symm ip
        cases hq : finSumFinEquiv.symm q with
        | inl t =>
            simpa [blockMatrixFirstSplitFlat, hp, hq, is] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A
                (Fin.succ is.1) 0 is.2 t
        | inr qt =>
            let jt := finProdFinEquiv.symm qt
            simpa [blockMatrixFirstSplitFlat, hp, hq, is, jt] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A
                (Fin.succ is.1) (Fin.succ jt.1) is.2 jt.2
  simpa [maxEntryNormRect_eq_maxEntryNorm (Nat.add_pos_left hr (m * r))]
    using hrect

lemma maxEntryNorm_blockMatrixFirstSplitFlat_le_blockMaxNorm_of_hN {m r : РёЋ}
    (hN : 0 < r + m * r) (_hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    maxEntryNorm hN (blockMatrixFirstSplitFlat A) РЅц
        blockMaxNorm (Nat.succ_pos m) hr A := by
  have hrect :
      maxEntryNormRect hN hN (blockMatrixFirstSplitFlat A) РЅц
        blockMaxNorm (Nat.succ_pos m) hr A := by
    apply maxEntryNormRect_le_of_entry_abs_le
    intro p q
    cases hp : finSumFinEquiv.symm p with
    | inl s =>
        cases hq : finSumFinEquiv.symm q with
        | inl t =>
            simpa [blockMatrixFirstSplitFlat, hp, hq] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A 0 0 s t
        | inr qt =>
            let jt := finProdFinEquiv.symm qt
            simpa [blockMatrixFirstSplitFlat, hp, hq, jt] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A
                0 (Fin.succ jt.1) s jt.2
    | inr ip =>
        let is := finProdFinEquiv.symm ip
        cases hq : finSumFinEquiv.symm q with
        | inl t =>
            simpa [blockMatrixFirstSplitFlat, hp, hq, is] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A
                (Fin.succ is.1) 0 is.2 t
        | inr qt =>
            let jt := finProdFinEquiv.symm qt
            simpa [blockMatrixFirstSplitFlat, hp, hq, is, jt] using
              block_entry_abs_le_blockMaxNorm (Nat.succ_pos m) hr A
                (Fin.succ is.1) (Fin.succ jt.1) is.2 jt.2
  simpa [maxEntryNormRect_eq_maxEntryNorm hN] using hrect

/-- The first-split scalar flattening contains every block entry of `A`. -/
lemma blockMaxNorm_le_maxEntryNorm_blockMatrixFirstSplitFlat {m r : РёЋ}
    (_hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    blockMaxNorm (Nat.succ_pos m) hr A РЅц
      maxEntryNorm (Nat.add_pos_left hr (m * r)) (blockMatrixFirstSplitFlat A) := by
  apply blockMaxNorm_le_of_entry_abs_le
  intro i j s t
  by_cases hi : i = 0
  ┬и subst i
    by_cases hj : j = 0
    ┬и subst j
      have hentry :=
        entry_le_maxEntryNorm (Nat.add_pos_left hr (m * r))
          (blockMatrixFirstSplitFlat A)
          (finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r)))
          (finSumFinEquiv (Sum.inl t : Fin r РіЋ Fin (m * r)))
      rw [blockMatrixFirstSplitFlat_11 A s t] at hentry
      exact hentry
    ┬и have hentry :=
        entry_le_maxEntryNorm (Nat.add_pos_left hr (m * r))
          (blockMatrixFirstSplitFlat A)
          (finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r)))
          (finSumFinEquiv
            (Sum.inr (finProdFinEquiv (j.pred hj, t)) : Fin r РіЋ Fin (m * r)))
      rw [blockMatrixFirstSplitFlat_12 A s (j.pred hj) t] at hentry
      simpa [Fin.succ_pred j hj] using hentry
  ┬и by_cases hj : j = 0
    ┬и subst j
      have hentry :=
        entry_le_maxEntryNorm (Nat.add_pos_left hr (m * r))
          (blockMatrixFirstSplitFlat A)
          (finSumFinEquiv
            (Sum.inr (finProdFinEquiv (i.pred hi, s)) : Fin r РіЋ Fin (m * r)))
          (finSumFinEquiv (Sum.inl t : Fin r РіЋ Fin (m * r)))
      rw [blockMatrixFirstSplitFlat_21 A (i.pred hi) s t] at hentry
      simpa [Fin.succ_pred i hi] using hentry
    ┬и have hentry :=
        entry_le_maxEntryNorm (Nat.add_pos_left hr (m * r))
          (blockMatrixFirstSplitFlat A)
          (finSumFinEquiv
            (Sum.inr (finProdFinEquiv (i.pred hi, s)) : Fin r РіЋ Fin (m * r)))
          (finSumFinEquiv
            (Sum.inr (finProdFinEquiv (j.pred hj, t)) : Fin r РіЋ Fin (m * r)))
      rw [blockMatrixFirstSplitFlat_22 A (i.pred hi) (j.pred hj) s t] at hentry
      simpa [Fin.succ_pred i hi, Fin.succ_pred j hj] using hentry

/-- The first-split scalar flattening has exactly the block max norm. -/
theorem maxEntryNorm_blockMatrixFirstSplitFlat_eq_blockMaxNorm {m r : РёЋ}
    (hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    maxEntryNorm (Nat.add_pos_left hr (m * r)) (blockMatrixFirstSplitFlat A) =
      blockMaxNorm (Nat.succ_pos m) hr A := by
  exact le_antisymm
    (maxEntryNorm_blockMatrixFirstSplitFlat_le_blockMaxNorm hm hr A)
    (blockMaxNorm_le_maxEntryNorm_blockMatrixFirstSplitFlat hm hr A)

/-- The first-split flattening and the uniform flat block matrix have the same
    Chapter 13 max-entry norm. -/
theorem maxEntryNorm_blockMatrixFirstSplitFlat_eq_blockMatrixFlatFin {m r : РёЋ}
    (hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) :
    maxEntryNorm (Nat.add_pos_left hr (m * r)) (blockMatrixFirstSplitFlat A) =
      maxEntryNorm (Nat.mul_pos (Nat.succ_pos m) hr) (blockMatrixFlatFin A) := by
  rw [maxEntryNorm_blockMatrixFirstSplitFlat_eq_blockMaxNorm hm hr A]
  rw [maxEntryNorm_blockMatrixFlatFin_eq_blockMaxNorm (Nat.succ_pos m) hr A]

/-- Reindex the first-split scalar ordering `Fin (r + m*r)` to the uniform
    block/product ordering `Fin (m+1) ├Ќ Fin r`. -/
noncomputable def blockMatrixFirstSplitToFlatProductEquiv {m r : РёЋ} :
    Fin (r + m * r) РЅЃ Fin (m + 1) ├Ќ Fin r where
  toFun p :=
    match finSumFinEquiv.symm p with
    | Sum.inl s => (0, s)
    | Sum.inr q =>
        let jq := finProdFinEquiv.symm q
        (Fin.succ jq.1, jq.2)
  invFun is :=
    if hi : is.1 = 0 then
      finSumFinEquiv (Sum.inl is.2 : Fin r РіЋ Fin (m * r))
    else
      finSumFinEquiv
        (Sum.inr (finProdFinEquiv (is.1.pred hi, is.2)) :
          Fin r РіЋ Fin (m * r))
  left_inv := by
    intro p
    cases hp : finSumFinEquiv.symm p with
    | inl s =>
        dsimp
        rw [hp]
        simp
        have hp' :
            finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r)) = p := by
          rw [Рєљ hp]
          exact finSumFinEquiv.apply_symm_apply p
        simpa using hp'
    | inr q =>
        dsimp
        rw [hp]
        simp
        have hq : finProdFinEquiv (q.divNat, q.modNat) = q := by
          exact finProdFinEquiv.apply_symm_apply q
        have hp' :
            finSumFinEquiv (Sum.inr q : Fin r РіЋ Fin (m * r)) = p := by
          rw [Рєљ hp]
          exact finSumFinEquiv.apply_symm_apply p
        simpa [hq] using hp'
  right_inv := by
    intro is
    rcases is with РЪеi, sРЪЕ
    by_cases hi : i = 0
    ┬и subst i
      dsimp
      simp
    ┬и have hsucc : Fin.succ (i.pred hi) = i := Fin.succ_pred i hi
      dsimp
      simp [hi]
      constructor
      ┬и have hpair :
            finProdFinEquiv.symm (finProdFinEquiv (i.pred hi, s)) =
              (i.pred hi, s) :=
          finProdFinEquiv.symm_apply_apply (i.pred hi, s)
        have hfst := congrArg Prod.fst hpair
        change (finProdFinEquiv (i.pred hi, s)).divNat = i.pred hi at hfst
        rw [hfst, hsucc]
      ┬и have hpair :
            finProdFinEquiv.symm (finProdFinEquiv (i.pred hi, s)) =
              (i.pred hi, s) :=
          finProdFinEquiv.symm_apply_apply (i.pred hi, s)
        have hsnd := congrArg Prod.snd hpair
        change (finProdFinEquiv (i.pred hi, s)).modNat = s at hsnd
        exact hsnd

/-- Reindex the first-split scalar ordering `Fin (r + m*r)` to the uniform
    flat ordering `Fin ((m+1)*r)`. -/
noncomputable def blockMatrixFirstSplitToFlatFinEquiv {m r : РёЋ} :
    Fin (r + m * r) РЅЃ Fin ((m + 1) * r) :=
  blockMatrixFirstSplitToFlatProductEquiv.trans finProdFinEquiv

@[simp] theorem blockMatrixFirstSplitToFlatFinEquiv_inl {m r : РёЋ}
    (s : Fin r) :
    (blockMatrixFirstSplitToFlatFinEquiv
        (finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r))) :
      Fin ((m + 1) * r)) =
      finProdFinEquiv ((0 : Fin (m + 1)), s) := by
  dsimp [blockMatrixFirstSplitToFlatFinEquiv, blockMatrixFirstSplitToFlatProductEquiv]
  simp

@[simp] theorem blockMatrixFirstSplitToFlatFinEquiv_inr {m r : РёЋ}
    (j : Fin m) (t : Fin r) :
    (blockMatrixFirstSplitToFlatFinEquiv
        (finSumFinEquiv
          (Sum.inr (finProdFinEquiv (j, t)) : Fin r РіЋ Fin (m * r))) :
      Fin ((m + 1) * r)) =
      finProdFinEquiv (Fin.succ j, t) := by
  dsimp [blockMatrixFirstSplitToFlatFinEquiv, blockMatrixFirstSplitToFlatProductEquiv]
  have hpair :
      finProdFinEquiv.symm (finProdFinEquiv (j, t)) = (j, t) :=
    finProdFinEquiv.symm_apply_apply (j, t)
  have hfst := congrArg Prod.fst hpair
  have hsnd := congrArg Prod.snd hpair
  change (finProdFinEquiv (j, t)).divNat = j at hfst
  change (finProdFinEquiv (j, t)).modNat = t at hsnd
  rw [finSumFinEquiv_symm_apply_natAdd]
  change finProdFinEquiv
      ((finProdFinEquiv (j, t)).divNat.succ,
        (finProdFinEquiv (j, t)).modNat) =
    finProdFinEquiv (Fin.succ j, t)
  rw [hfst, hsnd]

/-- The first-split flattening is the uniform flat block matrix reindexed by
    `blockMatrixFirstSplitToFlatFinEquiv`. -/
theorem blockMatrixFirstSplitFlat_eq_blockMatrixFlatFin_reindex {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ) :
    blockMatrixFirstSplitFlat A =
      fun p q : Fin (r + m * r) =>
        blockMatrixFlatFin A (blockMatrixFirstSplitToFlatFinEquiv p)
          (blockMatrixFirstSplitToFlatFinEquiv q) := by
  ext p q
  cases hp : finSumFinEquiv.symm p with
  | inl s =>
      cases hq : finSumFinEquiv.symm q with
      | inl t =>
          have hp' :
              p = finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hp]
            exact (finSumFinEquiv.apply_symm_apply p).symm
          have hq' :
              q = finSumFinEquiv (Sum.inl t : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hq]
            exact (finSumFinEquiv.apply_symm_apply q).symm
          rw [hp', hq']
          rw [blockMatrixFirstSplitFlat_11]
          rw [blockMatrixFirstSplitToFlatFinEquiv_inl,
            blockMatrixFirstSplitToFlatFinEquiv_inl]
          rw [blockMatrixFlatFin_apply]
      | inr qt =>
          let jt := finProdFinEquiv.symm qt
          have hp' :
              p = finSumFinEquiv (Sum.inl s : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hp]
            exact (finSumFinEquiv.apply_symm_apply p).symm
          have hq' :
              q = finSumFinEquiv (Sum.inr qt : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hq]
            exact (finSumFinEquiv.apply_symm_apply q).symm
          have hqt : finProdFinEquiv (jt.1, jt.2) = qt := by
            exact finProdFinEquiv.apply_symm_apply qt
          rw [hp', hq', Рєљ hqt]
          rw [blockMatrixFirstSplitFlat_12]
          rw [blockMatrixFirstSplitToFlatFinEquiv_inl,
            blockMatrixFirstSplitToFlatFinEquiv_inr]
          rw [blockMatrixFlatFin_apply]
  | inr ip =>
      let is := finProdFinEquiv.symm ip
      cases hq : finSumFinEquiv.symm q with
      | inl t =>
          have hip : finProdFinEquiv (is.1, is.2) = ip := by
            exact finProdFinEquiv.apply_symm_apply ip
          have hp' :
              p = finSumFinEquiv (Sum.inr ip : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hp]
            exact (finSumFinEquiv.apply_symm_apply p).symm
          have hq' :
              q = finSumFinEquiv (Sum.inl t : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hq]
            exact (finSumFinEquiv.apply_symm_apply q).symm
          rw [hp', hq', Рєљ hip]
          rw [blockMatrixFirstSplitFlat_21]
          rw [blockMatrixFirstSplitToFlatFinEquiv_inr,
            blockMatrixFirstSplitToFlatFinEquiv_inl]
          rw [blockMatrixFlatFin_apply]
      | inr qt =>
          let jt := finProdFinEquiv.symm qt
          have hip : finProdFinEquiv (is.1, is.2) = ip := by
            exact finProdFinEquiv.apply_symm_apply ip
          have hqt : finProdFinEquiv (jt.1, jt.2) = qt := by
            exact finProdFinEquiv.apply_symm_apply qt
          have hp' :
              p = finSumFinEquiv (Sum.inr ip : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hp]
            exact (finSumFinEquiv.apply_symm_apply p).symm
          have hq' :
              q = finSumFinEquiv (Sum.inr qt : Fin r РіЋ Fin (m * r)) := by
            rw [Рєљ hq]
            exact (finSumFinEquiv.apply_symm_apply q).symm
          rw [hp', hq', Рєљ hip, Рєљ hqt]
          rw [blockMatrixFirstSplitFlat_22]
          rw [blockMatrixFirstSplitToFlatFinEquiv_inr,
            blockMatrixFirstSplitToFlatFinEquiv_inr]
          rw [blockMatrixFlatFin_apply]

/-- First-split flattening preserves invertibility from the uniform flat
    block-matrix representation. -/
noncomputable def blockMatrixFirstSplitFlat_invertible_of_blockMatrixFlatFin
    {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (blockMatrixFlatFin A)] :
    Invertible (blockMatrixFirstSplitFlat A) := by
  classical
  let M : Matrix (Fin ((m + 1) * r)) (Fin ((m + 1) * r)) РёЮ :=
    blockMatrixFlatFin A
  let e : Fin (r + m * r) РЅЃ Fin ((m + 1) * r) :=
    blockMatrixFirstSplitToFlatFinEquiv
  letI : Invertible (M.submatrix e e) :=
    Matrix.submatrixEquivInvertible M e e
  rw [blockMatrixFirstSplitFlat_eq_blockMatrixFlatFin_reindex A]
  exact (inferInstance : Invertible (M.submatrix e e))

/-- The `Matrix.fromBlocks` view of a first-split block matrix preserves
    invertibility from the scalar first-split flattening. -/
noncomputable def blockMatrixFirstSplit_fromBlocks_invertible_of_blockMatrixFirstSplitFlat
    {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (blockMatrixFirstSplitFlat A)] :
    Invertible (Matrix.fromBlocks
      (blockMatrixFirstSplitA11 A)
      (blockMatrixFirstSplitA12 A)
      (blockMatrixFirstSplitA21 A)
      (blockMatrixFirstSplitA22 A)) := by
  classical
  let M : Matrix (Fin (r + m * r)) (Fin (r + m * r)) РёЮ :=
    blockMatrixFirstSplitFlat A
  let e : Fin r РіЋ Fin (m * r) РЅЃ Fin (r + m * r) := finSumFinEquiv
  letI : Invertible (M.submatrix e e) :=
    Matrix.submatrixEquivInvertible M e e
  suffices
      Matrix.fromBlocks
          (blockMatrixFirstSplitA11 A)
          (blockMatrixFirstSplitA12 A)
          (blockMatrixFirstSplitA21 A)
          (blockMatrixFirstSplitA22 A) =
        M.submatrix e e by
    simpa [this] using (inferInstance : Invertible (M.submatrix e e))
  ext i j
  cases i with
  | inl s =>
      cases j with
      | inl t =>
          simpa [M, e, Fin.castAdd, blockMatrixFirstSplitA11] using
            (blockMatrixFirstSplitFlat_11 A s t).symm
      | inr q =>
          let jq := finProdFinEquiv.symm q
          have hq : finProdFinEquiv jq = q := finProdFinEquiv.apply_symm_apply q
          rw [Рєљ hq]
          simpa [M, e, Fin.castAdd, Fin.natAdd, blockMatrixFirstSplitA12] using
            (blockMatrixFirstSplitFlat_12 A s jq.1 jq.2).symm
  | inr p =>
      cases j with
      | inl t =>
          let ip := finProdFinEquiv.symm p
          have hp : finProdFinEquiv ip = p := finProdFinEquiv.apply_symm_apply p
          rw [Рєљ hp]
          simpa [M, e, Fin.castAdd, Fin.natAdd, blockMatrixFirstSplitA21] using
            (blockMatrixFirstSplitFlat_21 A ip.1 ip.2 t).symm
      | inr q =>
          let ip := finProdFinEquiv.symm p
          let jq := finProdFinEquiv.symm q
          have hp : finProdFinEquiv ip = p := finProdFinEquiv.apply_symm_apply p
          have hq : finProdFinEquiv jq = q := finProdFinEquiv.apply_symm_apply q
          rw [Рєљ hp, Рєљ hq]
          change
            blockMatrixFirstSplitA22 A (finProdFinEquiv ip) (finProdFinEquiv jq) =
              blockMatrixFirstSplitFlat A
                (finSumFinEquiv
                  (Sum.inr (finProdFinEquiv ip) : Fin r РіЋ Fin (m * r)))
                (finSumFinEquiv
                  (Sum.inr (finProdFinEquiv jq) : Fin r РіЋ Fin (m * r)))
          rw [blockMatrixFirstSplitA22, blockMatrixFlatFin_apply]
          exact (blockMatrixFirstSplitFlat_22 A ip.1 jq.1 ip.2 jq.2).symm

/-- The `Matrix.fromBlocks` view of a first-split block matrix preserves
    invertibility from the uniform flat block-matrix representation. -/
noncomputable def blockMatrixFirstSplit_fromBlocks_invertible_of_blockMatrixFlatFin
    {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (blockMatrixFlatFin A)] :
    Invertible (Matrix.fromBlocks
      (blockMatrixFirstSplitA11 A)
      (blockMatrixFirstSplitA12 A)
      (blockMatrixFirstSplitA21 A)
      (blockMatrixFirstSplitA22 A)) := by
  classical
  letI : Invertible (blockMatrixFirstSplitFlat A) :=
    blockMatrixFirstSplitFlat_invertible_of_blockMatrixFlatFin A
  exact blockMatrixFirstSplit_fromBlocks_invertible_of_blockMatrixFirstSplitFlat A

/-- The first-split inverse has max-entry norm bounded by the uniform-flat
    canonical inverse of the same block matrix. -/
theorem maxEntryNormRect_nonsingInv_blockMatrixFirstSplitFlat_le_blockMatrixFlatFin
    {m r : РёЋ} (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (blockMatrixFirstSplitFlat A)] :
    maxEntryNormRect (Nat.add_pos_left hr (m * r)) (Nat.add_pos_left hr (m * r))
        (nonsingInv (r + m * r) (blockMatrixFirstSplitFlat A)) РЅц
      maxEntryNormRect (Nat.mul_pos (Nat.succ_pos m) hr)
        (Nat.mul_pos (Nat.succ_pos m) hr)
        (nonsingInv ((m + 1) * r) (blockMatrixFlatFin A)) := by
  apply maxEntryNormRect_le_of_entry_abs_le
  intro i j
  have hEqInv :
      nonsingInv (r + m * r) (blockMatrixFirstSplitFlat A) =
        fun i j : Fin (r + m * r) =>
          (РЁЪ(blockMatrixFirstSplitFlat A :
            Matrix (Fin (r + m * r)) (Fin (r + m * r)) РёЮ)) i j := by
    exact
      nonsingInv_eq_of_isRightInverse
        (blockMatrixFirstSplitFlat A)
        (fun i j : Fin (r + m * r) =>
          (РЁЪ(blockMatrixFirstSplitFlat A :
            Matrix (Fin (r + m * r)) (Fin (r + m * r)) РёЮ)) i j)
        (isRightInverse_of_eq_invOf
          (blockMatrixFirstSplitFlat A)
          (РЁЪ(blockMatrixFirstSplitFlat A :
            Matrix (Fin (r + m * r)) (Fin (r + m * r)) РёЮ))
          rfl)
  rw [hEqInv]
  exact
    maxEntryNormRect_invOf_reindex_equiv_nonsingInv_entry_bound
      (Nat.mul_pos (Nat.succ_pos m) hr)
      (blockMatrixFirstSplitToFlatFinEquiv : Fin (r + m * r) РЅЃ Fin ((m + 1) * r))
      (blockMatrixFlatFin A)
      (blockMatrixFirstSplitFlat A)
      (blockMatrixFirstSplitFlat_eq_blockMatrixFlatFin_reindex A)
      i j

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    parent first-split inverse entries are bounded by the canonical ambient
    `nonsingInv` max-entry norm.

    This packages the reindexing bridge between the displayed first-split
    `Matrix.fromBlocks` inverse and the flat source matrix used by the
    Eq.13.22/Eq.13.23 exact-`╬║(A)` denominators. -/
theorem higham13_problem13_4_firstSplit_parent_inverse_entry_bound_from_nonsingInv
    {m r : РёЋ} (hN : 0 < r + (m + 1) * r)
    (Ablk : Fin ((m + 1) + 1) Рєњ Fin ((m + 1) + 1) Рєњ
      Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (Matrix.fromBlocks
      (blockMatrixFirstSplitA11 Ablk)
      (blockMatrixFirstSplitA12 Ablk)
      (blockMatrixFirstSplitA21 Ablk)
      (blockMatrixFirstSplitA22 Ablk))] :
    Рѕђ i j : Fin r РіЋ Fin ((m + 1) * r),
      |(РЁЪ(Matrix.fromBlocks
          (blockMatrixFirstSplitA11 Ablk)
          (blockMatrixFirstSplitA12 Ablk)
          (blockMatrixFirstSplitA21 Ablk)
          (blockMatrixFirstSplitA22 Ablk)) :
        Matrix (Fin r РіЋ Fin ((m + 1) * r))
          (Fin r РіЋ Fin ((m + 1) * r)) РёЮ) i j| РЅц
        maxEntryNormRect hN hN
          (nonsingInv (r + (m + 1) * r) (blockMatrixFirstSplitFlat Ablk)) := by
  classical
  let A0 : Fin (r + (m + 1) * r) Рєњ Fin (r + (m + 1) * r) Рєњ РёЮ :=
    blockMatrixFirstSplitFlat Ablk
  have hFull_eq :
      Matrix.fromBlocks
          (blockMatrixFirstSplitA11 Ablk)
          (blockMatrixFirstSplitA12 Ablk)
          (blockMatrixFirstSplitA21 Ablk)
          (blockMatrixFirstSplitA22 Ablk) =
        (fun i j : Fin r РіЋ Fin ((m + 1) * r) =>
          A0 (finSumFinEquiv i) (finSumFinEquiv j)) := by
    ext i j
    cases i with
    | inl i =>
        cases j with
        | inl j =>
            simp [A0, blockMatrixFirstSplitA11, blockMatrixFirstSplitFlat]
        | inr j =>
            simp [A0, blockMatrixFirstSplitA12, blockMatrixFirstSplitFlat]
    | inr i =>
        cases j with
        | inl j =>
            simp [A0, blockMatrixFirstSplitA21, blockMatrixFirstSplitFlat]
        | inr j =>
            simp [A0, blockMatrixFirstSplitA22, blockMatrixFirstSplitFlat,
              blockMatrixFlatFin]
  simpa [A0] using
    (maxEntryNormRect_invOf_reindex_equiv_nonsingInv_entry_bound
      hN
      (finSumFinEquiv :
        (Fin r РіЋ Fin ((m + 1) * r)) РЅЃ Fin (r + (m + 1) * r))
      A0
      (Matrix.fromBlocks
        (blockMatrixFirstSplitA11 Ablk)
        (blockMatrixFirstSplitA12 Ablk)
        (blockMatrixFirstSplitA21 Ablk)
        (blockMatrixFirstSplitA22 Ablk))
      hFull_eq)

/-- The exact max-entry condition product for the first-split scalar matrix is
    bounded by the same product for the uniform flat representation. -/
theorem maxEntryNormRect_kappa_blockMatrixFirstSplitFlat_le_blockMatrixFlatFin
    {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (blockMatrixFirstSplitFlat A)] :
    maxEntryNormRect (Nat.add_pos_left hr (m * r)) (Nat.add_pos_left hr (m * r))
        (blockMatrixFirstSplitFlat A) *
      maxEntryNormRect (Nat.add_pos_left hr (m * r)) (Nat.add_pos_left hr (m * r))
        (nonsingInv (r + m * r) (blockMatrixFirstSplitFlat A)) РЅц
    maxEntryNormRect (Nat.mul_pos (Nat.succ_pos m) hr)
        (Nat.mul_pos (Nat.succ_pos m) hr) (blockMatrixFlatFin A) *
      maxEntryNormRect (Nat.mul_pos (Nat.succ_pos m) hr)
        (Nat.mul_pos (Nat.succ_pos m) hr)
        (nonsingInv ((m + 1) * r) (blockMatrixFlatFin A)) := by
  let hSplit : 0 < r + m * r := Nat.add_pos_left hr (m * r)
  let hFlat : 0 < (m + 1) * r := Nat.mul_pos (Nat.succ_pos m) hr
  have hAeq :
      maxEntryNormRect hSplit hSplit (blockMatrixFirstSplitFlat A) =
        maxEntryNormRect hFlat hFlat (blockMatrixFlatFin A) := by
    rw [maxEntryNormRect_eq_maxEntryNorm hSplit]
    rw [maxEntryNormRect_eq_maxEntryNorm hFlat]
    exact maxEntryNorm_blockMatrixFirstSplitFlat_eq_blockMatrixFlatFin hm hr A
  have hInv :=
    maxEntryNormRect_nonsingInv_blockMatrixFirstSplitFlat_le_blockMatrixFlatFin
      hr A
  have hFlatNonneg :
      0 РЅц maxEntryNormRect hFlat hFlat (blockMatrixFlatFin A) :=
    maxEntryNormRect_nonneg hFlat hFlat (blockMatrixFlatFin A)
  calc
    maxEntryNormRect hSplit hSplit (blockMatrixFirstSplitFlat A) *
        maxEntryNormRect hSplit hSplit
          (nonsingInv (r + m * r) (blockMatrixFirstSplitFlat A))
        =
      maxEntryNormRect hFlat hFlat (blockMatrixFlatFin A) *
        maxEntryNormRect hSplit hSplit
          (nonsingInv (r + m * r) (blockMatrixFirstSplitFlat A)) := by
        rw [hAeq]
    _ РЅц maxEntryNormRect hFlat hFlat (blockMatrixFlatFin A) *
        maxEntryNormRect hFlat hFlat
          (nonsingInv ((m + 1) * r) (blockMatrixFlatFin A)) := by
        exact mul_le_mul_of_nonneg_left hInv hFlatNonneg

/-- Determinant-nonzero variant of the first-split/uniform-flat exact
    condition-product bridge. -/
theorem
    maxEntryNormRect_kappa_blockMatrixFirstSplitFlat_le_blockMatrixFlatFin_of_det_ne_zero
    {m r : РёЋ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (hdet :
      Matrix.det (blockMatrixFirstSplitFlat A :
        Matrix (Fin (r + m * r)) (Fin (r + m * r)) РёЮ) РЅа 0) :
    maxEntryNormRect (Nat.add_pos_left hr (m * r)) (Nat.add_pos_left hr (m * r))
        (blockMatrixFirstSplitFlat A) *
      maxEntryNormRect (Nat.add_pos_left hr (m * r)) (Nat.add_pos_left hr (m * r))
        (nonsingInv (r + m * r) (blockMatrixFirstSplitFlat A)) РЅц
    maxEntryNormRect (Nat.mul_pos (Nat.succ_pos m) hr)
        (Nat.mul_pos (Nat.succ_pos m) hr) (blockMatrixFlatFin A) *
      maxEntryNormRect (Nat.mul_pos (Nat.succ_pos m) hr)
        (Nat.mul_pos (Nat.succ_pos m) hr)
        (nonsingInv ((m + 1) * r) (blockMatrixFlatFin A)) := by
  let M : Matrix (Fin (r + m * r)) (Fin (r + m * r)) РёЮ :=
    blockMatrixFirstSplitFlat A
  letI : Invertible M :=
    Matrix.invertibleOfIsUnitDet (A := M) (isUnit_iff_ne_zero.mpr hdet)
  simpa [M] using
    maxEntryNormRect_kappa_blockMatrixFirstSplitFlat_le_blockMatrixFlatFin
      hm hr A

/-- Higham, 2nd ed., Chapter 13, SPD/block-LU existence dependency:
    a two-sided inverse for the flattened block matrix gives the chapter's
    explicit block-matrix nonsingularity predicate.

    This theorem is only a representation bridge; determinant or SPD facts
    still have to supply the flattened inverse or nonsingularity premise. -/
theorem blockMatrixNonsingular_of_flat_inverse {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (AinvFlat : Matrix (Fin m ├Ќ Fin r) (Fin m ├Ќ Fin r) РёЮ)
    (hLeft : AinvFlat * blockMatrixFlat A = 1)
    (hRight : blockMatrixFlat A * AinvFlat = 1) :
    BlockMatrixNonsingular A := by
  let Ainv : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ) :=
    fun i j s t => AinvFlat (i, s) (j, t)
  refine РЪеAinv, ?_, ?_РЪЕ
  ┬и intro i j s t
    have h := congr_fun (congr_fun hLeft (i, s)) (j, t)
    have hId :
        blockMatrixIdentity m r i j s t =
          if (i, s) = (j, t) then 1 else 0 := by
      by_cases hij : i = j <;> by_cases hst : s = t <;>
        simp [blockMatrixIdentity, idBlock, zeroBlock, hij, hst, Prod.ext_iff]
    simpa [Ainv, blockMatrixFlat, Matrix.mul_apply, Fintype.sum_prod_type,
      Matrix.one_apply, hId] using h
  ┬и intro i j s t
    have h := congr_fun (congr_fun hRight (i, s)) (j, t)
    have hId :
        blockMatrixIdentity m r i j s t =
          if (i, s) = (j, t) then 1 else 0 := by
      by_cases hij : i = j <;> by_cases hst : s = t <;>
        simp [blockMatrixIdentity, idBlock, zeroBlock, hij, hst, Prod.ext_iff]
    simpa [Ainv, blockMatrixFlat, Matrix.mul_apply, Fintype.sum_prod_type,
      Matrix.one_apply, hId] using h

/-- Higham, 2nd ed., Chapter 13, SPD/block-LU existence dependency:
    determinant nonsingularity of the flattened block matrix gives the
    chapter's block-matrix nonsingularity predicate. -/
theorem blockMatrixNonsingular_of_isUnit_det_flat {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hdet : IsUnit (Matrix.det (blockMatrixFlat A))) :
    BlockMatrixNonsingular A := by
  exact blockMatrixNonsingular_of_flat_inverse A (blockMatrixFlat A)РЂ╗┬╣
    (Matrix.nonsing_inv_mul (blockMatrixFlat A) hdet)
    (Matrix.mul_nonsing_inv (blockMatrixFlat A) hdet)

/-- Higham, 2nd ed., Chapter 13, SPD/block-LU existence dependency:
    nonzero determinant of the flattened block matrix gives block-matrix
    nonsingularity over `РёЮ`. -/
theorem blockMatrixNonsingular_of_det_ne_zero_flat {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hdet : Matrix.det (blockMatrixFlat A) РЅа 0) :
    BlockMatrixNonsingular A :=
  blockMatrixNonsingular_of_isUnit_det_flat A (isUnit_iff_ne_zero.mpr hdet)

/-- A block matrix with an explicit two-sided block inverse has nonzero
    determinant after flattening.  This is the converse determinant bridge to
    `blockMatrixNonsingular_of_det_ne_zero_flat`. -/
theorem blockMatrixFlat_det_ne_zero_of_blockMatrixNonsingular {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hA : BlockMatrixNonsingular A) :
    Matrix.det (blockMatrixFlat A) РЅа 0 := by
  classical
  rcases hA with РЪеAinv, _hLeft, hRightРЪЕ
  let AinvFlat : Matrix (Fin m ├Ќ Fin r) (Fin m ├Ќ Fin r) РёЮ :=
    fun p q => Ainv p.1 q.1 p.2 q.2
  have hRightFlat : blockMatrixFlat A * AinvFlat = 1 := by
    ext p q
    rcases p with РЪеi, sРЪЕ
    rcases q with РЪеj, tРЪЕ
    have h := hRight i j s t
    have hId :
        blockMatrixIdentity m r i j s t =
          if (i, s) = (j, t) then 1 else 0 := by
      by_cases hij : i = j <;> by_cases hst : s = t <;>
        simp [blockMatrixIdentity, idBlock, zeroBlock, hij, hst, Prod.ext_iff]
    simpa [AinvFlat, blockMatrixFlat, Matrix.mul_apply, Fintype.sum_prod_type,
      Matrix.one_apply, hId] using h
  exact Matrix.det_ne_zero_of_right_inverse hRightFlat

/-- A block-nonsingular matrix has nonzero determinant after uniform
    `Fin (m*r)` flattening. -/
theorem det_ne_zero_blockMatrixFlatFin_of_blockMatrixNonsingular {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hA : BlockMatrixNonsingular A) :
    Matrix.det (blockMatrixFlatFin A :
      Matrix (Fin (m * r)) (Fin (m * r)) РёЮ) РЅа 0 := by
  rw [Рєљ det_blockMatrixFlat_eq_blockMatrixFlatFin A]
  exact blockMatrixFlat_det_ne_zero_of_blockMatrixNonsingular A hA

/-- Higham, 2nd ed., Chapter 13, Theorem 13.7 proof step:
    if one block column has zero off-diagonal blocks and the diagonal block has
    a nonzero right-kernel vector, then the flattened block matrix is singular.

    This formalizes the vector-kernel part of the source sentence following
    (13.18): after BDD forces the off-diagonal column norms to vanish, a
    singular active diagonal block makes the whole Schur complement singular. -/
theorem higham13_blockMatrixFlat_det_eq_zero_of_offdiag_col_zero_of_diag_kernel
    {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ Fin r Рєњ Fin r Рєњ РёЮ)
    (j : Fin m) (x : Fin r Рєњ РёЮ) (s0 : Fin r) (hx : x s0 РЅа 0)
    (hdiag : Рѕђ s : Fin r, РѕЉ t : Fin r, A j j s t * x t = 0)
    (hoff : Рѕђ i : Fin m, i РЅа j Рєњ Рѕђ s t : Fin r, A i j s t = 0) :
    Matrix.det (blockMatrixFlat A) = 0 := by
  classical
  let v : Fin m ├Ќ Fin r Рєњ РёЮ := fun q => if q.1 = j then x q.2 else 0
  have hmul : (blockMatrixFlat A).mulVec v = 0 := by
    ext p
    rcases p with РЪеi, sРЪЕ
    have hsum_eq :
        (РѕЉ q : Fin m ├Ќ Fin r, A i q.1 s q.2 * v q) =
          РѕЉ t : Fin r, A i j s t * x t := by
      rw [Fintype.sum_prod_type]
      simp [v]
    rw [Matrix.mulVec, dotProduct]
    change (РѕЉ q : Fin m ├Ќ Fin r, A i q.1 s q.2 * v q) = 0
    rw [hsum_eq]
    by_cases hij : i = j
    ┬и subst i
      exact hdiag s
    ┬и simp [hoff i hij]
  have hvne : v РЅа 0 := by
    intro hv
    have hvcoord := congr_fun hv (j, s0)
    simp [v] at hvcoord
    exact hx hvcoord
  exact (Matrix.exists_mulVec_eq_zero_iff).mp РЪеv, hvne, hmulРЪЕ

/-- Higham, 2nd ed., Chapter 13, Theorem 13.7 proof step:
    the zero-off-column/right-kernel situation contradicts the chapter's
    explicit block-nonsingularity predicate. -/
theorem higham13_not_blockMatrixNonsingular_of_offdiag_col_zero_of_diag_kernel
    {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ Fin r Рєњ Fin r Рєњ РёЮ)
    (j : Fin m) (x : Fin r Рєњ РёЮ) (s0 : Fin r) (hx : x s0 РЅа 0)
    (hdiag : Рѕђ s : Fin r, РѕЉ t : Fin r, A j j s t * x t = 0)
    (hoff : Рѕђ i : Fin m, i РЅа j Рєњ Рѕђ s t : Fin r, A i j s t = 0) :
    ┬г BlockMatrixNonsingular A := by
  intro hA
  exact
    (blockMatrixFlat_det_ne_zero_of_blockMatrixNonsingular A hA)
      (higham13_blockMatrixFlat_det_eq_zero_of_offdiag_col_zero_of_diag_kernel
        A j x s0 hx hdiag hoff)

/-- A nonzero finite vector has a nonzero coordinate.  This small adapter keeps
    the Theorem 13.7 diagonal-kernel extraction explicit. -/
theorem higham13_exists_nonzero_coord_of_vec_ne_zero {r : РёЋ} {x : Fin r Рєњ РёЮ}
    (hx : x РЅа 0) :
    РѕЃ s0 : Fin r, x s0 РЅа 0 := by
  classical
  by_contra h
  apply hx
  funext s
  by_contra hs
  exact h РЪеs, hsРЪЕ

/-- Higham, 2nd ed., Chapter 13, Theorem 13.7 proof dependency:
    a singular diagonal block has a nonzero right-kernel vector with an
    explicitly nonzero coordinate. -/
theorem higham13_exists_diag_kernel_coord_of_det_eq_zero {r : РёЋ}
    (B : Fin r Рєњ Fin r Рєњ РёЮ)
    (hdet : Matrix.det B = 0) :
    РѕЃ (x : Fin r Рєњ РёЮ) (s0 : Fin r),
      x s0 РЅа 0 РѕД Рѕђ s : Fin r, РѕЉ t : Fin r, B s t * x t = 0 := by
  classical
  obtain РЪеx, hxne, hmulРЪЕ :=
    (Matrix.exists_mulVec_eq_zero_iff (M := B)).mpr hdet
  obtain РЪеs0, hs0РЪЕ := higham13_exists_nonzero_coord_of_vec_ne_zero hxne
  refine РЪеx, s0, hs0, ?_РЪЕ
  intro s
  have hs := congr_fun hmul s
  simpa [Matrix.mulVec, dotProduct] using hs

/-- Higham, 2nd ed., Chapter 13, Theorem 13.7 proof step:
    if one block column has zero off-diagonal blocks and the diagonal block is
    singular, then the flattened block matrix is singular. -/
theorem higham13_blockMatrixFlat_det_eq_zero_of_offdiag_col_zero_of_diag_det_eq_zero
    {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ Fin r Рєњ Fin r Рєњ РёЮ)
    (j : Fin m)
    (hdiagdet : Matrix.det (A j j) = 0)
    (hoff : Рѕђ i : Fin m, i РЅа j Рєњ Рѕђ s t : Fin r, A i j s t = 0) :
    Matrix.det (blockMatrixFlat A) = 0 := by
  obtain РЪеx, s0, hx, hdiagРЪЕ :=
    higham13_exists_diag_kernel_coord_of_det_eq_zero (A j j) hdiagdet
  exact
    higham13_blockMatrixFlat_det_eq_zero_of_offdiag_col_zero_of_diag_kernel
      A j x s0 hx hdiag hoff

/-- Higham, 2nd ed., Chapter 13, Theorem 13.7 proof step:
    the zero-off-column/singular-diagonal-block situation contradicts the
    chapter's explicit block-nonsingularity predicate. -/
theorem higham13_not_blockMatrixNonsingular_of_offdiag_col_zero_of_diag_det_eq_zero
    {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ Fin r Рєњ Fin r Рєњ РёЮ)
    (j : Fin m)
    (hdiagdet : Matrix.det (A j j) = 0)
    (hoff : Рѕђ i : Fin m, i РЅа j Рєњ Рѕђ s t : Fin r, A i j s t = 0) :
    ┬г BlockMatrixNonsingular A := by
  intro hA
  exact
    (blockMatrixFlat_det_ne_zero_of_blockMatrixNonsingular A hA)
      (higham13_blockMatrixFlat_det_eq_zero_of_offdiag_col_zero_of_diag_det_eq_zero
        A j hdiagdet hoff)

/-- Higham, 2nd ed., Chapter 13, ┬Д13.3.2:
    positive definiteness of the flattened block matrix gives block-matrix
    nonsingularity.  This is the determinant bridge needed on the route from
    SPD leading principal submatrices to the Theorem 13.2 block-LU existence
    condition. -/
theorem blockMatrixNonsingular_of_posDef_flat {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hPos : Matrix.PosDef (blockMatrixFlat A)) :
    BlockMatrixNonsingular A := by
  exact blockMatrixNonsingular_of_det_ne_zero_flat A
    (ne_of_gt (Matrix.PosDef.det_pos hPos))

/-- A positive-definite matrix remains positive definite after taking an
    injective principal submatrix.  This local wrapper exposes the exact
    submatrix fact needed for Chapter 13 leading block prefixes. -/
theorem matrix_posDef_submatrix_of_injective {╬╣ ╬║ : Type*} [Fintype ╬╣] [Fintype ╬║]
    {M : Matrix ╬╣ ╬╣ РёЮ}
    (hM : Matrix.PosDef M) (e : ╬║ Рєњ ╬╣) (he : Function.Injective e) :
    Matrix.PosDef (M.submatrix e e) := by
  refine РЪеhM.1.submatrix e, fun x hx => ?_РЪЕ
  have hxmap : Finsupp.mapDomain e x РЅа 0 := by
    intro hzero
    apply hx
    have hz :
        Finsupp.mapDomain e x =
          Finsupp.mapDomain e (0 : ╬║ РєњРѓђ РёЮ) := by
      simpa [Finsupp.mapDomain_zero] using hzero
    exact Finsupp.mapDomain_injective he hz
  simpa [Finsupp.sum_mapDomain_index, add_mul, mul_add] using hM.2 hxmap

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2:
    the leading `(p+1) ├Ќ (p+1)` principal block submatrix of a uniform block
    matrix.  Lean's `p = 0` corresponds to the source's first leading block. -/
noncomputable def leadingBlockPrefix13_2 {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (p : РёЋ) (hp : p < m) :
    Fin (p + 1) Рєњ Fin (p + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ) :=
  fun i j =>
    A РЪеi.val, by
        have hi : i.val < p + 1 := i.isLt
        omegaРЪЕ
      РЪеj.val, by
        have hj : j.val < p + 1 := j.isLt
        omegaРЪЕ

/-- The flattened leading block prefix is the principal submatrix of the
    flattened full block matrix on the first block indices. -/
theorem blockMatrixFlat_leadingBlockPrefix13_2 {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (p : РёЋ) (hp : p < m) :
    blockMatrixFlat (leadingBlockPrefix13_2 A p hp) =
      (blockMatrixFlat A).submatrix
        (fun is : Fin (p + 1) ├Ќ Fin r =>
          (РЪеis.1.val, by
              have hi : is.1.val < p + 1 := is.1.isLt
              omegaРЪЕ, is.2))
        (fun is : Fin (p + 1) ├Ќ Fin r =>
          (РЪеis.1.val, by
              have hi : is.1.val < p + 1 := is.1.isLt
              omegaРЪЕ, is.2)) := by
  ext is jt
  rcases is with РЪеi, sРЪЕ
  rcases jt with РЪеj, tРЪЕ
  simp [blockMatrixFlat, leadingBlockPrefix13_2]

/-- The all-leading-prefix nonsingularity table contains the full matrix when
    the block dimension is positive. -/
theorem higham13_blockMatrixNonsingular_of_all_leadingBlockPrefixes {m r : РёЋ}
    (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hPrefix : Рѕђ p : РёЋ, Рѕђ hp : p < m,
      BlockMatrixNonsingular (leadingBlockPrefix13_2 A p hp)) :
    BlockMatrixNonsingular A := by
  cases m with
  | zero =>
      exact False.elim ((Nat.lt_irrefl 0) hm)
  | succ m =>
      simpa [leadingBlockPrefix13_2] using hPrefix m (Nat.lt_succ_self m)

/-- Determinant form of the full-matrix certificate contained in an
    all-leading-prefix nonsingularity table, stated for the uniform
    `Fin (m*r)` flattening used by the Chapter 13 growth-factor API. -/
theorem higham13_blockMatrixFlatFin_det_ne_zero_of_all_leadingBlockPrefixes
    {m r : РёЋ} (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hPrefix : Рѕђ p : РёЋ, Рѕђ hp : p < m,
      BlockMatrixNonsingular (leadingBlockPrefix13_2 A p hp)) :
    Matrix.det (blockMatrixFlatFin A :
      Matrix (Fin (m * r)) (Fin (m * r)) РёЮ) РЅа 0 := by
  exact
    det_ne_zero_blockMatrixFlatFin_of_blockMatrixNonsingular A
      (higham13_blockMatrixNonsingular_of_all_leadingBlockPrefixes
        hm A hPrefix)

/-- Higham, 2nd ed., Chapter 13, ┬Д13.3.2:
    if the flattened full block matrix is positive definite, then every leading
    block prefix is positive definite after flattening. -/
theorem leadingBlockPrefix13_2_posDef_flat_of_posDef_flat {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (p : РёЋ) (hp : p < m)
    (hPos : Matrix.PosDef (blockMatrixFlat A)) :
    Matrix.PosDef (blockMatrixFlat (leadingBlockPrefix13_2 A p hp)) := by
  rw [blockMatrixFlat_leadingBlockPrefix13_2 A p hp]
  exact matrix_posDef_submatrix_of_injective hPos
    (fun is : Fin (p + 1) ├Ќ Fin r =>
      (РЪеis.1.val, by
          have hi : is.1.val < p + 1 := is.1.isLt
          omegaРЪЕ, is.2))
    (by
      intro x y hxy
      apply Prod.ext
      ┬и apply Fin.ext
        exact congrArg (fun z : Fin m ├Ќ Fin r => z.1.val) hxy
      ┬и exact congrArg (fun z : Fin m ├Ќ Fin r => z.2) hxy)

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2:
    the source condition that the first `m-1` leading principal block
    submatrices are nonsingular.  For a matrix with `m` block rows/columns, this
    asks for nonsingularity of prefixes of block sizes `1, ..., m-1`. -/
def LeadingPrincipalBlockNonsingular13_2 {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)) : Prop :=
  Рѕђ p : РёЋ, (hp : p + 1 < m) Рєњ
    BlockMatrixNonsingular
      (leadingBlockPrefix13_2 A p (Nat.lt_trans (Nat.lt_succ_self p) hp))

/-- Higham, 2nd ed., Chapter 13, ┬Д13.3.2:
    positive definiteness of the flattened block matrix supplies the
    leading-principal-block nonsingularity condition used by Theorem 13.2.

    This proves the source prose "SPD matrices have block LU because all
    leading principal submatrices are nonsingular" at the repository's uniform
    block-matrix model level. -/
theorem LeadingPrincipalBlockNonsingular13_2.of_posDef_flat {m r : РёЋ}
    (A : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hPos : Matrix.PosDef (blockMatrixFlat A)) :
    LeadingPrincipalBlockNonsingular13_2 A := by
  intro p hp
  exact blockMatrixNonsingular_of_posDef_flat
    (leadingBlockPrefix13_2 A p (Nat.lt_trans (Nat.lt_succ_self p) hp))
    (leadingBlockPrefix13_2_posDef_flat_of_posDef_flat A p
      (Nat.lt_trans (Nat.lt_succ_self p) hp) hPos)

private lemma sum_fin_prefix_eq_of_tail_zero {q m : РёЋ}
    (hqm : q РЅц m) (f : Fin m Рєњ РёЮ)
    (hzero : Рѕђ k : Fin m, q РЅц k.val Рєњ f k = 0) :
    РѕЉ k : Fin q, f (Fin.castLE hqm k) = РѕЉ k : Fin m, f k := by
  let g : РёЋ Рєњ РёЮ := fun n => if hn : n < m then f РЪеn, hnРЪЕ else 0
  have hleft :
      (РѕЉ k : Fin q, f (Fin.castLE hqm k)) =
        РѕЉ n Рѕѕ Finset.range q, g n := by
    calc
      (РѕЉ k : Fin q, f (Fin.castLE hqm k)) = РѕЉ k : Fin q, g k.val := by
        apply Finset.sum_congr rfl
        intro k _hk
        have hkm : k.val < m := Nat.lt_of_lt_of_le k.isLt hqm
        have hk_eq : Fin.castLE hqm k = (РЪеk.val, hkmРЪЕ : Fin m) := Fin.ext rfl
        simp [g, hkm, hk_eq]
      _ = РѕЉ n Рѕѕ Finset.range q, g n := Fin.sum_univ_eq_sum_range g q
  have hright :
      (РѕЉ k : Fin m, f k) = РѕЉ n Рѕѕ Finset.range m, g n := by
    calc
      (РѕЉ k : Fin m, f k) = РѕЉ k : Fin m, g k.val := by
        apply Finset.sum_congr rfl
        intro k _hk
        simp [g, k.isLt]
      _ = РѕЉ n Рѕѕ Finset.range m, g n := Fin.sum_univ_eq_sum_range g m
  have hsubset : Finset.range q Ріє Finset.range m := by
    intro n hn
    exact Finset.mem_range.mpr (Nat.lt_of_lt_of_le (Finset.mem_range.mp hn) hqm)
  have hsum_subset :
      РѕЉ n Рѕѕ Finset.range q, g n = РѕЉ n Рѕѕ Finset.range m, g n := by
    apply Finset.sum_subset hsubset
    intro n hn_m hn_not_q
    have hnm : n < m := Finset.mem_range.mp hn_m
    have hqn : q РЅц n := Nat.le_of_not_gt (by
      intro hnq
      exact hn_not_q (Finset.mem_range.mpr hnq))
    simp [g, hnm, hzero РЪеn, hnmРЪЕ hqn]
  rw [hleft, hright]
  exact hsum_subset

private lemma leadingBlockPrefix13_2_apply_castLE {m r : РёЋ}
    {B : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    {p : РёЋ} (hp : p < m) (hle : p + 1 РЅц m)
    (i j : Fin (p + 1)) :
    leadingBlockPrefix13_2 B p hp i j =
      B (Fin.castLE hle i) (Fin.castLE hle j) := by
  unfold leadingBlockPrefix13_2
  congr

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 converse-side dependency:
    any block LU factorization restricts to a block LU factorization of each
    leading principal block prefix.

    This is the structural bridge needed before uniqueness of a full
    factorization can be pushed down to the leading submatrices appearing in
    the theorem. -/
theorem BlockLUFactSpec.of_leadingBlockPrefix13_2 {m r : РёЋ}
    {A L U : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    (hLU : BlockLUFactSpec m r A L U)
    (p : РёЋ) (hp : p < m) :
    BlockLUFactSpec (p + 1) r
      (leadingBlockPrefix13_2 A p hp)
      (leadingBlockPrefix13_2 L p hp)
      (leadingBlockPrefix13_2 U p hp) := by
  let hle : p + 1 РЅц m := Nat.succ_le_of_lt hp
  refine РЪе?_, ?_, ?_, ?_РЪЕ
  ┬и intro i
    simpa [leadingBlockPrefix13_2] using hLU.L_diag (Fin.castLE hle i)
  ┬и intro i j hij
    exact hLU.L_upper_zero (Fin.castLE hle i) (Fin.castLE hle j) (by simpa using hij)
  ┬и intro i j hij
    exact hLU.U_lower_zero (Fin.castLE hle i) (Fin.castLE hle j) (by simpa using hij)
  ┬и intro i j s t
    let term : Fin m Рєњ РёЮ := fun k =>
      РѕЉ l : Fin r, L (Fin.castLE hle i) k s l * U k (Fin.castLE hle j) l t
    have htail_zero : Рѕђ k : Fin m, p + 1 РЅц k.val Рєњ term k = 0 := by
      intro k hk
      have hlt : (Fin.castLE hle i).val < k.val := by
        exact Nat.lt_of_lt_of_le i.isLt hk
      have hLzero : L (Fin.castLE hle i) k = zeroBlock r :=
        hLU.L_upper_zero (Fin.castLE hle i) k hlt
      simp [term, hLzero, zeroBlock]
    have hsum :
        РѕЉ k : Fin (p + 1), term (Fin.castLE hle k) =
          РѕЉ k : Fin m, term k :=
      sum_fin_prefix_eq_of_tail_zero hle term htail_zero
    have hprod :
        РѕЉ k : Fin m, term k =
          A (Fin.castLE hle i) (Fin.castLE hle j) s t := by
      simpa [term] using hLU.product_eq (Fin.castLE hle i) (Fin.castLE hle j) s t
    calc
      РѕЉ k : Fin (p + 1),
          РѕЉ l : Fin r,
            leadingBlockPrefix13_2 L p hp i k s l *
              leadingBlockPrefix13_2 U p hp k j l t
          = РѕЉ k : Fin (p + 1), term (Fin.castLE hle k) := by
              simp_rw [leadingBlockPrefix13_2_apply_castLE hp hle]
              rfl
      _ = РѕЉ k : Fin m, term k := hsum
      _ = A (Fin.castLE hle i) (Fin.castLE hle j) s t := hprod
      _ = leadingBlockPrefix13_2 A p hp i j s t := by
              rw [leadingBlockPrefix13_2_apply_castLE hp hle]

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 dependency:
    from nonsingularity of the first leading principal block submatrix, extract
    the two-sided inverse data for the leading block `AРѓЂРѓЂ`.  This is the bridge
    from the source condition to the one-step Schur-complement construction. -/
theorem LeadingPrincipalBlockNonsingular13_2.first_block_inverse {m r : РёЋ}
    {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    (hm : 0 < m)
    (hlead : LeadingPrincipalBlockNonsingular13_2 A) :
    РѕЃ A11_inv : Fin r Рєњ Fin r Рєњ РёЮ,
      (Рѕђ s t : Fin r,
        РѕЉ l : Fin r, A11_inv s l * A 0 0 l t = if s = t then 1 else 0) РѕД
      (Рѕђ s t : Fin r,
        РѕЉ l : Fin r, A 0 0 s l * A11_inv l t = if s = t then 1 else 0) := by
  have hprefix :
      BlockMatrixNonsingular
        (leadingBlockPrefix13_2 A 0 (Nat.lt_trans (Nat.lt_succ_self 0)
          (by simpa using Nat.succ_lt_succ hm))) :=
    hlead 0 (by simpa using Nat.succ_lt_succ hm)
  rcases hprefix with РЪеAinv, hInvРЪЕ
  refine РЪеAinv 0 0, ?_, ?_РЪЕ
  ┬и intro s t
    have h := hInv.1 0 0 s t
    rw [Fin.sum_univ_one] at h
    simpa [leadingBlockPrefix13_2, blockMatrixIdentity, idBlock] using h
  ┬и intro s t
    have h := hInv.2 0 0 s t
    rw [Fin.sum_univ_one] at h
    simpa [leadingBlockPrefix13_2, blockMatrixIdentity, idBlock] using h

-- ============================================================
-- ┬Д13.1  Block LU versus standard LU
-- ============================================================

/-- Multiplication by a homogeneous block-diagonal matrix acts block-rowwise on
    the flattened `(within-block index, block index)` representation. -/
lemma blockDiagonal_mul_apply_block
    {╬╣ r ╬▒ : Type*} [DecidableEq ╬╣] [Fintype r] [Fintype ╬╣]
    [NonUnitalNonAssocSemiring ╬▒]
    (D : ╬╣ Рєњ Matrix r r ╬▒) (N : Matrix (r ├Ќ ╬╣) (r ├Ќ ╬╣) ╬▒)
    (s t : r) (i j : ╬╣) :
    (Matrix.blockDiagonal D * N) (s, i) (t, j) =
      РѕЉ a : r, D i s a * N (a, i) (t, j) := by
  simp [Matrix.mul_apply, Matrix.blockDiagonal_apply, Fintype.sum_prod_type]

/-- Adjust the block upper factor after factoring each diagonal block
    `Uрхбрхб = Lbarрхб Ubarрхб`.  The diagonal blocks become `Ubarрхб`; every block in
    block row `i` is premultiplied by `LbarрхбРЂ╗┬╣`. -/
noncomputable def higham13_standardUpperFromBlockUpper
    {╬╣ r ╬▒ : Type*} [DecidableEq ╬╣] [DecidableEq r] [Fintype r] [Fintype ╬╣]
    [CommRing ╬▒]
    (Lbar Ubar : ╬╣ Рєњ Matrix r r ╬▒) [Рѕђ i, Invertible (Lbar i)]
    (U : Matrix (r ├Ќ ╬╣) (r ├Ќ ╬╣) ╬▒) :
    Matrix (r ├Ќ ╬╣) (r ├Ќ ╬╣) ╬▒ :=
  fun si tj =>
    if _h : si.2 = tj.2 then Ubar si.2 si.1 tj.1
    else
      let B : Matrix r r ╬▒ := fun s t => U (s, si.2) (t, tj.2)
      ((РЁЪ(Lbar si.2) : Matrix r r ╬▒) * B) si.1 tj.1

/-- Higham, 2nd ed., Chapter 13, Section 13.1, p.247:
    diagonal-block LU factorizations refine a block upper factor.

    If each diagonal block of the block upper factor `U` satisfies
    `Uрхбрхб = Lbarрхб Ubarрхб`, then the block-diagonal matrix with blocks `Lbarрхб`
    times the adjusted upper factor reconstructs `U`. -/
theorem higham13_block_upper_refinement_eq
    {╬╣ r ╬▒ : Type*} [DecidableEq ╬╣] [DecidableEq r] [Fintype r] [Fintype ╬╣]
    [CommRing ╬▒]
    (Lbar Ubar : ╬╣ Рєњ Matrix r r ╬▒) [Рѕђ i, Invertible (Lbar i)]
    (U : Matrix (r ├Ќ ╬╣) (r ├Ќ ╬╣) ╬▒)
    (hdiag : Рѕђ i : ╬╣, Lbar i * Ubar i = fun s t => U (s, i) (t, i)) :
    Matrix.blockDiagonal Lbar * higham13_standardUpperFromBlockUpper Lbar Ubar U = U := by
  ext si tj
  rcases si with РЪеs, iРЪЕ
  rcases tj with РЪеt, jРЪЕ
  rw [blockDiagonal_mul_apply_block]
  by_cases hij : i = j
  ┬и subst j
    have h := congr_fun (congr_fun (hdiag i) s) t
    simpa [Matrix.mul_apply, higham13_standardUpperFromBlockUpper] using h
  ┬и let B : Matrix r r ╬▒ := fun a b => U (a, i) (b, j)
    have hmat : Lbar i * ((РЁЪ(Lbar i) : Matrix r r ╬▒) * B) = B := by
      simp
    have h := congr_fun (congr_fun hmat s) t
    simpa [Matrix.mul_apply, higham13_standardUpperFromBlockUpper, hij, B] using h

/-- Higham, 2nd ed., Chapter 13, Section 13.1, p.247:
    relation between block LU and standard LU factorizations.

    Given a flattened block LU product `A = L U` and LU factorizations
    `Uрхбрхб = Lbarрхб Ubarрхб` for each diagonal block of `U`, the same matrix factors
    as `(L diag(Lbarрхб))` times the adjusted upper factor.  This is the exact
    product identity behind the prose statement; triangularity of the two
    refined factors is deliberately left to the caller's lower/upper-triangular
    hypotheses. -/
theorem higham13_block_lu_to_standard_lu_product
    {╬╣ r ╬▒ : Type*} [DecidableEq ╬╣] [DecidableEq r] [Fintype r] [Fintype ╬╣]
    [CommRing ╬▒]
    (A L U : Matrix (r ├Ќ ╬╣) (r ├Ќ ╬╣) ╬▒)
    (Lbar Ubar : ╬╣ Рєњ Matrix r r ╬▒) [Рѕђ i, Invertible (Lbar i)]
    (hA : A = L * U)
    (hdiag : Рѕђ i : ╬╣, Lbar i * Ubar i = fun s t => U (s, i) (t, i)) :
    A =
      (L * Matrix.blockDiagonal Lbar) *
        higham13_standardUpperFromBlockUpper Lbar Ubar U := by
  calc
    A = L * U := hA
    _ = L * (Matrix.blockDiagonal Lbar *
          higham13_standardUpperFromBlockUpper Lbar Ubar U) := by
        rw [higham13_block_upper_refinement_eq Lbar Ubar U hdiag]
    _ = (L * Matrix.blockDiagonal Lbar) *
          higham13_standardUpperFromBlockUpper Lbar Ubar U := by
        rw [Matrix.mul_assoc]

-- ============================================================
-- ┬Д13.1  Block Schur complement (eq. 13.2)
-- ============================================================

/-- **Block Schur complement** (Higham, 2nd ed., Chapter 13, eq. 13.2):
    S_{ij} = A_{i+1,j+1} Рѕњ РѕЉ_{lРѓЂ,lРѓѓ} A_{i+1,0}(s,lРѓЂ) ┬и AРѓЂРѓЂРЂ╗┬╣(lРѓЂ,lРѓѓ) ┬и A_{0,j+1}(lРѓѓ,t).
    Eliminates block row/column 0, yielding an m├Ќm block matrix from (m+1)├Ќ(m+1). -/
noncomputable def blockSchur {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (A11_inv : Fin r Рєњ Fin r Рєњ РёЮ) :
    Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ) :=
  fun i j s t => A i.succ j.succ s t -
    РѕЉ lРѓЂ : Fin r, РѕЉ lРѓѓ : Fin r,
      A i.succ (0 : Fin (m + 1)) s lРѓЂ * A11_inv lРѓЂ lРѓѓ *
      A (0 : Fin (m + 1)) j.succ lРѓѓ t

/-- The scalar Schur complement of the first-split flattening is the standard
    flattening of the Chapter 13 block Schur complement. -/
theorem blockMatrixFirstSplit_schur_eq_blockMatrixFlatFin_blockSchur {m r : РёЋ}
    (A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (A11_inv : Matrix (Fin r) (Fin r) РёЮ) :
    blockMatrixFirstSplitA22 A -
        blockMatrixFirstSplitA21 A * A11_inv * blockMatrixFirstSplitA12 A =
      blockMatrixFlatFin (blockSchur A A11_inv) := by
  ext p q
  simp [blockMatrixFirstSplitA22, blockMatrixFirstSplitA21,
    blockMatrixFirstSplitA12, blockMatrixFlatFin, blockSchur, Matrix.mul_apply,
    Finset.sum_mul, mul_assoc]
  rw [Finset.sum_comm]

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    the first-split `Matrix.fromBlocks` view of a Schur tail is invertible
    whenever the scalar Schur-complement block is invertible.

    This is a representation bridge: it transports invertibility across the
    equality between the scalar Schur complement of the first-split flattening
    and the uniform flat matrix of the recursive block Schur tail. -/
noncomputable def higham13_problem13_4_schurTail_fromBlocks_invertible_of_schur_invertible
    {m r : РёЋ}
    (Ablk : Fin ((m + 1) + 1) Рєњ Fin ((m + 1) + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (A11_inv : Matrix (Fin r) (Fin r) РёЮ)
    (Atail : Fin (m + 1) Рєњ Fin (m + 1) Рєњ Matrix (Fin r) (Fin r) РёЮ)
    [Invertible (blockMatrixFirstSplitA22 Ablk -
      blockMatrixFirstSplitA21 Ablk * A11_inv *
        blockMatrixFirstSplitA12 Ablk)]
    (hAtail : Atail = blockSchur Ablk A11_inv) :
    Invertible (Matrix.fromBlocks
      (blockMatrixFirstSplitA11 Atail)
      (blockMatrixFirstSplitA12 Atail)
      (blockMatrixFirstSplitA21 Atail)
      (blockMatrixFirstSplitA22 Atail)) := by
  classical
  have hflat :
      blockMatrixFlatFin Atail =
        blockMatrixFirstSplitA22 Ablk -
          blockMatrixFirstSplitA21 Ablk * A11_inv *
            blockMatrixFirstSplitA12 Ablk := by
    rw [hAtail, Рєљ blockMatrixFirstSplit_schur_eq_blockMatrixFlatFin_blockSchur]
  letI : Invertible (blockMatrixFlatFin Atail) :=
    hflat.symm РќИ
      (inferInstance : Invertible
        (blockMatrixFirstSplitA22 Ablk -
          blockMatrixFirstSplitA21 Ablk * A11_inv *
            blockMatrixFirstSplitA12 Ablk))
  exact blockMatrixFirstSplit_fromBlocks_invertible_of_blockMatrixFlatFin Atail

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 induction bookkeeping:
    the leading prefix of the Schur complement is the Schur complement of the
    next larger leading prefix.  This is the index bridge needed to transfer
    leading-principal-block nonsingularity down the recursive Schur step. -/
theorem leadingBlockPrefix13_2_blockSchur {m r : РёЋ}
    (A : Fin (m + 2) Рєњ Fin (m + 2) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (A11_inv : Fin r Рєњ Fin r Рєњ РёЮ)
    (p : РёЋ) (hp : p < m + 1) :
    leadingBlockPrefix13_2 (blockSchur A A11_inv) p hp =
      blockSchur
        (leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hp))
        A11_inv := by
  ext i j s t
  simp [leadingBlockPrefix13_2, blockSchur]

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 induction dependency:
    if a block matrix is nonsingular and its leading block has the supplied
    two-sided inverse, then the Schur complement is nonsingular.

    The inverse of the Schur complement is the lower-right block of a two-sided
    inverse of the full block matrix.  The proof uses `Matrix.of` internally to
    force Lean's reducible matrix type to use inner matrix multiplication rather
    than pointwise function multiplication on raw function-valued blocks. -/
theorem blockSchur_nonsingular_of_nonsingular_of_first_block_inverse {m r : РёЋ}
    {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    {A11_inv : Fin r Рєњ Fin r Рєњ РёЮ}
    (hInvLeft : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A11_inv s l * A 0 0 l t = if s = t then 1 else 0)
    (hInvRight : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A 0 0 s l * A11_inv l t = if s = t then 1 else 0)
    (hA : BlockMatrixNonsingular A) :
    BlockMatrixNonsingular (blockSchur A A11_inv) := by
  classical
  rcases hA with РЪеAinv, hInvРЪЕ
  let A00 : Matrix (Fin 1) (Fin 1) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun _ _ => Matrix.of (A 0 0)
  let P : Matrix (Fin 1) (Fin 1) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun _ _ => Matrix.of A11_inv
  let B : Matrix (Fin 1) (Fin m) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun _ j => Matrix.of (A 0 (Fin.succ j))
  let C : Matrix (Fin m) (Fin 1) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun i _ => Matrix.of (A (Fin.succ i) 0)
  let D : Matrix (Fin m) (Fin m) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun i j => Matrix.of (A (Fin.succ i) (Fin.succ j))
  let G : Matrix (Fin m) (Fin 1) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun i _ => Matrix.of (Ainv (Fin.succ i) 0)
  let F : Matrix (Fin 1) (Fin m) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun _ j => Matrix.of (Ainv 0 (Fin.succ j))
  let H : Matrix (Fin m) (Fin m) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun i j => Matrix.of (Ainv (Fin.succ i) (Fin.succ j))
  let S : Matrix (Fin m) (Fin m) (Matrix (Fin r) (Fin r) РёЮ) :=
    fun i j => Matrix.of (blockSchur A A11_inv i j)
  have hS : S = D - C * P * B := by
    ext i j s t
    have hCPB :
        (C * P * B) i j s t =
          РѕЉ lРѓЂ : Fin r, РѕЉ lРѓѓ : Fin r,
            A (Fin.succ i) 0 s lРѓЂ * A11_inv lРѓЂ lРѓѓ *
              A 0 (Fin.succ j) lРѓѓ t := by
      simp only [C, P, B, Matrix.mul_apply, Fin.sum_univ_one, Matrix.sum_apply]
      simp_rw [Finset.sum_mul, mul_assoc]
      rw [Finset.sum_comm]
      apply Finset.sum_congr rfl
      intro lРѓЂ _hlРѓЂ
      apply Finset.sum_congr rfl
      intro lРѓѓ _hlРѓѓ
      simp
    change blockSchur A A11_inv i j s t = D i j s t - (C * P * B) i j s t
    rw [hCPB]
    simp [D, blockSchur]
  have hA00P : A00 * P = 1 := by
    ext i j s t
    fin_cases i
    fin_cases j
    simpa [A00, P, Matrix.mul_apply, Fin.sum_univ_one, Matrix.one_apply, idBlock,
      Matrix.sum_apply, Finset.sum_apply]
      using hInvRight s t
  have hPA00 : P * A00 = 1 := by
    ext i j s t
    fin_cases i
    fin_cases j
    simpa [A00, P, Matrix.mul_apply, Fin.sum_univ_one, Matrix.one_apply, idBlock,
      Matrix.sum_apply, Finset.sum_apply]
      using hInvLeft s t
  have hG_A00_H_C : G * A00 + H * C = 0 := by
    ext i j s t
    fin_cases j
    have h := hInv.1 (Fin.succ i) 0 s t
    rw [Fin.sum_univ_succ] at h
    simpa [G, A00, H, C, Matrix.mul_apply, Matrix.add_apply, Matrix.zero_apply,
      blockMatrixIdentity, zeroBlock, Fin.sum_univ_one, Matrix.sum_apply,
      Finset.sum_apply, Pi.add_apply] using h
  have hG_B_H_D : G * B + H * D = 1 := by
    ext i j s t
    have h := hInv.1 (Fin.succ i) (Fin.succ j) s t
    rw [Fin.sum_univ_succ] at h
    simpa [G, B, H, D, Matrix.mul_apply, Matrix.add_apply, Matrix.one_apply,
      blockMatrixIdentity, idBlock, zeroBlock, Fin.sum_univ_one, Matrix.sum_apply,
      Finset.sum_apply, Pi.add_apply] using h
  have hA00_F_B_H : A00 * F + B * H = 0 := by
    ext i j s t
    fin_cases i
    have h := hInv.2 0 (Fin.succ j) s t
    rw [Fin.sum_univ_succ] at h
    simpa [A00, F, B, H, Matrix.mul_apply, Matrix.add_apply, Matrix.zero_apply,
      blockMatrixIdentity, zeroBlock, Fin.sum_univ_one, Matrix.sum_apply,
      Finset.sum_apply, Pi.add_apply] using h
  have hC_F_D_H : C * F + D * H = 1 := by
    ext i j s t
    have h := hInv.2 (Fin.succ i) (Fin.succ j) s t
    rw [Fin.sum_univ_succ] at h
    simpa [C, F, D, H, Matrix.mul_apply, Matrix.add_apply, Matrix.one_apply,
      blockMatrixIdentity, idBlock, zeroBlock, Fin.sum_univ_one, Matrix.sum_apply,
      Finset.sum_apply, Pi.add_apply] using h
  have hHC : H * C = -(G * A00) := by
    rw [Рєљ add_eq_zero_iff_eq_neg]
    simpa [add_comm] using hG_A00_H_C
  have hBH : B * H = -(A00 * F) := by
    rw [Рєљ add_eq_zero_iff_eq_neg]
    simpa [add_comm] using hA00_F_B_H
  have hHS : H * S = 1 := by
    rw [hS]
    calc
      H * (D - C * P * B) = H * D - H * (C * P * B) := by
        exact Matrix.mul_sub H D (C * P * B)
      _ = H * D - (H * C) * P * B := by
        rw [Рєљ Matrix.mul_assoc H (C * P) B, Рєљ Matrix.mul_assoc H C P]
      _ = H * D - (-(G * A00)) * P * B := by
        rw [hHC]
      _ = H * D + G * (A00 * P) * B := by
        have hneg : (-(G * A00)) * P * B = -((G * A00) * P * B) := by
          calc
            (-(G * A00)) * P * B = (-((G * A00) * P)) * B := by
              exact congrArg (fun X => X * B) (Matrix.neg_mul (G * A00) P)
            _ = -((G * A00) * P * B) := by
              exact Matrix.neg_mul ((G * A00) * P) B
        rw [hneg, sub_neg_eq_add, Matrix.mul_assoc G A00 P]
      _ = H * D + G * B := by
        rw [hA00P]
        simp
      _ = G * B + H * D := by
        rw [add_comm]
      _ = 1 := hG_B_H_D
  have hSH : S * H = 1 := by
    rw [hS]
    calc
      (D - C * P * B) * H = D * H - (C * P * B) * H := by
        exact Matrix.sub_mul D (C * P * B) H
      _ = D * H - C * P * (B * H) := by
        rw [Matrix.mul_assoc (C * P) B H]
      _ = D * H - C * P * (-(A00 * F)) := by
        rw [hBH]
      _ = D * H + C * (P * A00) * F := by
        have hneg : C * P * (-(A00 * F)) = -(C * P * (A00 * F)) := by
          exact Matrix.mul_neg (C * P) (A00 * F)
        rw [hneg, sub_neg_eq_add]
        rw [Рєљ Matrix.mul_assoc (C * P) A00 F, Matrix.mul_assoc C P A00]
      _ = D * H + C * F := by
        rw [hPA00]
        simp
      _ = C * F + D * H := by
        rw [add_comm]
      _ = 1 := hC_F_D_H
  refine РЪеfun i j => H i j, ?_, ?_РЪЕ
  ┬и intro i j s t
    have hblock := congr_fun (congr_fun hHS i) j
    have hscalar := congr_fun (congr_fun hblock s) t
    simpa [S, H, Matrix.mul_apply, Matrix.sum_apply, Finset.sum_apply,
      blockMatrixIdentity, idBlock, zeroBlock, Matrix.one_apply] using hscalar
  ┬и intro i j s t
    have hblock := congr_fun (congr_fun hSH i) j
    have hscalar := congr_fun (congr_fun hblock s) t
    simpa [S, H, Matrix.mul_apply, Matrix.sum_apply, Finset.sum_apply,
      blockMatrixIdentity, idBlock, zeroBlock, Matrix.one_apply] using hscalar

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 converse-side dependency:
    if the first block has the supplied two-sided inverse and the Schur
    complement is nonsingular, then the whole one-step block matrix is
    nonsingular.

    The proof flattens the trailing block rows/columns to a scalar matrix over
    `РёЮ`, applies Mathlib's Schur-complement invertibility theorem there, and
    then unflattens the inverse back to the chapter's uniform-block predicate. -/
theorem blockMatrixNonsingular_of_first_block_inverse_of_blockSchur_nonsingular {m r : РёЋ}
    {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    {A11_inv : Fin r Рєњ Fin r Рєњ РёЮ}
    (hInvLeft : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A11_inv s l * A 0 0 l t = if s = t then 1 else 0)
    (hInvRight : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A 0 0 s l * A11_inv l t = if s = t then 1 else 0)
    (hSchur : BlockMatrixNonsingular (blockSchur A A11_inv)) :
    BlockMatrixNonsingular A := by
  classical
  rcases hSchur with РЪеSinv, hSinvРЪЕ
  let A00 : Matrix (Fin r) (Fin r) РёЮ := Matrix.of (A 0 0)
  let P : Matrix (Fin r) (Fin r) РёЮ := Matrix.of A11_inv
  let B : Matrix (Fin r) (Fin m ├Ќ Fin r) РёЮ :=
    fun s jt => A 0 (Fin.succ jt.1) s jt.2
  let C : Matrix (Fin m ├Ќ Fin r) (Fin r) РёЮ :=
    fun is t => A (Fin.succ is.1) 0 is.2 t
  let D : Matrix (Fin m ├Ќ Fin r) (Fin m ├Ќ Fin r) РёЮ :=
    fun is jt => A (Fin.succ is.1) (Fin.succ jt.1) is.2 jt.2
  let S : Matrix (Fin m ├Ќ Fin r) (Fin m ├Ќ Fin r) РёЮ :=
    fun is jt => blockSchur A A11_inv is.1 jt.1 is.2 jt.2
  let H : Matrix (Fin m ├Ќ Fin r) (Fin m ├Ќ Fin r) РёЮ :=
    fun is jt => Sinv is.1 jt.1 is.2 jt.2
  have hS_eq : S = D - C * P * B := by
    ext is jt
    rcases is with РЪеi, sРЪЕ
    rcases jt with РЪеj, tРЪЕ
    have hCPB :
        (C * P * B) (i, s) (j, t) =
          РѕЉ lРѓЂ : Fin r, РѕЉ lРѓѓ : Fin r,
            A (Fin.succ i) 0 s lРѓЂ * A11_inv lРѓЂ lРѓѓ *
              A 0 (Fin.succ j) lРѓѓ t := by
      simp only [C, P, B, Matrix.mul_apply]
      simp_rw [Finset.sum_mul, mul_assoc]
      rw [Finset.sum_comm]
      apply Finset.sum_congr rfl
      intro lРѓЂ _hlРѓЂ
      apply Finset.sum_congr rfl
      intro lРѓѓ _hlРѓѓ
      simp
    change blockSchur A A11_inv i j s t =
      D (i, s) (j, t) - (C * P * B) (i, s) (j, t)
    rw [hCPB]
    simp [D, blockSchur]
  have hA00P : A00 * P = 1 := by
    ext s t
    simpa [A00, P, Matrix.mul_apply, Matrix.one_apply] using hInvRight s t
  have hPA00 : P * A00 = 1 := by
    ext s t
    simpa [A00, P, Matrix.mul_apply, Matrix.one_apply] using hInvLeft s t
  letI : Invertible A00 := {
    invOf := P
    invOf_mul_self := hPA00
    mul_invOf_self := hA00P
  }
  have hHS : H * S = 1 := by
    ext is jt
    rcases is with РЪеi, sРЪЕ
    rcases jt with РЪеj, tРЪЕ
    have h := hSinv.1 i j s t
    have hId :
        (if i = j then idBlock r else zeroBlock r) s t =
          if i = j РѕД s = t then 1 else 0 := by
      by_cases hij : i = j <;> by_cases hst : s = t <;>
        simp [hij, hst, idBlock, zeroBlock]
    simpa [H, S, Matrix.mul_apply, Fintype.sum_prod_type, blockMatrixIdentity,
      idBlock, zeroBlock, Matrix.one_apply, Prod.ext_iff, hId] using h
  have hSH : S * H = 1 := by
    ext is jt
    rcases is with РЪеi, sРЪЕ
    rcases jt with РЪеj, tРЪЕ
    have h := hSinv.2 i j s t
    have hId :
        (if i = j then idBlock r else zeroBlock r) s t =
          if i = j РѕД s = t then 1 else 0 := by
      by_cases hij : i = j <;> by_cases hst : s = t <;>
        simp [hij, hst, idBlock, zeroBlock]
    simpa [H, S, Matrix.mul_apply, Fintype.sum_prod_type, blockMatrixIdentity,
      idBlock, zeroBlock, Matrix.one_apply, Prod.ext_iff, hId] using h
  let iS : Invertible S := {
    invOf := H
    invOf_mul_self := hHS
    mul_invOf_self := hSH
  }
  letI : Invertible (D - C * РЁЪA00 * B) :=
    Invertible.copy iS _ (by
      change D - C * P * B = S
      exact hS_eq.symm)
  let M : Matrix (Fin r РіЋ (Fin m ├Ќ Fin r)) (Fin r РіЋ (Fin m ├Ќ Fin r)) РёЮ :=
    Matrix.fromBlocks A00 B C D
  letI : Invertible M := Matrix.fromBlocksРѓЂРѓЂInvertible A00 B C D
  let Ainv : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ) := fun i j s t =>
    if hi : i = 0 then
      if hj : j = 0 then
        (РЁЪM) (Sum.inl s) (Sum.inl t)
      else
        (РЁЪM) (Sum.inl s) (Sum.inr (j.pred hj, t))
    else
      if hj : j = 0 then
        (РЁЪM) (Sum.inr (i.pred hi, s)) (Sum.inl t)
      else
        (РЁЪM) (Sum.inr (i.pred hi, s)) (Sum.inr (j.pred hj, t))
  refine РЪеAinv, ?_, ?_РЪЕ
  ┬и intro i j s t
    by_cases hi : i = 0 <;> by_cases hj : j = 0
    ┬и subst i
      subst j
      have h := congr_fun (congr_fun (invOf_mul_self M) (Sum.inl s)) (Sum.inl t)
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply] using h
    ┬и subst i
      have h := congr_fun (congr_fun (invOf_mul_self M) (Sum.inl s))
        (Sum.inr (j.pred hj, t))
      have h0j : (0 : Fin (m + 1)) РЅа j := fun h0j => hj h0j.symm
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply, h0j, hj, Fin.succ_pred j hj] using h
    ┬и subst j
      have h := congr_fun (congr_fun (invOf_mul_self M) (Sum.inr (i.pred hi, s)))
        (Sum.inl t)
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply, hi, Fin.succ_pred i hi] using h
    ┬и have h := congr_fun (congr_fun (invOf_mul_self M) (Sum.inr (i.pred hi, s)))
        (Sum.inr (j.pred hj, t))
      have hBlockId :
          (if i = j then idBlock r else zeroBlock r) s t =
            if i = j РѕД s = t then 1 else 0 := by
        by_cases hij : i = j <;> by_cases hst : s = t <;>
          simp [hij, hst, idBlock, zeroBlock]
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply, hi, hj, Fin.succ_pred i hi,
        Fin.succ_pred j hj, Prod.ext_iff, hBlockId] using h
  ┬и intro i j s t
    by_cases hi : i = 0 <;> by_cases hj : j = 0
    ┬и subst i
      subst j
      have h := congr_fun (congr_fun (mul_invOf_self M) (Sum.inl s)) (Sum.inl t)
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply] using h
    ┬и subst i
      have h := congr_fun (congr_fun (mul_invOf_self M) (Sum.inl s))
        (Sum.inr (j.pred hj, t))
      have h0j : (0 : Fin (m + 1)) РЅа j := fun h0j => hj h0j.symm
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply, h0j, hj, Fin.succ_pred j hj] using h
    ┬и subst j
      have h := congr_fun (congr_fun (mul_invOf_self M) (Sum.inr (i.pred hi, s)))
        (Sum.inl t)
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply, hi, Fin.succ_pred i hi] using h
    ┬и have h := congr_fun (congr_fun (mul_invOf_self M) (Sum.inr (i.pred hi, s)))
        (Sum.inr (j.pred hj, t))
      have hBlockId :
          (if i = j then idBlock r else zeroBlock r) s t =
            if i = j РѕД s = t then 1 else 0 := by
        by_cases hij : i = j <;> by_cases hst : s = t <;>
          simp [hij, hst, idBlock, zeroBlock]
      simpa [Ainv, M, A00, B, C, D, Matrix.mul_apply, Matrix.fromBlocks,
        Fin.sum_univ_succ, Fintype.sum_prod_type, blockMatrixIdentity, idBlock,
        zeroBlock, Matrix.one_apply, hi, hj, Fin.succ_pred i hi,
        Fin.succ_pred j hj, Prod.ext_iff, hBlockId] using h

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 induction dependency:
    leading-principal-block nonsingularity transfers from a full block matrix
    to the Schur complement after eliminating the first block. -/
theorem LeadingPrincipalBlockNonsingular13_2.schur {m r : РёЋ}
    {A : Fin (m + 2) Рєњ Fin (m + 2) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    {A11_inv : Fin r Рєњ Fin r Рєњ РёЮ}
    (hInvLeft : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A11_inv s l * A 0 0 l t = if s = t then 1 else 0)
    (hInvRight : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A 0 0 s l * A11_inv l t = if s = t then 1 else 0)
    (hlead : LeadingPrincipalBlockNonsingular13_2 A) :
    LeadingPrincipalBlockNonsingular13_2 (blockSchur A A11_inv) := by
  intro p hp
  have hpPrefix : p < m + 1 := Nat.lt_trans (Nat.lt_succ_self p) hp
  have hA_prefix :
      BlockMatrixNonsingular
        (leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpPrefix)) := by
    simpa [leadingBlockPrefix13_2] using
      hlead (p + 1) (by
        have := Nat.succ_lt_succ hp
        simpa [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm] using this)
  have hInvLeft_prefix :
      Рѕђ s t : Fin r,
        РѕЉ l : Fin r,
          A11_inv s l *
            leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpPrefix) 0 0 l t =
          if s = t then 1 else 0 := by
    intro s t
    simpa [leadingBlockPrefix13_2] using hInvLeft s t
  have hInvRight_prefix :
      Рѕђ s t : Fin r,
        РѕЉ l : Fin r,
          leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpPrefix) 0 0 s l *
            A11_inv l t =
          if s = t then 1 else 0 := by
    intro s t
    simpa [leadingBlockPrefix13_2] using hInvRight s t
  have hSchur_prefix :
      BlockMatrixNonsingular
        (blockSchur
          (leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpPrefix))
          A11_inv) :=
    blockSchur_nonsingular_of_nonsingular_of_first_block_inverse
      (A := leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpPrefix))
      (A11_inv := A11_inv)
      hInvLeft_prefix hInvRight_prefix hA_prefix
  rw [leadingBlockPrefix13_2_blockSchur A A11_inv p hpPrefix]
  exact hSchur_prefix

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 converse dependency:
    a two-sided inverse for the first block makes the first leading principal
    block submatrix nonsingular.  This closes the base prefix in the
    Schur-tail-to-full leading-principal-block assembly step. -/
theorem leadingBlockPrefix13_2_zero_nonsingular_of_first_block_inverse {m r : РёЋ}
    {A : Fin (m + 1) Рєњ Fin (m + 1) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    {A11_inv : Fin r Рєњ Fin r Рєњ РёЮ}
    (hInvLeft : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A11_inv s l * A 0 0 l t = if s = t then 1 else 0)
    (hInvRight : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A 0 0 s l * A11_inv l t = if s = t then 1 else 0) :
    BlockMatrixNonsingular (leadingBlockPrefix13_2 A 0 (Nat.succ_pos m)) := by
  refine РЪеfun _ _ => A11_inv, ?_, ?_РЪЕ
  ┬и intro i j s t
    fin_cases i
    fin_cases j
    rw [Fin.sum_univ_one]
    simpa [leadingBlockPrefix13_2, blockMatrixIdentity, idBlock] using hInvLeft s t
  ┬и intro i j s t
    fin_cases i
    fin_cases j
    rw [Fin.sum_univ_one]
    simpa [leadingBlockPrefix13_2, blockMatrixIdentity, idBlock] using hInvRight s t

/-- Higham, 2nd ed., Chapter 13, Theorem 13.2 converse dependency:
    if the first block is nonsingular and the Schur complement has all required
    leading principal block submatrices nonsingular, then the original matrix
    has all required leading principal block submatrices nonsingular.

    This is the reverse of `LeadingPrincipalBlockNonsingular13_2.schur` at the
    level of the source condition; the remaining converse-side bottleneck is
    deriving the first-block inverse from uniqueness of the full block LU
    factorization. -/
theorem LeadingPrincipalBlockNonsingular13_2.of_first_block_inverse_of_schur
    {m r : РёЋ}
    {A : Fin (m + 2) Рєњ Fin (m + 2) Рєњ (Fin r Рєњ Fin r Рєњ РёЮ)}
    {A11_inv : Fin r Рєњ Fin r Рєњ РёЮ}
    (hInvLeft : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A11_inv s l * A 0 0 l t = if s = t then 1 else 0)
    (hInvRight : Рѕђ s t : Fin r,
      РѕЉ l : Fin r, A 0 0 s l * A11_inv l t = if s = t then 1 else 0)
    (hSchurLead : LeadingPrincipalBlockNonsingular13_2 (blockSchur A A11_inv)) :
    LeadingPrincipalBlockNonsingular13_2 A := by
  intro p hp
  cases p with
  | zero =>
      have h0 :
          BlockMatrixNonsingular
            (leadingBlockPrefix13_2 A 0 (Nat.succ_pos (m + 1))) :=
        leadingBlockPrefix13_2_zero_nonsingular_of_first_block_inverse
          (A := A) (A11_inv := A11_inv) hInvLeft hInvRight
      simpa [leadingBlockPrefix13_2] using h0
  | succ p =>
      have hpTail : p + 1 < m + 1 := by omega
      have hpSchur : p < m + 1 := Nat.lt_trans (Nat.lt_succ_self p) hpTail
      have hTailPrefix :
          BlockMatrixNonsingular
            (leadingBlockPrefix13_2 (blockSchur A A11_inv) p hpSchur) :=
        hSchurLead p hpTail
      have hSchurPrefix :
          BlockMatrixNonsingular
            (blockSchur
              (leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpSchur))
              A11_inv) := by
        rw [Рєљ leadingBlockPrefix13_2_blockSchur A A11_inv p hpSchur]
        exact hTailPrefix
      have hInvLeftPrefix :
          Рѕђ s t : Fin r,
            РѕЉ l : Fin r,
              A11_inv s l *
                leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpSchur) 0 0 l t =
              if s = t then 1 else 0 := by
        intro s t
        simpa [leadingBlockPrefix13_2] using hInvLeft s t
      have hInvRightPrefix :
          Рѕђ s t : Fin r,
            РѕЉ l : Fin r,
              leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpSchur) 0 0 s l *
                A11_inv l t =
              if s = t then 1 else 0 := by
        intro s t
        simpa [leadingBlockPrefix13_2] using hInvRight s t
      have hAssembled :
          BlockMatrixNonsingular
            (leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpSchur)) :=
        blockMatrixNonsingular_of_first_block_inverse_of_blockSchur_nonsingular
          (A := leadingBlockPrefix13_2 A (p + 1) (Nat.succ_lt_succ hpSchur))
          (A11_inv := A11_inv)
          hInvLeftPrefix hInvRightPrefix hSchurPrefix
      simpa [leadingBlockPrefix13_2] using hAssembled

