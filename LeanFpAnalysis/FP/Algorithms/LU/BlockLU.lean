    apply le_antisymm
    ┬и apply maxEntryNormRect_le_of_entry_abs_le
      intro i j
      fin_cases i <;> fin_cases j <;> norm_num [S]
    ┬и have h :=
        entry_le_maxEntryNormRect (by norm_num : 0 < 2) (by norm_num : 0 < 2)
