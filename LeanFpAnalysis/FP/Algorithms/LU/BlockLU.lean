theorem higham13_problem13_4_schur_kappa_maxEntryNormRect_from_entrywise_inverse_bound
    {s : РёЋ} (hs : 0 < s)
    (S Sinv : Fin s Рєњ Fin s Рєњ РёЮ)
    {normA normAinv rho kappaA : РёЮ}
    (hRho : 0 РЅц rho)
    (hS_entry : Рѕђ i : Fin s, Рѕђ j : Fin s, |S i j| РЅц rho * normA)
    (hSinv_entry : Рѕђ i : Fin s, Рѕђ j : Fin s, |Sinv i j| РЅц normAinv)
