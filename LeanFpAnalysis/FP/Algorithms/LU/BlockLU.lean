    (A : Fin n → Fin n → ℝ)
    (hSPD : IsSymPosDef n A) :
    IsRightInverse n A (nonsingInv n A) :=
  (isInverse_nonsingInv_of_det_ne_zero n A
    (isSymPosDef_det_ne_zero A hSPD)).2

