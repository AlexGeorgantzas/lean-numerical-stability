      (fun k i j => maxEntryNorm hr (stageBlock k i j))
      (fun i j => maxEntryNorm hr (A i j))
      (by
        intro i j
        simpa using congrArg (maxEntryNorm hr) (hInit i j))
      (higham13_theorem13_8_active_column_step_on_active_of_mixed_column_mass
