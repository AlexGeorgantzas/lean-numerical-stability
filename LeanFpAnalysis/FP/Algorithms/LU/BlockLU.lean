    `¤Ђ_n = growthFactorEntry A G`. -/
theorem blockMaxNorm_le_growthFactorEntry_mul_of_le_maxEntryNorm
    {N m r : РёЋ} (hN : 0 < N) (hm : 0 < m) (hr : 0 < r)
    (A G : Fin N Рєњ Fin N Рєњ РёЮ)
    (Ufac : Fin m Рєњ Fin m Рєњ (Fin r Рєњ Fin r Рєњ РёЮ))
    (hApos : 0 < maxEntryNorm hN A)
    (hU_le_G : blockMaxNorm hm hr Ufac РЅц maxEntryNorm hN G) :
    blockMaxNorm hm hr Ufac РЅц
      growthFactorEntry hN A G hApos * maxEntryNormRect hN hN A := by
  calc
    blockMaxNorm hm hr Ufac РЅц maxEntryNorm hN G := hU_le_G
    _ = growthFactorEntry hN A G hApos * maxEntryNormRect hN hN A := by
      rw [maxEntryNormRect_eq_maxEntryNorm hN A]
      unfold growthFactorEntry
      exact (div_mul_cancelРѓђ (maxEntryNorm hN G) (ne_of_gt hApos)).symm

/-- Higham, 2nd ed., Chapter 13, equation (13.22) nonvacuity support:
    the exact max-entry condition product makes the lower-factor diagonal
    budget at least one.

    If `Ainv` is a right inverse of `A`, the growth object contains the initial
    matrix, and the displayed scalar dimension `n` dominates the matrix
    dimension `N`, then
    `1 <= n * ¤Ђ^2 * (РђќAРђќ_max РђќAinvРђќ_max)`. -/
theorem higham13_eq13_22_lower_diagonal_budget_from_right_inverse_growth
    {N : РёЋ} (hN : 0 < N)
    (A G Ainv : Fin N Рєњ Fin N Рєњ РёЮ)
    (hApos : 0 < maxEntryNorm hN A)
    (hRight : IsRightInverse N A Ainv)
    (n : РёЋ)
    (hNn : (N : РёЮ) РЅц (n : РёЮ))
    (hA_le_G : maxEntryNorm hN A РЅц maxEntryNorm hN G) :
    1 РЅц (n : РёЮ) * (growthFactorEntry hN A G hApos) ^ 2 *
      (maxEntryNormRect hN hN A * maxEntryNormRect hN hN Ainv) := by
  let rho : РёЮ := growthFactorEntry hN A G hApos
  let kappaA : РёЮ := maxEntryNormRect hN hN A * maxEntryNormRect hN hN Ainv
  have hkappa_nonneg : 0 РЅц kappaA := by
    exact mul_nonneg (maxEntryNormRect_nonneg hN hN A)
      (maxEntryNormRect_nonneg hN hN Ainv)
  have hbase : 1 РЅц (N : РёЮ) * kappaA := by
    simpa [kappaA, mul_assoc] using
      one_le_dim_mul_maxEntryNormRect_mul_of_isRightInverse hN A Ainv hRight
  have hrho_ge_one : 1 РЅц rho := by
    simpa [rho] using
      growthFactorEntry_ge_one_of_maxEntryNorm_le hN A G hApos hA_le_G
  have hrho_nonneg : 0 РЅц rho := le_trans zero_le_one hrho_ge_one
  have hrho_sq_ge_one : 1 РЅц rho ^ 2 := by
    have hmul := mul_le_mul hrho_ge_one hrho_ge_one zero_le_one hrho_nonneg
    simpa [pow_two] using hmul
  have hcoef : (N : РёЮ) РЅц (n : РёЮ) * rho ^ 2 := by
    calc
      (N : РёЮ) РЅц (n : РёЮ) := hNn
      _ = (n : РёЮ) * 1 := by ring
      _ РЅц (n : РёЮ) * rho ^ 2 :=
        mul_le_mul_of_nonneg_left hrho_sq_ge_one (Nat.cast_nonneg n)
  have hbudget :
      (N : РёЮ) * kappaA РЅц ((n : РёЮ) * rho ^ 2) * kappaA :=
    mul_le_mul_of_nonneg_right hcoef hkappa_nonneg
  calc
    (1 : РёЮ) РЅц (N : РёЮ) * kappaA := hbase
    _ РЅц ((n : РёЮ) * rho ^ 2) * kappaA := hbudget
    _ = (n : РёЮ) * rho ^ 2 * kappaA := by ring
    _ = (n : РёЮ) * (growthFactorEntry hN A G hApos) ^ 2 *
        (maxEntryNormRect hN hN A * maxEntryNormRect hN hN Ainv) := by
        simp [rho, kappaA]

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    source-indexed exact-╬║ bounds with `rho` instantiated as the formal
    max-entry growth factor.

    This specializes
    `higham13_problem13_4_maxEntry_bounds_from_source_schur_growth_exact_kappa`
    by deriving the source Schur-growth premise from `growthFactorEntry`.
    The remaining mathematical source obligation is the concrete GE/stage
    bookkeeping certificate
    `||S||_max <= ||U||_max` for the growth-factor matrix `U`. -/
theorem higham13_problem13_4_maxEntry_bounds_from_source_growthFactorEntry_exact_kappa
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s) (hN : 0 < r + s)
    (A U : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A12 : Matrix (Fin r) (Fin s) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    (hA11_block : A11 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)))
    (hA12_block : A12 =
      fun (i : Fin r) (j : Fin s) =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)))
    (hA21_block : A21 =
      fun (i : Fin s) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)))
    (hA22_block : A22 =
      fun i j : Fin s =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)))
    (hApos : 0 < maxEntryNorm hN A)
    (n : РёЋ)
    (hsn : (s : РёЮ) РЅц (n : РёЮ))
    (hS_le_U :
      maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) РЅц
        maxEntryNorm hN U) :
    maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
        (n : РёЮ) * growthFactorEntry hN A U hApos *
          (maxEntryNormRect hN hN A *
            maxEntryNormRect hN hN (nonsingInv (r + s) A)) РѕД
      maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) *
          maxEntryNormRect hs hs
            ((РЁЪ(A22 - A21 * РЁЪA11 * A12)) : Matrix (Fin s) (Fin s) РёЮ) РЅц
        growthFactorEntry hN A U hApos *
          (maxEntryNormRect hN hN A *
            maxEntryNormRect hN hN (nonsingInv (r + s) A)) := by
  have hRho : 0 РЅц growthFactorEntry hN A U hApos := by
    unfold growthFactorEntry
    exact div_nonneg (maxEntryNorm_nonneg hN U) (le_of_lt hApos)
  have hS_growth :
      maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) РЅц
        growthFactorEntry hN A U hApos * maxEntryNormRect hN hN A :=
    maxEntryNormRect_le_growthFactorEntry_mul_of_le_maxEntryNorm
      hN hs A U (A22 - A21 * РЁЪA11 * A12) hApos hS_le_U
  exact
    higham13_problem13_4_maxEntry_bounds_from_source_schur_growth_exact_kappa
      hr hs hN A A11 A12 A21 A22
      hA11_block hA12_block hA21_block hA22_block
      n hRho hsn hS_growth

/-- Higham, 2nd ed., Chapter 13, Problem 13.4 feeding equation (13.22):
    an arbitrary source growth-factor matrix that contains both the initial
    max-entry norm and the Schur complement supplies the lower-factor premise
    `РђќLРђќ <= n ¤Ђ_n^2 ╬║(A)`.

    The two containment hypotheses are the remaining recursive GE bookkeeping:
    `hA_le_U` records that the growth object includes the initial matrix, and
    `hS_le_U` records that it includes the current Schur complement. -/
theorem higham13_problem13_4_L21_eq13_22_premise_from_source_growthFactorEntry_exact_kappa
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s) (hN : 0 < r + s)
    (A U : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
    (A11 : Matrix (Fin r) (Fin r) РёЮ)
    (A12 : Matrix (Fin r) (Fin s) РёЮ)
    (A21 : Matrix (Fin s) (Fin r) РёЮ)
    (A22 : Matrix (Fin s) (Fin s) РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    (hA11_block : A11 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)))
    (hA12_block : A12 =
      fun (i : Fin r) (j : Fin s) =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)))
    (hA21_block : A21 =
      fun (i : Fin s) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin s)))
    (hA22_block : A22 =
      fun i j : Fin s =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin s))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin s)))
    (hApos : 0 < maxEntryNorm hN A)
    (n : РёЋ)
    (hsn : (s : РёЮ) РЅц (n : РёЮ))
    (hA_le_U : maxEntryNorm hN A РЅц maxEntryNorm hN U)
    (hS_le_U :
      maxEntryNormRect hs hs (A22 - A21 * РЁЪA11 * A12) РЅц
        maxEntryNorm hN U) :
    maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
        (n : РёЮ) * (growthFactorEntry hN A U hApos) ^ 2 *
          (maxEntryNormRect hN hN A *
            maxEntryNormRect hN hN (nonsingInv (r + s) A)) := by
  let rho : РёЮ := growthFactorEntry hN A U hApos
  let kappaA : РёЮ :=
    maxEntryNormRect hN hN A *
      maxEntryNormRect hN hN (nonsingInv (r + s) A)
  have hProblem :
      maxEntryNormRect hs hr ((A21 * РЁЪA11 : Matrix (Fin s) (Fin r) РёЮ)) РЅц
        (n : РёЮ) * rho * kappaA := by
    have hpair :=
      higham13_problem13_4_maxEntry_bounds_from_source_growthFactorEntry_exact_kappa
        hr hs hN A U A11 A12 A21 A22
        hA11_block hA12_block hA21_block hA22_block
        hApos n hsn hS_le_U
    simpa [rho, kappaA] using hpair.1
  have hrho_ge_one : 1 РЅц rho := by
    simpa [rho] using
      growthFactorEntry_ge_one_of_maxEntryNorm_le hN A U hApos hA_le_U
  have hrho_nonneg : 0 РЅц rho := le_trans zero_le_one hrho_ge_one
  have hkappa_nonneg : 0 РЅц kappaA := by
    exact mul_nonneg (maxEntryNormRect_nonneg hN hN A)
      (maxEntryNormRect_nonneg hN hN (nonsingInv (r + s) A))
  have hn_nonneg : 0 РЅц (n : РёЮ) := Nat.cast_nonneg n
  have hrho_le_sq : rho РЅц rho ^ 2 := by
    have hmul := mul_le_mul_of_nonneg_left hrho_ge_one hrho_nonneg
    simpa [pow_two] using hmul
  have hfactor :
      (n : РёЮ) * rho * kappaA РЅц (n : РёЮ) * rho ^ 2 * kappaA := by
    exact mul_le_mul_of_nonneg_right
      (mul_le_mul_of_nonneg_left hrho_le_sq hn_nonneg) hkappa_nonneg
  exact le_trans hProblem (by simpa [rho, kappaA] using hfactor)

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    source local lower-block estimate with the one-growth-factor budget used
    by the text before the ambient Eq.13.22/Eq.13.23 comparison.

    This is the direct lower-left half of Problem 13.4 for a square local
    `2 x 2` partition.  It keeps the local growth factor and local exact-╬║
    object visible, instead of immediately enlarging them to the ambient
    `rho^2 * kappa(A)` budget. -/
theorem higham13_problem13_4_single_block_source_lblock_bound_from_local_growth
    {r : РёЋ} (hr : 0 < r)
    (A11 A12 A21 A22 P : Matrix (Fin r) (Fin r) РёЮ)
    (U : Fin (r + r) Рєњ Fin (r + r) Рєњ РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    (hpivot : P = РЁЪA11)
    (hApos :
      0 < maxEntryNorm (Nat.add_pos_left hr r)
        (fun p q : Fin (r + r) =>
          (Matrix.fromBlocks A11 A12 A21 A22)
            (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)))
    (hS_le_U :
      maxEntryNormRect hr hr (A22 - A21 * РЁЪA11 * A12) РЅц
        maxEntryNorm (Nat.add_pos_left hr r) U) :
    maxEntryNorm hr (A21 * P) РЅц
      (r : РёЮ) *
        growthFactorEntry (Nat.add_pos_left hr r)
          (fun p q : Fin (r + r) =>
            (Matrix.fromBlocks A11 A12 A21 A22)
              (finSumFinEquiv.symm p) (finSumFinEquiv.symm q))
          U hApos *
        (maxEntryNormRect (Nat.add_pos_left hr r) (Nat.add_pos_left hr r)
            (fun p q : Fin (r + r) =>
              (Matrix.fromBlocks A11 A12 A21 A22)
                (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)) *
          maxEntryNormRect (Nat.add_pos_left hr r) (Nat.add_pos_left hr r)
            (nonsingInv (r + r)
              (fun p q : Fin (r + r) =>
                (Matrix.fromBlocks A11 A12 A21 A22)
                  (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)))) := by
  subst P
  let hN : 0 < r + r := Nat.add_pos_left hr r
  let A : Fin (r + r) Рєњ Fin (r + r) Рєњ РёЮ :=
    fun p q =>
      (Matrix.fromBlocks A11 A12 A21 A22)
        (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)
  have hA11_block : A11 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_castAdd, finSumFinEquiv_symm_apply_castAdd]
    simp
  have hA12_block : A12 =
      fun (i : Fin r) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_castAdd, finSumFinEquiv_symm_apply_natAdd]
    simp
  have hA21_block : A21 =
      fun (i : Fin r) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_natAdd, finSumFinEquiv_symm_apply_castAdd]
    simp
  have hA22_block : A22 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_natAdd, finSumFinEquiv_symm_apply_natAdd]
    simp
  have hpair :=
    higham13_problem13_4_maxEntry_bounds_from_source_growthFactorEntry_exact_kappa
      hr hr hN A U A11 A12 A21 A22
      hA11_block hA12_block hA21_block hA22_block
      hApos r le_rfl
      (by simpa [hN, A] using hS_le_U)
  calc
    maxEntryNorm hr ((A21 * РЁЪA11 : Matrix (Fin r) (Fin r) РёЮ))
        = maxEntryNormRect hr hr ((A21 * РЁЪA11 : Matrix (Fin r) (Fin r) РёЮ)) := by
          rw [maxEntryNormRect_eq_maxEntryNorm hr]
    _ РЅц (r : РёЮ) *
          growthFactorEntry hN A U hApos *
          (maxEntryNormRect hN hN A *
            maxEntryNormRect hN hN (nonsingInv (r + r) A)) :=
          hpair.1
    _ = (r : РёЮ) *
          growthFactorEntry (Nat.add_pos_left hr r)
            (fun p q : Fin (r + r) =>
              (Matrix.fromBlocks A11 A12 A21 A22)
                (finSumFinEquiv.symm p) (finSumFinEquiv.symm q))
            U hApos *
          (maxEntryNormRect (Nat.add_pos_left hr r) (Nat.add_pos_left hr r)
              (fun p q : Fin (r + r) =>
                (Matrix.fromBlocks A11 A12 A21 A22)
                  (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)) *
            maxEntryNormRect (Nat.add_pos_left hr r) (Nat.add_pos_left hr r)
              (nonsingInv (r + r)
                (fun p q : Fin (r + r) =>
                  (Matrix.fromBlocks A11 A12 A21 A22)
                    (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)))) := by
          rfl

/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    single block multiplier bound from a local two-block growth budget.

    A block multiplier `AРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣` appearing in one Algorithm 13.3 stage is
    the lower-left product in a local `2 ├Ќ 2` block partition.  This theorem
    applies the source Problem 13.4 lower-left bridge to that local partition
    and then allows the local `¤Ђ┬▓╬║(A)` budget to be compared with any ambient
    source budget `C`.

    The comparison hypothesis is intentionally explicit: the theorem closes the
    lower-left multiplier extraction, while the recursive Schur-condition
    propagation that supplies the ambient budget remains a separate source
    obligation. -/
theorem higham13_problem13_4_single_block_multiplier_bound_from_local_growth_budget
    {r : РёЋ} (hr : 0 < r)
    (A11 A12 A21 A22 P : Matrix (Fin r) (Fin r) РёЮ)
    (U : Fin (r + r) Рєњ Fin (r + r) Рєњ РёЮ)
    [Invertible A11] [Invertible (A22 - A21 * РЁЪA11 * A12)]
    [Invertible (Matrix.fromBlocks A11 A12 A21 A22)]
    (hpivot : P = РЁЪA11)
    (hApos :
      0 < maxEntryNorm (Nat.add_pos_left hr r)
        (fun p q : Fin (r + r) =>
          (Matrix.fromBlocks A11 A12 A21 A22)
            (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)))
    (n : РёЋ) (hrn : (r : РёЮ) РЅц (n : РёЮ))
    (hA_le_U :
      maxEntryNorm (Nat.add_pos_left hr r)
          (fun p q : Fin (r + r) =>
            (Matrix.fromBlocks A11 A12 A21 A22)
              (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)) РЅц
        maxEntryNorm (Nat.add_pos_left hr r) U)
    (hS_le_U :
      maxEntryNormRect hr hr (A22 - A21 * РЁЪA11 * A12) РЅц
        maxEntryNorm (Nat.add_pos_left hr r) U)
    {C : РёЮ}
    (hBudget :
      (growthFactorEntry (Nat.add_pos_left hr r)
          (fun p q : Fin (r + r) =>
            (Matrix.fromBlocks A11 A12 A21 A22)
              (finSumFinEquiv.symm p) (finSumFinEquiv.symm q))
          U hApos) ^ 2 *
        (maxEntryNormRect (Nat.add_pos_left hr r) (Nat.add_pos_left hr r)
            (fun p q : Fin (r + r) =>
              (Matrix.fromBlocks A11 A12 A21 A22)
                (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)) *
          maxEntryNormRect (Nat.add_pos_left hr r) (Nat.add_pos_left hr r)
            (nonsingInv (r + r)
              (fun p q : Fin (r + r) =>
                (Matrix.fromBlocks A11 A12 A21 A22)
                  (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)))) РЅц C) :
    maxEntryNorm hr (A21 * P) РЅц (n : РёЮ) * C := by
  subst P
  let hN : 0 < r + r := Nat.add_pos_left hr r
  let A : Fin (r + r) Рєњ Fin (r + r) Рєњ РёЮ :=
    fun p q =>
      (Matrix.fromBlocks A11 A12 A21 A22)
        (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)
  let localKappa : РёЮ :=
    maxEntryNormRect hN hN A *
      maxEntryNormRect hN hN (nonsingInv (r + r) A)
  have hA11_block : A11 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_castAdd, finSumFinEquiv_symm_apply_castAdd]
    simp
  have hA12_block : A12 =
      fun (i : Fin r) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inl i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_castAdd, finSumFinEquiv_symm_apply_natAdd]
    simp
  have hA21_block : A21 =
      fun (i : Fin r) (j : Fin r) =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inl j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_natAdd, finSumFinEquiv_symm_apply_castAdd]
    simp
  have hA22_block : A22 =
      fun i j : Fin r =>
        A (finSumFinEquiv (Sum.inr i : Fin r РіЋ Fin r))
          (finSumFinEquiv (Sum.inr j : Fin r РіЋ Fin r)) := by
    ext i j
    dsimp [A]
    rw [finSumFinEquiv_symm_apply_natAdd, finSumFinEquiv_symm_apply_natAdd]
    simp
  have hLocal :
      maxEntryNormRect hr hr ((A21 * РЁЪA11 : Matrix (Fin r) (Fin r) РёЮ)) РЅц
        (n : РёЮ) * (growthFactorEntry hN A U hApos) ^ 2 * localKappa := by
    exact
      higham13_problem13_4_L21_eq13_22_premise_from_source_growthFactorEntry_exact_kappa
        hr hr hN A U A11 A12 A21 A22
        hA11_block hA12_block hA21_block hA22_block
        hApos n hrn
        (by simpa [hN, A] using hA_le_U)
        (by simpa [hN, A] using hS_le_U)
  have hBudget' :
      (growthFactorEntry hN A U hApos) ^ 2 * localKappa РЅц C := by
    simpa [hN, A, localKappa] using hBudget
  have hmul :
      (n : РёЮ) * ((growthFactorEntry hN A U hApos) ^ 2 * localKappa) РЅц
        (n : РёЮ) * C :=
    mul_le_mul_of_nonneg_left hBudget' (Nat.cast_nonneg n)
  calc
    maxEntryNorm hr ((A21 * РЁЪA11 : Matrix (Fin r) (Fin r) РёЮ))
        = maxEntryNormRect hr hr ((A21 * РЁЪA11 : Matrix (Fin r) (Fin r) РёЮ)) := by
            rw [maxEntryNormRect_eq_maxEntryNorm hr]
    _ РЅц (n : РёЮ) * (growthFactorEntry hN A U hApos) ^ 2 * localKappa := hLocal
    _ = (n : РёЮ) * ((growthFactorEntry hN A U hApos) ^ 2 * localKappa) := by
          ring
    _ РЅц (n : РёЮ) * C := hmul

/-- A matrix right-inverse certificate identifies the supplied inverse with
    Mathlib's `РЁЪ` inverse for an `Invertible` matrix. -/
theorem matrix_invOf_eq_of_isRightInverse {r : РёЋ}
    (A P : Matrix (Fin r) (Fin r) РёЮ) [Invertible A]
    (hRight : IsRightInverse r A P) :
    P = РЁЪA := by
  symm
  apply invOf_eq_right_inv
  ext i j
  simpa [Matrix.mul_apply] using hRight i j

/-- The local `2 ├Ќ 2` block matrix seen by one Algorithm 13.3 multiplier.

    For an active lower multiplier in column `j` and row `i`, the local
    Problem 13.4 partition is formed from the stage-`j` blocks
    `(j,j)`, `(j,i)`, `(i,j)`, and `(i,i)`. -/
noncomputable def higham13_algorithm13_3_stageLocalBlockMatrix {m r : РёЋ}
    (Ablk : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (i j : Fin m) :
    Matrix (Fin r РіЋ Fin r) (Fin r РіЋ Fin r) РёЮ :=
  Matrix.fromBlocks
    (higham13_algorithm13_3_schurStageMatrixBlock Ablk pivotInv j.val j j)
    (higham13_algorithm13_3_schurStageMatrixBlock Ablk pivotInv j.val j i)
    (higham13_algorithm13_3_schurStageMatrixBlock Ablk pivotInv j.val i j)
    (higham13_algorithm13_3_schurStageMatrixBlock Ablk pivotInv j.val i i)

/-- The scalar `Fin (r+r)` flattening of the local `2 ├Ќ 2` stage matrix. -/
noncomputable def higham13_algorithm13_3_stageLocalFlatMatrix {m r : РёЋ}
    (Ablk : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (i j : Fin m) :
    Fin (r + r) Рєњ Fin (r + r) Рєњ РёЮ :=
  fun p q =>
    higham13_algorithm13_3_stageLocalBlockMatrix Ablk pivotInv i j
      (finSumFinEquiv.symm p) (finSumFinEquiv.symm q)

/-- The local `2 ├Ќ 2` stage matrix has positive flattened max-entry norm when
    the unflattened block matrix is invertible. -/
theorem higham13_algorithm13_3_stageLocalFlatMatrix_pos_of_invertible
    {m r : РёЋ} (hr : 0 < r)
    (Ablk : Fin m Рєњ Fin m Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (pivotInv : РёЋ Рєњ Matrix (Fin r) (Fin r) РёЮ)
    (i j : Fin m)
    [Invertible (higham13_algorithm13_3_stageLocalBlockMatrix Ablk pivotInv i j)] :
    0 < maxEntryNorm (Nat.add_pos_left hr r)
      (higham13_algorithm13_3_stageLocalFlatMatrix Ablk pivotInv i j) := by
  let M : Matrix (Fin r РіЋ Fin r) (Fin r РіЋ Fin r) РёЮ :=
    higham13_algorithm13_3_stageLocalBlockMatrix Ablk pivotInv i j
  let e : Fin (r + r) РЅЃ Fin r РіЋ Fin r := finSumFinEquiv.symm
  letI : Invertible (M.submatrix e e) :=
    Matrix.submatrixEquivInvertible M e e
  have hpos := maxEntryNorm_pos_of_invertible (Nat.add_pos_left hr r)
    (M.submatrix e e)
