    higham13_algorithm13_3_normedStageHistoryBound_contains_stage
      hm A pivotInv 0 (Nat.zero_le m)

/-- The source-norm history bound is nonnegative. -/
lemma higham13_algorithm13_3_normedStageHistoryBound_nonneg {m : РёЋ}
    {╬▒ : Type*} [SeminormedRing ╬▒]
    (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ ╬▒) (pivotInv : РёЋ Рєњ ╬▒) :
    0 РЅц higham13_algorithm13_3_normedStageHistoryBound hm A pivotInv := by
