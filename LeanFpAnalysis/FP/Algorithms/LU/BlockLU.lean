-- ┬Д13.3.1  Equation 13.18 proof-chain pieces
-- ============================================================

/-- **Equation (13.18), min-step abstraction**.

    Higham's proof uses the reverse triangle inequality to pass from
    `min_{РђќxРђќ=1} РђќA_jj xРђќ - c` to
    `min_{РђќxРђќ=1} Рђќ(A_jj - A_j1 A_11^{-1} A_1j) xРђќ`.  This lemma records that
    normed-space step without choosing a concrete subordinate matrix norm. -/
theorem higham13_eq13_18_min_lower_bound {E : Type*}
    [SeminormedAddCommGroup E]
    (diag perturb schur : E Рєњ E) (diagMin schurMin perturbBound : РёЮ)
    (hDiagMin : Рѕђ x : E, РђќxРђќ = 1 Рєњ diagMin РЅц Рђќdiag xРђќ)
    (hSchurMin : РѕЃ x : E, РђќxРђќ = 1 РѕД schurMin = Рђќschur xРђќ)
    (hPerturb : Рѕђ x : E, РђќxРђќ = 1 Рєњ Рђќperturb xРђќ РЅц perturbBound)
    (hSchur : Рѕђ x : E, schur x = diag x - perturb x) :
    diagMin - perturbBound РЅц schurMin := by
  rcases hSchurMin with РЪеx, hxUnit, hxMinРЪЕ
  calc
    diagMin - perturbBound РЅц Рђќdiag xРђќ - perturbBound :=
      sub_le_sub_right (hDiagMin x hxUnit) perturbBound
    _ РЅц Рђќdiag xРђќ - Рђќperturb xРђќ :=
      sub_le_sub_left (hPerturb x hxUnit) Рђќdiag xРђќ
    _ РЅц Рђќdiag x - perturb xРђќ := norm_sub_norm_le (diag x) (perturb x)
    _ = schurMin := by rw [Рєљ hSchur x, hxMin]

/-- **Equation (13.18), Euclidean min-step abstraction**.

    This is the explicit `vecNorm2` version of
    `higham13_eq13_18_min_lower_bound`.  It is used when the block norm is
    represented by the repository's concrete finite-vector Euclidean norm rather
    than by the ambient typeclass norm on `Fin r Рєњ РёЮ`. -/
theorem higham13_eq13_18_vecNorm2_min_lower_bound {r : РёЋ}
    (diag perturb schur : (Fin r Рєњ РёЮ) Рєњ (Fin r Рєњ РёЮ))
    (diagMin schurMin perturbBound : РёЮ)
    (hDiagMin : Рѕђ x : Fin r Рєњ РёЮ, vecNorm2 x = 1 Рєњ
      diagMin РЅц vecNorm2 (diag x))
    (hSchurMin : РѕЃ x : Fin r Рєњ РёЮ, vecNorm2 x = 1 РѕД
      schurMin = vecNorm2 (schur x))
    (hPerturb : Рѕђ x : Fin r Рєњ РёЮ, vecNorm2 x = 1 Рєњ
      vecNorm2 (perturb x) РЅц perturbBound)
    (hSchur : Рѕђ x : Fin r Рєњ РёЮ,
      schur x = fun i => diag x i - perturb x i) :
    diagMin - perturbBound РЅц schurMin := by
  rcases hSchurMin with РЪеx, hxUnit, hxMinРЪЕ
  calc
    diagMin - perturbBound РЅц vecNorm2 (diag x) - perturbBound :=
      sub_le_sub_right (hDiagMin x hxUnit) perturbBound
    _ РЅц vecNorm2 (diag x) - vecNorm2 (perturb x) :=
      sub_le_sub_left (hPerturb x hxUnit) (vecNorm2 (diag x))
    _ РЅц vecNorm2 (fun i => diag x i - perturb x i) :=
      (le_abs_self _).trans
        (abs_vecNorm2_sub_le_vecNorm2_sub (diag x) (perturb x))
    _ = schurMin := by rw [Рєљ hSchur x, hxMin]

/-- **Equation (13.18), scalar column-chain part**.

    From block column diagonal dominance (13.17), submultiplicativity for
    `РђќA_11^{-1}Рђќ`, and the Schur off-diagonal triangle bound, the off-diagonal
    column sum in the first Schur complement is bounded by
    `РђќA_jj^{-1}Рђќ^{-1} - РђќA_j1РђќРђќA_11^{-1}РђќРђќA_1jРђќ`. -/
theorem higham13_eq13_18_scalar_column_chain {m : РёЋ}
    (blockNorm : Fin (m + 1) Рєњ Fin (m + 1) Рєњ РёЮ)
    (hNorm : Рѕђ i j, 0 РЅц blockNorm i j)
    (invDiagBound : Fin (m + 1) Рєњ РёЮ)
    (normInv : РёЮ) (hNormInv : 0 РЅц normInv)
    (hDom : IsBlockDiagDomCol (m + 1) blockNorm invDiagBound)
    (hNormInvBound : normInv * invDiagBound 0 РЅц 1)
    (schurNorm : Fin m Рєњ Fin m Рєњ РёЮ)
    (hSchurBound : Рѕђ i j : Fin m,
      schurNorm i j РЅц blockNorm i.succ j.succ +
        blockNorm i.succ 0 * normInv * blockNorm 0 j.succ) :
    Рѕђ j : Fin m,
      РѕЉ i : Fin m, (if i = j then 0 else schurNorm i j) РЅц
        invDiagBound j.succ - blockNorm j.succ 0 * normInv * blockNorm 0 j.succ := by
  intro j
  calc РѕЉ i : Fin m, (if i = j then 0 else schurNorm i j)
      РЅц РѕЉ i : Fin m, (if i = j then 0 else
          (blockNorm i.succ j.succ +
           blockNorm i.succ 0 * normInv * blockNorm 0 j.succ)) := by
        apply Finset.sum_le_sum; intro i _
        split_ifs with h <;> [exact le_refl 0; exact hSchurBound i j]
    _ = РѕЉ i : Fin m, (if i = j then 0 else blockNorm i.succ j.succ) +
        РѕЉ i : Fin m, (if i = j then 0 else
          blockNorm i.succ 0 * normInv * blockNorm 0 j.succ) := by
        rw [Рєљ Finset.sum_add_distrib]
        apply Finset.sum_congr rfl; intro i _; split_ifs <;> ring
    _ РЅц (invDiagBound j.succ - blockNorm 0 j.succ) +
        normInv * blockNorm 0 j.succ * (invDiagBound 0 - blockNorm j.succ 0) := by
        apply add_le_add
        ┬и have hdom_j := hDom j.succ
          rw [Fin.sum_univ_succ] at hdom_j
          simp only [show ┬г((0 : Fin (m + 1)) = j.succ) from
            fun h => absurd (congr_arg Fin.val h) (by simp)] at hdom_j
          simp_rw [show Рѕђ k : Fin m, (if k.succ = j.succ then (0 : РёЮ)
            else blockNorm k.succ j.succ) =
            if k = j then 0 else blockNorm k.succ j.succ from
            fun k => by congr 1; exact propext Fin.succ_inj] at hdom_j
          simp only [ite_false] at hdom_j
          linarith
        ┬и conv_lhs =>
            arg 2; ext i
            rw [show (if i = j then (0 : РёЮ) else
              blockNorm i.succ 0 * normInv * blockNorm 0 j.succ) =
              normInv * blockNorm 0 j.succ *
              (if i = j then 0 else blockNorm i.succ 0) by split_ifs <;> ring]
          rw [Рєљ Finset.mul_sum]
          apply mul_le_mul_of_nonneg_left _ (mul_nonneg hNormInv (hNorm 0 j.succ))
          have hdom_0 := hDom 0
          rw [Fin.sum_univ_succ] at hdom_0
          simp only [ite_true] at hdom_0
          simp_rw [show Рѕђ k : Fin m, (if k.succ = (0 : Fin (m + 1)) then (0 : РёЮ)
            else blockNorm k.succ 0) = blockNorm k.succ 0 from
            fun k => by simp [Fin.succ_ne_zero]] at hdom_0
          have hsplit : РѕЉ k : Fin m, blockNorm k.succ 0 =
              blockNorm j.succ 0 +
              РѕЉ i : Fin m, (if i = j then 0 else blockNorm i.succ 0) := by
            have h1 : Рѕђ k : Fin m, blockNorm k.succ 0 =
              (if k = j then blockNorm k.succ 0 else 0) +
              (if k = j then 0 else blockNorm k.succ 0) :=
              fun k => by split_ifs <;> simp
            conv_lhs => arg 2; ext k; rw [h1 k]
            rw [Finset.sum_add_distrib]
            congr 1
            simp [Finset.sum_ite_eq', Finset.mem_univ]
          rw [hsplit] at hdom_0; linarith
    _ РЅц invDiagBound j.succ - blockNorm j.succ 0 * normInv * blockNorm 0 j.succ := by
        nlinarith [hNorm 0 j.succ, hNormInvBound]

/-- **Equation (13.18), source-facing Schur column dominance wrapper**.

    The theorem combines the scalar column chain with the min/reverse-triangle
    step.  `diag`, `perturb`, and `schurDiag` abstract the actions of
    `A_jj`, `A_j1 A_11^{-1} A_1j`, and the diagonal Schur block on unit vectors.
    The full Theorem 13.7 still also needs the induction and nonsingularity
    argument around this one-step proof chain. -/
theorem higham13_eq13_18_schur_column_dominance {m : РёЋ} {E : Type*}
    [SeminormedAddCommGroup E]
    (blockNorm : Fin (m + 1) Рєњ Fin (m + 1) Рєњ РёЮ)
    (hNorm : Рѕђ i j, 0 РЅц blockNorm i j)
    (invDiagBound : Fin (m + 1) Рєњ РёЮ)
    (normInv : РёЮ) (hNormInv : 0 РЅц normInv)
    (hDom : IsBlockDiagDomCol (m + 1) blockNorm invDiagBound)
    (hNormInvBound : normInv * invDiagBound 0 РЅц 1)
    (schurNorm : Fin m Рєњ Fin m Рєњ РёЮ)
    (hSchurBound : Рѕђ i j : Fin m,
      schurNorm i j РЅц blockNorm i.succ j.succ +
        blockNorm i.succ 0 * normInv * blockNorm 0 j.succ)
    (diag perturb schurDiag : Fin m Рєњ E Рєњ E)
    (schurDiagMin : Fin m Рєњ РёЮ)
    (hDiagMin : Рѕђ j : Fin m, Рѕђ x : E, РђќxРђќ = 1 Рєњ
      invDiagBound j.succ РЅц Рђќdiag j xРђќ)
    (hSchurMin : Рѕђ j : Fin m,
      РѕЃ x : E, РђќxРђќ = 1 РѕД schurDiagMin j = РђќschurDiag j xРђќ)
    (hPerturb : Рѕђ j : Fin m, Рѕђ x : E, РђќxРђќ = 1 Рєњ
      Рђќperturb j xРђќ РЅц blockNorm j.succ 0 * normInv * blockNorm 0 j.succ)
    (hSchurDiag : Рѕђ j : Fin m, Рѕђ x : E,
      schurDiag j x = diag j x - perturb j x) :
    IsBlockDiagDomCol m schurNorm schurDiagMin := by
  intro j
  calc
    РѕЉ i : Fin m, (if i = j then 0 else schurNorm i j)
        РЅц invDiagBound j.succ - blockNorm j.succ 0 * normInv * blockNorm 0 j.succ :=
      higham13_eq13_18_scalar_column_chain blockNorm hNorm invDiagBound normInv
        hNormInv hDom hNormInvBound schurNorm hSchurBound j
    _ РЅц schurDiagMin j :=
      higham13_eq13_18_min_lower_bound (diag j) (perturb j) (schurDiag j)
        (invDiagBound j.succ) (schurDiagMin j)
        (blockNorm j.succ 0 * normInv * blockNorm 0 j.succ)
        (hDiagMin j) (hSchurMin j) (hPerturb j) (hSchurDiag j)

