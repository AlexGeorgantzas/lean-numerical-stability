theorem higham13_eq13_23_local_product_from_source_growthFactorEntry_exact_kappa
    {r s : ℕ} (hr : 0 < r) (hs : 0 < s) (hN : 0 < r + s)
    (A G Ufac : Fin (r + s) → Fin (r + s) → ℝ)
