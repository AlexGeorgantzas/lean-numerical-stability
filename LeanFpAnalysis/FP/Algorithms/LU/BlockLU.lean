theorem higham13_lemma13_9_cholesky_block_equations_of_cholesky_fact_equiv
    {r s n : РёЋ}
    (e : (Fin r РіЋ Fin s) РЅЃ Fin n)
    (A R : Fin n Рєњ Fin n Рєњ РёЮ)
    (A22 : Fin s Рєњ Fin s Рєњ РёЮ)
    (A21 : Fin s Рєњ Fin r Рєњ РёЮ)
    (R11 : Fin r Рєњ Fin r Рєњ РёЮ)
    (R12 : Fin r Рєњ Fin s Рєњ РёЮ)
    (R22 : Fin s Рєњ Fin s Рєњ РёЮ)
    (hA22_block : A22 =
      fun i j : Fin s => A (e (Sum.inr i)) (e (Sum.inr j)))
    (hA21_block : A21 =
      fun (i : Fin s) (j : Fin r) => A (e (Sum.inr i)) (e (Sum.inl j)))
    (hR11 : Рѕђ i j, R (e (Sum.inl i)) (e (Sum.inl j)) = R11 i j)
    (hR12 : Рѕђ i j, R (e (Sum.inl i)) (e (Sum.inr j)) = R12 i j)
