    {r s : РёЋ} {╬╣ : Type*} [Fintype ╬╣] [Nonempty (Fin r РіЋ Fin s)]
    (e : (Fin r РіЋ Fin s) РЅЃ ╬╣)
    (A Ainv R : ╬╣ Рєњ ╬╣ Рєњ РёЮ)
    (A22 : Fin s Рєњ Fin s Рєњ РёЮ)
