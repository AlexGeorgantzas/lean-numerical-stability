    higham13_lemma13_9_R12_rectOpNorm2Le_of_full_cholesky_block
      (fun i j : Fin r ⊕ Fin s => A (finSumFinEquiv i) (finSumFinEquiv j))
      A22 R12 R22 hNormA_nonneg hA22_block hA22_chol hA_sum
