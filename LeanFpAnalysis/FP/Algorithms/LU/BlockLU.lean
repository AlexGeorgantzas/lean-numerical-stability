        ⅟(blockMatrixFirstSplitA11
          (higham13_algorithm13_3_schurStageMatrixTailBlock A pivotInv k tailFull)))
    (hsn : ((r : ℕ) : ℝ) ≤ (n : ℝ))
    (hA_le_G :
      maxEntryNorm hN Aglob ≤
        maxEntryNorm hN
          (higham13_algorithm13_3_matrixStageHistoryGrowthMatrix hN hM hr A pivotInv))
    (hAinv_entry :
