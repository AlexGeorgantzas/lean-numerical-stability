    calc
      |Sinv i j| = |Ainv (Sum.inr i) (Sum.inr j)| := by rw [hSinv]
      _ РЅц normAinv := hAinv_entry (Sum.inr i) (Sum.inr j)
  exact maxEntryNormRect_le_of_entry_abs_le hs hs Sinv normAinv hSinv_entry

