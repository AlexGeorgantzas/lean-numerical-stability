    intro i j
    simpa [normMax] using higham13_block_norm_le_blockNormSup hm A i j
  have hPivotBound :
      Рѕђ k : РёЋ, Рѕђ hk : k < m,
        higham13_algorithm13_3_pivotInvNorm pivotInv k *
