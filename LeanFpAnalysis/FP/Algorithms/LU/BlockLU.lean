theorem higham13_algorithm13_3_matrixStageHistoryBound_contains_upperFromMatrixStages
    {m r : ℕ} (hm : 0 < m) (hr : 0 < r)
    (A : Fin m → Fin m → Matrix (Fin r) (Fin r) ℝ)
