    (stageInvDiagBound : РёЋ Рєњ Fin m Рєњ РёЮ)
    (hInit : Рѕђ i j : Fin m, stageBlock 0 i j = A i j)
    (hDomInf : IsBlockDiagDomCol m (fun i j : Fin m => infNorm (A i j)) invDiagBound)
    (hDiagMax : Рѕђ j : Fin m, invDiagBound j РЅц maxEntryNorm hr (A j j))
