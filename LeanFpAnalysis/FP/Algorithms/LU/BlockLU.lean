/-- Higham, 2nd ed., Chapter 13, Problem 13.4:
    max-entry-norm product bridge for the lower-left solve
    `AРѓѓРѓЂ AРѓЂРѓЂРЂ╗┬╣`.

    The source exercise sets `||A|| := max_ij |a_ij|`.  This theorem proves
    the exact max-entry product propagation once the growth-factor route has
    supplied `||AРѓѓРѓЂ||_max <= rho ||A||`, the principal-inverse route has
    supplied `||AРѓЂРѓЂРЂ╗┬╣||_max <= ||AРЂ╗┬╣||`, and the displayed condition-number
    product has supplied `||A|| ||AРЂ╗┬╣|| <= kappa(A)`. -/
theorem higham13_problem13_4_A21A11inv_maxEntryNormRect_from_growth_certificates
    {r s : РёЋ} (hr : 0 < r) (hs : 0 < s)
    (A21 : Fin s Рєњ Fin r Рєњ РёЮ) (A11inv : Fin r Рєњ Fin r Рєњ РёЮ)
    {normA normAinv rho kappaA : РёЮ} (n : РёЋ)
    (hRho : 0 РЅц rho) (hKappa : 0 РЅц kappaA)
    (hrn : (r : РёЮ) РЅц (n : РёЮ))
    (hA21_bound : maxEntryNormRect hs hr A21 РЅц rho * normA)
    (hA11inv_bound : maxEntryNormRect hr hr A11inv РЅц normAinv)
    (hkappa : normA * normAinv РЅц kappaA) :
    maxEntryNormRect hs hr (rectMatMul A21 A11inv) РЅц
      (n : РёЮ) * rho * kappaA := by
  let normA21 : РёЮ := maxEntryNormRect hs hr A21
  let normA11inv : РёЮ := maxEntryNormRect hr hr A11inv
  have hProduct :
      maxEntryNormRect hs hr (rectMatMul A21 A11inv) РЅц
        (r : РёЮ) * normA21 * normA11inv := by
    simpa [normA21, normA11inv] using
      maxEntryNormRect_rectMatMul_le hs hr hr A21 A11inv
  have hNormA21_nonneg : 0 РЅц normA21 :=
    maxEntryNormRect_nonneg hs hr A21
  have hNormA11inv_nonneg : 0 РЅц normA11inv :=
    maxEntryNormRect_nonneg hr hr A11inv
  have hRhoNormA_nonneg : 0 РЅц rho * normA :=
    le_trans hNormA21_nonneg (by simpa [normA21] using hA21_bound)
  have hAinv_nonneg : 0 РЅц normAinv :=
    le_trans hNormA11inv_nonneg (by simpa [normA11inv] using hA11inv_bound)
  have hNormProduct :
      normA21 * normA11inv РЅц rho * kappaA := by
    have hmul :
        normA21 * normA11inv РЅц (rho * normA) * normAinv :=
      mul_le_mul
        (by simpa [normA21] using hA21_bound)
        (by simpa [normA11inv] using hA11inv_bound)
        hNormA11inv_nonneg hRhoNormA_nonneg
    calc
      normA21 * normA11inv РЅц (rho * normA) * normAinv := hmul
      _ = rho * (normA * normAinv) := by ring
      _ РЅц rho * kappaA := mul_le_mul_of_nonneg_left hkappa hRho
  have hScaleR :
      (r : РёЮ) * normA21 * normA11inv РЅц (r : РёЮ) * (rho * kappaA) := by
    calc
      (r : РёЮ) * normA21 * normA11inv = (r : РёЮ) * (normA21 * normA11inv) := by
        ring
      _ РЅц (r : РёЮ) * (rho * kappaA) :=
        mul_le_mul_of_nonneg_left hNormProduct (Nat.cast_nonneg r)
  have hScaleN :
      (r : РёЮ) * (rho * kappaA) РЅц (n : РёЮ) * (rho * kappaA) :=
    mul_le_mul_of_nonneg_right hrn (mul_nonneg hRho hKappa)
  calc
    maxEntryNormRect hs hr (rectMatMul A21 A11inv)
        РЅц (r : РёЮ) * normA21 * normA11inv := hProduct
    _ РЅц (r : РёЮ) * (rho * kappaA) := hScaleR
    _ РЅц (n : РёЮ) * (rho * kappaA) := hScaleN
    _ = (n : РёЮ) * rho * kappaA := by ring

