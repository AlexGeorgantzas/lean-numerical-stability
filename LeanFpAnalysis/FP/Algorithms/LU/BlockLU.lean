theorem
    higham13_lemma13_9_cholesky_route_rectOpNorm2Le_from_cholesky_fact_fin_sum_spd_and_principal_inverse_eigenvalue_upper
    {r s : РёЋ} [Nonempty (Fin r)]
    (A R : Fin (r + s) Рєњ Fin (r + s) Рєњ РёЮ)
