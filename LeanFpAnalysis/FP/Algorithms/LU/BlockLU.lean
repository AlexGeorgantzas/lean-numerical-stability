/-- Higham, 2nd ed., Chapter 13, Theorem 13.8:
    source-norm stage-history bound from the one-sided active diagonal
    certificate. -/
theorem
    higham13_algorithm13_3_normedStageHistoryBound_le_two_of_column_bdd_diag_lower
    {m : РёЋ} {╬▒ : Type*} [SeminormedRing ╬▒]
    (hm : 0 < m)
    (A : Fin m Рєњ Fin m Рєњ ╬▒) (pivotInv : РёЋ Рєњ ╬▒)
    (invDiagBound : Fin m Рєњ РёЮ)
    (stageInvDiagBound : РёЋ Рєњ Fin m Рєњ РёЮ)
    (hDom : IsBlockDiagDomCol m
      (fun i j : Fin m => РђќA i jРђќ) invDiagBound)
    (hDiagBound : Рѕђ j : Fin m, invDiagBound j РЅц РђќA j jРђќ)
