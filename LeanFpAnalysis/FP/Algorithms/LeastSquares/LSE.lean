theorem theorem20_10_partB_backward_error_of_constructed_source_householder_rhs_conservative_bound
    {r p q : ℕ} (fp : FPModel)
    {A : Fin (r + q) → Fin (p + q) → ℝ}
    {B : Fin p → Fin (p + q) → ℝ}
    (h : GeneralizedQRFactorization r p q A B)
    (b : Fin (r + q) → ℝ) (d : Fin p → ℝ)
    (gammaA gammaB : ℝ)
    (hUfl :
