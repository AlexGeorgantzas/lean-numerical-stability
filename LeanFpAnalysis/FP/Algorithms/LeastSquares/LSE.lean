    linarith
  have hop_nonneg : 0 ≤ op := by
    dsimp [op]
    exact complexMatrixOp2_nonneg (realRectToCMatrix Aleft)
  exact lt_of_le_of_ne hop_nonneg (Ne.symm hop_ne)

