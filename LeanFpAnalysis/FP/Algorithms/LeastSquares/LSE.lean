              (fun k => b k + Deltab k) (Fin.natAdd r j) =
            beta j) ∧
        ((∀ i : Fin p, hpert.S i i ≠ 0) →
          (∀ i : Fin q, hpert.L22 i i ≠ 0) →
          ∃ (DeltaS : Fin p → Fin p → ℝ)
            (DeltaL22 : Fin q → Fin q → ℝ),
            (∀ i j, |DeltaS i j| ≤ gamma fp p * |hpert.S i j|) ∧
