      theorem20_8_vecNorm2_APplus_data_forcing_difference_le_of_maxRelativePerturbation
        A DeltaA b Deltab B DeltaB d Deltad APplus y x
        hApos hbpos hBpos hdpos hmax
  calc
    vecNorm2
        (fun j : Fin n =>
