      frobNormRect DeltaB ≤ gammaB * frobNormRect B ∧
      vecNorm2 Deltab ≤
        gammaA * vecNorm2 b + gammaB * frobNormRect A * vecNorm2 xhat ∧
      vecNorm2 Deltad ≤ gammaB * frobNormRect B * vecNorm2 xhat ∧
      (∃ hpert : GeneralizedQRFactorization r p q
