    (hvalidB :
      gammaValid fp (p * householderConstructApplyGammaIndex (p + q)))
    (hhalf :
      ((householderQRRhsPanelGammaClosedGrowthIndex (r + q) q : ℝ) *
        fp.u ≤ 1 / 2)) :
    let Qb : Fin (p + q) → Fin (p + q) → ℝ :=
      fl_householderQRPanel_Q fp (p + q) p (finiteTranspose B)
