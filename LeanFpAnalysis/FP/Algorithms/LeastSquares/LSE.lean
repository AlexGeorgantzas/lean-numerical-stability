theorem theorem20_10_partB_backward_error_of_constructed_householder_returned_xhat_computed_B_transpose_Q_source_ranks_unit_roundoff_smallnessThreshold_conservative_gamma
    {r p q : ℕ} (fp : FPModel)
    (A : Fin (r + q) → Fin (p + q) → ℝ)
