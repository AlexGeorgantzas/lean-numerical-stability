  have hidxB :
      0 <
        (((p * householderConstructApplyGammaIndex (p + q) : ℕ) : ℝ)) := by
    exact_mod_cast hidxB_nat
  have hidxRhs :
      0 <
        ((householderQRRhsPanelGammaClosedGrowthIndex (r + q) q : ℕ) : ℝ) := by
