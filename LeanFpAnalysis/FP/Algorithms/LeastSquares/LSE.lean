    (hstack : LSEStackedFullColumnRank A B)
    (hstackPert : LSEStackedFullColumnRank
      (fun i j => A i j + DeltaA i j)
      (fun i j => B i j + DeltaB i j))
    (hx : IsLSEMinimizer A b B d x)
    (hy : IsLSEMinimizer
