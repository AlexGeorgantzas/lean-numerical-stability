  apply theorem20_7_alphaBetaMax_le_of_alpha_beta_le
  · intro i
    exact theorem20_7_alpha_le_of_entry_growth hn Astage A i (hdenA i)
      (fun k j => hA i k j)
  · intro i
    apply theorem20_7_beta_le_of_component_bounds hn Astage A bstage b phi i
