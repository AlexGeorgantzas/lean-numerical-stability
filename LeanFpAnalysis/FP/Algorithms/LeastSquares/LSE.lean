    (hexact :
      ∀ i : Fin m, i.val + 1 < n → ∀ j : Fin n, i.val ≤ j.val →
        |matMulVec m (householder m (v i.val) (beta i.val))
            (fun r => Astage i.val r j) i| ≤
          H19.Theorem19_6.active_row_growth_factor m * B i)
    (hbudget :
      ∀ i : Fin m, i.val + 1 < n → ∀ j : Fin n, i.val ≤ j.val →
        H19.Theorem19_6.active_row_growth_factor m * B i +
