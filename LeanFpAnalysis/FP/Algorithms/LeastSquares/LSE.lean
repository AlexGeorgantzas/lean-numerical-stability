                (fun i => b i + Deltab i) (Fin.natAdd r i) -
                rectMatMulVec hpert.L21 yz.1 i) ∧
          IsLSEMinimizer
            (fun i j => A i j + DeltaA i j)
            (fun i => b i + Deltab i)
            (fun i j => B i j + DeltaB i j)
            (fun i => d i + Deltad i)
            (matMulVec (p + q) hpert.Q (Fin.append yz.1 yz.2))) ∧
        (∃! x : Fin (p + q) → ℝ,
