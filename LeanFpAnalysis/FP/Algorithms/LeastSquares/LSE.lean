  have hdata :
      vecNorm2 (fun j : Fin n => dataY j - dataX j) ≤
        complexMatrixOp2 (realRectToCMatrix APplus) *
          ((eps * frobNormRect A) * vecNorm2 (fun j : Fin n => y j - x j)) := by
    dsimp [dataY, dataX]
