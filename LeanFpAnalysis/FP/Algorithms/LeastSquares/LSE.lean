        (rectMatMulVec A
          (rectMatMulVec APplus
            (rectMatMulVec A
              (rectMatMulVec Bplus
                (fun i : Fin p => Deltad i - rectMatMulVec DeltaB y i))))) ≤
      theorem20_8KappaB A APplus *
