    composition step. -/
theorem theorem20_10_householder_constructed_perturbed_gqr_reversed_rhs_tail_partA_certificate_of_diagonal
    {r p q : ℕ} (fp : FPModel)
    (A : Fin (r + q) → Fin (p + q) → ℝ)
    (B : Fin p → Fin (p + q) → ℝ)
    (b : Fin (r + q) → ℝ) (d : Fin p → ℝ)
