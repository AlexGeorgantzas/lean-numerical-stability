        (fun i j => A i j + DeltaA i j)
        (fun i => b i + Deltab i)
        (fun i j => B i j + DeltaB i j)
        (fun i => d i + Deltad i) y :=
  theorem20_8_exists_unique_perturbed_lse_minimizer_of_relativePerturbationBudget_lt_margins
