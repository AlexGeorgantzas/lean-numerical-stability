    (hAPdiff :
      rectMatMulVec (theorem20_8AP A B Bplus)
          (fun k : Fin n => y k - x k) =
        fun i : Fin m =>
          (rectMatMulVec DeltaA y i - Deltab i) -
            rectMatMulVec A
              (rectMatMulVec Bplus
