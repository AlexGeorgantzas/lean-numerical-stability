          (fun i => b i + Deltab i)
          (fun i j => B i j + DeltaB i j)
          (fun i => d i + Deltad i) y ∧
      IsLeastSquaresMinimizer
          (theorem20_8AP (fun i j => A i j + DeltaA i j)
            (fun i j => B i j + DeltaB i j)
            (theorem20_8_conditions20_24_of_maxRelativePerturbation_lt_margins
