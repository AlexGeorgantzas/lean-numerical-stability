    (hL22diag_pert : ∀ i : Fin q, hpert.L22 i i ≠ 0)
    (hSeq :
      rectMatMulVec (fun i j => h.S i j + DeltaS i j)
        (theorem20_10_gqr_y1hat fp h d) = d)
    (hL22eq :
      rectMatMulVec (fun i j => h.L22 i j + DeltaL22 i j)
