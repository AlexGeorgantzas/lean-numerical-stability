          (rectMatMulVec APplus (fun i : Fin m => forcingY i - forcingX i)) := by
    simpa [forcingY, forcingX] using
      congrArg vecNorm2 (rectMatMulVec_sub APplus forcingY forcingX).symm
  have hforcing_norm :
