    ∃ DeltaB : Fin p → Fin (p + q) → ℝ,
    ∃ Deltab : Fin (r + q) → ℝ,
    ∃ Deltad : Fin p → ℝ,
      (∀ i,
        rectMatMulVec (fun i j => B i j + DeltaB i j) xhat i =
          rectMatMulVec B xhat i + Deltad i) ∧
