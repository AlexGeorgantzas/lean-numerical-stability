              H19.Theorem19_6.rowwise_step_growth_factor ^ (i.val + 1) +
            err) *
            theorem20_7_initialRowMax hn A i) :
    ∀ i : Fin m, i.val + 1 < n → ∀ j : Fin n,
      |Astage (i.val + 1) i j| ≤
        (Real.sqrt (m : ℝ) *
            H19.Theorem19_6.rowwise_step_growth_factor ^ (i.val + 1) + err) *
