theorem LSEStackedFullColumnRank.of_maxRelativePerturbation_lt_lowerMargin
    {m n p : ℕ}
    {A DeltaA : Fin m → Fin n → ℝ} {b Deltab : Fin m → ℝ}
    {B DeltaB : Fin p → Fin n → ℝ} {d Deltad : Fin p → ℝ}
    {eps : ℝ}
    (hAB : LSEStackedFullColumnRank A B)
