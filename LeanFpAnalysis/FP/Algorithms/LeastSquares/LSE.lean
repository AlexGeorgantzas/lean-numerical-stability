theorem
    theorem20_8_exists_perturbed_reduced_minimizer_orthogonal_of_maxRelativePerturbation_lt_margins
    {r p q : ℕ}
    {A DeltaA : Fin (r + q) → Fin (p + q) → ℝ}
    {b Deltab : Fin (r + q) → ℝ}
    {B DeltaB : Fin p → Fin (p + q) → ℝ}
    {d Deltad : Fin p → ℝ} {eps : ℝ}
    (hBsrc : LSEFullRowRank B)
