            (fun k => (b k + Deltab k) + (0 : Fin (r + q) → ℝ) k)
            (Fin.natAdd r i) =
          beta i := by
      intro i
      simpa using hb_tail i
    exact
      ⟨DeltaS, DeltaL22, hDeltaSbound, hDeltaL22bound,
        hDeltaSfrob, hDeltaL22frob, hcert hDeltab0 hb_tail0⟩

