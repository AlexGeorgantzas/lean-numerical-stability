        ((eps * frobNormRect B) * vecNorm2 (fun j : Fin n => y j - x j)) +
      complexMatrixOp2 (realRectToCMatrix APplus) *
        ((eps * frobNormRect A) * vecNorm2 (fun j : Fin n => y j - x j)) := by
  let BAplus := theorem20_8BAplus A B Bplus APplus
