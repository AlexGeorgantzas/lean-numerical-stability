    {r p q : ℕ}
    {A : Fin (r + q) → Fin (p + q) → ℝ}
    {B : Fin p → Fin (p + q) → ℝ}
    (hB : LSEFullRowRank B)
    (hStack : LSEStackedFullColumnRank A B) : ℝ :=
