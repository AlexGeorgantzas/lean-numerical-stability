theorem LSAsymmetricAugmentedSystem.exists_exact_qr_solution_of_fl_householderQRPanel_higham_matrix_solve_components
    {n k : ℕ} (fp : FPModel)
    (A : Fin (n + k) → Fin n → ℝ)
