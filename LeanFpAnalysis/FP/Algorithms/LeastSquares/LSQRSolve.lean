/-- If every diagonal-dominant inverse-budget factor is bounded by a displayed
    scalar, then the canonical finite maximum is bounded by that scalar.

    The nonnegativity hypothesis is only needed for the zero-pivot case, where
    the finite maximum is defined to be `0` and the pointwise hypothesis is
    vacuous. -/
theorem storedQRDiagDominantInvFactorBudget_le_of_forall_le
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (Dmax : ℝ)
    (hDmax_nonneg : 0 ≤ Dmax)
    (hD : ∀ k : Fin n,
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤ Dmax) :
    storedQRDiagDominantInvFactorBudget hmn A_hat ≤ Dmax := by
  classical
  unfold storedQRDiagDominantInvFactorBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      Finset.sup'_le
        (H := (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩))
        (f := fun k : Fin n =>
          diagDominantUpperInvBudgetExpr (k.val + 1)
            (qrLeadingBlock (A_hat k.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
            ⟨k.val, Nat.lt_succ_self k.val⟩)
        (by
          intro k _hk
          exact hD k)
  · rw [dif_neg hn]
    exact hDmax_nonneg

/-- Finite maximum of the displayed pivot-column norms used in the stored QR
    compact-product condition.  The value is `0` when there are no pivots. -/
noncomputable def storedQRPivotColumnNormBudget
    {m n : ℕ} (_hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ) : ℝ :=
  if hn : 0 < n then
    Finset.sup' (Finset.univ : Finset (Fin n))
      (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
      (fun k => vecNorm2 (fun i : Fin m => A_hat k.val i k))
  else 0

/-- Each displayed pivot-column norm is bounded by its finite maximum. -/
theorem storedQRPivotColumnNorm_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (k : Fin n) :
    vecNorm2 (fun i : Fin m => A_hat k.val i k) ≤
      storedQRPivotColumnNormBudget hmn A_hat := by
  classical
  unfold storedQRPivotColumnNormBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      Finset.le_sup' (s := (Finset.univ : Finset (Fin n)))
        (f := fun k : Fin n =>
          vecNorm2 (fun i : Fin m => A_hat k.val i k))
        (Finset.mem_univ k)
  · have hnpos : 0 < n := lt_of_le_of_lt (Nat.zero_le k.val) k.isLt
    exact False.elim (hn hnpos)

/-- The finite pivot-column norm budget is nonnegative. -/
theorem storedQRPivotColumnNormBudget_nonneg
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ) :
    0 ≤ storedQRPivotColumnNormBudget hmn A_hat := by
  classical
  unfold storedQRPivotColumnNormBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    let k0 : Fin n := ⟨0, hn⟩
    exact
      le_trans (vecNorm2_nonneg (fun i : Fin m => A_hat k0.val i k0))
        (Finset.le_sup' (s := (Finset.univ : Finset (Fin n)))
          (f := fun k => vecNorm2 (fun i : Fin m => A_hat k.val i k))
          (Finset.mem_univ k0))
  · rw [dif_neg hn]

/-- If every displayed pivot-column norm is bounded by a scalar, then the
    canonical finite maximum of the pivot-column norms is bounded by that
    scalar.

    The nonnegativity hypothesis is only needed for the zero-pivot case. -/
theorem storedQRPivotColumnNormBudget_le_of_forall_le
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
