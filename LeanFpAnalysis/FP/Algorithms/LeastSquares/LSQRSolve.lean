theorem not_forall_leadingBlock_upper_det_activeBlockPos_activeMaxPivot_activeBlockBudget_offdiagBudget_implies_stageBudget_le_rowMax :
    ¬ (∀ (A_hat : ℕ → Fin 2 → Fin 2 → ℝ) (stageBudget : ℕ → ℝ),
