/-- Meta route elimination for the Cox--Higham row-budget split.

    Adding an arbitrary auxiliary side property that happens to hold of the
    displayed-stage sequence and row budget still cannot turn active-block
    budgets, active max-pivoting, and strict-upper row-growth bounds into the
    missing diagonal lower-bound field.  This is a guard against repeatedly
    trying to close the QR bottleneck by appending unrelated scalar/product
    hypotheses instead of proving a genuine diagonal lower-bound invariant. -/
theorem not_forall_leadingBlock_upper_det_activeBlockPos_activeMaxPivot_activeBlockBudget_offdiagBudget_property_implies_rowBudget_diag :
    ¬ (∀
      (P : (ℕ → Fin 2 → Fin 2 → ℝ) → (ℕ → ℝ) → Prop)
      (A_hat : ℕ → Fin 2 → Fin 2 → ℝ) (rowBudget : ℕ → ℝ),
      (∀ k (hk : k < 2), ∀ i j : Fin (k + 1), j.val < i.val →
        qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i j = 0) →
      (∀ k (hk : k < 2),
        Matrix.det
          (qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk :
            Matrix (Fin (k + 1)) (Fin (k + 1)) ℝ) ≠ 0) →
      (∀ k (hk : k < 2),
        0 < householderActiveBlockNorm2Sq
          ⟨k, hk⟩ ⟨k, hk⟩ (A_hat k)) →
      (∀ k (hk : k < 2), ∀ l : Fin 2, k ≤ l.val →
        householderTrailingColumnNorm2Sq
            (m := 2) (n := 2) ⟨k, hk⟩ (A_hat k) l ≤
          householderTrailingColumnNorm2Sq
            (m := 2) (n := 2) ⟨k, hk⟩ (A_hat k) ⟨k, hk⟩) →
      (∀ k (_hk : k < 2), 0 ≤ rowBudget k) →
      (∀ k (_hk : k < 2), ∀ r l : Fin 2, k ≤ r.val → k ≤ l.val →
        |A_hat k r l| ≤ rowBudget k) →
      (∀ k (hk : k < 2), ∀ i j : Fin (k + 1), i.val < j.val →
        |qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i j| ≤
          rowBudget k) →
      P A_hat rowBudget →
      (∀ k (hk : k < 2), ∀ i : Fin (k + 1), i.val < k →
        rowBudget k ≤
          |qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i i|)) := by
  intro h
  exact
    not_forall_leadingBlock_upper_det_activeBlockPos_activeMaxPivot_activeBlockBudget_offdiagBudget_implies_rowBudget_diag
      (by
        intro A_hat rowBudget hupper hdetLead hactive hpivotMax
          hbudget_nonneg hactiveBlockBudget hoffdiagBudget
        exact h (fun _ _ => True) A_hat rowBudget hupper hdetLead hactive
          hpivotMax hbudget_nonneg hactiveBlockBudget hoffdiagBudget trivial)

/-- Explicit compact-budget QR least-squares certificate from diagonally
    dominant nonsingular leading blocks.

    This is the determinant-facing diagonal-dominance version of
    `..._leadingBlock_det_ne_zero_invNorm_dualBudget`.  It uses Higham's
    triangular inverse bound already formalized in `InverseBounds.lean` to
    derive the direct inverse-∞ budget for each local leading block.  The dual
