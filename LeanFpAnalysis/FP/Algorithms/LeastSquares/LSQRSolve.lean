              (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)
            ⟨k, Nat.lt_succ_self k⟩ *
        ((m : ℝ) *
          (storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha *
            vecNorm2 (fun i : Fin m => A_hat k i ⟨k, hk⟩)) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  refine
    storedQRCompactSequenceProductBudget_lt_one_of_forall_expr_lt
      hmn fp A_hat b_hat alpha ?_
  intro k
  simpa [storedQRCompactSequenceProductExpr] using hproduct k.val k.isLt

/-- The stored compact-product side condition is automatic in the zero
    compact-update regime.

If the common stored compact relative budget is exactly zero, every per-pivot
product expression is zero, so the finite product maximum is strictly below
`1`.  This closes the exact/zero-compact product-smallness dependency without
claiming anything about the genuinely rounded floating-point case, where the
relative budget must still be bounded. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_relativeBudget_eq_zero
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
