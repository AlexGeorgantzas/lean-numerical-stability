/-- Scalar sufficient condition for the global compact-product smallness
    hypothesis.

    If the diagonal-dominant inverse-budget factor is bounded by `Dmax` at
    every pivot and the displayed pivot-column norm is bounded by `Nmax`, then
    the single scalar inequality using `Dmax` and `Nmax` implies
    `storedQRCompactSequenceProductBudget < 1`.  This is still a visible
    product-smallness assumption, but it reduces the finite family of product
    obligations to one source-facing scalar budget. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_factor_norm_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (Dmax Nmax : ℝ)
    (hm : gammaValid fp m)
    (hDmax : 0 ≤ Dmax)
    (hNmax : 0 ≤ Nmax)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDle : ∀ k : Fin n,
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤ Dmax)
    (hNle : ∀ k : Fin n,
      vecNorm2 (fun i : Fin m => A_hat k.val i k) ≤ Nmax)
    (hsmall :
      2 * Dmax *
          ((m : ℝ) *
            (storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha *
              Nmax) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  classical
  refine
    storedQRCompactSequenceProductBudget_lt_one_of_forall_expr_lt
      hmn fp A_hat b_hat alpha ?_
  intro k
  let D : ℝ :=
    diagDominantUpperInvBudgetExpr (k.val + 1)
      (qrLeadingBlock (A_hat k.val)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
      ⟨k.val, Nat.lt_succ_self k.val⟩
  let c : ℝ :=
    storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha
  let r : ℝ := vecNorm2 (fun i : Fin m => A_hat k.val i k)
  have hD_nonneg : 0 ≤ D := by
    exact le_of_lt (diagDominantUpperInvBudgetExpr_pos (k.val + 1)
      (qrLeadingBlock (A_hat k.val)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
      ⟨k.val, Nat.lt_succ_self k.val⟩ (hDD k))
  have hD_bound : D ≤ Dmax := by
    simpa [D] using hDle k
  have hc_nonneg : 0 ≤ c := by
    simpa [c] using
      storedQRCompactSequenceRelativeBudget_nonneg
        hmn fp A_hat b_hat alpha hm
  have hr_nonneg : 0 ≤ r := by
    simpa [r] using vecNorm2_nonneg (fun i : Fin m => A_hat k.val i k)
  have hr_bound : r ≤ Nmax := by
    simpa [r] using hNle k
  have hcr_bound : c * r ≤ c * Nmax :=
    mul_le_mul_of_nonneg_left hr_bound hc_nonneg
  have hcr_nonneg : 0 ≤ c * r := mul_nonneg hc_nonneg hr_nonneg
  have hcN_nonneg : 0 ≤ c * Nmax := mul_nonneg hc_nonneg hNmax
  have hsq_bound : (c * r) ^ 2 ≤ (c * Nmax) ^ 2 := by
    nlinarith [hcr_bound, hcr_nonneg, hcN_nonneg]
  have hm_nonneg : 0 ≤ (m : ℝ) := Nat.cast_nonneg m
  have hright_bound :
      (m : ℝ) * (c * r) ^ 2 ≤ (m : ℝ) * (c * Nmax) ^ 2 :=
    mul_le_mul_of_nonneg_left hsq_bound hm_nonneg
  have hright_nonneg : 0 ≤ (m : ℝ) * (c * r) ^ 2 :=
    mul_nonneg hm_nonneg (sq_nonneg _)
  have hleft_bound : 2 * D ≤ 2 * Dmax := by
    nlinarith
  have hleft_nonneg : 0 ≤ 2 * Dmax := by
    nlinarith
  have hprod_bound :
      2 * D * ((m : ℝ) * (c * r) ^ 2) ≤
        2 * Dmax * ((m : ℝ) * (c * Nmax) ^ 2) :=
    mul_le_mul hleft_bound hright_bound hright_nonneg hleft_nonneg
  exact lt_of_le_of_lt (by
    simpa [storedQRCompactSequenceProductExpr, D, c, r] using hprod_bound)
    hsmall

/-- Finite maximum of the diagonal-dominant inverse-budget factors used in the
    stored QR compact-product condition.  The value is `0` when there are no
    pivots. -/
noncomputable def storedQRDiagDominantInvFactorBudget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ) : ℝ :=
  if hn : 0 < n then
    Finset.sup' (Finset.univ : Finset (Fin n))
      (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
      (fun k =>
        diagDominantUpperInvBudgetExpr (k.val + 1)
          (qrLeadingBlock (A_hat k.val)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
          ⟨k.val, Nat.lt_succ_self k.val⟩)
  else 0

/-- Each diagonal-dominant inverse-budget factor is bounded by its finite
    maximum. -/
theorem storedQRDiagDominantInvFactor_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (k : Fin n) :
    diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤
      storedQRDiagDominantInvFactorBudget hmn A_hat := by
  classical
  unfold storedQRDiagDominantInvFactorBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      Finset.le_sup' (s := (Finset.univ : Finset (Fin n)))
        (f := fun k : Fin n =>
          diagDominantUpperInvBudgetExpr (k.val + 1)
            (qrLeadingBlock (A_hat k.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
            ⟨k.val, Nat.lt_succ_self k.val⟩)
        (Finset.mem_univ k)
  · have hnpos : 0 < n := lt_of_le_of_lt (Nat.zero_le k.val) k.isLt
    exact False.elim (hn hnpos)

/-- The finite diagonal-dominant inverse-factor budget is nonnegative when all
    displayed leading blocks are diagonally dominant. -/
theorem storedQRDiagDominantInvFactorBudget_nonneg
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)) :
    0 ≤ storedQRDiagDominantInvFactorBudget hmn A_hat := by
  classical
  unfold storedQRDiagDominantInvFactorBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    let k0 : Fin n := ⟨0, hn⟩
    have hk0_pos :
        0 <
          diagDominantUpperInvBudgetExpr (k0.val + 1)
            (qrLeadingBlock (A_hat k0.val)
