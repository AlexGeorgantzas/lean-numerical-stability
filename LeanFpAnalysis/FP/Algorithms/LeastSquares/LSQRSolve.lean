/-- The per-pivot compact-product expression used by the stored QR
    off-diagonal-control route. -/
noncomputable def storedQRCompactSequenceProductExpr
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (k : Fin n) : ℝ :=
  2 *
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ *
    ((m : ℝ) *
      (storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha *
        vecNorm2 (fun i : Fin m => A_hat k.val i k)) ^ 2)

/-- Finite global compact-product budget for the stored QR sequence.

    This is the maximum, over all pivots, of the per-pivot compact-product
    expression used by the off-diagonal-control route.  For `n = 0` the product
    side condition is vacuous, so the definition returns `0`. -/
noncomputable def storedQRCompactSequenceProductBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ) : ℝ :=
  if hn : 0 < n then
    Finset.sup' (Finset.univ : Finset (Fin n))
      (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
      (fun k => storedQRCompactSequenceProductExpr hmn fp A_hat b_hat alpha k)
  else 0

/-- Each per-pivot compact-product expression is bounded by the finite global
    compact-product budget. -/
theorem storedQRCompactSequenceProductExpr_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (k : Fin n) :
    storedQRCompactSequenceProductExpr hmn fp A_hat b_hat alpha k ≤
      storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha := by
  classical
  unfold storedQRCompactSequenceProductBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      Finset.le_sup' (s := (Finset.univ : Finset (Fin n)))
        (f := fun k =>
          storedQRCompactSequenceProductExpr hmn fp A_hat b_hat alpha k)
        (Finset.mem_univ k)
  · have hnpos : 0 < n := lt_of_le_of_lt (Nat.zero_le k.val) k.isLt
    exact False.elim (hn hnpos)

/-- The finite global compact-product budget is strictly below `1` whenever
    every per-pivot compact-product expression is strictly below `1`.

    This is the converse bookkeeping adapter to
    `storedQRCompactSequenceProductExpr_le_budget`: it does not prove the
    per-pivot inequalities, but it closes the finite-maximum step needed to
    move between older per-pivot smallness hypotheses and the newer scalar
    global product condition. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_forall_expr_lt
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (hprod : ∀ k : Fin n,
      storedQRCompactSequenceProductExpr hmn fp A_hat b_hat alpha k < 1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  classical
  unfold storedQRCompactSequenceProductBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      (Finset.sup'_lt_iff
        (s := (Finset.univ : Finset (Fin n)))
        (H := Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
        (f := fun k =>
          storedQRCompactSequenceProductExpr hmn fp A_hat b_hat alpha k)
        (a := (1 : ℝ))).mpr
        (fun k _hk => hprod k)
  · rw [dif_neg hn]
    norm_num

/-- Natural-indexed version of
    `storedQRCompactSequenceProductBudget_lt_one_of_forall_expr_lt`.

    This matches the product-smallness hypotheses used by the older
    source-control wrappers. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_forall_pivot_product
    {m n : ℕ} (hmn : n ≤ m)
