          (householderCompactComponentBudget fp m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
            (fun a => A_hat k a ⟨k, hk⟩)
            ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
        householderTrailingNorm2Sq m
          ⟨k, lt_of_lt_of_le hk hmn⟩
          (fun a => A_hat k a ⟨k, hk⟩))
    (hdetLead : ∀ k (hk : k < n),
      Matrix.det
        (qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk :
          Matrix (Fin (k + 1)) (Fin (k + 1)) ℝ) ≠ 0)
    (hinit : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ _hij : i.val < j.val,
      |A_hat 0
          (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
          (qrLeadingColumn n k hk j)| ≤
        stageBudget 0)
    (hbudget : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ _hij : i.val < j.val,
      ∀ t : ℕ, t < qrLeadingOffdiagStop j →
        coxHighamActiveRowGrowthFactor m * stageBudget t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a (qrLeadingColumn n k hk j))
              (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
          ≤ stageBudget (t + 1))
    (hBudget_nonneg : ∀ t : ℕ, 0 ≤ stageBudget t)
    (hBudget_mono : ∀ a b : ℕ, a ≤ b → stageBudget a ≤ stageBudget b)
    (hBudget_diag : ∀ k (hk : k < n),
      ∀ i : Fin (k + 1), i.val < k →
        stageBudget k ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|)
    (hpivotMax : ∀ t (ht : t < n), ∀ l : Fin n, t ≤ l.val →
        householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) l ≤
          householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) ⟨t, ht⟩)
    (hstageActiveBlockBound : ∀ t, t < n →
      ∀ r : Fin m, t ≤ r.val →
        ∀ l : Fin n, t ≤ l.val → |A_hat t r l| ≤ stageBudget t)
    (hstagePrefixRowBound : ∀ k (hk : k < n), ∀ i j : Fin (k + 1),
      ∀ _hij : i.val < j.val, ∀ t : ℕ, t < qrLeadingOffdiagStop j →
        ∀ l : Fin n, t ≤ l.val →
          (qrLeadingRow m k
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i).val < t →
            |A_hat t
              (qrLeadingRow m k
                (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i) l| ≤
              stageBudget t)
    (hproduct : ∀ k (hk : k < n),
      2 *
          diagDominantUpperInvBudgetExpr (k + 1)
            (qrLeadingBlock (A_hat k)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)
            ⟨k, Nat.lt_succ_self k⟩ *
        ((m : ℝ) *
          (storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha *
            vecNorm2 (fun i : Fin m => A_hat k i ⟨k, hk⟩)) ^ 2) <
        1) :
    StoredQRSourceOffDiagonalControl hmn fp A_hat b_hat alpha := by
  classical
  refine
    StoredQRSourceOffDiagonalControl.of_stored_trailing_sequence_leadingBlock_det_ne_zero_normSqBudget_signedStageUniformBudget_product_of_normSqBudget_stage_entry_bounds_offdiag_rows
      hmn fp A_hat b_hat alpha stageBudget hm hStepA hAlphaDef
      hbudgetNormSq hdetLead hinit hbudget hBudget_nonneg hBudget_mono
      hBudget_diag hpivotMax ?_ ?_ hproduct
  · intro k hk i j hij t ht l hl
    let row : Fin m :=
      qrLeadingRow m k
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i
    have ht_le_k : t ≤ k := by
      exact le_trans (Nat.le_of_lt ht) (qrLeadingOffdiagStop_le j)
    have htn : t < n := lt_of_le_of_lt ht_le_k hk
    by_cases hrow : t ≤ row.val
    · simpa [row] using hstageActiveBlockBound t htn row hrow l hl
    · have hprefix : row.val < t := Nat.lt_of_not_ge hrow
      simpa [row] using
        hstagePrefixRowBound k hk i j hij t ht l hl hprefix
  · intro k hk i j hij t ht r hr
    let col : Fin n := qrLeadingColumn n k hk j
    have ht_le_k : t ≤ k := by
      exact le_trans (Nat.le_of_lt ht) (qrLeadingOffdiagStop_le j)
    have htn : t < n := lt_of_le_of_lt ht_le_k hk
    have hcolActive : t ≤ col.val := by
      by_cases hjk : j.val < k
      · have htj : t ≤ j.val := by
          exact Nat.lt_succ_iff.mp
            (by simpa [qrLeadingOffdiagStop, hjk] using ht)
        simpa [col, qrLeadingColumn] using htj
      · have hle : j.val ≤ k := Nat.le_of_lt_succ j.isLt
        have heq : j.val = k := le_antisymm hle (le_of_not_gt hjk)
        have htk : t < k := by
          simpa [qrLeadingOffdiagStop, hjk, heq] using ht
        have htj : t ≤ j.val := by omega
        simpa [col, qrLeadingColumn] using htj
    simpa [col] using hstageActiveBlockBound t htn r hr col hcolActive

/-- Active-suffix stage bounds from the rounded signed-pivot active-block
    recurrence.

    This factors out the reusable part of the rectangular QR bottleneck: the
    Cox--Higham stored-panel sequence theorem propagates one uniform bound over
    the active trailing block, provided the signed pivot stages use a positive
    nonbreakdown norm, pivot-maximal columns, completed-column preservation,
    pivot-column zeroing, and the one-step active-block budget. -/
theorem storedQRSignedStage_active_block_bound_of_signed_stage_budget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hStepA : ∀ k (hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
          (householderBetaSpec m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
          (A_hat k))
    (hAlphaDef : ∀ k (hk : k < n),
      alpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩)))
          (A_hat k ⟨k, lt_of_lt_of_le hk hmn⟩ ⟨k, hk⟩))
    (hbudgetNormSq : ∀ k (hk : k < n),
      (m : ℝ) *
          (householderCompactComponentBudget fp m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
            (fun a => A_hat k a ⟨k, hk⟩)
            ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
        householderTrailingNorm2Sq m
          ⟨k, lt_of_lt_of_le hk hmn⟩
          (fun a => A_hat k a ⟨k, hk⟩))
    (hinitBlock : ∀ r : Fin m, ∀ l : Fin n,
      |A_hat 0 r l| ≤ stageBudget 0)
    (hactiveBudget : ∀ t : ℕ, t + 1 < n →
      ∀ r : Fin m, t + 1 ≤ r.val →
        ∀ l : Fin n, t + 1 ≤ l.val →
          coxHighamActiveRowGrowthFactor m * stageBudget t +
              householderCompactComponentBudget fp m
                (storedQRSignedStageVector hmn A_hat alpha t)
                (storedQRSignedStageBeta hmn A_hat alpha t)
                (fun a => A_hat t a l) r ≤
            stageBudget (t + 1))
    (hBudget_nonneg : ∀ t : ℕ, 0 ≤ stageBudget t)
    (hpivotMax : ∀ t (ht : t < n), ∀ l : Fin n, t ≤ l.val →
        householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) l ≤
          householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) ⟨t, ht⟩)
    (hcompleted : ∀ t (_ht : t < n), ∀ j : Fin n, j.val < t →
      ∀ i : Fin m,
        matMulVec m
          (householder m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t))
          (fun a => A_hat t a j) i = A_hat t i j) :
    ∀ t (_ht : t < n), ∀ row : Fin m, t ≤ row.val →
      ∀ l : Fin n, t ≤ l.val → |A_hat t row l| ≤ stageBudget t := by
  classical
  intro t ht row hrow l hl
  have hnpos : 0 < n := lt_of_le_of_lt (Nat.zero_le t) ht
  have hmpos : 0 < m := lt_of_lt_of_le hnpos hmn
  let p : ℕ → Fin m := fun s =>
    if hs : s < n then ⟨s, lt_of_lt_of_le hs hmn⟩ else ⟨0, hmpos⟩
  let pivotCol : ℕ → Fin n := fun s =>
    if hs : s < n then ⟨s, hs⟩ else ⟨0, hnpos⟩
  have hactiveSeq :
      ∀ s : ℕ, s ≤ t →
        ∀ row' : Fin m, (p s).val ≤ row'.val →
          ∀ l' : Fin n, (pivotCol s).val ≤ l'.val →
            |A_hat s row' l'| ≤ stageBudget s := by
    exact
      coxHigham_storedPanel_sequence_active_block_bound_of_signed_pivot_stage_bounds
        fp t A_hat p pivotCol stageBudget hm hinitBlock
        (fun s _hs => hBudget_nonneg s)
        (fun s hs => by
          have hsn : s < n := Nat.lt_trans hs ht
          have halpha := hAlphaDef s hsn
          simpa [p, pivotCol, hsn, signedPivotHouseholderVector,
            signedPivotHouseholderBeta, storedQRSignedStageVector,
            storedQRSignedStageBeta, halpha, householderTrailingColumnNorm2Sq]
            using hStepA s hsn)
        (fun u s hus hst => by
          have hsn : s < n := lt_of_le_of_lt hst ht
          have hun : u < n := lt_of_le_of_lt hus hsn
          simpa [p, hun, hsn] using hus)
        (fun u s hus hst => by
          have hsn : s < n := lt_of_le_of_lt hst ht
          have hun : u < n := lt_of_le_of_lt hus hsn
          simpa [pivotCol, hun, hsn] using hus)
        (fun s hs => by
          have hsn : s < n := Nat.lt_trans hs ht
          have hleft_nonneg :
              0 ≤
                (m : ℝ) *
                  (householderCompactComponentBudget fp m
                    (householderTrailingActiveVector m
                      ⟨s, lt_of_lt_of_le hsn hmn⟩
                      (fun a => A_hat s a ⟨s, hsn⟩) (alpha s))
                    (householderBetaSpec m
                      (householderTrailingActiveVector m
                        ⟨s, lt_of_lt_of_le hsn hmn⟩
                        (fun a => A_hat s a ⟨s, hsn⟩) (alpha s)))
                    (fun a => A_hat s a ⟨s, hsn⟩)
                    ⟨s, lt_of_lt_of_le hsn hmn⟩) ^ 2 := by
            exact mul_nonneg (Nat.cast_nonneg m) (sq_nonneg _)
          have hpos := lt_of_le_of_lt hleft_nonneg (hbudgetNormSq s hsn)
          simpa [p, pivotCol, hsn, householderTrailingColumnNorm2Sq] using
            hpos)
        (fun s hs l' hl' => by
          have hsn : s < n := Nat.lt_trans hs ht
          have hl_s : s ≤ l'.val := by
            simpa [pivotCol, hsn] using hl'
          simpa [p, pivotCol, hsn] using hpivotMax s hsn l' hl_s)
        (fun s hs j hj i => by
          have hsn : s < n := Nat.lt_trans hs ht
          have halpha := hAlphaDef s hsn
          simpa [p, pivotCol, hsn, signedPivotHouseholderVector,
            signedPivotHouseholderBeta, storedQRSignedStageVector,
            storedQRSignedStageBeta, halpha, householderTrailingColumnNorm2Sq]
            using hcompleted s hsn j (by simpa [pivotCol, hsn] using hj) i)
        (fun s hs j hj i hi => by
          have hsn : s < n := Nat.lt_trans hs ht
          have halpha := hAlphaDef s hsn
          have hleft_nonneg :
              0 ≤
                (m : ℝ) *
                  (householderCompactComponentBudget fp m
                    (householderTrailingActiveVector m
                      ⟨s, lt_of_lt_of_le hsn hmn⟩
                      (fun a => A_hat s a ⟨s, hsn⟩) (alpha s))
                    (householderBetaSpec m
                      (householderTrailingActiveVector m
                        ⟨s, lt_of_lt_of_le hsn hmn⟩
                        (fun a => A_hat s a ⟨s, hsn⟩) (alpha s)))
                    (fun a => A_hat s a ⟨s, hsn⟩)
                    ⟨s, lt_of_lt_of_le hsn hmn⟩) ^ 2 := by
            exact mul_nonneg (Nat.cast_nonneg m) (sq_nonneg _)
          have hpos := lt_of_le_of_lt hleft_nonneg (hbudgetNormSq s hsn)
          have hcol : j = ⟨s, hsn⟩ := by
            apply Fin.ext
            simpa [pivotCol, hsn] using hj
          subst hcol
          have hzero :=
            storedQRSignedStage_pivot_column_zero_below_of_trailingNorm_pos
              hmn A_hat alpha s hsn (hAlphaDef s hsn) hpos i
              (by simpa [pivotCol, hsn] using hi)
          simpa [p, pivotCol, hsn, signedPivotHouseholderVector,
            signedPivotHouseholderBeta, storedQRSignedStageVector,
            storedQRSignedStageBeta, halpha, householderTrailingColumnNorm2Sq]
            using hzero)
        (fun s hs row' l' hrowNext hcolNext => by
          have hsn : s < n := Nat.lt_trans hs ht
          have hsuccn : s + 1 < n := lt_of_le_of_lt (Nat.succ_le_iff.mpr hs) ht
          have halpha := hAlphaDef s hsn
          have hrowNext' : s + 1 ≤ row'.val := by
            simpa [p, hsuccn] using hrowNext
          have hcolNext' : s + 1 ≤ l'.val := by
            simpa [pivotCol, hsuccn] using hcolNext
          simpa [p, pivotCol, hsn, hsuccn, signedPivotHouseholderVector,
            signedPivotHouseholderBeta, storedQRSignedStageVector,
            storedQRSignedStageBeta, halpha, householderTrailingColumnNorm2Sq]
            using hactiveBudget s hsuccn row' hrowNext' l' hcolNext')
  have hpt : (p t).val ≤ row.val := by
    simpa [p, ht] using hrow
  have hct : (pivotCol t).val ≤ l.val := by
    simpa [pivotCol, ht] using hl
  exact hactiveSeq t le_rfl row hpt l hct

/-- Prefix-row stage bounds from the active-block invariant and a displayed-row
    recurrence.

    This is the next dependency in the rectangular QR/preconditioner bottleneck.
    Once a row has moved into the displayed prefix, its later entries are
    controlled by the same exact-reflector row-growth theorem used for active
    rows, followed by the concrete stored-panel floating-point component
    budget.  The hypothesis `hprefixBudget` is exactly that one-step recurrence
    for rows with `row.val < t + 1`. -/
theorem storedQRSignedStage_prefix_row_bound_of_active_block_and_prefix_budget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hStepA : ∀ k (hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
          (householderBetaSpec m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
          (A_hat k))
    (hAlphaDef : ∀ k (hk : k < n),
      alpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩)))
          (A_hat k ⟨k, lt_of_lt_of_le hk hmn⟩ ⟨k, hk⟩))
    (hbudgetNormSq : ∀ k (hk : k < n),
      (m : ℝ) *
          (householderCompactComponentBudget fp m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
            (fun a => A_hat k a ⟨k, hk⟩)
            ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
        householderTrailingNorm2Sq m
          ⟨k, lt_of_lt_of_le hk hmn⟩
          (fun a => A_hat k a ⟨k, hk⟩))
    (hBudget_nonneg : ∀ t : ℕ, 0 ≤ stageBudget t)
    (hpivotMax : ∀ t (ht : t < n), ∀ l : Fin n, t ≤ l.val →
        householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) l ≤
          householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) ⟨t, ht⟩)
    (hstageActiveBlockBound : ∀ t, t < n →
      ∀ r : Fin m, t ≤ r.val →
        ∀ l : Fin n, t ≤ l.val → |A_hat t r l| ≤ stageBudget t)
    (hprefixBudget : ∀ t (_ht : t < n),
      ∀ r : Fin m, r.val < t + 1 →
        ∀ l : Fin n, t ≤ l.val →
          coxHighamActiveRowGrowthFactor m * stageBudget t +
              householderCompactComponentBudget fp m
                (storedQRSignedStageVector hmn A_hat alpha t)
                (storedQRSignedStageBeta hmn A_hat alpha t)
                (fun a => A_hat t a l) r ≤
            stageBudget (t + 1)) :
    ∀ t (_ht : t < n), ∀ r : Fin m, r.val < t →
      ∀ l : Fin n, t ≤ l.val → |A_hat t r l| ≤ stageBudget t := by
  classical
  intro t
  induction t with
  | zero =>
      intro _ht r hr
      exact (Nat.not_lt_zero r.val hr).elim
  | succ t ih =>
      intro ht r hr l hl
      have htn : t < n := Nat.lt_trans (Nat.lt_succ_self t) ht
      have hcolStep : t ≤ l.val := le_trans (Nat.le_succ t) hl
      have hcolStrict : t < l.val := Nat.lt_of_succ_le hl
      have hstep := congrFun (congrFun (hStepA t htn) r) l
      rw [hstep]
      have hnorm :
          0 <
            householderTrailingColumnNorm2Sq
              (m := m) (n := n) ⟨t, lt_of_lt_of_le htn hmn⟩
              (A_hat t) ⟨t, htn⟩ := by
        have hleft_nonneg :
            0 ≤
              (m : ℝ) *
                (householderCompactComponentBudget fp m
                  (householderTrailingActiveVector m
                    ⟨t, lt_of_lt_of_le htn hmn⟩
                    (fun a => A_hat t a ⟨t, htn⟩) (alpha t))
                  (householderBetaSpec m
                    (householderTrailingActiveVector m
                      ⟨t, lt_of_lt_of_le htn hmn⟩
                      (fun a => A_hat t a ⟨t, htn⟩) (alpha t)))
                  (fun a => A_hat t a ⟨t, htn⟩)
                  ⟨t, lt_of_lt_of_le htn hmn⟩) ^ 2 := by
          exact mul_nonneg (Nat.cast_nonneg m) (sq_nonneg _)
        have hpos := lt_of_le_of_lt hleft_nonneg (hbudgetNormSq t htn)
        simpa [householderTrailingColumnNorm2Sq] using hpos
      have hexact :
          |matMulVec m
            (householder m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t))
            (fun a => A_hat t a l) r| ≤
            coxHighamActiveRowGrowthFactor m * stageBudget t := by
        exact
          storedQRSignedStage_exact_same_reflector_bound_of_prefix_or_active_stage_bounds
            hmn A_hat alpha t htn r l (stageBudget t)
            (hAlphaDef t htn) hcolStep (hBudget_nonneg t)
            (fun hprefix => ih htn r hprefix l hcolStep)
            hnorm
            (fun l' hl' => hpivotMax t htn l' hl')
            (fun l' hl' => by
              by_cases hprefix : r.val < t
              · exact ih htn r hprefix l' hl'
              · have hactive : t ≤ r.val := le_of_not_gt hprefix
                exact hstageActiveBlockBound t htn r hactive l' hl')
            (fun r' hr' =>
              hstageActiveBlockBound t htn r' hr' l hcolStep)
      have hstepBound :
          |fl_householderStoredPanelStep fp m n t
            (householderTrailingActiveVector m
              ⟨t, lt_of_lt_of_le htn hmn⟩
              (fun a => A_hat t a ⟨t, htn⟩) (alpha t))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨t, lt_of_lt_of_le htn hmn⟩
                (fun a => A_hat t a ⟨t, htn⟩) (alpha t)))
            (A_hat t) r l| ≤
            coxHighamActiveRowGrowthFactor m * stageBudget t +
              householderCompactComponentBudget fp m
                (storedQRSignedStageVector hmn A_hat alpha t)
                (storedQRSignedStageBeta hmn A_hat alpha t)
                (fun a => A_hat t a l) r := by
        have hraw :=
          coxHigham_storedPanelStep_active_entry_bound_of_exact_stage_budget_factor
            fp m n t
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t)
            (coxHighamActiveRowGrowthFactor m) (stageBudget t)
            (A_hat t) hm r l hcolStep
            (fun hlt _i => False.elim ((Nat.not_lt_of_ge hcolStep) hlt))
            (fun heq _i _hi => False.elim ((Nat.ne_of_gt hcolStrict) heq))
            hexact
        simpa [storedQRSignedStageVector, storedQRSignedStageBeta, htn]
          using hraw
      exact hstepBound.trans (hprefixBudget t htn r hr l hcolStep)

/-- Finite global compact-update budget for one signed stored-QR stage.

    For a fixed stage `t < n`, this is the maximum, over all displayed matrix
    entries, of the floating-point compact-update component budget generated by
    the signed stored-QR reflector at that stage. -/
noncomputable def storedQRSignedStageGlobalCompactBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (t : ℕ) (ht : t < n) : ℝ :=
  Finset.sup' (Finset.univ : Finset (Fin m × Fin n))
    (Finset.univ_nonempty_iff.mpr
      ⟨((⟨t, lt_of_lt_of_le ht hmn⟩ : Fin m), (⟨t, ht⟩ : Fin n))⟩)
    (fun rc =>
      householderCompactComponentBudget fp m
        (storedQRSignedStageVector hmn A_hat alpha t)
        (storedQRSignedStageBeta hmn A_hat alpha t)
        (fun a => A_hat t a rc.2) rc.1)

/-- Every matrix-entry compact component is bounded by the finite global
    compact-update budget for the signed stored-QR stage. -/
theorem storedQRSignedStage_compact_component_le_globalBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (t : ℕ) (ht : t < n)
    (r : Fin m) (l : Fin n) :
    householderCompactComponentBudget fp m
        (storedQRSignedStageVector hmn A_hat alpha t)
        (storedQRSignedStageBeta hmn A_hat alpha t)
        (fun a => A_hat t a l) r ≤
      storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht := by
  classical
  unfold storedQRSignedStageGlobalCompactBudget
  exact
    Finset.le_sup' (s := (Finset.univ : Finset (Fin m × Fin n)))
      (f := fun rc =>
        householderCompactComponentBudget fp m
          (storedQRSignedStageVector hmn A_hat alpha t)
          (storedQRSignedStageBeta hmn A_hat alpha t)
          (fun a => A_hat t a rc.2) rc.1)
      (Finset.mem_univ (r, l))

/-- The finite global compact-update budget is nonnegative.

This packages component-budget nonnegativity for later stage-recurrence
arguments: the finite maximum contains the pivot entry, and every compact
component budget is nonnegative under `gammaValid fp m`. -/
theorem storedQRSignedStageGlobalCompactBudget_nonneg
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (t : ℕ) (ht : t < n)
    (hm : gammaValid fp m) :
    0 ≤ storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht := by
  classical
  let r : Fin m := ⟨t, lt_of_lt_of_le ht hmn⟩
  let l : Fin n := ⟨t, ht⟩
  have hcomp :
      0 ≤
        householderCompactComponentBudget fp m
          (storedQRSignedStageVector hmn A_hat alpha t)
          (storedQRSignedStageBeta hmn A_hat alpha t)
          (fun a => A_hat t a l) r := by
    exact
      householderCompactComponentBudget_nonneg fp m
        (storedQRSignedStageVector hmn A_hat alpha t)
        (storedQRSignedStageBeta hmn A_hat alpha t)
        (fun a => A_hat t a l) hm r
  exact
    hcomp.trans
      (storedQRSignedStage_compact_component_le_globalBudget
        hmn fp A_hat alpha t ht r l)

/-- A signed-stage global compact-budget recurrence is monotone on QR stages.

If the stage budgets are nonnegative and each successor budget dominates
`coxHighamActiveRowGrowthFactor m * B_t` plus the finite compact-update budget,
then the budget sequence is monotone for all indices up to the QR horizon `n`.
This removes the need to prove a separate monotonicity invariant on the actual
algorithmic stage range. -/
theorem storedQRSignedStageBudget_mono_on_stages_of_globalCompactBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hglobalBudget : ∀ t (ht : t < n),
      coxHighamActiveRowGrowthFactor m * stageBudget t +
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht ≤
        stageBudget (t + 1))
    (hBudget_nonneg : ∀ t : ℕ, 0 ≤ stageBudget t) :
    ∀ a b : ℕ, a ≤ b → b ≤ n → stageBudget a ≤ stageBudget b := by
  have hstepMono : ∀ b : ℕ, b < n → stageBudget b ≤ stageBudget (b + 1) := by
    intro b hb_lt
    have hscale :
        stageBudget b ≤ coxHighamActiveRowGrowthFactor m * stageBudget b := by
      simpa [one_mul] using
        mul_le_mul_of_nonneg_right
          (one_le_coxHighamActiveRowGrowthFactor m) (hBudget_nonneg b)
    have hcompact_nonneg :
        0 ≤ storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha b hb_lt :=
      storedQRSignedStageGlobalCompactBudget_nonneg
        hmn fp A_hat alpha b hb_lt hm
    have hstep :
        stageBudget b ≤ stageBudget (b + 1) :=
      hscale.trans
        ((le_add_of_nonneg_right hcompact_nonneg).trans
          (hglobalBudget b hb_lt))
    exact hstep
  intro a b hab hb
  induction b generalizing a with
  | zero =>
      have ha0 : a = 0 := Nat.eq_zero_of_le_zero hab
      subst a
      rfl
  | succ b ih =>
      rcases Nat.eq_or_lt_of_le hab with heq | hlt
      · subst a
        rfl
      · have hab' : a ≤ b := Nat.lt_succ_iff.mp hlt
        have hb_le : b ≤ n := Nat.le_of_succ_le hb
        have hb_lt : b < n := Nat.lt_of_succ_le hb
        exact (ih a hab' hb_le).trans (hstepMono b hb_lt)

/-- Clamp a stage-budget sequence after the QR horizon.

The QR source-control theorems only compare stages `b <= n`, but some older
surfaces asked for monotonicity on all natural indices.  This extension keeps
the original budget on the algorithmic horizon and freezes it afterward. -/
def qrStageHorizonBudget (n : ℕ) (stageBudget : ℕ → ℝ) : ℕ → ℝ :=
  fun t => if t ≤ n then stageBudget t else stageBudget n

theorem qrStageHorizonBudget_eq_of_le
    (n : ℕ) (stageBudget : ℕ → ℝ) {t : ℕ} (ht : t ≤ n) :
    qrStageHorizonBudget n stageBudget t = stageBudget t := by
  simp [qrStageHorizonBudget, ht]

theorem qrStageHorizonBudget_nonneg
    (n : ℕ) (stageBudget : ℕ → ℝ)
    (hBudget_nonneg : ∀ t : ℕ, 0 ≤ stageBudget t) :
    ∀ t : ℕ, 0 ≤ qrStageHorizonBudget n stageBudget t := by
  intro t
  by_cases ht : t ≤ n
  · simpa [qrStageHorizonBudget, ht] using hBudget_nonneg t
  · simpa [qrStageHorizonBudget, ht] using hBudget_nonneg n

theorem qrStageHorizonBudget_mono_of_mono_on_stages
    (n : ℕ) (stageBudget : ℕ → ℝ)
    (hBudget_mono_on_stages :
      ∀ a b : ℕ, a ≤ b → b ≤ n → stageBudget a ≤ stageBudget b) :
    ∀ a b : ℕ, a ≤ b →
      qrStageHorizonBudget n stageBudget a ≤
        qrStageHorizonBudget n stageBudget b := by
  intro a b hab
  by_cases hb : b ≤ n
  · have ha : a ≤ n := le_trans hab hb
    simpa [qrStageHorizonBudget, ha, hb] using
      hBudget_mono_on_stages a b hab hb
  · by_cases ha : a ≤ n
    · have hle : stageBudget a ≤ stageBudget n :=
        hBudget_mono_on_stages a n ha le_rfl
      simpa [qrStageHorizonBudget, ha, hb] using hle
    · simp [qrStageHorizonBudget, ha, hb]

/-- The scalar active/prefix row-max comparison defect is stable under the
    QR-horizon clamp.

Only stages `k < n` appear in the finite comparison maximum, so replacing the
budget by `qrStageHorizonBudget n stageBudget` preserves the displayed
comparison certificate consumed by the source-control handoff. -/
theorem storedQRStageRowMaxComparisonDefectBudget_nonpos_of_horizonBudget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ)
    (hcomparison :
      storedQRStageRowMaxComparisonDefectBudget hmn A_hat stageBudget ≤ 0) :
    storedQRStageRowMaxComparisonDefectBudget hmn A_hat
        (qrStageHorizonBudget n stageBudget) ≤ 0 := by
  apply storedQRStageRowMaxComparisonDefectBudget_nonpos_of_stageBudget_le_rowMax
  intro k hk i hi
  have hstage :=
    storedQRStageBudget_le_rowMax_of_stageRowMaxComparisonDefectBudget_nonpos
      hmn A_hat stageBudget hcomparison k hk i hi
  have hk_le : k ≤ n := Nat.le_of_lt hk
  simpa [qrStageHorizonBudget, hk_le] using hstage

/-- A single finite global compact-step recurrence supplies both one-step
    budget fields used by the active/prefix QR certificate.

    This closes the bookkeeping part of the red QR bottleneck: instead of
    assuming separate active-row and prefix-row one-step inequalities, it is
    enough to show that `stageBudget (t+1)` dominates the Cox--Higham exact
    factor plus the finite maximum compact component at stage `t`. -/
theorem storedQRSignedStage_active_prefix_budgets_of_globalCompactBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hglobalBudget : ∀ t (ht : t < n),
      coxHighamActiveRowGrowthFactor m * stageBudget t +
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht ≤
        stageBudget (t + 1)) :
    (∀ t : ℕ, t + 1 < n →
      ∀ r : Fin m, t + 1 ≤ r.val →
        ∀ l : Fin n, t + 1 ≤ l.val →
          coxHighamActiveRowGrowthFactor m * stageBudget t +
              householderCompactComponentBudget fp m
                (storedQRSignedStageVector hmn A_hat alpha t)
                (storedQRSignedStageBeta hmn A_hat alpha t)
                (fun a => A_hat t a l) r ≤
            stageBudget (t + 1)) ∧
    (∀ t (_ht : t < n),
      ∀ r : Fin m, r.val < t + 1 →
        ∀ l : Fin n, t ≤ l.val →
          coxHighamActiveRowGrowthFactor m * stageBudget t +
              householderCompactComponentBudget fp m
                (storedQRSignedStageVector hmn A_hat alpha t)
                (storedQRSignedStageBeta hmn A_hat alpha t)
                (fun a => A_hat t a l) r ≤
            stageBudget (t + 1)) := by
  classical
  constructor
  · intro t ht r _hr l _hl
    have htn : t < n := Nat.lt_trans (Nat.lt_succ_self t) ht
    have hcomp :
        householderCompactComponentBudget fp m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t)
            (fun a => A_hat t a l) r ≤
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t htn :=
      storedQRSignedStage_compact_component_le_globalBudget
        hmn fp A_hat alpha t htn r l
    have hstep :
        coxHighamActiveRowGrowthFactor m * stageBudget t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a l) r ≤
          coxHighamActiveRowGrowthFactor m * stageBudget t +
            storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t htn := by
      simpa [add_comm] using
        (add_le_add_left hcomp
          (coxHighamActiveRowGrowthFactor m * stageBudget t))
    exact hstep.trans (hglobalBudget t htn)
  · intro t ht r _hr l _hl
    have hcomp :
        householderCompactComponentBudget fp m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t)
            (fun a => A_hat t a l) r ≤
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht :=
      storedQRSignedStage_compact_component_le_globalBudget
        hmn fp A_hat alpha t ht r l
    have hstep :
        coxHighamActiveRowGrowthFactor m * stageBudget t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a l) r ≤
          coxHighamActiveRowGrowthFactor m * stageBudget t +
            storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht := by
      simpa [add_comm] using
        (add_le_add_left hcomp
          (coxHighamActiveRowGrowthFactor m * stageBudget t))
    exact hstep.trans (hglobalBudget t ht)

/-- Uniform signed-stage source-control handoff deriving the active-suffix
