      (∀ i, |Deltaf i| ≤
        cFsrc * lsTheorem20_4DeltafMajorant H1w H2w f rhat i) ∧
      (∀ j, |Deltag j| ≤
        cG * lsTheorem20_4DeltagMajorant A H3w rhat j) ∧
