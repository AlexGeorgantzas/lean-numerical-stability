      (∀ i j, 0 ≤ H2w i j) ∧
      (∀ i j, 0 ≤ H3w i j) ∧
      frobNorm H1w = 1 ∧
      frobNorm H2w = 1 ∧
      frobNorm H3w = 1 ∧
