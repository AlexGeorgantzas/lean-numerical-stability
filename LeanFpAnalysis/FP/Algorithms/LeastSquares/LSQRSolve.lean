/-- Route-elimination witness for the canonical rational-gamma scalar
    smallness condition.

    Even in the `1 x 1` diagonally dominant, source-nonbreakdown case with
    `fp.u <= Ucap` and `(m : ℝ) * Ucap < 1`, the displayed canonical scalar
    inequality need not hold.  The witness takes the abstract exact
    `FPModel.exactWithUnitRoundoff (1/2)`, the constant matrix `A = [1]`, and
    `Ucap = 1/2`; the canonical scalar expression evaluates to a concrete
    number greater than `1`.

    This is a theorem-statement correction for the QR bottleneck: the scalar
    inequality is a genuine numerical/domain assumption unless future work
    proves stronger scale, conditioning, or machine-model hypotheses. -/
theorem not_forall_diagDominant_sourceDen_uCap_implies_uRationalGammaCanonicalSmallness :
    ¬ (∀
      (fp : FPModel)
      (A_hat : ℕ → Fin 1 → Fin 1 → ℝ)
      (alpha : ℕ → ℝ)
      (Ucap : ℝ),
      gammaValid fp 1 →
      (∀ k : Fin 1,
        IsDiagDominantUpper (k.val + 1)
          (qrLeadingBlock (A_hat k.val)
            (Nat.succ_le_iff.mpr
              (lt_of_lt_of_le k.isLt (by norm_num : 1 ≤ 1))) k.isLt)) →
      0 ≤ Ucap →
      (∀ k (hk : k < 1),
        (∑ i : Fin 1,
          householderTrailingActiveVector 1
              ⟨k, lt_of_lt_of_le hk (by norm_num : 1 ≤ 1)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
            householderTrailingActiveVector 1
              ⟨k, lt_of_lt_of_le hk (by norm_num : 1 ≤ 1)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0) →
      fp.u ≤ Ucap →
      (1 : ℝ) * Ucap < 1 →
      (let Dcap := storedQRDiagDominantInvFactorBudget (by norm_num : 1 ≤ 1) A_hat
       let Ncap := storedQRPivotColumnNormBudget (by norm_num : 1 ≤ 1) A_hat
       let Gcap := ((1 : ℝ) * Ucap) / (1 - (1 : ℝ) * Ucap)
       let Fcap :=
          Ucap * (1 + Gcap) * (1 + Ucap) +
            Ucap * (1 + Gcap) +
            Gcap +
            Ucap * (1 + Gcap) * (1 + Ucap) ^ 2
       2 * Dcap *
            ((1 : ℝ) *
              ((((1 : ℝ) * ((1 : ℝ) + 1) * (Ucap + 2 * Fcap)) *
                  Ncap) ^ 2)) <
          1)) := by
  intro h
  let fp : FPModel := FPModel.exactWithUnitRoundoff ((1 : ℝ) / 2) (by norm_num)
  let A_hat : ℕ → Fin 1 → Fin 1 → ℝ := fun _ _ _ => 1
  let alpha : ℕ → ℝ := fun _ => 0
  have hm : gammaValid fp 1 := by
    norm_num [fp, FPModel.exactWithUnitRoundoff, gammaValid]
  have hDD : ∀ k : Fin 1,
        IsDiagDominantUpper (k.val + 1)
          (qrLeadingBlock (A_hat k.val)
            (Nat.succ_le_iff.mpr
              (lt_of_lt_of_le k.isLt (by norm_num : 1 ≤ 1))) k.isLt) := by
    intro k
    fin_cases k
    refine ⟨?_, ?_, ?_⟩
    · intro i j hji
      fin_cases i
      fin_cases j
      omega
    · intro i
      fin_cases i
      norm_num [A_hat, qrLeadingBlock, qrLeadingRow, qrLeadingColumn]
    · intro i j hij
      fin_cases i
      fin_cases j
      omega
  have hden : ∀ k (hk : k < 1),
        (∑ i : Fin 1,
          householderTrailingActiveVector 1
              ⟨k, lt_of_lt_of_le hk (by norm_num : 1 ≤ 1)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
            householderTrailingActiveVector 1
              ⟨k, lt_of_lt_of_le hk (by norm_num : 1 ≤ 1)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0 := by
    intro k hk
    interval_cases k
    norm_num [A_hat, alpha, householderTrailingActiveVector,
      householderActiveVector, householderTrailingPart]
  have hbad := h fp A_hat alpha ((1 : ℝ) / 2) hm hDD
    (by norm_num) hden (by norm_num [fp, FPModel.exactWithUnitRoundoff])
    (by norm_num)
  norm_num [storedQRDiagDominantInvFactorBudget,
    storedQRPivotColumnNormBudget, diagDominantUpperInvBudgetExpr,
    qrLeadingBlock, qrLeadingRow, qrLeadingColumn, vecNorm2, vecNorm2Sq,
    A_hat] at hbad
  ring_nf at hbad
  have hnot :
      ¬ (441 / 2 + 1 * Nat.rawCast 567 + 1 ^ 2 * (729 / 2) : ℝ) < 1 := by
    intro hlt
    norm_num at hlt
    exact (by norm_num : ¬ ((1152 : ℝ) < 1)) hlt
  exact hnot hbad

