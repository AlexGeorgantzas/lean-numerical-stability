/-- The first exact Householder QR counterexample state used to rule out
    deriving diagonal dominance from the unpivoted trailing Householder
    recurrence itself. -/
def exactHouseholderQRDiagDominanceCounterexampleA1 :
    Fin 2 → Fin 2 → ℝ :=
  fun i j =>
    if i.val = 0 ∧ j.val = 0 then -1
    else if i.val = 0 ∧ j.val = 1 then -2
    else if i.val = 1 ∧ j.val = 1 then 1
    else 0

/-- The final exact Householder QR counterexample state.  It is upper
    triangular with nonzero diagonal but it is not diagonally dominant. -/
def exactHouseholderQRDiagDominanceCounterexampleA2 :
    Fin 2 → Fin 2 → ℝ :=
  fun i j =>
    if i.val = 0 ∧ j.val = 0 then -1
    else if i.val = 0 ∧ j.val = 1 then -2
    else if i.val = 1 ∧ j.val = 1 then -1
    else 0

/-- Exact two-step unpivoted trailing Householder sequence for the diagonal
    dominance counterexample. -/
def exactHouseholderQRDiagDominanceCounterexampleSeq :
    ℕ → Fin 2 → Fin 2 → ℝ
  | 0 => diagDominanceCounterexample2
  | 1 => exactHouseholderQRDiagDominanceCounterexampleA1
  | _ => exactHouseholderQRDiagDominanceCounterexampleA2

/-- Source-style signed Householder scalars for the two-step counterexample. -/
def exactHouseholderQRDiagDominanceCounterexampleAlpha : ℕ → ℝ
  | 0 => -1
  | _ => -1

/-- Exact arithmetic model used to lift the diagonal-dominance counterexample
    to the stored-panel floating-point recurrence surface. -/
noncomputable def exactHouseholderQRDiagDominanceCounterexampleFP : FPModel :=
  FPModel.exactWithUnitRoundoff 0 (by norm_num)

/-- The counterexample sequence really follows the exact unpivoted trailing
    Householder recurrence. -/
theorem exactHouseholderQRDiagDominanceCounterexample_step :
    ∀ k (hk : k < 2),
      exactHouseholderQRDiagDominanceCounterexampleSeq (k + 1) =
        matMulRectLeft
          (householder 2
            (householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i =>
                exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩)
              (exactHouseholderQRDiagDominanceCounterexampleAlpha k))
            (householderBetaSpec 2
              (householderTrailingActiveVector 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i =>
                  exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩)
                (exactHouseholderQRDiagDominanceCounterexampleAlpha k))))
          (exactHouseholderQRDiagDominanceCounterexampleSeq k) := by
  intro k hk
  interval_cases k
  · ext i j
    fin_cases i <;> fin_cases j <;>
      norm_num [exactHouseholderQRDiagDominanceCounterexampleSeq,
        exactHouseholderQRDiagDominanceCounterexampleA1,
        diagDominanceCounterexample2,
        exactHouseholderQRDiagDominanceCounterexampleAlpha,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec, householder,
        matMulRectLeft, idMatrix]
  · ext i j
    fin_cases i <;> fin_cases j <;>
      norm_num [exactHouseholderQRDiagDominanceCounterexampleSeq,
        exactHouseholderQRDiagDominanceCounterexampleA1,
        exactHouseholderQRDiagDominanceCounterexampleA2,
        exactHouseholderQRDiagDominanceCounterexampleAlpha,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec, householder,
        matMulRectLeft, idMatrix]

