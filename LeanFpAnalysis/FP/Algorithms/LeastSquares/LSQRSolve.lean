      (fl_backSub fp n
        (fun i j => A_hat n ⟨i.val, lt_of_lt_of_le i.isLt hmn⟩ j)
        (fun i => b_hat n ⟨i.val, lt_of_lt_of_le i.isLt hmn⟩))
      c_G c_g := by
  classical
  have hdetPrev : ∀ k (hk : k < n),
      Matrix.det
        (qrPreviousLeadingBlockTranspose (A_hat k)
          (le_of_lt (lt_of_lt_of_le hk hmn)) hk :
