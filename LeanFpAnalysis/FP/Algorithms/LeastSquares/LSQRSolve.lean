    let cTop : Fin n → ℝ := fun i => c_hat (Fin.castAdd k i)
    let cBot : Fin k → ℝ := fun i => c_hat (Fin.natAdd n i)
    let h : Fin n → ℝ := fl_forwardSub fp n (matTranspose R) g
    let x : Fin n → ℝ := fl_backSub fp n R (fun i : Fin n => cTop i - h i)
