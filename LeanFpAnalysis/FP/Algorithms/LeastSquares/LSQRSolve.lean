  have hdual : (m : ℝ) * budget ^ 2 < 1 / (2 * D) :=
    mul_sq_lt_inv_two_mul_of_two_mul_mul_sq_lt_one hDpos hsmall_local
  have hKpos : 0 < 2 * D := by nlinarith
  simpa [budget, S, C, D, hkm] using
    dim_mul_budget_sq_lt_trailingNorm2Sq_of_leadingBlock_leftInverse_infNorm_budget
