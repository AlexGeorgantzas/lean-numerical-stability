        (qrPrefixRow m k (le_of_lt (lt_of_lt_of_le hk hmn)) r)
        (qrPreviousColumn n k hk r) ≠ 0)
    (hdiagLead : ∀ k (hk : k < n) (r : Fin (k + 1)),
