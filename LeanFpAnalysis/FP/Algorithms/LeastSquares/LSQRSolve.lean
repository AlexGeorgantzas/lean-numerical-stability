  · intro k hk i j _hij t ht
    have ht_le_k : t ≤ k := by
      exact le_trans (Nat.le_of_lt ht) (qrLeadingOffdiagStop_le j)
    have htn : t < n := lt_of_le_of_lt ht_le_k hk
    have hcomp :
        householderCompactComponentBudget fp m
            (storedQRSignedStageVector hmn A_hat alpha t)
