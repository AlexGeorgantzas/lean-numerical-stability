        (qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk :
          Matrix (Fin (k + 1)) (Fin (k + 1)) ℝ) ≠ 0)
    (hoffdiagBudget : ∀ k (hk : k < n),
      ∀ i j : Fin (k + 1), i.val < j.val →
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i j| ≤
        rowBudget k hk i)
    (hrowBudget_diag : ∀ k (hk : k < n),
      ∀ i : Fin (k + 1), i.val < k →
        rowBudget k hk i ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|)
    (hproduct : ∀ k (hk : k < n),
      2 *
          diagDominantUpperInvBudgetExpr (k + 1)
            (qrLeadingBlock (A_hat k)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)
            ⟨k, Nat.lt_succ_self k⟩ *
        ((m : ℝ) *
          (storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha *
            vecNorm2 (fun i : Fin m => A_hat k i ⟨k, hk⟩)) ^ 2) <
        1) :
    StoredQRSourceOffDiagonalControl hmn fp A_hat b_hat alpha := by
  classical
  refine
    StoredQRSourceOffDiagonalControl.of_stored_trailing_sequence_leadingBlock_det_ne_zero_normSqBudget_offdiag_product
      hmn fp A_hat b_hat alpha hm hStepA hAlphaDef hbudgetNormSq
      hdetLead ?_ hproduct
  intro k hk i j hij
  have hj_le_k : j.val ≤ k := Nat.le_of_lt_succ j.isLt
  have hi_lt_k : i.val < k := lt_of_lt_of_le hij hj_le_k
  exact (hoffdiagBudget k hk i j hij).trans
    (hrowBudget_diag k hk i hi_lt_k)

/-- Explicit row-budget control certificate for displayed QR leading blocks.

    This packages the two source-facing obligations left by the Cox--Higham
    row-growth route: a row budget controls every displayed strict upper entry,
    and that same row budget is no larger than the displayed diagonal on rows
    that actually have strict upper entries.  The final row of a `(k+1) ×
    (k+1)` leading block has no such strict upper entry, so no diagonal
    comparison is required there. -/
structure StoredQRDisplayedRowBudgetControl
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (rowBudget : ∀ k, k < n → Fin (k + 1) → ℝ) : Prop where
  offdiag_le : ∀ k (hk : k < n),
    ∀ i j : Fin (k + 1), i.val < j.val →
      |qrLeadingBlock (A_hat k)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i j| ≤
      rowBudget k hk i
  diag_lower : ∀ k (hk : k < n),
    ∀ i : Fin (k + 1), i.val < k →
      rowBudget k hk i ≤
      |qrLeadingBlock (A_hat k)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|

/-- Canonical finite row budget for strict upper entries of a displayed
    leading block.

For rows `i < k`, this is the maximum absolute value among the strict upper
entries `(i,j)`, `i < j`, of the `(k+1) × (k+1)` displayed leading block.  The
last row has no strict upper entry, so its value is irrelevant to
`StoredQRDisplayedRowBudgetControl` and is set to zero. -/
noncomputable def qrLeadingStrictUpperRowMaxBudget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (k : ℕ) (hk : k < n) (i : Fin (k + 1)) : ℝ :=
  if hi : i.val < k then
    Finset.sup'
      (Finset.univ.filter (fun j : Fin (k + 1) => i.val < j.val))
      (by
        refine ⟨⟨k, Nat.lt_succ_self k⟩, ?_⟩
        simp only [Finset.mem_filter, Finset.mem_univ, true_and]
        exact hi)
      (fun j =>
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i j|)
  else 0

theorem qrLeadingStrictUpperRowMaxBudget_entry_le
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    {k : ℕ} (hk : k < n) {i j : Fin (k + 1)}
    (hij : i.val < j.val) :
    |qrLeadingBlock (A_hat k)
      (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i j| ≤
    qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i := by
  classical
  have hi_lt_k : i.val < k :=
    lt_of_lt_of_le hij (Nat.le_of_lt_succ j.isLt)
  rw [qrLeadingStrictUpperRowMaxBudget, dif_pos hi_lt_k]
  have hmem :
      j ∈ Finset.univ.filter (fun j : Fin (k + 1) => i.val < j.val) := by
    simp only [Finset.mem_filter, Finset.mem_univ, true_and]
    exact hij
  exact
    Finset.le_sup'
      (s := Finset.univ.filter (fun j : Fin (k + 1) => i.val < j.val))
      (f := fun j =>
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i j|)
      hmem

theorem qrLeadingStrictUpperRowMaxBudget_le_diag_of_offdiag
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    {k : ℕ} (hk : k < n) {i : Fin (k + 1)}
    (hi : i.val < k)
    (hoffdiag : ∀ j : Fin (k + 1), i.val < j.val →
      |qrLeadingBlock (A_hat k)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i j| ≤
      |qrLeadingBlock (A_hat k)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|) :
    qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i ≤
      |qrLeadingBlock (A_hat k)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| := by
  classical
  rw [qrLeadingStrictUpperRowMaxBudget, dif_pos hi]
  apply Finset.sup'_le
  intro j hj
  have hij : i.val < j.val := by
    exact (Finset.mem_filter.mp hj).2
  exact hoffdiag j hij

/-- Finite scalar defect for the route-1 row-max/diagonal contraction field.

This is the maximum over all displayed rows that have strict upper entries of
`rowMax - |diag|`.  It is zero when no such displayed row exists.  Thus the
single scalar condition `storedQRRowMaxDiagDefectBudget <= 0` is exactly the
finite check needed for the `ρ = 1` row-max contraction branch. -/
noncomputable def storedQRRowMaxDiagDefectBudget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ) : ℝ :=
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  if hs : s.Nonempty then
    Finset.sup' s hs (fun p =>
      if hi : p.2.val < p.1.val then
        let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
        qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i -
          |qrLeadingBlock (A_hat p.1.val)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn)) p.1.isLt
            i i|
      else 0)
  else 0

/-- Each displayed row-max/diagonal defect is bounded by the finite scalar
    defect budget. -/
theorem storedQRRowMaxDiagDefect_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    {k : ℕ} (hk : k < n) (i : Fin (k + 1)) (hi : i.val < k) :
    qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i -
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| ≤
      storedQRRowMaxDiagDefectBudget hmn A_hat := by
  classical
  let p : Fin n × Fin n := (⟨k, hk⟩, ⟨i.val, lt_trans hi hk⟩)
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  have hmem : p ∈ s := by
    simp [s, p, hi]
  have hs : s.Nonempty := ⟨p, hmem⟩
  unfold storedQRRowMaxDiagDefectBudget
  rw [dif_pos hs]
  have hsup :
      (if hp : p.2.val < p.1.val then
        let i' : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hp⟩
        qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i' -
          |qrLeadingBlock (A_hat p.1.val)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn)) p.1.isLt
            i' i'|
      else 0) ≤
        Finset.sup' s hs (fun p =>
          if hi : p.2.val < p.1.val then
            let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
            qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i -
              |qrLeadingBlock (A_hat p.1.val)
                (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
                p.1.isLt i i|
          else 0) :=
    Finset.le_sup' (s := s)
      (f := fun p =>
        if hi : p.2.val < p.1.val then
          let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
          qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i -
            |qrLeadingBlock (A_hat p.1.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
              p.1.isLt i i|
        else 0)
      hmem
  convert hsup using 1
  simp [p, hi]

/-- Local diagonal dominance makes the canonical scalar row-max/diagonal defect
    nonpositive.

This bridges the diagonal-dominant route and the row-max defect route: if every
displayed leading block is `IsDiagDominantUpper`, then every strict-upper row
maximum is bounded by the matching displayed diagonal, so the finite maximum of
`rowMax - |diag|` is at most zero. -/
theorem storedQRRowMaxDiagDefectBudget_nonpos_of_diagDominant
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (hDD : ∀ k (hk : k < n),
      IsDiagDominantUpper (k + 1)
        (qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)) :
    storedQRRowMaxDiagDefectBudget hmn A_hat ≤ 0 := by
  classical
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  unfold storedQRRowMaxDiagDefectBudget
  by_cases hs : s.Nonempty
  · rw [dif_pos hs]
    apply Finset.sup'_le
    intro p hp
    by_cases hi : p.2.val < p.1.val
    · let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
      have hrow :
          qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i ≤
            |qrLeadingBlock (A_hat p.1.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
              p.1.isLt i i| := by
        refine
          qrLeadingStrictUpperRowMaxBudget_le_diag_of_offdiag
            hmn A_hat p.1.isLt hi ?_
        intro j hij
        exact (hDD p.1.val p.1.isLt).2.2 i j hij
      have hterm :
          qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i -
              |qrLeadingBlock (A_hat p.1.val)
                (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
                p.1.isLt i i| ≤ 0 := by
        linarith
      simpa [hi, i] using hterm
    · simp [hi]
  · rw [dif_neg hs]

/-- Uniform row-max contraction gives the displayed row-budget certificate.

This is the source-facing shape of the stronger computed-loop invariant needed
by the rectangular QR/preconditioner route.  If every finite strict-upper row
maximum in a displayed leading block is at most a scalar `ρ ≤ 1` times the
corresponding displayed diagonal, then the canonical row-max budget supplies
both fields of `StoredQRDisplayedRowBudgetControl`. -/
theorem StoredQRDisplayedRowBudgetControl.of_rowMaxBudget_le_diag_factor
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    {ρ : ℝ} (hρ : ρ ≤ 1)
    (hrowMaxContract : ∀ k (hk : k < n), ∀ i : Fin (k + 1), i.val < k →
      qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i ≤
        ρ *
          |qrLeadingBlock (A_hat k)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|) :
    StoredQRDisplayedRowBudgetControl hmn A_hat
      (fun k hk i => qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i) := by
  refine ⟨?_, ?_⟩
  · intro k hk i j hij
    exact qrLeadingStrictUpperRowMaxBudget_entry_le hmn A_hat hk hij
  · intro k hk i hi
    have hdiag_nonneg :
        0 ≤
          |qrLeadingBlock (A_hat k)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| :=
      abs_nonneg _
    have hfactor :
        ρ *
            |qrLeadingBlock (A_hat k)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| ≤
          1 *
            |qrLeadingBlock (A_hat k)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| :=
      mul_le_mul_of_nonneg_right hρ hdiag_nonneg
    exact (hrowMaxContract k hk i hi).trans (by simpa using hfactor)

/-- A nonpositive finite row-max/diagonal defect budget supplies the displayed
    row-budget certificate.

This is the scalar-budget version of the route-1 contraction branch: instead of
passing a family of inequalities, the caller proves the single finite condition
`storedQRRowMaxDiagDefectBudget <= 0`. -/
theorem StoredQRDisplayedRowBudgetControl.of_rowMaxDiagDefectBudget_nonpos
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (hdefect : storedQRRowMaxDiagDefectBudget hmn A_hat ≤ 0) :
    StoredQRDisplayedRowBudgetControl hmn A_hat
      (fun k hk i => qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i) := by
  refine
    StoredQRDisplayedRowBudgetControl.of_rowMaxBudget_le_diag_factor
      hmn A_hat (ρ := 1) (by norm_num) ?_
  intro k hk i hi
  have hle :=
    storedQRRowMaxDiagDefect_le_budget hmn A_hat hk i hi
  have hnonpos :
      qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i -
          |qrLeadingBlock (A_hat k)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| ≤ 0 :=
    hle.trans hdefect
  nlinarith

/-- Local diagonal dominance supplies the canonical row-max displayed
    row-budget certificate.

This is a small reuse wrapper around
`storedQRRowMaxDiagDefectBudget_nonpos_of_diagDominant` and
`StoredQRDisplayedRowBudgetControl.of_rowMaxDiagDefectBudget_nonpos`. -/
theorem StoredQRDisplayedRowBudgetControl.of_diagDominant
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (hDD : ∀ k (hk : k < n),
      IsDiagDominantUpper (k + 1)
        (qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)) :
    StoredQRDisplayedRowBudgetControl hmn A_hat
      (fun k hk i => qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i) :=
  StoredQRDisplayedRowBudgetControl.of_rowMaxDiagDefectBudget_nonpos
    hmn A_hat
    (storedQRRowMaxDiagDefectBudget_nonpos_of_diagDominant hmn A_hat hDD)

/-- Finite scalar defect for the uniform Cox--Higham stage-budget diagonal
    lower-bound field.

This is the maximum over displayed rows that have strict upper entries of
`stageBudget k - |S_k(i,i)|`.  Thus the single scalar condition
`storedQRStageDiagLowerDefectBudget <= 0` is exactly the finite check needed
to discharge the active/prefix route's diagonal lower-bound hypothesis
`stageBudget k <= |S_k(i,i)|` for rows `i < k`. -/
noncomputable def storedQRStageDiagLowerDefectBudget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ) : ℝ :=
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  if hs : s.Nonempty then
    Finset.sup' s hs (fun p =>
      if hi : p.2.val < p.1.val then
        let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
        stageBudget p.1.val -
          |qrLeadingBlock (A_hat p.1.val)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn)) p.1.isLt
            i i|
      else 0)
  else 0

/-- Each displayed stage-budget/diagonal defect is bounded by the finite scalar
    diagonal-lower defect budget. -/
theorem storedQRStageDiagLowerDefect_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ)
    {k : ℕ} (hk : k < n) (i : Fin (k + 1)) (hi : i.val < k) :
    stageBudget k -
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| ≤
      storedQRStageDiagLowerDefectBudget hmn A_hat stageBudget := by
  classical
  let p : Fin n × Fin n := (⟨k, hk⟩, ⟨i.val, lt_trans hi hk⟩)
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  have hmem : p ∈ s := by
    simp [s, p, hi]
  have hs : s.Nonempty := ⟨p, hmem⟩
  unfold storedQRStageDiagLowerDefectBudget
  rw [dif_pos hs]
  have hsup :
      (if hp : p.2.val < p.1.val then
        let i' : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hp⟩
        stageBudget p.1.val -
          |qrLeadingBlock (A_hat p.1.val)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
            p.1.isLt i' i'|
      else 0) ≤
        Finset.sup' s hs (fun p =>
          if hi : p.2.val < p.1.val then
            let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
            stageBudget p.1.val -
              |qrLeadingBlock (A_hat p.1.val)
                (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
                p.1.isLt i i|
          else 0) :=
    Finset.le_sup' (s := s)
      (f := fun p =>
        if hi : p.2.val < p.1.val then
          let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
          stageBudget p.1.val -
            |qrLeadingBlock (A_hat p.1.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
              p.1.isLt i i|
        else 0)
      hmem
  convert hsup using 1
  simp [p, hi]

/-- A nonpositive finite stage-diagonal defect budget supplies the diagonal
    lower-bound field for all displayed rows with strict upper entries. -/
theorem storedQRStageBudget_le_diag_of_stageDiagLowerDefectBudget_nonpos
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ)
    (hdefect : storedQRStageDiagLowerDefectBudget hmn A_hat stageBudget ≤ 0) :
    ∀ k (hk : k < n), ∀ i : Fin (k + 1), i.val < k →
      stageBudget k ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| := by
  intro k hk i hi
  have hle :=
    storedQRStageDiagLowerDefect_le_budget hmn A_hat stageBudget hk i hi
  have hnonpos :
      stageBudget k -
          |qrLeadingBlock (A_hat k)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i| ≤ 0 :=
    hle.trans hdefect
  linarith

/-- Pointwise diagonal lower bounds supply the scalar finite stage-diagonal
    defect condition.

This is the converse packaging theorem for
`storedQRStageBudget_le_diag_of_stageDiagLowerDefectBudget_nonpos`: the
finite scalar maximum is nonpositive exactly when every displayed
stage-budget/diagonal defect is nonpositive. -/
theorem storedQRStageDiagLowerDefectBudget_nonpos_of_stageBudget_le_diag
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ)
    (hdiag : ∀ k (hk : k < n), ∀ i : Fin (k + 1), i.val < k →
      stageBudget k ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|) :
    storedQRStageDiagLowerDefectBudget hmn A_hat stageBudget ≤ 0 := by
  classical
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  unfold storedQRStageDiagLowerDefectBudget
  by_cases hs : s.Nonempty
  · rw [dif_pos hs]
    apply Finset.sup'_le
    intro p hp
    by_cases hi : p.2.val < p.1.val
    · let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
      have hdiag_pi := hdiag p.1.val p.1.isLt i hi
      have hterm :
          stageBudget p.1.val -
            |qrLeadingBlock (A_hat p.1.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le p.1.isLt hmn))
              p.1.isLt i i| ≤ 0 := by
        linarith
      simpa [hi, i] using hterm
    · simp [hi]
  · rw [dif_neg hs]

/-- Row-max scalar control also supplies the stage-diagonal scalar condition
    when the uniform stage budget is no larger than the displayed row maximum.

This adapter links the row-max branch and the active/prefix stage-budget
branch without re-opening the finite-maximum proof: if `rowMax - |diag|` is
nonpositive everywhere and `stageBudget k <= rowMax(k,i)` on each displayed
off-diagonal row, then `stageBudget k - |diag|` is nonpositive everywhere. -/
theorem storedQRStageDiagLowerDefectBudget_nonpos_of_rowMaxDiagDefectBudget_nonpos_stageBudget_le_rowMax
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ)
    (hrowDefect : storedQRRowMaxDiagDefectBudget hmn A_hat ≤ 0)
    (hstage_le_rowMax : ∀ k (hk : k < n), ∀ i : Fin (k + 1), i.val < k →
      stageBudget k ≤ qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i) :
    storedQRStageDiagLowerDefectBudget hmn A_hat stageBudget ≤ 0 := by
  classical
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  unfold storedQRStageDiagLowerDefectBudget
  by_cases hs : s.Nonempty
  · rw [dif_pos hs]
    apply Finset.sup'_le
    intro p hp
    by_cases hi : p.2.val < p.1.val
    · let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
      have hstage :
          stageBudget p.1.val ≤
            qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i :=
        hstage_le_rowMax p.1.val p.1.isLt i hi
      have hrow_le :=
        storedQRRowMaxDiagDefect_le_budget hmn A_hat p.1.isLt i hi
      have hterm :
