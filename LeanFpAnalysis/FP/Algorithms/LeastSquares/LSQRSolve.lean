  let v : ℕ → Fin m → ℝ := fun k =>
    if hk : k < n then
      householderTrailingActiveVector m
        ⟨k, lt_of_lt_of_le hk hmn⟩
        (fun a => A_hat k a ⟨k, hk⟩) (alpha k)
    else 0
  let β : ℕ → ℝ := fun k => householderBetaSpec m (v k)
  have hStep : ∀ k, k < n →
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k (v k) (β k) (A_hat k) := by
    intro k hk
    simpa [v, β, hk] using hStepA k hk
  have hprefixLower :=
    fl_householderStoredPanel_sequence_prefix_lower_zero
      fp v β A_hat hStep
  intro k hk
  let hkm : k + 1 ≤ m :=
    Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)
  let S : Fin (k + 1) → Fin (k + 1) → ℝ :=
    qrLeadingBlock (A_hat k) hkm hk
  let C : Fin (k + 1) → Fin (k + 1) → ℝ :=
    nonsingInv (k + 1) S
  let budget : ℝ :=
    householderCompactComponentBudget fp m
      (householderTrailingActiveVector m
        ⟨k, lt_of_lt_of_le hk hmn⟩
        (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
      (householderBetaSpec m
        (householderTrailingActiveVector m
          ⟨k, lt_of_lt_of_le hk hmn⟩
          (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
      (fun a => A_hat k a ⟨k, hk⟩)
      ⟨k, lt_of_lt_of_le hk hmn⟩
  have hupper : ∀ i j : Fin (k + 1), j.val < i.val →
      qrLeadingBlock (A_hat k) hkm hk i j = 0 := by
    intro i j hji
    have hjk : j.val < k := by omega
    exact
      hprefixLower k (Nat.le_of_lt hk)
        (qrLeadingRow m k hkm i)
        (qrLeadingColumn n k hk j)
        (by simpa [qrLeadingColumn] using hjk)
        (by simpa [qrLeadingRow, qrLeadingColumn] using hji)
  have hlowerPrev : ∀ (i : Fin m) (j : Fin k), k ≤ i.val →
      A_hat k i (qrPreviousColumn n k hk j) = 0 := by
    intro i j hi
    exact
      hprefixLower k (Nat.le_of_lt hk) i (qrPreviousColumn n k hk j)
        (by simp [qrPreviousColumn])
        (lt_of_lt_of_le j.isLt hi)
  have hprefixSpan : qrPrefixSupportSpannedByPreviousColumns (A_hat k) hk :=
    qrPrefixSupportSpannedByPreviousColumns_of_leadingBlock_upper_det_ne_zero
      (A_hat k) hkm hk hupper (by simpa [S, hkm] using hdetLead k hk)
      hlowerPrev
  have hC : IsLeftInverse (k + 1) S C := by
    exact
      (isInverse_nonsingInv_of_det_ne_zero (k + 1) S
        (by simpa [S, hkm] using hdetLead k hk)).1
  have hCinf : ((k + 1 : ℕ) : ℝ) * infNorm C ^ 2 ≤ K k := by
    simpa [S, C, hkm] using
      infNorm_sq_budget_of_kappaInf_le_and_det_ne_zero
        (k + 1) (Nat.succ_pos k) S C (κ k) (K k)
        (by simpa [S, hkm] using hdetLead k hk)
        (by simpa [S, C, hkm] using hκ k hk)
        (by simpa [S, hkm] using hκbudget k hk)
  simpa [budget, S, C, hkm] using
    dim_mul_budget_sq_lt_trailingNorm2Sq_of_leadingBlock_leftInverse_infNorm_budget
      (A_hat k) hkm hk C hC hprefixSpan (K k) budget
      (hK k hk) hCinf (by simpa [budget] using hbudgetDual k hk)

/-- Build the displayed row-budget control certificate from one monotone
    signed-stage budget sequence and a finite global compact-step budget.

This is the packaged-certificate version of the active/prefix Cox--Higham
route.  The finite global compact budget supplies the one-step row recurrences,
the active/prefix lemmas supply the exact same-reflector bounds, and the
remaining honest domain field is still the offdiag-row diagonal lower bound. -/
theorem StoredQRDisplayedRowBudgetControl.of_signed_stage_uniformBudget_globalCompactBudget_of_normSqBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hStepA : ∀ k (hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
          (householderBetaSpec m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
          (A_hat k))
    (hAlphaDef : ∀ k (hk : k < n),
      alpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩)))
          (A_hat k ⟨k, lt_of_lt_of_le hk hmn⟩ ⟨k, hk⟩))
    (hbudgetNormSq : ∀ k (hk : k < n),
      (m : ℝ) *
          (householderCompactComponentBudget fp m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
            (fun a => A_hat k a ⟨k, hk⟩)
            ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
        householderTrailingNorm2Sq m
          ⟨k, lt_of_lt_of_le hk hmn⟩
          (fun a => A_hat k a ⟨k, hk⟩))
    (hinitBlock : ∀ r : Fin m, ∀ l : Fin n,
      |A_hat 0 r l| ≤ stageBudget 0)
    (hglobalBudget : ∀ t (ht : t < n),
      coxHighamActiveRowGrowthFactor m * stageBudget t +
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht ≤
        stageBudget (t + 1))
    (hBudget_nonneg : ∀ t : ℕ, 0 ≤ stageBudget t)
    (hBudget_mono : ∀ a b : ℕ, a ≤ b → stageBudget a ≤ stageBudget b)
    (hBudget_diag : ∀ k (hk : k < n),
      ∀ i : Fin (k + 1), i.val < k →
        stageBudget k ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|)
    (hpivotMax : ∀ t (ht : t < n), ∀ l : Fin n, t ≤ l.val →
        householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) l ≤
          householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) ⟨t, ht⟩) :
    StoredQRDisplayedRowBudgetControl hmn A_hat
      (fun k (_hk : k < n) (_i : Fin (k + 1)) => stageBudget k) := by
  classical
  have hcompleted : ∀ t (_ht : t < n), ∀ j : Fin n, j.val < t →
      ∀ i : Fin m,
        matMulVec m
          (householder m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t))
          (fun a => A_hat t a j) i = A_hat t i j :=
    storedQRSignedStage_completed_column_preservation
      hmn fp A_hat alpha hStepA
  have hbudgets :=
    storedQRSignedStage_active_prefix_budgets_of_globalCompactBudget
      hmn fp A_hat alpha stageBudget hglobalBudget
  have hactiveBlock :
      ∀ t (_ht : t < n), ∀ row : Fin m, t ≤ row.val →
        ∀ l : Fin n, t ≤ l.val → |A_hat t row l| ≤ stageBudget t :=
    storedQRSignedStage_active_block_bound_of_signed_stage_budget
      hmn fp A_hat alpha stageBudget hm hStepA hAlphaDef hbudgetNormSq
      hinitBlock hbudgets.1 hBudget_nonneg hpivotMax hcompleted
  have hprefixRows :
      ∀ t (_ht : t < n), ∀ row : Fin m, row.val < t →
        ∀ l : Fin n, t ≤ l.val → |A_hat t row l| ≤ stageBudget t :=
    storedQRSignedStage_prefix_row_bound_of_active_block_and_prefix_budget
      hmn fp A_hat alpha stageBudget hm hStepA hAlphaDef hbudgetNormSq
      hBudget_nonneg hpivotMax hactiveBlock hbudgets.2
  refine
    StoredQRDisplayedRowBudgetControl.of_signed_stage_uniformBudget_factor_of_normSqBudget
      hmn fp A_hat alpha (coxHighamActiveRowGrowthFactor m) stageBudget
      hm hStepA hAlphaDef hbudgetNormSq ?_ ?_ ?_ hBudget_mono
      hBudget_diag
  · intro k hk i j _hij
    exact hinitBlock
      (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
      (qrLeadingColumn n k hk j)
  · intro k hk i j _hij t ht
    have ht_le_k : t ≤ k := by
      exact le_trans (Nat.le_of_lt ht) (qrLeadingOffdiagStop_le j)
    have htn : t < n := lt_of_le_of_lt ht_le_k hk
    have hcomp :
        householderCompactComponentBudget fp m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t)
            (fun a => A_hat t a (qrLeadingColumn n k hk j))
            (qrLeadingRow m k
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i) ≤
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t htn :=
      storedQRSignedStage_compact_component_le_globalBudget
        hmn fp A_hat alpha t htn
        (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
        (qrLeadingColumn n k hk j)
    have hstep :
        coxHighamActiveRowGrowthFactor m * stageBudget t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a (qrLeadingColumn n k hk j))
              (qrLeadingRow m k
                (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i) ≤
          coxHighamActiveRowGrowthFactor m * stageBudget t +
            storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t htn := by
      simpa [add_comm] using
        add_le_add_left hcomp (coxHighamActiveRowGrowthFactor m * stageBudget t)
    exact hstep.trans (hglobalBudget t htn)
  · intro k hk i j _hij t ht
    let row : Fin m :=
      qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i
    let col : Fin n := qrLeadingColumn n k hk j
    have ht_le_k : t ≤ k := by
      exact le_trans (Nat.le_of_lt ht) (qrLeadingOffdiagStop_le j)
    have htn : t < n := lt_of_le_of_lt ht_le_k hk
    have hcol : t ≤ col.val := by
      by_cases hjk : j.val < k
      · have htj : t ≤ j.val := by
          exact Nat.lt_succ_iff.mp
            (by simpa [col, qrLeadingOffdiagStop, hjk] using ht)
        simpa [col, qrLeadingColumn] using htj
      · have hle : j.val ≤ k := Nat.le_of_lt_succ j.isLt
        have heq : j.val = k := le_antisymm hle (le_of_not_gt hjk)
        have htk : t < k := by
          simpa [col, qrLeadingOffdiagStop, hjk, heq] using ht
        have htj : t ≤ j.val := by omega
        simpa [col, qrLeadingColumn] using htj
    have hnorm :
        0 <
          householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le htn hmn⟩
            (A_hat t) ⟨t, htn⟩ := by
      have hleft_nonneg :
          0 ≤
            (m : ℝ) *
              (householderCompactComponentBudget fp m
                (householderTrailingActiveVector m
                  ⟨t, lt_of_lt_of_le htn hmn⟩
                  (fun a => A_hat t a ⟨t, htn⟩) (alpha t))
                (householderBetaSpec m
                  (householderTrailingActiveVector m
                    ⟨t, lt_of_lt_of_le htn hmn⟩
                    (fun a => A_hat t a ⟨t, htn⟩) (alpha t)))
                (fun a => A_hat t a ⟨t, htn⟩)
                ⟨t, lt_of_lt_of_le htn hmn⟩) ^ 2 := by
        exact mul_nonneg (Nat.cast_nonneg m) (sq_nonneg _)
      have hpos := lt_of_le_of_lt hleft_nonneg (hbudgetNormSq t htn)
      simpa [householderTrailingColumnNorm2Sq] using hpos
    exact
      storedQRSignedStage_exact_same_reflector_bound_of_prefix_or_active_stage_bounds
        hmn A_hat alpha t htn row col (stageBudget t) (hAlphaDef t htn)
        hcol (hBudget_nonneg t)
        (fun hprefix => hprefixRows t htn row hprefix col hcol)
        hnorm
        (fun l hl => hpivotMax t htn l hl)
        (fun l hl => by
          by_cases hprefix : row.val < t
          · exact hprefixRows t htn row hprefix l hl
          · have hactive : t ≤ row.val := le_of_not_gt hprefix
            exact hactiveBlock t htn row hactive l hl)
        (fun r hr => hactiveBlock t htn r hr col hcol)

/-- Build the displayed row-budget control certificate from the same global
    compact-step recurrence, deriving norm-square nonbreakdown from the local
    `κ∞`/dual-budget route.

This is the row-budget-certificate counterpart of the solver-level
`..._kappaInf_selfNorm_dualBudget...` wrappers: the raw norm-square margin is
not a hidden hypothesis, but follows from the existing repository inverse
budget theorem. -/
theorem StoredQRDisplayedRowBudgetControl.of_signed_stage_uniformBudget_globalCompactBudget_kappaInf_dualBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha κ K : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hStepA : ∀ k (hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
          (householderBetaSpec m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
          (A_hat k))
    (hAlphaDef : ∀ k (hk : k < n),
      alpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩)))
          (A_hat k ⟨k, lt_of_lt_of_le hk hmn⟩ ⟨k, hk⟩))
    (hdetLead : ∀ k (hk : k < n),
      Matrix.det
        (qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk :
          Matrix (Fin (k + 1)) (Fin (k + 1)) ℝ) ≠ 0)
    (hK : ∀ k (_hk : k < n), 0 < K k)
    (hκ : ∀ k (hk : k < n),
      kappaInf (k + 1) (Nat.succ_pos k)
          (qrLeadingBlock (A_hat k)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)
          (nonsingInv (k + 1)
            (qrLeadingBlock (A_hat k)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)) ≤
        κ k)
    (hκbudget : ∀ k (hk : k < n),
      ((k + 1 : ℕ) : ℝ) *
          (κ k /
            infNorm
              (qrLeadingBlock (A_hat k)
                (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk)) ^ 2 ≤
        K k)
    (hbudgetDual : ∀ k (hk : k < n),
      (m : ℝ) *
          (householderCompactComponentBudget fp m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
            (fun a => A_hat k a ⟨k, hk⟩)
            ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
        1 / K k)
    (hinitBlock : ∀ r : Fin m, ∀ l : Fin n,
      |A_hat 0 r l| ≤ stageBudget 0)
    (hglobalBudget : ∀ t (ht : t < n),
      coxHighamActiveRowGrowthFactor m * stageBudget t +
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht ≤
        stageBudget (t + 1))
    (hBudget_nonneg : ∀ t : ℕ, 0 ≤ stageBudget t)
    (hBudget_mono : ∀ a b : ℕ, a ≤ b → stageBudget a ≤ stageBudget b)
    (hBudget_diag : ∀ k (hk : k < n),
      ∀ i : Fin (k + 1), i.val < k →
        stageBudget k ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|)
    (hpivotMax : ∀ t (ht : t < n), ∀ l : Fin n, t ≤ l.val →
        householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) l ≤
          householderTrailingColumnNorm2Sq
            (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
            (A_hat t) ⟨t, ht⟩) :
    StoredQRDisplayedRowBudgetControl hmn A_hat
      (fun k (_hk : k < n) (_i : Fin (k + 1)) => stageBudget k) := by
  have hbudgetNormSq :
      ∀ k (hk : k < n),
        (m : ℝ) *
            (householderCompactComponentBudget fp m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
              (householderBetaSpec m
                (householderTrailingActiveVector m
                  ⟨k, lt_of_lt_of_le hk hmn⟩
                  (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
              (fun a => A_hat k a ⟨k, hk⟩)
              ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
          householderTrailingNorm2Sq m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) :=
    storedQRSignedStage_normSqBudget_of_leadingBlock_det_ne_zero_kappaInf_selfNorm_dualBudget
      hmn fp A_hat alpha κ K hStepA hdetLead hK hκ hκbudget hbudgetDual
  exact
    StoredQRDisplayedRowBudgetControl.of_signed_stage_uniformBudget_globalCompactBudget_of_normSqBudget
      hmn fp A_hat alpha stageBudget hm hStepA hAlphaDef hbudgetNormSq
      hinitBlock hglobalBudget hBudget_nonneg hBudget_mono hBudget_diag
      hpivotMax

/-- The finite active-pivot policy supplies the raw pivot-maximality field.

This is the local pivot-policy reduction used by the active/prefix QR route:
if the displayed pivot column is chosen by `householderActiveMaxPivotColumn`
at every stored stage, then the row-growth theorems may consume the usual
trailing-column-norm maximality inequality. -/
theorem storedQRActiveMaxPivotColumn_pivotMax
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (hpivotChoice : ∀ t (ht : t < n),
      ⟨t, ht⟩ =
        householderActiveMaxPivotColumn
          ⟨t, lt_of_lt_of_le ht hmn⟩ ⟨t, ht⟩ (A_hat t)) :
    ∀ t (ht : t < n), ∀ l : Fin n, t ≤ l.val →
      householderTrailingColumnNorm2Sq
          (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
          (A_hat t) l ≤
        householderTrailingColumnNorm2Sq
          (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
          (A_hat t) ⟨t, ht⟩ := by
  intro t ht l hl
  have hmax :=
    householderActiveMaxPivotColumn_pivot_max
      ⟨t, lt_of_lt_of_le ht hmn⟩ ⟨t, ht⟩ (A_hat t) l hl
  have hnormEq :
      householderTrailingColumnNorm2Sq
          (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
          (A_hat t)
          (householderActiveMaxPivotColumn
            ⟨t, lt_of_lt_of_le ht hmn⟩ ⟨t, ht⟩ (A_hat t)) =
        householderTrailingColumnNorm2Sq
          (m := m) (n := n) ⟨t, lt_of_lt_of_le ht hmn⟩
          (A_hat t) ⟨t, ht⟩ := by
    rw [← hpivotChoice t ht]
  exact hmax.trans_eq hnormEq

/-- Active-max-pivot variant of
    `StoredQRDisplayedRowBudgetControl.of_signed_stage_uniformBudget_globalCompactBudget_of_normSqBudget`.

Instead of assuming the raw column-pivot maximality inequality, this constructor
uses the repository's finite active max-pivot selector.  This is the
Cox--Higham source-facing pivot-policy field: if the displayed active column is
chosen by `householderActiveMaxPivotColumn`, then the needed pivot-max
inequality follows from `householderActiveMaxPivotColumn_pivot_max`. -/
theorem StoredQRDisplayedRowBudgetControl.of_signed_stage_uniformBudget_globalCompactBudget_activeMaxPivot_of_normSqBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hStepA : ∀ k (hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
          (householderBetaSpec m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
          (A_hat k))
    (hAlphaDef : ∀ k (hk : k < n),
      alpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq m
              ⟨k, lt_of_lt_of_le hk hmn⟩
