  intro h
  exact exactHouseholderQRDiagDominanceCounterexample_not_diagDominant
    (h exactHouseholderQRDiagDominanceCounterexampleSeq
      exactHouseholderQRDiagDominanceCounterexampleAlpha
      exactHouseholderQRDiagDominanceCounterexample_step
      exactHouseholderQRDiagDominanceCounterexample_alpha_sq
      exactHouseholderQRDiagDominanceCounterexample_den_ne_zero)

