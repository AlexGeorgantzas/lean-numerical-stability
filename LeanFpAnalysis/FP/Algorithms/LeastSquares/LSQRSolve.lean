/-- Pointwise route bounds with the compact Householder coefficient estimated
    from `|β_k| * ‖v_k‖₂^2`.

    This specializes
    `storedQRCompactNormBudgetCoeffSmallness_of_pointwise_bounds` by taking
    `Cmax = u + Bmax * householderCompactNormBudgetCoeffFactor fp m`.
    It reduces the compact-coefficient route to three visible per-pivot fields:
    diagonal-dominant inverse-factor bounds, signed-stage
    `|β_k| * ‖v_k‖₂^2` bounds, and pivot-column norm bounds. -/
theorem storedQRCompactNormBudgetCoeffSmallness_of_pointwise_absBetaNormSq_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Dmax Bmax Nmax : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDmax_nonneg : 0 ≤ Dmax)
    (hBmax_nonneg : 0 ≤ Bmax)
    (hNmax_nonneg : 0 ≤ Nmax)
    (hD : ∀ k : Fin n,
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤ Dmax)
    (hB : ∀ k : Fin n,
      |storedQRSignedStageBeta hmn A_hat alpha k.val| *
          vecNorm2 (storedQRSignedStageVector hmn A_hat alpha k.val) ^ 2 ≤
        Bmax)
    (hN : ∀ k : Fin n,
      vecNorm2 (fun i : Fin m => A_hat k.val i k) ≤ Nmax)
    (hsmall :
      2 * Dmax *
          ((m : ℝ) *
            (((n : ℝ) *
                ((n : ℝ) *
                    (fp.u +
                      Bmax * householderCompactNormBudgetCoeffFactor fp m) +
                  (fp.u +
                    Bmax * householderCompactNormBudgetCoeffFactor fp m))) *
              Nmax) ^ 2) <
        1) :
    2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
        ((m : ℝ) *
          (((n : ℝ) *
              ((n : ℝ) *
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha +
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha)) *
            storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
      1 := by
  let Cmax : ℝ :=
    fp.u + Bmax * householderCompactNormBudgetCoeffFactor fp m
  have hCmax_nonneg : 0 ≤ Cmax := by
    dsimp [Cmax]
    exact add_nonneg fp.u_nonneg
      (mul_nonneg hBmax_nonneg
        (householderCompactNormBudgetCoeffFactor_nonneg fp m hm))
  have hC : ∀ k : Fin n,
      storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k ≤ Cmax := by
    intro k
    dsimp [Cmax]
    exact
      storedQRCompactStepNormBudgetCoeff_le_of_abs_beta_norm_sq_le
        hmn fp A_hat alpha Bmax hm k (hB k)
  have hsmallC :
      2 * Dmax *
          ((m : ℝ) *
            (((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax) ^ 2) <
        1 := by
    simpa [Cmax, add_assoc] using hsmall
  exact
    storedQRCompactNormBudgetCoeffSmallness_of_pointwise_bounds
      hmn fp A_hat alpha Dmax Cmax Nmax hm hDD
      hDmax_nonneg hCmax_nonneg hNmax_nonneg hD hC hN hsmallC

/-- Pointwise route bounds with the compact Householder coefficient specialized
    to exact Householder normalization and source-shaped nonbreakdown.

    This is the concrete `Bmax = 2` version of the preceding beta-norm route.
    It removes the abstract pointwise `|β_k| ‖v_k‖₂² ≤ Bmax` assumption by
    reusing the exact `β = 2/(vᵀv)` normalization theorem for each nonzero
    signed-stage denominator. -/
theorem storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Dmax Nmax : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDmax_nonneg : 0 ≤ Dmax)
    (hNmax_nonneg : 0 ≤ Nmax)
    (hD : ∀ k : Fin n,
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤ Dmax)
    (hden : ∀ k (hk : k < n),
      (∑ i : Fin m,
        householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
          householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0)
    (hN : ∀ k : Fin n,
      vecNorm2 (fun i : Fin m => A_hat k.val i k) ≤ Nmax)
    (hsmall :
      2 * Dmax *
          ((m : ℝ) *
            (((n : ℝ) *
                ((n : ℝ) *
                    (fp.u +
                      2 * householderCompactNormBudgetCoeffFactor fp m) +
                  (fp.u +
                    2 * householderCompactNormBudgetCoeffFactor fp m))) *
              Nmax) ^ 2) <
        1) :
    2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
        ((m : ℝ) *
          (((n : ℝ) *
              ((n : ℝ) *
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha +
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha)) *
            storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
      1 := by
  let Cmax : ℝ :=
    fp.u + 2 * householderCompactNormBudgetCoeffFactor fp m
  have hfactor_nonneg :
      0 ≤ householderCompactNormBudgetCoeffFactor fp m :=
    householderCompactNormBudgetCoeffFactor_nonneg fp m hm
  have hCmax_nonneg : 0 ≤ Cmax := by
    dsimp [Cmax]
    exact add_nonneg fp.u_nonneg (mul_nonneg (by linarith) hfactor_nonneg)
  have hC : ∀ k : Fin n,
      storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k ≤ Cmax :=
    storedQRCompactStepNormBudgetCoeff_le_of_forall_source_den_ne_zero
      hmn fp A_hat alpha hm hden
  have hsmallC :
      2 * Dmax *
          ((m : ℝ) *
            (((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax) ^ 2) <
        1 := by
    simpa [Cmax, add_assoc] using hsmall
  exact
    storedQRCompactNormBudgetCoeffSmallness_of_pointwise_bounds
      hmn fp A_hat alpha Dmax Cmax Nmax hm hDD
      hDmax_nonneg hCmax_nonneg hNmax_nonneg hD hC hN hsmallC

/-- Source-denominator coefficient route with the scalar smallness written in
    the compact form `n * (n + 1) * (u + 2F_m)`.

    This is only an algebraic normalization of
    `storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_bounds`.
    It keeps the numerical scalar-smallness condition explicit, but presents
    the exact-normalization coefficient branch in the source-facing form used
    by the route ledger. -/
theorem storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_simple_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Dmax Nmax : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDmax_nonneg : 0 ≤ Dmax)
    (hNmax_nonneg : 0 ≤ Nmax)
    (hD : ∀ k : Fin n,
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤ Dmax)
    (hden : ∀ k (hk : k < n),
      (∑ i : Fin m,
        householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
          householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0)
    (hN : ∀ k : Fin n,
      vecNorm2 (fun i : Fin m => A_hat k.val i k) ≤ Nmax)
    (hsmall :
      2 * Dmax *
          ((m : ℝ) *
            ((((n : ℝ) * ((n : ℝ) + 1) *
                    (fp.u +
                      2 * householderCompactNormBudgetCoeffFactor fp m)) *
                Nmax) ^ 2)) <
        1) :
    2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
        ((m : ℝ) *
          (((n : ℝ) *
              ((n : ℝ) *
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha +
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha)) *
            storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
      1 := by
  refine
    storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_bounds
      hmn fp A_hat alpha Dmax Nmax hm hDD
      hDmax_nonneg hNmax_nonneg hD hden hN ?_
  ring_nf at hsmall ⊢
  simpa using hsmall

/-- Source-denominator coefficient route with explicit caps on the unit roundoff
    and the Householder coefficient factor.

    This is a scalar-smallness dependency for the red LS.2g route: if the
    route constants `Dcap` and `Ncap` bound the local diagonal-dominant inverse
    factors and pivot-column norms, and if `Ucap` and `Fcap` bound `fp.u` and
    `householderCompactNormBudgetCoeffFactor fp m`, then the source-facing
    smallness condition follows from the same displayed inequality with those
    caps.  The theorem does not prove the `Dcap`/`Ncap` pointwise estimates,
    diagonal dominance, source nonbreakdown, or the numerical cap inequality. -/
theorem storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_cap_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Dcap Ncap Ucap Fcap : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDcap_nonneg : 0 ≤ Dcap)
    (hNcap_nonneg : 0 ≤ Ncap)
    (hUcap_nonneg : 0 ≤ Ucap)
    (hFcap_nonneg : 0 ≤ Fcap)
    (hD : ∀ k : Fin n,
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤ Dcap)
    (hden : ∀ k (hk : k < n),
      (∑ i : Fin m,
        householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
          householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0)
    (hN : ∀ k : Fin n,
      vecNorm2 (fun i : Fin m => A_hat k.val i k) ≤ Ncap)
    (hu : fp.u ≤ Ucap)
    (hF : householderCompactNormBudgetCoeffFactor fp m ≤ Fcap)
    (hsmall :
      2 * Dcap *
          ((m : ℝ) *
            ((((n : ℝ) * ((n : ℝ) + 1) * (Ucap + 2 * Fcap)) *
                Ncap) ^ 2)) <
        1) :
    2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
        ((m : ℝ) *
          (((n : ℝ) *
              ((n : ℝ) *
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha +
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha)) *
            storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
      1 := by
  refine
    storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_simple_bounds
      hmn fp A_hat alpha Dcap Ncap hm hDD
      hDcap_nonneg hNcap_nonneg hD hden hN ?_
  let F : ℝ := householderCompactNormBudgetCoeffFactor fp m
  let scale : ℝ := (n : ℝ) * ((n : ℝ) + 1)
  have hF_nonneg : 0 ≤ F := by
    simpa [F] using householderCompactNormBudgetCoeffFactor_nonneg fp m hm
  have hround_bound : fp.u + 2 * F ≤ Ucap + 2 * Fcap := by
    nlinarith [hu, hF]
  have hround_nonneg : 0 ≤ fp.u + 2 * F := by
    nlinarith [fp.u_nonneg, hF_nonneg]
  have hroundcap_nonneg : 0 ≤ Ucap + 2 * Fcap := by
    nlinarith [hUcap_nonneg, hFcap_nonneg]
  have hn_nonneg : 0 ≤ (n : ℝ) := Nat.cast_nonneg n
  have hn1_nonneg : 0 ≤ ((n : ℝ) + 1) := by
    nlinarith [hn_nonneg]
  have hscale_nonneg : 0 ≤ scale := by
    dsimp [scale]
    exact mul_nonneg hn_nonneg hn1_nonneg
  have hscale_bound :
      scale * (fp.u + 2 * F) ≤ scale * (Ucap + 2 * Fcap) :=
    mul_le_mul_of_nonneg_left hround_bound hscale_nonneg
  have hscale_actual_nonneg : 0 ≤ scale * (fp.u + 2 * F) :=
    mul_nonneg hscale_nonneg hround_nonneg
  have hscale_cap_nonneg : 0 ≤ scale * (Ucap + 2 * Fcap) :=
    mul_nonneg hscale_nonneg hroundcap_nonneg
  have hscaledN_bound :
      (scale * (fp.u + 2 * F)) * Ncap ≤
        (scale * (Ucap + 2 * Fcap)) * Ncap :=
    mul_le_mul_of_nonneg_right hscale_bound hNcap_nonneg
  have hscaledN_actual_nonneg : 0 ≤ (scale * (fp.u + 2 * F)) * Ncap :=
    mul_nonneg hscale_actual_nonneg hNcap_nonneg
  have hscaledN_cap_nonneg : 0 ≤ (scale * (Ucap + 2 * Fcap)) * Ncap :=
    mul_nonneg hscale_cap_nonneg hNcap_nonneg
  have hsq_bound :
      ((scale * (fp.u + 2 * F)) * Ncap) ^ 2 ≤
        ((scale * (Ucap + 2 * Fcap)) * Ncap) ^ 2 := by
    nlinarith [hscaledN_bound, hscaledN_actual_nonneg,
      hscaledN_cap_nonneg]
  have hm_nonneg : 0 ≤ (m : ℝ) := Nat.cast_nonneg m
  have hright_bound :
      (m : ℝ) * ((scale * (fp.u + 2 * F)) * Ncap) ^ 2 ≤
        (m : ℝ) * ((scale * (Ucap + 2 * Fcap)) * Ncap) ^ 2 :=
    mul_le_mul_of_nonneg_left hsq_bound hm_nonneg
  have hright_nonneg :
      0 ≤ (m : ℝ) * ((scale * (fp.u + 2 * F)) * Ncap) ^ 2 :=
    mul_nonneg hm_nonneg (sq_nonneg _)
  have hleft_nonneg : 0 ≤ 2 * Dcap := by
    nlinarith [hDcap_nonneg]
  have hprod_bound :
      2 * Dcap *
          ((m : ℝ) * ((scale * (fp.u + 2 * F)) * Ncap) ^ 2) ≤
        2 * Dcap *
          ((m : ℝ) * ((scale * (Ucap + 2 * Fcap)) * Ncap) ^ 2) :=
    mul_le_mul_of_nonneg_left hright_bound hleft_nonneg
  have hactual :
      2 * Dcap *
          ((m : ℝ) * ((scale * (fp.u + 2 * F)) * Ncap) ^ 2) < 1 :=
    lt_of_le_of_lt hprod_bound (by
      simpa [scale, mul_assoc] using hsmall)
  simpa [F, scale, mul_assoc] using hactual

/-- Source-denominator coefficient route with the Householder factor cap
    derived directly from a unit-roundoff cap.

    Compared with
    `storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_cap_bounds`,
    this theorem removes the separate hypothesis
    `householderCompactNormBudgetCoeffFactor fp m ≤ Fcap`.  The displayed
    `Fcap` is the explicit polynomial in `Ucap` and `Gcap`, while the remaining
    route obligations are the primitive unit-roundoff cap, the rational gamma
    cap, pointwise `Dcap`/`Ncap` bounds, source nonbreakdown, and the scalar
    cap-smallness inequality. -/
theorem storedQRCompactNormBudgetCoeffSmallness_of_pointwise_source_den_ne_zero_uGammaCapBounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Dcap Ncap Ucap Gcap : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
