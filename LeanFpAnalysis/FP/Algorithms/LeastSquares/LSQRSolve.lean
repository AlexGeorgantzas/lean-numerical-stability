  exact
    storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_stepBudget_le
      hmn fp A_hat b_hat alpha cStep hm hDD hcStep_nonneg hStep
      (by simpa [cStep] using hsmall)

/-- Canonical finite-maximum compact-product smallness from componentwise
    compact Householder column/RHS caps.

    This is the componentwise primitive-facing version of
    `storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_columnRhsNormBudget_le`:
    each explicit compact component budget is bounded by `cCol * |A_k(i,j)|`
    or `cRhs * |b_k(i)|`, and the local vector-norm adapter turns those
    inequalities into the norm-budget caps consumed by the product theorem. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_columnRhsComponentBudget_le
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (cCol cRhs : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hcCol_nonneg : 0 ≤ cCol)
    (hcRhs_nonneg : 0 ≤ cRhs)
    (hCol : ∀ k : Fin n, ∀ j : Fin n, ∀ i : Fin m,
      householderCompactComponentBudget fp m
        (storedQRSignedStageVector hmn A_hat alpha k.val)
        (storedQRSignedStageBeta hmn A_hat alpha k.val)
        (fun a : Fin m => A_hat k.val a j) i ≤
          cCol * |A_hat k.val i j|)
    (hRhs : ∀ k : Fin n, ∀ i : Fin m,
      householderCompactComponentBudget fp m
        (storedQRSignedStageVector hmn A_hat alpha k.val)
        (storedQRSignedStageBeta hmn A_hat alpha k.val)
        (b_hat k.val) i ≤ cRhs * |b_hat k.val i|)
    (hsmall :
      2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
          ((m : ℝ) *
            (((n : ℝ) * ((n : ℝ) * cCol + cRhs)) *
              storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  let cStep : ℝ := (n : ℝ) * cCol + cRhs
  have hcStep_nonneg : 0 ≤ cStep := by
    exact add_nonneg
      (mul_nonneg (Nat.cast_nonneg n) hcCol_nonneg)
      hcRhs_nonneg
  have hStep : ∀ k : Fin n,
      storedQRCompactStepRelativeBudget hmn fp A_hat b_hat alpha k ≤
        cStep := by
    intro k
    exact
      storedQRCompactStepRelativeBudget_le_mul_add_of_componentBudget_le_mul_abs
        hmn fp A_hat b_hat alpha k cCol cRhs
        hm hcCol_nonneg hcRhs_nonneg
        (hCol k) (hRhs k)
  exact
    storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_stepBudget_le
      hmn fp A_hat b_hat alpha cStep hm hDD hcStep_nonneg hStep
      (by simpa [cStep] using hsmall)

/-- Canonical finite-maximum compact-product smallness from the explicit
    reflector-dependent compact norm coefficient.

    This avoids assuming entrywise relative caps of the form
    `budget_i <= c * |input_i|`.  Instead each stored stage uses the valid
    normwise coefficient produced by the compact dot/scale/subtract arithmetic,
    and the caller only supplies a uniform bound `cHH` on those finite stage
    coefficients plus the resulting scalar smallness inequality. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_normBudgetCoeff_le
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (cHH : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hcHH_nonneg : 0 ≤ cHH)
    (hCoeff : ∀ k : Fin n,
      storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k ≤ cHH)
    (hsmall :
      2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
          ((m : ℝ) *
            (((n : ℝ) * ((n : ℝ) * cHH + cHH)) *
              storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  let cStep : ℝ := (n : ℝ) * cHH + cHH
  have hcStep_nonneg : 0 ≤ cStep := by
    exact add_nonneg
      (mul_nonneg (Nat.cast_nonneg n) hcHH_nonneg)
      hcHH_nonneg
  have hStep : ∀ k : Fin n,
      storedQRCompactStepRelativeBudget hmn fp A_hat b_hat alpha k ≤
        cStep := by
    intro k
    have hlocal :
        storedQRCompactStepRelativeBudget hmn fp A_hat b_hat alpha k ≤
          (n : ℝ) *
              storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k +
            storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k :=
      storedQRCompactStepRelativeBudget_le_mul_add_normBudgetCoeff
        hmn fp A_hat b_hat alpha hm k
    have hcap :
        (n : ℝ) *
              storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k +
            storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k ≤
          cStep := by
      exact add_le_add
        (mul_le_mul_of_nonneg_left (hCoeff k) (Nat.cast_nonneg n))
        (hCoeff k)
    exact hlocal.trans hcap
  exact
    storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_stepBudget_le
      hmn fp A_hat b_hat alpha cStep hm hDD hcStep_nonneg hStep
      (by simpa [cStep] using hsmall)

/-- Canonical finite maximum of the reflector-dependent compact norm
    coefficients over the stored QR stages.  The value is `0` when there are no
    pivots. -/
noncomputable def storedQRCompactStepNormBudgetCoeffBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ) : ℝ :=
  if hn : 0 < n then
    Finset.sup' (Finset.univ : Finset (Fin n))
      (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
      (fun k => storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k)
  else 0

/-- Each stored-stage reflector-dependent compact norm coefficient is bounded
    by its canonical finite maximum. -/
theorem storedQRCompactStepNormBudgetCoeff_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ) (k : Fin n) :
    storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k ≤
      storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha := by
  classical
  unfold storedQRCompactStepNormBudgetCoeffBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      Finset.le_sup' (s := (Finset.univ : Finset (Fin n)))
        (f := fun k => storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k)
        (Finset.mem_univ k)
  · have hnpos : 0 < n := lt_of_le_of_lt (Nat.zero_le k.val) k.isLt
    exact False.elim (hn hnpos)

/-- The canonical finite maximum of stored-stage compact norm coefficients is
    nonnegative. -/
theorem storedQRCompactStepNormBudgetCoeffBudget_nonneg
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ) (hm : gammaValid fp m) :
    0 ≤ storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha := by
  classical
  unfold storedQRCompactStepNormBudgetCoeffBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    let k0 : Fin n := ⟨0, hn⟩
    exact
      le_trans
        (storedQRCompactStepNormBudgetCoeff_nonneg hmn fp A_hat alpha hm k0)
        (Finset.le_sup' (s := (Finset.univ : Finset (Fin n)))
          (f := fun k =>
            storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k)
          (Finset.mem_univ k0))
  · rw [dif_neg hn]

/-- If every stored-stage reflector-dependent compact norm coefficient is
    bounded by a scalar, then the canonical finite maximum is bounded by that
    scalar.

    The nonnegativity hypothesis is only needed for the zero-pivot case. -/
theorem storedQRCompactStepNormBudgetCoeffBudget_le_of_forall_le
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Cmax : ℝ)
    (hCmax_nonneg : 0 ≤ Cmax)
    (hC : ∀ k : Fin n,
      storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k ≤ Cmax) :
    storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha ≤ Cmax := by
  classical
  unfold storedQRCompactStepNormBudgetCoeffBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      Finset.sup'_le
        (H := (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩))
        (f := fun k : Fin n =>
          storedQRCompactStepNormBudgetCoeff hmn fp A_hat alpha k)
        (by
          intro k _hk
          exact hC k)
  · rw [dif_neg hn]
    exact hCmax_nonneg

/-- The canonical finite maximum of stored-stage compact norm coefficients is
    bounded by the explicit Householder scalar factor once each signed stage
    satisfies a pivot-local `|β_k| * ‖v_k‖₂^2` bound.

    This is the coefficient-estimate handoff for the compact QR product route:
    it reduces the abstract `Cmax` hypothesis to a uniform bound on the
    reflector normalization quantity. -/
theorem storedQRCompactStepNormBudgetCoeffBudget_le_of_forall_abs_beta_norm_sq_le
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Bmax : ℝ)
    (hm : gammaValid fp m)
    (hBmax_nonneg : 0 ≤ Bmax)
    (hB : ∀ k : Fin n,
      |storedQRSignedStageBeta hmn A_hat alpha k.val| *
          vecNorm2 (storedQRSignedStageVector hmn A_hat alpha k.val) ^ 2 ≤
        Bmax) :
    storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha ≤
      fp.u + Bmax * householderCompactNormBudgetCoeffFactor fp m := by
  have hfactor_nonneg :
      0 ≤ householderCompactNormBudgetCoeffFactor fp m :=
    householderCompactNormBudgetCoeffFactor_nonneg fp m hm
  have hCmax_nonneg :
      0 ≤ fp.u + Bmax * householderCompactNormBudgetCoeffFactor fp m :=
    add_nonneg fp.u_nonneg (mul_nonneg hBmax_nonneg hfactor_nonneg)
  exact
    storedQRCompactStepNormBudgetCoeffBudget_le_of_forall_le
      hmn fp A_hat alpha
      (fp.u + Bmax * householderCompactNormBudgetCoeffFactor fp m)
      hCmax_nonneg
      (storedQRCompactStepNormBudgetCoeff_le_of_forall_abs_beta_norm_sq_le
        hmn fp A_hat alpha Bmax hm hB)

/-- Canonical finite-maximum coefficient bound from the source-shaped
    nonbreakdown hypothesis for the signed Householder stages.

    This closes the `Bmax` dependency of the compact-product route for the
    exact Householder normalization: each nonzero denominator gives
    `|β_k| ‖v_k‖₂² = 2`, hence the displayed coefficient maximum is bounded by
    `u + 2 * householderCompactNormBudgetCoeffFactor fp m`. -/
theorem storedQRCompactStepNormBudgetCoeffBudget_le_of_forall_source_den_ne_zero
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hden : ∀ k (hk : k < n),
      (∑ i : Fin m,
        householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
          householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0) :
    storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha ≤
      fp.u + 2 * householderCompactNormBudgetCoeffFactor fp m := by
  have hfactor_nonneg :
      0 ≤ householderCompactNormBudgetCoeffFactor fp m :=
    householderCompactNormBudgetCoeffFactor_nonneg fp m hm
  have hCmax_nonneg :
      0 ≤ fp.u + 2 * householderCompactNormBudgetCoeffFactor fp m :=
    add_nonneg fp.u_nonneg (mul_nonneg (by linarith) hfactor_nonneg)
  exact
    storedQRCompactStepNormBudgetCoeffBudget_le_of_forall_le
      hmn fp A_hat alpha
      (fp.u + 2 * householderCompactNormBudgetCoeffFactor fp m)
      hCmax_nonneg
      (storedQRCompactStepNormBudgetCoeff_le_of_forall_source_den_ne_zero
        hmn fp A_hat alpha hm hden)

/-- Canonical finite-maximum compact-product smallness from the explicit
    reflector-dependent compact norm coefficient.

    This is the finite-max version of
    `storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_normBudgetCoeff_le`.
    Instead of asking the caller for an arbitrary uniform coefficient `cHH` and
    a proof that every stage coefficient is below it, it chooses `cHH` to be the
    finite maximum of the stored-stage coefficients.  The only remaining
    numerical compact-product obligation is the scalar smallness inequality
    using that displayed finite maximum. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_normBudgetCoeffBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hsmall :
      2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
          ((m : ℝ) *
            (((n : ℝ) *
                ((n : ℝ) *
                  storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha +
                  storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha)) *
              storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  exact
    storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_normBudgetCoeff_le
      hmn fp A_hat b_hat alpha
      (storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha)
      hm hDD
      (storedQRCompactStepNormBudgetCoeffBudget_nonneg hmn fp A_hat alpha hm)
      (storedQRCompactStepNormBudgetCoeff_le_budget hmn fp A_hat alpha)
      hsmall

/-- Monotonicity certificate for the canonical norm-coefficient scalar
    smallness condition.

    If the diagonal-dominant inverse budget, the explicit compact Householder
    coefficient maximum, and the pivot-column norm budget are each bounded by
    route constants `Dmax`, `Cmax`, and `Nmax`, then the exact
    scalar condition used by the canonical coefficient theorem follows from
    the same condition with those route constants.

    This is only scalar algebra.  It does not prove the three bounds, diagonal
    dominance, or the numerical smallness of the displayed route constants.
    Nonnegativity of those constants follows from the domination hypotheses. -/
theorem storedQRCompactNormBudgetCoeffSmallness_of_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (Dmax Cmax Nmax : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDmax :
      storedQRDiagDominantInvFactorBudget hmn A_hat ≤ Dmax)
    (hCmax :
      storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha ≤ Cmax)
    (hNmax :
      storedQRPivotColumnNormBudget hmn A_hat ≤ Nmax)
    (hsmall :
      2 * Dmax *
          ((m : ℝ) *
            (((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax) ^ 2) <
        1) :
    2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
        ((m : ℝ) *
          (((n : ℝ) *
              ((n : ℝ) *
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha +
                storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha)) *
            storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
      1 := by
  let D : ℝ := storedQRDiagDominantInvFactorBudget hmn A_hat
  let C : ℝ := storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha
  let N : ℝ := storedQRPivotColumnNormBudget hmn A_hat
  have hD_nonneg : 0 ≤ D := by
    simpa [D] using storedQRDiagDominantInvFactorBudget_nonneg hmn A_hat hDD
  have hC_nonneg : 0 ≤ C := by
    simpa [C] using
      storedQRCompactStepNormBudgetCoeffBudget_nonneg hmn fp A_hat alpha hm
  have hN_nonneg : 0 ≤ N := by
    simpa [N] using storedQRPivotColumnNormBudget_nonneg hmn A_hat
  have hD_bound : D ≤ Dmax := by
    simpa [D] using hDmax
  have hC_bound : C ≤ Cmax := by
    simpa [C] using hCmax
  have hN_bound : N ≤ Nmax := by
    simpa [N] using hNmax
  have hDmax_nonneg : 0 ≤ Dmax := le_trans hD_nonneg hD_bound
  have hCmax_nonneg : 0 ≤ Cmax := le_trans hC_nonneg hC_bound
  have hNmax_nonneg : 0 ≤ Nmax := le_trans hN_nonneg hN_bound
  have hn_nonneg : 0 ≤ (n : ℝ) := Nat.cast_nonneg n
  have hm_nonneg : 0 ≤ (m : ℝ) := Nat.cast_nonneg m
  have hCsum_bound : (n : ℝ) * C + C ≤ (n : ℝ) * Cmax + Cmax := by
    have hmul : (n : ℝ) * C ≤ (n : ℝ) * Cmax :=
      mul_le_mul_of_nonneg_left hC_bound hn_nonneg
    linarith
  have hCsum_nonneg : 0 ≤ (n : ℝ) * C + C := by
    nlinarith [mul_nonneg hn_nonneg hC_nonneg, hC_nonneg]
  have hCmaxsum_nonneg : 0 ≤ (n : ℝ) * Cmax + Cmax := by
    nlinarith [mul_nonneg hn_nonneg hCmax_nonneg, hCmax_nonneg]
  have hseq_bound :
      (n : ℝ) * ((n : ℝ) * C + C) ≤
        (n : ℝ) * ((n : ℝ) * Cmax + Cmax) :=
    mul_le_mul_of_nonneg_left hCsum_bound hn_nonneg
  have hseq_nonneg : 0 ≤ (n : ℝ) * ((n : ℝ) * C + C) :=
    mul_nonneg hn_nonneg hCsum_nonneg
  have hseqmax_nonneg : 0 ≤ (n : ℝ) * ((n : ℝ) * Cmax + Cmax) :=
    mul_nonneg hn_nonneg hCmaxsum_nonneg
  have hseqN_bound :
      ((n : ℝ) * ((n : ℝ) * C + C)) * N ≤
        ((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax :=
    mul_le_mul hseq_bound hN_bound hN_nonneg hseqmax_nonneg
  have hseqN_nonneg : 0 ≤ ((n : ℝ) * ((n : ℝ) * C + C)) * N :=
    mul_nonneg hseq_nonneg hN_nonneg
  have hseqNmax_nonneg :
      0 ≤ ((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax :=
    mul_nonneg hseqmax_nonneg hNmax_nonneg
  have hsq_bound :
      (((n : ℝ) * ((n : ℝ) * C + C)) * N) ^ 2 ≤
        (((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax) ^ 2 := by
    nlinarith [hseqN_bound, hseqN_nonneg, hseqNmax_nonneg]
  have hright_bound :
      (m : ℝ) * (((n : ℝ) * ((n : ℝ) * C + C)) * N) ^ 2 ≤
        (m : ℝ) *
          (((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax) ^ 2 :=
    mul_le_mul_of_nonneg_left hsq_bound hm_nonneg
  have hright_nonneg :
      0 ≤ (m : ℝ) * (((n : ℝ) * ((n : ℝ) * C + C)) * N) ^ 2 :=
    mul_nonneg hm_nonneg (sq_nonneg _)
  have hleft_bound : 2 * D ≤ 2 * Dmax := by nlinarith
  have hleftmax_nonneg : 0 ≤ 2 * Dmax := by nlinarith
  have hprod_bound :
      2 * D * ((m : ℝ) * (((n : ℝ) * ((n : ℝ) * C + C)) * N) ^ 2) ≤
        2 * Dmax *
          ((m : ℝ) *
            (((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax) ^ 2) :=
    mul_le_mul hleft_bound hright_bound hright_nonneg hleftmax_nonneg
  have hactual :
      2 * D * ((m : ℝ) * (((n : ℝ) * ((n : ℝ) * C + C)) * N) ^ 2) < 1 :=
    lt_of_le_of_lt hprod_bound hsmall
  simpa [D, C, N] using hactual

/-- Canonical finite-maximum compact-product smallness from explicit route
    bounds on the three displayed maxima.

    This packages `storedQRCompactNormBudgetCoeffSmallness_of_bounds` with the
    existing coefficient-maximum product theorem.  It reduces the scalar
    obligation to route constants `Dmax`, `Cmax`, and `Nmax` that dominate the
    canonical budgets; it does not prove those bounds or local diagonal
    dominance. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_normBudgetCoeffBudget_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (Dmax Cmax Nmax : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDmax :
      storedQRDiagDominantInvFactorBudget hmn A_hat ≤ Dmax)
    (hCmax :
      storedQRCompactStepNormBudgetCoeffBudget hmn fp A_hat alpha ≤ Cmax)
    (hNmax :
      storedQRPivotColumnNormBudget hmn A_hat ≤ Nmax)
    (hsmall :
      2 * Dmax *
          ((m : ℝ) *
            (((n : ℝ) * ((n : ℝ) * Cmax + Cmax)) * Nmax) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  exact
    storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_normBudgetCoeffBudget
      hmn fp A_hat b_hat alpha hm hDD
      (storedQRCompactNormBudgetCoeffSmallness_of_bounds
        hmn fp A_hat alpha Dmax Cmax Nmax hm hDD
        hDmax hCmax hNmax hsmall)

/-- Pointwise route bounds for the canonical norm-coefficient scalar smallness
    condition.

    If every diagonal-dominant inverse factor, every stored compact
    norm-coefficient, and every displayed pivot-column norm are bounded by the
    displayed constants `Dmax`, `Cmax`, and `Nmax`, then the exact canonical
    scalar condition follows from the same cleaner inequality in those
    constants.  Nonnegativity of the displayed constants is only needed for the
