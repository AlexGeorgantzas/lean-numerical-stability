          matMulRectLeft Q (lsQRTallBlock DeltaR1) i j)
        (fun i j => A i j + DeltaA i j +
          matMulRectLeft Q (lsQRTallBlock DeltaR2) i j)
        (fun i => f i + Deltaf i) (fun j => g j + Deltag j)
