/-- Scalar sufficient condition for the global compact-product smallness
    hypothesis.

    If the diagonal-dominant inverse-budget factor is bounded by `Dmax` at
    every pivot and the displayed pivot-column norm is bounded by `Nmax`, then
    the single scalar inequality using `Dmax` and `Nmax` implies
    `storedQRCompactSequenceProductBudget < 1`.  This is still a visible
    product-smallness assumption, but it reduces the finite family of product
    obligations to one source-facing scalar budget. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_factor_norm_bounds
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (Dmax Nmax : ℝ)
    (hm : gammaValid fp m)
    (hDmax : 0 ≤ Dmax)
    (hNmax : 0 ≤ Nmax)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hDle : ∀ k : Fin n,
      diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤ Dmax)
    (hNle : ∀ k : Fin n,
      vecNorm2 (fun i : Fin m => A_hat k.val i k) ≤ Nmax)
    (hsmall :
      2 * Dmax *
          ((m : ℝ) *
            (storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha *
              Nmax) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  classical
  refine
    storedQRCompactSequenceProductBudget_lt_one_of_forall_expr_lt
      hmn fp A_hat b_hat alpha ?_
  intro k
  let D : ℝ :=
    diagDominantUpperInvBudgetExpr (k.val + 1)
      (qrLeadingBlock (A_hat k.val)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
      ⟨k.val, Nat.lt_succ_self k.val⟩
  let c : ℝ :=
    storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha
  let r : ℝ := vecNorm2 (fun i : Fin m => A_hat k.val i k)
  have hD_nonneg : 0 ≤ D := by
    exact le_of_lt (diagDominantUpperInvBudgetExpr_pos (k.val + 1)
      (qrLeadingBlock (A_hat k.val)
        (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
      ⟨k.val, Nat.lt_succ_self k.val⟩ (hDD k))
  have hD_bound : D ≤ Dmax := by
    simpa [D] using hDle k
  have hc_nonneg : 0 ≤ c := by
    simpa [c] using
      storedQRCompactSequenceRelativeBudget_nonneg
        hmn fp A_hat b_hat alpha hm
  have hr_nonneg : 0 ≤ r := by
    simpa [r] using vecNorm2_nonneg (fun i : Fin m => A_hat k.val i k)
  have hr_bound : r ≤ Nmax := by
    simpa [r] using hNle k
  have hcr_bound : c * r ≤ c * Nmax :=
    mul_le_mul_of_nonneg_left hr_bound hc_nonneg
  have hcr_nonneg : 0 ≤ c * r := mul_nonneg hc_nonneg hr_nonneg
  have hcN_nonneg : 0 ≤ c * Nmax := mul_nonneg hc_nonneg hNmax
