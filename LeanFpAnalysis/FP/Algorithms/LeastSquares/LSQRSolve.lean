/-- Canonical finite-maximum version of the scalar compact-product smallness
    adapter.

    This removes the caller's separate `Dmax`/`Nmax` bound fields by choosing
    them as finite maxima over the stored sequence.  The remaining assumption
    is the single scalar smallness inequality for those canonical budgets. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_smallness
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hsmall :
      2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
          ((m : ℝ) *
            (storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha *
              storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  exact
    storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_factor_norm_bounds
      hmn fp A_hat b_hat alpha
      (storedQRDiagDominantInvFactorBudget hmn A_hat)
      (storedQRPivotColumnNormBudget hmn A_hat)
      hm
      (storedQRDiagDominantInvFactorBudget_nonneg hmn A_hat hDD)
      (storedQRPivotColumnNormBudget_nonneg hmn A_hat)
      hDD
      (storedQRDiagDominantInvFactor_le_budget hmn A_hat)
      (storedQRPivotColumnNorm_le_budget hmn A_hat)
      hsmall

