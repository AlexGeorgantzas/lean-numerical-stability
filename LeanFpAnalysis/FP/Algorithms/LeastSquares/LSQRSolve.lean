          (2 ^ k *
            (1 / Finset.inf' Finset.univ
              ⟨(⟨k, Nat.lt_succ_self k⟩ : Fin (k + 1)), Finset.mem_univ _⟩
              (fun r : Fin (k + 1) =>
                |qrLeadingBlock (A_hat k)
                    (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk r r|))) ^ 2 ≤
