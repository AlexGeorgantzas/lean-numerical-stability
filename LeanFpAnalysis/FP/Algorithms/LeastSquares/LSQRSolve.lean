/-- Finite maximum of the diagonal-dominant inverse-budget factors used in the
    stored QR compact-product condition.  The value is `0` when there are no
    pivots. -/
noncomputable def storedQRDiagDominantInvFactorBudget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ) : ℝ :=
  if hn : 0 < n then
    Finset.sup' (Finset.univ : Finset (Fin n))
      (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
      (fun k =>
        diagDominantUpperInvBudgetExpr (k.val + 1)
          (qrLeadingBlock (A_hat k.val)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
          ⟨k.val, Nat.lt_succ_self k.val⟩)
  else 0

/-- Each diagonal-dominant inverse-budget factor is bounded by its finite
    maximum. -/
theorem storedQRDiagDominantInvFactor_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (k : Fin n) :
    diagDominantUpperInvBudgetExpr (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
        ⟨k.val, Nat.lt_succ_self k.val⟩ ≤
      storedQRDiagDominantInvFactorBudget hmn A_hat := by
  classical
  unfold storedQRDiagDominantInvFactorBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    exact
      Finset.le_sup' (s := (Finset.univ : Finset (Fin n)))
        (f := fun k : Fin n =>
          diagDominantUpperInvBudgetExpr (k.val + 1)
            (qrLeadingBlock (A_hat k.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt)
            ⟨k.val, Nat.lt_succ_self k.val⟩)
        (Finset.mem_univ k)
  · have hnpos : 0 < n := lt_of_le_of_lt (Nat.zero_le k.val) k.isLt
    exact False.elim (hn hnpos)

