    factor plus the finite maximum compact component at stage `t`. -/
theorem storedQRSignedStage_active_prefix_budgets_of_globalCompactBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ)
    (stageBudget : ℕ → ℝ)
    (hglobalBudget : ∀ t (ht : t < n),
      coxHighamActiveRowGrowthFactor m * stageBudget t +
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht ≤
        stageBudget (t + 1)) :
    (∀ t : ℕ, t + 1 < n →
      ∀ r : Fin m, t + 1 ≤ r.val →
        ∀ l : Fin n, t + 1 ≤ l.val →
          coxHighamActiveRowGrowthFactor m * stageBudget t +
              householderCompactComponentBudget fp m
                (storedQRSignedStageVector hmn A_hat alpha t)
                (storedQRSignedStageBeta hmn A_hat alpha t)
                (fun a => A_hat t a l) r ≤
            stageBudget (t + 1)) ∧
    (∀ t (_ht : t < n),
      ∀ r : Fin m, r.val < t + 1 →
        ∀ l : Fin n, t ≤ l.val →
          coxHighamActiveRowGrowthFactor m * stageBudget t +
              householderCompactComponentBudget fp m
                (storedQRSignedStageVector hmn A_hat alpha t)
                (storedQRSignedStageBeta hmn A_hat alpha t)
                (fun a => A_hat t a l) r ≤
            stageBudget (t + 1)) := by
  classical
  constructor
  · intro t ht r _hr l _hl
    have htn : t < n := Nat.lt_trans (Nat.lt_succ_self t) ht
    have hcomp :
        householderCompactComponentBudget fp m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t)
            (fun a => A_hat t a l) r ≤
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t htn :=
      storedQRSignedStage_compact_component_le_globalBudget
        hmn fp A_hat alpha t htn r l
    have hstep :
        coxHighamActiveRowGrowthFactor m * stageBudget t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a l) r ≤
          coxHighamActiveRowGrowthFactor m * stageBudget t +
            storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t htn := by
      simpa [add_comm] using
        (add_le_add_left hcomp
          (coxHighamActiveRowGrowthFactor m * stageBudget t))
    exact hstep.trans (hglobalBudget t htn)
  · intro t ht r _hr l _hl
    have hcomp :
        householderCompactComponentBudget fp m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t)
            (fun a => A_hat t a l) r ≤
          storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht :=
      storedQRSignedStage_compact_component_le_globalBudget
        hmn fp A_hat alpha t ht r l
    have hstep :
        coxHighamActiveRowGrowthFactor m * stageBudget t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a l) r ≤
          coxHighamActiveRowGrowthFactor m * stageBudget t +
            storedQRSignedStageGlobalCompactBudget hmn fp A_hat alpha t ht := by
      simpa [add_comm] using
        (add_le_add_left hcomp
          (coxHighamActiveRowGrowthFactor m * stageBudget t))
    exact hstep.trans (hglobalBudget t ht)

