+      have hfin' : (∑ t : Fin m, g (idx t)) = ∑ q ∈ Finset.range m, gu q := by
+        simpa [gu] using (Fin.sum_univ_eq_sum_range gu m)
+      rw [hfin']
+      apply Finset.sum_congr rfl
+      intro q hq
+      have hqm : q < m := Finset.mem_range.mp hq
+      have hqn : i.val + 1 + q < n := by
+        dsimp [m] at hqm
+        omega
+      simp [f, gu, idx, hqm, hqn]
+    rw [hfull, hsplit, hlow, hupper]
+  let xhat := fl_backSub fp n U b
+  change infNormVec hnpos (triangularResidual n U xhat b) ≤
+    gamma fp n * infNorm hnpos U * infNormVec hnpos xhat
+  unfold infNormVec
+  apply Finset.sup'_le
+  intro i hi
+  let m := n - i.val - 1
+  let idx : Fin m → Fin n := fun t => ⟨i.val + 1 + t.val, by omega⟩
+  let a : Fin m → ℝ := fun t => U i (idx t)
+  let z : Fin m → ℝ := fun t => xhat (idx t)
+  have hrow :
+      xhat i = fp.fl_div (rowFold i xhat) (U i i) := by
+    dsimp [xhat, fl_backSub]
+    exact row_eq n (le_refl n) (fun _ => 0) i i.isLt
+  have hm_succ : m + 1 ≤ n := by
+    dsimp [m]
+    omega
+  have hscalar :=
+    scalar_bound m hm_succ a z (U i i) (b i) (hdiag i)
+  have hscalar' :
+      |U i i * xhat i + ∑ t : Fin m, U i (idx t) * xhat (idx t) - b i| ≤
+        gamma fp n *
+          (|U i i * xhat i| + ∑ t : Fin m, |U i (idx t) * xhat (idx t)|) := by
+    simpa [a, z, idx, rowFold, m, ← hrow] using hscalar
+  have hsum :
+      (∑ j : Fin n, U i j * xhat j) =
+        U i i * xhat i + ∑ t : Fin m, U i (idx t) * xhat (idx t) := by
+    have hzero : ∀ j : Fin n, j.val < i.val → U i j * xhat j = 0 := by
+      intro j hj
+      simp [hupper i j hj]
+    simpa [m, idx] using sum_split_upper i (fun j => U i j * xhat j) hzero
+  have habs_sum :
+      (∑ j : Fin n, |U i j * xhat j|) =
+        |U i i * xhat i| + ∑ t : Fin m, |U i (idx t) * xhat (idx t)| := by
+    have hzero : ∀ j : Fin n, j.val < i.val → |U i j * xhat j| = 0 := by
+      intro j hj
+      simp [hupper i j hj]
+    simpa [m, idx] using sum_split_upper i (fun j => |U i j * xhat j|) hzero
+  have hxnorm_nonneg : 0 ≤ infNormVec hnpos xhat := by
+    unfold infNormVec
+    exact le_trans (abs_nonneg (xhat ⟨0, hnpos⟩))
+      (Finset.le_sup' (fun j : Fin n => |xhat j|) (Finset.mem_univ ⟨0, hnpos⟩))
+  have hprod_bound :
+      (∑ j : Fin n, |U i j * xhat j|) ≤
+        (∑ j : Fin n, |U i j|) * infNormVec hnpos xhat := by
+    calc
+      (∑ j : Fin n, |U i j * xhat j|)
+          = ∑ j : Fin n, |U i j| * |xhat j| := by simp [abs_mul]
+      _ ≤ ∑ j : Fin n, |U i j| * infNormVec hnpos xhat := by
+        apply Finset.sum_le_sum
+        intro j hj
+        apply mul_le_mul_of_nonneg_left
+        · unfold infNormVec
+          exact Finset.le_sup' (fun k : Fin n => |xhat k|) (Finset.mem_univ j)
+        · exact abs_nonneg (U i j)
+      _ = (∑ j : Fin n, |U i j|) * infNormVec hnpos xhat := by
+        rw [Finset.sum_mul]
+  have hrow_le_unorm : (∑ j : Fin n, |U i j|) ≤ infNorm hnpos U := by
+    unfold infNorm
+    exact Finset.le_sup' (fun r : Fin n => ∑ j : Fin n, |U r j|) (Finset.mem_univ i)
+  have hdu_bound :
+      |U i i * xhat i| + ∑ t : Fin m, |U i (idx t) * xhat (idx t)| ≤
+        infNorm hnpos U * infNormVec hnpos xhat := by
+    rw [← habs_sum]
+    exact le_trans hprod_bound
+      (mul_le_mul_of_nonneg_right hrow_le_unorm hxnorm_nonneg)
+  have hres :
+      |∑ j : Fin n, U i j * xhat j - b i| ≤
+        gamma fp n *
+          (|U i i * xhat i| + ∑ t : Fin m, |U i (idx t) * xhat (idx t)|) := by
+    simpa [hsum] using hscalar'
+  exact le_trans hres
+    (by
+      simpa [mul_assoc] using
+        (mul_le_mul_of_nonneg_left hdu_bound hgamma_nonneg))
 
 end LeanFpAnalysis.FP
