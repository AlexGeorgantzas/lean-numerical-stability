  refine ⟨ΔA', Δb', ?_, ?_, hls⟩
  · intro j
    have hcol := hcols j
    let aNorm : ℝ := vecNorm2 (fun i : Fin m => A i j)
    calc
      vecNorm2 (fun i : Fin m => ΔA' i j)
          ≤ η * aNorm + gamma fp n * (aNorm + η * aNorm) := by
            simpa [aNorm] using hcol
