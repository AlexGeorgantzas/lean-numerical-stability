def storedDiagDominantComparisonCounterexampleAlpha : ℕ → ℝ
  | 0 => -3
  | _ => -1

/-- Zero right-hand-side sequence paired with the diagonally-dominant
    scalar-comparison stored-panel witness. -/
def storedDiagDominantComparisonCounterexampleRhsSeq :
    ℕ → Fin 2 → ℝ := fun _ _ => 0

/-- The diagonally-dominant scalar-comparison witness follows the stored-panel
    recurrence under exact arithmetic. -/
theorem storedDiagDominantComparisonCounterexample_stored_step :
    ∀ k (hk : k < 2),
      storedDiagDominantComparisonCounterexampleSeq (k + 1) =
        fl_householderStoredPanelStep
          exactHouseholderQRDiagDominanceCounterexampleFP 2 2 k
          (householderTrailingActiveVector 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun i =>
              storedDiagDominantComparisonCounterexampleSeq k i ⟨k, hk⟩)
            (storedDiagDominantComparisonCounterexampleAlpha k))
          (householderBetaSpec 2
            (householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i =>
                storedDiagDominantComparisonCounterexampleSeq k i ⟨k, hk⟩)
              (storedDiagDominantComparisonCounterexampleAlpha k)))
          (storedDiagDominantComparisonCounterexampleSeq k) := by
  intro k hk
  interval_cases k
  · ext i j
    fin_cases i <;> fin_cases j <;>
      simp [exactHouseholderQRDiagDominanceCounterexampleFP,
        FPModel.exactWithUnitRoundoff,
        storedDiagDominantComparisonCounterexampleSeq,
        storedDiagDominantComparisonCounterexampleA1,
        activeMaxPivotRowMaxComparisonCounterexampleA0,
        storedDiagDominantComparisonCounterexampleAlpha,
        fl_householderStoredPanelStep, fl_householderApplyCompactPanel,
        fl_householderApplyCompact, fl_dotProduct, Fin.foldl_succ,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec]
    all_goals ring_nf
  · ext i j
    fin_cases i <;> fin_cases j <;>
      simp [exactHouseholderQRDiagDominanceCounterexampleFP,
        FPModel.exactWithUnitRoundoff,
        storedDiagDominantComparisonCounterexampleSeq,
        storedDiagDominantComparisonCounterexampleA1,
        storedDiagDominantComparisonCounterexampleA2,
        storedDiagDominantComparisonCounterexampleAlpha,
        fl_householderStoredPanelStep, fl_householderApplyCompactPanel,
        fl_householderApplyCompact, fl_dotProduct, Fin.foldl_succ,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec]
    all_goals ring_nf

/-- The zero right-hand side follows the stored RHS recurrence for the
    diagonally-dominant scalar-comparison witness under exact arithmetic. -/
theorem storedDiagDominantComparisonCounterexample_rhs_step :
    ∀ k (hk : k < 2),
      storedDiagDominantComparisonCounterexampleRhsSeq (k + 1) =
        fl_householderStoredRhsStep
          exactHouseholderQRDiagDominanceCounterexampleFP 2 k
