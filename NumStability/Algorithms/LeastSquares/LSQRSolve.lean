          householderTrailingColumnNorm2Sq
            (m := 2) (n := 2) ⟨k, hk⟩ (A_hat k) ⟨k, hk⟩) →
      (∀ k (_hk : k < 2), 0 ≤ stageBudget k) →
      (∀ k (_hk : k < 2), ∀ r l : Fin 2, k ≤ r.val → k ≤ l.val →
        |A_hat k r l| ≤ stageBudget k) →
      (∀ k (hk : k < 2), ∀ i j : Fin (k + 1), i.val < j.val →
        |qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i j| ≤
          stageBudget k) →
      (∀ k (hk : k < 2), ∀ i : Fin (k + 1), i.val < k →
        stageBudget k ≤
          qrLeadingStrictUpperRowMaxBudget (by omega : 2 ≤ 2) A_hat k hk i)) := by
  intro h
  let A_hat := activeMaxPivotRowBudgetDiagCounterexampleSeq
  let stageBudget : ℕ → ℝ := fun _ => 3
  have hupper : ∀ k (hk : k < 2), ∀ i j : Fin (k + 1), j.val < i.val →
      qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i j = 0 := by
    intro k hk i j hji
    interval_cases k
    · fin_cases i
      fin_cases j
      omega
    · simpa [A_hat, activeMaxPivotRowBudgetDiagCounterexampleSeq,
        qrLeadingBlock, qrLeadingRow, qrLeadingColumn] using
        diagDominanceCounterexample2_upper
          (qrLeadingRow 2 1 (Nat.succ_le_iff.mpr hk) i)
          (qrLeadingColumn 2 1 hk j)
