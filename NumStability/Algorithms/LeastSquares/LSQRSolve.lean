/-- Finite scalar defect for the active/prefix comparison
    `stageBudget <= rowMax`.

This is the maximum over displayed rows that have strict upper entries of
`stageBudget k - rowMax(k,i)`.  Its nonpositivity is exactly the finite scalar
form of the displayed-row comparison consumed by the row-max bridge. -/
noncomputable def storedQRStageRowMaxComparisonDefectBudget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ) : ℝ :=
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  if hs : s.Nonempty then
    Finset.sup' s hs (fun p =>
      if hi : p.2.val < p.1.val then
        let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
        stageBudget p.1.val -
          qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i
      else 0)
  else 0

/-- Each displayed stage-budget/row-max comparison defect is bounded by the
    finite scalar comparison defect budget. -/
theorem storedQRStageRowMaxComparisonDefect_le_budget
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (stageBudget : ℕ → ℝ)
    {k : ℕ} (hk : k < n) (i : Fin (k + 1)) (hi : i.val < k) :
    stageBudget k - qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i ≤
      storedQRStageRowMaxComparisonDefectBudget hmn A_hat stageBudget := by
  classical
  let p : Fin n × Fin n := (⟨k, hk⟩, ⟨i.val, lt_trans hi hk⟩)
  let s : Finset (Fin n × Fin n) :=
    Finset.univ.filter (fun p : Fin n × Fin n => p.2.val < p.1.val)
  have hmem : p ∈ s := by
    simp [s, p, hi]
  have hs : s.Nonempty := ⟨p, hmem⟩
  unfold storedQRStageRowMaxComparisonDefectBudget
  rw [dif_pos hs]
  have hsup :
      (if hp : p.2.val < p.1.val then
        let i' : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hp⟩
        stageBudget p.1.val -
          qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i'
      else 0) ≤
        Finset.sup' s hs (fun p =>
          if hi : p.2.val < p.1.val then
            let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
            stageBudget p.1.val -
              qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i
          else 0) :=
    Finset.le_sup' (s := s)
      (f := fun p =>
        if hi : p.2.val < p.1.val then
          let i : Fin (p.1.val + 1) := ⟨p.2.val, Nat.lt_succ_of_lt hi⟩
          stageBudget p.1.val -
            qrLeadingStrictUpperRowMaxBudget hmn A_hat p.1.val p.1.isLt i
        else 0)
      hmem
  convert hsup using 1
  simp [p, hi]

/-- A nonpositive finite stage-budget/row-max comparison defect supplies the
    displayed comparison field used by the row-max bridge. -/
theorem storedQRStageBudget_le_rowMax_of_stageRowMaxComparisonDefectBudget_nonpos
    {m n : ℕ} (hmn : n ≤ m)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
