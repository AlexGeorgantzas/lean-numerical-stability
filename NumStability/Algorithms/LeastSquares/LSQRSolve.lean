  exact
    lsScaledAugmentedBalancedBranchRatio_le_two_sigma_ratio
      (alpha := alpha) (sigmaMin := sigmaMin) (sigmaMax := sigmaMax)
      halpha_pos hsigmaMin hsigmaMax

