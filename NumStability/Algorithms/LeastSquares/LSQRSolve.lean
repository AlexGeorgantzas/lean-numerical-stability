/-- The first exact Householder QR counterexample state used to rule out
    deriving diagonal dominance from the unpivoted trailing Householder
    recurrence itself. -/
def exactHouseholderQRDiagDominanceCounterexampleA1 :
    Fin 2 → Fin 2 → ℝ :=
  fun i j =>
    if i.val = 0 ∧ j.val = 0 then -1
    else if i.val = 0 ∧ j.val = 1 then -2
    else if i.val = 1 ∧ j.val = 1 then 1
    else 0

/-- The final exact Householder QR counterexample state.  It is upper
    triangular with nonzero diagonal but it is not diagonally dominant. -/
def exactHouseholderQRDiagDominanceCounterexampleA2 :
    Fin 2 → Fin 2 → ℝ :=
  fun i j =>
    if i.val = 0 ∧ j.val = 0 then -1
    else if i.val = 0 ∧ j.val = 1 then -2
    else if i.val = 1 ∧ j.val = 1 then -1
    else 0

/-- Exact two-step unpivoted trailing Householder sequence for the diagonal
    dominance counterexample. -/
def exactHouseholderQRDiagDominanceCounterexampleSeq :
    ℕ → Fin 2 → Fin 2 → ℝ
  | 0 => diagDominanceCounterexample2
  | 1 => exactHouseholderQRDiagDominanceCounterexampleA1
  | _ => exactHouseholderQRDiagDominanceCounterexampleA2

/-- Source-style signed Householder scalars for the two-step counterexample. -/
def exactHouseholderQRDiagDominanceCounterexampleAlpha : ℕ → ℝ
  | 0 => -1
  | _ => -1

/-- Exact arithmetic model used to lift the diagonal-dominance counterexample
    to the stored-panel floating-point recurrence surface. -/
noncomputable def exactHouseholderQRDiagDominanceCounterexampleFP : FPModel :=
  FPModel.exactWithUnitRoundoff 0 (by norm_num)

/-- The counterexample sequence really follows the exact unpivoted trailing
    Householder recurrence. -/
theorem exactHouseholderQRDiagDominanceCounterexample_step :
    ∀ k (hk : k < 2),
      exactHouseholderQRDiagDominanceCounterexampleSeq (k + 1) =
        matMulRectLeft
          (householder 2
            (householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i =>
                exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩)
              (exactHouseholderQRDiagDominanceCounterexampleAlpha k))
            (householderBetaSpec 2
              (householderTrailingActiveVector 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i =>
                  exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩)
                (exactHouseholderQRDiagDominanceCounterexampleAlpha k))))
          (exactHouseholderQRDiagDominanceCounterexampleSeq k) := by
  intro k hk
  interval_cases k
  · ext i j
    fin_cases i <;> fin_cases j <;>
      norm_num [exactHouseholderQRDiagDominanceCounterexampleSeq,
        exactHouseholderQRDiagDominanceCounterexampleA1,
        diagDominanceCounterexample2,
        exactHouseholderQRDiagDominanceCounterexampleAlpha,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec, householder,
        matMulRectLeft, idMatrix]
  · ext i j
    fin_cases i <;> fin_cases j <;>
      norm_num [exactHouseholderQRDiagDominanceCounterexampleSeq,
        exactHouseholderQRDiagDominanceCounterexampleA1,
        exactHouseholderQRDiagDominanceCounterexampleA2,
        exactHouseholderQRDiagDominanceCounterexampleAlpha,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec, householder,
        matMulRectLeft, idMatrix]

/-- The counterexample scalars have the squared trailing-norm magnitude
    required by the exact Householder recurrence. -/
theorem exactHouseholderQRDiagDominanceCounterexample_alpha_sq :
    ∀ k (hk : k < 2),
      exactHouseholderQRDiagDominanceCounterexampleAlpha k *
          exactHouseholderQRDiagDominanceCounterexampleAlpha k =
        householderTrailingNorm2Sq 2
          ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
          (fun i =>
            exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩) := by
  intro k hk
  interval_cases k
  · norm_num [exactHouseholderQRDiagDominanceCounterexampleAlpha,
      exactHouseholderQRDiagDominanceCounterexampleSeq,
      diagDominanceCounterexample2, householderTrailingNorm2Sq,
      vecNorm2Sq, householderTrailingPart]
    rfl
  · norm_num [exactHouseholderQRDiagDominanceCounterexampleAlpha,
      exactHouseholderQRDiagDominanceCounterexampleSeq,
      exactHouseholderQRDiagDominanceCounterexampleA1,
      householderTrailingNorm2Sq, vecNorm2Sq, householderTrailingPart]
    rfl

/-- The exact Householder denominators in the counterexample are nonzero. -/
theorem exactHouseholderQRDiagDominanceCounterexample_den_ne_zero :
    ∀ k (hk : k < 2),
      (∑ i : Fin 2,
        householderTrailingActiveVector 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun a =>
              exactHouseholderQRDiagDominanceCounterexampleSeq k a ⟨k, hk⟩)
            (exactHouseholderQRDiagDominanceCounterexampleAlpha k) i *
          householderTrailingActiveVector 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun a =>
              exactHouseholderQRDiagDominanceCounterexampleSeq k a ⟨k, hk⟩)
            (exactHouseholderQRDiagDominanceCounterexampleAlpha k) i) ≠ 0 := by
  intro k hk
  interval_cases k
  · norm_num [exactHouseholderQRDiagDominanceCounterexampleAlpha,
      exactHouseholderQRDiagDominanceCounterexampleSeq,
      diagDominanceCounterexample2, householderTrailingActiveVector,
      householderActiveVector, householderTrailingPart]
  · norm_num [exactHouseholderQRDiagDominanceCounterexampleAlpha,
      exactHouseholderQRDiagDominanceCounterexampleSeq,
      exactHouseholderQRDiagDominanceCounterexampleA1,
      householderTrailingActiveVector, householderActiveVector,
      householderTrailingPart]

/-- The same counterexample follows the stored-panel recurrence under exact
    arithmetic.  Completed columns are preserved and the newly completed
    pivot column is explicitly zeroed below the pivot, matching the existing
    upper-triangular witness. -/
theorem exactHouseholderQRDiagDominanceCounterexample_stored_step :
    ∀ k (hk : k < 2),
      exactHouseholderQRDiagDominanceCounterexampleSeq (k + 1) =
        fl_householderStoredPanelStep
          exactHouseholderQRDiagDominanceCounterexampleFP 2 2 k
          (householderTrailingActiveVector 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun i =>
              exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩)
            (exactHouseholderQRDiagDominanceCounterexampleAlpha k))
          (householderBetaSpec 2
            (householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i =>
                exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩)
              (exactHouseholderQRDiagDominanceCounterexampleAlpha k)))
          (exactHouseholderQRDiagDominanceCounterexampleSeq k) := by
  intro k hk
  interval_cases k
  · ext i j
    fin_cases i <;> fin_cases j <;>
      simp [exactHouseholderQRDiagDominanceCounterexampleFP,
        FPModel.exactWithUnitRoundoff,
        exactHouseholderQRDiagDominanceCounterexampleSeq,
        exactHouseholderQRDiagDominanceCounterexampleA1,
        diagDominanceCounterexample2,
        exactHouseholderQRDiagDominanceCounterexampleAlpha,
        fl_householderStoredPanelStep, fl_householderApplyCompactPanel,
        fl_householderApplyCompact, fl_dotProduct, Fin.foldl_succ,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec]
    all_goals ring_nf
  · ext i j
    fin_cases i <;> fin_cases j <;>
      simp [exactHouseholderQRDiagDominanceCounterexampleFP,
        FPModel.exactWithUnitRoundoff,
        exactHouseholderQRDiagDominanceCounterexampleSeq,
        exactHouseholderQRDiagDominanceCounterexampleA1,
        exactHouseholderQRDiagDominanceCounterexampleA2,
        exactHouseholderQRDiagDominanceCounterexampleAlpha,
        fl_householderStoredPanelStep, fl_householderApplyCompactPanel,
        fl_householderApplyCompact, fl_dotProduct, Fin.foldl_succ,
        householderTrailingActiveVector, householderActiveVector,
        householderTrailingPart, householderBetaSpec]
    all_goals ring_nf

/-- The counterexample scalars are exactly the signed Householder choices used
    by the stored-panel least-squares route. -/
theorem exactHouseholderQRDiagDominanceCounterexample_signed_alpha_def :
    ∀ k (hk : k < 2),
      exactHouseholderQRDiagDominanceCounterexampleAlpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i =>
                exactHouseholderQRDiagDominanceCounterexampleSeq k i ⟨k, hk⟩)))
          (exactHouseholderQRDiagDominanceCounterexampleSeq k
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ ⟨k, hk⟩) := by
  intro k hk
  interval_cases k
  · norm_num [exactHouseholderQRDiagDominanceCounterexampleAlpha,
      exactHouseholderQRDiagDominanceCounterexampleSeq,
      diagDominanceCounterexample2, signedHouseholderAlpha,
      householderTrailingNorm2Sq, vecNorm2Sq, householderTrailingPart]
  · norm_num [exactHouseholderQRDiagDominanceCounterexampleAlpha,
      exactHouseholderQRDiagDominanceCounterexampleSeq,
      exactHouseholderQRDiagDominanceCounterexampleA1, signedHouseholderAlpha,
      householderTrailingNorm2Sq, vecNorm2Sq, householderTrailingPart]

/-- The actual exact unpivoted trailing Householder QR recurrence can output an
    upper triangular factor that is not diagonally dominant.

    This rules out the remaining tempting shortcut in the rectangular
    QR/preconditioner bottleneck: diagonal dominance cannot be recovered merely
    from using the exact no-pivot Householder loop.  A positive route must
    prove a separate off-diagonal-control hypothesis or keep diagonal
    dominance visible as a domain assumption. -/
theorem exactHouseholderQRDiagDominanceCounterexample_not_diagDominant :
    ¬ IsDiagDominantUpper 2
      (exactHouseholderQRDiagDominanceCounterexampleSeq 2) := by
  intro hDD
  have hbad := hDD.2.2 ⟨0, by norm_num⟩ ⟨1, by norm_num⟩ (by norm_num)
  norm_num [exactHouseholderQRDiagDominanceCounterexampleSeq,
    exactHouseholderQRDiagDominanceCounterexampleA2] at hbad

/-- Universal-form route elimination: exact unpivoted trailing Householder
    recurrence, valid Householder squared norms, and nonzero denominators do
    not imply the triangular diagonal-dominance hypothesis used by the current
    QR least-squares solve route. -/
theorem not_forall_exact_trailing_householder_sequence_implies_diagDominant :
    ¬ (∀ (A_hat : ℕ → Fin 2 → Fin 2 → ℝ) (alpha : ℕ → ℝ),
      (∀ k (hk : k < 2),
        A_hat (k + 1) =
          matMulRectLeft
            (householder 2
              (householderTrailingActiveVector 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i => A_hat k i ⟨k, hk⟩) (alpha k))
              (householderBetaSpec 2
                (householderTrailingActiveVector 2
                  ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                  (fun i => A_hat k i ⟨k, hk⟩) (alpha k))))
            (A_hat k)) →
      (∀ k (hk : k < 2),
        alpha k * alpha k =
          householderTrailingNorm2Sq 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun i => A_hat k i ⟨k, hk⟩)) →
      (∀ k (hk : k < 2),
        (∑ i : Fin 2,
          householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
            householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0) →
      IsDiagDominantUpper 2 (fun i j => A_hat 2 i j)) := by
  intro h
  exact exactHouseholderQRDiagDominanceCounterexample_not_diagDominant
    (h exactHouseholderQRDiagDominanceCounterexampleSeq
      exactHouseholderQRDiagDominanceCounterexampleAlpha
      exactHouseholderQRDiagDominanceCounterexample_step
      exactHouseholderQRDiagDominanceCounterexample_alpha_sq
      exactHouseholderQRDiagDominanceCounterexample_den_ne_zero)

/-- Universal-form route elimination on the stored-panel actual-unit surface:
    the stored recurrence, signed-alpha choice, nonzero source denominators,
    and a small declared unit roundoff do not imply the local diagonal
    dominance hypothesis used by the active QR/preconditioner branch. -/
theorem not_forall_signedAlphaDef_stored_trailing_sequence_actualU_sourceDen_implies_diagDominant :
    ¬ (∀
      (fp : FPModel)
      (A_hat : ℕ → Fin 2 → Fin 2 → ℝ)
      (alpha : ℕ → ℝ),
      (∀ k (hk : k < 2),
        A_hat (k + 1) =
          fl_householderStoredPanelStep fp 2 2 k
            (householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i => A_hat k i ⟨k, hk⟩) (alpha k))
            (householderBetaSpec 2
              (householderTrailingActiveVector 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i => A_hat k i ⟨k, hk⟩) (alpha k)))
            (A_hat k)) →
      (∀ k (hk : k < 2),
        alpha k =
          signedHouseholderAlpha
            (Real.sqrt
              (householderTrailingNorm2Sq 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i => A_hat k i ⟨k, hk⟩)))
            (A_hat k ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ ⟨k, hk⟩)) →
      (∀ k (hk : k < 2),
        (∑ i : Fin 2,
          householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
            householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0) →
      (2 : ℝ) * fp.u < 1 →
      IsDiagDominantUpper 2 (fun i j => A_hat 2 i j)) := by
  intro h
  exact exactHouseholderQRDiagDominanceCounterexample_not_diagDominant
    (h exactHouseholderQRDiagDominanceCounterexampleFP
      exactHouseholderQRDiagDominanceCounterexampleSeq
      exactHouseholderQRDiagDominanceCounterexampleAlpha
      exactHouseholderQRDiagDominanceCounterexample_stored_step
      exactHouseholderQRDiagDominanceCounterexample_signed_alpha_def
      exactHouseholderQRDiagDominanceCounterexample_den_ne_zero
      (by
        norm_num [exactHouseholderQRDiagDominanceCounterexampleFP,
          FPModel.exactWithUnitRoundoff]))

/-- At the initial diagonal-dominance counterexample state, the displayed first
    column is not the active max-pivot column: the second column has larger
    active trailing norm. -/
theorem exactHouseholderQRDiagDominanceCounterexample_not_activeMaxPivotChoice :
    ¬ ((⟨0, by norm_num⟩ : Fin 2) =
        householderActiveMaxPivotColumn
          (⟨0, by norm_num⟩ : Fin 2)
          (⟨0, by norm_num⟩ : Fin 2)
          (exactHouseholderQRDiagDominanceCounterexampleSeq 0)) := by
  intro hchoice
  have hmax :=
    householderActiveMaxPivotColumn_pivot_max
      (p := (⟨0, by norm_num⟩ : Fin 2))
      (k := (⟨0, by norm_num⟩ : Fin 2))
      (A := exactHouseholderQRDiagDominanceCounterexampleSeq 0)
      (l := (⟨1, by norm_num⟩ : Fin 2)) (by norm_num)
  rw [← hchoice] at hmax
  norm_num [exactHouseholderQRDiagDominanceCounterexampleSeq,
    diagDominanceCounterexample2, householderTrailingColumnNorm2Sq,
    householderTrailingNorm2Sq, householderTrailingPart, vecNorm2Sq] at hmax

/-- Universal-form route elimination on the stored-panel actual-unit surface:
    the stored recurrence, signed-alpha choice, nonzero source denominators,
    and a small declared unit roundoff do not imply that the displayed pivot is
    the finite active max-pivot choice. -/
theorem not_forall_signedAlphaDef_stored_trailing_sequence_actualU_sourceDen_implies_activeMaxPivotChoice :
    ¬ (∀
      (fp : FPModel)
      (A_hat : ℕ → Fin 2 → Fin 2 → ℝ)
      (alpha : ℕ → ℝ),
      (∀ k (hk : k < 2),
        A_hat (k + 1) =
          fl_householderStoredPanelStep fp 2 2 k
            (householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i => A_hat k i ⟨k, hk⟩) (alpha k))
            (householderBetaSpec 2
              (householderTrailingActiveVector 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i => A_hat k i ⟨k, hk⟩) (alpha k)))
            (A_hat k)) →
      (∀ k (hk : k < 2),
        alpha k =
          signedHouseholderAlpha
            (Real.sqrt
              (householderTrailingNorm2Sq 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i => A_hat k i ⟨k, hk⟩)))
            (A_hat k ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ ⟨k, hk⟩)) →
      (∀ k (hk : k < 2),
        (∑ i : Fin 2,
          householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
            householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0) →
      (2 : ℝ) * fp.u < 1 →
      (∀ k (hk : k < 2),
        (⟨k, hk⟩ : Fin 2) =
          householderActiveMaxPivotColumn
            (⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ : Fin 2)
            (⟨k, hk⟩ : Fin 2)
            (A_hat k))) := by
  intro h
  have hpivot :=
    h exactHouseholderQRDiagDominanceCounterexampleFP
      exactHouseholderQRDiagDominanceCounterexampleSeq
      exactHouseholderQRDiagDominanceCounterexampleAlpha
      exactHouseholderQRDiagDominanceCounterexample_stored_step
      exactHouseholderQRDiagDominanceCounterexample_signed_alpha_def
      exactHouseholderQRDiagDominanceCounterexample_den_ne_zero
      (by
        norm_num [exactHouseholderQRDiagDominanceCounterexampleFP,
          FPModel.exactWithUnitRoundoff])
  exact exactHouseholderQRDiagDominanceCounterexample_not_activeMaxPivotChoice
    (by
      simpa using hpivot 0 (by norm_num))

/-- Stronger universal-form route elimination for the finite-max route: the
    exact unpivoted trailing Householder recurrence cannot generically produce
    diagonal dominance together with any additional property `P` of the final
    triangular block.  In particular, a future proof cannot obtain the pair
    "local diagonal dominance plus scalar finite-max smallness" from this
    recurrence without adding a genuinely stronger invariant or visible domain
    assumptions. -/
theorem not_forall_exact_trailing_householder_sequence_implies_diagDominant_and_property
    (P : (Fin 2 → Fin 2 → ℝ) → Prop) :
    ¬ (∀ (A_hat : ℕ → Fin 2 → Fin 2 → ℝ) (alpha : ℕ → ℝ),
      (∀ k (hk : k < 2),
        A_hat (k + 1) =
          matMulRectLeft
            (householder 2
              (householderTrailingActiveVector 2
                ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                (fun i => A_hat k i ⟨k, hk⟩) (alpha k))
              (householderBetaSpec 2
                (householderTrailingActiveVector 2
                  ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
                  (fun i => A_hat k i ⟨k, hk⟩) (alpha k))))
            (A_hat k)) →
      (∀ k (hk : k < 2),
        alpha k * alpha k =
          householderTrailingNorm2Sq 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun i => A_hat k i ⟨k, hk⟩)) →
      (∀ k (hk : k < 2),
        (∑ i : Fin 2,
          householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
            householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0) →
      IsDiagDominantUpper 2 (fun i j => A_hat 2 i j) ∧ P (fun i j => A_hat 2 i j)) := by
  intro h
  exact exactHouseholderQRDiagDominanceCounterexample_not_diagDominant
    (h exactHouseholderQRDiagDominanceCounterexampleSeq
      exactHouseholderQRDiagDominanceCounterexampleAlpha
      exactHouseholderQRDiagDominanceCounterexample_step
      exactHouseholderQRDiagDominanceCounterexample_alpha_sq
      exactHouseholderQRDiagDominanceCounterexample_den_ne_zero).1

/-- Universal-form route elimination: upper-triangular nonsingular leading
    blocks together with positive active-block mass still do not imply the
    off-diagonal domination field required by
    `StoredQRSourceOffDiagonalControl`.

    This prevents the rectangular QR bottleneck from silently replacing the
    explicit off-diagonal-control hypothesis by the weaker nonbreakdown data
    available from rank/determinant arguments. -/
theorem not_forall_leadingBlock_upper_det_activeBlockPos_implies_offdiag_le_diag :
    ¬ (∀ (A_hat : ℕ → Fin 2 → Fin 2 → ℝ),
      (∀ k (hk : k < 2), ∀ i j : Fin (k + 1), j.val < i.val →
        qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i j = 0) →
      (∀ k (hk : k < 2),
        Matrix.det
          (qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk :
            Matrix (Fin (k + 1)) (Fin (k + 1)) ℝ) ≠ 0) →
      (∀ k (hk : k < 2),
        0 < householderActiveBlockNorm2Sq
          ⟨k, hk⟩ ⟨k, hk⟩ (A_hat k)) →
      (∀ k (hk : k < 2), ∀ i j : Fin (k + 1), i.val < j.val →
        |qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i j| ≤
          |qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i i|)) := by
  intro h
  let A_hat : ℕ → Fin 2 → Fin 2 → ℝ := fun _ => diagDominanceCounterexample2
  have hupper : ∀ k (hk : k < 2), ∀ i j : Fin (k + 1), j.val < i.val →
      qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk i j = 0 := by
    intro k hk i j hji
    interval_cases k
    · fin_cases i
      fin_cases j
      omega
    · simpa [A_hat, qrLeadingBlock, qrLeadingRow, qrLeadingColumn] using
        diagDominanceCounterexample2_upper
          (qrLeadingRow 2 1 (Nat.succ_le_iff.mpr hk) i)
          (qrLeadingColumn 2 1 hk j)
          (by simpa [qrLeadingRow, qrLeadingColumn] using hji)
  have hdetLead : ∀ k (hk : k < 2),
      Matrix.det
        (qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk :
          Matrix (Fin (k + 1)) (Fin (k + 1)) ℝ) ≠ 0 := by
    intro k hk
    have hk_cases : k = 0 ∨ k = 1 := by omega
    rcases hk_cases with rfl | rfl
    · have hblock :
          (qrLeadingBlock diagDominanceCounterexample2
              (Nat.succ_le_iff.mpr hk) hk :
            Matrix (Fin (0 + 1)) (Fin (0 + 1)) ℝ) =
            (fun _ _ => (1 : ℝ)) := by
        ext i j
        fin_cases i
        fin_cases j
        norm_num [qrLeadingBlock, qrLeadingRow, qrLeadingColumn,
          diagDominanceCounterexample2]
      rw [hblock, Matrix.det_fin_one]
