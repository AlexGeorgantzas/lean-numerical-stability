      fl_dotProduct, Fin.foldl_succ, householderTrailingActiveVector,
      householderActiveVector, householderTrailingPart, householderBetaSpec]

/-- The stored diagonally-dominant scalar-comparison witness uses the signed
    Householder alpha definition. -/
theorem storedDiagDominantComparisonCounterexample_signed_alpha_def :
    ∀ k (hk : k < 2),
      storedDiagDominantComparisonCounterexampleAlpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i =>
                storedDiagDominantComparisonCounterexampleSeq k i ⟨k, hk⟩)))
          (storedDiagDominantComparisonCounterexampleSeq k
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ ⟨k, hk⟩) := by
  intro k hk
  interval_cases k
  · have hsqrt9 : Real.sqrt (9 : ℝ) = 3 := by
      rw [Real.sqrt_eq_iff_mul_self_eq_of_pos (by norm_num : (0 : ℝ) < 3)]
      norm_num
    norm_num [storedDiagDominantComparisonCounterexampleAlpha,
      storedDiagDominantComparisonCounterexampleSeq,
      activeMaxPivotRowMaxComparisonCounterexampleA0, signedHouseholderAlpha,
      householderTrailingNorm2Sq, vecNorm2Sq, householderTrailingPart]
    exact hsqrt9.symm
  · norm_num [storedDiagDominantComparisonCounterexampleAlpha,
      storedDiagDominantComparisonCounterexampleSeq,
      storedDiagDominantComparisonCounterexampleA1, signedHouseholderAlpha,
      householderTrailingNorm2Sq, vecNorm2Sq, householderTrailingPart]

/-- The exact Householder source denominators in the stored diagonally-dominant
    scalar-comparison witness are nonzero. -/
theorem storedDiagDominantComparisonCounterexample_den_ne_zero :
    ∀ k (hk : k < 2),
      (∑ i : Fin 2,
        householderTrailingActiveVector 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun a =>
              storedDiagDominantComparisonCounterexampleSeq k a ⟨k, hk⟩)
            (storedDiagDominantComparisonCounterexampleAlpha k) i *
          householderTrailingActiveVector 2
            ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
            (fun a =>
              storedDiagDominantComparisonCounterexampleSeq k a ⟨k, hk⟩)
            (storedDiagDominantComparisonCounterexampleAlpha k) i) ≠ 0 := by
  intro k hk
  interval_cases k
  · norm_num [storedDiagDominantComparisonCounterexampleAlpha,
      storedDiagDominantComparisonCounterexampleSeq,
      activeMaxPivotRowMaxComparisonCounterexampleA0,
      householderTrailingActiveVector, householderActiveVector,
      householderTrailingPart]
  · norm_num [storedDiagDominantComparisonCounterexampleAlpha,
      storedDiagDominantComparisonCounterexampleSeq,
      storedDiagDominantComparisonCounterexampleA1,
      householderTrailingActiveVector, householderActiveVector,
      householderTrailingPart]

/-- The stored scalar-comparison counterexample is diagonally dominant at every
    displayed leading block consumed by the active branch. -/
theorem storedDiagDominantComparisonCounterexample_diagDominant :
    ∀ k (hk : k < 2),
      IsDiagDominantUpper (k + 1)
        (qrLeadingBlock (storedDiagDominantComparisonCounterexampleSeq k)
          (Nat.succ_le_iff.mpr hk) hk) := by
  intro k hk
  interval_cases k
  · refine ⟨?_, ?_, ?_⟩
    · intro i j hji
      fin_cases i
      fin_cases j
      omega
    · intro i
      fin_cases i
      norm_num [storedDiagDominantComparisonCounterexampleSeq,
        activeMaxPivotRowMaxComparisonCounterexampleA0, qrLeadingBlock,
        qrLeadingRow, qrLeadingColumn]
    · intro i j hij
      fin_cases i
      fin_cases j
      omega
  · refine ⟨?_, ?_, ?_⟩
    · intro i j hji
      fin_cases i
      · fin_cases j
        · norm_num at hji
        · norm_num at hji
      · fin_cases j
        · norm_num [storedDiagDominantComparisonCounterexampleSeq,
            storedDiagDominantComparisonCounterexampleA1, qrLeadingBlock,
            qrLeadingRow, qrLeadingColumn]
        · norm_num at hji
    · intro i
      fin_cases i <;>
        norm_num [storedDiagDominantComparisonCounterexampleSeq,
          storedDiagDominantComparisonCounterexampleA1, qrLeadingBlock,
          qrLeadingRow, qrLeadingColumn]
    · intro i j hij
      fin_cases i <;> fin_cases j <;>
        first
        | omega
        | norm_num [storedDiagDominantComparisonCounterexampleSeq,
            storedDiagDominantComparisonCounterexampleA1, qrLeadingBlock,
            qrLeadingRow, qrLeadingColumn]

/-- The stored diagonally-dominant scalar-comparison witness also satisfies the
    finite active max-pivot policy.  This keeps the later route elimination on
    the active-pivot branch, rather than only on an unpivoted stored surface. -/
theorem storedDiagDominantComparisonCounterexample_activeMaxPivotChoice :
    ∀ k (hk : k < 2),
      (⟨k, hk⟩ : Fin 2) =
        householderActiveMaxPivotColumn
          (⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ : Fin 2)
          (⟨k, hk⟩ : Fin 2)
          (storedDiagDominantComparisonCounterexampleSeq k) := by
  intro k hk
  interval_cases k
  · let q : Fin 2 :=
      householderActiveMaxPivotColumn
        (⟨0, by norm_num⟩ : Fin 2) (⟨0, by norm_num⟩ : Fin 2)
        (storedDiagDominantComparisonCounterexampleSeq 0)
    have hmax :=
      householderActiveMaxPivotColumn_pivot_max
        (p := (⟨0, by norm_num⟩ : Fin 2))
        (k := (⟨0, by norm_num⟩ : Fin 2))
        (A := storedDiagDominantComparisonCounterexampleSeq 0)
        (l := (⟨0, by norm_num⟩ : Fin 2)) (by norm_num)
    change
      householderTrailingColumnNorm2Sq
          (⟨0, by norm_num⟩ : Fin 2)
          (storedDiagDominantComparisonCounterexampleSeq 0)
          (⟨0, by norm_num⟩ : Fin 2) ≤
        householderTrailingColumnNorm2Sq
          (⟨0, by norm_num⟩ : Fin 2)
          (storedDiagDominantComparisonCounterexampleSeq 0) q at hmax
    have hq_ne_one : q.val ≠ 1 := by
      intro hq
      have hqeq : q = (⟨1, by norm_num⟩ : Fin 2) := Fin.ext hq
      rw [hqeq] at hmax
      norm_num [storedDiagDominantComparisonCounterexampleSeq,
        activeMaxPivotRowMaxComparisonCounterexampleA0,
        householderTrailingColumnNorm2Sq, householderTrailingNorm2Sq,
        householderTrailingPart, vecNorm2Sq] at hmax
    apply Fin.ext
    have hq_lt : q.val < 2 := q.isLt
    interval_cases q.val
    · rfl
    · exact False.elim (hq_ne_one rfl)
  · let q : Fin 2 :=
      householderActiveMaxPivotColumn
        (⟨1, by norm_num⟩ : Fin 2) (⟨1, by norm_num⟩ : Fin 2)
        (storedDiagDominantComparisonCounterexampleSeq 1)
    have hge :=
      householderActiveMaxPivotColumn_ge
        (p := (⟨1, by norm_num⟩ : Fin 2))
        (k := (⟨1, by norm_num⟩ : Fin 2))
        (A := storedDiagDominantComparisonCounterexampleSeq 1)
    apply Fin.ext
    have hgeq : 1 ≤ q.val := by
      simpa [q] using hge
    exact Nat.le_antisymm hgeq (Nat.le_of_lt_succ q.isLt)

/-- Even on the stored-recursive diagonally-dominant surface, an oversized
    uniform stage budget can violate the scalar diagonal lower-bound defect. -/
theorem storedDiagDominantComparisonCounterexample_stageDiagLowerDefectBudget_pos :
    0 < storedQRStageDiagLowerDefectBudget (by omega : 2 ≤ 2)
      storedDiagDominantComparisonCounterexampleSeq (fun _ => (4 : ℝ)) := by
  let i : Fin (1 + 1) := ⟨0, by norm_num⟩
  have hle :=
    storedQRStageDiagLowerDefect_le_budget
      (by omega : 2 ≤ 2)
      storedDiagDominantComparisonCounterexampleSeq
      (fun _ => (4 : ℝ))
      (k := 1) (hk := by norm_num) i (by norm_num)
  have hentry :
      (4 : ℝ) -
          |qrLeadingBlock (storedDiagDominantComparisonCounterexampleSeq 1)
            (Nat.succ_le_iff.mpr
              (lt_of_lt_of_le (by norm_num : 1 < 2) (by omega : 2 ≤ 2)))
            (by norm_num : 1 < 2) i i| = 1 := by
    norm_num [i, storedDiagDominantComparisonCounterexampleSeq,
      storedDiagDominantComparisonCounterexampleA1, qrLeadingBlock,
      qrLeadingRow, qrLeadingColumn]
    rfl
  have hbudget :
      (1 : ℝ) ≤
        storedQRStageDiagLowerDefectBudget (by omega : 2 ≤ 2)
          storedDiagDominantComparisonCounterexampleSeq (fun _ => (4 : ℝ)) := by
    simpa [hentry] using hle
  linarith

/-- Even on the stored-recursive diagonally-dominant surface, the scalar
    stage-budget/row-max comparison can remain positive. -/
theorem storedDiagDominantComparisonCounterexample_stageRowMaxComparisonDefectBudget_pos :
    0 < storedQRStageRowMaxComparisonDefectBudget (by omega : 2 ≤ 2)
      storedDiagDominantComparisonCounterexampleSeq (fun _ => (3 : ℝ)) := by
  let i : Fin (1 + 1) := ⟨0, by norm_num⟩
  have hle :=
    storedQRStageRowMaxComparisonDefect_le_budget
      (by omega : 2 ≤ 2)
      storedDiagDominantComparisonCounterexampleSeq
      (fun _ => (3 : ℝ))
      (k := 1) (hk := by norm_num) i (by norm_num)
  have hentry :
      (3 : ℝ) -
          qrLeadingStrictUpperRowMaxBudget (by omega : 2 ≤ 2)
            storedDiagDominantComparisonCounterexampleSeq 1
            (by norm_num) i = 1 := by
    rw [qrLeadingStrictUpperRowMaxBudget]
    rw [dif_pos (by norm_num : i.val < 1)]
    have hsup :
        (Finset.univ.filter (fun j : Fin (1 + 1) => i.val < j.val)).sup'
            (by
              refine ⟨(⟨1, by norm_num⟩ : Fin (1 + 1)), ?_⟩
              simp [i])
            (fun j =>
              |qrLeadingBlock
                (storedDiagDominantComparisonCounterexampleSeq 1)
                (Nat.succ_le_iff.mpr
                  (lt_of_lt_of_le (by norm_num : 1 < 2) (by omega : 2 ≤ 2)))
                (by norm_num : 1 < 2) i j|) = 2 := by
      apply Finset.sup'_eq_of_forall
      intro j hj
      have hj_one : j = (⟨1, by norm_num⟩ : Fin (1 + 1)) := by
        have hjpos : i.val < j.val := (Finset.mem_filter.mp hj).2
        fin_cases j
        · norm_num [i] at hjpos
        · rfl
      subst hj_one
      norm_num [i, storedDiagDominantComparisonCounterexampleSeq,
        storedDiagDominantComparisonCounterexampleA1, qrLeadingBlock,
        qrLeadingRow, qrLeadingColumn]
    rw [hsup]
    norm_num
  have hbudget :
      (1 : ℝ) ≤
        storedQRStageRowMaxComparisonDefectBudget (by omega : 2 ≤ 2)
          storedDiagDominantComparisonCounterexampleSeq (fun _ => (3 : ℝ)) := by
    simpa [hentry] using hle
  linarith

