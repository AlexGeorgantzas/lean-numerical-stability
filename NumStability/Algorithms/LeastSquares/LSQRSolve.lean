/-- Build the displayed row-budget control certificate from signed-stage
    Cox--Higham row-growth budgets.

The signed-stage row-growth theorem supplies the strict-upper-entry budget
field.  The diagonal lower-bound field remains the honest source/domain
obligation, restricted to rows that can actually have strict upper entries.
The pivot-column zeroing field is derived from the same norm-square
nonbreakdown budget used elsewhere in the stored-QR source-control route. -/
theorem StoredQRDisplayedRowBudgetControl.of_signed_stage_budgets_factor_of_normSqBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ) (c : ℝ)
    (rowBudget : ∀ k, k < n → Fin (k + 1) → ℝ)
    (entryBudget :
      ∀ k (_hk : k < n), ∀ i j : Fin (k + 1), i.val < j.val → ℕ → ℝ)
    (hm : gammaValid fp m)
    (hStepA : ∀ k (hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
          (householderBetaSpec m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
          (A_hat k))
    (hAlphaDef : ∀ k (hk : k < n),
      alpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩)))
          (A_hat k ⟨k, lt_of_lt_of_le hk hmn⟩ ⟨k, hk⟩))
    (hbudgetNormSq : ∀ k (hk : k < n),
      (m : ℝ) *
          (householderCompactComponentBudget fp m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
            (fun a => A_hat k a ⟨k, hk⟩)
            ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
        householderTrailingNorm2Sq m
          ⟨k, lt_of_lt_of_le hk hmn⟩
          (fun a => A_hat k a ⟨k, hk⟩))
    (hinit : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ hij : i.val < j.val,
      |A_hat 0
          (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
          (qrLeadingColumn n k hk j)| ≤
        entryBudget k hk i j hij 0)
    (hbudget : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ hij : i.val < j.val,
      ∀ t : ℕ, t < qrLeadingOffdiagStop j →
        c * entryBudget k hk i j hij t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a (qrLeadingColumn n k hk j))
              (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
          ≤ entryBudget k hk i j hij (t + 1))
    (hexact : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ hij : i.val < j.val,
      ∀ t : ℕ, t < qrLeadingOffdiagStop j →
        |matMulVec m
          (householder m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t))
          (fun a => A_hat t a (qrLeadingColumn n k hk j))
          (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)| ≤
          c * entryBudget k hk i j hij t)
    (hrowBudget : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ hij : i.val < j.val,
      entryBudget k hk i j hij (qrLeadingOffdiagStop j) ≤
        rowBudget k hk i)
    (hdiagLower : ∀ k (hk : k < n),
      ∀ i : Fin (k + 1), i.val < k →
        rowBudget k hk i ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|) :
    StoredQRDisplayedRowBudgetControl hmn A_hat rowBudget := by
  refine ⟨?_, hdiagLower⟩
  have hStepStored : ∀ k (_hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (storedQRSignedStageVector hmn A_hat alpha k)
          (storedQRSignedStageBeta hmn A_hat alpha k)
          (A_hat k) := by
    intro k hk
    simpa [storedQRSignedStageVector, storedQRSignedStageBeta, hk] using
      hStepA k hk
  exact
    fl_householderStoredPanel_sequence_leadingBlock_offdiag_budget_of_signed_stage_budgets_factor
      hmn fp A_hat alpha c rowBudget entryBudget hm hStepStored hinit
      (storedQRSignedStage_pivot_zeroing_field_of_normSqBudget
        hmn fp A_hat alpha hAlphaDef hbudgetNormSq)
      hbudget hexact hrowBudget

/-- Build the displayed row-budget control certificate from one monotone
    signed-stage Cox--Higham budget sequence.

This specializes the row-budget package to `rowBudget k i = stageBudget k`.
The stop-time inequality for displayed upper entries supplies the terminal
budget domination field from monotonicity, so the remaining source/domain field
is exactly the offdiag-row diagonal lower bound
`stageBudget k <= |(S_k)_{ii}|`. -/
theorem StoredQRDisplayedRowBudgetControl.of_signed_stage_uniformBudget_factor_of_normSqBudget
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (alpha : ℕ → ℝ) (c : ℝ)
    (stageBudget : ℕ → ℝ)
    (hm : gammaValid fp m)
    (hStepA : ∀ k (hk : k < n),
      A_hat (k + 1) =
        fl_householderStoredPanelStep fp m n k
          (householderTrailingActiveVector m
            ⟨k, lt_of_lt_of_le hk hmn⟩
            (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
          (householderBetaSpec m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
          (A_hat k))
    (hAlphaDef : ∀ k (hk : k < n),
      alpha k =
        signedHouseholderAlpha
          (Real.sqrt
            (householderTrailingNorm2Sq m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩)))
          (A_hat k ⟨k, lt_of_lt_of_le hk hmn⟩ ⟨k, hk⟩))
    (hbudgetNormSq : ∀ k (hk : k < n),
      (m : ℝ) *
          (householderCompactComponentBudget fp m
            (householderTrailingActiveVector m
              ⟨k, lt_of_lt_of_le hk hmn⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k))
            (householderBetaSpec m
              (householderTrailingActiveVector m
                ⟨k, lt_of_lt_of_le hk hmn⟩
                (fun a => A_hat k a ⟨k, hk⟩) (alpha k)))
            (fun a => A_hat k a ⟨k, hk⟩)
            ⟨k, lt_of_lt_of_le hk hmn⟩) ^ 2 <
        householderTrailingNorm2Sq m
          ⟨k, lt_of_lt_of_le hk hmn⟩
          (fun a => A_hat k a ⟨k, hk⟩))
    (hinit : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ _hij : i.val < j.val,
      |A_hat 0
          (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
          (qrLeadingColumn n k hk j)| ≤
        stageBudget 0)
    (hbudget : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ _hij : i.val < j.val,
      ∀ t : ℕ, t < qrLeadingOffdiagStop j →
        c * stageBudget t +
            householderCompactComponentBudget fp m
              (storedQRSignedStageVector hmn A_hat alpha t)
              (storedQRSignedStageBeta hmn A_hat alpha t)
              (fun a => A_hat t a (qrLeadingColumn n k hk j))
              (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)
          ≤ stageBudget (t + 1))
    (hexact : ∀ k (hk : k < n), ∀ i j : Fin (k + 1), ∀ _hij : i.val < j.val,
      ∀ t : ℕ, t < qrLeadingOffdiagStop j →
        |matMulVec m
          (householder m
            (storedQRSignedStageVector hmn A_hat alpha t)
            (storedQRSignedStageBeta hmn A_hat alpha t))
          (fun a => A_hat t a (qrLeadingColumn n k hk j))
          (qrLeadingRow m k (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) i)| ≤
          c * stageBudget t)
    (hBudget_mono : ∀ a b : ℕ, a ≤ b → stageBudget a ≤ stageBudget b)
    (hdiagLower : ∀ k (hk : k < n),
      ∀ i : Fin (k + 1), i.val < k →
        stageBudget k ≤
        |qrLeadingBlock (A_hat k)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le hk hmn)) hk i i|) :
    StoredQRDisplayedRowBudgetControl hmn A_hat
      (fun k (_hk : k < n) (_i : Fin (k + 1)) => stageBudget k) := by
  refine
    StoredQRDisplayedRowBudgetControl.of_signed_stage_budgets_factor_of_normSqBudget
      hmn fp A_hat alpha c
      (fun k (_hk : k < n) (_i : Fin (k + 1)) => stageBudget k)
      (fun _k (_hk : _k < n) (_i _j : Fin (_k + 1))
        (_hij : _i.val < _j.val) t => stageBudget t)
      hm hStepA hAlphaDef hbudgetNormSq ?_ ?_ ?_ ?_ hdiagLower
  · intro k hk i j hij
    simpa using hinit k hk i j hij
  · intro k hk i j hij t ht
    simpa using hbudget k hk i j hij t ht
  · intro k hk i j hij t ht
    simpa using hexact k hk i j hij t ht
  · intro k hk i j hij
    simpa using hBudget_mono (qrLeadingOffdiagStop j) k (qrLeadingOffdiagStop_le j)

