theorem lsNormwiseBackwardErrorEtaF_eq_formulaRHS_of_formulaMatrixRowRank_eq_card_of_formulaMatrixSigmaMin_attainer_projected_eq_zero_of_dot_b_ne_zero
    {m n : ℕ} {theta : ℝ} (htheta : 0 < theta)
