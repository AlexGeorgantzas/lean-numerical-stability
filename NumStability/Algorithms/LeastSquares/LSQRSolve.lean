theorem StoredQRSourceOffDiagonalControl.of_stored_trailing_sequence_leadingBlock_det_ne_zero_normSqBudget_stageBudget_rowBudget_product
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
