  unfold storedQRDiagDominantInvFactorBudget
  by_cases hn : 0 < n
  · rw [dif_pos hn]
    let k0 : Fin n := ⟨0, hn⟩
    have hk0_pos :
        0 <
          diagDominantUpperInvBudgetExpr (k0.val + 1)
            (qrLeadingBlock (A_hat k0.val)
              (Nat.succ_le_iff.mpr (lt_of_lt_of_le k0.isLt hmn)) k0.isLt)
            ⟨k0.val, Nat.lt_succ_self k0.val⟩ := by
      exact
        diagDominantUpperInvBudgetExpr_pos (k0.val + 1)
          (qrLeadingBlock (A_hat k0.val)
            (Nat.succ_le_iff.mpr (lt_of_lt_of_le k0.isLt hmn)) k0.isLt)
          ⟨k0.val, Nat.lt_succ_self k0.val⟩ (hDD k0)
    exact
      le_trans (le_of_lt hk0_pos)
