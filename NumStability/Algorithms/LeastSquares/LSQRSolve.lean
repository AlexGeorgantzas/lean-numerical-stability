def activeMaxPivotRowMaxComparisonCounterexampleA0 :
    Fin 2 → Fin 2 → ℝ :=
  fun i j =>
    if i.val = 0 ∧ j.val = 0 then 3
    else if i.val = 0 ∧ j.val = 1 then 2
    else if i.val = 1 ∧ j.val = 1 then 1
    else 0

