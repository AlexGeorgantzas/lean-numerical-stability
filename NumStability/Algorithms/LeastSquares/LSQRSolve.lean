            (householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun i =>
                storedDiagDominantComparisonCounterexampleSeq k i ⟨k, hk⟩)
