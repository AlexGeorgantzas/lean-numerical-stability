  intro k hk i hi
  have hle :=
    storedQRStageRowMaxComparisonDefect_le_budget hmn A_hat stageBudget hk i hi
  have hnonpos :
      stageBudget k -
          qrLeadingStrictUpperRowMaxBudget hmn A_hat k hk i ≤ 0 :=
    hle.trans hdefect
  linarith

