/-- Canonical finite-maximum compact-product smallness from an explicit
    relative-budget cap.

    This is the positive-budget sibling of the zero-relative-budget endpoint.
    If the stored compact relative budget is bounded by a nonnegative scalar
    `cmax`, then it is enough to check the canonical scalar product condition
    with `cmax`.  The theorem still exposes a genuine numerical smallness
    assumption: it does not prove the cap or the scalar inequality from the
    stored QR recurrence. -/
theorem storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_relativeBudget_le
    {m n : ℕ} (hmn : n ≤ m)
    (fp : FPModel)
    (A_hat : ℕ → Fin m → Fin n → ℝ)
    (b_hat : ℕ → Fin m → ℝ)
    (alpha : ℕ → ℝ)
    (cmax : ℝ)
    (hm : gammaValid fp m)
    (hDD : ∀ k : Fin n,
      IsDiagDominantUpper (k.val + 1)
        (qrLeadingBlock (A_hat k.val)
          (Nat.succ_le_iff.mpr (lt_of_lt_of_le k.isLt hmn)) k.isLt))
    (hcmax_nonneg : 0 ≤ cmax)
    (hc_le :
      storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha ≤ cmax)
    (hsmall :
      2 * storedQRDiagDominantInvFactorBudget hmn A_hat *
          ((m : ℝ) *
            (cmax * storedQRPivotColumnNormBudget hmn A_hat) ^ 2) <
        1) :
    storedQRCompactSequenceProductBudget hmn fp A_hat b_hat alpha < 1 := by
  let c : ℝ :=
    storedQRCompactSequenceRelativeBudget hmn fp A_hat b_hat alpha
  let D : ℝ := storedQRDiagDominantInvFactorBudget hmn A_hat
  let N : ℝ := storedQRPivotColumnNormBudget hmn A_hat
  have hD_nonneg : 0 ≤ D := by
    simpa [D] using storedQRDiagDominantInvFactorBudget_nonneg hmn A_hat hDD
  have hN_nonneg : 0 ≤ N := by
    simpa [N] using storedQRPivotColumnNormBudget_nonneg hmn A_hat
  have hc_nonneg : 0 ≤ c := by
    simpa [c] using
      storedQRCompactSequenceRelativeBudget_nonneg
        hmn fp A_hat b_hat alpha hm
  have hc_bound : c ≤ cmax := by
    simpa [c] using hc_le
  have hcN_bound : c * N ≤ cmax * N :=
    mul_le_mul_of_nonneg_right hc_bound hN_nonneg
  have hcN_nonneg : 0 ≤ c * N := mul_nonneg hc_nonneg hN_nonneg
  have hcmaxN_nonneg : 0 ≤ cmax * N := mul_nonneg hcmax_nonneg hN_nonneg
  have hsq_bound : (c * N) ^ 2 ≤ (cmax * N) ^ 2 := by
    nlinarith [hcN_bound, hcN_nonneg, hcmaxN_nonneg]
  have hm_nonneg : 0 ≤ (m : ℝ) := Nat.cast_nonneg m
  have hright_bound :
      (m : ℝ) * (c * N) ^ 2 ≤ (m : ℝ) * (cmax * N) ^ 2 :=
    mul_le_mul_of_nonneg_left hsq_bound hm_nonneg
  have hright_nonneg : 0 ≤ (m : ℝ) * (c * N) ^ 2 :=
    mul_nonneg hm_nonneg (sq_nonneg _)
  have hleft_nonneg : 0 ≤ 2 * D := by
    nlinarith
  have hprod_bound :
      2 * D * ((m : ℝ) * (c * N) ^ 2) ≤
        2 * D * ((m : ℝ) * (cmax * N) ^ 2) :=
    mul_le_mul_of_nonneg_left hright_bound hleft_nonneg
  have hsmall_actual :
      2 * D * ((m : ℝ) * (c * N) ^ 2) < 1 :=
    lt_of_le_of_lt hprod_bound (by simpa [D, N] using hsmall)
  exact
    storedQRCompactSequenceProductBudget_lt_one_of_diagDominant_finite_max_smallness
      hmn fp A_hat b_hat alpha hm hDD
      (by simpa [c, D, N] using hsmall_actual)

