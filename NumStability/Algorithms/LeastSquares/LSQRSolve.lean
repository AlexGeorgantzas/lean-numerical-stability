    ∃ Deltaf : Fin (n + k) → ℝ,
    ∃ Deltag : Fin n → ℝ,
    ∃ H3 : Fin (n + k) → Fin (n + k) → ℝ,
    ∃ DeltaR1 DeltaR2 : Fin n → Fin n → ℝ,
