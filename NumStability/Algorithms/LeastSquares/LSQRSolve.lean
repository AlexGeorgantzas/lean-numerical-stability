      (∀ i j, |DeltaA i j| ≤
        ((n + k : ℝ) *
          gamma fp (n * householderConstructApplyGammaIndex (n + k))) *
          matMulRect (n + k) (n + k) n G
            (fun a b => |A a b|) i j) ∧
