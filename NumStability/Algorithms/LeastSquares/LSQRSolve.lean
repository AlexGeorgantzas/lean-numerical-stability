        · norm_num at hij
  have hcompare := h A_hat stageBudget hupper hdetLead hactive hpivotMax
    hbudget_nonneg hactiveBlockBudget hoffdiagBudget
  have hbad :=
    hcompare 1 (by norm_num) (⟨0, by norm_num⟩ : Fin (1 + 1)) (by norm_num)
