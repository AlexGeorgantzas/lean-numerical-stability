  have hη_nonneg : 0 ≤ η := by
    unfold η
    have hbase : (1 : ℝ) ≤ 1 + cStep := by linarith
    exact sub_nonneg.mpr (one_le_pow₀ hbase)
  have hΔA : frobNormRect ΔA ≤ η * frobNormRect A := by
    apply frobNormRect_le_of_col_vecNorm2_le
    · exact hη_nonneg
    · intro j
