          stageBudget k := by
    intro k hk i j hij
    interval_cases k
    · fin_cases i
      fin_cases j
      omega
    · fin_cases i
      · fin_cases j
        · norm_num at hij
        · norm_num [A_hat, stageBudget, activeMaxPivotRowBudgetDiagCounterexampleSeq,
