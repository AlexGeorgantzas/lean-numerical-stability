          (k := (⟨0, by norm_num⟩ : Fin 2))
          (A := activeMaxPivotRowBudgetDiagCounterexampleA0)
          ⟨⟨0, by norm_num⟩, by norm_num,
            ⟨0, by norm_num⟩, by norm_num,
            by norm_num [activeMaxPivotRowBudgetDiagCounterexampleA0]⟩
    · simpa [A_hat, activeMaxPivotRowBudgetDiagCounterexampleSeq] using
        householderActiveBlockNorm2Sq_pos_of_exists_active_entry_ne
          (p := (⟨1, by norm_num⟩ : Fin 2))
          (k := (⟨1, by norm_num⟩ : Fin 2))
          (A := diagDominanceCounterexample2)
          ⟨⟨1, by norm_num⟩, by norm_num,
            ⟨1, by norm_num⟩, by norm_num,
            by norm_num [diagDominanceCounterexample2]⟩
  have hpivotMax : ∀ k (hk : k < 2), ∀ l : Fin 2, k ≤ l.val →
      householderTrailingColumnNorm2Sq
          (m := 2) (n := 2) ⟨k, hk⟩ (A_hat k) l ≤
        householderTrailingColumnNorm2Sq
          (m := 2) (n := 2) ⟨k, hk⟩ (A_hat k) ⟨k, hk⟩ := by
    intro k hk l hl
    interval_cases k
    · fin_cases l <;>
        norm_num [A_hat, activeMaxPivotRowBudgetDiagCounterexampleSeq,
          activeMaxPivotRowBudgetDiagCounterexampleA0,
