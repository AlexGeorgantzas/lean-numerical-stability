            (A_hat k ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ ⟨k, hk⟩)) →
      (∀ k (hk : k < 2),
        (∑ i : Fin 2,
          householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i *
            householderTrailingActiveVector 2
              ⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩
              (fun a => A_hat k a ⟨k, hk⟩) (alpha k) i) ≠ 0) →
      (2 : ℝ) * fp.u < 1 →
      (∀ k (hk : k < 2),
        IsDiagDominantUpper (k + 1)
          (qrLeadingBlock (A_hat k) (Nat.succ_le_iff.mpr hk) hk)) →
      (∀ k (hk : k < 2),
        (⟨k, hk⟩ : Fin 2) =
          householderActiveMaxPivotColumn
            (⟨k, lt_of_lt_of_le hk (by omega : 2 ≤ 2)⟩ : Fin 2)
            (⟨k, hk⟩ : Fin 2)
            (A_hat k)) →
      (∀ k : ℕ, 0 ≤ stageBudget k) →
      storedQRStageRowMaxComparisonDefectBudget (by omega : 2 ≤ 2)
        A_hat stageBudget ≤ 0) := by
  intro h
  let stageBudget : ℕ → ℝ := fun _ => 3
  have hnonpos :
      storedQRStageRowMaxComparisonDefectBudget (by omega : 2 ≤ 2)
        storedDiagDominantComparisonCounterexampleSeq stageBudget ≤ 0 :=
    h exactHouseholderQRDiagDominanceCounterexampleFP
      storedDiagDominantComparisonCounterexampleSeq
      storedDiagDominantComparisonCounterexampleAlpha stageBudget
      storedDiagDominantComparisonCounterexample_stored_step
      storedDiagDominantComparisonCounterexample_signed_alpha_def
      storedDiagDominantComparisonCounterexample_den_ne_zero
      (by
        norm_num [exactHouseholderQRDiagDominanceCounterexampleFP,
          FPModel.exactWithUnitRoundoff])
      storedDiagDominantComparisonCounterexample_diagDominant
      storedDiagDominantComparisonCounterexample_activeMaxPivotChoice
      (by intro k; norm_num [stageBudget])
  have hpos :
      0 < storedQRStageRowMaxComparisonDefectBudget (by omega : 2 ≤ 2)
        storedDiagDominantComparisonCounterexampleSeq stageBudget := by
    simpa [stageBudget] using
      storedDiagDominantComparisonCounterexample_stageRowMaxComparisonDefectBudget_pos
  exact not_lt_of_ge hnonpos hpos

/-- Source-shaped off-diagonal control supplies a displayed row-budget
