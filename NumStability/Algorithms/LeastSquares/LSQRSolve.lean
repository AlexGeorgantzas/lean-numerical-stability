    {ι : Sort*} {alpha sigmaMin sigmaMax : ℝ} {d : ι → ℝ}
    (hsigmaMin_pos : 0 < sigmaMin)
    (halpha : alpha = sigmaMin / Real.sqrt 2)
    (hd : ∀ i : ι,
