    let Q : Fin (n + k) → Fin (n + k) → ℝ :=
      fl_householderQRPanel_Q fp (n + k) n A
    let Rhat : Fin (n + k) → Fin n → ℝ :=
      fl_householderQRPanel_R fp (n + k) n A
    let R : Fin n → Fin n → ℝ :=
