  ofEntrywiseBoundThenStorage fp A Araw Astore (fun _ _ => eta) C
    (by
      intro _ _
      exact heta_nonneg)
    hC_nonneg
    (by
      intro i j
      exact (ofFrobeniusBound fp A Araw eta heta_nonneg hF).entry_abs_error_bound i j)
    hstore

