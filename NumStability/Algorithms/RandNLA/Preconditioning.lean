          flFhtPairUpdate_propagated_error_bound fp
            pair.1 pair.2 x xhat E hE j
      have hrest := ih x₁ xhat₁ E₁ hstep i
      simpa [flFhtPairSchedule, fhtPairScheduleExact,
        fhtPairSchedulePropagatedErrorBudget, x₁, xhat₁, E₁] using hrest

