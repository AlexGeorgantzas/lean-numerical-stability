    ComputedMatrix fp (fun j i => A i j) where
  matrix := fun j i => Ahat.matrix i j
  abs_error := fun j i => Ahat.abs_error i j
  abs_error_nonneg := by
    intro j i
    exact Ahat.abs_error_nonneg i j
  abs_error_bound := by
    intro j i
    exact Ahat.abs_error_bound i j

