@[simp] theorem flBasisColumnProjectorOfColumnwiseCertifiedStoredBasis_matrix
    (fp : FPModel) {m k : ℕ}
    (Q Qraw Qstore : Fin m → Fin k → ℝ) (eta : Fin k → ℝ)
    (C : Fin m → Fin k → ℝ)
    (heta_nonneg : ∀ a, 0 ≤ eta a)
    (hC_nonneg : ∀ i j, 0 ≤ C i j)
    (hcol : ∀ a : Fin k,
