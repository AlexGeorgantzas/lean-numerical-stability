import NumStability.Algorithms.Circulant.Higham24LiteralSolver
import NumStability.Algorithms.Circulant.Higham24BackwardStability
import Mathlib.Analysis.Normed.Ring.Units

namespace NumStability

open scoped Matrix.Norms.L2Operator

/-!
# The produced structured perturbations in Higham's Theorem 24.3

The declarations in this file construct the three perturbations in the
structured mixed forward--backward equation from the literal four-stage
rounded solver.  No perturbation split or target equation is supplied as a
hypothesis.
-/

/-- Conjugating a diagonal by the inverse and forward DFT produces the
circulant generated by the inverse transform of that diagonal. -/
theorem higham24_dftInverse_diagonal_dft_eq_circulant
    (t : ℕ) (v : Fin (2 ^ t) → ℂ) :
    higham24DFTInverse (2 ^ t) * Matrix.diagonal v * higham24DFT (2 ^ t) =
      higham24Circulant (higham24DFTInverseApply v) := by
  have hdiag := higham24_circulant_diagonalization (pow_pos (by omega) t)
    (higham24DFTInverseApply v)
  rw [higham24_forward_after_inverse] at hdiag
  rw [← hdiag]
  calc
    higham24DFTInverse (2 ^ t) *
          (higham24DFT (2 ^ t) *
            higham24Circulant (higham24DFTInverseApply v) *
            higham24DFTInverse (2 ^ t)) *
          higham24DFT (2 ^ t) =
        (higham24DFTInverse (2 ^ t) * higham24DFT (2 ^ t)) *
          higham24Circulant (higham24DFTInverseApply v) *
          (higham24DFTInverse (2 ^ t) * higham24DFT (2 ^ t)) := by
      noncomm_ring
    _ = higham24Circulant (higham24DFTInverseApply v) := by
      rw [higham24_dftInverse_mul_dft]
      simp

/-- A complex relative perturbation of norm less than one cannot turn one
into zero. -/
theorem higham24_one_add_ne_zero_of_norm_lt_one {z : ℂ} (hz : ‖z‖ < 1) :
    1 + z ≠ 0 := by
  intro h
  have hzneg : z = -1 := by
    calc
      z = (1 + z) - 1 := by ring
      _ = -1 := by rw [h]; ring
  have hnorm : ‖z‖ = 1 := by rw [hzneg]; simp
  linarith

/-- Spectral matrix norm controls the Euclidean norm of a matrix action, in
the chapter's plain `Fin n → ℂ` presentation. -/
theorem higham24_l2OpNorm_mulVec_norm_le {m n : ℕ}
    (A : Matrix (Fin m) (Fin n) ℂ) (x : Fin n → ℂ) :
    higham24FinEuclideanNorm (A.mulVec x) ≤
      ‖A‖ * higham24FinEuclideanNorm x := by
  simpa [higham24FinEuclideanNorm] using
    Matrix.l2_opNorm_mulVec A
      (WithLp.toLp (2 : ENNReal) x : EuclideanSpace ℂ (Fin n))

/-- Scalar inverse bound used for the diagonal factor `(I+E)⁻¹`. -/
theorem higham24_norm_one_add_inv_le {z : ℂ} {s : ℝ}
    (hz : ‖z‖ ≤ s) (hs : s < 1) :
    ‖(1 + z)⁻¹‖ ≤ (1 - s)⁻¹ := by
  have hne := higham24_one_add_ne_zero_of_norm_lt_one (lt_of_le_of_lt hz hs)
  have hden : 0 < 1 - s := by linarith
  have hnormpos : 0 < ‖1 + z‖ := norm_pos_iff.mpr hne
  have htri : (1 : ℝ) ≤ ‖1 + z‖ + ‖z‖ := by
    have h := norm_sub_le (1 + z) z
    simpa using h
  have hlower : 1 - s ≤ ‖1 + z‖ := by linarith
  rw [norm_inv]
  exact (inv_le_inv₀ hnormpos hden).2 hlower

/-- Difference of the scalar inverse from one. -/
theorem higham24_norm_one_add_inv_sub_one_le {z : ℂ} {s : ℝ}
    (hz : ‖z‖ ≤ s) (hs : s < 1) :
    ‖(1 + z)⁻¹ - 1‖ ≤ s / (1 - s) := by
  have hne := higham24_one_add_ne_zero_of_norm_lt_one (lt_of_le_of_lt hz hs)
  have hinv := higham24_norm_one_add_inv_le hz hs
  have hid : (1 + z)⁻¹ - 1 = -(1 + z)⁻¹ * z := by
    calc
      (1 + z)⁻¹ - 1 = (1 + z)⁻¹ - (1 + z)⁻¹ * (1 + z) := by
        rw [inv_mul_cancel₀ hne]
      _ = -(1 + z)⁻¹ * z := by ring
  rw [hid, norm_mul, norm_neg]
  calc
    ‖(1 + z)⁻¹‖ * ‖z‖ ≤ (1 - s)⁻¹ * s :=
      mul_le_mul hinv hz (norm_nonneg _) (inv_nonneg.mpr (by linarith))
    _ = s / (1 - s) := by rw [div_eq_mul_inv]; ring

/-- The inverse diagonal generated by the literal complex-division errors. -/
noncomputable def higham24LiteralScalingInverse
    (fp : FPModel) (hgamma4 : gammaValid fp 4) {n : ℕ}
    (d g : Fin n → ℂ) (hd : ∀ i, d i ≠ 0) :
    Matrix (Fin n) (Fin n) ℂ :=
  Matrix.diagonal (fun i =>
    (1 + higham24DiagonalSolveRelativeError fp hgamma4 d g hd i)⁻¹)

/-- Norm of the produced diagonal inverse. -/
theorem higham24_literalScalingInverse_norm_le
    (fp : FPModel) (hgamma4 : gammaValid fp 4) {n : ℕ}
    (d g : Fin n → ℂ) (hd : ∀ i, d i ≠ 0)
    (hsmall : Real.sqrt 2 * gamma fp 4 < 1) :
    ‖higham24LiteralScalingInverse fp hgamma4 d g hd‖ ≤
      (1 - Real.sqrt 2 * gamma fp 4)⁻¹ := by
  rw [higham24LiteralScalingInverse, Matrix.l2_opNorm_diagonal]
  apply (pi_norm_le_iff_of_nonneg (inv_nonneg.mpr (by linarith))).2
  intro i
  exact higham24_norm_one_add_inv_le
    (higham24_diagonalSolveRelativeError_spec fp hgamma4 d g hd i).1 hsmall

/-- Norm of the difference `(I+E)⁻¹-I`. -/
theorem higham24_literalScalingInverse_sub_one_norm_le
    (fp : FPModel) (hgamma4 : gammaValid fp 4) {n : ℕ}
    (d g : Fin n → ℂ) (hd : ∀ i, d i ≠ 0)
    (hsmall : Real.sqrt 2 * gamma fp 4 < 1) :
    ‖higham24LiteralScalingInverse fp hgamma4 d g hd - 1‖ ≤
      (Real.sqrt 2 * gamma fp 4) /
        (1 - Real.sqrt 2 * gamma fp 4) := by
  rw [higham24LiteralScalingInverse, ← Matrix.diagonal_one,
    Matrix.diagonal_sub, Matrix.l2_opNorm_diagonal]
  have hs0 : 0 ≤ Real.sqrt 2 * gamma fp 4 :=
    mul_nonneg (Real.sqrt_nonneg _) (gamma_nonneg fp hgamma4)
  have hquot : 0 ≤ (Real.sqrt 2 * gamma fp 4) /
      (1 - Real.sqrt 2 * gamma fp 4) :=
    div_nonneg hs0 (by linarith)
  apply (pi_norm_le_iff_of_nonneg hquot).2
  intro i
  exact higham24_norm_one_add_inv_sub_one_le
    (higham24_diagonalSolveRelativeError_spec fp hgamma4 d g hd i).1 hsmall

/-- The Neumann inverse of `I + K`, represented as an actual unit. -/
noncomputable def higham24OneAddUnit {n : ℕ}
    (K : Matrix (Fin n) (Fin n) ℂ) (hK : ‖K‖ < 1) :
    (Matrix (Fin n) (Fin n) ℂ)ˣ :=
  Units.oneSub (-K) (by simpa using hK)

/-- The matrix inverse selected from the Neumann unit for `I + K`. -/
noncomputable def higham24OneAddInverse {n : ℕ}
    (K : Matrix (Fin n) (Fin n) ℂ) (hK : ‖K‖ < 1) :
    Matrix (Fin n) (Fin n) ℂ :=
  ↑((higham24OneAddUnit K hK)⁻¹)

theorem higham24_oneAddInverse_mul {n : ℕ}
    (K : Matrix (Fin n) (Fin n) ℂ) (hK : ‖K‖ < 1) :
    higham24OneAddInverse K hK * (1 + K) = 1 := by
  change (↑((higham24OneAddUnit K hK)⁻¹) :
      Matrix (Fin n) (Fin n) ℂ) * (1 + K) = 1
  have hval : (↑(higham24OneAddUnit K hK) :
      Matrix (Fin n) (Fin n) ℂ) = 1 + K := by
    simp [higham24OneAddUnit]
  rw [← hval, ← Units.val_mul]
  simp

theorem higham24_mul_oneAddInverse {n : ℕ}
    (K : Matrix (Fin n) (Fin n) ℂ) (hK : ‖K‖ < 1) :
    (1 + K) * higham24OneAddInverse K hK = 1 := by
  change (1 + K) * (↑((higham24OneAddUnit K hK)⁻¹) :
      Matrix (Fin n) (Fin n) ℂ) = 1
  have hval : (↑(higham24OneAddUnit K hK) :
      Matrix (Fin n) (Fin n) ℂ) = 1 + K := by
    simp [higham24OneAddUnit]
  rw [← hval, ← Units.val_mul]
  simp

/-- Neumann-series norm bound for the inverse of `I+K`. -/
theorem higham24_oneAddInverse_norm_le {n : ℕ} [Nonempty (Fin n)]
    (K : Matrix (Fin n) (Fin n) ℂ) (hK : ‖K‖ < 1) :
    ‖higham24OneAddInverse K hK‖ ≤ (1 - ‖K‖)⁻¹ := by
  have hone : ‖(1 : Matrix (Fin n) (Fin n) ℂ)‖ = 1 := by
    rw [← Matrix.diagonal_one, Matrix.l2_opNorm_diagonal]
    simp
  change ‖∑' j : ℕ, (-K) ^ j‖ ≤ (1 - ‖K‖)⁻¹
  simpa [hone] using
    tsum_geometric_le_of_norm_lt_one (-K) (by simpa using hK)

/-- Neumann-series bound for the correction `(I+K)⁻¹-I`. -/
theorem higham24_oneAddInverse_sub_one_norm_le {n : ℕ} [Nonempty (Fin n)]
    (K : Matrix (Fin n) (Fin n) ℂ) (hK : ‖K‖ < 1) :
    ‖higham24OneAddInverse K hK - 1‖ ≤ ‖K‖ / (1 - ‖K‖) := by
  have hid : higham24OneAddInverse K hK - 1 =
      -(higham24OneAddInverse K hK * K) := by
    calc
      higham24OneAddInverse K hK - 1 =
          higham24OneAddInverse K hK -
            higham24OneAddInverse K hK * (1 + K) := by
        rw [higham24_oneAddInverse_mul K hK]
      _ = -(higham24OneAddInverse K hK * K) := by noncomm_ring
  rw [hid, norm_neg]
  calc
    ‖higham24OneAddInverse K hK * K‖ ≤
        ‖higham24OneAddInverse K hK‖ * ‖K‖ := Matrix.l2_opNorm_mul _ _
    _ ≤ (1 - ‖K‖)⁻¹ * ‖K‖ :=
      mul_le_mul_of_nonneg_right (higham24_oneAddInverse_norm_le K hK)
        (norm_nonneg _)
    _ = ‖K‖ / (1 - ‖K‖) := by rw [div_eq_mul_inv]; ring

/-- Monotonicity of the rational Neumann radius on `[0,1)`. -/
theorem higham24_neumann_radius_mono {q rho : ℝ}
    (hqrho : q ≤ rho) (hrho : rho < 1) :
    q / (1 - q) ≤ rho / (1 - rho) := by
  have hqden : 0 < 1 - q := by linarith
  have hrden : 0 < 1 - rho := by linarith
  rw [div_le_div_iff₀ hqden hrden]
  nlinarith

/-- The inverse-FFT perturbation followed by the exact DFT has the relative
coefficient `rho = t*eta/(1-t*eta)` from (24.5). -/
theorem higham24_literalInversePerturbation_mul_dft_norm_le
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (x : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1) :
    ‖higham24LiteralInversePerturbation fp weight t x *
        higham24DFT (2 ^ t)‖ ≤
      higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) := by
  let eta := higham24Eta mu (gamma fp 4)
  let rho := higham24RelativeFFTBound t eta
  let s := Real.sqrt (((2 ^ t : ℕ) : ℝ))
  have hspos : 0 < s := by dsimp [s]; positivity
  have hn : (((2 ^ t : ℕ) : ℝ)) = s ^ 2 := by
    dsimp [s]
    rw [Real.sq_sqrt]
    positivity
  calc
    ‖higham24LiteralInversePerturbation fp weight t x *
        higham24DFT (2 ^ t)‖ ≤
      ‖higham24LiteralInversePerturbation fp weight t x‖ *
        ‖higham24DFT (2 ^ t)‖ := Matrix.l2_opNorm_mul _ _
    _ = ‖higham24LiteralInversePerturbation fp weight t x‖ * s := by
      rw [higham24_dft_l2_opNorm]
    _ ≤ ((((2 ^ t : ℕ) : ℝ))⁻¹ *
          higham24Eq24_6Bound (2 ^ t) t eta) * s := by
      apply mul_le_mul_of_nonneg_right _ hspos.le
      simpa [eta] using higham24_literalInversePerturbation_norm_le
        fp hgamma4 weight mu hmu hw t x hvalid
    _ = rho := by
      change (((2 ^ t : ℕ) : ℝ))⁻¹ * (s * rho) * s = rho
      rw [hn]
      field_simp [hspos.ne']
    _ = higham24RelativeFFTBound t
        (higham24Eta mu (gamma fp 4)) := rfl

/-- The inverse DFT followed by either produced forward perturbation has
operator norm at most the same relative coefficient `rho`. -/
theorem higham24_dftInverse_mul_literalForwardPerturbation_norm_le
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (x : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1) :
    ‖higham24DFTInverse (2 ^ t) *
        higham24LiteralForwardPerturbation fp weight t x‖ ≤
      higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) := by
  let eta := higham24Eta mu (gamma fp 4)
  let rho := higham24RelativeFFTBound t eta
  let s := Real.sqrt (((2 ^ t : ℕ) : ℝ))
  have hspos : 0 < s := by dsimp [s]; positivity
  calc
    ‖higham24DFTInverse (2 ^ t) *
        higham24LiteralForwardPerturbation fp weight t x‖ ≤
      ‖higham24DFTInverse (2 ^ t)‖ *
        ‖higham24LiteralForwardPerturbation fp weight t x‖ :=
      Matrix.l2_opNorm_mul _ _
    _ = s⁻¹ * ‖higham24LiteralForwardPerturbation fp weight t x‖ := by
      rw [higham24_dftInverse_l2_opNorm]
    _ ≤ s⁻¹ * higham24Eq24_6Bound (2 ^ t) t eta := by
      apply mul_le_mul_of_nonneg_left _ (inv_nonneg.mpr hspos.le)
      simpa [eta] using higham24_literalForwardPerturbation_norm_le
        fp hgamma4 weight mu hmu hw t x hvalid
    _ = rho := by
      change s⁻¹ * (s * rho) = rho
      field_simp [hspos.ne']
    _ = higham24RelativeFFTBound t
        (higham24Eta mu (gamma fp 4)) := rfl

/-- The literal diagonal perturbation and its constructed inverse cancel. -/
theorem higham24_literalScalingInverse_mul
    (fp : FPModel) (hgamma4 : gammaValid fp 4) {n : ℕ}
    (d g : Fin n → ℂ) (hd : ∀ i, d i ≠ 0)
    (hsmall : Real.sqrt 2 * gamma fp 4 < 1) :
    higham24LiteralScalingInverse fp hgamma4 d g hd *
        (1 + higham24DiagonalSolvePerturbation fp hgamma4 d g hd) = 1 := by
  rw [higham24LiteralScalingInverse,
    higham24DiagonalSolvePerturbation, ← Matrix.diagonal_one,
    Matrix.diagonal_add, Matrix.diagonal_mul_diagonal]
  congr 1
  funext i
  have he :=
    (higham24_diagonalSolveRelativeError_spec fp hgamma4 d g hd i).1
  have hne : 1 + higham24DiagonalSolveRelativeError fp hgamma4 d g hd i ≠ 0 :=
    higham24_one_add_ne_zero_of_norm_lt_one (lt_of_le_of_lt he hsmall)
  exact inv_mul_cancel₀ hne

/-- The computed diagonal and its literal inverse cancel under nonbreakdown. -/
theorem higham24_diagonal_mul_inverseDiagonal {n : ℕ}
    (d : Fin n → ℂ) (hd : ∀ i, d i ≠ 0) :
    Matrix.diagonal d * higham24InverseDiagonal d = 1 := by
  rw [higham24InverseDiagonal, Matrix.diagonal_mul_diagonal,
    ← Matrix.diagonal_one]
  congr 1
  funext i
  exact mul_inv_cancel₀ (hd i)

/-- Generator of the nearby circulant produced by the literal first FFT and
literal rounded diagonal division. -/
noncomputable def higham24LiteralPerturbedGenerator
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hd : ∀ i, higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    Fin (2 ^ t) → ℂ :=
  let d := higham24LiteralRoundedCirculantEigenvalues fp weight t c
  let g := higham24LiteralRoundedCirculantRhs fp weight t b
  higham24DFTInverseApply (fun i =>
    d i * (1 + higham24DiagonalSolveRelativeError fp hgamma4 d g hd i)⁻¹)

/-- Structured generator perturbation produced by the literal computation. -/
noncomputable def higham24LiteralGeneratorPerturbation
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hd : ∀ i, higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    Fin (2 ^ t) → ℂ :=
  higham24LiteralPerturbedGenerator fp hgamma4 weight t c b hd - c

/-- Right-hand-side perturbation in (24.8), produced by the second literal
forward FFT. -/
noncomputable def higham24LiteralRhsPerturbation
    (fp : FPModel) (weight : ∀ s, Higham24BitIndex s → ℂ)
    (t : ℕ) (b : Fin (2 ^ t) → ℂ) : Fin (2 ^ t) → ℂ :=
  (higham24DFTInverse (2 ^ t) *
    higham24LiteralForwardPerturbation fp weight t b).mulVec b

/-- Solution perturbation obtained from the actual inverse-FFT perturbation. -/
noncomputable def higham24LiteralSolutionPerturbation
    (fp : FPModel) (weight : ∀ s, Higham24BitIndex s → ℂ)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hK : ‖higham24LiteralInversePerturbation fp weight t
          (higham24LiteralRoundedCirculantScaledRhs fp weight t c b) *
        higham24DFT (2 ^ t)‖ < 1) : Fin (2 ^ t) → ℂ :=
  let xHat := higham24LiteralRoundedCirculantSolve fp weight t c b
  let K := higham24LiteralInversePerturbation fp weight t
      (higham24LiteralRoundedCirculantScaledRhs fp weight t c b) *
    higham24DFT (2 ^ t)
  (higham24OneAddInverse K hK).mulVec xHat - xHat

/-- Quantitative right-hand-side part of Theorem 24.3. -/
theorem higham24_literalRhsPerturbation_norm_le
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (b : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1) :
    higham24FinEuclideanNorm
        (higham24LiteralRhsPerturbation fp weight t b) ≤
      higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) *
        higham24FinEuclideanNorm b := by
  unfold higham24LiteralRhsPerturbation
  calc
    higham24FinEuclideanNorm
        ((higham24DFTInverse (2 ^ t) *
          higham24LiteralForwardPerturbation fp weight t b).mulVec b) ≤
      ‖higham24DFTInverse (2 ^ t) *
          higham24LiteralForwardPerturbation fp weight t b‖ *
        higham24FinEuclideanNorm b :=
      higham24_l2OpNorm_mulVec_norm_le _ _
    _ ≤ higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) *
        higham24FinEuclideanNorm b :=
      mul_le_mul_of_nonneg_right
        (higham24_dftInverse_mul_literalForwardPerturbation_norm_le
          fp hgamma4 weight mu hmu hw t b hvalid)
        (norm_nonneg _)

/-- Quantitative solution-correction part of Theorem 24.3. -/
theorem higham24_literalSolutionPerturbation_norm_le
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1)
    (hrho : higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4)) < 1) :
    let hHat := higham24LiteralRoundedCirculantScaledRhs fp weight t c b
    let K := higham24LiteralInversePerturbation fp weight t hHat *
      higham24DFT (2 ^ t)
    let hK : ‖K‖ < 1 := lt_of_le_of_lt
      (higham24_literalInversePerturbation_mul_dft_norm_le
        fp hgamma4 weight mu hmu hw t hHat hvalid) hrho
    higham24FinEuclideanNorm
        (higham24LiteralSolutionPerturbation fp weight t c b hK) ≤
      (higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) /
          (1 - higham24RelativeFFTBound t
            (higham24Eta mu (gamma fp 4)))) *
        higham24FinEuclideanNorm
          (higham24LiteralRoundedCirculantSolve fp weight t c b) := by
  dsimp only
  let hHat := higham24LiteralRoundedCirculantScaledRhs fp weight t c b
  let xHat := higham24LiteralRoundedCirculantSolve fp weight t c b
  let K := higham24LiteralInversePerturbation fp weight t hHat *
    higham24DFT (2 ^ t)
  let rho := higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4))
  have hKle : ‖K‖ ≤ rho := by
    exact higham24_literalInversePerturbation_mul_dft_norm_le
      fp hgamma4 weight mu hmu hw t hHat hvalid
  have hK : ‖K‖ < 1 := lt_of_le_of_lt hKle hrho
  have hdelta : higham24LiteralSolutionPerturbation fp weight t c b hK =
      (higham24OneAddInverse K hK - 1).mulVec xHat := by
    unfold higham24LiteralSolutionPerturbation
    rw [Matrix.sub_mulVec, Matrix.one_mulVec]
  rw [hdelta]
  calc
    higham24FinEuclideanNorm
        ((higham24OneAddInverse K hK - 1).mulVec xHat) ≤
      ‖higham24OneAddInverse K hK - 1‖ *
        higham24FinEuclideanNorm xHat :=
      higham24_l2OpNorm_mulVec_norm_le _ _
    _ ≤ (‖K‖ / (1 - ‖K‖)) * higham24FinEuclideanNorm xHat :=
      mul_le_mul_of_nonneg_right
        (higham24_oneAddInverse_sub_one_norm_le K hK) (norm_nonneg _)
    _ ≤ (rho / (1 - rho)) * higham24FinEuclideanNorm xHat :=
      mul_le_mul_of_nonneg_right
        (higham24_neumann_radius_mono hKle hrho) (norm_nonneg _)
    _ = _ := rfl

/-- The generator perturbation is the action of the explicit matrix obtained
by expanding the first FFT and the diagonal inverse. -/
theorem higham24_literalGeneratorPerturbation_representation
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hd : ∀ i,
      higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    let F := higham24DFT (2 ^ t)
    let FInv := higham24DFTInverse (2 ^ t)
    let Delta1 := higham24LiteralForwardPerturbation fp weight t c
    let d := higham24LiteralRoundedCirculantEigenvalues fp weight t c
    let g := higham24LiteralRoundedCirculantRhs fp weight t b
    let EInv := higham24LiteralScalingInverse fp hgamma4 d g hd
    higham24LiteralGeneratorPerturbation fp hgamma4 weight t c b hd =
      (FInv * ((EInv - 1) * F + EInv * Delta1)).mulVec c := by
  dsimp only
  let F := higham24DFT (2 ^ t)
  let FInv := higham24DFTInverse (2 ^ t)
  let Delta1 := higham24LiteralForwardPerturbation fp weight t c
  let d := higham24LiteralRoundedCirculantEigenvalues fp weight t c
  let g := higham24LiteralRoundedCirculantRhs fp weight t b
  let EInv := higham24LiteralScalingInverse fp hgamma4 d g hd
  have hdstage : d = (F + Delta1).mulVec c := by
    exact higham24_literalForwardFFT_representation
      fp hgamma4 weight mu hmu hw t c
  have hv : (fun i =>
      d i * (1 + higham24DiagonalSolveRelativeError fp hgamma4 d g hd i)⁻¹) =
      EInv.mulVec d := by
    funext i
    rw [show EInv = Matrix.diagonal (fun i =>
      (1 + higham24DiagonalSolveRelativeError fp hgamma4 d g hd i)⁻¹) by
        rfl, Matrix.mulVec_diagonal]
    ring
  have hperturbed :
      higham24LiteralPerturbedGenerator fp hgamma4 weight t c b hd =
        (FInv * EInv * (F + Delta1)).mulVec c := by
    unfold higham24LiteralPerturbedGenerator
    change FInv.mulVec (fun i =>
      d i * (1 + higham24DiagonalSolveRelativeError fp hgamma4 d g hd i)⁻¹) = _
    rw [hv, hdstage, ← Matrix.mulVec_mulVec, ← Matrix.mulVec_mulVec]
  have hc : c = (FInv * F).mulVec c := by
    rw [show FInv * F = 1 by
      simpa [FInv, F] using higham24_dftInverse_mul_dft (2 ^ t)]
    simp
  unfold higham24LiteralGeneratorPerturbation
  rw [hperturbed]
  calc
    (FInv * EInv * (F + Delta1)).mulVec c - c =
        (FInv * EInv * (F + Delta1)).mulVec c - (FInv * F).mulVec c := by
      rw [← hc]
    _ = (FInv * EInv * (F + Delta1) - FInv * F).mulVec c := by
      rw [Matrix.sub_mulVec]
    _ = (FInv * ((EInv - 1) * F + EInv * Delta1)).mulVec c := by
      congr 1
      noncomm_ring

/-- Exact rational generator radius before the first-order simplification in
Theorem 24.3. -/
theorem higham24_literalGeneratorPerturbation_norm_le
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1)
    (hscale : Real.sqrt 2 * gamma fp 4 < 1)
    (hd : ∀ i,
      higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    higham24FinEuclideanNorm
        (higham24LiteralGeneratorPerturbation fp hgamma4 weight t c b hd) ≤
      ((higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) +
          Real.sqrt 2 * gamma fp 4) /
        (1 - Real.sqrt 2 * gamma fp 4)) *
          higham24FinEuclideanNorm c := by
  let eta := higham24Eta mu (gamma fp 4)
  let rho := higham24RelativeFFTBound t eta
  let sigma := Real.sqrt 2 * gamma fp 4
  let sqn := Real.sqrt (((2 ^ t : ℕ) : ℝ))
  let F := higham24DFT (2 ^ t)
  let FInv := higham24DFTInverse (2 ^ t)
  let Delta1 := higham24LiteralForwardPerturbation fp weight t c
  let d := higham24LiteralRoundedCirculantEigenvalues fp weight t c
  let g := higham24LiteralRoundedCirculantRhs fp weight t b
  let EInv := higham24LiteralScalingInverse fp hgamma4 d g hd
  let M := FInv * ((EInv - 1) * F + EInv * Delta1)
  have hsq : 0 < sqn := by dsimp [sqn]; positivity
  have hsigma0 : 0 ≤ sigma := by
    dsimp [sigma]
    exact mul_nonneg (Real.sqrt_nonneg _) (gamma_nonneg fp hgamma4)
  have hden : 0 < 1 - sigma := by
    change 0 < 1 - Real.sqrt 2 * gamma fp 4
    linarith
  have hrho0 : 0 ≤ rho := higham24_relativeFFTBound_nonneg t eta
    (by
      dsimp [eta, higham24Eta]
      exact add_nonneg hmu
        (mul_nonneg (gamma_nonneg fp hgamma4)
          (add_nonneg (Real.sqrt_nonneg _) hmu))) hvalid
  have hF : ‖F‖ = sqn := by
    simpa [F, sqn] using higham24_dft_l2_opNorm t
  have hFInv : ‖FInv‖ = sqn⁻¹ := by
    simpa [FInv, sqn] using higham24_dftInverse_l2_opNorm t
  have hDelta1 : ‖Delta1‖ ≤ sqn * rho := by
    simpa [Delta1, sqn, rho, eta, higham24Eq24_6Bound] using
      higham24_literalForwardPerturbation_norm_le
        fp hgamma4 weight mu hmu hw t c hvalid
  have hEInv : ‖EInv‖ ≤ (1 - sigma)⁻¹ := by
    simpa [EInv, d, g, sigma] using
      higham24_literalScalingInverse_norm_le fp hgamma4 d g hd hscale
  have hEdiff : ‖EInv - 1‖ ≤ sigma / (1 - sigma) := by
    simpa [EInv, d, g, sigma] using
      higham24_literalScalingInverse_sub_one_norm_le
        fp hgamma4 d g hd hscale
  have hfirst : ‖FInv * (EInv - 1) * F‖ ≤ sigma / (1 - sigma) := by
    calc
      ‖FInv * (EInv - 1) * F‖ ≤ ‖FInv * (EInv - 1)‖ * ‖F‖ :=
        Matrix.l2_opNorm_mul _ _
      _ ≤ (‖FInv‖ * ‖EInv - 1‖) * ‖F‖ := by
        gcongr
        exact Matrix.l2_opNorm_mul _ _
      _ ≤ (sqn⁻¹ * (sigma / (1 - sigma))) * sqn := by
        rw [hFInv, hF]
        apply mul_le_mul_of_nonneg_right _ hsq.le
        exact mul_le_mul_of_nonneg_left hEdiff (inv_nonneg.mpr hsq.le)
      _ = sigma / (1 - sigma) := by field_simp [hsq.ne']
  have hsecond : ‖FInv * EInv * Delta1‖ ≤
      rho / (1 - sigma) := by
    calc
      ‖FInv * EInv * Delta1‖ ≤ ‖FInv * EInv‖ * ‖Delta1‖ :=
        Matrix.l2_opNorm_mul _ _
      _ ≤ (‖FInv‖ * ‖EInv‖) * ‖Delta1‖ := by
        exact mul_le_mul_of_nonneg_right (Matrix.l2_opNorm_mul _ _)
          (norm_nonneg _)
      _ ≤ (sqn⁻¹ * (1 - sigma)⁻¹) * (sqn * rho) := by
        rw [hFInv]
        have hleft : sqn⁻¹ * ‖EInv‖ ≤ sqn⁻¹ * (1 - sigma)⁻¹ :=
          mul_le_mul_of_nonneg_left hEInv (inv_nonneg.mpr hsq.le)
        exact mul_le_mul hleft hDelta1 (norm_nonneg _)
          (mul_nonneg (inv_nonneg.mpr hsq.le) (inv_nonneg.mpr hden.le))
      _ = rho / (1 - sigma) := by
        rw [div_eq_mul_inv]
        field_simp [hsq.ne']
  have hM : ‖M‖ ≤ (rho + sigma) / (1 - sigma) := by
    have hExpand : M = FInv * (EInv - 1) * F + FInv * EInv * Delta1 := by
      dsimp [M]
      noncomm_ring
    rw [hExpand]
    calc
      ‖FInv * (EInv - 1) * F + FInv * EInv * Delta1‖ ≤
          ‖FInv * (EInv - 1) * F‖ + ‖FInv * EInv * Delta1‖ :=
        norm_add_le _ _
      _ ≤ sigma / (1 - sigma) + rho / (1 - sigma) :=
        add_le_add hfirst hsecond
      _ = (rho + sigma) / (1 - sigma) := by ring
  rw [higham24_literalGeneratorPerturbation_representation
    fp hgamma4 weight mu hmu hw t c b hd]
  calc
    higham24FinEuclideanNorm (M.mulVec c) ≤
        ‖M‖ * higham24FinEuclideanNorm c :=
      higham24_l2OpNorm_mulVec_norm_le _ _
    _ ≤ ((rho + sigma) / (1 - sigma)) *
        higham24FinEuclideanNorm c :=
      mul_le_mul_of_nonneg_right hM (norm_nonneg _)
    _ = _ := rfl

/-! ## First-order form of the exact radii -/

/-- Explicit remainder left after extracting the printed `t*eta + 6u`
terms from all three exact rational radii. -/
noncomputable def higham24LiteralTheorem24_3Remainder
    (fp : FPModel) (t : ℕ) (mu : ℝ) : ℝ :=
  let a := (t : ℝ) * higham24Eta mu (gamma fp 4)
  let rho := higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4))
  let sigma := Real.sqrt 2 * gamma fp 4
  let gamma4Remainder := (((4 : ℝ) * fp.u) ^ 2) / (1 - (4 : ℝ) * fp.u)
  a ^ 2 / (1 - a) + Real.sqrt 2 * gamma4Remainder +
    sigma * (rho + sigma) / (1 - sigma) +
    rho ^ 2 / (1 - rho)

theorem higham24_sqrtTwo_le_three_halves : Real.sqrt 2 ≤ (3 : ℝ) / 2 := by
  have hs0 : 0 ≤ Real.sqrt 2 := Real.sqrt_nonneg _
  have hs2 : (Real.sqrt 2) ^ 2 = 2 := Real.sq_sqrt (by norm_num)
  nlinarith

/-- The exact rational radii are bounded by the printed first-order term and
the explicit common remainder. -/
theorem higham24_literalTheorem24_3_radii_firstOrder
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (t : ℕ) (mu : ℝ) (hmu : 0 ≤ mu)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1)
    (hrho : higham24RelativeFFTBound t
        (higham24Eta mu (gamma fp 4)) < 1)
    (hscale : Real.sqrt 2 * gamma fp 4 < 1) :
    let first := (t : ℝ) * higham24Eta mu (gamma fp 4) + 6 * fp.u
    let remainder := higham24LiteralTheorem24_3Remainder fp t mu
    ((higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) +
        Real.sqrt 2 * gamma fp 4) /
      (1 - Real.sqrt 2 * gamma fp 4) ≤ first + remainder) ∧
    (higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) ≤
      first + remainder) ∧
    (higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) /
      (1 - higham24RelativeFFTBound t
        (higham24Eta mu (gamma fp 4))) ≤ first + remainder) := by
  dsimp only
  let eta := higham24Eta mu (gamma fp 4)
  let a := (t : ℝ) * eta
  let rho := higham24RelativeFFTBound t eta
  let sigma := Real.sqrt 2 * gamma fp 4
  let q4 := (((4 : ℝ) * fp.u) ^ 2) / (1 - (4 : ℝ) * fp.u)
  let rem := a ^ 2 / (1 - a) + Real.sqrt 2 * q4 +
    sigma * (rho + sigma) / (1 - sigma) + rho ^ 2 / (1 - rho)
  have ha0 : 0 ≤ a := by
    dsimp [a, eta, higham24Eta]
    exact mul_nonneg (Nat.cast_nonneg _)
      (add_nonneg hmu
        (mul_nonneg (gamma_nonneg fp hgamma4)
          (add_nonneg (Real.sqrt_nonneg _) hmu)))
  have hsig0 : 0 ≤ sigma := by
    dsimp [sigma]
    exact mul_nonneg (Real.sqrt_nonneg _) (gamma_nonneg fp hgamma4)
  have hrho0 : 0 ≤ rho := by
    exact higham24_relativeFFTBound_nonneg t eta
      (by
        dsimp [eta, higham24Eta]
        exact add_nonneg hmu
          (mul_nonneg (gamma_nonneg fp hgamma4)
            (add_nonneg (Real.sqrt_nonneg _) hmu))) hvalid
  have haden : 0 < 1 - a := by
    change 0 < 1 - (t : ℝ) * higham24Eta mu (gamma fp 4)
    linarith
  have hsden : 0 < 1 - sigma := by
    change 0 < 1 - Real.sqrt 2 * gamma fp 4
    linarith
  have hrden : 0 < 1 - rho := by
    change 0 < 1 - higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4))
    linarith
  have hq40 : 0 ≤ q4 := by
    dsimp [q4]
    exact div_nonneg (sq_nonneg _) (by
      unfold gammaValid at hgamma4
      norm_num at hgamma4 ⊢
      linarith)
  have haRem0 : 0 ≤ a ^ 2 / (1 - a) := div_nonneg (sq_nonneg _) haden.le
  have hsCross0 : 0 ≤ sigma * (rho + sigma) / (1 - sigma) :=
    div_nonneg (mul_nonneg hsig0 (add_nonneg hrho0 hsig0)) hsden.le
  have hrCross0 : 0 ≤ rho ^ 2 / (1 - rho) :=
    div_nonneg (sq_nonneg _) hrden.le
  have hrhoSplit : rho = a + a ^ 2 / (1 - a) := by
    change a / (1 - a) = a + a ^ 2 / (1 - a)
    field_simp [haden.ne']
    ring
  have hsigmaSplit : sigma = 4 * Real.sqrt 2 * fp.u +
      Real.sqrt 2 * q4 := by
    rw [show sigma = Real.sqrt 2 * gamma fp 4 by rfl,
      gamma_eq_linear_plus_quadratic_remainder fp 4 hgamma4]
    dsimp [q4]
    ring
  have hsigmaFirst : sigma ≤ 6 * fp.u + Real.sqrt 2 * q4 := by
    rw [hsigmaSplit]
    have hmul := mul_le_mul_of_nonneg_right higham24_sqrtTwo_le_three_halves
      fp.u_nonneg
    nlinarith
  have hgenSplit : (rho + sigma) / (1 - sigma) =
      rho + sigma + sigma * (rho + sigma) / (1 - sigma) := by
    field_simp [hsden.ne']
    ring
  have hsolSplit : rho / (1 - rho) =
      rho + rho ^ 2 / (1 - rho) := by
    field_simp [hrden.ne']
    ring
  have hrem : higham24LiteralTheorem24_3Remainder fp t mu = rem := rfl
  rw [hrem]
  constructor
  · change (rho + sigma) / (1 - sigma) ≤ a + 6 * fp.u + rem
    calc
      (rho + sigma) / (1 - sigma) =
          rho + sigma + sigma * (rho + sigma) / (1 - sigma) := hgenSplit
      _ ≤ (a + a ^ 2 / (1 - a)) +
          (6 * fp.u + Real.sqrt 2 * q4) +
          sigma * (rho + sigma) / (1 - sigma) := by
        rw [← hrhoSplit]
        linarith
      _ ≤ a + 6 * fp.u + rem := by
        dsimp [rem]
        nlinarith [hrCross0]
  constructor
  · change rho ≤ a + 6 * fp.u + rem
    rw [hrhoSplit]
    dsimp [rem]
    nlinarith [fp.u_nonneg, mul_nonneg (Real.sqrt_nonneg 2) hq40,
      hsCross0, hrCross0]
  · change rho / (1 - rho) ≤ a + 6 * fp.u + rem
    calc
      rho / (1 - rho) = rho + rho ^ 2 / (1 - rho) := hsolSplit
      _ = (a + a ^ 2 / (1 - a)) + rho ^ 2 / (1 - rho) := by
        rw [hrhoSplit]
      _ ≤ a + 6 * fp.u + rem := by
        dsimp [rem]
        nlinarith [fp.u_nonneg, mul_nonneg (Real.sqrt_nonneg 2) hq40,
          hsCross0]

/-- A primitive coefficient bounding `eta/u` when the twiddle error satisfies
`mu ≤ cMu*u` and `4u ≤ 1/2`. -/
noncomputable def higham24EtaLinearCoefficient (cMu : ℝ) : ℝ :=
  cMu + 8 * (Real.sqrt 2 + cMu)

/-- Explicit coefficient witnessing that the common remainder is quadratic. -/
noncomputable def higham24LiteralTheorem24_3QuadraticCoefficient
    (t : ℕ) (cMu : ℝ) : ℝ :=
  let k := higham24EtaLinearCoefficient cMu
  2 * ((t : ℝ) * k) ^ 2 + 32 * Real.sqrt 2 +
    16 * Real.sqrt 2 * (2 * (t : ℝ) * k + 8 * Real.sqrt 2) +
    8 * ((t : ℝ) * k) ^ 2

/-- Under the standard source regime `mu ≤ c*u`, the explicit remainder is
bounded by a constant times `u²`.  This is a pointwise witness for the
`O(u²)` term in Theorem 24.3, with the constant displayed in primitive
parameters. -/
theorem higham24_literalTheorem24_3_remainder_quadratic
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (t : ℕ) (mu cMu : ℝ) (hmu : 0 ≤ mu) (hcMu : 0 ≤ cMu)
    (hmuLinear : mu ≤ cMu * fp.u)
    (hfourHalf : (4 : ℝ) * fp.u ≤ 1 / 2)
    (haHalf : (t : ℝ) * higham24Eta mu (gamma fp 4) ≤ 1 / 2)
    (hsigmaHalf : Real.sqrt 2 * gamma fp 4 ≤ 1 / 2)
    (hrhoHalf : higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4)) ≤ 1 / 2) :
    higham24LiteralTheorem24_3Remainder fp t mu ≤
      higham24LiteralTheorem24_3QuadraticCoefficient t cMu * fp.u ^ 2 := by
  let u := fp.u
  let eta := higham24Eta mu (gamma fp 4)
  let a := (t : ℝ) * eta
  let rho := higham24RelativeFFTBound t eta
  let sigma := Real.sqrt 2 * gamma fp 4
  let q4 := (((4 : ℝ) * u) ^ 2) / (1 - (4 : ℝ) * u)
  let k := higham24EtaLinearCoefficient cMu
  have hu0 : 0 ≤ u := fp.u_nonneg
  have huOne : u ≤ 1 := by linarith
  have hden4 : 0 < 1 - 4 * u := by
    change 0 < 1 - (4 : ℝ) * fp.u
    linarith
  have hq40 : 0 ≤ q4 := div_nonneg (sq_nonneg _) hden4.le
  have hq4 : q4 ≤ 32 * u ^ 2 := by
    dsimp [q4]
    rw [div_le_iff₀ hden4]
    have hu2 : 0 ≤ u ^ 2 := sq_nonneg _
    nlinarith [mul_nonneg hu2 (sub_nonneg.mpr hfourHalf)]
  have hgamma8 : gamma fp 4 ≤ 8 * u := by
    convert gamma_le_two_mul_n_u_of_nu_le_half fp 4 hfourHalf using 1 <;>
      dsimp [u] <;> ring
  have hmuC : mu ≤ cMu := by
    have hcu : cMu * u ≤ cMu := by
      nlinarith [mul_nonneg hcMu (sub_nonneg.mpr huOne)]
    exact hmuLinear.trans hcu
  have heta : eta ≤ k * u := by
    have hfactor0 : 0 ≤ Real.sqrt 2 + mu :=
      add_nonneg (Real.sqrt_nonneg _) hmu
    have hfactor : Real.sqrt 2 + mu ≤ Real.sqrt 2 + cMu :=
      by linarith
    calc
      eta = mu + gamma fp 4 * (Real.sqrt 2 + mu) := rfl
      _ ≤ cMu * u + (8 * u) * (Real.sqrt 2 + cMu) := by
        exact add_le_add hmuLinear
          (mul_le_mul hgamma8 hfactor hfactor0
            (mul_nonneg (by norm_num) hu0))
      _ = k * u := by
        dsimp [k, higham24EtaLinearCoefficient]
        ring
  have hk0 : 0 ≤ k := by
    dsimp [k, higham24EtaLinearCoefficient]
    positivity
  have ha0 : 0 ≤ a := by
    have heta0 : 0 ≤ eta := by
      dsimp [eta, higham24Eta]
      exact add_nonneg hmu
        (mul_nonneg (gamma_nonneg fp hgamma4)
          (add_nonneg (Real.sqrt_nonneg _) hmu))
    exact mul_nonneg (Nat.cast_nonneg _) heta0
  have ha : a ≤ (t : ℝ) * k * u := by
    dsimp [a]
    calc
      (t : ℝ) * eta ≤ (t : ℝ) * (k * u) :=
        mul_le_mul_of_nonneg_left heta (Nat.cast_nonneg _)
      _ = (t : ℝ) * k * u := by ring
  have haden : 0 < 1 - a := by
    change 0 < 1 - (t : ℝ) * higham24Eta mu (gamma fp 4)
    linarith
  have haRem : a ^ 2 / (1 - a) ≤
      2 * (((t : ℝ) * k) ^ 2) * u ^ 2 := by
    have hdiv : a ^ 2 / (1 - a) ≤ 2 * a ^ 2 := by
      rw [div_le_iff₀ haden]
      nlinarith [sq_nonneg a]
    have haSq : a ^ 2 ≤ (((t : ℝ) * k) * u) ^ 2 :=
      (sq_le_sq₀ ha0 (mul_nonneg
        (mul_nonneg (Nat.cast_nonneg _) hk0) hu0)).2 ha
    calc
      a ^ 2 / (1 - a) ≤ 2 * a ^ 2 := hdiv
      _ ≤ 2 * (((t : ℝ) * k) * u) ^ 2 :=
        mul_le_mul_of_nonneg_left haSq (by norm_num)
      _ = 2 * (((t : ℝ) * k) ^ 2) * u ^ 2 := by ring
  have hrho0 : 0 ≤ rho := by
    exact higham24_relativeFFTBound_nonneg t eta
      (by
        dsimp [eta, higham24Eta]
        exact add_nonneg hmu
          (mul_nonneg (gamma_nonneg fp hgamma4)
            (add_nonneg (Real.sqrt_nonneg _) hmu)))
      (by change a < 1; linarith)
  have hrho : rho ≤ 2 * (t : ℝ) * k * u := by
    have hrhoa : rho ≤ 2 * a := by
      change a / (1 - a) ≤ 2 * a
      rw [div_le_iff₀ haden]
      nlinarith [mul_nonneg ha0 (sub_nonneg.mpr (by linarith : 0 ≤ 1 - 2 * a))]
    linarith
  have hsigma0 : 0 ≤ sigma := by
    dsimp [sigma]
    exact mul_nonneg (Real.sqrt_nonneg _) (gamma_nonneg fp hgamma4)
  have hsigma : sigma ≤ 8 * Real.sqrt 2 * u := by
    dsimp [sigma]
    calc
      Real.sqrt 2 * gamma fp 4 ≤ Real.sqrt 2 * (8 * u) :=
        mul_le_mul_of_nonneg_left hgamma8 (Real.sqrt_nonneg _)
      _ = 8 * Real.sqrt 2 * u := by ring
  have hsden : 0 < 1 - sigma := by
    change 0 < 1 - Real.sqrt 2 * gamma fp 4
    linarith
  have hrden : 0 < 1 - rho := by
    change 0 < 1 - higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4))
    linarith
  have hqTerm : Real.sqrt 2 * q4 ≤ 32 * Real.sqrt 2 * u ^ 2 := by
    calc
      Real.sqrt 2 * q4 ≤ Real.sqrt 2 * (32 * u ^ 2) :=
        mul_le_mul_of_nonneg_left hq4 (Real.sqrt_nonneg _)
      _ = 32 * Real.sqrt 2 * u ^ 2 := by ring
  have hsCross : sigma * (rho + sigma) / (1 - sigma) ≤
      (16 * Real.sqrt 2 *
        (2 * (t : ℝ) * k + 8 * Real.sqrt 2)) * u ^ 2 := by
    have hnum : sigma * (rho + sigma) ≤
        (8 * Real.sqrt 2 * u) *
          ((2 * (t : ℝ) * k + 8 * Real.sqrt 2) * u) := by
      have hrs : rho + sigma ≤
          (2 * (t : ℝ) * k + 8 * Real.sqrt 2) * u := by
        nlinarith
      exact mul_le_mul hsigma hrs (add_nonneg hrho0 hsigma0)
        (mul_nonneg (by positivity) hu0)
    have hdiv : sigma * (rho + sigma) / (1 - sigma) ≤
        2 * (sigma * (rho + sigma)) := by
      rw [div_le_iff₀ hsden]
      have hn0 := mul_nonneg hsigma0 (add_nonneg hrho0 hsigma0)
      nlinarith
    calc
      sigma * (rho + sigma) / (1 - sigma) ≤
          2 * (sigma * (rho + sigma)) := hdiv
      _ ≤ 2 * ((8 * Real.sqrt 2 * u) *
          ((2 * (t : ℝ) * k + 8 * Real.sqrt 2) * u)) :=
        mul_le_mul_of_nonneg_left hnum (by norm_num)
      _ = (16 * Real.sqrt 2 *
          (2 * (t : ℝ) * k + 8 * Real.sqrt 2)) * u ^ 2 := by ring
  have hrCross : rho ^ 2 / (1 - rho) ≤
      8 * (((t : ℝ) * k) ^ 2) * u ^ 2 := by
    have hdiv : rho ^ 2 / (1 - rho) ≤ 2 * rho ^ 2 := by
      rw [div_le_iff₀ hrden]
      nlinarith [sq_nonneg rho]
    have hrSq : rho ^ 2 ≤ (2 * (t : ℝ) * k * u) ^ 2 :=
      (sq_le_sq₀ hrho0 (by positivity)).2 hrho
    calc
      rho ^ 2 / (1 - rho) ≤ 2 * rho ^ 2 := hdiv
      _ ≤ 2 * (2 * (t : ℝ) * k * u) ^ 2 :=
        mul_le_mul_of_nonneg_left hrSq (by norm_num)
      _ = 8 * (((t : ℝ) * k) ^ 2) * u ^ 2 := by ring
  change a ^ 2 / (1 - a) + Real.sqrt 2 * q4 +
      sigma * (rho + sigma) / (1 - sigma) + rho ^ 2 / (1 - rho) ≤ _
  calc
    a ^ 2 / (1 - a) + Real.sqrt 2 * q4 +
        sigma * (rho + sigma) / (1 - sigma) + rho ^ 2 / (1 - rho) ≤
      2 * (((t : ℝ) * k) ^ 2) * u ^ 2 +
        32 * Real.sqrt 2 * u ^ 2 +
        (16 * Real.sqrt 2 *
          (2 * (t : ℝ) * k + 8 * Real.sqrt 2)) * u ^ 2 +
        8 * (((t : ℝ) * k) ^ 2) * u ^ 2 := by
      linarith
    _ = higham24LiteralTheorem24_3QuadraticCoefficient t cMu * fp.u ^ 2 := by
      dsimp [higham24LiteralTheorem24_3QuadraticCoefficient, k, u]
      ring

/-- Exact structured mixed forward--backward equation for the literal
four-stage executor.  The only smallness conditions are those needed for the
two genuine inverses occurring in (24.8). -/
theorem higham24_literalStructuredMixedStability_identity
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1)
    (hrho : higham24RelativeFFTBound t
        (higham24Eta mu (gamma fp 4)) < 1)
    (hscale : Real.sqrt 2 * gamma fp 4 < 1)
    (hd : ∀ i,
      higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    let hHat := higham24LiteralRoundedCirculantScaledRhs fp weight t c b
    let K := higham24LiteralInversePerturbation fp weight t hHat *
      higham24DFT (2 ^ t)
    let hK : ‖K‖ < 1 := lt_of_le_of_lt
      (higham24_literalInversePerturbation_mul_dft_norm_le
        fp hgamma4 weight mu hmu hw t hHat hvalid) hrho
    (higham24Circulant
        (c + higham24LiteralGeneratorPerturbation
          fp hgamma4 weight t c b hd)).mulVec
      (higham24LiteralRoundedCirculantSolve fp weight t c b +
        higham24LiteralSolutionPerturbation fp weight t c b hK) =
      b + higham24LiteralRhsPerturbation fp weight t b := by
  dsimp only
  let n := 2 ^ t
  let F := higham24DFT n
  let FInv := higham24DFTInverse n
  let d := higham24LiteralRoundedCirculantEigenvalues fp weight t c
  let g := higham24LiteralRoundedCirculantRhs fp weight t b
  let hHat := higham24LiteralRoundedCirculantScaledRhs fp weight t c b
  let xHat := higham24LiteralRoundedCirculantSolve fp weight t c b
  let Delta2 := higham24LiteralForwardPerturbation fp weight t b
  let Delta3 := higham24LiteralInversePerturbation fp weight t hHat
  let E := higham24DiagonalSolvePerturbation fp hgamma4 d g hd
  let EInv := higham24LiteralScalingInverse fp hgamma4 d g hd
  let D := Matrix.diagonal d
  let DInv := higham24InverseDiagonal d
  let K := Delta3 * F
  have hKle : ‖K‖ ≤ higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4)) := by
    exact higham24_literalInversePerturbation_mul_dft_norm_le
      fp hgamma4 weight mu hmu hw t hHat hvalid
  have hK : ‖K‖ < 1 := lt_of_le_of_lt hKle hrho
  let QInv := higham24OneAddInverse K hK
  have hx : xHat =
      ((FInv + Delta3) * (1 + E) * DInv * (F + Delta2)).mulVec b := by
    simpa [n, F, FInv, d, g, hHat, xHat, Delta2, Delta3, E, DInv] using
      higham24_literalRoundedCirculantSolve_composed
        fp hgamma4 weight mu hmu hw t c b hvalid hd
  have heq := higham24_eq24_8 F FInv D DInv E EInv Delta2 Delta3 QInv
    b xHat (by simpa [F, FInv, n] using higham24_dft_mul_dftInverse n)
    (by simpa [F, FInv, n] using higham24_dftInverse_mul_dft n)
    (by simpa [D, DInv, d] using higham24_diagonal_mul_inverseDiagonal d hd)
    (by simpa [EInv, E, d, g] using
      higham24_literalScalingInverse_mul fp hgamma4 d g hd hscale)
    (by simpa [QInv, K, F, Delta3] using higham24_oneAddInverse_mul K hK)
    hx
  have hcirculant : FInv * D * EInv * F =
      higham24Circulant
        (higham24LiteralPerturbedGenerator fp hgamma4 weight t c b hd) := by
    have hDE : D * EInv = Matrix.diagonal (fun i =>
        d i * (1 + higham24DiagonalSolveRelativeError
          fp hgamma4 d g hd i)⁻¹) := by
      simp [D, EInv, higham24LiteralScalingInverse,
        Matrix.diagonal_mul_diagonal]
    calc
      FInv * D * EInv * F = FInv * (D * EInv) * F := by noncomm_ring
      _ = FInv * Matrix.diagonal (fun i =>
          d i * (1 + higham24DiagonalSolveRelativeError
            fp hgamma4 d g hd i)⁻¹) * F := by rw [hDE]
      _ = higham24Circulant (higham24DFTInverseApply (fun i =>
          d i * (1 + higham24DiagonalSolveRelativeError
            fp hgamma4 d g hd i)⁻¹)) := by
        simpa [F, FInv, n] using
          higham24_dftInverse_diagonal_dft_eq_circulant t (fun i =>
            d i * (1 + higham24DiagonalSolveRelativeError
              fp hgamma4 d g hd i)⁻¹)
      _ = _ := rfl
  have hleft :
      (FInv * D * EInv * F * QInv).mulVec xHat =
        (higham24Circulant
          (higham24LiteralPerturbedGenerator fp hgamma4 weight t c b hd)).mulVec
          (QInv.mulVec xHat) := by
    rw [Matrix.mulVec_mulVec, hcirculant]
  rw [hleft] at heq
  rw [Matrix.add_mulVec, Matrix.one_mulVec] at heq
  have hcadd : c +
      higham24LiteralGeneratorPerturbation fp hgamma4 weight t c b hd =
      higham24LiteralPerturbedGenerator fp hgamma4 weight t c b hd := by
    simp [higham24LiteralGeneratorPerturbation]
  have hxadd : higham24LiteralRoundedCirculantSolve fp weight t c b +
      higham24LiteralSolutionPerturbation fp weight t c b hK =
      QInv.mulVec xHat := by
    change xHat + (QInv.mulVec xHat - xHat) = QInv.mulVec xHat
    abel
  rw [hcadd, hxadd]
  simpa [higham24LiteralRhsPerturbation, Delta2, FInv, n] using heq

/-- Theorem 24.3 for the literal four-stage rounded radix-2 solver, with the
exact rational radii that precede the book's first-order simplification.  All
three witnesses are constructed from the algorithm. -/
theorem higham24_theorem24_3_literal_exactRadii
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1)
    (hrho : higham24RelativeFFTBound t
        (higham24Eta mu (gamma fp 4)) < 1)
    (hscale : Real.sqrt 2 * gamma fp 4 < 1)
    (hd : ∀ i,
      higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    ∃ deltaC deltaX deltaB : Fin (2 ^ t) → ℂ,
      (higham24Circulant (c + deltaC)).mulVec
          (higham24LiteralRoundedCirculantSolve fp weight t c b + deltaX) =
        b + deltaB ∧
      higham24FinEuclideanNorm deltaC ≤
        ((higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) +
            Real.sqrt 2 * gamma fp 4) /
          (1 - Real.sqrt 2 * gamma fp 4)) *
            higham24FinEuclideanNorm c ∧
      higham24FinEuclideanNorm deltaB ≤
        higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) *
          higham24FinEuclideanNorm b ∧
      higham24FinEuclideanNorm deltaX ≤
        (higham24RelativeFFTBound t (higham24Eta mu (gamma fp 4)) /
          (1 - higham24RelativeFFTBound t
            (higham24Eta mu (gamma fp 4)))) *
          higham24FinEuclideanNorm
            (higham24LiteralRoundedCirculantSolve fp weight t c b) := by
  let hHat := higham24LiteralRoundedCirculantScaledRhs fp weight t c b
  let K := higham24LiteralInversePerturbation fp weight t hHat *
    higham24DFT (2 ^ t)
  have hKle : ‖K‖ ≤ higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4)) := by
    exact higham24_literalInversePerturbation_mul_dft_norm_le
      fp hgamma4 weight mu hmu hw t hHat hvalid
  have hK : ‖K‖ < 1 := lt_of_le_of_lt hKle hrho
  refine ⟨higham24LiteralGeneratorPerturbation
      fp hgamma4 weight t c b hd,
    higham24LiteralSolutionPerturbation fp weight t c b hK,
    higham24LiteralRhsPerturbation fp weight t b, ?_, ?_, ?_, ?_⟩
  · exact higham24_literalStructuredMixedStability_identity
      fp hgamma4 weight mu hmu hw t c b hvalid hrho hscale hd
  · exact higham24_literalGeneratorPerturbation_norm_le
      fp hgamma4 weight mu hmu hw t c b hvalid hscale hd
  · exact higham24_literalRhsPerturbation_norm_le
      fp hgamma4 weight mu hmu hw t b hvalid
  · exact higham24_literalSolutionPerturbation_norm_le
      fp hgamma4 weight mu hmu hw t c b hvalid hrho

/-- The printed first-order form of Theorem 24.3 for the literal four-stage
solver.  The common explicit remainder is produced by the proof rather than
assumed as part of a target-bearing perturbation premise. -/
theorem higham24_theorem24_3_literal_firstOrder
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu : ℝ) (hmu : 0 ≤ mu)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1)
    (hrho : higham24RelativeFFTBound t
        (higham24Eta mu (gamma fp 4)) < 1)
    (hscale : Real.sqrt 2 * gamma fp 4 < 1)
    (hd : ∀ i,
      higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    let radius := (t : ℝ) * higham24Eta mu (gamma fp 4) + 6 * fp.u +
      higham24LiteralTheorem24_3Remainder fp t mu
    ∃ deltaC deltaX deltaB : Fin (2 ^ t) → ℂ,
      (higham24Circulant (c + deltaC)).mulVec
          (higham24LiteralRoundedCirculantSolve fp weight t c b + deltaX) =
        b + deltaB ∧
      higham24FinEuclideanNorm deltaC ≤
        radius * higham24FinEuclideanNorm c ∧
      higham24FinEuclideanNorm deltaB ≤
        radius * higham24FinEuclideanNorm b ∧
      higham24FinEuclideanNorm deltaX ≤
        radius * higham24FinEuclideanNorm
          (higham24LiteralRoundedCirculantSolve fp weight t c b) := by
  dsimp only
  obtain ⟨deltaC, deltaX, deltaB, heq, hC, hB, hX⟩ :=
    higham24_theorem24_3_literal_exactRadii
      fp hgamma4 weight mu hmu hw t c b hvalid hrho hscale hd
  have hradii := higham24_literalTheorem24_3_radii_firstOrder
    fp hgamma4 t mu hmu hvalid hrho hscale
  dsimp only at hradii
  refine ⟨deltaC, deltaX, deltaB, heq, ?_, ?_, ?_⟩
  · exact hC.trans (mul_le_mul_of_nonneg_right hradii.1 (norm_nonneg _))
  · exact hB.trans
      (mul_le_mul_of_nonneg_right hradii.2.1 (norm_nonneg _))
  · exact hX.trans
      (mul_le_mul_of_nonneg_right hradii.2.2 (norm_nonneg _))

/-- A fully explicit interpretation of the `O(u²)` in Theorem 24.3.
When the twiddle error is at most `cMu*u` and the exact radii remain below a
half, the three algorithmically produced perturbations all satisfy the
printed first-order radius plus the displayed quadratic coefficient. -/
theorem higham24_theorem24_3_literal_quadraticRemainder
    (fp : FPModel) (hgamma4 : gammaValid fp 4)
    (weight : ∀ s, Higham24BitIndex s → ℂ)
    (mu cMu : ℝ) (hmu : 0 ≤ mu) (hcMu : 0 ≤ cMu)
    (hmuLinear : mu ≤ cMu * fp.u)
    (hw : ∀ s (p : Higham24BitIndex s),
      Higham24WeightApproximation
        (higham24FourierRoot (2 ^ s) ^ higham24BitIndexBEValue s p)
        (weight s p) mu)
    (t : ℕ) (c b : Fin (2 ^ t) → ℂ)
    (hfourHalf : (4 : ℝ) * fp.u ≤ 1 / 2)
    (haHalf : (t : ℝ) * higham24Eta mu (gamma fp 4) ≤ 1 / 2)
    (hsigmaHalf : Real.sqrt 2 * gamma fp 4 ≤ 1 / 2)
    (hrhoHalf : higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4)) ≤ 1 / 2)
    (hd : ∀ i,
      higham24LiteralRoundedCirculantEigenvalues fp weight t c i ≠ 0) :
    let radius := (t : ℝ) * higham24Eta mu (gamma fp 4) + 6 * fp.u +
      higham24LiteralTheorem24_3QuadraticCoefficient t cMu * fp.u ^ 2
    ∃ deltaC deltaX deltaB : Fin (2 ^ t) → ℂ,
      (higham24Circulant (c + deltaC)).mulVec
          (higham24LiteralRoundedCirculantSolve fp weight t c b + deltaX) =
        b + deltaB ∧
      higham24FinEuclideanNorm deltaC ≤
        radius * higham24FinEuclideanNorm c ∧
      higham24FinEuclideanNorm deltaB ≤
        radius * higham24FinEuclideanNorm b ∧
      higham24FinEuclideanNorm deltaX ≤
        radius * higham24FinEuclideanNorm
          (higham24LiteralRoundedCirculantSolve fp weight t c b) := by
  dsimp only
  have hvalid : (t : ℝ) * higham24Eta mu (gamma fp 4) < 1 := by
    linarith
  have hrho : higham24RelativeFFTBound t
      (higham24Eta mu (gamma fp 4)) < 1 := by
    linarith
  have hscale : Real.sqrt 2 * gamma fp 4 < 1 := by
    linarith
  obtain ⟨deltaC, deltaX, deltaB, heq, hC, hB, hX⟩ :=
    higham24_theorem24_3_literal_firstOrder
      fp hgamma4 weight mu hmu hw t c b hvalid hrho hscale hd
  have hrem := higham24_literalTheorem24_3_remainder_quadratic
    fp hgamma4 t mu cMu hmu hcMu hmuLinear hfourHalf haHalf
      hsigmaHalf hrhoHalf
  have hradius :
      (t : ℝ) * higham24Eta mu (gamma fp 4) + 6 * fp.u +
          higham24LiteralTheorem24_3Remainder fp t mu ≤
        (t : ℝ) * higham24Eta mu (gamma fp 4) + 6 * fp.u +
          higham24LiteralTheorem24_3QuadraticCoefficient t cMu * fp.u ^ 2 := by
    linarith
  refine ⟨deltaC, deltaX, deltaB, heq, ?_, ?_, ?_⟩
  · exact hC.trans (mul_le_mul_of_nonneg_right hradius (norm_nonneg _))
  · exact hB.trans (mul_le_mul_of_nonneg_right hradius (norm_nonneg _))
  · exact hX.trans (mul_le_mul_of_nonneg_right hradius (norm_nonneg _))

end NumStability
