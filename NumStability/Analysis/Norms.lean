theorem complexMatrixLpNorm_le_card_rpow_abs_mul_complexMatrixTwoNorm_of_mixedSubordinateMatrixNormValue
    {n : ℕ} (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p) {A : CMatrix n n} {dp d2 : ℝ}
    (hAp : IsMixedSubordinateMatrixNormValue
