    `||A||_2 <= || |A| ||_2 <= sqrt(rank A) * ||A||_2`. -/
theorem complexMatrixLpNormOfReal_two_absMatrix_bounds
    {m n : ℕ} (hn : 0 < n) (A : CMatrix m n) :
