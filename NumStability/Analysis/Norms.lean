theorem complexMatrixLpNorm_ratio_max_card_rpow_of_exponent_le
    {n : ℕ} (hn : 0 < n) {p q : ℝ} (hq : 1 ≤ q) (hqp : q ≤ p) :
    IsMaxMixedSubordinateMatrixNormRatioValue
      (complexVecLpNorm (n := n) (ENNReal.ofReal p))
