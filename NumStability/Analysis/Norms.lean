    dp ≤ (n : ℝ) ^ |p⁻¹ - (2 : ℝ)⁻¹| * d2 := by
  haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hp⟩
  haveI : Fact (1 ≤ ENNReal.ofReal (2 : ℝ)) := ⟨by
    rw [ENNReal.one_le_ofReal]
    norm_num⟩
