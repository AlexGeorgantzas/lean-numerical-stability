theorem problem2_10_ieeeDouble_two_pow_le_maxFiniteMagnitude
    {k : ℕ} (hk : k ≤ 1023) :
    (2 : ℝ) ^ k ≤ ieeeDoubleFormat.maxFiniteMagnitude := by
  rw [maxFiniteMagnitude, ieeeDoubleFormat, betaR]
  change (2 : ℝ) ^ k ≤ (2 : ℝ) ^ (1024 : ℤ) *
    (1 - (2 : ℝ) ^ (-53 : ℤ))
  have hfactor : (1 / 2 : ℝ) ≤ 1 - (2 : ℝ) ^ (-53 : ℤ) := by
    rw [zpow_neg]
    have hden : (2 : ℝ) ≤ (2 : ℝ) ^ (53 : ℕ) := by
      exact le_self_pow₀ (by norm_num : (1 : ℝ) ≤ 2)
        (by norm_num : (53 : ℕ) ≠ 0)
    have hinv : 1 / ((2 : ℝ) ^ (53 : ℕ)) ≤ 1 / (2 : ℝ) :=
      one_div_le_one_div_of_le (by norm_num : (0 : ℝ) < 2) hden
    norm_num at hinv ⊢
  have hpow_k : (2 : ℝ) ^ k ≤ (2 : ℝ) ^ (1023 : ℕ) :=
    pow_le_pow_right₀ (by norm_num : (1 : ℝ) ≤ 2) hk
  have hhalf :
      (2 : ℝ) ^ (1023 : ℕ) =
        (2 : ℝ) ^ (1024 : ℤ) * (1 / 2 : ℝ) := by
    rw [show (1024 : ℤ) = ((1023 : ℕ) : ℤ) + 1 by norm_num]
    rw [zpow_add₀ (by norm_num : (2 : ℝ) ≠ 0), zpow_natCast, zpow_one]
    field_simp
  calc
    (2 : ℝ) ^ k ≤ (2 : ℝ) ^ (1023 : ℕ) := hpow_k
    _ = (2 : ℝ) ^ (1024 : ℤ) * (1 / 2 : ℝ) := hhalf
    _ ≤ (2 : ℝ) ^ (1024 : ℤ) * (1 - (2 : ℝ) ^ (-53 : ℤ)) :=
      mul_le_mul_of_nonneg_left hfactor
        (le_of_lt (zpow_pos (by norm_num : (0 : ℝ) < 2) (1024 : ℤ)))

theorem problem2_10_ieeeDouble_two_pow_div_three_finiteNormalRange
    {k : ℕ} (hk : k ≤ 1023) :
    ieeeDoubleFormat.finiteNormalRange (((2 : ℝ) ^ k) / 3) := by
  rw [finiteNormalRange]
  have hxnonneg : 0 ≤ ((2 : ℝ) ^ k) / 3 := by positivity
  rw [abs_of_nonneg hxnonneg]
  constructor
  · have hpow_ge_one : (1 : ℝ) ≤ (2 : ℝ) ^ k :=
      one_le_pow₀ (by norm_num : (1 : ℝ) ≤ 2)
    exact le_trans problem2_10_ieeeDoubleFormat_minNormalMagnitude_le_one_third
      (by linarith : (1 / 3 : ℝ) ≤ ((2 : ℝ) ^ k) / 3)
  · have hdiv_le : ((2 : ℝ) ^ k) / 3 ≤ (2 : ℝ) ^ k := by
      have hpow_nonneg : 0 ≤ (2 : ℝ) ^ k := by positivity
      linarith
    exact le_trans hdiv_le
      (problem2_10_ieeeDouble_two_pow_le_maxFiniteMagnitude hk)

/-- Generic denominator-`3` first-operation fact for the power-of-two
subfamily of Kahan's Problem 2.10 theorem: finite IEEE-double round-to-even
rounds `(2^k)/3` to the lower adjacent endpoint, whenever the source value is
within the finite normal range. -/
theorem problem2_10_ieeeDouble_two_pow_thirds_rounds_to_lower
    {k : ℕ} (hk : k ≤ 1023) :
    ieeeDoubleFormat.finiteRoundToEven (((2 : ℝ) ^ k) / 3) =
