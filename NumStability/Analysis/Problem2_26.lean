-- Analysis/Problem2_26.lean
--
-- Problem-specific theorem surface for Higham Chapter 2, Problem 2.26.

import NumStability.Analysis.Problem2_14

namespace NumStability

noncomputable section

/-!
# Higham Chapter 2, Problem 2.26

Problem 2.26 asks for Newton's method applied to `f(x) = a - 1/x = 0`,
the reciprocal equation underlying division by `a * (1/b)`.  This file records
the exact algebraic derivation and the standard squared residual/error identity.
-/

/-- The literal Newton correction for `f(x) = a - 1/x`. -/
def reciprocalNewtonCorrection (a x : ℝ) : ℝ :=
  x - (a - 1 / x) / (1 / x ^ 2)

/-- The simplified reciprocal Newton iteration. -/
def reciprocalNewtonStep (a x : ℝ) : ℝ :=
  x * (2 - a * x)

/-- Exact reciprocal Newton iterates generated by the simplified recurrence. -/
def reciprocalNewtonStepIter (a x : ℝ) : ℕ → ℝ
  | 0 => x
  | n + 1 => reciprocalNewtonStep a (reciprocalNewtonStepIter a x n)

/-- The rounded primitive-operation trace for one reciprocal Newton step:
compute `a*x`, subtract from `2`, then multiply by `x`. -/
def reciprocalNewtonRoundedStep (fp : FPModel) (a x : ℝ) : ℝ :=
  let ax := fp.fl_mul a x
  let correction := fp.fl_sub 2 ax
  fp.fl_mul x correction

/-- The same rounded trace with the three local standard-model errors exposed. -/
def reciprocalNewtonRoundedStepErrorEval
    (a x δax δsub δmul : ℝ) : ℝ :=
  x * ((2 - (a * x) * (1 + δax)) * (1 + δsub)) * (1 + δmul)

/-- The rounded residual after one reciprocal Newton step. -/
def reciprocalNewtonRoundedResidual (fp : FPModel) (a x : ℝ) : ℝ :=
  1 - a * reciprocalNewtonRoundedStep fp a x

/-- Stored rounded reciprocal Newton iterates generated by repeatedly applying
the concrete rounded primitive-operation trace. -/
def reciprocalNewtonRoundedStepIter (fp : FPModel) (a x : ℝ) : ℕ → ℝ
  | 0 => x
  | n + 1 => reciprocalNewtonRoundedStep fp a
      (reciprocalNewtonRoundedStepIter fp a x n)

/-- Residual recurrence for the rounded reciprocal Newton trace, written in
terms of the incoming residual `r = 1 - a*x` and the three local errors. -/
def reciprocalNewtonRoundedResidualErrorEval
    (r δax δsub δmul : ℝ) : ℝ :=
  1 - (1 - r) * (1 + r - δax + r * δax) * (1 + δsub) * (1 + δmul)

/-- A conservative one-step absolute residual bound for the rounded reciprocal
Newton recurrence.  The first term is the exact Newton square; the remaining
terms account for the rounded `a*x`, subtraction, and final product. -/
def reciprocalNewtonRoundedResidualAbsBound (r u : ℝ) : ℝ :=
  |r| ^ 2 + |1 - r| ^ 2 * u +
    (|1 - r ^ 2| + |1 - r| ^ 2 * u) * (2 * u + u ^ 2)

theorem reciprocalNewtonCorrection_eq_step {a x : ℝ} (hx : x ≠ 0) :
    reciprocalNewtonCorrection a x = reciprocalNewtonStep a x := by
  rw [reciprocalNewtonCorrection, reciprocalNewtonStep]
  field_simp [hx]
  ring

theorem reciprocalNewtonStep_residual_sq (a x : ℝ) :
    1 - a * reciprocalNewtonStep a x = (1 - a * x) ^ 2 := by
  rw [reciprocalNewtonStep]
  ring

theorem reciprocalNewtonStep_error_sq {a x : ℝ} (ha : a ≠ 0) :
    (1 / a) - reciprocalNewtonStep a x =
      (1 / a) * (1 - a * x) ^ 2 := by
  rw [reciprocalNewtonStep]
  field_simp [ha]
  ring

theorem reciprocalNewtonStep_fixed_point {a : ℝ} (ha : a ≠ 0) :
    reciprocalNewtonStep a (1 / a) = 1 / a := by
  rw [reciprocalNewtonStep]
  field_simp [ha]
  ring

/-- The exact reciprocal Newton residual squares at every stored iterate. -/
theorem reciprocalNewtonStepIter_residual_pow_two (a x : ℝ) (n : ℕ) :
    1 - a * reciprocalNewtonStepIter a x n =
      (1 - a * x) ^ (2 ^ n) := by
  induction n with
  | zero =>
      simp [reciprocalNewtonStepIter]
  | succ n ih =>
      rw [reciprocalNewtonStepIter, reciprocalNewtonStep_residual_sq, ih]
      rw [pow_succ]
      exact (pow_mul (1 - a * x) (2 ^ n) 2).symm

/-- Source sentence `a / b = a * (1 / b)`: exact division is multiplication
by the reciprocal. -/
theorem division_eq_multiply_by_reciprocal (num denom : ℝ) :
    num / denom = num * (1 / denom) := by
  rw [div_eq_mul_inv]
  ring

/-- Error in division computed by multiplying a numerator by an approximate
reciprocal is the numerator-scaled reciprocal residual. -/
theorem divisionViaReciprocal_error_eq_residual
    {num denom y : ℝ} (hden : denom ≠ 0) :
    num / denom - num * y = (num / denom) * (1 - denom * y) := by
  field_simp [hden]

/-- One exact Newton reciprocal step gives a squared division error when the
division `num / denom` is implemented as `num * (1 / denom)`. -/
theorem reciprocalNewtonStep_division_error_sq
    {num denom x : ℝ} (hden : denom ≠ 0) :
    num / denom - num * reciprocalNewtonStep denom x =
      (num / denom) * (1 - denom * x) ^ 2 := by
  rw [divisionViaReciprocal_error_eq_residual hden,
    reciprocalNewtonStep_residual_sq]

/-- Exact reciprocal Newton iterates give the doubled-exponent division error
law for division implemented as multiplication by the computed reciprocal. -/
theorem reciprocalNewtonStepIter_division_error_pow_two
    {num denom x : ℝ} (hden : denom ≠ 0) (n : ℕ) :
    num / denom - num * reciprocalNewtonStepIter denom x n =
      (num / denom) * (1 - denom * x) ^ (2 ^ n) := by
  rw [divisionViaReciprocal_error_eq_residual hden,
    reciprocalNewtonStepIter_residual_pow_two]

/-- With zero local errors, the rounded residual recurrence reduces to the
exact Newton residual square. -/
theorem reciprocalNewtonRoundedResidualErrorEval_zero_errors (r : ℝ) :
    reciprocalNewtonRoundedResidualErrorEval r 0 0 0 = r ^ 2 := by
  rw [reciprocalNewtonRoundedResidualErrorEval]
  ring

/-- Rewrites the rounded-step residual in terms of the incoming exact residual
`1 - a*x` and the three local error factors. -/
theorem reciprocalNewtonRoundedStepErrorEval_residual_eq
    (a x δax δsub δmul : ℝ) :
    1 - a * reciprocalNewtonRoundedStepErrorEval a x δax δsub δmul =
      reciprocalNewtonRoundedResidualErrorEval (1 - a * x) δax δsub δmul := by
  rw [reciprocalNewtonRoundedStepErrorEval,
    reciprocalNewtonRoundedResidualErrorEval]
  ring

/-- Exact decomposition of the rounded residual recurrence into the ideal
Newton square plus the perturbations caused by the three local errors. -/
theorem reciprocalNewtonRoundedResidualErrorEval_eq_sq_plus_roundoff
    (r δax δsub δmul : ℝ) :
    reciprocalNewtonRoundedResidualErrorEval r δax δsub δmul =
      r ^ 2 + (1 - r) ^ 2 * δax -
        (1 - r ^ 2 - (1 - r) ^ 2 * δax) *
          (δsub + δmul + δsub * δmul) := by
  rw [reciprocalNewtonRoundedResidualErrorEval]
  ring

/-- Conservative absolute residual bound for one rounded reciprocal Newton
step, assuming each local standard-model error has magnitude at most `u`. -/
theorem reciprocalNewtonRoundedResidualErrorEval_abs_le
    {r δax δsub δmul u : ℝ}
    (hu : 0 ≤ u)
    (hδax : |δax| ≤ u)
    (hδsub : |δsub| ≤ u)
    (hδmul : |δmul| ≤ u) :
    |reciprocalNewtonRoundedResidualErrorEval r δax δsub δmul| ≤
      reciprocalNewtonRoundedResidualAbsBound r u := by
  have hAabs :
      |(1 - r) ^ 2 * δax| ≤ |1 - r| ^ 2 * u := by
    rw [abs_mul, abs_pow]
    exact mul_le_mul_of_nonneg_left hδax (sq_nonneg |1 - r|)
  have hBabs :
      |1 - r ^ 2 - (1 - r) ^ 2 * δax| ≤
        |1 - r ^ 2| + |1 - r| ^ 2 * u := by
    have htri₀ := abs_add_le (1 - r ^ 2) (-((1 - r) ^ 2 * δax))
    calc
      |1 - r ^ 2 - (1 - r) ^ 2 * δax|
          = |(1 - r ^ 2) + -((1 - r) ^ 2 * δax)| := by
            simp [sub_eq_add_neg, add_assoc]
      _ ≤ |1 - r ^ 2| + |-((1 - r) ^ 2 * δax)| := htri₀
      _ = |1 - r ^ 2| + |(1 - r) ^ 2 * δax| := by
            rw [abs_neg]
      _ ≤ |1 - r ^ 2| + |1 - r| ^ 2 * u := by
            exact add_le_add (le_refl _) hAabs
  have hδmul_abs :
      |δsub * δmul| ≤ u ^ 2 := by
    rw [abs_mul]
    calc
      |δsub| * |δmul| ≤ u * u :=
        mul_le_mul hδsub hδmul (abs_nonneg δmul) hu
      _ = u ^ 2 := by ring
  have hCabs :
      |δsub + δmul + δsub * δmul| ≤ 2 * u + u ^ 2 := by
    have htri₁ :
        |δsub + δmul + δsub * δmul| ≤
          |δsub + δmul| + |δsub * δmul| := by
      simpa [add_assoc] using abs_add_le (δsub + δmul) (δsub * δmul)
    have htri₂ : |δsub + δmul| ≤ |δsub| + |δmul| := abs_add_le δsub δmul
    calc
      |δsub + δmul + δsub * δmul|
          ≤ |δsub + δmul| + |δsub * δmul| := htri₁
      _ ≤ (|δsub| + |δmul|) + |δsub * δmul| := by
            exact add_le_add htri₂ (le_refl _)
      _ ≤ (u + u) + u ^ 2 := by
            exact add_le_add (add_le_add hδsub hδmul) hδmul_abs
      _ = 2 * u + u ^ 2 := by ring
  have hBbound_nonneg :
      0 ≤ |1 - r ^ 2| + |1 - r| ^ 2 * u :=
    add_nonneg (abs_nonneg _) (mul_nonneg (sq_nonneg _) hu)
  have hPabs :
      |(1 - r ^ 2 - (1 - r) ^ 2 * δax) *
          (δsub + δmul + δsub * δmul)| ≤
        (|1 - r ^ 2| + |1 - r| ^ 2 * u) * (2 * u + u ^ 2) := by
    rw [abs_mul]
    exact mul_le_mul hBabs hCabs
      (abs_nonneg (δsub + δmul + δsub * δmul)) hBbound_nonneg
  rw [reciprocalNewtonRoundedResidualErrorEval_eq_sq_plus_roundoff,
    reciprocalNewtonRoundedResidualAbsBound]
  have htri₁ :
      |r ^ 2 + (1 - r) ^ 2 * δax -
          (1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul)| ≤
        |r ^ 2 + (1 - r) ^ 2 * δax| +
          |(1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul)| := by
    have htri₀ :=
      abs_add_le (r ^ 2 + (1 - r) ^ 2 * δax)
        (-((1 - r ^ 2 - (1 - r) ^ 2 * δax) *
          (δsub + δmul + δsub * δmul)))
    calc
      |r ^ 2 + (1 - r) ^ 2 * δax -
          (1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul)|
          =
        |(r ^ 2 + (1 - r) ^ 2 * δax) +
          -((1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul))| := by
            simp [sub_eq_add_neg, add_assoc]
      _ ≤ |r ^ 2 + (1 - r) ^ 2 * δax| +
          |-((1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul))| := htri₀
      _ = |r ^ 2 + (1 - r) ^ 2 * δax| +
          |(1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul)| := by
            rw [abs_neg]
  have htri₂ :
      |r ^ 2 + (1 - r) ^ 2 * δax| ≤
        |r ^ 2| + |(1 - r) ^ 2 * δax| :=
    abs_add_le (r ^ 2) ((1 - r) ^ 2 * δax)
  calc
    |r ^ 2 + (1 - r) ^ 2 * δax -
        (1 - r ^ 2 - (1 - r) ^ 2 * δax) *
          (δsub + δmul + δsub * δmul)|
        ≤ |r ^ 2 + (1 - r) ^ 2 * δax| +
          |(1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul)| := htri₁
    _ ≤ (|r ^ 2| + |(1 - r) ^ 2 * δax|) +
          |(1 - r ^ 2 - (1 - r) ^ 2 * δax) *
            (δsub + δmul + δsub * δmul)| := by
          exact add_le_add htri₂ (le_refl _)
    _ ≤ |r| ^ 2 + |1 - r| ^ 2 * u +
          (|1 - r ^ 2| + |1 - r| ^ 2 * u) * (2 * u + u ^ 2) := by
          rw [abs_pow]
          linarith

/-- Radius form of the conservative rounded reciprocal Newton residual bound.
If the incoming residual is bounded by `rho`, the exact bound can be written
using only `rho` and `u`. -/
theorem reciprocalNewtonRoundedResidualAbsBound_le_radius
    {r rho u : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hu : 0 ≤ u)
    (hr : |r| ≤ rho) :
    reciprocalNewtonRoundedResidualAbsBound r u ≤
      rho ^ 2 + (1 + rho) ^ 2 * u +
        (1 + rho ^ 2 + (1 + rho) ^ 2 * u) * (2 * u + u ^ 2) := by
  have hone_rho_nonneg : 0 ≤ 1 + rho := by linarith
  have hr_abs_le :
      |(|r| : ℝ)| ≤ |rho| := by
    simpa [abs_of_nonneg hrho_nonneg] using hr
  have hr_sq : |r| ^ 2 ≤ rho ^ 2 := (sq_le_sq).mpr hr_abs_le
  have h_one_sub :
      |1 - r| ≤ 1 + rho := by
    calc
      |1 - r| = |(1 : ℝ) + -r| := by
        simp [sub_eq_add_neg]
      _ ≤ |(1 : ℝ)| + |-r| := abs_add_le (1 : ℝ) (-r)
      _ = 1 + |r| := by simp
      _ ≤ 1 + rho := add_le_add_right hr 1
  have h_one_sub_abs_le :
      |(|1 - r| : ℝ)| ≤ |1 + rho| := by
    simpa [abs_of_nonneg hone_rho_nonneg] using h_one_sub
  have h_one_sub_sq :
      |1 - r| ^ 2 ≤ (1 + rho) ^ 2 :=
    (sq_le_sq).mpr h_one_sub_abs_le
  have hr2_abs :
      |r ^ 2| ≤ rho ^ 2 := by
    rw [abs_pow]
    exact hr_sq
  have h_one_sub_sq_term :
      |1 - r| ^ 2 * u ≤ (1 + rho) ^ 2 * u :=
    mul_le_mul_of_nonneg_right h_one_sub_sq hu
  have h_one_sub_rsq :
      |1 - r ^ 2| ≤ 1 + rho ^ 2 := by
    calc
      |1 - r ^ 2| = |(1 : ℝ) + -(r ^ 2)| := by
        simp [sub_eq_add_neg]
      _ ≤ |(1 : ℝ)| + |-(r ^ 2)| := abs_add_le (1 : ℝ) (-(r ^ 2))
      _ = 1 + |r ^ 2| := by simp
      _ ≤ 1 + rho ^ 2 := add_le_add_right hr2_abs 1
  have hfactor :
      |1 - r ^ 2| + |1 - r| ^ 2 * u ≤
        1 + rho ^ 2 + (1 + rho) ^ 2 * u := by
    linarith [h_one_sub_rsq, h_one_sub_sq_term]
  have hround_nonneg :
      0 ≤ 2 * u + u ^ 2 := by
    nlinarith [hu, sq_nonneg u]
  have hprod :
      (|1 - r ^ 2| + |1 - r| ^ 2 * u) * (2 * u + u ^ 2) ≤
        (1 + rho ^ 2 + (1 + rho) ^ 2 * u) * (2 * u + u ^ 2) :=
    mul_le_mul_of_nonneg_right hfactor hround_nonneg
  rw [reciprocalNewtonRoundedResidualAbsBound]
  linarith [hr_sq, h_one_sub_sq_term, hprod]

/-- Readable small-residual corollary for one rounded reciprocal Newton step:
for `|r| <= rho <= 1` and `0 <= u <= 1`, the conservative residual radius is
at most the exact Newton square plus a linear roundoff term. -/
theorem reciprocalNewtonRoundedResidualAbsBound_le_small_radius
    {r rho u : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_one : rho ≤ 1)
    (hu : 0 ≤ u)
    (hu_le_one : u ≤ 1)
    (hr : |r| ≤ rho) :
    reciprocalNewtonRoundedResidualAbsBound r u ≤ rho ^ 2 + 22 * u := by
  have hbase :=
    reciprocalNewtonRoundedResidualAbsBound_le_radius
      (r := r) (rho := rho) (u := u) hrho_nonneg hu hr
  have hrho_sq_le_one : rho ^ 2 ≤ 1 := by
    have hmul : rho * rho ≤ 1 * 1 :=
      mul_le_mul hrho_le_one hrho_le_one hrho_nonneg
        (by norm_num : (0 : ℝ) ≤ 1)
    nlinarith
  have hone_rho_sq_le_four : (1 + rho) ^ 2 ≤ 4 := by
    nlinarith [hrho_sq_le_one, hrho_nonneg, hrho_le_one]
  have hone_rho_sq_u_le_four_u :
      (1 + rho) ^ 2 * u ≤ 4 * u :=
    mul_le_mul_of_nonneg_right hone_rho_sq_le_four hu
  have hone_rho_sq_u_le_four :
      (1 + rho) ^ 2 * u ≤ 4 := by
    have hfour_u : 4 * u ≤ 4 := by nlinarith
    linarith
  have hfactor_le_six :
      1 + rho ^ 2 + (1 + rho) ^ 2 * u ≤ 6 := by
    linarith [hrho_sq_le_one, hone_rho_sq_u_le_four]
  have hu_sq_le_u : u ^ 2 ≤ u := by
    have hmul : u * u ≤ 1 * u :=
      mul_le_mul hu_le_one (le_refl u) hu
        (by norm_num : (0 : ℝ) ≤ 1)
    nlinarith
  have hround_le_three_u :
      2 * u + u ^ 2 ≤ 3 * u := by
    linarith [hu_sq_le_u]
  have hround_nonneg :
      0 ≤ 2 * u + u ^ 2 := by
    nlinarith [hu, sq_nonneg u]
  have hprod_le :
      (1 + rho ^ 2 + (1 + rho) ^ 2 * u) * (2 * u + u ^ 2) ≤
        18 * u := by
    have hmul :=
      mul_le_mul hfactor_le_six hround_le_three_u hround_nonneg
        (by norm_num : (0 : ℝ) ≤ 6)
    nlinarith
  linarith [hbase, hone_rho_sq_u_le_four_u, hprod_le]

/-- A convergence-style one-step residual bound for the rounded residual
recurrence with local standard-model errors. -/
theorem reciprocalNewtonRoundedResidualErrorEval_abs_le_small_radius
    {r δax δsub δmul rho u : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_one : rho ≤ 1)
    (hu : 0 ≤ u)
    (hu_le_one : u ≤ 1)
    (hr : |r| ≤ rho)
    (hδax : |δax| ≤ u)
    (hδsub : |δsub| ≤ u)
    (hδmul : |δmul| ≤ u) :
    |reciprocalNewtonRoundedResidualErrorEval r δax δsub δmul| ≤
      rho ^ 2 + 22 * u := by
  exact le_trans
    (reciprocalNewtonRoundedResidualErrorEval_abs_le hu hδax hδsub hδmul)
    (reciprocalNewtonRoundedResidualAbsBound_le_small_radius
      hrho_nonneg hrho_le_one hu hu_le_one hr)

/-- Small-ball preservation for one rounded reciprocal Newton residual step:
if `rho <= 1/2` and the roundoff term is small enough that `44*u <= rho`,
then the rounded residual remains in the same `rho`-ball. -/
theorem reciprocalNewtonRoundedResidualErrorEval_abs_le_self_radius
    {r δax δsub δmul rho u : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu : 0 ≤ u)
    (hu_small : 44 * u ≤ rho)
    (hr : |r| ≤ rho)
    (hδax : |δax| ≤ u)
    (hδsub : |δsub| ≤ u)
    (hδmul : |δmul| ≤ u) :
    |reciprocalNewtonRoundedResidualErrorEval r δax δsub δmul| ≤ rho := by
  have hrho_le_one : rho ≤ 1 := by linarith
  have hu_le_one : u ≤ 1 := by nlinarith
  have hsmall :=
    reciprocalNewtonRoundedResidualErrorEval_abs_le_small_radius
      hrho_nonneg hrho_le_one hu hu_le_one hr hδax hδsub hδmul
  have hsquare : rho ^ 2 ≤ rho / 2 := by nlinarith [sq_nonneg rho]
  have hround : 22 * u ≤ rho / 2 := by nlinarith
  exact le_trans hsmall (by nlinarith)

/-- Iteration of the rounded residual recurrence with an arbitrary sequence of
local standard-model errors.  The initial state is the incoming residual. -/
def reciprocalNewtonRoundedResidualErrorEvalIter
    (r : ℝ) (δax δsub δmul : ℕ → ℝ) : ℕ → ℝ
  | 0 => r
  | n + 1 =>
      reciprocalNewtonRoundedResidualErrorEval
        (reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n)
        (δax n) (δsub n) (δmul n)

/-- Scalar envelope for the rounded residual recurrence.  It tracks the
source-shaped `rho^2 + 22*u` one-step bound. -/
def reciprocalNewtonRoundedResidualEnvelope (rho u : ℝ) : ℕ → ℝ
  | 0 => rho
  | n + 1 => (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 + 22 * u

/-- The scalar rounded-residual envelope is nonnegative when its initial
radius and roundoff parameter are nonnegative. -/
theorem reciprocalNewtonRoundedResidualEnvelope_nonneg
    {rho u : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hu : 0 ≤ u)
    (n : ℕ) :
    0 ≤ reciprocalNewtonRoundedResidualEnvelope rho u n := by
  induction n with
  | zero =>
      simpa [reciprocalNewtonRoundedResidualEnvelope] using hrho_nonneg
  | succ n ih =>
      change
        0 ≤ (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 + 22 * u
      nlinarith [sq_nonneg (reciprocalNewtonRoundedResidualEnvelope rho u n)]

/-- If the roundoff floor `44*u` is below the radius `rho <= 1/2`, then the
scalar envelope remains inside the same `rho`-ball for every finite iterate. -/
theorem reciprocalNewtonRoundedResidualEnvelope_le_self_radius
    {rho u : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu : 0 ≤ u)
    (hu_small : 44 * u ≤ rho)
    (n : ℕ) :
    reciprocalNewtonRoundedResidualEnvelope rho u n ≤ rho := by
  induction n with
  | zero =>
      simp [reciprocalNewtonRoundedResidualEnvelope]
  | succ n ih =>
      change
        (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 + 22 * u ≤ rho
      have henv_nonneg :
          0 ≤ reciprocalNewtonRoundedResidualEnvelope rho u n :=
        reciprocalNewtonRoundedResidualEnvelope_nonneg hrho_nonneg hu n
      have hsquare :
          (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 ≤ rho / 2 := by
        nlinarith [henv_nonneg, ih, hrho_le_half]
      have hround : 22 * u ≤ rho / 2 := by
        nlinarith
      nlinarith

/-- Explicit roundoff-floor corollary for the scalar envelope: if the initial
radius is `44*u` and `u <= 1/88`, then all envelope iterates stay below
`44*u`. -/
theorem reciprocalNewtonRoundedResidualEnvelope_le_roundoff_floor
    {u : ℝ}
    (hu : 0 ≤ u)
    (hu_le : u ≤ 1 / 88)
    (n : ℕ) :
    reciprocalNewtonRoundedResidualEnvelope (44 * u) u n ≤ 44 * u := by
  exact reciprocalNewtonRoundedResidualEnvelope_le_self_radius
    (rho := 44 * u) (u := u)
    (by nlinarith) (by nlinarith) hu (by linarith) n

/-- Closed-form geometric-plus-floor bound for the scalar envelope.  Under the
same small-radius condition used for the invariant, the envelope is bounded by
the initial radius damped by `2^n` plus the roundoff floor `44*u`. -/
theorem reciprocalNewtonRoundedResidualEnvelope_le_geometric_floor
    {rho u : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu : 0 ≤ u)
    (hu_small : 44 * u ≤ rho)
    (n : ℕ) :
    reciprocalNewtonRoundedResidualEnvelope rho u n ≤
      rho / (2 : ℝ) ^ n + 44 * u := by
  induction n with
  | zero =>
      simp [reciprocalNewtonRoundedResidualEnvelope]
      nlinarith
  | succ n ih =>
      change
        (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 + 22 * u ≤
          rho / (2 : ℝ) ^ (n + 1) + 44 * u
      have henv_nonneg :
          0 ≤ reciprocalNewtonRoundedResidualEnvelope rho u n :=
        reciprocalNewtonRoundedResidualEnvelope_nonneg hrho_nonneg hu n
      have henv_le_half :
          reciprocalNewtonRoundedResidualEnvelope rho u n ≤ 1 / 2 := by
        exact le_trans
          (reciprocalNewtonRoundedResidualEnvelope_le_self_radius
            hrho_nonneg hrho_le_half hu hu_small n)
          hrho_le_half
      have hsquare :
          (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 ≤
            reciprocalNewtonRoundedResidualEnvelope rho u n / 2 := by
        nlinarith [henv_nonneg, henv_le_half]
      have hstep :
          (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 + 22 * u ≤
            (rho / (2 : ℝ) ^ n + 44 * u) / 2 + 22 * u := by
        nlinarith [hsquare, ih]
      have hpow_ne : (2 : ℝ) ^ n ≠ 0 := pow_ne_zero n (by norm_num)
      have halg :
          (rho / (2 : ℝ) ^ n + 44 * u) / 2 + 22 * u =
            rho / (2 : ℝ) ^ (n + 1) + 44 * u := by
        rw [pow_succ]
        field_simp [hpow_ne]
        ring
      exact le_trans hstep (by rw [halg])

/-- Every finite rounded-residual iterate is dominated by the scalar envelope,
provided the envelope remains in the small-radius regime where the one-step
bound applies. -/
theorem reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_envelope
    {r rho u : ℝ} {δax δsub δmul : ℕ → ℝ}
    (hu : 0 ≤ u)
    (hu_le_one : u ≤ 1)
    (hr : |r| ≤ rho)
    (henv_nonneg : ∀ n, 0 ≤ reciprocalNewtonRoundedResidualEnvelope rho u n)
    (henv_le_one : ∀ n, reciprocalNewtonRoundedResidualEnvelope rho u n ≤ 1)
    (hδax : ∀ n, |δax n| ≤ u)
    (hδsub : ∀ n, |δsub n| ≤ u)
    (hδmul : ∀ n, |δmul n| ≤ u)
    (n : ℕ) :
    |reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n| ≤
      reciprocalNewtonRoundedResidualEnvelope rho u n := by
  induction n with
  | zero =>
      simpa [reciprocalNewtonRoundedResidualErrorEvalIter,
        reciprocalNewtonRoundedResidualEnvelope] using hr
  | succ n ih =>
      change
        |reciprocalNewtonRoundedResidualErrorEval
          (reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n)
          (δax n) (δsub n) (δmul n)| ≤
          (reciprocalNewtonRoundedResidualEnvelope rho u n) ^ 2 + 22 * u
      exact reciprocalNewtonRoundedResidualErrorEval_abs_le_small_radius
        (henv_nonneg n) (henv_le_one n) hu hu_le_one ih
        (hδax n) (hδsub n) (hδmul n)

/-- Envelope domination with the small-radius side conditions discharged by
the proved envelope invariant `E_n <= rho`. -/
theorem reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_envelope_of_self_radius
    {r rho u : ℝ} {δax δsub δmul : ℕ → ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu : 0 ≤ u)
    (hu_small : 44 * u ≤ rho)
    (hr : |r| ≤ rho)
    (hδax : ∀ n, |δax n| ≤ u)
    (hδsub : ∀ n, |δsub n| ≤ u)
    (hδmul : ∀ n, |δmul n| ≤ u)
    (n : ℕ) :
    |reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n| ≤
      reciprocalNewtonRoundedResidualEnvelope rho u n := by
  have hu_le_one : u ≤ 1 := by nlinarith
  exact reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_envelope
    hu hu_le_one hr
    (reciprocalNewtonRoundedResidualEnvelope_nonneg hrho_nonneg hu)
    (fun k =>
      le_trans
        (reciprocalNewtonRoundedResidualEnvelope_le_self_radius
          hrho_nonneg hrho_le_half hu hu_small k)
        (by linarith))
    hδax hδsub hδmul n

/-- Finite-iterate small-ball invariant for the rounded reciprocal Newton
residual recurrence under uniformly bounded local errors. -/
theorem reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_self_radius
    {r rho u : ℝ} {δax δsub δmul : ℕ → ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu : 0 ≤ u)
    (hu_small : 44 * u ≤ rho)
    (hr : |r| ≤ rho)
    (hδax : ∀ n, |δax n| ≤ u)
    (hδsub : ∀ n, |δsub n| ≤ u)
    (hδmul : ∀ n, |δmul n| ≤ u)
    (n : ℕ) :
    |reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n| ≤
      rho := by
  induction n with
  | zero =>
      simpa [reciprocalNewtonRoundedResidualErrorEvalIter] using hr
  | succ n ih =>
      change
        |reciprocalNewtonRoundedResidualErrorEval
          (reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n)
          (δax n) (δsub n) (δmul n)| ≤ rho
      exact reciprocalNewtonRoundedResidualErrorEval_abs_le_self_radius
        hrho_nonneg hrho_le_half hu hu_small ih
        (hδax n) (hδsub n) (hδmul n)

/-- Explicit roundoff-floor corollary for finite rounded-residual iterates:
starting inside `44*u`, every finite iterate stays inside `44*u` when
`u <= 1/88`. -/
theorem reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_roundoff_floor
    {r u : ℝ} {δax δsub δmul : ℕ → ℝ}
    (hu : 0 ≤ u)
    (hu_le : u ≤ 1 / 88)
    (hr : |r| ≤ 44 * u)
    (hδax : ∀ n, |δax n| ≤ u)
    (hδsub : ∀ n, |δsub n| ≤ u)
    (hδmul : ∀ n, |δmul n| ≤ u)
    (n : ℕ) :
    |reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n| ≤
      44 * u := by
  exact reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_self_radius
    (rho := 44 * u) (u := u)
    (by nlinarith) (by nlinarith) hu (by linarith) hr
    hδax hδsub hδmul n

/-- Closed-form geometric-plus-floor bound for finite rounded-residual iterates.
The exact residual contribution decays like `2^-n` until the explicit roundoff
floor `44*u` dominates. -/
theorem reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_geometric_floor
    {r rho u : ℝ} {δax δsub δmul : ℕ → ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu : 0 ≤ u)
    (hu_small : 44 * u ≤ rho)
    (hr : |r| ≤ rho)
    (hδax : ∀ n, |δax n| ≤ u)
    (hδsub : ∀ n, |δsub n| ≤ u)
    (hδmul : ∀ n, |δmul n| ≤ u)
    (n : ℕ) :
    |reciprocalNewtonRoundedResidualErrorEvalIter r δax δsub δmul n| ≤
      rho / (2 : ℝ) ^ n + 44 * u := by
  exact le_trans
    (reciprocalNewtonRoundedResidualErrorEvalIter_abs_le_envelope_of_self_radius
      hrho_nonneg hrho_le_half hu hu_small hr hδax hδsub hδmul n)
    (reciprocalNewtonRoundedResidualEnvelope_le_geometric_floor
      hrho_nonneg hrho_le_half hu hu_small n)

/-- One rounded reciprocal Newton step has exactly the displayed three
standard-model local error factors: the product `a*x`, the subtraction
`2 - fl(a*x)`, and the final product by `x`. -/
theorem reciprocalNewtonRoundedStep_eq_errorEval
    (fp : FPModel) (a x : ℝ) :
    ∃ δax δsub δmul : ℝ,
      |δax| ≤ fp.u ∧ |δsub| ≤ fp.u ∧ |δmul| ≤ fp.u ∧
        reciprocalNewtonRoundedStep fp a x =
          reciprocalNewtonRoundedStepErrorEval a x δax δsub δmul := by
  rcases fp.model_mul a x with ⟨δax, hδax, hax⟩
  rcases fp.model_sub 2 (fp.fl_mul a x) with ⟨δsub, hδsub, hsub⟩
  rcases fp.model_mul x (fp.fl_sub 2 (fp.fl_mul a x)) with
    ⟨δmul, hδmul, hmul⟩
  refine ⟨δax, δsub, δmul, hδax, hδsub, hδmul, ?_⟩
  unfold reciprocalNewtonRoundedStep reciprocalNewtonRoundedStepErrorEval
  rw [hmul, hsub, hax]

/-- Residual form of the rounded reciprocal Newton trace with all local errors
visible.  This is the finite-precision analogue of
`reciprocalNewtonStep_residual_sq`; it deliberately does not hide the
subtraction-input perturbation caused by the rounded `a*x`. -/
theorem reciprocalNewtonRoundedResidual_eq_errorEval
    (fp : FPModel) (a x : ℝ) :
    ∃ δax δsub δmul : ℝ,
      |δax| ≤ fp.u ∧ |δsub| ≤ fp.u ∧ |δmul| ≤ fp.u ∧
        reciprocalNewtonRoundedResidual fp a x =
          1 - a * reciprocalNewtonRoundedStepErrorEval a x δax δsub δmul := by
  rcases reciprocalNewtonRoundedStep_eq_errorEval fp a x with
    ⟨δax, δsub, δmul, hδax, hδsub, hδmul, hstep⟩
  refine ⟨δax, δsub, δmul, hδax, hδsub, hδmul, ?_⟩
  unfold reciprocalNewtonRoundedResidual
  rw [hstep]

/-- Range-free residual recurrence for one rounded reciprocal Newton step in
the standard model.  The theorem exposes exactly the incoming exact residual
`1-a*x` and the three local errors, with no hidden computed quantities. -/
theorem reciprocalNewtonRoundedResidual_eq_residualErrorEval
    (fp : FPModel) (a x : ℝ) :
    ∃ δax δsub δmul : ℝ,
      |δax| ≤ fp.u ∧ |δsub| ≤ fp.u ∧ |δmul| ≤ fp.u ∧
        reciprocalNewtonRoundedResidual fp a x =
          reciprocalNewtonRoundedResidualErrorEval
            (1 - a * x) δax δsub δmul := by
  rcases reciprocalNewtonRoundedResidual_eq_errorEval fp a x with
    ⟨δax, δsub, δmul, hδax, hδsub, hδmul, hres⟩
  refine ⟨δax, δsub, δmul, hδax, hδsub, hδmul, ?_⟩
  rw [hres, reciprocalNewtonRoundedStepErrorEval_residual_eq]

/-- Source-shaped standard-model residual corollary for a concrete rounded
reciprocal Newton trace.  When the incoming residual has radius `rho <= 1` and
the model unit roundoff satisfies `fp.u <= 1`, one step has residual at most
`rho^2 + 22*fp.u`. -/
theorem reciprocalNewtonRoundedResidual_abs_le_small_radius
    (fp : FPModel) {a x rho : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_one : rho ≤ 1)
    (hu_le_one : fp.u ≤ 1)
    (hr : |1 - a * x| ≤ rho) :
    |reciprocalNewtonRoundedResidual fp a x| ≤ rho ^ 2 + 22 * fp.u := by
  rcases reciprocalNewtonRoundedResidual_eq_residualErrorEval fp a x with
    ⟨δax, δsub, δmul, hδax, hδsub, hδmul, hres⟩
  rw [hres]
  exact reciprocalNewtonRoundedResidualErrorEval_abs_le_small_radius
    hrho_nonneg hrho_le_one fp.u_nonneg hu_le_one hr hδax hδsub hδmul

/-- Concrete rounded-trace small-ball preservation for one reciprocal Newton
step. -/
theorem reciprocalNewtonRoundedResidual_abs_le_self_radius
    (fp : FPModel) {a x rho : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu_small : 44 * fp.u ≤ rho)
    (hr : |1 - a * x| ≤ rho) :
    |reciprocalNewtonRoundedResidual fp a x| ≤ rho := by
  rcases reciprocalNewtonRoundedResidual_eq_residualErrorEval fp a x with
    ⟨δax, δsub, δmul, hδax, hδsub, hδmul, hres⟩
  rw [hres]
  exact reciprocalNewtonRoundedResidualErrorEval_abs_le_self_radius
    hrho_nonneg hrho_le_half fp.u_nonneg hu_small hr hδax hδsub hδmul

/-- The residuals of the concrete stored rounded reciprocal Newton iterates are
bounded by the same scalar envelope as the abstract standard-model residual
recurrence. -/
theorem reciprocalNewtonRoundedStepIter_residual_abs_le_envelope_of_self_radius
    (fp : FPModel) {a x rho : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu_small : 44 * fp.u ≤ rho)
    (hr : |1 - a * x| ≤ rho)
    (n : ℕ) :
    |1 - a * reciprocalNewtonRoundedStepIter fp a x n| ≤
      reciprocalNewtonRoundedResidualEnvelope rho fp.u n := by
  induction n with
  | zero =>
      simpa [reciprocalNewtonRoundedStepIter,
        reciprocalNewtonRoundedResidualEnvelope] using hr
  | succ n ih =>
      change
        |1 - a * reciprocalNewtonRoundedStep fp a
          (reciprocalNewtonRoundedStepIter fp a x n)| ≤
          (reciprocalNewtonRoundedResidualEnvelope rho fp.u n) ^ 2 +
            22 * fp.u
      have henv_nonneg :
          0 ≤ reciprocalNewtonRoundedResidualEnvelope rho fp.u n :=
        reciprocalNewtonRoundedResidualEnvelope_nonneg
          hrho_nonneg fp.u_nonneg n
      have henv_le_self :
          reciprocalNewtonRoundedResidualEnvelope rho fp.u n ≤ rho :=
        reciprocalNewtonRoundedResidualEnvelope_le_self_radius
          hrho_nonneg hrho_le_half fp.u_nonneg hu_small n
      have henv_le_one :
          reciprocalNewtonRoundedResidualEnvelope rho fp.u n ≤ 1 := by
        linarith
      have hu_le_one : fp.u ≤ 1 := by
        nlinarith
      simpa [reciprocalNewtonRoundedResidual] using
        (reciprocalNewtonRoundedResidual_abs_le_small_radius
          fp henv_nonneg henv_le_one hu_le_one ih)

/-- Closed-form geometric-plus-floor bound for the concrete stored rounded
reciprocal Newton iterates. -/
theorem reciprocalNewtonRoundedStepIter_residual_abs_le_geometric_floor
    (fp : FPModel) {a x rho : ℝ}
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu_small : 44 * fp.u ≤ rho)
    (hr : |1 - a * x| ≤ rho)
    (n : ℕ) :
    |1 - a * reciprocalNewtonRoundedStepIter fp a x n| ≤
      rho / (2 : ℝ) ^ n + 44 * fp.u := by
  exact le_trans
    (reciprocalNewtonRoundedStepIter_residual_abs_le_envelope_of_self_radius
      fp hrho_nonneg hrho_le_half hu_small hr n)
    (reciprocalNewtonRoundedResidualEnvelope_le_geometric_floor
      hrho_nonneg hrho_le_half fp.u_nonneg hu_small n)

/-- Explicit roundoff-floor corollary for the concrete stored rounded reciprocal
Newton iterates. -/
theorem reciprocalNewtonRoundedStepIter_residual_abs_le_roundoff_floor
    (fp : FPModel) {a x : ℝ}
    (hu_le : fp.u ≤ 1 / 88)
    (hr : |1 - a * x| ≤ 44 * fp.u)
    (n : ℕ) :
    |1 - a * reciprocalNewtonRoundedStepIter fp a x n| ≤
      44 * fp.u := by
  exact le_trans
    (reciprocalNewtonRoundedStepIter_residual_abs_le_envelope_of_self_radius
      fp (rho := 44 * fp.u)
      (by nlinarith [fp.u_nonneg]) (by nlinarith) (by linarith) hr n)
    (reciprocalNewtonRoundedResidualEnvelope_le_roundoff_floor
      fp.u_nonneg hu_le n)

/-- Division-error version of the concrete rounded reciprocal Newton trace:
using the stored rounded reciprocal estimate for `1 / denom`, multiplication
by `num` has absolute error controlled by the reciprocal residual radius. -/
theorem reciprocalNewtonRoundedStepIter_division_error_abs_le_geometric_floor
    (fp : FPModel) {num denom x rho : ℝ}
    (hden : denom ≠ 0)
    (hrho_nonneg : 0 ≤ rho)
    (hrho_le_half : rho ≤ 1 / 2)
    (hu_small : 44 * fp.u ≤ rho)
    (hr : |1 - denom * x| ≤ rho)
    (n : ℕ) :
    |num / denom - num * reciprocalNewtonRoundedStepIter fp denom x n| ≤
      |num / denom| * (rho / (2 : ℝ) ^ n + 44 * fp.u) := by
  rw [divisionViaReciprocal_error_eq_residual hden, abs_mul]
  exact mul_le_mul_of_nonneg_left
    (reciprocalNewtonRoundedStepIter_residual_abs_le_geometric_floor
      fp hrho_nonneg hrho_le_half hu_small hr n)
    (abs_nonneg (num / denom))

/-- Roundoff-floor division-error corollary for the concrete stored rounded
reciprocal Newton trace. -/
theorem reciprocalNewtonRoundedStepIter_division_error_abs_le_roundoff_floor
    (fp : FPModel) {num denom x : ℝ}
    (hden : denom ≠ 0)
    (hu_le : fp.u ≤ 1 / 88)
    (hr : |1 - denom * x| ≤ 44 * fp.u)
    (n : ℕ) :
    |num / denom - num * reciprocalNewtonRoundedStepIter fp denom x n| ≤
      |num / denom| * (44 * fp.u) := by
  rw [divisionViaReciprocal_error_eq_residual hden, abs_mul]
  exact mul_le_mul_of_nonneg_left
    (reciprocalNewtonRoundedStepIter_residual_abs_le_roundoff_floor
      fp hu_le hr n)
    (abs_nonneg (num / denom))

namespace FloatingPointFormat

/-- Concrete finite round-to-even trace for one reciprocal Newton step. -/
def reciprocalNewtonFiniteStep
    (fmt : FloatingPointFormat) (a x : ℝ) : ℝ :=
  let ax := fmt.finiteRoundToEvenOp BasicOp.mul a x
  let correction := fmt.finiteRoundToEvenOp BasicOp.sub 2 ax
  fmt.finiteRoundToEvenOp BasicOp.mul x correction

/-- Stored finite round-to-even reciprocal Newton iterates. -/
def reciprocalNewtonFiniteStepIter
    (fmt : FloatingPointFormat) (a x : ℝ) : ℕ → ℝ
  | 0 => x
  | n + 1 => fmt.reciprocalNewtonFiniteStep a
      (reciprocalNewtonFiniteStepIter fmt a x n)

/-- If all exact intermediates of one reciprocal Newton step are finite
representable, the concrete finite round-to-even trace agrees with the exact
Newton step. -/
theorem reciprocalNewtonFiniteStep_eq_step_of_finiteSystem
    {fmt : FloatingPointFormat} {a x : ℝ}
    (hax : fmt.finiteSystem (a * x))
    (hsub : fmt.finiteSystem (2 - a * x))
    (hstep : fmt.finiteSystem (x * (2 - a * x))) :
    fmt.reciprocalNewtonFiniteStep a x = reciprocalNewtonStep a x := by
  have hax_round :
      fmt.finiteRoundToEvenOp BasicOp.mul a x = a * x := by
    simpa [finiteRoundToEvenOp, BasicOp.exact] using
      (fmt.finiteRoundToEvenOp_eq_exact_of_finiteSystem
        (op := BasicOp.mul) (x := a) (y := x)
        (by simpa [BasicOp.exact] using hax))
  have hsub_round :
      fmt.finiteRoundToEvenOp BasicOp.sub 2 (a * x) = 2 - a * x := by
    simpa [finiteRoundToEvenOp, BasicOp.exact] using
      (fmt.finiteRoundToEvenOp_eq_exact_of_finiteSystem
        (op := BasicOp.sub) (x := (2 : ℝ)) (y := a * x)
        (by simpa [BasicOp.exact] using hsub))
  have hstep_round :
      fmt.finiteRoundToEvenOp BasicOp.mul x (2 - a * x) =
        x * (2 - a * x) := by
    simpa [finiteRoundToEvenOp, BasicOp.exact] using
      (fmt.finiteRoundToEvenOp_eq_exact_of_finiteSystem
        (op := BasicOp.mul) (x := x) (y := 2 - a * x)
        (by simpa [BasicOp.exact] using hstep))
  simp [reciprocalNewtonFiniteStep, reciprocalNewtonStep, hax_round,
    hsub_round, hstep_round]

/-- Under the same exact-intermediate side conditions, the finite trace inherits
the exact squared residual identity. -/
theorem reciprocalNewtonFiniteStep_residual_sq_of_finiteSystem
    {fmt : FloatingPointFormat} {a x : ℝ}
    (hax : fmt.finiteSystem (a * x))
    (hsub : fmt.finiteSystem (2 - a * x))
    (hstep : fmt.finiteSystem (x * (2 - a * x))) :
    1 - a * fmt.reciprocalNewtonFiniteStep a x = (1 - a * x) ^ 2 := by
  rw [fmt.reciprocalNewtonFiniteStep_eq_step_of_finiteSystem hax hsub hstep]
  exact reciprocalNewtonStep_residual_sq a x

/-- Under exact-intermediate side conditions, the finite trace also inherits
the exact reciprocal-error square identity. -/
theorem reciprocalNewtonFiniteStep_error_sq_of_finiteSystem
    {fmt : FloatingPointFormat} {a x : ℝ}
    (ha : a ≠ 0)
    (hax : fmt.finiteSystem (a * x))
    (hsub : fmt.finiteSystem (2 - a * x))
    (hstep : fmt.finiteSystem (x * (2 - a * x))) :
    (1 / a) - fmt.reciprocalNewtonFiniteStep a x =
      (1 / a) * (1 - a * x) ^ 2 := by
  rw [fmt.reciprocalNewtonFiniteStep_eq_step_of_finiteSystem hax hsub hstep]
  exact reciprocalNewtonStep_error_sq ha

/-- Stored finite round-to-even iterates inherit the one-step squared residual
identity whenever the exact intermediates at that stored step are finite
representable. -/
theorem reciprocalNewtonFiniteStepIter_residual_sq_of_finiteSystem
    {fmt : FloatingPointFormat} {a x : ℝ}
    (hax : ∀ n, fmt.finiteSystem
      (a * fmt.reciprocalNewtonFiniteStepIter a x n))
    (hsub : ∀ n, fmt.finiteSystem
      (2 - a * fmt.reciprocalNewtonFiniteStepIter a x n))
    (hstep : ∀ n, fmt.finiteSystem
      (fmt.reciprocalNewtonFiniteStepIter a x n *
        (2 - a * fmt.reciprocalNewtonFiniteStepIter a x n)))
    (n : ℕ) :
    1 - a * fmt.reciprocalNewtonFiniteStepIter a x (n + 1) =
      (1 - a * fmt.reciprocalNewtonFiniteStepIter a x n) ^ 2 := by
  change 1 - a * fmt.reciprocalNewtonFiniteStep a
      (fmt.reciprocalNewtonFiniteStepIter a x n) =
    (1 - a * fmt.reciprocalNewtonFiniteStepIter a x n) ^ 2
  exact fmt.reciprocalNewtonFiniteStep_residual_sq_of_finiteSystem
    (hax n) (hsub n) (hstep n)

/-- Stored finite round-to-even iterates match the exact doubled-exponent
residual law under per-step exact-intermediate finiteness hypotheses. -/
theorem reciprocalNewtonFiniteStepIter_residual_pow_two_of_finiteSystem
    {fmt : FloatingPointFormat} {a x : ℝ}
    (hax : ∀ n, fmt.finiteSystem
      (a * fmt.reciprocalNewtonFiniteStepIter a x n))
    (hsub : ∀ n, fmt.finiteSystem
      (2 - a * fmt.reciprocalNewtonFiniteStepIter a x n))
    (hstep : ∀ n, fmt.finiteSystem
      (fmt.reciprocalNewtonFiniteStepIter a x n *
        (2 - a * fmt.reciprocalNewtonFiniteStepIter a x n)))
    (n : ℕ) :
    1 - a * fmt.reciprocalNewtonFiniteStepIter a x n =
      (1 - a * x) ^ (2 ^ n) := by
  induction n with
  | zero =>
      simp [reciprocalNewtonFiniteStepIter]
  | succ n ih =>
      rw [fmt.reciprocalNewtonFiniteStepIter_residual_sq_of_finiteSystem
        hax hsub hstep n, ih]
      rw [pow_succ]
      exact (pow_mul (1 - a * x) (2 ^ n) 2).symm

/-- Stored finite round-to-even iterates also satisfy the exact reciprocal-error
power law when `a` is nonzero and every step's exact intermediates are finite
representable. -/
theorem reciprocalNewtonFiniteStepIter_error_pow_two_of_finiteSystem
    {fmt : FloatingPointFormat} {a x : ℝ}
    (ha : a ≠ 0)
    (hax : ∀ n, fmt.finiteSystem
      (a * fmt.reciprocalNewtonFiniteStepIter a x n))
    (hsub : ∀ n, fmt.finiteSystem
      (2 - a * fmt.reciprocalNewtonFiniteStepIter a x n))
    (hstep : ∀ n, fmt.finiteSystem
      (fmt.reciprocalNewtonFiniteStepIter a x n *
        (2 - a * fmt.reciprocalNewtonFiniteStepIter a x n)))
    (n : ℕ) :
    (1 / a) - fmt.reciprocalNewtonFiniteStepIter a x n =
      (1 / a) * (1 - a * x) ^ (2 ^ n) := by
  have hres :
      1 - a * fmt.reciprocalNewtonFiniteStepIter a x n =
        (1 - a * x) ^ (2 ^ n) :=
    fmt.reciprocalNewtonFiniteStepIter_residual_pow_two_of_finiteSystem
      hax hsub hstep n
  calc
    (1 / a) - fmt.reciprocalNewtonFiniteStepIter a x n =
        (1 / a) *
          (1 - a * fmt.reciprocalNewtonFiniteStepIter a x n) := by
      field_simp [ha]
    _ = (1 / a) * (1 - a * x) ^ (2 ^ n) := by
      rw [hres]

/-- Finite exact-intermediate reciprocal Newton iterates give the same
doubled-exponent division-error law when division is implemented as numerator
times the stored reciprocal estimate. -/
theorem reciprocalNewtonFiniteStepIter_division_error_pow_two_of_finiteSystem
    {fmt : FloatingPointFormat} {num denom x : ℝ}
    (hden : denom ≠ 0)
    (hax : ∀ n, fmt.finiteSystem
      (denom * fmt.reciprocalNewtonFiniteStepIter denom x n))
    (hsub : ∀ n, fmt.finiteSystem
      (2 - denom * fmt.reciprocalNewtonFiniteStepIter denom x n))
    (hstep : ∀ n, fmt.finiteSystem
      (fmt.reciprocalNewtonFiniteStepIter denom x n *
        (2 - denom * fmt.reciprocalNewtonFiniteStepIter denom x n)))
    (n : ℕ) :
    num / denom - num * fmt.reciprocalNewtonFiniteStepIter denom x n =
      (num / denom) * (1 - denom * x) ^ (2 ^ n) := by
  rw [divisionViaReciprocal_error_eq_residual hden,
    fmt.reciprocalNewtonFiniteStepIter_residual_pow_two_of_finiteSystem
      hax hsub hstep n]

end FloatingPointFormat

end

end NumStability
