-- ============================================================

/-- Higham Theorem 7.1, arbitrary subordinate-norm necessary direction over
    complex matrices. -/
theorem theorem7_1_subordinate_necessary
    {n : ℕ} (_hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A E ΔA : CMatrix n n} {y b f Δb : CVec n} {e ε : ℝ}
    (_hε : 0 ≤ ε)
    (_hE : IsMixedSubordinateMatrixNormValue ν ν E e)
    (hΔA : MixedSubordinateMatrixBound ν ν ΔA (ε * e))
    (hΔb : ν Δb ≤ ε * ν f)
    (hPerturbed : complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
      fun i => b i + Δb i) :
    ν (fun i => b i - complexMatrixVecMul A y i) ≤
      ε * (e * ν y + ν f) := by
  have hres :
      (fun i => b i - complexMatrixVecMul A y i) =
        (fun i => complexMatrixVecMul ΔA y i - Δb i) := by
    ext i
    have hPerti := congrFun hPerturbed i
    unfold complexMatrixVecMul at hPerti ⊢
    simp_rw [add_mul, Finset.sum_add_distrib] at hPerti
    have hmain :
        b i = (∑ j : Fin n, A i j * y j) + (∑ j : Fin n, ΔA i j * y j) - Δb i := by
      calc
        b i = (b i + Δb i) - Δb i := by ring
        _ = (∑ j : Fin n, A i j * y j) + (∑ j : Fin n, ΔA i j * y j) - Δb i := by
              rw [← hPerti]
    calc
      b i - ∑ j : Fin n, A i j * y j
          = ((∑ j : Fin n, A i j * y j) + (∑ j : Fin n, ΔA i j * y j) - Δb i) -
              ∑ j : Fin n, A i j * y j := by rw [hmain]
      _ = ∑ j : Fin n, ΔA i j * y j - Δb i := by ring
  have hsub :
      ν (fun i => complexMatrixVecMul ΔA y i - Δb i) ≤
        ν (complexMatrixVecMul ΔA y) + ν Δb := by
    have hsub_eq :
        (fun i => complexMatrixVecMul ΔA y i - Δb i) =
          complexVecAdd (complexMatrixVecMul ΔA y) (complexVecSMul (-1 : ℂ) Δb) := by
      ext i
      simp [complexVecAdd, complexVecSMul, sub_eq_add_neg]
    calc
      ν (fun i => complexMatrixVecMul ΔA y i - Δb i)
          = ν (complexVecAdd (complexMatrixVecMul ΔA y)
              (complexVecSMul (-1 : ℂ) Δb)) := by rw [hsub_eq]
      _ ≤ ν (complexMatrixVecMul ΔA y) + ν (complexVecSMul (-1 : ℂ) Δb) :=
          hν.add_le _ _
      _ = ν (complexMatrixVecMul ΔA y) + ν Δb := by
          rw [hν.smul (-1 : ℂ) Δb]
          norm_num
  calc
    ν (fun i => b i - complexMatrixVecMul A y i)
        = ν (fun i => complexMatrixVecMul ΔA y i - Δb i) := by rw [hres]
    _ ≤ ν (complexMatrixVecMul ΔA y) + ν Δb := hsub
    _ ≤ (ε * e) * ν y + ε * ν f := add_le_add (hΔA y) hΔb
    _ = ε * (e * ν y + ν f) := by ring

/-- Higham equation (7.3), arbitrary subordinate-norm attaining perturbations
    over complex matrices, in the positive-denominator case. -/
theorem eq_7_3_subordinate_attaining_perturbations
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A E : CMatrix n n} {y b f : CVec n} {e : ℝ}
    (hE : IsMixedSubordinateMatrixNormValue ν ν E e)
    (hy : 0 < ν y) (hd : 0 < e * ν y + ν f) :
    let r : CVec n := fun i => b i - complexMatrixVecMul A y i
    let d : ℝ := e * ν y + ν f
    ∃ φ : CVec n → ℂ, ∃ ΔAmin : CMatrix n n, ∃ Δbmin : CVec n,
      IsDualFunctionalNormValue ν φ 1 ∧
      φ y = (ν y : ℂ) ∧
      ΔAmin =
        (fun i j =>
          (((e / d) : ℝ) : ℂ) * rankOneCMatrixFromFunctional φ r i j) ∧
      Δbmin = complexVecSMul (-((ν f / d) : ℝ) : ℂ) r ∧
      MixedSubordinateMatrixBound ν ν ΔAmin ((ν r / d) * e) ∧
      ν Δbmin ≤ (ν r / d) * ν f ∧
      complexMatrixVecMul (fun i j => A i j + ΔAmin i j) y =
        fun i => b i + Δbmin i := by
  intro r d
  have he_nonneg : 0 ≤ e :=
    mixedSubordinateMatrixNormValue_nonneg_of_nonempty hn hν hν hE
  have hd_ne : d ≠ 0 := ne_of_gt hd
  obtain ⟨φ, hφ, hφy⟩ := exists_dualFunctionalNormValue_one_of_pos_vector hν hy
  let ΔAmin : CMatrix n n := fun i j =>
    (((e / d) : ℝ) : ℂ) * rankOneCMatrixFromFunctional φ r i j
  let Δbmin : CVec n := complexVecSMul (-((ν f / d) : ℝ) : ℂ) r
  refine ⟨φ, ΔAmin, Δbmin, hφ, hφy, rfl, rfl, ?_, ?_, ?_⟩
  · intro v
    have hcoef_nonneg : 0 ≤ e / d := div_nonneg he_nonneg (le_of_lt hd)
    calc
      ν (complexMatrixVecMul ΔAmin v)
          = ν (complexVecSMul (((e / d) : ℝ) : ℂ)
              (complexMatrixVecMul (rankOneCMatrixFromFunctional φ r) v)) := by
              congr 1
              ext i
              dsimp [ΔAmin, complexMatrixVecMul, complexVecSMul]
              rw [Finset.mul_sum]
              refine Finset.sum_congr rfl ?_
              intro j _hj
              ring
      _ = (e / d) * ν (complexMatrixVecMul (rankOneCMatrixFromFunctional φ r) v) := by
            rw [hν.smul (((e / d) : ℝ) : ℂ)
              (complexMatrixVecMul (rankOneCMatrixFromFunctional φ r) v)]
            rw [Complex.norm_of_nonneg hcoef_nonneg]
      _ = (e / d) * (‖φ v‖ * ν r) := by
            rw [complexMatrixVecMul_rankOneCMatrixFromFunctional hφ.linear]
            rw [rankOneOperator_apply_norm hν φ r v]
      _ ≤ (e / d) * (ν v * ν r) := by
            have hφv : ‖φ v‖ ≤ ν v := by
              simpa using hφ.bound v
            apply mul_le_mul_of_nonneg_left
            exact mul_le_mul_of_nonneg_right hφv (hν.nonneg r)
            exact hcoef_nonneg
      _ = ((ν r / d) * e) * ν v := by
            ring_nf
  · have hfd_nonneg : 0 ≤ ν f / d := div_nonneg (hν.nonneg f) (le_of_lt hd)
    calc
      ν Δbmin = (ν f / d) * ν r := by
        dsimp [Δbmin]
        have hscalar : ‖(-((ν f / d) : ℝ) : ℂ)‖ = ν f / d := by
          rw [norm_neg]
          exact Complex.norm_of_nonneg hfd_nonneg
        rw [hν.smul (-((ν f / d) : ℝ) : ℂ) r, hscalar]
      _ ≤ (ν r / d) * ν f := by
        exact le_of_eq (by ring)
  · have hΔA_apply :
        complexMatrixVecMul ΔAmin y =
          complexVecSMul (((e * ν y) / d : ℝ) : ℂ) r := by
      calc
        complexMatrixVecMul ΔAmin y
            = complexVecSMul (((e / d) : ℝ) : ℂ)
                (complexMatrixVecMul (rankOneCMatrixFromFunctional φ r) y) := by
                ext i
                dsimp [ΔAmin, complexMatrixVecMul, complexVecSMul]
                rw [Finset.mul_sum]
                refine Finset.sum_congr rfl ?_
                intro j _hj
                ring
        _ = complexVecSMul (((e / d) : ℝ) : ℂ) (rankOneOperator φ r y) := by
              rw [complexMatrixVecMul_rankOneCMatrixFromFunctional hφ.linear]
        _ = complexVecSMul (((e * ν y) / d : ℝ) : ℂ) r := by
              ext i
              simp [rankOneOperator, hφy, complexVecSMul]
              ring_nf
    have hbeta_real : 1 - (e * ν y) / d = ν f / d := by
      field_simp [hd_ne]
      ring
    have hbeta :
        (1 : ℂ) - ((((e * ν y) / d) : ℝ) : ℂ) = (((ν f / d) : ℝ) : ℂ) := by
      exact_mod_cast hbeta_real
    ext i
    have hΔAi := congrFun hΔA_apply i
    have hri : r i = b i - complexMatrixVecMul A y i := by rfl
    have hΔbi : Δbmin i = -((ν f / d : ℝ) : ℂ) * r i := by
      simp [Δbmin, complexVecSMul]
    let α : ℂ := (((e * ν y) / d : ℝ) : ℂ)
    let β : ℂ := (((ν f / d) : ℝ) : ℂ)
    calc
      complexMatrixVecMul (fun i j => A i j + ΔAmin i j) y i
          = complexMatrixVecMul A y i + complexMatrixVecMul ΔAmin y i := by
              simp [complexMatrixVecMul, Finset.sum_add_distrib, add_mul]
      _ = complexMatrixVecMul A y i + α * r i := by
            rw [hΔAi]
            simp [complexVecSMul, α]
      _ = complexMatrixVecMul A y i + α * (b i - complexMatrixVecMul A y i) := by
            rw [hri]
      _ = α * b i + ((1 : ℂ) - α) * complexMatrixVecMul A y i := by
            ring
      _ = α * b i + β * complexMatrixVecMul A y i := by
            rw [hbeta]
      _ = b i + (-β) * (b i - complexMatrixVecMul A y i) := by
            have halpha : α = 1 - β := by
              calc
                α = 1 - (1 - α) := by ring
                _ = 1 - β := by rw [hbeta]
            rw [halpha]
            ring
      _ = b i + Δbmin i := by
            rw [hΔbi]

/-- Higham Theorem 7.1, arbitrary subordinate-norm sufficient direction over
    complex matrices. -/
theorem theorem7_1_subordinate_sufficient
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A E : CMatrix n n} {y b f : CVec n} {e ε : ℝ}
    (hε : 0 ≤ ε)
    (hE : IsMixedSubordinateMatrixNormValue ν ν E e)
    (hBound : ν (fun i => b i - complexMatrixVecMul A y i) ≤
      ε * (e * ν y + ν f)) :
    ∃ ΔA : CMatrix n n, ∃ Δb : CVec n,
      MixedSubordinateMatrixBound ν ν ΔA (ε * e) ∧
      ν Δb ≤ ε * ν f ∧
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i := by
  have he_nonneg : 0 ≤ e :=
    mixedSubordinateMatrixNormValue_nonneg_of_nonempty hn hν hν hE
  let ΔA0 : CMatrix n n := fun _ _ => 0
  have hΔA0 : MixedSubordinateMatrixBound ν ν ΔA0 (ε * e) := by
    intro v
    have hzero : complexMatrixVecMul ΔA0 v = 0 := by
      ext i
      simp [ΔA0, complexMatrixVecMul]
    calc
      ν (complexMatrixVecMul ΔA0 v) = 0 := by
        rw [hzero]
        exact (hν.eq_zero_iff (0 : CVec n)).2 rfl
      _ ≤ (ε * e) * ν v := by
        exact mul_nonneg (mul_nonneg hε he_nonneg) (hν.nonneg v)
  by_cases hy0 : ν y = 0
  · let r : CVec n := fun i => b i - complexMatrixVecMul A y i
    let Δb0 : CVec n := complexVecSMul (-1 : ℂ) r
    refine ⟨ΔA0, Δb0, hΔA0, ?_, ?_⟩
    · calc
        ν Δb0 = ν r := by
          dsimp [Δb0]
          rw [hν.smul (-1 : ℂ) r]
          norm_num
        _ ≤ ε * (e * ν y + ν f) := by simpa [r] using hBound
        _ = ε * ν f := by rw [hy0]; ring
    · have hy_vec : y = 0 := (hν.eq_zero_iff y).1 hy0
      subst hy_vec
      ext i
      simp [ΔA0, Δb0, r, complexMatrixVecMul, complexVecSMul]
  · have hy : 0 < ν y := lt_of_le_of_ne (hν.nonneg y) (Ne.symm hy0)
    let r : CVec n := fun i => b i - complexMatrixVecMul A y i
    let d : ℝ := e * ν y + ν f
    by_cases hd0 : d = 0
    · have hr_zero : ν r = 0 := by
        apply le_antisymm
        · have hle : ν r ≤ 0 := by simpa [r, d, hd0] using hBound
          exact hle
        · exact hν.nonneg r
      have hr_vec : r = 0 := (hν.eq_zero_iff r).1 hr_zero
      refine ⟨ΔA0, 0, hΔA0, ?_, ?_⟩
      · rw [(hν.eq_zero_iff (0 : CVec n)).2 rfl]
        exact mul_nonneg hε (hν.nonneg f)
      · have hAy_eq_b : complexMatrixVecMul A y = b := by
          ext i
          have hi := congrFun hr_vec i
          exact (sub_eq_zero.mp (by simpa [r] using hi)).symm
        ext i
        simpa [ΔA0, complexMatrixVecMul] using congrFun hAy_eq_b i
    · have hd : 0 < d := lt_of_le_of_ne
          (add_nonneg (mul_nonneg he_nonneg (le_of_lt hy)) (hν.nonneg f))
          (Ne.symm hd0)
      have hatt :=
        eq_7_3_subordinate_attaining_perturbations
          (n := n) (ν := ν) (A := A) (E := E)
          (y := y) (b := b) (f := f) (e := e) hn hν hE hy hd
      dsimp [r, d] at hatt
      obtain ⟨φ, ΔAmin, Δbmin, hφ, hφy, hΔA_def, hΔb_def,
          hΔA_eta, hΔb_eta, hExact⟩ := hatt
      have hη_le : ν r / d ≤ ε := by
        apply (div_le_iff₀ hd).2
        simpa [r, d] using hBound
      refine ⟨ΔAmin, Δbmin, ?_, ?_, hExact⟩
      · intro v
        calc
          ν (complexMatrixVecMul ΔAmin v) ≤ ((ν r / d) * e) * ν v := hΔA_eta v
          _ ≤ (ε * e) * ν v := by
            apply mul_le_mul_of_nonneg_right
            exact mul_le_mul_of_nonneg_right hη_le he_nonneg
            exact hν.nonneg v
      · calc
          ν Δbmin ≤ (ν r / d) * ν f := hΔb_eta
          _ ≤ ε * ν f := mul_le_mul_of_nonneg_right hη_le (hν.nonneg f)

/-- Higham Theorem 7.1, arbitrary subordinate-norm Rigal-Gaches wrapper over
    complex matrices. -/
theorem theorem7_1_subordinate
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A E : CMatrix n n} {y b f : CVec n} {e ε : ℝ}
    (hε : 0 ≤ ε)
    (hE : IsMixedSubordinateMatrixNormValue ν ν E e) :
    (ν (fun i => b i - complexMatrixVecMul A y i) ≤
      ε * (e * ν y + ν f)) ↔
    (∃ ΔA : CMatrix n n, ∃ Δb : CVec n,
      MixedSubordinateMatrixBound ν ν ΔA (ε * e) ∧
      ν Δb ≤ ε * ν f ∧
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i) := by
  constructor
  · exact theorem7_1_subordinate_sufficient hn hν hε hE
  · intro ⟨ΔA, Δb, hΔA, hΔb, hExact⟩
    exact theorem7_1_subordinate_necessary hn hν hε hE hΔA hΔb hExact

