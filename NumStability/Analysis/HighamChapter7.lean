/-- Problem 7.10(e), source-shaped one-norm condition-product infimum under an
explicit positive Perron-vector certificate for `|A|ᵀ|A⁻¹|ᵀ`. -/
theorem problem7_10e_scaledOneKappaSet_sInf_eq_perron_of_abs_inverse_transpose_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (y : Fin n → ℝ)
