/-- For every positive radius, the first-order normwise Problem 7.9 radius
supremum is exactly
`‖cᵀA⁻¹‖₂(‖E‖₂‖x‖₂ + ‖f‖₂)/|cᵀx|`. -/
theorem ch7Problem79NormwiseLinearizedRadiusSup_eq
    (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) {rho : ℝ}
    (hrho : 0 < rho)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0) :
    ch7Problem79NormwiseLinearizedRadiusSup n A_inv E_norm f_norm c x rho =
      ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x := by
  let S := Ch7Problem79NormwiseLinearizedRadiusSet
    n A_inv E_norm f_norm c x rho
  let κ := ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x
  have hκmem : κ ∈ S := by
    dsimp [S, κ]
    exact
      exists_ch7Problem79NormwiseLinearizedRadiusSet_exact_witness
        n A_inv E_norm f_norm c x hrho hE hf hden hx hw
  have hupper : ∀ q : ℝ, q ∈ S → q ≤ κ := by
    intro q hq
    dsimp [S, κ] at hq ⊢
    exact
      ch7Problem79NormwiseLinearizedRadiusSet_value_le
        n A_inv E_norm f_norm c x hden hq
  change sSup S = κ
  exact le_antisymm (csSup_le ⟨κ, hκmem⟩ hupper) (le_csSup ⟨κ, hupper⟩ hκmem)

/-- Source-radius limit packaging of the first-order normwise Problem 7.9
formula.  The radius supremum is constant for all positive radii. -/
theorem problem7_9_normwise_linearized_radiusSup_tendsto_formula
    {ι : Type*} {l : Filter ι}
    (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0) :
    IsCh7Problem79NormwiseLinearizedRadiusLimitValue l
      n A_inv E_norm f_norm c x rho
      (ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x) := by
  dsimp [IsCh7Problem79NormwiseLinearizedRadiusLimitValue]
  have heq :
      (fun t =>
          ch7Problem79NormwiseLinearizedRadiusSup
            n A_inv E_norm f_norm c x (rho t)) =ᶠ[l]
        fun _ : ι =>
          ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x := by
    filter_upwards [hrho_pos] with t ht
    exact
      ch7Problem79NormwiseLinearizedRadiusSup_eq
        n A_inv E_norm f_norm c x ht hE hf hden hx hw
  exact Filter.Tendsto.congr' heq.symm tendsto_const_nhds

/-- Product-plus-limit packaging for the first-order normwise scalar-output
condition number in Problem 7.9. -/
theorem problem7_9_normwise_linearized_condition_of_positive_radii
    {ι : Type*} {l : Filter ι}
    (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0) :
    ∃ κ : ℝ,
      IsCh7Problem79NormwiseLinearizedCondValue
        n A_inv E_norm f_norm c x κ ∧
        IsCh7Problem79NormwiseLinearizedRadiusLimitValue l
          n A_inv E_norm f_norm c x rho κ := by
  refine
    ⟨ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x, rfl, ?_⟩
  exact
    problem7_9_normwise_linearized_radiusSup_tendsto_formula
      n A_inv E_norm f_norm c x rho hrho_pos hE hf hden hx hw

-- ============================================================
-- Problem 7.11: linearized inverse componentwise perturbations
-- ============================================================

/-- The first-order entry of `A⁻¹ ΔA A⁻¹` in Problem 7.11.  The source
formula for `ΔX` has an overall minus sign, which disappears in the
componentwise relative magnitude. -/
noncomputable def ch7InverseLinearizedEntry (n : ℕ)
    (A_inv ΔA : Fin n → Fin n → ℝ) (i j : Fin n) : ℝ :=
  ∑ k : Fin n, ∑ l : Fin n, A_inv i k * ΔA k l * A_inv l j

/-- The numerator `(|A⁻¹| E |A⁻¹|)ᵢⱼ` from Problem 7.11. -/
noncomputable def ch7InverseCompSensitivityEntry (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (i j : Fin n) : ℝ :=
  ∑ k : Fin n, ∑ l : Fin n, |A_inv i k| * E k l * |A_inv l j|

/-- The componentwise relative entry ratio
`(|A⁻¹| E |A⁻¹|)ᵢⱼ / |(A⁻¹)ᵢⱼ|` from Problem 7.11. -/
noncomputable def ch7InverseCompSensitivityRatio (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (i j : Fin n) : ℝ :=
  ch7InverseCompSensitivityEntry n A_inv E i j / |A_inv i j|

/-- Finite maximum of the Problem 7.11 componentwise relative entry ratios. -/
noncomputable def ch7InverseComponentwiseLinearizedCond (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) : ℝ :=
  Finset.sup' Finset.univ
    (Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩)
    (fun p : Fin n × Fin n =>
      ch7InverseCompSensitivityRatio n A_inv E p.1 p.2)

/-- The maximum relative first-order entry change for a particular `ΔA`. -/
noncomputable def ch7InverseLinearizedRelativeChangeMax (n : ℕ) (hn : 0 < n)
    (A_inv ΔA : Fin n → Fin n → ℝ) : ℝ :=
  Finset.sup' Finset.univ
    (Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩)
    (fun p : Fin n × Fin n =>
      |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| / |A_inv p.1 p.2|)

/-- Appendix A.11 sign choice
`ΔA = ε D₁ E D₂`, represented entrywise for a chosen output entry `(r,s)`. -/
noncomputable def ch7Problem711AttainingDelta (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (ε : ℝ) (r s : Fin n) :
    Fin n → Fin n → ℝ :=
  fun k l => ε * ch7AbsSign (A_inv r k) * E k l *
    ch7AbsSign (A_inv l s)

lemma ch7InverseCompSensitivityEntry_nonneg (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (i j : Fin n)
    (hE : ∀ k l, 0 ≤ E k l) :
    0 ≤ ch7InverseCompSensitivityEntry n A_inv E i j := by
  unfold ch7InverseCompSensitivityEntry
  exact Finset.sum_nonneg fun k _ =>
    Finset.sum_nonneg fun l _ =>
      mul_nonneg (mul_nonneg (abs_nonneg _) (hE k l)) (abs_nonneg _)

lemma ch7_inverseLinearizedEntry_abs_le (n : ℕ)
    (A_inv ΔA E : Fin n → Fin n → ℝ) (ε : ℝ) (i j : Fin n)
    (_hε : 0 ≤ ε) (_hE : ∀ k l, 0 ≤ E k l)
    (hΔ : ∀ k l, |ΔA k l| ≤ ε * E k l) :
    |ch7InverseLinearizedEntry n A_inv ΔA i j| ≤
      ε * ch7InverseCompSensitivityEntry n A_inv E i j := by
  unfold ch7InverseLinearizedEntry ch7InverseCompSensitivityEntry
  calc
    |∑ k : Fin n, ∑ l : Fin n, A_inv i k * ΔA k l * A_inv l j|
        ≤ ∑ k : Fin n, |∑ l : Fin n, A_inv i k * ΔA k l * A_inv l j| :=
          Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ k : Fin n, ∑ l : Fin n, |A_inv i k * ΔA k l * A_inv l j| := by
          apply Finset.sum_le_sum
          intro k _
          exact Finset.abs_sum_le_sum_abs _ _
    _ = ∑ k : Fin n, ∑ l : Fin n, |A_inv i k| * |ΔA k l| * |A_inv l j| := by
          apply Finset.sum_congr rfl
          intro k _
          apply Finset.sum_congr rfl
          intro l _
          rw [abs_mul, abs_mul]
    _ ≤ ∑ k : Fin n, ∑ l : Fin n, |A_inv i k| * (ε * E k l) * |A_inv l j| := by
          apply Finset.sum_le_sum
          intro k _
          apply Finset.sum_le_sum
          intro l _
          exact mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_left (hΔ k l) (abs_nonneg _))
            (abs_nonneg _)
    _ = ε * ∑ k : Fin n, ∑ l : Fin n, |A_inv i k| * E k l * |A_inv l j| := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro k _
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro l _
          ring

lemma ch7_inverseLinearizedRatio_le (n : ℕ)
    (A_inv ΔA E : Fin n → Fin n → ℝ) (ε : ℝ) (i j : Fin n)
    (hε : 0 ≤ ε) (hE : ∀ k l, 0 ≤ E k l)
    (hden : 0 < |A_inv i j|)
    (hΔ : ∀ k l, |ΔA k l| ≤ ε * E k l) :
    |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| ≤
      ε * ch7InverseCompSensitivityRatio n A_inv E i j := by
  unfold ch7InverseCompSensitivityRatio
  calc
    |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j|
        ≤ (ε * ch7InverseCompSensitivityEntry n A_inv E i j) /
            |A_inv i j| :=
          div_le_div_of_nonneg_right
            (ch7_inverseLinearizedEntry_abs_le n A_inv ΔA E ε i j hε hE hΔ)
            (le_of_lt hden)
    _ = ε * (ch7InverseCompSensitivityEntry n A_inv E i j / |A_inv i j|) := by
          ring

lemma ch7_inverseLinearizedRelativeChangeMax_le (n : ℕ) (hn : 0 < n)
    (A_inv ΔA E : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ k l, 0 ≤ E k l)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : ∀ k l, |ΔA k l| ≤ ε * E k l) :
    ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA ≤
      ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E := by
  unfold ch7InverseLinearizedRelativeChangeMax
    ch7InverseComponentwiseLinearizedCond
  apply Finset.sup'_le
  intro p _
  calc
    |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| / |A_inv p.1 p.2|
        ≤ ε * ch7InverseCompSensitivityRatio n A_inv E p.1 p.2 :=
          ch7_inverseLinearizedRatio_le n A_inv ΔA E ε p.1 p.2 hε hE
            (hden p.1 p.2) hΔ
    _ ≤ ε *
        Finset.sup' Finset.univ
          (Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩)
          (fun p : Fin n × Fin n =>
            ch7InverseCompSensitivityRatio n A_inv E p.1 p.2) :=
          mul_le_mul_of_nonneg_left
            (Finset.le_sup'
              (fun p : Fin n × Fin n =>
                ch7InverseCompSensitivityRatio n A_inv E p.1 p.2)
              (Finset.mem_univ p))
            hε

lemma ch7_problem711_attainingDelta_bound (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (ε : ℝ) (r s k l : Fin n)
    (hε : 0 ≤ ε) (hE : ∀ k l, 0 ≤ E k l) :
    |ch7Problem711AttainingDelta n A_inv E ε r s k l| ≤ ε * E k l := by
  unfold ch7Problem711AttainingDelta
  rw [abs_mul, abs_mul, abs_mul, ch7_abs_ch7AbsSign,
    ch7_abs_ch7AbsSign]
  rw [abs_of_nonneg hε, abs_of_nonneg (hE k l)]
  ring_nf
  exact le_rfl

lemma ch7_problem711_attainingDelta_entry_eq (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (ε : ℝ) (r s : Fin n) :
    ch7InverseLinearizedEntry n A_inv
      (ch7Problem711AttainingDelta n A_inv E ε r s) r s =
      ε * ch7InverseCompSensitivityEntry n A_inv E r s := by
  unfold ch7InverseLinearizedEntry ch7Problem711AttainingDelta
    ch7InverseCompSensitivityEntry
  calc
    ∑ k : Fin n, ∑ l : Fin n,
        A_inv r k *
          (ε * ch7AbsSign (A_inv r k) * E k l *
            ch7AbsSign (A_inv l s)) *
          A_inv l s
        = ∑ k : Fin n, ∑ l : Fin n,
            ε * (|A_inv r k| * E k l * |A_inv l s|) := by
          apply Finset.sum_congr rfl
          intro k _
          apply Finset.sum_congr rfl
          intro l _
          calc
            A_inv r k *
                (ε * ch7AbsSign (A_inv r k) * E k l *
                  ch7AbsSign (A_inv l s)) *
                A_inv l s
                = ε * ((A_inv r k * ch7AbsSign (A_inv r k)) * E k l *
                    (ch7AbsSign (A_inv l s) * A_inv l s)) := by
                  ring
            _ = ε * (|A_inv r k| * E k l * |A_inv l s|) := by
                  rw [ch7_mul_ch7AbsSign_eq_abs, ch7AbsSign_mul_eq_abs]
    _ = ε * ∑ k : Fin n, ∑ l : Fin n,
            |A_inv r k| * E k l * |A_inv l s| := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro k _
          rw [Finset.mul_sum]

/-- Problem 7.11, linearized componentwise inverse perturbation package:
every admissible first-order perturbation is bounded by
`ε maxᵢⱼ (|A⁻¹|E|A⁻¹|)ᵢⱼ / |(A⁻¹)ᵢⱼ|`, and the Appendix A.11 sign choice
attains the selected entry.  This is the checked first-order core of the
source `lim sup` formula. -/
theorem problem7_11_linearized_inverse_componentwise_upper_and_sign_attainment
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ)
    (hE : ∀ k l, 0 ≤ E k l)
    (hden : ∀ i j, 0 < |A_inv i j|) :
    (∀ ε ΔA, 0 ≤ ε →
      (∀ k l, |ΔA k l| ≤ ε * E k l) →
      ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA ≤
        ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E) ∧
    (∀ ε r s, 0 ≤ ε →
      ∃ ΔA : Fin n → Fin n → ℝ,
        (∀ k l, |ΔA k l| ≤ ε * E k l) ∧
          ch7InverseLinearizedEntry n A_inv ΔA r s =
            ε * ch7InverseCompSensitivityEntry n A_inv E r s) := by
  constructor
  · intro ε ΔA hε hΔ
    exact ch7_inverseLinearizedRelativeChangeMax_le n hn A_inv ΔA E ε
      hε hE hden hΔ
  · intro ε r s hε
    refine ⟨ch7Problem711AttainingDelta n A_inv E ε r s, ?_, ?_⟩
    · intro k l
      exact ch7_problem711_attainingDelta_bound n A_inv E ε r s k l hε hE
    · exact ch7_problem711_attainingDelta_entry_eq n A_inv E ε r s

/-- Problem 7.11, finite maximum version of the linearized formula.  For
nonnegative tolerances and nonzero inverse entries, the maximum relative
first-order inverse change over `|ΔA| ≤ εE` is exactly
`ε maxᵢⱼ (|A⁻¹|E|A⁻¹|)ᵢⱼ / |(A⁻¹)ᵢⱼ|`, with a sign perturbation attaining a
maximizing entry. -/
theorem problem7_11_linearized_inverse_componentwise_formula
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ)
    (hE : ∀ k l, 0 ≤ E k l)
    (hden : ∀ i j, 0 < |A_inv i j|) :
    (∀ ε ΔA, 0 ≤ ε →
      (∀ k l, |ΔA k l| ≤ ε * E k l) →
      ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA ≤
        ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E) ∧
    (∀ ε, 0 ≤ ε →
      ∃ r : Fin n, ∃ s : Fin n, ∃ ΔA : Fin n → Fin n → ℝ,
        (∀ k l, |ΔA k l| ≤ ε * E k l) ∧
          ch7InverseLinearizedEntry n A_inv ΔA r s =
            ε * ch7InverseCompSensitivityEntry n A_inv E r s ∧
          ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA =
            ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E) := by
  constructor
  · intro ε ΔA hε hΔ
    exact ch7_inverseLinearizedRelativeChangeMax_le n hn A_inv ΔA E ε
      hε hE hden hΔ
  · intro ε hε
    let hne : (Finset.univ : Finset (Fin n × Fin n)).Nonempty :=
      Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩
    have hcond_le_self :
        ch7InverseComponentwiseLinearizedCond n hn A_inv E ≤
          ch7InverseComponentwiseLinearizedCond n hn A_inv E := le_rfl
    unfold ch7InverseComponentwiseLinearizedCond at hcond_le_self
    rw [Finset.le_sup'_iff] at hcond_le_self
    rcases hcond_le_self with ⟨p, _hp_mem, hcond_le_ratio⟩
    rcases p with ⟨r, s⟩
    let ΔA := ch7Problem711AttainingDelta n A_inv E ε r s
    have hΔ : ∀ k l, |ΔA k l| ≤ ε * E k l := by
      intro k l
      exact ch7_problem711_attainingDelta_bound n A_inv E ε r s k l hε hE
    have hratio_le_cond :
        ch7InverseCompSensitivityRatio n A_inv E r s ≤
          ch7InverseComponentwiseLinearizedCond n hn A_inv E := by
      unfold ch7InverseComponentwiseLinearizedCond
      exact Finset.le_sup'
        (fun p : Fin n × Fin n =>
          ch7InverseCompSensitivityRatio n A_inv E p.1 p.2)
        (Finset.mem_univ (r, s))
    have hratio_eq_cond :
        ch7InverseCompSensitivityRatio n A_inv E r s =
          ch7InverseComponentwiseLinearizedCond n hn A_inv E :=
      le_antisymm hratio_le_cond hcond_le_ratio
    have hsens_nonneg :
        0 ≤ ch7InverseCompSensitivityEntry n A_inv E r s :=
      ch7InverseCompSensitivityEntry_nonneg n A_inv E r s hE
    have hentry :
        ch7InverseLinearizedEntry n A_inv ΔA r s =
          ε * ch7InverseCompSensitivityEntry n A_inv E r s := by
      dsimp [ΔA]
      exact ch7_problem711_attainingDelta_entry_eq n A_inv E ε r s
    have hentry_abs :
        |ch7InverseLinearizedEntry n A_inv ΔA r s| =
          ε * ch7InverseCompSensitivityEntry n A_inv E r s := by
      rw [hentry]
      exact abs_of_nonneg (mul_nonneg hε hsens_nonneg)
    have hentry_ratio :
        |ch7InverseLinearizedEntry n A_inv ΔA r s| / |A_inv r s| =
          ε * ch7InverseCompSensitivityRatio n A_inv E r s := by
      rw [hentry_abs]
      unfold ch7InverseCompSensitivityRatio
      ring
    have hlower :
        ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E ≤
          ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA := by
      unfold ch7InverseLinearizedRelativeChangeMax
      calc
        ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E
            = ε * ch7InverseCompSensitivityRatio n A_inv E r s := by
              rw [hratio_eq_cond]
        _ = |ch7InverseLinearizedEntry n A_inv ΔA r s| / |A_inv r s| := by
              rw [hentry_ratio]
        _ ≤ Finset.sup' Finset.univ hne
            (fun p : Fin n × Fin n =>
              |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
                |A_inv p.1 p.2|) :=
              Finset.le_sup'
                (fun p : Fin n × Fin n =>
                  |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
                    |A_inv p.1 p.2|)
                (Finset.mem_univ (r, s))
    have hupper :
        ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA ≤
          ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E :=
      ch7_inverseLinearizedRelativeChangeMax_le n hn A_inv ΔA E ε
        hε hE hden hΔ
    exact ⟨r, s, ΔA, hΔ, hentry, le_antisymm hupper hlower⟩

/-- The quadratic remainder entry `A⁻¹ ΔA A⁻¹ ΔA B` in the exact inverse
perturbation identity.  Here `B` is a right inverse of `A + ΔA`. -/
noncomputable def ch7InverseQuadraticRemainderEntry (n : ℕ)
    (A_inv ΔA B : Fin n → Fin n → ℝ) (i j : Fin n) : ℝ :=
  matMul n (matMul n A_inv ΔA) (matMul n (matMul n A_inv ΔA) B) i j

lemma ch7_matMul_of_IsLeftInverse (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv) :
    matMul n A_inv A = idMatrix n := by
  ext i j
  exact hInv i j

lemma ch7_matMul_of_IsRightInverse (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ)
    (hInv : IsRightInverse n A A_inv) :
    matMul n A A_inv = idMatrix n := by
  ext i j
  exact hInv i j

lemma ch7InverseLinearizedEntry_eq_matMul (n : ℕ)
    (A_inv ΔA : Fin n → Fin n → ℝ) (i j : Fin n) :
    ch7InverseLinearizedEntry n A_inv ΔA i j =
      matMul n (matMul n A_inv ΔA) A_inv i j := by
  unfold ch7InverseLinearizedEntry matMul
  calc
    ∑ k : Fin n, ∑ l : Fin n, A_inv i k * ΔA k l * A_inv l j
        = ∑ l : Fin n, ∑ k : Fin n, A_inv i k * ΔA k l * A_inv l j := by
          rw [Finset.sum_comm]
    _ = ∑ l : Fin n, (∑ k : Fin n, A_inv i k * ΔA k l) * A_inv l j := by
          apply Finset.sum_congr rfl
          intro l _
          rw [Finset.sum_mul]

lemma ch7_inversePerturbation_decomposition (n : ℕ)
    (A A_inv ΔA B : Fin n → Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    ∀ i j,
      B i j + matMul n (matMul n A_inv ΔA) B i j = A_inv i j := by
  let M : Fin n → Fin n → ℝ := matMul n A_inv ΔA
  have hSA : matMul n A_inv A = idMatrix n :=
    ch7_matMul_of_IsLeftInverse n A A_inv hLeft
  have hPert : matMul n (fun i j => A i j + ΔA i j) B = idMatrix n :=
    ch7_matMul_of_IsRightInverse n (fun i j => A i j + ΔA i j) B hRight
  have hmatrix :
      (fun i j => B i j + matMul n M B i j) = A_inv := by
    calc
      (fun i j => B i j + matMul n M B i j)
          = (fun i j => matMul n (matMul n A_inv A) B i j +
              matMul n M B i j) := by
            ext i j
            rw [hSA, matMul_id_left]
      _ = matMul n (fun i j => matMul n A_inv A i j + M i j) B := by
            exact (matMul_add_left n (matMul n A_inv A) M B).symm
      _ = matMul n (matMul n A_inv (fun i j => A i j + ΔA i j)) B := by
            dsimp [M]
            exact congrArg (fun X : Fin n → Fin n → ℝ => matMul n X B)
              (matMul_add_right n A_inv A ΔA).symm
      _ = matMul n A_inv (matMul n (fun i j => A i j + ΔA i j) B) := by
            rw [matMul_assoc]
      _ = matMul n A_inv (idMatrix n) := by
            rw [hPert]
      _ = A_inv := by
            rw [matMul_id_right]
  intro i j
  have h :=
    congrFun (congrFun hmatrix i) j
  simpa [M] using h

/-- Problem 7.11 nonlinear algebraic bridge: if `A⁻¹` is a left inverse of
`A` and `B` is a right inverse of `A + ΔA`, then entrywise
`B - A⁻¹ = -A⁻¹ΔAA⁻¹ + A⁻¹ΔAA⁻¹ΔAB`.  This is the exact finite-dimensional
identity needed before turning the checked first-order formula into the full
source `lim sup` statement. -/
theorem problem7_11_exact_inverse_firstOrder_remainder_identity
    (n : ℕ)
    (A A_inv ΔA B : Fin n → Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    ∀ i j,
      B i j - A_inv i j =
        -ch7InverseLinearizedEntry n A_inv ΔA i j +
          ch7InverseQuadraticRemainderEntry n A_inv ΔA B i j := by
  intro i j
  let M : Fin n → Fin n → ℝ := matMul n A_inv ΔA
  have hdecomp :=
    ch7_inversePerturbation_decomposition n A A_inv ΔA B hLeft hRight
  have hBminus : B i j - A_inv i j = -matMul n M B i j := by
    have h := hdecomp i j
    dsimp [M] at h ⊢
    linarith
  have hMdecomp :
      matMul n M B i j =
        matMul n M A_inv i j - matMul n M (matMul n M B) i j := by
    change (∑ l : Fin n, M i l * B l j) =
      (∑ l : Fin n, M i l * A_inv l j) -
        (∑ l : Fin n, M i l * matMul n M B l j)
    calc
      ∑ l : Fin n, M i l * B l j
          = ∑ l : Fin n, M i l * (A_inv l j - matMul n M B l j) := by
            apply Finset.sum_congr rfl
            intro l _
            have h := hdecomp l j
            dsimp [M] at h ⊢
            rw [eq_sub_of_add_eq h]
      _ = ∑ l : Fin n, M i l * A_inv l j -
            ∑ l : Fin n, M i l * matMul n M B l j := by
            simp_rw [mul_sub]
            rw [Finset.sum_sub_distrib]
  rw [hBminus, hMdecomp]
  unfold ch7InverseQuadraticRemainderEntry
  rw [ch7InverseLinearizedEntry_eq_matMul]
  dsimp [M]
  ring

/-- Nonnegativity is preserved by finite matrix multiplication. -/
lemma ch7_matMul_nonneg (n : ℕ)
    (A B : Fin n → Fin n → ℝ)
    (hA : ∀ i j, 0 ≤ A i j) (hB : ∀ i j, 0 ≤ B i j) :
    ∀ i j, 0 ≤ matMul n A B i j := by
  intro i j
  unfold matMul
  exact Finset.sum_nonneg fun k _ => mul_nonneg (hA i k) (hB k j)

/-- Left multiplication by a componentwise nonnegative matrix preserves
componentwise order. -/
lemma ch7_matMul_le_of_nonneg_left (n : ℕ)
    (A B C : Fin n → Fin n → ℝ)
    (hA : ∀ i j, 0 ≤ A i j)
    (hBC : ∀ i j, B i j ≤ C i j) :
    ∀ i j, matMul n A B i j ≤ matMul n A C i j := by
  intro i j
  unfold matMul
  exact Finset.sum_le_sum fun k _ =>
    mul_le_mul_of_nonneg_left (hBC k j) (hA i k)

/-- Componentwise matrix-product domination with explicit scalar radii. -/
lemma ch7_matMul_abs_le_of_scaled_abs_le (n : ℕ)
    (A B P Q : Fin n → Fin n → ℝ) (α β : ℝ)
    (hα : 0 ≤ α) (_hβ : 0 ≤ β)
    (hP : ∀ i j, 0 ≤ P i j) (_hQ : ∀ i j, 0 ≤ Q i j)
    (hA : ∀ i j, |A i j| ≤ α * P i j)
    (hB : ∀ i j, |B i j| ≤ β * Q i j) :
    ∀ i j,
      |matMul n A B i j| ≤ α * β * matMul n P Q i j := by
  intro i j
  unfold matMul
  calc
    |∑ k : Fin n, A i k * B k j|
        ≤ ∑ k : Fin n, |A i k * B k j| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = ∑ k : Fin n, |A i k| * |B k j| := by
          apply Finset.sum_congr rfl
          intro k _
          rw [abs_mul]
    _ ≤ ∑ k : Fin n, (α * P i k) * (β * Q k j) := by
          apply Finset.sum_le_sum
          intro k _
          exact mul_le_mul (hA i k) (hB k j) (abs_nonneg _)
            (mul_nonneg hα (hP i k))
    _ = α * β * ∑ k : Fin n, P i k * Q k j := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro k _
          ring

/-- The first product `|A⁻¹|E` appearing in the quadratic remainder bound
for Problem 7.11. -/
noncomputable def ch7InverseFirstProductSensitivity (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) : Fin n → Fin n → ℝ :=
  matMul n (absMatrix n A_inv) E

lemma ch7InverseFirstProductSensitivity_nonneg (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) :
    ∀ i j, 0 ≤ ch7InverseFirstProductSensitivity n A_inv E i j := by
  unfold ch7InverseFirstProductSensitivity
  exact ch7_matMul_nonneg n (absMatrix n A_inv) E
    (by intro i j; exact abs_nonneg _) hE

/-- The finite nonnegative coefficient multiplying `ε²` in the exact
Problem 7.11 quadratic remainder bound. -/
noncomputable def ch7InverseQuadraticRemainderSensitivityEntry (n : ℕ)
    (A_inv E B : Fin n → Fin n → ℝ) (i j : Fin n) : ℝ :=
  let P := ch7InverseFirstProductSensitivity n A_inv E
  matMul n P (matMul n P (absMatrix n B)) i j

lemma ch7InverseQuadraticRemainderSensitivityEntry_nonneg (n : ℕ)
    (A_inv E B : Fin n → Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) :
    ∀ i j, 0 ≤ ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j := by
  intro i j
  let P := ch7InverseFirstProductSensitivity n A_inv E
  have hP : ∀ i j, 0 ≤ P i j := by
    intro i j
    exact ch7InverseFirstProductSensitivity_nonneg n A_inv E hE i j
  have hPB : ∀ i j, 0 ≤ matMul n P (absMatrix n B) i j :=
    ch7_matMul_nonneg n P (absMatrix n B) hP
      (by intro i j; exact abs_nonneg _)
  unfold ch7InverseQuadraticRemainderSensitivityEntry
  dsimp [P]
  exact ch7_matMul_nonneg n P (matMul n P (absMatrix n B)) hP hPB i j

lemma ch7_inverseFirstProduct_abs_le (n : ℕ)
    (A_inv ΔA E : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j) :
    ∀ i j,
      |matMul n A_inv ΔA i j| ≤
        ε * ch7InverseFirstProductSensitivity n A_inv E i j := by
  intro i j
  have h :=
    ch7_matMul_abs_le_of_scaled_abs_le n A_inv ΔA
      (absMatrix n A_inv) E 1 ε (by norm_num) hε
      (by intro i j; exact abs_nonneg _) hE
      (by intro i j; simp [absMatrix])
      hΔ i j
  simpa [ch7InverseFirstProductSensitivity, one_mul] using h

/-- Problem 7.11 quadratic-remainder bound: under `|ΔA| ≤ εE`, the exact
remainder `A⁻¹ΔAA⁻¹ΔAB` is bounded componentwise by `ε²` times a finite
nonnegative sensitivity coefficient. -/
theorem ch7InverseQuadraticRemainderEntry_abs_le (n : ℕ)
    (A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j) :
    ∀ i j,
      |ch7InverseQuadraticRemainderEntry n A_inv ΔA B i j| ≤
        ε ^ 2 * ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j := by
  intro i j
  let M : Fin n → Fin n → ℝ := matMul n A_inv ΔA
  let P : Fin n → Fin n → ℝ := ch7InverseFirstProductSensitivity n A_inv E
  let Q : Fin n → Fin n → ℝ := matMul n P (absMatrix n B)
  have hP : ∀ i j, 0 ≤ P i j := by
    intro i j
    exact ch7InverseFirstProductSensitivity_nonneg n A_inv E hE i j
  have hQ : ∀ i j, 0 ≤ Q i j :=
    ch7_matMul_nonneg n P (absMatrix n B) hP
      (by intro i j; exact abs_nonneg _)
  have hM : ∀ i j, |M i j| ≤ ε * P i j := by
    intro i j
    exact ch7_inverseFirstProduct_abs_le n A_inv ΔA E ε hε hE hΔ i j
  have hMB : ∀ i j, |matMul n M B i j| ≤ ε * Q i j := by
    intro i j
    have h :=
      ch7_matMul_abs_le_of_scaled_abs_le n M B P (absMatrix n B)
        ε 1 hε (by norm_num) hP (by intro i j; exact abs_nonneg _)
        hM (by intro i j; simp [absMatrix]) i j
    simpa [Q, one_mul, mul_one] using h
  have h :=
    ch7_matMul_abs_le_of_scaled_abs_le n M (matMul n M B) P Q
      ε ε hε hε hP hQ hM hMB i j
  unfold ch7InverseQuadraticRemainderEntry
  dsimp [M] at h ⊢
  unfold ch7InverseQuadraticRemainderSensitivityEntry
  dsimp [P, Q]
  calc
    |matMul n (matMul n A_inv ΔA)
        (matMul n (matMul n A_inv ΔA) B) i j|
        ≤ ε * ε * matMul n
            (ch7InverseFirstProductSensitivity n A_inv E)
            (matMul n (ch7InverseFirstProductSensitivity n A_inv E)
              (absMatrix n B)) i j := h
    _ = ε ^ 2 *
        matMul n (ch7InverseFirstProductSensitivity n A_inv E)
          (matMul n (ch7InverseFirstProductSensitivity n A_inv E)
            (absMatrix n B)) i j := by
          ring

/-- Exact relative inverse change used in the nonlinear Problem 7.11
condition-number row. -/
noncomputable def ch7InverseExactRelativeChangeMax (n : ℕ) (hn : 0 < n)
    (A_inv B : Fin n → Fin n → ℝ) : ℝ :=
  Finset.sup' Finset.univ
    (Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩)
    (fun p : Fin n × Fin n =>
      |B p.1 p.2 - A_inv p.1 p.2| / |A_inv p.1 p.2|)

/-- The maximum relative quadratic-remainder coefficient for Problem 7.11. -/
noncomputable def ch7InverseQuadraticRemainderRelativeMax (n : ℕ) (hn : 0 < n)
    (A_inv E B : Fin n → Fin n → ℝ) : ℝ :=
  Finset.sup' Finset.univ
    (Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩)
    (fun p : Fin n × Fin n =>
      ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
        |A_inv p.1 p.2|)

/-- A source-facing finite bound for the Problem 7.11 relative quadratic
remainder coefficient when the exact perturbed inverse has entrywise absolute
bound `C_B`. -/
noncomputable def ch7InverseQuadraticRemainderRelativeMaxEntryBound
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) (C_B : ℝ) : ℝ :=
  let P := ch7InverseFirstProductSensitivity n A_inv E
  let Cmat : Fin n → Fin n → ℝ := fun _ _ => C_B
  Finset.sup' Finset.univ
    (Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩)
    (fun p : Fin n × Fin n =>
      matMul n P (matMul n P Cmat) p.1 p.2 /
        |A_inv p.1 p.2|)

/-- The Problem 7.11 quadratic sensitivity entry is monotone in the entrywise
absolute bound on the exact perturbed inverse. -/
theorem ch7InverseQuadraticRemainderSensitivityEntry_le_of_entry_bound
    (n : ℕ)
    (A_inv E B : Fin n → Fin n → ℝ) (C_B : ℝ)
    (hE : ∀ i j, 0 ≤ E i j)
    (hB : ∀ i j, |B i j| ≤ C_B)
    (i j : Fin n) :
    ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j ≤
      matMul n (ch7InverseFirstProductSensitivity n A_inv E)
        (matMul n (ch7InverseFirstProductSensitivity n A_inv E)
          (fun _ _ => C_B)) i j := by
  let P := ch7InverseFirstProductSensitivity n A_inv E
  let Cmat : Fin n → Fin n → ℝ := fun _ _ => C_B
  have hP : ∀ i j, 0 ≤ P i j := by
    intro i j
    exact ch7InverseFirstProductSensitivity_nonneg n A_inv E hE i j
  have hinner :
      ∀ i j, matMul n P (absMatrix n B) i j ≤ matMul n P Cmat i j := by
    exact ch7_matMul_le_of_nonneg_left n P (absMatrix n B) Cmat hP
      (by
        intro i j
        simpa [absMatrix, Cmat] using hB i j)
  have houter :
      matMul n P (matMul n P (absMatrix n B)) i j ≤
        matMul n P (matMul n P Cmat) i j :=
    ch7_matMul_le_of_nonneg_left n P
      (matMul n P (absMatrix n B)) (matMul n P Cmat) hP hinner i j
  simpa [ch7InverseQuadraticRemainderSensitivityEntry, P, Cmat] using houter

/-- Entrywise exact inverse-change bound: the nonlinear change is controlled
by its first-order term plus the proved quadratic remainder coefficient. -/
theorem problem7_11_exact_inverse_relative_entry_le_linearized_plus_quadratic
    (n : ℕ)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (i j : Fin n)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    |B i j - A_inv i j| / |A_inv i j| ≤
      |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| +
        ε ^ 2 *
          (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
            |A_inv i j|) := by
  have hidentity :=
    problem7_11_exact_inverse_firstOrder_remainder_identity
      n A A_inv ΔA B hLeft hRight i j
  have hrem :=
    ch7InverseQuadraticRemainderEntry_abs_le n A_inv ΔA E B ε hε hE hΔ i j
  have hden_nonneg : 0 ≤ |A_inv i j| := le_of_lt hden
  have htri :
      |B i j - A_inv i j| ≤
        |ch7InverseLinearizedEntry n A_inv ΔA i j| +
          |ch7InverseQuadraticRemainderEntry n A_inv ΔA B i j| := by
    rw [hidentity]
    simpa [abs_neg] using
      abs_add_le (-(ch7InverseLinearizedEntry n A_inv ΔA i j))
        (ch7InverseQuadraticRemainderEntry n A_inv ΔA B i j)
  calc
    |B i j - A_inv i j| / |A_inv i j|
        ≤ (|ch7InverseLinearizedEntry n A_inv ΔA i j| +
            |ch7InverseQuadraticRemainderEntry n A_inv ΔA B i j|) /
            |A_inv i j| :=
          div_le_div_of_nonneg_right htri hden_nonneg
    _ =
        |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| +
          |ch7InverseQuadraticRemainderEntry n A_inv ΔA B i j| /
            |A_inv i j| := by
          rw [add_div]
    _ ≤
        |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| +
          (ε ^ 2 * ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j) /
            |A_inv i j| := by
          exact add_le_add le_rfl
            (div_le_div_of_nonneg_right hrem hden_nonneg)
    _ =
        |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| +
        ε ^ 2 *
            (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
              |A_inv i j|) := by
          rw [mul_div_assoc]

/-- Entrywise lower companion to the exact Problem 7.11 upper estimate: the
nonlinear relative inverse change is bounded below by the selected linearized
entry minus the explicit quadratic remainder coefficient. -/
theorem problem7_11_exact_inverse_relative_entry_ge_linearized_minus_quadratic
    (n : ℕ)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (i j : Fin n)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| -
      ε ^ 2 *
        (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
          |A_inv i j|) ≤
        |B i j - A_inv i j| / |A_inv i j| := by
  have hidentity :=
    problem7_11_exact_inverse_firstOrder_remainder_identity
      n A A_inv ΔA B hLeft hRight i j
  have hrem :=
    ch7InverseQuadraticRemainderEntry_abs_le n A_inv ΔA E B ε hε hE hΔ i j
  have hden_nonneg : 0 ≤ |A_inv i j| := le_of_lt hden
  let L := ch7InverseLinearizedEntry n A_inv ΔA i j
  let R := ch7InverseQuadraticRemainderEntry n A_inv ΔA B i j
  have habs_base : |-L| - |-R| ≤ |(-L) - (-R)| := by
    exact abs_sub_abs_le_abs_sub (-L) (-R)
  have habs :
      |L| - |R| ≤ |B i j - A_inv i j| := by
    simpa [L, R, hidentity, abs_neg, sub_eq_add_neg] using habs_base
  have hdiv :
      |L| / |A_inv i j| - |R| / |A_inv i j| ≤
        |B i j - A_inv i j| / |A_inv i j| := by
    have h := div_le_div_of_nonneg_right habs hden_nonneg
    simpa [sub_div] using h
  have hrem_div :
      |R| / |A_inv i j| ≤
        ε ^ 2 *
          (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
            |A_inv i j|) := by
    calc
      |R| / |A_inv i j|
          ≤ (ε ^ 2 * ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j) /
              |A_inv i j| := by
            exact div_le_div_of_nonneg_right (by simpa [R] using hrem) hden_nonneg
      _ = ε ^ 2 *
          (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
            |A_inv i j|) := by
            rw [mul_div_assoc]
  have hsub :
      |L| / |A_inv i j| -
          ε ^ 2 *
            (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
              |A_inv i j|) ≤
        |L| / |A_inv i j| - |R| / |A_inv i j| := by
    linarith
  exact le_trans (by simpa [L] using hsub) hdiv

/-- Finite-maximum lower envelope obtained from any selected entry. -/
theorem problem7_11_exact_inverse_relative_change_max_ge_linearized_entry_minus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (i j : Fin n)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| -
      ε ^ 2 *
        (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
          |A_inv i j|) ≤
        ch7InverseExactRelativeChangeMax n hn A_inv B := by
  have hentry :=
    problem7_11_exact_inverse_relative_entry_ge_linearized_minus_quadratic
      n A A_inv ΔA E B ε i j hε hE (hden i j) hΔ hLeft hRight
  have hmax :
      |B i j - A_inv i j| / |A_inv i j| ≤
        ch7InverseExactRelativeChangeMax n hn A_inv B := by
    unfold ch7InverseExactRelativeChangeMax
    exact Finset.le_sup'
      (fun p : Fin n × Fin n =>
        |B p.1 p.2 - A_inv p.1 p.2| / |A_inv p.1 p.2|)
      (Finset.mem_univ (i, j))
  exact le_trans hentry hmax

/-- Lower finite-envelope route for Problem 7.11 when a selected linearized
entry attains the first-order componentwise condition number. -/
theorem problem7_11_exact_inverse_relative_change_max_ge_condition_minus_quadratic_of_linearized_attainer
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (i j : Fin n)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B)
    (hlin :
      |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| =
        ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E) :
    ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E -
      ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
        ch7InverseExactRelativeChangeMax n hn A_inv B := by
  have hentry :=
    problem7_11_exact_inverse_relative_change_max_ge_linearized_entry_minus_quadratic
      n hn A A_inv ΔA E B ε i j hε hE hden hΔ hLeft hRight
  have hratio_le :
      ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
          |A_inv i j| ≤
        ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
    unfold ch7InverseQuadraticRemainderRelativeMax
    exact Finset.le_sup'
      (fun p : Fin n × Fin n =>
        ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
          |A_inv p.1 p.2|)
      (Finset.mem_univ (i, j))
  have hquad :
      ε ^ 2 *
          (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
            |A_inv i j|) ≤
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B :=
    mul_le_mul_of_nonneg_left hratio_le (sq_nonneg ε)
  have hsub :
      ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E -
          ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
        |ch7InverseLinearizedEntry n A_inv ΔA i j| / |A_inv i j| -
          ε ^ 2 *
            (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B i j /
              |A_inv i j|) := by
    linarith
  exact le_trans hsub hentry

/-- Existence form of the Problem 7.11 finite lower envelope.  The perturbation
is chosen by the Appendix A.11 sign construction, and a finite entry attaining
the resulting linearized maximum supplies the lower witness for every exact
right inverse `B = (A + ΔA)⁻¹`. -/
theorem problem7_11_exists_exact_inverse_relative_change_max_lower_witness
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|) :
    ∃ ΔA : Fin n → Fin n → ℝ,
      (∀ k l, |ΔA k l| ≤ ε * E k l) ∧
        ∀ B : Fin n → Fin n → ℝ,
          IsLeftInverse n A A_inv →
          IsRightInverse n (fun k l => A k l + ΔA k l) B →
            ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E -
              ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
                ch7InverseExactRelativeChangeMax n hn A_inv B := by
  rcases
    (problem7_11_linearized_inverse_componentwise_formula n hn A_inv E hE hden).2
      ε hε with
    ⟨_r, _s, ΔA, hΔ, _hentry, hmaxlin⟩
  let hne : (Finset.univ : Finset (Fin n × Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩
  rcases
    Finset.exists_mem_eq_sup' (s := Finset.univ) hne
      (fun p : Fin n × Fin n =>
        |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
          |A_inv p.1 p.2|) with
    ⟨p, _hp, hp_eq⟩
  refine ⟨ΔA, hΔ, ?_⟩
  intro B hLeft hRight
  have hlin :
      |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
          |A_inv p.1 p.2| =
        ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E := by
    calc
      |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
          |A_inv p.1 p.2|
          = Finset.sup' Finset.univ hne
              (fun p : Fin n × Fin n =>
                |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
                  |A_inv p.1 p.2|) := hp_eq.symm
      _ = ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA := rfl
      _ = ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E := hmaxlin
  exact
    problem7_11_exact_inverse_relative_change_max_ge_condition_minus_quadratic_of_linearized_attainer
      n hn A A_inv ΔA E B ε p.1 p.2 hε hE hden hΔ hLeft hRight hlin

/-- Finite maximum version of the exact Problem 7.11 upper estimate.  It is
the source `lim sup` upper-bound route before taking the remaining asymptotic
limit: the first-order term is the linearized condition number and the leftover
term is explicitly quadratic in `ε`. -/
theorem problem7_11_exact_inverse_relative_change_max_le_condition_plus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    ch7InverseExactRelativeChangeMax n hn A_inv B ≤
      ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E +
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
  unfold ch7InverseExactRelativeChangeMax
  apply Finset.sup'_le
  intro p _
  have hentry :=
    problem7_11_exact_inverse_relative_entry_le_linearized_plus_quadratic
      n A A_inv ΔA E B ε p.1 p.2 hε hE (hden p.1 p.2) hΔ hLeft hRight
  have hlin :=
    ch7_inverseLinearizedRatio_le n A_inv ΔA E ε p.1 p.2
      hε hE (hden p.1 p.2) hΔ
  have hlinMax :
      |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| / |A_inv p.1 p.2| ≤
        ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E := by
    calc
      |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| / |A_inv p.1 p.2|
          ≤ ε * ch7InverseCompSensitivityRatio n A_inv E p.1 p.2 := hlin
      _ ≤ ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E := by
          unfold ch7InverseComponentwiseLinearizedCond
          exact mul_le_mul_of_nonneg_left
            (Finset.le_sup'
              (fun p : Fin n × Fin n =>
                ch7InverseCompSensitivityRatio n A_inv E p.1 p.2)
              (Finset.mem_univ p))
            hε
  have hquad :
      ε ^ 2 *
          (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
            |A_inv p.1 p.2|) ≤
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
    apply mul_le_mul_of_nonneg_left
    · unfold ch7InverseQuadraticRemainderRelativeMax
      exact Finset.le_sup'
        (fun p : Fin n × Fin n =>
          ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
            |A_inv p.1 p.2|)
        (Finset.mem_univ p)
    · exact sq_nonneg ε
  calc
    |B p.1 p.2 - A_inv p.1 p.2| / |A_inv p.1 p.2|
        ≤ |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
            |A_inv p.1 p.2| +
          ε ^ 2 *
            (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
              |A_inv p.1 p.2|) := hentry
    _ ≤ ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E +
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B :=
          add_le_add hlinMax hquad

/-- Exact nonlinear inverse changes are bounded above by the finite linearized
maximum plus the explicit quadratic envelope.  This is the upper half of the
source `(7.25)` asymptotic squeeze before dividing by `ε`. -/
theorem problem7_11_exact_inverse_relative_change_max_le_linearized_max_plus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    ch7InverseExactRelativeChangeMax n hn A_inv B ≤
      ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA +
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
  unfold ch7InverseExactRelativeChangeMax
  apply Finset.sup'_le
  intro p _
  have hentry :=
    problem7_11_exact_inverse_relative_entry_le_linearized_plus_quadratic
      n A A_inv ΔA E B ε p.1 p.2 hε hE (hden p.1 p.2) hΔ hLeft hRight
  have hlinMax :
      |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| / |A_inv p.1 p.2| ≤
        ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA := by
    unfold ch7InverseLinearizedRelativeChangeMax
    exact Finset.le_sup'
      (fun p : Fin n × Fin n =>
        |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| / |A_inv p.1 p.2|)
      (Finset.mem_univ p)
  have hquad :
      ε ^ 2 *
          (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
            |A_inv p.1 p.2|) ≤
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
    apply mul_le_mul_of_nonneg_left
    · unfold ch7InverseQuadraticRemainderRelativeMax
      exact Finset.le_sup'
        (fun p : Fin n × Fin n =>
          ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
            |A_inv p.1 p.2|)
        (Finset.mem_univ p)
    · exact sq_nonneg ε
  calc
    |B p.1 p.2 - A_inv p.1 p.2| / |A_inv p.1 p.2|
        ≤ |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
            |A_inv p.1 p.2| +
          ε ^ 2 *
            (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
              |A_inv p.1 p.2|) := hentry
    _ ≤ ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA +
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B :=
          add_le_add hlinMax hquad

/-- Exact nonlinear inverse changes are bounded below by the finite linearized
maximum minus the explicit quadratic envelope.  This is the lower half of the
source `(7.25)` asymptotic squeeze before dividing by `ε`. -/
theorem problem7_11_exact_inverse_relative_change_max_ge_linearized_max_minus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA -
      ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
        ch7InverseExactRelativeChangeMax n hn A_inv B := by
  let hne : (Finset.univ : Finset (Fin n × Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨(⟨0, hn⟩, ⟨0, hn⟩)⟩
  rcases
    Finset.exists_mem_eq_sup' (s := Finset.univ) hne
      (fun p : Fin n × Fin n =>
        |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
          |A_inv p.1 p.2|) with
    ⟨p, _hp, hp_eq⟩
  have hlin_eq :
      ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA =
        |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| /
          |A_inv p.1 p.2| := by
    simpa [ch7InverseLinearizedRelativeChangeMax] using hp_eq
  have hentry :=
    problem7_11_exact_inverse_relative_change_max_ge_linearized_entry_minus_quadratic
      n hn A A_inv ΔA E B ε p.1 p.2 hε hE hden hΔ hLeft hRight
  have hratio_le :
      ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
          |A_inv p.1 p.2| ≤
        ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
    unfold ch7InverseQuadraticRemainderRelativeMax
    exact Finset.le_sup'
      (fun p : Fin n × Fin n =>
        ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
          |A_inv p.1 p.2|)
      (Finset.mem_univ p)
  have hquad :
      ε ^ 2 *
          (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
            |A_inv p.1 p.2|) ≤
        ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B :=
    mul_le_mul_of_nonneg_left hratio_le (sq_nonneg ε)
  have hsub :
      ch7InverseLinearizedRelativeChangeMax n hn A_inv ΔA -
          ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
        |ch7InverseLinearizedEntry n A_inv ΔA p.1 p.2| / |A_inv p.1 p.2| -
          ε ^ 2 *
            (ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
              |A_inv p.1 p.2|) := by
    rw [hlin_eq]
    linarith
  exact le_trans hsub hentry

/-- The finite relative quadratic-remainder coefficient is nonnegative. -/
theorem ch7InverseQuadraticRemainderRelativeMax_nonneg (n : ℕ) (hn : 0 < n)
    (A_inv E B : Fin n → Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) :
    0 ≤ ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
  let p0 : Fin n × Fin n := (⟨0, hn⟩, ⟨0, hn⟩)
  have hentry :
      0 ≤
        ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p0.1 p0.2 /
          |A_inv p0.1 p0.2| := by
    exact div_nonneg
      (ch7InverseQuadraticRemainderSensitivityEntry_nonneg n A_inv E B hE p0.1 p0.2)
      (abs_nonneg _)
  unfold ch7InverseQuadraticRemainderRelativeMax
  exact le_trans hentry
    (Finset.le_sup'
      (fun p : Fin n × Fin n =>
        ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
          |A_inv p.1 p.2|)
      (Finset.mem_univ p0))

/-- The entrywise inverse-bound envelope for the Problem 7.11 quadratic
relative coefficient is nonnegative. -/
theorem ch7InverseQuadraticRemainderRelativeMaxEntryBound_nonneg
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) (C_B : ℝ)
    (hE : ∀ i j, 0 ≤ E i j) (hCB : 0 ≤ C_B) :
    0 ≤ ch7InverseQuadraticRemainderRelativeMaxEntryBound n hn A_inv E C_B := by
  let p0 : Fin n × Fin n := (⟨0, hn⟩, ⟨0, hn⟩)
  let P := ch7InverseFirstProductSensitivity n A_inv E
  let Cmat : Fin n → Fin n → ℝ := fun _ _ => C_B
  have hP : ∀ i j, 0 ≤ P i j := by
    intro i j
    exact ch7InverseFirstProductSensitivity_nonneg n A_inv E hE i j
  have hCmat : ∀ i j, 0 ≤ Cmat i j := by
    intro i j
    exact hCB
  have hPC : ∀ i j, 0 ≤ matMul n P Cmat i j :=
    ch7_matMul_nonneg n P Cmat hP hCmat
  have hentry :
      0 ≤ matMul n P (matMul n P Cmat) p0.1 p0.2 /
        |A_inv p0.1 p0.2| := by
    exact div_nonneg
      (ch7_matMul_nonneg n P (matMul n P Cmat) hP hPC p0.1 p0.2)
      (abs_nonneg _)
  unfold ch7InverseQuadraticRemainderRelativeMaxEntryBound
  dsimp [P, Cmat] at hentry ⊢
  exact le_trans hentry
    (Finset.le_sup'
      (fun p : Fin n × Fin n =>
        matMul n (ch7InverseFirstProductSensitivity n A_inv E)
          (matMul n (ch7InverseFirstProductSensitivity n A_inv E)
            (fun _ _ => C_B)) p.1 p.2 /
          |A_inv p.1 p.2|)
      (Finset.mem_univ p0))

/-- The Problem 7.11 relative quadratic-remainder coefficient is bounded by
the source-facing finite envelope associated with any entrywise bound on the
exact perturbed inverse. -/
theorem ch7InverseQuadraticRemainderRelativeMax_le_of_entry_bound
    (n : ℕ) (hn : 0 < n)
    (A_inv E B : Fin n → Fin n → ℝ) (C_B : ℝ)
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hB : ∀ i j, |B i j| ≤ C_B) :
    ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
      ch7InverseQuadraticRemainderRelativeMaxEntryBound n hn A_inv E C_B := by
  unfold ch7InverseQuadraticRemainderRelativeMax
  apply Finset.sup'_le
  intro p _
  have hentry :=
    ch7InverseQuadraticRemainderSensitivityEntry_le_of_entry_bound
      n A_inv E B C_B hE hB p.1 p.2
  have hratio :
      ch7InverseQuadraticRemainderSensitivityEntry n A_inv E B p.1 p.2 /
          |A_inv p.1 p.2| ≤
        matMul n (ch7InverseFirstProductSensitivity n A_inv E)
          (matMul n (ch7InverseFirstProductSensitivity n A_inv E)
            (fun _ _ => C_B)) p.1 p.2 /
          |A_inv p.1 p.2| := by
    exact div_le_div_of_nonneg_right hentry (le_of_lt (hden p.1 p.2))
  refine le_trans hratio ?_
  unfold ch7InverseQuadraticRemainderRelativeMaxEntryBound
  exact Finset.le_sup'
    (fun q : Fin n × Fin n =>
      matMul n (ch7InverseFirstProductSensitivity n A_inv E)
        (matMul n (ch7InverseFirstProductSensitivity n A_inv E)
          (fun _ _ => C_B)) q.1 q.2 /
        |A_inv q.1 q.2|)
    (Finset.mem_univ p)

/-- Absolute-value version of
`ch7InverseQuadraticRemainderRelativeMax_le_of_entry_bound`, ready for the
filter-level asymptotic theorem. -/
theorem ch7InverseQuadraticRemainderRelativeMax_abs_le_of_entry_bound
    (n : ℕ) (hn : 0 < n)
    (A_inv E B : Fin n → Fin n → ℝ) (C_B : ℝ)
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hB : ∀ i j, |B i j| ≤ C_B) :
    |ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B| ≤
      ch7InverseQuadraticRemainderRelativeMaxEntryBound n hn A_inv E C_B := by
  rw [abs_of_nonneg (ch7InverseQuadraticRemainderRelativeMax_nonneg n hn A_inv E B hE)]
  exact
    ch7InverseQuadraticRemainderRelativeMax_le_of_entry_bound
      n hn A_inv E B C_B hE hden hB

/-- Each matrix entry is bounded in absolute value by the matrix infinity
norm.  This local Chapter 7 adapter avoids importing the Chapter 9 LU growth
module solely for its identical helper. -/
lemma ch7_abs_entry_le_infNorm {n : ℕ} (B : Fin n → Fin n → ℝ)
    (i j : Fin n) : |B i j| ≤ infNorm B := by
  have hrow : |B i j| ≤ ∑ j' : Fin n, |B i j'| :=
    Finset.single_le_sum (fun j' _ => abs_nonneg (B i j')) (Finset.mem_univ j)
  exact le_trans hrow (row_sum_le_infNorm B i)

/-- The Problem 7.11 relative quadratic-remainder coefficient is bounded by
the source-facing finite envelope whenever the exact perturbed inverse is
bounded in matrix infinity norm. -/
theorem ch7InverseQuadraticRemainderRelativeMax_le_of_infNorm_bound
    (n : ℕ) (hn : 0 < n)
    (A_inv E B : Fin n → Fin n → ℝ) (C_B : ℝ)
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hBnorm : infNorm B ≤ C_B) :
    ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
      ch7InverseQuadraticRemainderRelativeMaxEntryBound n hn A_inv E C_B := by
  exact
    ch7InverseQuadraticRemainderRelativeMax_le_of_entry_bound
      n hn A_inv E B C_B hE hden
      (fun i j => le_trans (ch7_abs_entry_le_infNorm B i j) hBnorm)

/-- Absolute-value version of
`ch7InverseQuadraticRemainderRelativeMax_le_of_infNorm_bound`, ready for
filter-level Problem 7.11 asymptotic bridges. -/
theorem ch7InverseQuadraticRemainderRelativeMax_abs_le_of_infNorm_bound
    (n : ℕ) (hn : 0 < n)
    (A_inv E B : Fin n → Fin n → ℝ) (C_B : ℝ)
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hBnorm : infNorm B ≤ C_B) :
    |ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B| ≤
      ch7InverseQuadraticRemainderRelativeMaxEntryBound n hn A_inv E C_B := by
  exact
    ch7InverseQuadraticRemainderRelativeMax_abs_le_of_entry_bound
      n hn A_inv E B C_B hE hden
      (fun i j => le_trans (ch7_abs_entry_le_infNorm B i j) hBnorm)

/-- Source-local notation for `I + C`, used by the Problem 7.11 local inverse
existence package. -/
noncomputable def ch7MatAddId (n : ℕ) (C : Fin n → Fin n → ℝ) :
    Fin n → Fin n → ℝ :=
  fun i j => idMatrix n i j + C i j

/-- In finite square real matrices, a left inverse is also a right inverse.
This small adapter lets the Problem 7.11 Neumann factorization use the existing
left-inverse certificate for `A⁻¹A = I` without adding a theorem-equivalent
right-inverse hypothesis. -/
theorem ch7_isRightInverse_of_isLeftInverse {n : ℕ}
    {A A_inv : Fin n → Fin n → ℝ}
    (hLeft : IsLeftInverse n A A_inv) :
    IsRightInverse n A A_inv := by
  have hmatLeft :
      (Matrix.of A_inv : Matrix (Fin n) (Fin n) ℝ) *
          (Matrix.of A : Matrix (Fin n) (Fin n) ℝ) = 1 := by
    ext i j
    simpa [Matrix.mul_apply, Matrix.of_apply, idMatrix] using hLeft i j
  have hmatRight :
      (Matrix.of A : Matrix (Fin n) (Fin n) ℝ) *
          (Matrix.of A_inv : Matrix (Fin n) (Fin n) ℝ) = 1 :=
    (mul_eq_one_comm.mp hmatLeft)
  intro i j
  have hij := congrArg (fun M : Matrix (Fin n) (Fin n) ℝ => M i j) hmatRight
  simpa [Matrix.mul_apply, Matrix.of_apply, idMatrix] using hij

/-- Neumann-style resolution for `I + C`: if `‖ |C| ‖∞ ≤ c < 1` and
`(I + C)w = v`, then each entry of `w` is bounded by
`(1-c)⁻¹ * sum |v|`. -/
theorem ch7_matAdd_id_abs_solution_bound_of_abs_infNorm_bound
    (n : ℕ) (hn : 0 < n)
    (C : Fin n → Fin n → ℝ) (c : ℝ)
    (hc_nn : 0 ≤ c) (hc_lt : c < 1)
    (hbound : infNormBound n (absMatrix n C) c)
    (v w : Fin n → ℝ)
    (hsolve : ∀ i,
      w i + ∑ j : Fin n, C i j * w j = v i) :
    ∀ i, |w i| ≤ (1 / (1 - c)) * ∑ j : Fin n, |v j| := by
  let M : Fin n → Fin n → ℝ := absMatrix n C
  let z : Fin n → ℝ := fun i => |w i|
  let rhs : Fin n → ℝ := fun i => |v i|
  have hM : ∀ i j, 0 ≤ M i j := by
    intro i j
    exact abs_nonneg _
  have hrhs : ∀ i, 0 ≤ rhs i := by
    intro i
    exact abs_nonneg _
  have hz : ∀ i, 0 ≤ z i := by
    intro i
    exact abs_nonneg _
  have hineq : ∀ i, z i ≤ rhs i + ∑ j : Fin n, M i j * z j := by
    intro i
    have hwi : w i = v i - ∑ j : Fin n, C i j * w j := by
      linarith [hsolve i]
    calc
      z i = |v i - ∑ j : Fin n, C i j * w j| := by
          simp [z, hwi]
      _ ≤ |v i| + |∑ j : Fin n, C i j * w j| := by
          simpa [sub_eq_add_neg] using abs_add_le (v i) (-(∑ j : Fin n, C i j * w j))
      _ ≤ |v i| + ∑ j : Fin n, |C i j * w j| := by
          have hsum :
              |∑ j : Fin n, C i j * w j| ≤
                ∑ j : Fin n, |C i j * w j| :=
            Finset.abs_sum_le_sum_abs (fun j : Fin n => C i j * w j) Finset.univ
          linarith
      _ = rhs i + ∑ j : Fin n, M i j * z j := by
          unfold rhs M z absMatrix
          congr 1
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_mul]
  exact
    problem7_1_neumann_componentwise_inequality_bound n hn M hM c hc_nn hc_lt
      hbound rhs z hrhs hz hineq

/-- If `‖ |C| ‖∞ ≤ c < 1`, then `I + C` is nonsingular. -/
theorem ch7_matAdd_id_det_ne_zero_of_abs_infNorm_bound
    (n : ℕ) (hn : 0 < n)
    (C : Fin n → Fin n → ℝ) (c : ℝ)
    (hc_nn : 0 ≤ c) (hc_lt : c < 1)
    (hbound : infNormBound n (absMatrix n C) c) :
    Matrix.det (ch7MatAddId n C : Matrix (Fin n) (Fin n) ℝ) ≠ 0 := by
  intro hdet
  have hex :
      ∃ w : Fin n → ℝ, w ≠ 0 ∧
        Matrix.mulVec (ch7MatAddId n C : Matrix (Fin n) (Fin n) ℝ) w = 0 :=
    (Matrix.exists_mulVec_eq_zero_iff
      (M := (ch7MatAddId n C : Matrix (Fin n) (Fin n) ℝ))).2 hdet
  rcases hex with ⟨w, hw_ne, hmul_zero⟩
  have hsolve : ∀ i,
      w i + ∑ j : Fin n, C i j * w j = (0 : ℝ) := by
    intro i
    have hi := congrFun hmul_zero i
    change (∑ j : Fin n, ch7MatAddId n C i j * w j) = 0 at hi
    unfold ch7MatAddId at hi
    simp_rw [add_mul, Finset.sum_add_distrib] at hi
    have hid : (∑ j : Fin n, idMatrix n i j * w j) = w i := by
      unfold idMatrix
      simp [Finset.sum_ite_eq, Finset.mem_univ]
    rwa [hid] at hi
  have hzero :=
    ch7_matAdd_id_abs_solution_bound_of_abs_infNorm_bound n hn C c
      hc_nn hc_lt hbound (fun _ : Fin n => (0 : ℝ)) w hsolve
  have hw_zero : w = 0 := by
    ext i
    have habs_nonpos : |w i| ≤ 0 := by
      simpa using hzero i
    exact abs_eq_zero.mp (le_antisymm habs_nonpos (abs_nonneg _))
  exact hw_ne hw_zero

/-- Entrywise bound on the repository inverse of `I + C` under a strict
absolute infinity-norm contraction. -/
theorem ch7_nonsingInv_matAdd_id_entry_abs_le_of_abs_infNorm_bound
    (n : ℕ) (hn : 0 < n)
    (C : Fin n → Fin n → ℝ) (c : ℝ)
    (hc_nn : 0 ≤ c) (hc_lt : c < 1)
    (hbound : infNormBound n (absMatrix n C) c) :
    ∀ i j,
      |nonsingInv n (ch7MatAddId n C) i j| ≤ 1 / (1 - c) := by
  have hdet :=
    ch7_matAdd_id_det_ne_zero_of_abs_infNorm_bound n hn C c
      hc_nn hc_lt hbound
  have hInv : IsInverse n (ch7MatAddId n C) (nonsingInv n (ch7MatAddId n C)) :=
    isInverse_nonsingInv_of_det_ne_zero n (ch7MatAddId n C) hdet
  intro i j
  let e : Fin n → ℝ := fun k => if k = j then (1 : ℝ) else 0
  let w : Fin n → ℝ := fun k => nonsingInv n (ch7MatAddId n C) k j
  have hsolve : ∀ k, w k + ∑ l : Fin n, C k l * w l = e k := by
    intro k
    have hk := hInv.2 k j
    dsimp [w, e]
    change (∑ l : Fin n, (idMatrix n k l + C k l) *
        nonsingInv n (ch7MatAddId n C) l j) = (if k = j then 1 else 0) at hk
    simp_rw [add_mul, Finset.sum_add_distrib] at hk
    have hid :
        (∑ l : Fin n, idMatrix n k l *
            nonsingInv n (ch7MatAddId n C) l j) =
          nonsingInv n (ch7MatAddId n C) k j := by
      unfold idMatrix
      simp [Finset.sum_ite_eq, Finset.mem_univ]
    simpa [hid] using hk
  have hbound_entry :=
    ch7_matAdd_id_abs_solution_bound_of_abs_infNorm_bound n hn C c
      hc_nn hc_lt hbound e w hsolve i
  have hsum_e : (∑ k : Fin n, |e k|) = 1 := by
    unfold e
    calc
      ∑ k : Fin n, |if k = j then (1 : ℝ) else 0|
          = ∑ k : Fin n, (if k = j then (1 : ℝ) else 0) := by
            apply Finset.sum_congr rfl
            intro k _
            split <;> simp
      _ = 1 := by
            simp [Finset.mem_univ]
  simpa [w, hsum_e] using hbound_entry

/-- Infinity-norm bound on the repository inverse of `I + C` under a strict
absolute infinity-norm contraction. -/
theorem ch7_nonsingInv_matAdd_id_infNorm_le_of_abs_infNorm_bound
    (n : ℕ) (hn : 0 < n)
    (C : Fin n → Fin n → ℝ) (c : ℝ)
    (hc_nn : 0 ≤ c) (hc_lt : c < 1)
    (hbound : infNormBound n (absMatrix n C) c) :
    infNorm (nonsingInv n (ch7MatAddId n C)) ≤
      (n : ℝ) * (1 / (1 - c)) := by
  have hentry :=
    ch7_nonsingInv_matAdd_id_entry_abs_le_of_abs_infNorm_bound n hn C c
      hc_nn hc_lt hbound
  have hcden : 0 < 1 - c := by linarith
  have hinv_nonneg : 0 ≤ 1 / (1 - c) := by positivity
  apply infNorm_le_of_row_sum_le
  · intro i
    calc
      ∑ j : Fin n, |nonsingInv n (ch7MatAddId n C) i j|
          ≤ ∑ j : Fin n, 1 / (1 - c) := by
            apply Finset.sum_le_sum
            intro j _
            exact hentry i j
      _ = (n : ℝ) * (1 / (1 - c)) := by
            simp
  · exact mul_nonneg (Nat.cast_nonneg n) hinv_nonneg

/-- The explicit inverse candidate for `A + ΔA` obtained from the factorization
`A + ΔA = A (I + A⁻¹ΔA)`. -/
noncomputable def ch7Problem711PerturbedInverseCandidate (n : ℕ)
    (A_inv ΔA : Fin n → Fin n → ℝ) : Fin n → Fin n → ℝ :=
  let C := matMul n A_inv ΔA
  matMul n (nonsingInv n (ch7MatAddId n C)) A_inv

/-- The source-local inverse existence package for Problem 7.11: if
`‖ |A⁻¹ΔA| ‖∞ ≤ c < 1`, the explicit Neumann candidate is a certified right
inverse of `A + ΔA`. -/
theorem problem7_11_perturbed_inverse_candidate_right_inverse_of_abs_left_product_bound
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA : Fin n → Fin n → ℝ) (c : ℝ)
    (hc_nn : 0 ≤ c) (hc_lt : c < 1)
    (hLeft : IsLeftInverse n A A_inv)
    (hbound : infNormBound n (absMatrix n (matMul n A_inv ΔA)) c) :
    IsRightInverse n (fun i j => A i j + ΔA i j)
      (ch7Problem711PerturbedInverseCandidate n A_inv ΔA) := by
  let C : Fin n → Fin n → ℝ := matMul n A_inv ΔA
  let T : Fin n → Fin n → ℝ := ch7MatAddId n C
  let R : Fin n → Fin n → ℝ := nonsingInv n T
  have hRightA : IsRightInverse n A A_inv :=
    ch7_isRightInverse_of_isLeftInverse hLeft
  have hdet : Matrix.det (T : Matrix (Fin n) (Fin n) ℝ) ≠ 0 := by
    exact ch7_matAdd_id_det_ne_zero_of_abs_infNorm_bound n hn C c
      hc_nn hc_lt hbound
  have hR : IsRightInverse n T R :=
    (isInverse_nonsingInv_of_det_ne_zero n T hdet).2
  have hfactor : matMul n A T = fun i j => A i j + ΔA i j := by
    ext i j
    unfold matMul T ch7MatAddId C
    simp_rw [mul_add, Finset.sum_add_distrib]
    have hid : (∑ k : Fin n, A i k * idMatrix n k j) = A i j := by
      unfold idMatrix
      simp [Finset.sum_ite_eq', Finset.mem_univ]
    rw [hid]
    congr 1
    calc
      ∑ k : Fin n, A i k * (∑ l : Fin n, A_inv k l * ΔA l j)
          = ∑ l : Fin n, (∑ k : Fin n, A i k * A_inv k l) * ΔA l j := by
            simp_rw [Finset.mul_sum]
            rw [Finset.sum_comm]
            apply Finset.sum_congr rfl
            intro l _
            rw [Finset.sum_mul]
            apply Finset.sum_congr rfl
            intro k _
            ring
      _ = ∑ l : Fin n, idMatrix n i l * ΔA l j := by
            apply Finset.sum_congr rfl
            intro l _
            rw [hRightA i l]
            simp [idMatrix]
      _ = ΔA i j := by
            unfold idMatrix
            simp [Finset.sum_ite_eq, Finset.mem_univ]
  intro i j
  have hcalc := congrFun (congrFun
    (calc
      matMul n (fun i j => A i j + ΔA i j)
          (ch7Problem711PerturbedInverseCandidate n A_inv ΔA)
          = matMul n (matMul n A T) (matMul n R A_inv) := by
              rw [hfactor]
              rfl
      _ = matMul n A (matMul n T (matMul n R A_inv)) := by
              rw [matMul_assoc]
      _ = matMul n A (matMul n (matMul n T R) A_inv) := by
              rw [matMul_assoc]
      _ = matMul n A (matMul n (idMatrix n) A_inv) := by
              congr 1
              ext p q
              unfold matMul
              apply Finset.sum_congr rfl
              intro k _
              rw [hR p k]
              simp [idMatrix]
      _ = matMul n A A_inv := by
              rw [matMul_id_left]
      _ = idMatrix n := by
              ext p q
              exact hRightA p q) i) j
  simpa [idMatrix] using hcalc

/-- The same local inverse package gives a concrete infinity-norm bound for
the explicit perturbed inverse candidate. -/
theorem problem7_11_perturbed_inverse_candidate_infNorm_bound_of_abs_left_product_bound
    (n : ℕ) (hn : 0 < n)
    (A_inv ΔA : Fin n → Fin n → ℝ) (c : ℝ)
    (hc_nn : 0 ≤ c) (hc_lt : c < 1)
    (hbound : infNormBound n (absMatrix n (matMul n A_inv ΔA)) c) :
    infNorm (ch7Problem711PerturbedInverseCandidate n A_inv ΔA) ≤
      ((n : ℝ) * (1 / (1 - c))) * infNorm A_inv := by
  let C : Fin n → Fin n → ℝ := matMul n A_inv ΔA
  let R : Fin n → Fin n → ℝ := nonsingInv n (ch7MatAddId n C)
  have hRnorm :
      infNorm R ≤ (n : ℝ) * (1 / (1 - c)) := by
    exact ch7_nonsingInv_matAdd_id_infNorm_le_of_abs_infNorm_bound
      n hn C c hc_nn hc_lt hbound
  have hmul :
      infNorm (matMul n R A_inv) ≤ infNorm R * infNorm A_inv :=
    infNorm_matMul_le hn R A_inv
  calc
    infNorm (ch7Problem711PerturbedInverseCandidate n A_inv ΔA)
        = infNorm (matMul n R A_inv) := by
          rfl
    _ ≤ infNorm R * infNorm A_inv := hmul
    _ ≤ ((n : ℝ) * (1 / (1 - c))) * infNorm A_inv :=
        mul_le_mul_of_nonneg_right hRnorm (infNorm_nonneg A_inv)

/-- Componentwise admissibility `|ΔA| ≤ εE` implies an infinity-norm bound on
`|A⁻¹ΔA|` by `ε ‖ |A⁻¹|E ‖∞`. -/
theorem ch7_abs_left_product_infNorm_le_of_componentwise_bound
    (n : ℕ)
    (A_inv ΔA E : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j) :
    infNorm (absMatrix n (matMul n A_inv ΔA)) ≤
      ε * infNorm (ch7InverseFirstProductSensitivity n A_inv E) := by
  let P : Fin n → Fin n → ℝ := ch7InverseFirstProductSensitivity n A_inv E
  have hP : ∀ i j, 0 ≤ P i j := by
    intro i j
    exact ch7InverseFirstProductSensitivity_nonneg n A_inv E hE i j
  have hentry : ∀ i j,
      |matMul n A_inv ΔA i j| ≤ ε * P i j := by
    intro i j
    exact ch7_inverseFirstProduct_abs_le n A_inv ΔA E ε hε hE hΔ i j
  have hrows : ∀ i : Fin n,
      ∑ j : Fin n, |absMatrix n (matMul n A_inv ΔA) i j| ≤
        ε * infNorm P := by
    intro i
    calc
      ∑ j : Fin n, |absMatrix n (matMul n A_inv ΔA) i j|
          = ∑ j : Fin n, |matMul n A_inv ΔA i j| := by
            unfold absMatrix
            apply Finset.sum_congr rfl
            intro j _
            rw [abs_of_nonneg (abs_nonneg _)]
      _ ≤ ∑ j : Fin n, ε * P i j := by
            apply Finset.sum_le_sum
            intro j _
            exact hentry i j
      _ = ε * ∑ j : Fin n, P i j := by
            rw [Finset.mul_sum]
      _ ≤ ε * infNorm P := by
            have hrowP :
                ∑ j : Fin n, P i j = ∑ j : Fin n, |P i j| := by
              apply Finset.sum_congr rfl
              intro j _
              exact (abs_of_nonneg (hP i j)).symm
            rw [hrowP]
            exact mul_le_mul_of_nonneg_left (row_sum_le_infNorm P i) hε
  have htarget_nonneg : 0 ≤ ε * infNorm P :=
    mul_nonneg hε (infNorm_nonneg P)
  exact infNorm_le_of_row_sum_le (absMatrix n (matMul n A_inv ΔA)) hrows htarget_nonneg

/-- If `ε → 0` and `|ΔA(t)| ≤ ε(t)E` eventually, then `|A⁻¹ΔA(t)|`
eventually has infinity norm at most `1/2`. -/
theorem problem7_11_eventually_abs_left_product_infNormBound_half_of_componentwise_tendsto_zero
    {ι : Type*} {l : Filter ι}
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ)
    (ΔA : ι → Fin n → Fin n → ℝ) (ε : ι → ℝ)
    (hε_pos : Filter.Eventually (fun t => 0 < ε t) l)
    (hε_tendsto : Filter.Tendsto ε l (nhds 0))
    (hE : ∀ i j, 0 ≤ E i j)
    (hΔ : Filter.Eventually
      (fun t => ∀ i j, |ΔA t i j| ≤ ε t * E i j) l) :
    Filter.Eventually
      (fun t =>
        infNormBound n (absMatrix n (matMul n A_inv (ΔA t))) (1 / 2)) l := by
  let P : Fin n → Fin n → ℝ := ch7InverseFirstProductSensitivity n A_inv E
  have hprod_tendsto :
      Filter.Tendsto (fun t => ε t * infNorm P) l (nhds 0) := by
    simpa using hε_tendsto.mul_const (infNorm P)
  have hsmall : Filter.Eventually (fun t => ε t * infNorm P ≤ (1 / 2 : ℝ)) l := by
    have hmetric := (Metric.tendsto_nhds.mp hprod_tendsto) (1 / 2 : ℝ) (by norm_num)
    filter_upwards [hmetric] with t ht
    have habs : |ε t * infNorm P| < (1 / 2 : ℝ) := by
      simpa [Real.dist_eq] using ht
    exact le_of_lt ((le_abs_self (ε t * infNorm P)).trans_lt habs)
  filter_upwards [hε_pos, hΔ, hsmall] with t hεt_pos hΔt hsmallt
  have hεt : 0 ≤ ε t := le_of_lt hεt_pos
  have hleft :=
    ch7_abs_left_product_infNorm_le_of_componentwise_bound
      n A_inv (ΔA t) E (ε t) hεt hE hΔt
  exact le_trans hleft hsmallt

/-- Finite-radius version of the nonlinear Problem 7.11 upper route.  Once
the quadratic relative coefficient is bounded by `C` on a perturbation radius
`ε ≤ δ`, the exact inverse change is bounded by
`ε * (µ'_lin + δ*C)`.  This is the finite dependency needed before the remaining
source `lim sup` wrapper. -/
theorem problem7_11_exact_inverse_relative_change_max_le_condition_plus_radius_bound
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA E B : Fin n → Fin n → ℝ) (ε δ C : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B)
    (hεδ : ε ≤ δ)
    (hR : ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤ C) :
    ch7InverseExactRelativeChangeMax n hn A_inv B ≤
      ε * (ch7InverseComponentwiseLinearizedCond n hn A_inv E + δ * C) := by
  have hfinite :=
    problem7_11_exact_inverse_relative_change_max_le_condition_plus_quadratic
      n hn A A_inv ΔA E B ε hε hE hden hΔ hLeft hRight
  have hδ : 0 ≤ δ := le_trans hε hεδ
  have hRnonneg :
      0 ≤ ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B :=
    ch7InverseQuadraticRemainderRelativeMax_nonneg n hn A_inv E B hE
  have hquadInner :
      ε * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤ δ * C :=
    mul_le_mul hεδ hR hRnonneg hδ
  have hquad :
      ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
        ε * (δ * C) := by
    calc
      ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B
          = ε * (ε * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B) := by
            ring
      _ ≤ ε * (δ * C) := mul_le_mul_of_nonneg_left hquadInner hε
  calc
    ch7InverseExactRelativeChangeMax n hn A_inv B
        ≤ ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E +
          ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := hfinite
    _ ≤ ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E +
        ε * (δ * C) := add_le_add le_rfl hquad
    _ = ε * (ch7InverseComponentwiseLinearizedCond n hn A_inv E + δ * C) := by
          ring

/-- The asymptotic vanishing step for the Problem 7.11 quadratic envelope:
after dividing the exact `ε²R` remainder by `ε`, the term `εR` tends to zero
whenever `ε → 0` and the relative remainder coefficient is eventually bounded.
This leaves only the source task of proving that boundedness for inverses
`(A + ΔA)⁻¹` in a small perturbation radius. -/
theorem problem7_11_quadratic_remainder_relative_scaled_tendsto_zero_of_eventually_bounded
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ)
    (B : ι → Fin n → Fin n → ℝ)
    (ε : ι → ℝ) (C : ℝ)
    (hC : 0 ≤ C)
    (hε : Filter.Tendsto ε l (nhds 0))
    (hbound : Filter.Eventually
      (fun t => |ch7InverseQuadraticRemainderRelativeMax n hn A_inv E (B t)| ≤ C) l) :
    Filter.Tendsto
      (fun t => ε t * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E (B t))
      l (nhds 0) := by
  have h :=
    tendsto_const_mul_of_tendsto_zero_of_eventually_abs_le
      (K := 1) (d := ε)
      (b := fun t => ch7InverseQuadraticRemainderRelativeMax n hn A_inv E (B t))
      (B := C) (by norm_num) hC hε hbound
  simpa [one_mul] using h

/-- Problem 7.11 asymptotic bridge from the exact nonlinear inverse-change
family to its finite linearization.  If `ε → 0`, the perturbations are
componentwise admissible, the exact perturbed inverses exist as right inverses,
and the quadratic relative coefficient is eventually bounded, then
`max |B - A⁻¹|/|A⁻¹| / ε` has the same limit as the linearized maximum divided
by `ε`.  This is the source `(7.25)` squeeze step with the remaining inverse
existence and local boundedness hypotheses left explicit. -/
theorem problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_quadratic_bound
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ)
    (ΔA B : ι → Fin n → Fin n → ℝ)
    (ε : ι → ℝ) (μ C : ℝ)
    (hC : 0 ≤ C)
    (hε_pos : Filter.Eventually (fun t => 0 < ε t) l)
    (hε_tendsto : Filter.Tendsto ε l (nhds 0))
    (hlin_tendsto :
      Filter.Tendsto
        (fun t => ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t)
        l (nhds μ))
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : Filter.Eventually
      (fun t => ∀ i j, |ΔA t i j| ≤ ε t * E i j) l)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : Filter.Eventually
      (fun t => IsRightInverse n (fun i j => A i j + ΔA t i j) (B t)) l)
    (hbound : Filter.Eventually
      (fun t => |ch7InverseQuadraticRemainderRelativeMax n hn A_inv E (B t)| ≤ C) l) :
    Filter.Tendsto
      (fun t => ch7InverseExactRelativeChangeMax n hn A_inv (B t) / ε t)
      l (nhds μ) := by
  let R : ι → ℝ := fun t =>
    ch7InverseQuadraticRemainderRelativeMax n hn A_inv E (B t)
  have hrem :
      Filter.Tendsto (fun t => ε t * R t) l (nhds 0) := by
    exact
      problem7_11_quadratic_remainder_relative_scaled_tendsto_zero_of_eventually_bounded
        n hn A_inv E B ε C hC hε_tendsto hbound
  have hlower :
      Filter.Tendsto
        (fun t =>
          ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t -
            ε t * R t) l (nhds μ) := by
    simpa using hlin_tendsto.sub hrem
  have hupper :
      Filter.Tendsto
        (fun t =>
          ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t +
            ε t * R t) l (nhds μ) := by
    simpa using hlin_tendsto.add hrem
  have hbetween :
      Filter.Eventually
        (fun t =>
          ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t -
              ε t * R t ≤
            ch7InverseExactRelativeChangeMax n hn A_inv (B t) / ε t ∧
          ch7InverseExactRelativeChangeMax n hn A_inv (B t) / ε t ≤
            ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t +
              ε t * R t) l := by
    filter_upwards [hε_pos, hΔ, hRight] with t hεt_pos hΔt hRightt
    have hεt_nonneg : 0 ≤ ε t := le_of_lt hεt_pos
    have hεt_ne : ε t ≠ 0 := ne_of_gt hεt_pos
    have hlow :=
      problem7_11_exact_inverse_relative_change_max_ge_linearized_max_minus_quadratic
        n hn A A_inv (ΔA t) E (B t) (ε t)
        hεt_nonneg hE hden hΔt hLeft hRightt
    have hup :=
      problem7_11_exact_inverse_relative_change_max_le_linearized_max_plus_quadratic
        n hn A A_inv (ΔA t) E (B t) (ε t)
        hεt_nonneg hE hden hΔt hLeft hRightt
    have hlow_div :=
      div_le_div_of_nonneg_right hlow (le_of_lt hεt_pos)
    have hup_div :=
      div_le_div_of_nonneg_right hup (le_of_lt hεt_pos)
    constructor
    · have hleft_eq :
          (ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) -
              (ε t) ^ 2 * R t) / ε t =
            ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t -
              ε t * R t := by
        field_simp [hεt_ne]
      simpa [R, hleft_eq] using hlow_div
    · have hright_eq :
          (ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) +
              (ε t) ^ 2 * R t) / ε t =
            ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t +
              ε t * R t := by
        field_simp [hεt_ne]
      simpa [R, hright_eq] using hup_div
  exact tendsto_of_eventually_between_tendsto hlower hupper hbetween

/-- Problem 7.11 asymptotic bridge with the quadratic boundedness hypothesis
discharged from an eventual entrywise bound on the exact perturbed inverses.
The remaining source-facing task is to construct such inverse families and
prove their local boundedness for all sufficiently small admissible
perturbations. -/
theorem problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_eventually_entry_bound
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ)
    (ΔA B : ι → Fin n → Fin n → ℝ)
    (ε : ι → ℝ) (μ C_B : ℝ)
    (hCB : 0 ≤ C_B)
    (hε_pos : Filter.Eventually (fun t => 0 < ε t) l)
    (hε_tendsto : Filter.Tendsto ε l (nhds 0))
    (hlin_tendsto :
      Filter.Tendsto
        (fun t => ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t)
        l (nhds μ))
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : Filter.Eventually
      (fun t => ∀ i j, |ΔA t i j| ≤ ε t * E i j) l)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : Filter.Eventually
      (fun t => IsRightInverse n (fun i j => A i j + ΔA t i j) (B t)) l)
    (hBbound : Filter.Eventually
      (fun t => ∀ i j, |B t i j| ≤ C_B) l) :
    Filter.Tendsto
      (fun t => ch7InverseExactRelativeChangeMax n hn A_inv (B t) / ε t)
      l (nhds μ) := by
  let C :=
    ch7InverseQuadraticRemainderRelativeMaxEntryBound n hn A_inv E C_B
  have hC : 0 ≤ C := by
    exact ch7InverseQuadraticRemainderRelativeMaxEntryBound_nonneg
      n hn A_inv E C_B hE hCB
  have hbound : Filter.Eventually
      (fun t => |ch7InverseQuadraticRemainderRelativeMax n hn A_inv E (B t)| ≤ C) l := by
    filter_upwards [hBbound] with t hBt
    exact
      ch7InverseQuadraticRemainderRelativeMax_abs_le_of_entry_bound
        n hn A_inv E (B t) C_B hE hden hBt
  exact
    problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_quadratic_bound
      n hn A A_inv E ΔA B ε μ C hC hε_pos hε_tendsto hlin_tendsto
      hE hden hΔ hLeft hRight hbound

/-- Problem 7.11 asymptotic bridge with the bounded-remainder hypothesis
discharged from an eventual matrix infinity-norm bound on the exact perturbed
inverses.  This is the norm-bound form needed before proving the remaining
source-local inverse-family existence and boundedness package. -/
theorem problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_eventually_infNorm_bound
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ)
    (ΔA B : ι → Fin n → Fin n → ℝ)
    (ε : ι → ℝ) (μ C_B : ℝ)
    (hCB : 0 ≤ C_B)
    (hε_pos : Filter.Eventually (fun t => 0 < ε t) l)
    (hε_tendsto : Filter.Tendsto ε l (nhds 0))
    (hlin_tendsto :
      Filter.Tendsto
        (fun t => ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t)
        l (nhds μ))
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : Filter.Eventually
      (fun t => ∀ i j, |ΔA t i j| ≤ ε t * E i j) l)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : Filter.Eventually
      (fun t => IsRightInverse n (fun i j => A i j + ΔA t i j) (B t)) l)
    (hBnorm : Filter.Eventually (fun t => infNorm (B t) ≤ C_B) l) :
    Filter.Tendsto
      (fun t => ch7InverseExactRelativeChangeMax n hn A_inv (B t) / ε t)
      l (nhds μ) := by
  have hBbound : Filter.Eventually
      (fun t => ∀ i j, |B t i j| ≤ C_B) l := by
    filter_upwards [hBnorm] with t hBt i j
    exact le_trans (ch7_abs_entry_le_infNorm (B t) i j) hBt
  exact
    problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_eventually_entry_bound
      n hn A A_inv E ΔA B ε μ C_B hCB hε_pos hε_tendsto hlin_tendsto
      hE hden hΔ hLeft hRight hBbound

/-- Problem 7.11 exact-to-linearized asymptotic bridge with the local inverse
family and its infinity-norm bound constructed from a strict bound on
`‖ |A⁻¹ΔA(t)| ‖∞`. -/
theorem problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_eventually_abs_left_product_bound
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ)
    (ΔA : ι → Fin n → Fin n → ℝ)
    (ε : ι → ℝ) (μ c : ℝ)
    (hc_nn : 0 ≤ c) (hc_lt : c < 1)
    (hε_pos : Filter.Eventually (fun t => 0 < ε t) l)
    (hε_tendsto : Filter.Tendsto ε l (nhds 0))
    (hlin_tendsto :
      Filter.Tendsto
        (fun t => ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t)
        l (nhds μ))
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : Filter.Eventually
      (fun t => ∀ i j, |ΔA t i j| ≤ ε t * E i j) l)
    (hLeft : IsLeftInverse n A A_inv)
    (hbound : Filter.Eventually
      (fun t => infNormBound n (absMatrix n (matMul n A_inv (ΔA t))) c) l) :
    Filter.Tendsto
      (fun t =>
        ch7InverseExactRelativeChangeMax n hn A_inv
          (ch7Problem711PerturbedInverseCandidate n A_inv (ΔA t)) / ε t)
      l (nhds μ) := by
  let B : ι → Fin n → Fin n → ℝ :=
    fun t => ch7Problem711PerturbedInverseCandidate n A_inv (ΔA t)
  let C_B : ℝ := ((n : ℝ) * (1 / (1 - c))) * infNorm A_inv
  have hCden : 0 < 1 - c := by linarith
  have hCB : 0 ≤ C_B := by
    dsimp [C_B]
    exact mul_nonneg
      (mul_nonneg (Nat.cast_nonneg n) (div_nonneg zero_le_one (le_of_lt hCden)))
      (infNorm_nonneg A_inv)
  have hRight : Filter.Eventually
      (fun t => IsRightInverse n (fun i j => A i j + ΔA t i j) (B t)) l := by
    filter_upwards [hbound] with t hbt
    exact
      problem7_11_perturbed_inverse_candidate_right_inverse_of_abs_left_product_bound
        n hn A A_inv (ΔA t) c hc_nn hc_lt hLeft hbt
  have hBnorm : Filter.Eventually (fun t => infNorm (B t) ≤ C_B) l := by
    filter_upwards [hbound] with t hbt
    exact
      problem7_11_perturbed_inverse_candidate_infNorm_bound_of_abs_left_product_bound
        n hn A_inv (ΔA t) c hc_nn hc_lt hbt
  exact
    problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_eventually_infNorm_bound
      n hn A A_inv E ΔA B ε μ C_B hCB hε_pos hε_tendsto hlin_tendsto
      hE hden hΔ hLeft hRight hBnorm

/-- Problem 7.11 exact-to-linearized asymptotic bridge with the local inverse
family and its infinity-norm bound constructed directly from componentwise
admissibility and `ε → 0`.  This removes the previously explicit right-inverse
and inverse-boundedness hypotheses from the nonlinear bridge. -/
theorem problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_componentwise_tendsto_zero
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ)
    (ΔA : ι → Fin n → Fin n → ℝ)
    (ε : ι → ℝ) (μ : ℝ)
    (hε_pos : Filter.Eventually (fun t => 0 < ε t) l)
    (hε_tendsto : Filter.Tendsto ε l (nhds 0))
    (hlin_tendsto :
      Filter.Tendsto
        (fun t => ch7InverseLinearizedRelativeChangeMax n hn A_inv (ΔA t) / ε t)
        l (nhds μ))
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hΔ : Filter.Eventually
      (fun t => ∀ i j, |ΔA t i j| ≤ ε t * E i j) l)
    (hLeft : IsLeftInverse n A A_inv) :
    Filter.Tendsto
      (fun t =>
        ch7InverseExactRelativeChangeMax n hn A_inv
          (ch7Problem711PerturbedInverseCandidate n A_inv (ΔA t)) / ε t)
      l (nhds μ) := by
  have hbound :=
    problem7_11_eventually_abs_left_product_infNormBound_half_of_componentwise_tendsto_zero
      n A_inv E ΔA ε hε_pos hε_tendsto hE hΔ
  exact
    problem7_11_exact_inverse_relative_change_max_div_tendsto_linearized_of_eventually_abs_left_product_bound
      n hn A A_inv E ΔA ε μ (1 / 2) (by norm_num) (by norm_num)
      hε_pos hε_tendsto hlin_tendsto hE hden hΔ hLeft hbound

/-- Source-radius feasible exact inverse-change values for Problem 7.11.
The exact perturbed inverse is the locally constructed candidate
`(I + A⁻¹ΔA)⁻¹A⁻¹`; the small-radius theorems below prove that this candidate
is the required right inverse in the source limit. -/
def Ch7InverseComponentwiseRadiusSet
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) (rho : ℝ) : Set ℝ :=
  { q | ∃ ε : ℝ, ∃ ΔA : Fin n → Fin n → ℝ,
      0 < ε ∧
      ε ≤ rho ∧
      (∀ i j, |ΔA i j| ≤ ε * E i j) ∧
      q =
        ch7InverseExactRelativeChangeMax n hn A_inv
          (ch7Problem711PerturbedInverseCandidate n A_inv ΔA) / ε }

/-- Concrete `sSup` of the Problem 7.11 componentwise inverse radius set. -/
noncomputable def ch7InverseComponentwiseRadiusSup
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) (rho : ℝ) : ℝ :=
  sSup (Ch7InverseComponentwiseRadiusSet n hn A_inv E rho)

/-- Source-facing limit-value predicate for Problem 7.11's nonlinear
componentwise inverse condition number. -/
def IsCh7InverseComponentwiseRadiusLimitValue
    {ι : Type*} (l : Filter ι)
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) (rho : ι → ℝ) (κ : ℝ) : Prop :=
  Filter.Tendsto
    (fun t => ch7InverseComponentwiseRadiusSup n hn A_inv E (rho t))
    l (nhds κ)

/-- Source-facing value predicate for the finite linearized Problem 7.11
componentwise inverse condition number. -/
def IsCh7InverseComponentwiseCondValue
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) (κ : ℝ) : Prop :=
  κ = ch7InverseComponentwiseLinearizedCond n hn A_inv E

/-- Uniform infinity-norm bound for the locally constructed inverse candidate
in the Problem 7.11 radius proof, specialized to the contraction `1/2`. -/
noncomputable def ch7Problem711LocalInverseInfNormBound
    (n : ℕ) (A_inv : Fin n → Fin n → ℝ) : ℝ :=
  ((n : ℝ) * (1 / (1 - (1 / 2 : ℝ)))) * infNorm A_inv

lemma ch7Problem711LocalInverseInfNormBound_nonneg
    (n : ℕ) (A_inv : Fin n → Fin n → ℝ) :
    0 ≤ ch7Problem711LocalInverseInfNormBound n A_inv := by
  unfold ch7Problem711LocalInverseInfNormBound
  exact mul_nonneg
    (mul_nonneg (Nat.cast_nonneg n) (by norm_num))
    (infNorm_nonneg A_inv)

/-- Uniform bound for the relative quadratic-remainder coefficient used in
the Problem 7.11 radius squeeze. -/
noncomputable def ch7InverseComponentwiseRadiusRemainderBound
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ) : ℝ :=
  ch7InverseQuadraticRemainderRelativeMaxEntryBound n hn A_inv E
    (ch7Problem711LocalInverseInfNormBound n A_inv)

lemma ch7InverseComponentwiseRadiusRemainderBound_nonneg
    (n : ℕ) (hn : 0 < n)
    (A_inv E : Fin n → Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) :
    0 ≤ ch7InverseComponentwiseRadiusRemainderBound n hn A_inv E := by
  unfold ch7InverseComponentwiseRadiusRemainderBound
  exact ch7InverseQuadraticRemainderRelativeMaxEntryBound_nonneg
    n hn A_inv E (ch7Problem711LocalInverseInfNormBound n A_inv)
    hE (ch7Problem711LocalInverseInfNormBound_nonneg n A_inv)

lemma ch7_inverse_componentwise_radius_candidate_right_inverse_of_small
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA E : Fin n → Fin n → ℝ) (ε rho : ℝ)
    (hε : 0 ≤ ε) (hερ : ε ≤ rho)
    (hE : ∀ i j, 0 ≤ E i j)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hLeft : IsLeftInverse n A A_inv)
    (hsmall :
      rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤ (1 / 2 : ℝ)) :
    IsRightInverse n (fun i j => A i j + ΔA i j)
      (ch7Problem711PerturbedInverseCandidate n A_inv ΔA) := by
  have hleft_bound :
      infNorm (absMatrix n (matMul n A_inv ΔA)) ≤ (1 / 2 : ℝ) := by
    have hraw :=
      ch7_abs_left_product_infNorm_le_of_componentwise_bound
        n A_inv ΔA E ε hε hE hΔ
    have hscale :
        ε * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤
          rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) := by
      exact mul_le_mul_of_nonneg_right hερ
        (infNorm_nonneg (ch7InverseFirstProductSensitivity n A_inv E))
    exact hraw.trans (hscale.trans hsmall)
  exact
    problem7_11_perturbed_inverse_candidate_right_inverse_of_abs_left_product_bound
      n hn A A_inv ΔA (1 / 2) (by norm_num) (by norm_num)
      hLeft hleft_bound

lemma ch7_inverse_componentwise_radius_candidate_infNorm_bound_of_small
    (n : ℕ) (hn : 0 < n)
    (A_inv ΔA E : Fin n → Fin n → ℝ) (ε rho : ℝ)
    (hε : 0 ≤ ε) (hερ : ε ≤ rho)
    (hE : ∀ i j, 0 ≤ E i j)
    (hΔ : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hsmall :
      rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤ (1 / 2 : ℝ)) :
    infNorm (ch7Problem711PerturbedInverseCandidate n A_inv ΔA) ≤
      ch7Problem711LocalInverseInfNormBound n A_inv := by
  have hleft_bound :
      infNorm (absMatrix n (matMul n A_inv ΔA)) ≤ (1 / 2 : ℝ) := by
    have hraw :=
      ch7_abs_left_product_infNorm_le_of_componentwise_bound
        n A_inv ΔA E ε hε hE hΔ
    have hscale :
        ε * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤
          rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) := by
      exact mul_le_mul_of_nonneg_right hερ
        (infNorm_nonneg (ch7InverseFirstProductSensitivity n A_inv E))
    exact hraw.trans (hscale.trans hsmall)
  simpa [ch7Problem711LocalInverseInfNormBound] using
    problem7_11_perturbed_inverse_candidate_infNorm_bound_of_abs_left_product_bound
      n hn A_inv ΔA (1 / 2) (by norm_num) (by norm_num) hleft_bound

/-- Upper envelope for every source-radius feasible value in the Problem 7.11
componentwise inverse condition-number set. -/
theorem ch7InverseComponentwiseRadiusSet_value_le
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) {rho q : ℝ}
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hLeft : IsLeftInverse n A A_inv)
    (hsmall :
      rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤ (1 / 2 : ℝ))
    (hq : q ∈ Ch7InverseComponentwiseRadiusSet n hn A_inv E rho) :
    q ≤ ch7InverseComponentwiseLinearizedCond n hn A_inv E +
      rho * ch7InverseComponentwiseRadiusRemainderBound n hn A_inv E := by
  rcases hq with ⟨ε, ΔA, hεpos, hερ, hΔ, rfl⟩
  let B := ch7Problem711PerturbedInverseCandidate n A_inv ΔA
  let C := ch7InverseComponentwiseRadiusRemainderBound n hn A_inv E
  have hε : 0 ≤ ε := le_of_lt hεpos
  have hRight :
      IsRightInverse n (fun i j => A i j + ΔA i j) B :=
    ch7_inverse_componentwise_radius_candidate_right_inverse_of_small
      n hn A A_inv ΔA E ε rho hε hερ hE hΔ hLeft hsmall
  have hBnorm :
      infNorm B ≤ ch7Problem711LocalInverseInfNormBound n A_inv :=
    ch7_inverse_componentwise_radius_candidate_infNorm_bound_of_small
      n hn A_inv ΔA E ε rho hε hερ hE hΔ hsmall
  have hR :
      ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤ C := by
    unfold C ch7InverseComponentwiseRadiusRemainderBound
    exact
      ch7InverseQuadraticRemainderRelativeMax_le_of_infNorm_bound
        n hn A_inv E B (ch7Problem711LocalInverseInfNormBound n A_inv)
        hE hden hBnorm
  have hfinite :=
    problem7_11_exact_inverse_relative_change_max_le_condition_plus_quadratic
      n hn A A_inv ΔA E B ε hε hE hden hΔ hLeft hRight
  have hε_ne : ε ≠ 0 := ne_of_gt hεpos
  have hRnonneg :
      0 ≤ ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B :=
    ch7InverseQuadraticRemainderRelativeMax_nonneg n hn A_inv E B hE
  have hCnonneg : 0 ≤ C := by
    dsimp [C]
    exact ch7InverseComponentwiseRadiusRemainderBound_nonneg n hn A_inv E hE
  have hquad :
      ε * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤
        rho * C := by
    exact mul_le_mul hερ hR hRnonneg (le_trans hε hερ)
  calc
    ch7InverseExactRelativeChangeMax n hn A_inv B / ε
        ≤ (ε * ch7InverseComponentwiseLinearizedCond n hn A_inv E +
          ε ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B) / ε :=
          div_le_div_of_nonneg_right hfinite hε
    _ = ch7InverseComponentwiseLinearizedCond n hn A_inv E +
        ε * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
          field_simp [hε_ne]
    _ ≤ ch7InverseComponentwiseLinearizedCond n hn A_inv E + rho * C :=
          add_le_add le_rfl hquad

/-- Lower witness for the Problem 7.11 source-radius set.  The Appendix A.11
sign perturbation gives a feasible exact inverse-change value within the
explicit quadratic envelope of the finite linearized condition number. -/
theorem exists_ch7InverseComponentwiseRadiusSet_lower_witness
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) {rho : ℝ}
    (hrho : 0 < rho)
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hLeft : IsLeftInverse n A A_inv)
    (hsmall :
      rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤ (1 / 2 : ℝ)) :
    ∃ q : ℝ,
      q ∈ Ch7InverseComponentwiseRadiusSet n hn A_inv E rho ∧
      ch7InverseComponentwiseLinearizedCond n hn A_inv E -
          rho * ch7InverseComponentwiseRadiusRemainderBound n hn A_inv E ≤ q := by
  let μ := ch7InverseComponentwiseLinearizedCond n hn A_inv E
  let C := ch7InverseComponentwiseRadiusRemainderBound n hn A_inv E
  rcases
    problem7_11_exists_exact_inverse_relative_change_max_lower_witness
      n hn A A_inv E rho (le_of_lt hrho) hE hden with
    ⟨ΔA, hΔ, hlower_all⟩
  let B := ch7Problem711PerturbedInverseCandidate n A_inv ΔA
  let q := ch7InverseExactRelativeChangeMax n hn A_inv B / rho
  have hRight :
      IsRightInverse n (fun i j => A i j + ΔA i j) B :=
    ch7_inverse_componentwise_radius_candidate_right_inverse_of_small
      n hn A A_inv ΔA E rho rho (le_of_lt hrho) le_rfl hE hΔ hLeft hsmall
  have hBnorm :
      infNorm B ≤ ch7Problem711LocalInverseInfNormBound n A_inv :=
    ch7_inverse_componentwise_radius_candidate_infNorm_bound_of_small
      n hn A_inv ΔA E rho rho (le_of_lt hrho) le_rfl hE hΔ hsmall
  have hR :
      ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤ C := by
    unfold C ch7InverseComponentwiseRadiusRemainderBound
    exact
      ch7InverseQuadraticRemainderRelativeMax_le_of_infNorm_bound
        n hn A_inv E B (ch7Problem711LocalInverseInfNormBound n A_inv)
        hE hden hBnorm
  have hlower :=
    hlower_all B hLeft hRight
  have hrho_ne : rho ≠ 0 := ne_of_gt hrho
  have hdiv :
      μ - rho * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤ q := by
    have hdiv_le := div_le_div_of_nonneg_right hlower (le_of_lt hrho)
    have hleft_eq :
        (rho * μ -
            rho ^ 2 * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B) /
            rho =
          μ - rho * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
      field_simp [hrho_ne]
    simpa [q, μ, hleft_eq] using hdiv_le
  have hCstep :
      μ - rho * C ≤ μ - rho * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B := by
    have hmul :
        rho * ch7InverseQuadraticRemainderRelativeMax n hn A_inv E B ≤ rho * C :=
      mul_le_mul_of_nonneg_left hR (le_of_lt hrho)
    linarith
  refine ⟨q, ?_, hCstep.trans hdiv⟩
  refine ⟨rho, ΔA, hrho, le_rfl, hΔ, ?_⟩
  rfl

/-- Problem 7.11 source-radius `sSup` limit: the nonlinear componentwise
inverse condition number obtained by shrinking the perturbation radius equals
the finite linearized formula
`maxᵢⱼ (|A⁻¹|E|A⁻¹|)ᵢⱼ / |(A⁻¹)ᵢⱼ|`. -/
theorem problem7_11_inverse_componentwise_radiusSup_tendsto_linearized
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hrho_tendsto : Filter.Tendsto rho l (nhds 0))
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hLeft : IsLeftInverse n A A_inv) :
    IsCh7InverseComponentwiseRadiusLimitValue l n hn A_inv E rho
      (ch7InverseComponentwiseLinearizedCond n hn A_inv E) := by
  dsimp [IsCh7InverseComponentwiseRadiusLimitValue]
  let μ := ch7InverseComponentwiseLinearizedCond n hn A_inv E
  let C := ch7InverseComponentwiseRadiusRemainderBound n hn A_inv E
  let P := ch7InverseFirstProductSensitivity n A_inv E
  let L : ι → ℝ := fun t => μ - rho t * C
  let U : ι → ℝ := fun t => μ + rho t * C
  let Q : ι → ℝ := fun t => ch7InverseComponentwiseRadiusSup n hn A_inv E (rho t)
  have hL : Filter.Tendsto L l (nhds μ) := by
    have hterm : Filter.Tendsto (fun t => rho t * C) l (nhds 0) := by
      simpa using hrho_tendsto.mul_const C
    dsimp [L]
    simpa using tendsto_const_nhds.sub hterm
  have hU : Filter.Tendsto U l (nhds μ) := by
    have hterm : Filter.Tendsto (fun t => rho t * C) l (nhds 0) := by
      simpa using hrho_tendsto.mul_const C
    dsimp [U]
    simpa using tendsto_const_nhds.add hterm
  have hsmall : Filter.Eventually
      (fun t => rho t * infNorm P ≤ (1 / 2 : ℝ)) l := by
    have hscaled : Filter.Tendsto (fun t => rho t * infNorm P) l (nhds 0) := by
      simpa [P] using hrho_tendsto.mul_const (infNorm P)
    have hraw := (Metric.tendsto_nhds.mp hscaled) (1 / 2 : ℝ) (by norm_num)
    filter_upwards [hrho_pos, hraw] with t hρpos ht
    have hdist : |rho t * infNorm P| < (1 / 2 : ℝ) := by
      simpa [Real.dist_eq] using ht
    have hnonneg : 0 ≤ rho t * infNorm P :=
      mul_nonneg (le_of_lt hρpos) (infNorm_nonneg P)
    exact le_of_lt (by simpa [abs_of_nonneg hnonneg] using hdist)
  have hbetween : Filter.Eventually (fun t => L t ≤ Q t ∧ Q t ≤ U t) l := by
    filter_upwards [hrho_pos, hsmall] with t hρpos hsmall_t
    obtain ⟨q, hqmem, hLq⟩ :=
      exists_ch7InverseComponentwiseRadiusSet_lower_witness
        n hn A A_inv E hρpos hE hden hLeft hsmall_t
    have hUbound :
        ∀ r : ℝ, r ∈ Ch7InverseComponentwiseRadiusSet n hn A_inv E (rho t) →
          r ≤ U t := by
      intro r hr
      simpa [U, μ, C] using
        ch7InverseComponentwiseRadiusSet_value_le
          n hn A A_inv E hE hden hLeft hsmall_t hr
    have hbdd :
        BddAbove (Ch7InverseComponentwiseRadiusSet n hn A_inv E (rho t)) :=
      ⟨U t, hUbound⟩
    have hq_le_sup :
        q ≤ ch7InverseComponentwiseRadiusSup n hn A_inv E (rho t) :=
      le_csSup hbdd hqmem
    have hsup_le :
        ch7InverseComponentwiseRadiusSup n hn A_inv E (rho t) ≤ U t :=
      csSup_le ⟨q, hqmem⟩ hUbound
    exact ⟨by simpa [L, μ, C] using hLq.trans hq_le_sup, hsup_le⟩
  simpa [L, U, Q, μ] using
    tendsto_of_eventually_between_tendsto hL hU hbetween

/-- Product-plus-limit packaging of Problem 7.11: the source nonlinear
componentwise inverse condition number agrees with the checked finite
linearized maximum. -/
theorem problem7_11_inverse_componentwise_condition_of_positive_radii
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hrho_tendsto : Filter.Tendsto rho l (nhds 0))
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : ∀ i j, 0 < |A_inv i j|)
    (hLeft : IsLeftInverse n A A_inv) :
    ∃ κ : ℝ,
      IsCh7InverseComponentwiseCondValue n hn A_inv E κ ∧
        IsCh7InverseComponentwiseRadiusLimitValue l n hn A_inv E rho κ := by
  refine ⟨ch7InverseComponentwiseLinearizedCond n hn A_inv E, rfl, ?_⟩
  exact
    problem7_11_inverse_componentwise_radiusSup_tendsto_linearized
      n hn A A_inv E rho hrho_pos hrho_tendsto hE hden hLeft

-- ============================================================
-- Problem 7.9: exact componentwise scalar-output bridge
-- ============================================================

/-- In finite square real matrices, a right inverse is also a left inverse.
This is the converse adapter to `ch7_isRightInverse_of_isLeftInverse`, used to
turn the locally constructed Problem 7.11 inverse candidate into a solver for
the perturbed linear system in Problem 7.9. -/
theorem ch7_isLeftInverse_of_isRightInverse {n : ℕ}
    {A A_inv : Fin n → Fin n → ℝ}
    (hRight : IsRightInverse n A A_inv) :
    IsLeftInverse n A A_inv := by
  have hmatRight :
      (Matrix.of A : Matrix (Fin n) (Fin n) ℝ) *
          (Matrix.of A_inv : Matrix (Fin n) (Fin n) ℝ) = 1 := by
    ext i j
    simpa [Matrix.mul_apply, Matrix.of_apply, idMatrix] using hRight i j
  have hmatLeft :
      (Matrix.of A_inv : Matrix (Fin n) (Fin n) ℝ) *
          (Matrix.of A : Matrix (Fin n) (Fin n) ℝ) = 1 :=
    (mul_eq_one_comm.mp hmatRight)
  intro i j
  have hij := congrArg (fun M : Matrix (Fin n) (Fin n) ℝ => M i j) hmatLeft
  simpa [Matrix.mul_apply, Matrix.of_apply, idMatrix] using hij

/-- The exact perturbed solution used for the nonlinear Problem 7.9 bridge:
`x̂ = B(Ax + Δb)`, where `B` is the local inverse candidate for `A + ΔA`. -/
noncomputable def ch7Problem79PerturbedSolutionWithInverse (n : ℕ)
    (A B : Fin n → Fin n → ℝ) (x Δb : Fin n → ℝ) : Fin n → ℝ :=
  matMulVec n B (fun i => matMulVec n A x i + Δb i)

/-- Exact scalar-output relative change for Problem 7.9, parameterized by the
particular inverse candidate `B` used to solve the perturbed system. -/
noncomputable def ch7Problem79ExactScalarRelativeChange (n : ℕ)
    (A B : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ) : ℝ :=
  |ch7LinearFunctional n c
      (fun i => ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i)| /
    |ch7LinearFunctional n c x|

/-- Componentwise envelope for the residual perturbation
`Δb - ΔA x` in Problem 7.9. -/
noncomputable def ch7Problem79ComponentwiseRhsEnvelope (n : ℕ)
    (E : Fin n → Fin n → ℝ) (f x : Fin n → ℝ) : ℝ :=
  ∑ i : Fin n, (f i + ∑ j : Fin n, E i j * |x j|)

lemma ch7Problem79ComponentwiseRhsEnvelope_nonneg (n : ℕ)
    (E : Fin n → Fin n → ℝ) (f x : Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i) :
    0 ≤ ch7Problem79ComponentwiseRhsEnvelope n E f x := by
  unfold ch7Problem79ComponentwiseRhsEnvelope
  exact Finset.sum_nonneg fun i _ =>
    add_nonneg (hf i)
      (Finset.sum_nonneg fun j _ => mul_nonneg (hE i j) (abs_nonneg _))

/-- Relative quadratic-remainder coefficient for the exact componentwise
Problem 7.9 bridge.  The coefficient is intentionally a conservative finite
envelope; only finiteness and nonnegativity are needed for the source
`lim sup` squeeze. -/
noncomputable def ch7Problem79ComponentwiseExactRemainderBound (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (C_B : ℝ) : ℝ :=
  ((∑ i : Fin n, |c i|) *
      (infNorm (ch7InverseFirstProductSensitivity n A_inv E) * C_B *
        ch7Problem79ComponentwiseRhsEnvelope n E f x)) /
    |ch7LinearFunctional n c x|

lemma ch7Problem79ComponentwiseExactRemainderBound_nonneg (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (C_B : ℝ)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hCB : 0 ≤ C_B) (hden : 0 < |ch7LinearFunctional n c x|) :
    0 ≤ ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x C_B := by
  unfold ch7Problem79ComponentwiseExactRemainderBound
  exact div_nonneg
    (mul_nonneg
      (Finset.sum_nonneg fun i _ => abs_nonneg _)
      (mul_nonneg
        (mul_nonneg
          (infNorm_nonneg (ch7InverseFirstProductSensitivity n A_inv E))
          hCB)
        (ch7Problem79ComponentwiseRhsEnvelope_nonneg n E f x hE hf)))
    (le_of_lt hden)

lemma ch7Problem79_delta_rhs_abs_le_envelope (n : ℕ)
    (E ΔA : Fin n → Fin n → ℝ) (f x Δb : Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i) :
    ∀ i,
      |Δb i - matMulVec n ΔA x i| ≤
        ε * ch7Problem79ComponentwiseRhsEnvelope n E f x := by
  intro i
  let g : Fin n → ℝ :=
    fun r => f r + ∑ j : Fin n, E r j * |x j|
  have hg_nonneg : ∀ r, 0 ≤ g r := by
    intro r
    exact add_nonneg (hf r)
      (Finset.sum_nonneg fun j _ => mul_nonneg (hE r j) (abs_nonneg _))
  have hgi_le : g i ≤ ch7Problem79ComponentwiseRhsEnvelope n E f x := by
    unfold ch7Problem79ComponentwiseRhsEnvelope
    exact Finset.single_le_sum (fun r _ => hg_nonneg r) (Finset.mem_univ i)
  have hmat :
      |matMulVec n ΔA x i| ≤
        ε * ∑ j : Fin n, E i j * |x j| := by
    calc
      |matMulVec n ΔA x i|
          ≤ ∑ j : Fin n, |ΔA i j| * |x j| :=
            abs_matMulVec_le n ΔA x i
      _ ≤ ∑ j : Fin n, (ε * E i j) * |x j| := by
            apply Finset.sum_le_sum
            intro j _
            exact mul_le_mul_of_nonneg_right (hΔA i j) (abs_nonneg _)
      _ = ε * ∑ j : Fin n, E i j * |x j| := by
            rw [Finset.mul_sum]
            apply Finset.sum_congr rfl
            intro j _
            ring
  calc
    |Δb i - matMulVec n ΔA x i|
        ≤ |Δb i| + |matMulVec n ΔA x i| := by
          simpa [sub_eq_add_neg, abs_neg] using
            abs_add_le (Δb i) (-(matMulVec n ΔA x i))
    _ ≤ ε * f i + ε * ∑ j : Fin n, E i j * |x j| :=
          add_le_add (hΔb i) hmat
    _ = ε * g i := by
          dsimp [g]
          ring
    _ ≤ ε * ch7Problem79ComponentwiseRhsEnvelope n E f x :=
          mul_le_mul_of_nonneg_left hgi_le hε

lemma ch7Problem79_delta_rhs_infNormVec_le_envelope (n : ℕ)
    (E ΔA : Fin n → Fin n → ℝ) (f x Δb : Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i) :
    infNormVec (fun i => Δb i - matMulVec n ΔA x i) ≤
      ε * ch7Problem79ComponentwiseRhsEnvelope n E f x := by
  apply infNormVec_le_of_abs_le
  · exact ch7Problem79_delta_rhs_abs_le_envelope n E ΔA f x Δb ε
      hε hE hf hΔA hΔb
  · exact mul_nonneg hε
      (ch7Problem79ComponentwiseRhsEnvelope_nonneg n E f x hE hf)

lemma ch7Problem79_exact_delta_vector_decomposition (n : ℕ)
    (A A_inv ΔA B : Fin n → Fin n → ℝ) (x Δb : Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    (fun i =>
        ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i) =
      fun i =>
        matMulVec n A_inv (fun j => Δb j - matMulVec n ΔA x j) i -
          matMulVec n (matMul n (matMul n A_inv ΔA) B)
            (fun j => Δb j - matMulVec n ΔA x j) i := by
  let P : Fin n → Fin n → ℝ := fun i j => A i j + ΔA i j
  let v : Fin n → ℝ := fun j => Δb j - matMulVec n ΔA x j
  let M : Fin n → Fin n → ℝ := matMul n A_inv ΔA
  have hLeftPert : IsLeftInverse n P B :=
    ch7_isLeftInverse_of_isRightInverse hRight
  have hBpert_x : matMulVec n B (matMulVec n P x) = x := by
    ext i
    calc
      matMulVec n B (matMulVec n P x) i
          = matMulVec n (matMul n B P) x i := by
            exact (matMulVec_matMul n B P x i).symm
      _ = matMulVec n (idMatrix n) x i := by
            have hmat : matMul n B P = idMatrix n := by
              ext r s
              exact hLeftPert r s
            rw [hmat]
      _ = x i := by
            rw [matMulVec_id]
  have hsource :
      (fun i => matMulVec n A x i + Δb i) =
        fun i => matMulVec n P x i + v i := by
    ext i
    have hProw :
        matMulVec n P x i = matMulVec n A x i + matMulVec n ΔA x i := by
      unfold P matMulVec
      simp_rw [add_mul]
      rw [Finset.sum_add_distrib]
    dsimp [v]
    rw [hProw]
    ring_nf
  have hBdecomp :
      ∀ i j, B i j = A_inv i j - matMul n M B i j := by
    intro i j
    have h :=
      ch7_inversePerturbation_decomposition n A A_inv ΔA B hLeft hRight i j
    dsimp [M] at h ⊢
    linarith
  ext i
  unfold ch7Problem79PerturbedSolutionWithInverse
  calc
    matMulVec n B (fun i => matMulVec n A x i + Δb i) i - x i
        = matMulVec n B (fun i => matMulVec n P x i + v i) i - x i := by
          rw [hsource]
    _ = (matMulVec n B (matMulVec n P x) i + matMulVec n B v i) - x i := by
          rw [matMulVec_add_right]
    _ = matMulVec n B v i := by
          rw [hBpert_x]
          ring
    _ = matMulVec n A_inv v i - matMulVec n (matMul n M B) v i := by
          unfold matMulVec
          calc
            ∑ j : Fin n, B i j * v j
                = ∑ j : Fin n, (A_inv i j - matMul n M B i j) * v j := by
                  apply Finset.sum_congr rfl
                  intro j _
                  rw [hBdecomp i j]
            _ = ∑ j : Fin n, A_inv i j * v j -
                  ∑ j : Fin n, matMul n M B i j * v j := by
                  simp_rw [sub_mul]
                  rw [Finset.sum_sub_distrib]

lemma ch7Problem79_exact_scalar_decomposition (n : ℕ)
    (A A_inv ΔA B : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B) :
    ch7LinearFunctional n c
        (fun i =>
          ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i) =
      ch7Problem79FirstOrderChange n A_inv c x Δb ΔA -
        ch7LinearFunctional n c
          (matMulVec n (matMul n (matMul n A_inv ΔA) B)
            (fun j => Δb j - matMulVec n ΔA x j)) := by
  let v : Fin n → ℝ := fun j => Δb j - matMulVec n ΔA x j
  let R : Fin n → ℝ :=
    matMulVec n (matMul n (matMul n A_inv ΔA) B) v
  have hvec :=
    ch7Problem79_exact_delta_vector_decomposition n A A_inv ΔA B x Δb
      hLeft hRight
  have hfirst :
      ch7LinearFunctional n c (matMulVec n A_inv v) =
        ch7Problem79FirstOrderChange n A_inv c x Δb ΔA := by
    rw [← ch7Problem79_adjointWeight_mul_vec_eq_linearFunctional_matMulVec
      n A_inv c v]
    rfl
  calc
    ch7LinearFunctional n c
        (fun i =>
          ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i)
        = ch7LinearFunctional n c (fun i => matMulVec n A_inv v i - R i) := by
          rw [hvec]
    _ = ch7LinearFunctional n c (matMulVec n A_inv v) -
        ch7LinearFunctional n c R := by
          unfold ch7LinearFunctional
          simp_rw [mul_sub]
          rw [Finset.sum_sub_distrib]
    _ = ch7Problem79FirstOrderChange n A_inv c x Δb ΔA -
        ch7LinearFunctional n c R := by
          rw [hfirst]

lemma ch7Problem79_exact_scalar_remainder_abs_le (n : ℕ) (hn : 0 < n)
    (A_inv ΔA B E : Fin n → Fin n → ℝ) (f c x Δb : Fin n → ℝ)
    (ε C_B : ℝ)
    (hε : 0 ≤ ε)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i)
    (hBnorm : infNorm B ≤ C_B) :
    |ch7LinearFunctional n c
        (matMulVec n (matMul n (matMul n A_inv ΔA) B)
          (fun j => Δb j - matMulVec n ΔA x j))| ≤
      ε ^ 2 *
        ((∑ i : Fin n, |c i|) *
          (infNorm (ch7InverseFirstProductSensitivity n A_inv E) * C_B *
            ch7Problem79ComponentwiseRhsEnvelope n E f x)) := by
  let v : Fin n → ℝ := fun j => Δb j - matMulVec n ΔA x j
  let M : Fin n → Fin n → ℝ := matMul n A_inv ΔA
  let P : Fin n → Fin n → ℝ := ch7InverseFirstProductSensitivity n A_inv E
  let R : Fin n → ℝ := matMulVec n (matMul n M B) v
  let G : ℝ := ch7Problem79ComponentwiseRhsEnvelope n E f x
  have hG_nonneg : 0 ≤ G :=
    ch7Problem79ComponentwiseRhsEnvelope_nonneg n E f x hE hf
  have hCB_nonneg : 0 ≤ C_B :=
    le_trans (infNorm_nonneg B) hBnorm
  have hMnorm : infNorm M ≤ ε * infNorm P := by
    have hraw :=
      ch7_abs_left_product_infNorm_le_of_componentwise_bound
        n A_inv ΔA E ε hε hE hΔA
    dsimp [M, P]
    simpa [infNorm_absMatrix hn (matMul n A_inv ΔA)] using hraw
  have hMBnorm :
      infNorm (matMul n M B) ≤ (ε * infNorm P) * C_B := by
    calc
      infNorm (matMul n M B)
          ≤ infNorm M * infNorm B := infNorm_matMul_le hn M B
      _ ≤ (ε * infNorm P) * C_B :=
          mul_le_mul hMnorm hBnorm (infNorm_nonneg B)
            (mul_nonneg hε (infNorm_nonneg P))
  have hvnorm : infNormVec v ≤ ε * G := by
    dsimp [v, G]
    exact ch7Problem79_delta_rhs_infNormVec_le_envelope n E ΔA f x Δb ε
      hε hE hf hΔA hΔb
  have hRnorm :
      infNormVec R ≤ ε ^ 2 * (infNorm P * C_B * G) := by
    have hMB_nonneg : 0 ≤ (ε * infNorm P) * C_B :=
      mul_nonneg (mul_nonneg hε (infNorm_nonneg P)) hCB_nonneg
    calc
      infNormVec R
          ≤ infNorm (matMul n M B) * infNormVec v :=
            infNormVec_matMulVec_le hn (matMul n M B) v
      _ ≤ ((ε * infNorm P) * C_B) * (ε * G) :=
          mul_le_mul hMBnorm hvnorm (infNormVec_nonneg v) hMB_nonneg
      _ = ε ^ 2 * (infNorm P * C_B * G) := by
          ring
  have hscalar :
      |ch7LinearFunctional n c R| ≤ (∑ i : Fin n, |c i|) * infNormVec R := by
    unfold ch7LinearFunctional
    calc
      |∑ i : Fin n, c i * R i|
          ≤ ∑ i : Fin n, |c i * R i| :=
            Finset.abs_sum_le_sum_abs _ _
      _ = ∑ i : Fin n, |c i| * |R i| := by
            apply Finset.sum_congr rfl
            intro i _
            rw [abs_mul]
      _ ≤ ∑ i : Fin n, |c i| * infNormVec R := by
            apply Finset.sum_le_sum
            intro i _
            exact mul_le_mul_of_nonneg_left (abs_le_infNormVec R i) (abs_nonneg _)
      _ = (∑ i : Fin n, |c i|) * infNormVec R := by
            rw [Finset.sum_mul]
  calc
    |ch7LinearFunctional n c
        (matMulVec n (matMul n (matMul n A_inv ΔA) B)
          (fun j => Δb j - matMulVec n ΔA x j))|
        = |ch7LinearFunctional n c R| := by
          rfl
    _ ≤ (∑ i : Fin n, |c i|) * infNormVec R := hscalar
    _ ≤ (∑ i : Fin n, |c i|) *
        (ε ^ 2 * (infNorm P * C_B * G)) :=
          mul_le_mul_of_nonneg_left hRnorm
            (Finset.sum_nonneg fun i _ => abs_nonneg _)
    _ = ε ^ 2 *
        ((∑ i : Fin n, |c i|) * (infNorm P * C_B * G)) := by
          ring

/-- Exact finite upper bridge for Problem 7.9 componentwise scalar-output
perturbations.  The nonlinear scalar change is bounded by the checked
linearized formula plus a quadratic remainder. -/
theorem problem7_9_exact_componentwise_relative_change_le_linearized_plus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA B E : Fin n → Fin n → ℝ) (f c x Δb : Fin n → ℝ)
    (ε C_B : ℝ)
    (hε : 0 ≤ ε)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B)
    (hBnorm : infNorm B ≤ C_B) :
    ch7Problem79ExactScalarRelativeChange n A B c x Δb ≤
      ε * ch7Problem79LinearizedCond n A_inv E f c x +
        ε ^ 2 *
          ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x C_B := by
  let Rem : Fin n → ℝ :=
    matMulVec n (matMul n (matMul n A_inv ΔA) B)
      (fun j => Δb j - matMulVec n ΔA x j)
  have hscalar :=
    ch7Problem79_exact_scalar_decomposition n A A_inv ΔA B c x Δb
      hLeft hRight
  have hrem :=
    ch7Problem79_exact_scalar_remainder_abs_le n hn A_inv ΔA B E f c x Δb
      ε C_B hε hE hf hΔA hΔb hBnorm
  have hlin :=
    ch7Problem79_linearizedRelativeChange_le n A_inv E f c x Δb ΔA ε
      hε hE hf hden hΔA hΔb
  have hden_nonneg : 0 ≤ |ch7LinearFunctional n c x| := le_of_lt hden
  unfold ch7Problem79ExactScalarRelativeChange
  calc
    |ch7LinearFunctional n c
        (fun i => ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i)| /
        |ch7LinearFunctional n c x|
        ≤
        (|ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| +
          |ch7LinearFunctional n c Rem|) /
          |ch7LinearFunctional n c x| := by
          apply div_le_div_of_nonneg_right _ hden_nonneg
          rw [hscalar]
          simpa [Rem, sub_eq_add_neg] using
            abs_add_le (ch7Problem79FirstOrderChange n A_inv c x Δb ΔA)
              (-(ch7LinearFunctional n c Rem))
    _ =
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA +
          |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| := by
          unfold ch7Problem79LinearizedRelativeChange
          rw [add_div]
    _ ≤
        ε * ch7Problem79LinearizedCond n A_inv E f c x +
          (ε ^ 2 *
            ((∑ i : Fin n, |c i|) *
              (infNorm (ch7InverseFirstProductSensitivity n A_inv E) * C_B *
                ch7Problem79ComponentwiseRhsEnvelope n E f x))) /
            |ch7LinearFunctional n c x| :=
          add_le_add hlin (div_le_div_of_nonneg_right hrem hden_nonneg)
    _ =
        ε * ch7Problem79LinearizedCond n A_inv E f c x +
          ε ^ 2 *
            ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x C_B := by
          unfold ch7Problem79ComponentwiseExactRemainderBound
          ring

/-- Lower companion to the exact Problem 7.9 componentwise bridge.  When the
first-order perturbation attains the linearized condition number, the exact
nonlinear scalar change is within the same quadratic remainder from below. -/
theorem problem7_9_exact_componentwise_relative_change_ge_linearized_minus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA B E : Fin n → Fin n → ℝ) (f c x Δb : Fin n → ℝ)
    (ε C_B : ℝ)
    (hε : 0 ≤ ε)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B)
    (hBnorm : infNorm B ≤ C_B)
    (hlin :
      ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA =
        ε * ch7Problem79LinearizedCond n A_inv E f c x) :
    ε * ch7Problem79LinearizedCond n A_inv E f c x -
        ε ^ 2 *
          ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x C_B ≤
      ch7Problem79ExactScalarRelativeChange n A B c x Δb := by
  let Rem : Fin n → ℝ :=
    matMulVec n (matMul n (matMul n A_inv ΔA) B)
      (fun j => Δb j - matMulVec n ΔA x j)
  have hscalar :=
    ch7Problem79_exact_scalar_decomposition n A A_inv ΔA B c x Δb
      hLeft hRight
  have hrem :=
    ch7Problem79_exact_scalar_remainder_abs_le n hn A_inv ΔA B E f c x Δb
      ε C_B hε hE hf hΔA hΔb hBnorm
  have hden_nonneg : 0 ≤ |ch7LinearFunctional n c x| := le_of_lt hden
  have hrem_div :
      |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| ≤
        ε ^ 2 *
          ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x C_B := by
    calc
      |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x|
          ≤ (ε ^ 2 *
              ((∑ i : Fin n, |c i|) *
                (infNorm (ch7InverseFirstProductSensitivity n A_inv E) * C_B *
                  ch7Problem79ComponentwiseRhsEnvelope n E f x))) /
              |ch7LinearFunctional n c x| :=
            div_le_div_of_nonneg_right hrem hden_nonneg
      _ = ε ^ 2 *
            ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x C_B := by
            unfold ch7Problem79ComponentwiseExactRemainderBound
            ring
  have habs :
      |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| -
          |ch7LinearFunctional n c Rem| ≤
        |ch7LinearFunctional n c
          (fun i => ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i)| := by
    have hbase :=
      abs_sub_abs_le_abs_sub
        (ch7Problem79FirstOrderChange n A_inv c x Δb ΔA)
        (ch7LinearFunctional n c Rem)
    rw [hscalar]
    exact hbase
  have hdiv :
      ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA -
          |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| ≤
        ch7Problem79ExactScalarRelativeChange n A B c x Δb := by
    unfold ch7Problem79LinearizedRelativeChange
      ch7Problem79ExactScalarRelativeChange
    have h :=
      div_le_div_of_nonneg_right habs hden_nonneg
    simpa [sub_div] using h
  have hsub :
      ε * ch7Problem79LinearizedCond n A_inv E f c x -
          ε ^ 2 *
            ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x C_B ≤
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA -
          |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| := by
    linarith
  exact le_trans hsub hdiv

/-- Exact source-radius feasible scalar-output values for the componentwise
Problem 7.9 condition number.  The perturbed solution is evaluated with the
local inverse candidate already proved valid for sufficiently small radii. -/
def Ch7Problem79ComponentwiseExactRadiusSet
    (n : ℕ)
    (A A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ℝ) : Set ℝ :=
  { q | ∃ ε : ℝ, ∃ ΔA : Fin n → Fin n → ℝ, ∃ Δb : Fin n → ℝ,
      0 < ε ∧
      ε ≤ rho ∧
      (∀ i j, |ΔA i j| ≤ ε * E i j) ∧
      (∀ i, |Δb i| ≤ ε * f i) ∧
      q =
        ch7Problem79ExactScalarRelativeChange n A
          (ch7Problem711PerturbedInverseCandidate n A_inv ΔA) c x Δb / ε }

/-- Supremum over the exact componentwise scalar-output radius set in Problem
7.9. -/
noncomputable def ch7Problem79ComponentwiseExactRadiusSup
    (n : ℕ)
    (A A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ℝ) : ℝ :=
  sSup (Ch7Problem79ComponentwiseExactRadiusSet n A A_inv E f c x rho)

/-- Limit-value predicate for the exact componentwise scalar-output condition
number in Problem 7.9. -/
def IsCh7Problem79ComponentwiseExactRadiusLimitValue
    {ι : Type*} (l : Filter ι)
    (n : ℕ)
    (A A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ι → ℝ)
    (κ : ℝ) : Prop :=
  Filter.Tendsto
    (fun t => ch7Problem79ComponentwiseExactRadiusSup
      n A A_inv E f c x (rho t))
    l (nhds κ)

/-- Value predicate for the exact componentwise scalar-output condition number:
the nonlinear source value equals the checked finite linearized formula. -/
def IsCh7Problem79ComponentwiseExactCondValue
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (κ : ℝ) : Prop :=
  κ = ch7Problem79LinearizedCond n A_inv E f c x

/-- Radius-level quadratic coefficient for the exact componentwise Problem 7.9
source squeeze, using the uniform local inverse bound from Problem 7.11. -/
noncomputable def ch7Problem79ComponentwiseExactRadiusRemainderBound (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) : ℝ :=
  ch7Problem79ComponentwiseExactRemainderBound n A_inv E f c x
    (ch7Problem711LocalInverseInfNormBound n A_inv)

lemma ch7Problem79ComponentwiseExactRadiusRemainderBound_nonneg (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    0 ≤ ch7Problem79ComponentwiseExactRadiusRemainderBound n A_inv E f c x := by
  unfold ch7Problem79ComponentwiseExactRadiusRemainderBound
  exact
    ch7Problem79ComponentwiseExactRemainderBound_nonneg n A_inv E f c x
      (ch7Problem711LocalInverseInfNormBound n A_inv) hE hf
      (ch7Problem711LocalInverseInfNormBound_nonneg n A_inv) hden

/-- Upper envelope for every exact source-radius feasible scalar-output value
in the componentwise Problem 7.9 set. -/
theorem ch7Problem79ComponentwiseExactRadiusSet_value_le
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) {rho q : ℝ}
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hLeft : IsLeftInverse n A A_inv)
    (hsmall :
      rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤ (1 / 2 : ℝ))
    (hq :
      q ∈ Ch7Problem79ComponentwiseExactRadiusSet n A A_inv E f c x rho) :
    q ≤ ch7Problem79LinearizedCond n A_inv E f c x +
      rho * ch7Problem79ComponentwiseExactRadiusRemainderBound n A_inv E f c x := by
  rcases hq with ⟨ε, ΔA, Δb, hεpos, hερ, hΔA, hΔb, rfl⟩
  let B := ch7Problem711PerturbedInverseCandidate n A_inv ΔA
  let C := ch7Problem79ComponentwiseExactRadiusRemainderBound n A_inv E f c x
  have hε : 0 ≤ ε := le_of_lt hεpos
  have hRight :
      IsRightInverse n (fun i j => A i j + ΔA i j) B :=
    ch7_inverse_componentwise_radius_candidate_right_inverse_of_small
      n hn A A_inv ΔA E ε rho hε hερ hE hΔA hLeft hsmall
  have hBnorm :
      infNorm B ≤ ch7Problem711LocalInverseInfNormBound n A_inv :=
    ch7_inverse_componentwise_radius_candidate_infNorm_bound_of_small
      n hn A_inv ΔA E ε rho hε hερ hE hΔA hsmall
  have hfinite :=
    problem7_9_exact_componentwise_relative_change_le_linearized_plus_quadratic
      n hn A A_inv ΔA B E f c x Δb ε
      (ch7Problem711LocalInverseInfNormBound n A_inv)
      hε hE hf hden hΔA hΔb hLeft hRight hBnorm
  have hCnonneg : 0 ≤ C := by
    dsimp [C]
    exact ch7Problem79ComponentwiseExactRadiusRemainderBound_nonneg
      n A_inv E f c x hE hf hden
  have hε_ne : ε ≠ 0 := ne_of_gt hεpos
  calc
    ch7Problem79ExactScalarRelativeChange n A B c x Δb / ε
        ≤ (ε * ch7Problem79LinearizedCond n A_inv E f c x +
            ε ^ 2 * C) / ε := by
          exact div_le_div_of_nonneg_right (by simpa [B, C] using hfinite) hε
    _ = ch7Problem79LinearizedCond n A_inv E f c x + ε * C := by
          field_simp [hε_ne]
    _ ≤ ch7Problem79LinearizedCond n A_inv E f c x + rho * C :=
          add_le_add le_rfl (mul_le_mul_of_nonneg_right hερ hCnonneg)

/-- Lower witness for the exact componentwise Problem 7.9 source-radius set.
The finite sign perturbation that attains the linearized formula remains within
the explicit quadratic envelope for the nonlinear perturbed solution. -/
theorem exists_ch7Problem79ComponentwiseExactRadiusSet_lower_witness
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) {rho : ℝ}
    (hrho : 0 < rho)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hLeft : IsLeftInverse n A A_inv)
    (hsmall :
      rho * infNorm (ch7InverseFirstProductSensitivity n A_inv E) ≤ (1 / 2 : ℝ)) :
    ∃ q : ℝ,
      q ∈ Ch7Problem79ComponentwiseExactRadiusSet n A A_inv E f c x rho ∧
      ch7Problem79LinearizedCond n A_inv E f c x -
          rho * ch7Problem79ComponentwiseExactRadiusRemainderBound n A_inv E f c x
        ≤ q := by
  let μ := ch7Problem79LinearizedCond n A_inv E f c x
  let C := ch7Problem79ComponentwiseExactRadiusRemainderBound n A_inv E f c x
  rcases
    (problem7_9_linearized_componentwise_functional_formula
      n A_inv E f c x hE hf hden).2 rho (le_of_lt hrho) with
    ⟨ΔA, Δb, hΔA, hΔb, _hfirst, hrel⟩
  let B := ch7Problem711PerturbedInverseCandidate n A_inv ΔA
  let q := ch7Problem79ExactScalarRelativeChange n A B c x Δb / rho
  have hRight :
      IsRightInverse n (fun i j => A i j + ΔA i j) B :=
    ch7_inverse_componentwise_radius_candidate_right_inverse_of_small
      n hn A A_inv ΔA E rho rho (le_of_lt hrho) le_rfl hE hΔA hLeft hsmall
  have hBnorm :
      infNorm B ≤ ch7Problem711LocalInverseInfNormBound n A_inv :=
    ch7_inverse_componentwise_radius_candidate_infNorm_bound_of_small
      n hn A_inv ΔA E rho rho (le_of_lt hrho) le_rfl hE hΔA hsmall
  have hlower :=
    problem7_9_exact_componentwise_relative_change_ge_linearized_minus_quadratic
      n hn A A_inv ΔA B E f c x Δb rho
      (ch7Problem711LocalInverseInfNormBound n A_inv)
      (le_of_lt hrho) hE hf hden hΔA hΔb hLeft hRight hBnorm hrel
  have hrho_ne : rho ≠ 0 := ne_of_gt hrho
  have hdiv :=
    div_le_div_of_nonneg_right hlower (le_of_lt hrho)
  have hleft_eq :
      (rho * μ - rho ^ 2 * C) / rho = μ - rho * C := by
    field_simp [hrho_ne]
  refine ⟨q, ?_, ?_⟩
  · refine ⟨rho, ΔA, Δb, hrho, le_rfl, hΔA, hΔb, ?_⟩
    rfl
  · have hmain : μ - rho * C ≤ q := by
      calc
        μ - rho * C = (rho * μ - rho ^ 2 * C) / rho := by
          rw [hleft_eq]
        _ ≤ q := by
          simpa [q, μ, C, ch7Problem79ComponentwiseExactRadiusRemainderBound]
            using hdiv
    exact hmain

/-- Exact componentwise Problem 7.9 source-radius `sSup` limit.  The nonlinear
scalar-output condition number obtained from the perturbed system agrees with
the finite formula `|cᵀA⁻¹|(E|x|+f)/|cᵀx|`. -/
theorem problem7_9_componentwise_exact_radiusSup_tendsto_linearized
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hrho_tendsto : Filter.Tendsto rho l (nhds 0))
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hLeft : IsLeftInverse n A A_inv) :
    IsCh7Problem79ComponentwiseExactRadiusLimitValue l
      n A A_inv E f c x rho (ch7Problem79LinearizedCond n A_inv E f c x) := by
  dsimp [IsCh7Problem79ComponentwiseExactRadiusLimitValue]
  let μ := ch7Problem79LinearizedCond n A_inv E f c x
  let C := ch7Problem79ComponentwiseExactRadiusRemainderBound n A_inv E f c x
  let P := ch7InverseFirstProductSensitivity n A_inv E
  let L : ι → ℝ := fun t => μ - rho t * C
  let U : ι → ℝ := fun t => μ + rho t * C
  let Q : ι → ℝ :=
    fun t => ch7Problem79ComponentwiseExactRadiusSup n A A_inv E f c x (rho t)
  have hL : Filter.Tendsto L l (nhds μ) := by
    have hterm : Filter.Tendsto (fun t => rho t * C) l (nhds 0) := by
      simpa using hrho_tendsto.mul_const C
    dsimp [L]
    simpa using tendsto_const_nhds.sub hterm
  have hU : Filter.Tendsto U l (nhds μ) := by
    have hterm : Filter.Tendsto (fun t => rho t * C) l (nhds 0) := by
      simpa using hrho_tendsto.mul_const C
    dsimp [U]
    simpa using tendsto_const_nhds.add hterm
  have hsmall : Filter.Eventually
      (fun t => rho t * infNorm P ≤ (1 / 2 : ℝ)) l := by
    have hscaled : Filter.Tendsto (fun t => rho t * infNorm P) l (nhds 0) := by
      simpa [P] using hrho_tendsto.mul_const (infNorm P)
    have hraw := (Metric.tendsto_nhds.mp hscaled) (1 / 2 : ℝ) (by norm_num)
    filter_upwards [hrho_pos, hraw] with t hρpos ht
    have hdist : |rho t * infNorm P| < (1 / 2 : ℝ) := by
      simpa [Real.dist_eq] using ht
    have hnonneg : 0 ≤ rho t * infNorm P :=
      mul_nonneg (le_of_lt hρpos) (infNorm_nonneg P)
    exact le_of_lt (by simpa [abs_of_nonneg hnonneg] using hdist)
  have hbetween : Filter.Eventually (fun t => L t ≤ Q t ∧ Q t ≤ U t) l := by
    filter_upwards [hrho_pos, hsmall] with t hρpos hsmall_t
    obtain ⟨q, hqmem, hLq⟩ :=
      exists_ch7Problem79ComponentwiseExactRadiusSet_lower_witness
        n hn A A_inv E f c x hρpos hE hf hden hLeft hsmall_t
    have hUbound :
        ∀ r : ℝ,
          r ∈ Ch7Problem79ComponentwiseExactRadiusSet
            n A A_inv E f c x (rho t) →
          r ≤ U t := by
      intro r hr
      simpa [U, μ, C] using
        ch7Problem79ComponentwiseExactRadiusSet_value_le
          n hn A A_inv E f c x hE hf hden hLeft hsmall_t hr
    have hbdd :
        BddAbove
          (Ch7Problem79ComponentwiseExactRadiusSet n A A_inv E f c x (rho t)) :=
      ⟨U t, hUbound⟩
    have hq_le_sup :
        q ≤ ch7Problem79ComponentwiseExactRadiusSup n A A_inv E f c x (rho t) :=
      le_csSup hbdd hqmem
    have hsup_le :
        ch7Problem79ComponentwiseExactRadiusSup n A A_inv E f c x (rho t) ≤ U t :=
      csSup_le ⟨q, hqmem⟩ hUbound
    exact ⟨by simpa [L, μ, C] using hLq.trans hq_le_sup, hsup_le⟩
  simpa [L, U, Q, μ] using
    tendsto_of_eventually_between_tendsto hL hU hbetween

/-- Product-plus-limit packaging of Problem 7.9: the exact nonlinear
componentwise scalar-output condition number agrees with the checked finite
linearized formula. -/
theorem problem7_9_componentwise_exact_condition_of_positive_radii
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hrho_tendsto : Filter.Tendsto rho l (nhds 0))
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hLeft : IsLeftInverse n A A_inv) :
    ∃ κ : ℝ,
      IsCh7Problem79ComponentwiseExactCondValue n A_inv E f c x κ ∧
        IsCh7Problem79ComponentwiseExactRadiusLimitValue l
          n A A_inv E f c x rho κ := by
  refine ⟨ch7Problem79LinearizedCond n A_inv E f c x, rfl, ?_⟩
  exact
    problem7_9_componentwise_exact_radiusSup_tendsto_linearized
      n hn A A_inv E f c x rho hrho_pos hrho_tendsto hE hf hden hLeft

