/-- Problem 7.10(b), source-shaped infinity-norm condition-product infimum
under an explicit positive Perron-vector certificate for `|A||A⁻¹|`. -/
theorem problem7_10b_scaledInfKappaSet_sInf_eq_perron_of_abs_inverse_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hAinvx : ∀ i : Fin n, 0 < matMulVec n (absMatrix n A_inv) x i)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i =
        ρ * x i) :
    sInf (ch7TwoSidedScaledInfKappaSet A A_inv) = ρ := by
  let S : Set ℝ := ch7TwoSidedScaledInfKappaSet A A_inv
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledInfKappaSet_nonempty A A_inv
  have hS_bdd : BddBelow S := by
    simpa [S] using ch7TwoSidedScaledInfKappaSet_bddBelow A A_inv
  have hlower : ∀ κ : ℝ, κ ∈ S → ρ ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, hd₁pos, hd₁Invpos,
        hd₂pos, hd₂Invpos, hd₁, hd₂, rfl⟩
    exact problem7_10b_scaled_infKappa_ge_perron_of_abs_inverse_positive_eigenvector
      hn A A_inv ρ x hx heig d₁ d₁Inv d₂ d₂Inv
      hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  have hle_sInf : ρ ≤ sInf S := le_csInf hS_nonempty hlower
  let d₁ : Fin n → ℝ := fun i => (x i)⁻¹
  let d₁Inv : Fin n → ℝ := x
  let d₂ : Fin n → ℝ := fun i => matMulVec n (absMatrix n A_inv) x i
  let d₂Inv : Fin n → ℝ := fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹
  have hcan :
      ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv = ρ := by
    dsimp [d₁, d₁Inv, d₂, d₂Inv]
    exact problem7_10b_canonical_scaled_infKappa_eq_perron_of_abs_inverse_positive_eigenvector
      hn A A_inv ρ x hx hAinvx heig
  have hmem :
      ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ∈ S := by
    dsimp [S, d₁, d₁Inv, d₂, d₂Inv]
    exact ch7TwoSidedScaledInfKappa_mem_set A A_inv
      (fun i => (x i)⁻¹) x
      (fun i => matMulVec n (absMatrix n A_inv) x i)
      (fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹)
      (fun i => inv_pos.mpr (hx i))
      hx hAinvx
      (fun i => inv_pos.mpr (hAinvx i))
      (fun i => inv_mul_cancel₀ (ne_of_gt (hx i)))
      (fun i => mul_inv_cancel₀ (ne_of_gt (hAinvx i)))
  have hρmem : ρ ∈ S := by
    simpa [hcan] using hmem
  have hsInf_le : sInf S ≤ ρ := csInf_le hS_bdd hρmem
  exact le_antisymm hsInf_le hle_sInf

/-- Problem 7.10(b), genuine minimum-attainment form for the positive
two-sided `κ∞` value set, under the same explicit positive Perron-vector
certificate as the `sInf` wrapper.  The membership witness is the source
canonical scaling `D₁ = diag(x)⁻¹`, `D₂ = diag(|A⁻¹|x)`. -/
theorem problem7_10b_scaledInfKappaSet_isLeast_perron_of_abs_inverse_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hAinvx : ∀ i : Fin n, 0 < matMulVec n (absMatrix n A_inv) x i)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i =
        ρ * x i) :
    IsLeast (ch7TwoSidedScaledInfKappaSet A A_inv) ρ := by
  constructor
  · let d₁ : Fin n → ℝ := fun i => (x i)⁻¹
    let d₁Inv : Fin n → ℝ := x
    let d₂ : Fin n → ℝ := fun i => matMulVec n (absMatrix n A_inv) x i
    let d₂Inv : Fin n → ℝ := fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹
    have hcan :
        ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv = ρ := by
      dsimp [d₁, d₁Inv, d₂, d₂Inv]
      exact
        problem7_10b_canonical_scaled_infKappa_eq_perron_of_abs_inverse_positive_eigenvector
          hn A A_inv ρ x hx hAinvx heig
    have hmem :
        ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ∈
          ch7TwoSidedScaledInfKappaSet A A_inv := by
      dsimp [d₁, d₁Inv, d₂, d₂Inv]
      exact ch7TwoSidedScaledInfKappa_mem_set A A_inv
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n (absMatrix n A_inv) x i)
        (fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹)
        (fun i => inv_pos.mpr (hx i))
        hx hAinvx
        (fun i => inv_pos.mpr (hAinvx i))
        (fun i => inv_mul_cancel₀ (ne_of_gt (hx i)))
        (fun i => mul_inv_cancel₀ (ne_of_gt (hAinvx i)))
    simpa [hcan] using hmem
  · intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, hd₁pos, hd₁Invpos,
        hd₂pos, hd₂Invpos, hd₁, hd₂, rfl⟩
    exact problem7_10b_scaled_infKappa_ge_perron_of_abs_inverse_positive_eigenvector
      hn A A_inv ρ x hx heig d₁ d₁Inv d₂ d₂Inv
      hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂

