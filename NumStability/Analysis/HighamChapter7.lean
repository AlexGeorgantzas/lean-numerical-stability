/-- Theorem 7.5, `p = ∞` row minimum-attainment form with full-row-rank
supplied as surjectivity of `x ↦ A*x`. -/
theorem theorem7_5_pinf_row_equilibration_exists_right_inverse_of_rectMatMulVec_surjective
    {m n : ℕ}
