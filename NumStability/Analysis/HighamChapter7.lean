      (absMatrix n A_inv) (absMatrix n A) hCB
  have hTCB : Matrix.IsIrreducible
      (Matrix.of
        (matMul n (matTranspose (absMatrix n A_inv))
          (matTranspose (absMatrix n A))) :
          Matrix (Fin n) (Fin n) ℝ) :=
    ch7_irreducible_transpose_product_of_irreducible_product
      (absMatrix n A) (absMatrix n A_inv) hBC
  have ha_pos : ∀ i : Fin n, 0 < a i := by
    dsimp [a]
    exact problem7_10d_Cx_pos_of_irreducible_BC_CB
      hn (matTranspose (absMatrix n A)) (matTranspose (absMatrix n A_inv))
