    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm2 A i) {μ : ℝ}
    (hmin : IsLeast (ch7Op2LeftScaledCondSet A Aplus) μ) :
    ch7Op2LeftScaledCond A Aplus
        (ch7RowEquilibratingScale2Rect A)
        (fun i : Fin m => ch7RectRowNorm2 A i) ≤
      Real.sqrt (m : ℝ) * μ := by
  simpa [hmin.csInf_eq] using
    theorem7_5_p2_row_equilibration_le_sqrt_card_sInf_left_scalings
      hm A Aplus hrow

/-- Theorem 7.5, `p = 2` row source-`min` wrapper using a least-value
certificate on the absolute-sum-one normalized slice. -/
theorem theorem7_5_p2_row_equilibration_le_sqrt_card_min_left_scalings_of_normalized
    {m n : ℕ} (hm : 0 < m)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
