  exact complexMatrixOp2_realRectToCMatrix_le_of_opNorm2Le
    (ch7HadamardProduct A (matTranspose A_inv))
    (mul_nonneg (complexMatrixOp2_nonneg _) (complexMatrixOp2_nonneg _)) hHad

/-- Problem 7.15 source infimum lower bound:
`||A ∘ A_invᵀ||₂ <= inf_{positive D₁,D₂} κ₂(D₁ A D₂)`, in the repository's
