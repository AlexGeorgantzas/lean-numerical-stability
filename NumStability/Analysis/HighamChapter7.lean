/-- Equation (7.11), infinity-norm specialization:
    `cond_{E,f}(A,x) = ‖|A⁻¹|(E|x|+f)‖∞ / ‖x‖∞`. -/
noncomputable def ch7CondEFAtSolutionInf (n : ℕ) (hn : 0 < n)
    (A_inv : Fin n → Fin n → ℝ) (E : Fin n → Fin n → ℝ)
    (f x : Fin n → ℝ) : ℝ :=
  ch7ForwardBoundEF n hn A_inv E f x / infNormVec x

/-- The infinity norm of a constant nonnegative vector is the constant value. -/
lemma infNormVec_const_nonneg (n : ℕ) (hn : 0 < n) {t : ℝ} (ht : 0 ≤ t) :
    infNormVec (fun _ : Fin n => t) = t := by
  apply le_antisymm
  · apply infNormVec_le_of_abs_le
    · intro i
      simp [abs_of_nonneg ht]
    · exact ht
  · have h := abs_le_infNormVec (fun _ : Fin n => t) ⟨0, hn⟩
    simpa [abs_of_nonneg ht] using h

/-- For nonnegative tolerance matrix `E`, enlarging `|x|` from `0` to a
constant nonnegative vector can only increase the Chapter 7 amplified
right-hand side. -/
lemma ch7AmplifiedRhsEF_zero_le_const (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E : Fin n → Fin n → ℝ) (f : Fin n → ℝ)
    {t : ℝ} (hE : ∀ i j, 0 ≤ E i j) (ht : 0 ≤ t) :
    ∀ i : Fin n,
      ch7AmplifiedRhsEF n A_inv E f (fun _ : Fin n => 0) i ≤
        ch7AmplifiedRhsEF n A_inv E f (fun _ : Fin n => t) i := by
  intro i
  unfold ch7AmplifiedRhsEF
  apply Finset.sum_le_sum
  intro j _
  apply mul_le_mul_of_nonneg_left ?_ (abs_nonneg _)
  have hsum_nonneg : 0 ≤ ∑ k : Fin n, E j k * t := by
    exact Finset.sum_nonneg (fun k _ => mul_nonneg (hE j k) ht)
  rw [show (∑ k : Fin n, E j k * |(fun _ : Fin n => 0) k|) = 0 by simp]
  rw [show (∑ k : Fin n, E j k * |(fun _ : Fin n => t) k|) =
      ∑ k : Fin n, E j k * t by simp [abs_of_nonneg ht]]
  linarith

/-- The Chapter 7 forward bound with fixed `f` is monotone when the solution
vector is replaced by a constant nonnegative vector. -/
lemma ch7ForwardBoundEF_zero_le_const (n : ℕ) (hn : 0 < n)
    (A_inv : Fin n → Fin n → ℝ) (E : Fin n → Fin n → ℝ) (f : Fin n → ℝ)
    {t : ℝ} (hE : ∀ i j, 0 ≤ E i j) (ht : 0 ≤ t) :
    ch7ForwardBoundEF n hn A_inv E f (fun _ : Fin n => 0) ≤
      ch7ForwardBoundEF n hn A_inv E f (fun _ : Fin n => t) := by
  unfold ch7ForwardBoundEF
  apply Finset.sup'_le
  intro i _
  calc
    ch7AmplifiedRhsEF n A_inv E f (fun _ : Fin n => 0) i
        ≤ ch7AmplifiedRhsEF n A_inv E f (fun _ : Fin n => t) i :=
          ch7AmplifiedRhsEF_zero_le_const n A_inv E f hE ht i
    _ ≤ Finset.sup' Finset.univ
          (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
          (ch7AmplifiedRhsEF n A_inv E f (fun _ : Fin n => t)) :=
          Finset.le_sup' (ch7AmplifiedRhsEF n A_inv E f (fun _ : Fin n => t))
            (Finset.mem_univ i)

/-- Diagnostic theorem for equation `(7.12)` under the current fixed-`f` model:
if the `x = 0` contribution from `f` is already positive, then the naive
quantity `cond_{E,f}(A,x)` is unbounded over nonzero `x` because scaling `x`
toward zero leaves the `f` term in the numerator while shrinking the
denominator. -/
theorem exists_ch7CondEFAtSolutionInf_gt_of_positive_fixed_rhs_term
    (n : ℕ) (hn : 0 < n) (A_inv : Fin n → Fin n → ℝ)
    (E : Fin n → Fin n → ℝ) (f : Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j)
    (hc :
      0 < ch7ForwardBoundEF n hn A_inv E f (fun _ : Fin n => 0)) :
    ∀ M : ℝ, 0 ≤ M →
      ∃ x : Fin n → ℝ, 0 < infNormVec x ∧
        M < ch7CondEFAtSolutionInf n hn A_inv E f x := by
  intro M hM
  let c : ℝ := ch7ForwardBoundEF n hn A_inv E f (fun _ : Fin n => 0)
  let t : ℝ := c / (M + 1)
  have hM1 : 0 < M + 1 := by linarith
  have hc_ne : c ≠ 0 := ne_of_gt hc
  have ht : 0 < t := by
    dsimp [t, c]
    exact div_pos hc hM1
  refine ⟨fun _ : Fin n => t, ?_, ?_⟩
  · rw [infNormVec_const_nonneg n hn (le_of_lt ht)]
    exact ht
  · have hbound :
        c / t ≤ ch7CondEFAtSolutionInf n hn A_inv E f (fun _ : Fin n => t) := by
      unfold ch7CondEFAtSolutionInf
      rw [infNormVec_const_nonneg n hn (le_of_lt ht)]
      exact div_le_div_of_nonneg_right
        (ch7ForwardBoundEF_zero_le_const n hn A_inv E f hE (le_of_lt ht))
        (le_of_lt ht)
    have hct : c / t = M + 1 := by
      dsimp [t]
      field_simp [hM1.ne', hc_ne]
    have hMlt : M < c / t := by
      rw [hct]
      linarith
    exact hMlt.trans_le hbound

/-- Equation (7.13), infinity-norm Skeel condition number at a solution:
    `cond(A,x) = ‖|A⁻¹||A||x|‖∞ / ‖x‖∞`. -/
noncomputable def ch7SkeelCondAtSolutionInf (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) : ℝ :=
  ch7CondEFAtSolutionInf n hn A_inv (fun i j => |A i j|) (fun _ => 0) x

/-- Equation (7.12), modeled as the least upper bound of the
solution-dependent quantities.  The right-hand-side tolerance is allowed to
depend on `x`, which covers Higham's `f = |b| = |Ax|` reading and avoids the
fixed-`f` unboundedness diagnosed above. -/
noncomputable def ch7CondEFGlobalInf (n : ℕ) (hn : 0 < n)
    (A_inv : Fin n → Fin n → ℝ) (E : Fin n → Fin n → ℝ)
    (fOfX : (Fin n → ℝ) → Fin n → ℝ) : ℝ :=
  sSup {κ : ℝ | ∃ x : Fin n → ℝ, 0 < infNormVec x ∧
    κ = ch7CondEFAtSolutionInf n hn A_inv E (fOfX x) x}

/-- The `(7.12)` global condition number for the Skeel specialization
`E = |A|`, `f = 0`. -/
noncomputable def ch7SkeelGlobalCondInf (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) : ℝ :=
  ch7CondEFGlobalInf n hn A_inv (fun i j => |A i j|) (fun _x _ => 0)

/-- The infinity norm of the all-ones vector is one for `n > 0`. -/
lemma infNormVec_const_one (n : ℕ) (hn : 0 < n) :
    infNormVec (fun _ : Fin n => (1 : ℝ)) = 1 := by
  apply le_antisymm
  · apply infNormVec_le_of_abs_le
    · intro i
      simp
    · norm_num
  · have h := abs_le_infNormVec (fun _ : Fin n => (1 : ℝ)) ⟨0, hn⟩
    simpa using h

/-- Equation (7.14): the global Skeel condition is the solution-dependent
    Skeel condition evaluated at `e`. -/
theorem ch7SkeelCondAtOnes_eq_condSkeel (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) :
    ch7SkeelCondAtSolutionInf n hn A A_inv (fun _ : Fin n => (1 : ℝ)) =
      condSkeel n hn A A_inv := by
  unfold ch7SkeelCondAtSolutionInf ch7CondEFAtSolutionInf ch7ForwardBoundEF
    ch7AmplifiedRhsEF condSkeel
  rw [infNormVec_const_one n hn]
  simp

/-- Numerator bound behind `(7.12)`: `|A⁻¹||A||x|` is bounded componentwise
by `‖x‖∞` times the row sums defining `cond(A)`. -/
lemma ch7SkeelAmplifiedRhs_le_infNormVec_mul_condRow (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) (i : Fin n) :
    ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|) (fun _ => 0) x i ≤
      infNormVec x * (∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|) := by
  unfold ch7AmplifiedRhsEF
  calc
    ∑ j : Fin n, |A_inv i j| *
        (∑ k : Fin n, |A j k| * |x k| + 0)
        = ∑ j : Fin n, |A_inv i j| *
          ∑ k : Fin n, |A j k| * |x k| := by
          simp
    _ ≤ ∑ j : Fin n, infNormVec x *
          (|A_inv i j| * ∑ k : Fin n, |A j k|) := by
          apply Finset.sum_le_sum
          intro j _
          have hinner :
              ∑ k : Fin n, |A j k| * |x k| ≤
                infNormVec x * ∑ k : Fin n, |A j k| := by
            calc
              ∑ k : Fin n, |A j k| * |x k|
                  ≤ ∑ k : Fin n, |A j k| * infNormVec x := by
                    apply Finset.sum_le_sum
                    intro k _
                    exact mul_le_mul_of_nonneg_left
                      (abs_le_infNormVec x k) (abs_nonneg _)
              _ = infNormVec x * ∑ k : Fin n, |A j k| := by
                    rw [Finset.mul_sum]
                    apply Finset.sum_congr rfl
                    intro k _
                    ring
          calc
            |A_inv i j| * ∑ k : Fin n, |A j k| * |x k|
                ≤ |A_inv i j| *
                  (infNormVec x * ∑ k : Fin n, |A j k|) :=
                    mul_le_mul_of_nonneg_left hinner (abs_nonneg _)
            _ = infNormVec x *
                (|A_inv i j| * ∑ k : Fin n, |A j k|) := by
                  ring
    _ = infNormVec x *
        ∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k| := by
          rw [Finset.mul_sum]

/-- The solution-dependent Skeel condition number is bounded above by the
global Skeel condition number for every nonzero solution vector. -/
theorem ch7SkeelCondAtSolutionInf_le_condSkeel (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hx : 0 < infNormVec x) :
    ch7SkeelCondAtSolutionInf n hn A A_inv x ≤ condSkeel n hn A A_inv := by
  have hnum :
      ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|) (fun _ => 0) x ≤
        infNormVec x * condSkeel n hn A A_inv := by
    unfold ch7ForwardBoundEF condSkeel
    apply Finset.sup'_le
    intro i _
    calc
      ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|) (fun _ => 0) x i
          ≤ infNormVec x *
            (∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|) :=
              ch7SkeelAmplifiedRhs_le_infNormVec_mul_condRow n A A_inv x i
      _ ≤ infNormVec x *
          Finset.sup' Finset.univ
            (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
            (fun i => ∑ j : Fin n, |A_inv i j| *
              ∑ k : Fin n, |A j k|) :=
            mul_le_mul_of_nonneg_left
              (Finset.le_sup'
                (fun i => ∑ j : Fin n, |A_inv i j| *
                  ∑ k : Fin n, |A j k|)
                (Finset.mem_univ i))
              (infNormVec_nonneg x)
  unfold ch7SkeelCondAtSolutionInf ch7CondEFAtSolutionInf
  rw [div_le_iff₀ hx]
  simpa [mul_comm] using hnum

/-- Equation (7.12) in the Skeel specialization: the global supremum over
nonzero `x` equals the source's `cond(A)`, attained at the all-ones vector. -/
theorem eq_7_12_skeel_global_conditionNumber_eq_condSkeel (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) :
    ch7SkeelGlobalCondInf n hn A A_inv = condSkeel n hn A A_inv := by
  let S : Set ℝ := {κ : ℝ | ∃ x : Fin n → ℝ, 0 < infNormVec x ∧
    κ = ch7CondEFAtSolutionInf n hn A_inv (fun i j => |A i j|) (fun _ => 0) x}
  have hone_pos : 0 < infNormVec (fun _ : Fin n => (1 : ℝ)) := by
    rw [infNormVec_const_one n hn]
    norm_num
  have hmem : condSkeel n hn A A_inv ∈ S := by
    refine ⟨fun _ : Fin n => (1 : ℝ), hone_pos, ?_⟩
    simpa [S, ch7SkeelCondAtSolutionInf] using
      (ch7SkeelCondAtOnes_eq_condSkeel n hn A A_inv).symm
  have hbound : ∀ r : ℝ, r ∈ S → r ≤ condSkeel n hn A A_inv := by
    intro r hr
    rcases hr with ⟨x, hx, rfl⟩
    simpa [S, ch7SkeelCondAtSolutionInf] using
      ch7SkeelCondAtSolutionInf_le_condSkeel n hn A A_inv x hx
  have hbdd : BddAbove S := ⟨condSkeel n hn A A_inv, hbound⟩
  change sSup S = condSkeel n hn A A_inv
  exact le_antisymm (csSup_le ⟨condSkeel n hn A A_inv, hmem⟩ hbound)
    (le_csSup hbdd hmem)

/-- The componentwise relative-data condition at `x`, using the source
specialization `E = |A|` and `f = |b| = |Ax|`. -/
noncomputable def ch7ComponentwiseDataCondAtSolutionInf (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) : ℝ :=
  ch7CondEFAtSolutionInf n hn A_inv (fun i j => |A i j|)
    (fun i => |matMulVec n A x i|) x

/-- Triangle inequality for the source right-hand side `b = Ax`. -/
lemma ch7_abs_matMulVec_le_abs_matrix_mul_absVec (n : ℕ)
    (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ) (i : Fin n) :
    |matMulVec n A x i| ≤ ∑ k : Fin n, |A i k| * |x k| := by
  unfold matMulVec
  calc
    |∑ k : Fin n, A i k * x k|
        ≤ ∑ k : Fin n, |A i k * x k| := Finset.abs_sum_le_sum_abs _ _
    _ = ∑ k : Fin n, |A i k| * |x k| := by
          apply Finset.sum_congr rfl
          intro k _
          rw [abs_mul]

lemma ch7SkeelAmplifiedRhs_le_componentwiseDataAmplifiedRhs (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) (i : Fin n) :
    ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|) (fun _ => 0) x i ≤
      ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|)
        (fun i => |matMulVec n A x i|) x i := by
  unfold ch7AmplifiedRhsEF
  apply Finset.sum_le_sum
  intro j _
  apply mul_le_mul_of_nonneg_left ?_ (abs_nonneg _)
  linarith [abs_nonneg (matMulVec n A x j)]

lemma ch7ComponentwiseDataAmplifiedRhs_le_two_mul_skeelAmplifiedRhs (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) (i : Fin n) :
    ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|)
        (fun i => |matMulVec n A x i|) x i ≤
      2 * ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|) (fun _ => 0) x i := by
  unfold ch7AmplifiedRhsEF
  calc
    ∑ j : Fin n, |A_inv i j| *
        (∑ k : Fin n, |A j k| * |x k| + |matMulVec n A x j|)
        ≤ ∑ j : Fin n, |A_inv i j| *
          (2 * ∑ k : Fin n, |A j k| * |x k|) := by
          apply Finset.sum_le_sum
          intro j _
          apply mul_le_mul_of_nonneg_left ?_ (abs_nonneg _)
          linarith [ch7_abs_matMulVec_le_abs_matrix_mul_absVec n A x j]
    _ = 2 * ∑ j : Fin n, |A_inv i j| *
        (∑ k : Fin n, |A j k| * |x k| + 0) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring

/-- The source `f = |Ax|` componentwise-data condition is at least the Skeel
condition at the same nonzero solution vector. -/
theorem ch7SkeelCondAtSolutionInf_le_componentwiseDataCondAtSolutionInf
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hx : 0 < infNormVec x) :
    ch7SkeelCondAtSolutionInf n hn A A_inv x ≤
      ch7ComponentwiseDataCondAtSolutionInf n hn A A_inv x := by
  have hnum :
      ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|) (fun _ => 0) x ≤
        ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|)
          (fun i => |matMulVec n A x i|) x := by
    unfold ch7ForwardBoundEF
    apply Finset.sup'_le
    intro i _
    exact le_trans
      (ch7SkeelAmplifiedRhs_le_componentwiseDataAmplifiedRhs n A A_inv x i)
      (Finset.le_sup'
        (ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|)
          (fun i => |matMulVec n A x i|) x)
        (Finset.mem_univ i))
  unfold ch7SkeelCondAtSolutionInf ch7ComponentwiseDataCondAtSolutionInf
    ch7CondEFAtSolutionInf
  exact div_le_div_of_nonneg_right hnum (le_of_lt hx)

/-- The source prose after `(7.14)`: for `f = |b| = |Ax|`, the
componentwise-data condition differs from `cond(A,x)` by at most a factor
`2`. -/
theorem ch7ComponentwiseDataCondAtSolutionInf_le_two_mul_skeelCondAtSolutionInf
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hx : 0 < infNormVec x) :
    ch7ComponentwiseDataCondAtSolutionInf n hn A A_inv x ≤
      2 * ch7SkeelCondAtSolutionInf n hn A A_inv x := by
  have hnum :
      ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|)
          (fun i => |matMulVec n A x i|) x ≤
        2 * ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|) (fun _ => 0) x := by
    unfold ch7ForwardBoundEF
    apply Finset.sup'_le
    intro i _
    calc
      ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|)
          (fun i => |matMulVec n A x i|) x i
          ≤ 2 * ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|)
            (fun _ => 0) x i :=
            ch7ComponentwiseDataAmplifiedRhs_le_two_mul_skeelAmplifiedRhs n A A_inv x i
      _ ≤ 2 * Finset.sup' Finset.univ
          (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩)
          (ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|) (fun _ => 0) x) :=
          mul_le_mul_of_nonneg_left
            (Finset.le_sup'
              (ch7AmplifiedRhsEF n A_inv (fun i j => |A i j|) (fun _ => 0) x)
              (Finset.mem_univ i))
            (by norm_num)
  unfold ch7SkeelCondAtSolutionInf ch7ComponentwiseDataCondAtSolutionInf
    ch7CondEFAtSolutionInf
  calc
    ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|)
        (fun i => |matMulVec n A x i|) x / infNormVec x
        ≤ (2 * ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|)
          (fun _ => 0) x) / infNormVec x :=
          div_le_div_of_nonneg_right hnum (le_of_lt hx)
    _ = 2 * (ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|)
        (fun _ => 0) x / infNormVec x) := by
          ring

-- ============================================================
-- Problem 7.5: SVD-projected perturbation bound
-- ============================================================

lemma ch7Problem75_monomial_mulVec_apply_perm
    {ι : Type*} [Fintype ι] [DecidableEq ι]
    (q : Equiv.Perm ι) (z : ι → ℂ) (x : EuclideanSpace ℂ ι) (i : ι) :
    Matrix.mulVec (highamProblem65MonomialMatrix q z) x (q i) = z i * x i := by
  classical
  rw [Matrix.mulVec]
  simp [dotProduct, highamProblem65MonomialMatrix]

lemma ch7Problem75_monomial_mulVec_norm_sq_eq_sum
    {ι : Type*} [Fintype ι] [DecidableEq ι]
    (q : Equiv.Perm ι) (s : ι → ℝ) (x : EuclideanSpace ℂ ι) :
    ‖(WithLp.toLp (2 : ENNReal)
        (Matrix.mulVec (highamProblem65MonomialMatrix q (fun i => (s i : ℂ)))
          (WithLp.ofLp x)) : EuclideanSpace ℂ ι)‖ ^ 2 =
      ∑ i : ι, s i ^ 2 * ‖x i‖ ^ 2 := by
  classical
  rw [EuclideanSpace.norm_sq_eq]
  calc
    (∑ i : ι,
        ‖(WithLp.toLp (2 : ENNReal)
            (Matrix.mulVec (highamProblem65MonomialMatrix q (fun i => (s i : ℂ)))
              (WithLp.ofLp x)) : EuclideanSpace ℂ ι) i‖ ^ 2)
        = ∑ i : ι,
            ‖(WithLp.toLp (2 : ENNReal)
                (Matrix.mulVec (highamProblem65MonomialMatrix q (fun i => (s i : ℂ)))
                  (WithLp.ofLp x)) : EuclideanSpace ℂ ι) (q i)‖ ^ 2 := by
          exact (Fintype.sum_equiv q
            (fun i : ι =>
              ‖(WithLp.toLp (2 : ENNReal)
                (Matrix.mulVec (highamProblem65MonomialMatrix q (fun i => (s i : ℂ)))
                  (WithLp.ofLp x)) : EuclideanSpace ℂ ι) (q i)‖ ^ 2)
            (fun i : ι =>
              ‖(WithLp.toLp (2 : ENNReal)
                (Matrix.mulVec (highamProblem65MonomialMatrix q (fun i => (s i : ℂ)))
                  (WithLp.ofLp x)) : EuclideanSpace ℂ ι) i‖ ^ 2)
            (fun _ => rfl)).symm
    _ = ∑ i : ι, s i ^ 2 * ‖x i‖ ^ 2 := by
          apply Finset.sum_congr rfl
          intro i _hi
          simp only
          rw [ch7Problem75_monomial_mulVec_apply_perm]
          rw [norm_mul]
          rw [Complex.norm_real]
          rw [Real.norm_eq_abs, mul_pow, sq_abs]

/-- Higham, 2nd ed., Chapter 7, Problem 7.5: SVD-coordinate norm of the
    projection onto selected left singular directions.  The source projection
    `P_k b` is represented by the coordinates of `b` in a target orthonormal
    basis containing the local left singular vectors. -/
noncomputable def ch7Problem75SVDProjectionNorm {n : ℕ}
    (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (tail : Finset (Fin n)) (y : EuclideanSpace ℂ (Fin n)) : ℝ :=
  Real.sqrt
    (∑ i ∈ tail,
      ‖b.repr y (complexMatrixLeftSingularVectorBasisPerm A b hcontains i)‖ ^ 2)

lemma ch7Problem75SVDProjectionNorm_nonneg {n : ℕ}
    (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (tail : Finset (Fin n)) (y : EuclideanSpace ℂ (Fin n)) :
    0 ≤ ch7Problem75SVDProjectionNorm A b hcontains tail y :=
  Real.sqrt_nonneg _

lemma ch7Problem75SVDProjectionNorm_sq {n : ℕ}
    (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (tail : Finset (Fin n)) (y : EuclideanSpace ℂ (Fin n)) :
    ch7Problem75SVDProjectionNorm A b hcontains tail y ^ 2 =
      ∑ i ∈ tail,
        ‖b.repr y (complexMatrixLeftSingularVectorBasisPerm A b hcontains i)‖ ^ 2 := by
  unfold ch7Problem75SVDProjectionNorm
  rw [Real.sq_sqrt]
  exact Finset.sum_nonneg fun i _ => sq_nonneg _

lemma ch7Problem75_orthonormalBasis_repr_norm_sq {ι : Type*} [Fintype ι]
    (b : OrthonormalBasis ι ℂ (EuclideanSpace ℂ ι))
    (x : EuclideanSpace ℂ ι) :
    (∑ i : ι, ‖b.repr x i‖ ^ 2) = ‖x‖ ^ 2 := by
  have hnorm : ‖b.repr x‖ = ‖x‖ :=
    LinearIsometryEquiv.norm_map b.repr x
  rw [← hnorm, EuclideanSpace.norm_sq_eq]

theorem problem7_5_projection_norm_le_sigmaTail_mul_norm
    {n : ℕ} (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (tail : Finset (Fin n)) (x : EuclideanSpace ℂ (Fin n))
    {sigmaTail : ℝ}
    (hsigmaTail_nonneg : 0 ≤ sigmaTail)
    (htail : ∀ i : Fin n, i ∈ tail → complexMatrixSingularValue A i ≤ sigmaTail) :
    ch7Problem75SVDProjectionNorm A b hcontains tail
        (complexMatrixEuclideanLin A x) ≤ sigmaTail * ‖x‖ := by
  classical
  let q : Equiv.Perm (Fin n) := complexMatrixLeftSingularVectorBasisPerm A b hcontains
  let coeff : EuclideanSpace ℂ (Fin n) := (complexMatrixGramEigenvectorBasis A).repr x
  have hcoord :
      Matrix.mulVec (highamProblem65MonomialMatrix q
          (fun i => (complexMatrixSingularValue A i : ℂ))) coeff =
        b.repr (complexMatrixEuclideanLin A x) := by
    have h :=
      complexMatrixSVDFinDiagonalCoordinateMatrix_mulVec_repr A b hcontains x
    rw [complexMatrixSVDFinDiagonalCoordinateMatrix_eq_monomial_basisPerm A b hcontains] at h
    simpa [q, coeff] using h
  have hcoord_apply :
      ∀ i : Fin n,
        b.repr (complexMatrixEuclideanLin A x) (q i) =
          (complexMatrixSingularValue A i : ℂ) * coeff i := by
    intro i
    rw [← hcoord]
    exact ch7Problem75_monomial_mulVec_apply_perm q
      (fun i => (complexMatrixSingularValue A i : ℂ)) coeff i
  apply (sq_le_sq₀
    (ch7Problem75SVDProjectionNorm_nonneg A b hcontains tail
      (complexMatrixEuclideanLin A x))
    (mul_nonneg hsigmaTail_nonneg (norm_nonneg x))).mp
  rw [ch7Problem75SVDProjectionNorm_sq, mul_pow]
  calc
    (∑ i ∈ tail,
        ‖b.repr (complexMatrixEuclideanLin A x)
          (complexMatrixLeftSingularVectorBasisPerm A b hcontains i)‖ ^ 2)
        = ∑ i ∈ tail,
            complexMatrixSingularValue A i ^ 2 * ‖coeff i‖ ^ 2 := by
          apply Finset.sum_congr rfl
          intro i hi
          have hci := hcoord_apply i
          simp [q] at hci
          rw [hci, norm_mul, Complex.norm_real, Real.norm_eq_abs, mul_pow, sq_abs]
    _ ≤ ∑ i ∈ tail, sigmaTail ^ 2 * ‖coeff i‖ ^ 2 := by
          apply Finset.sum_le_sum
          intro i hi
          exact mul_le_mul_of_nonneg_right
            ((sq_le_sq₀ (complexMatrixSingularValue_nonneg A i)
              hsigmaTail_nonneg).mpr (htail i hi))
            (sq_nonneg _)
    _ ≤ ∑ i : Fin n, sigmaTail ^ 2 * ‖coeff i‖ ^ 2 := by
          exact Finset.sum_le_sum_of_subset_of_nonneg
            (by intro i hi; exact Finset.mem_univ i)
            (by intro i _hi_univ _hi_not_tail; exact mul_nonneg (sq_nonneg _) (sq_nonneg _))
    _ = sigmaTail ^ 2 * ‖x‖ ^ 2 := by
          rw [← Finset.mul_sum]
          rw [ch7Problem75_orthonormalBasis_repr_norm_sq]

theorem problem7_5_sigmaMin_mul_norm_le_image_norm
    {n : ℕ} (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (z : EuclideanSpace ℂ (Fin n)) {sigmaMin : ℝ}
    (hsigmaMin_nonneg : 0 ≤ sigmaMin)
    (hmin : ∀ i : Fin n, sigmaMin ≤ complexMatrixSingularValue A i) :
    sigmaMin * ‖z‖ ≤ ‖complexMatrixEuclideanLin A z‖ := by
  classical
  let q : Equiv.Perm (Fin n) := complexMatrixLeftSingularVectorBasisPerm A b hcontains
  let coeff : EuclideanSpace ℂ (Fin n) := (complexMatrixGramEigenvectorBasis A).repr z
  have hcoord :
      Matrix.mulVec (highamProblem65MonomialMatrix q
          (fun i => (complexMatrixSingularValue A i : ℂ))) coeff =
        b.repr (complexMatrixEuclideanLin A z) := by
    have h :=
      complexMatrixSVDFinDiagonalCoordinateMatrix_mulVec_repr A b hcontains z
    rw [complexMatrixSVDFinDiagonalCoordinateMatrix_eq_monomial_basisPerm A b hcontains] at h
    simpa [q, coeff] using h
  have hcoord_lift :
      (WithLp.toLp (2 : ENNReal)
        (Matrix.mulVec (highamProblem65MonomialMatrix q
          (fun i => (complexMatrixSingularValue A i : ℂ)))
          (WithLp.ofLp coeff)) : EuclideanSpace ℂ (Fin n)) =
        b.repr (complexMatrixEuclideanLin A z) := by
    apply WithLp.ofLp_injective
    simpa [q, coeff] using hcoord
  have hnorm_repr :
      ‖b.repr (complexMatrixEuclideanLin A z)‖ =
        ‖complexMatrixEuclideanLin A z‖ :=
    LinearIsometryEquiv.norm_map b.repr (complexMatrixEuclideanLin A z)
  have himage_sq :
      ‖complexMatrixEuclideanLin A z‖ ^ 2 =
        ∑ i : Fin n, complexMatrixSingularValue A i ^ 2 * ‖coeff i‖ ^ 2 := by
    rw [← hnorm_repr, ← hcoord_lift]
    exact ch7Problem75_monomial_mulVec_norm_sq_eq_sum q
      (fun i => complexMatrixSingularValue A i) coeff
  apply (sq_le_sq₀
    (mul_nonneg hsigmaMin_nonneg (norm_nonneg z))
    (norm_nonneg (complexMatrixEuclideanLin A z))).mp
  rw [mul_pow, himage_sq]
  calc
    sigmaMin ^ 2 * ‖z‖ ^ 2
        = ∑ i : Fin n, sigmaMin ^ 2 * ‖coeff i‖ ^ 2 := by
          rw [← ch7Problem75_orthonormalBasis_repr_norm_sq
            (complexMatrixGramEigenvectorBasis A) z]
          rw [Finset.mul_sum]
    _ ≤ ∑ i : Fin n, complexMatrixSingularValue A i ^ 2 * ‖coeff i‖ ^ 2 := by
          apply Finset.sum_le_sum
          intro i _hi
          exact mul_le_mul_of_nonneg_right
            ((sq_le_sq₀ hsigmaMin_nonneg
              (complexMatrixSingularValue_nonneg A i)).mpr (hmin i))
            (sq_nonneg _)

theorem problem7_5_norm_le_inv_sigmaMin_mul_image_norm
    {n : ℕ} (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (z : EuclideanSpace ℂ (Fin n)) {sigmaMin : ℝ}
    (hsigmaMin_pos : 0 < sigmaMin)
    (hmin : ∀ i : Fin n, sigmaMin ≤ complexMatrixSingularValue A i) :
    ‖z‖ ≤ sigmaMin⁻¹ * ‖complexMatrixEuclideanLin A z‖ := by
  have h :=
    problem7_5_sigmaMin_mul_norm_le_image_norm A b hcontains z
      hsigmaMin_pos.le hmin
  calc
    ‖z‖ = sigmaMin⁻¹ * (sigmaMin * ‖z‖) := by
      rw [← mul_assoc, inv_mul_cancel₀ (ne_of_gt hsigmaMin_pos), one_mul]
    _ ≤ sigmaMin⁻¹ * ‖complexMatrixEuclideanLin A z‖ :=
      mul_le_mul_of_nonneg_left h (inv_nonneg.mpr hsigmaMin_pos.le)

lemma problem7_5_relative_error_algebra
    {dxNorm xNorm dbNorm bNorm sigmaMin sigmaTail projNorm : ℝ}
    (hsigmaMin_pos : 0 < sigmaMin)
    (hsigmaTail_pos : 0 < sigmaTail)
    (hxNorm_pos : 0 < xNorm)
    (hbNorm_pos : 0 < bNorm)
    (hprojNorm_pos : 0 < projNorm)
    (hdbNorm_nonneg : 0 ≤ dbNorm)
    (hdx : dxNorm ≤ sigmaMin⁻¹ * dbNorm)
    (hproj : projNorm ≤ sigmaTail * xNorm) :
    dxNorm / xNorm ≤
      (sigmaTail * bNorm) / (sigmaMin * projNorm) * (dbNorm / bNorm) := by
  have hproj_div : projNorm / sigmaTail ≤ xNorm := by
    rw [div_le_iff₀ hsigmaTail_pos]
    simpa [mul_comm] using hproj
  have hinv' : 1 / xNorm ≤ 1 / (projNorm / sigmaTail) :=
    one_div_le_one_div_of_le (div_pos hprojNorm_pos hsigmaTail_pos) hproj_div
  have hinv : xNorm⁻¹ ≤ sigmaTail / projNorm := by
    rw [one_div, one_div] at hinv'
    calc
      xNorm⁻¹ ≤ (projNorm / sigmaTail)⁻¹ := hinv'
      _ = sigmaTail / projNorm := by
          field_simp [ne_of_gt hprojNorm_pos, ne_of_gt hsigmaTail_pos]
  calc
    dxNorm / xNorm = dxNorm * xNorm⁻¹ := by rw [div_eq_mul_inv]
    _ ≤ (sigmaMin⁻¹ * dbNorm) * xNorm⁻¹ :=
        mul_le_mul_of_nonneg_right hdx (inv_nonneg.mpr hxNorm_pos.le)
    _ ≤ (sigmaMin⁻¹ * dbNorm) * (sigmaTail / projNorm) :=
        mul_le_mul_of_nonneg_left hinv
          (mul_nonneg (inv_nonneg.mpr hsigmaMin_pos.le) hdbNorm_nonneg)
    _ = (sigmaTail * bNorm) / (sigmaMin * projNorm) * (dbNorm / bNorm) := by
        field_simp [ne_of_gt hsigmaMin_pos, ne_of_gt hprojNorm_pos,
          ne_of_gt hbNorm_pos]

/-- Higham, 2nd ed., Chapter 7, Problem 7.5: SVD-coordinate relative
    perturbation bound.  This is the complex finite-dimensional generalization
    of the real source statement; real matrices instantiate it through the
    repository's `realRectToCMatrix` bridge. -/
theorem problem7_5_svd_projection_relative_error_bound
    {n : ℕ} (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (tail : Finset (Fin n)) (x dx : EuclideanSpace ℂ (Fin n))
    {sigmaMin sigmaTail : ℝ}
    (hsigmaMin_pos : 0 < sigmaMin)
    (hsigmaTail_pos : 0 < sigmaTail)
    (hx_pos : 0 < ‖x‖)
    (hb_pos : 0 < ‖complexMatrixEuclideanLin A x‖)
    (hproj_pos :
      0 <
        ch7Problem75SVDProjectionNorm A b hcontains tail
          (complexMatrixEuclideanLin A x))
    (hmin : ∀ i : Fin n, sigmaMin ≤ complexMatrixSingularValue A i)
    (htail : ∀ i : Fin n, i ∈ tail → complexMatrixSingularValue A i ≤ sigmaTail) :
    ‖dx‖ / ‖x‖ ≤
      (sigmaTail * ‖complexMatrixEuclideanLin A x‖) /
          (sigmaMin *
            ch7Problem75SVDProjectionNorm A b hcontains tail
              (complexMatrixEuclideanLin A x)) *
        (‖complexMatrixEuclideanLin A dx‖ / ‖complexMatrixEuclideanLin A x‖) := by
  have hdx :=
    problem7_5_norm_le_inv_sigmaMin_mul_image_norm A b hcontains dx
      hsigmaMin_pos hmin
  have hproj :=
    problem7_5_projection_norm_le_sigmaTail_mul_norm A b hcontains tail x
      hsigmaTail_pos.le htail
  exact problem7_5_relative_error_algebra
    hsigmaMin_pos hsigmaTail_pos hx_pos hb_pos hproj_pos
    (norm_nonneg (complexMatrixEuclideanLin A dx)) hdx hproj

/-- Higham, 2nd ed., Chapter 7, Problem 7.5: zero-based tail set for the
    source range `i = n+1-k, ..., n`. -/
noncomputable def ch7Problem75TailSet (n k : ℕ) : Finset (Fin n) :=
  Finset.univ.filter fun i : Fin n => n - k ≤ i.val

/-- Higham, 2nd ed., Chapter 7, Problem 7.5, source-indexed form:
    for `k = 1, ..., n`, the printed factor
    `σ_{n+1-k}/σ_n` is represented by zero-based singular values
    `σ_{n-k}/σ_{n-1}`. -/
theorem problem7_5_svd_projection_relative_error_bound_source_indices
    {n k : ℕ} (hn : 0 < n) (hk_pos : 0 < k) (_hk_le : k ≤ n)
    (A : CMatrix n n)
    (b : OrthonormalBasis (Fin n) ℂ (EuclideanSpace ℂ (Fin n)))
    (hcontains :
      ∀ i : Fin n, complexMatrixSingularValue A i ≠ 0 →
        ∃ k : Fin n, b k = complexMatrixLeftSingularVector A i)
    (x dx : EuclideanSpace ℂ (Fin n))
    (hfull : complexMatrixRank A = n)
    (hx_pos : 0 < ‖x‖)
    (hb_pos : 0 < ‖complexMatrixEuclideanLin A x‖)
    (hproj_pos :
      0 <
        ch7Problem75SVDProjectionNorm A b hcontains
          (ch7Problem75TailSet n k)
          (complexMatrixEuclideanLin A x)) :
    ‖dx‖ / ‖x‖ ≤
      (complexMatrixSingularValue A ⟨n - k, Nat.sub_lt hn hk_pos⟩ *
          ‖complexMatrixEuclideanLin A x‖) /
          (complexMatrixSingularValue A ⟨n - 1, Nat.sub_lt hn (by norm_num)⟩ *
            ch7Problem75SVDProjectionNorm A b hcontains
              (ch7Problem75TailSet n k)
              (complexMatrixEuclideanLin A x)) *
        (‖complexMatrixEuclideanLin A dx‖ / ‖complexMatrixEuclideanLin A x‖) := by
  classical
  let iTail : Fin n := ⟨n - k, Nat.sub_lt hn hk_pos⟩
  let iMin : Fin n := ⟨n - 1, Nat.sub_lt hn (by norm_num)⟩
  have hmin_pos : 0 < complexMatrixSingularValue A iMin := by
    have hne := complexMatrixSingularValue_ne_zero_of_rank_eq_card A hfull iMin
    exact lt_of_le_of_ne (complexMatrixSingularValue_nonneg A iMin) (Ne.symm hne)
  have htail_pos : 0 < complexMatrixSingularValue A iTail := by
    have hne := complexMatrixSingularValue_ne_zero_of_rank_eq_card A hfull iTail
    exact lt_of_le_of_ne (complexMatrixSingularValue_nonneg A iTail) (Ne.symm hne)
  have hmin : ∀ i : Fin n,
      complexMatrixSingularValue A iMin ≤ complexMatrixSingularValue A i := by
    intro i
    exact complexMatrixSingularValue_antitone A
      (Fin.le_iff_val_le_val.2 (by
        dsimp [iMin]
        omega))
  have htail : ∀ i : Fin n, i ∈ ch7Problem75TailSet n k →
      complexMatrixSingularValue A i ≤ complexMatrixSingularValue A iTail := by
    intro i hi
    have hle_val : (iTail : Fin n).val ≤ i.val := by
      simpa [ch7Problem75TailSet, iTail] using hi
    exact complexMatrixSingularValue_antitone A
      (Fin.le_iff_val_le_val.2 hle_val)
  simpa [iTail, iMin] using
    problem7_5_svd_projection_relative_error_bound A b hcontains
      (ch7Problem75TailSet n k) x dx
      hmin_pos htail_pos hx_pos hb_pos hproj_pos hmin htail

-- ============================================================
-- Problem 7.6(a): row-wise relative perturbations
-- ============================================================

/-- Each vector component is bounded by the vector 1-norm. -/
lemma ch7_abs_le_oneNormVec {n : ℕ} (x : Fin n → ℝ) (i : Fin n) :
    |x i| ≤ oneNormVec x := by
  unfold oneNormVec
  exact Finset.single_le_sum
    (s := Finset.univ) (f := fun k : Fin n => |x k|)
    (fun k _ => abs_nonneg (x k)) (Finset.mem_univ i)

/-- Problem 7.6(a), row-wise relative matrix tolerance
`E = |A| e eᵀ`, represented entrywise by row sums of `|A|`. -/
noncomputable def ch7RowwiseRelativeToleranceMatrix (n : ℕ)
    (A : Fin n → Fin n → ℝ) : Fin n → Fin n → ℝ :=
  fun i _ => ∑ k : Fin n, |A i k|

/-- Problem 7.6(a), row-wise data condition at `x`, with
`E = |A| e eᵀ` and `f = |b| = |Ax|`. -/
noncomputable def ch7RowwiseDataCondAtSolutionInf (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) : ℝ :=
  ch7CondEFAtSolutionInf n hn A_inv (ch7RowwiseRelativeToleranceMatrix n A)
    (fun i => |matMulVec n A x i|) x

lemma ch7_rowwiseScaledCondRow_le_rowwiseDataAmplifiedRhs
    (n : ℕ) (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (i : Fin n) :
    oneNormVec x *
        (∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|) ≤
      ch7AmplifiedRhsEF n A_inv (ch7RowwiseRelativeToleranceMatrix n A)
        (fun j => |matMulVec n A x j|) x i := by
  unfold ch7AmplifiedRhsEF ch7RowwiseRelativeToleranceMatrix
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro j _
  have hrow :
      ∑ k : Fin n, (∑ l : Fin n, |A j l|) * |x k| =
        (∑ l : Fin n, |A j l|) * oneNormVec x := by
    unfold oneNormVec
    rw [Finset.mul_sum]
  calc
    oneNormVec x * (|A_inv i j| * ∑ k : Fin n, |A j k|)
        = |A_inv i j| * ((∑ k : Fin n, |A j k|) * oneNormVec x) := by
          ring
    _ = |A_inv i j| *
        (∑ k : Fin n, (∑ l : Fin n, |A j l|) * |x k|) := by
          rw [hrow]
    _ ≤ |A_inv i j| *
        (∑ k : Fin n, (∑ l : Fin n, |A j l|) * |x k| +
          |matMulVec n A x j|) :=
          mul_le_mul_of_nonneg_left
            (le_add_of_nonneg_right (abs_nonneg (matMulVec n A x j)))
            (abs_nonneg (A_inv i j))

lemma ch7_rowwiseDataAmplifiedRhs_le_two_oneNormVec_mul_skeelCondRow
    (n : ℕ) (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (i : Fin n) :
    ch7AmplifiedRhsEF n A_inv (ch7RowwiseRelativeToleranceMatrix n A)
        (fun j => |matMulVec n A x j|) x i ≤
      2 * oneNormVec x *
        (∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|) := by
  unfold ch7AmplifiedRhsEF ch7RowwiseRelativeToleranceMatrix
  calc
    ∑ j : Fin n, |A_inv i j| *
        (∑ k : Fin n, (∑ l : Fin n, |A j l|) * |x k| +
          |matMulVec n A x j|)
        ≤ ∑ j : Fin n, |A_inv i j| *
          (2 * ((∑ k : Fin n, |A j k|) * oneNormVec x)) := by
          apply Finset.sum_le_sum
          intro j _
          apply mul_le_mul_of_nonneg_left ?_ (abs_nonneg (A_inv i j))
          have hrow :
              ∑ k : Fin n, (∑ l : Fin n, |A j l|) * |x k| =
                (∑ l : Fin n, |A j l|) * oneNormVec x := by
            unfold oneNormVec
            rw [Finset.mul_sum]
          have hAx :
              |matMulVec n A x j| ≤
                (∑ k : Fin n, |A j k|) * oneNormVec x := by
            calc
              |matMulVec n A x j|
                  ≤ ∑ k : Fin n, |A j k| * |x k| :=
                    ch7_abs_matMulVec_le_abs_matrix_mul_absVec n A x j
              _ ≤ ∑ k : Fin n, |A j k| * oneNormVec x := by
                    apply Finset.sum_le_sum
                    intro k _
                    exact mul_le_mul_of_nonneg_left
                      (ch7_abs_le_oneNormVec x k) (abs_nonneg (A j k))
              _ = (∑ k : Fin n, |A j k|) * oneNormVec x := by
                    rw [Finset.sum_mul]
          calc
            ∑ k : Fin n, (∑ l : Fin n, |A j l|) * |x k| +
                |matMulVec n A x j|
                = (∑ k : Fin n, |A j k|) * oneNormVec x +
                  |matMulVec n A x j| := by
                    rw [hrow]
            _ ≤ (∑ k : Fin n, |A j k|) * oneNormVec x +
                (∑ k : Fin n, |A j k|) * oneNormVec x :=
                  add_le_add (le_refl _) hAx
            _ = 2 * ((∑ k : Fin n, |A j k|) * oneNormVec x) := by
                  ring
    _ = 2 * oneNormVec x *
        (∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring

lemma ch7_rowwiseDataForwardBound_lower
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) :
    oneNormVec x * condSkeel n hn A A_inv ≤
      ch7ForwardBoundEF n hn A_inv (ch7RowwiseRelativeToleranceMatrix n A)
        (fun j => |matMulVec n A x j|) x := by
  let hne : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  have hscale :
      oneNormVec x * condSkeel n hn A A_inv =
        Finset.sup' Finset.univ hne
          (fun i : Fin n =>
            oneNormVec x *
              (∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|)) := by
    unfold condSkeel
    simpa using
      (Finset.mul₀_sup' (ha := oneNormVec_nonneg x)
        (f := fun i : Fin n =>
          ∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|)
        (s := Finset.univ) hne)
  rw [hscale]
  unfold ch7ForwardBoundEF
  exact Finset.sup'_mono_fun (s := Finset.univ) (hs := hne)
    (fun i _ =>
      ch7_rowwiseScaledCondRow_le_rowwiseDataAmplifiedRhs n A A_inv x i)

lemma ch7_rowwiseDataForwardBound_upper
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) :
    ch7ForwardBoundEF n hn A_inv (ch7RowwiseRelativeToleranceMatrix n A)
        (fun j => |matMulVec n A x j|) x ≤
      2 * oneNormVec x * condSkeel n hn A A_inv := by
  let hne : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  have hscalar_nonneg : 0 ≤ 2 * oneNormVec x :=
    mul_nonneg (by norm_num) (oneNormVec_nonneg x)
  unfold ch7ForwardBoundEF condSkeel
  apply Finset.sup'_le
  intro i _
  calc
    ch7AmplifiedRhsEF n A_inv (ch7RowwiseRelativeToleranceMatrix n A)
        (fun j => |matMulVec n A x j|) x i
        ≤ 2 * oneNormVec x *
          (∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|) :=
          ch7_rowwiseDataAmplifiedRhs_le_two_oneNormVec_mul_skeelCondRow n A A_inv x i
    _ ≤ 2 * oneNormVec x *
        Finset.sup' Finset.univ hne
          (fun i : Fin n =>
            ∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|) :=
          mul_le_mul_of_nonneg_left
            (Finset.le_sup'
              (fun i : Fin n =>
                ∑ j : Fin n, |A_inv i j| * ∑ k : Fin n, |A j k|)
              (Finset.mem_univ i))
            hscalar_nonneg

/-- Problem 7.6(a), infinity-norm row-wise relative-data condition:
for `E = |A| e eᵀ` and `f = |b| = |Ax|`, the condition number lies between
`cond(A) ‖x‖₁ / ‖x‖∞` and twice that value. -/
theorem problem7_6a_rowwise_data_condition_bounds
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hx : 0 < infNormVec x) :
    condSkeel n hn A A_inv * (oneNormVec x / infNormVec x) ≤
        ch7RowwiseDataCondAtSolutionInf n hn A A_inv x ∧
      ch7RowwiseDataCondAtSolutionInf n hn A A_inv x ≤
        2 * condSkeel n hn A A_inv * (oneNormVec x / infNormVec x) := by
  have hx_ne : infNormVec x ≠ 0 := ne_of_gt hx
  constructor
  · unfold ch7RowwiseDataCondAtSolutionInf ch7CondEFAtSolutionInf
    rw [le_div_iff₀ hx]
    calc
      condSkeel n hn A A_inv * (oneNormVec x / infNormVec x) * infNormVec x
          = oneNormVec x * condSkeel n hn A A_inv := by
            calc
              condSkeel n hn A A_inv * (oneNormVec x / infNormVec x) *
                  infNormVec x
                  = condSkeel n hn A A_inv *
                    ((oneNormVec x / infNormVec x) * infNormVec x) := by
                    ring
              _ = condSkeel n hn A A_inv * oneNormVec x := by
                    rw [div_mul_cancel₀ (oneNormVec x) hx_ne]
              _ = oneNormVec x * condSkeel n hn A A_inv := by
                    ring
      _ ≤ ch7ForwardBoundEF n hn A_inv (ch7RowwiseRelativeToleranceMatrix n A)
          (fun j => |matMulVec n A x j|) x :=
          ch7_rowwiseDataForwardBound_lower n hn A A_inv x
  · unfold ch7RowwiseDataCondAtSolutionInf ch7CondEFAtSolutionInf
    rw [div_le_iff₀ hx]
    calc
      ch7ForwardBoundEF n hn A_inv (ch7RowwiseRelativeToleranceMatrix n A)
          (fun j => |matMulVec n A x j|) x
          ≤ 2 * oneNormVec x * condSkeel n hn A A_inv :=
          ch7_rowwiseDataForwardBound_upper n hn A A_inv x
      _ = 2 * condSkeel n hn A A_inv *
          (oneNormVec x / infNormVec x) * infNormVec x := by
          calc
            2 * oneNormVec x * condSkeel n hn A A_inv
                = 2 * condSkeel n hn A A_inv * oneNormVec x := by
                  ring
            _ = 2 * condSkeel n hn A A_inv *
                ((oneNormVec x / infNormVec x) * infNormVec x) := by
                  rw [div_mul_cancel₀ (oneNormVec x) hx_ne]
            _ = 2 * condSkeel n hn A A_inv *
                (oneNormVec x / infNormVec x) * infNormVec x := by
                  ring

-- ============================================================
-- Problem 7.6(b): columnwise relative perturbations
-- ============================================================

/-- Problem 7.6(b), columnwise relative matrix tolerance
`E = e eᵀ |A|`, represented entrywise by column sums of `|A|`. -/
noncomputable def ch7ColumnwiseRelativeToleranceMatrix (n : ℕ)
    (A : Fin n → Fin n → ℝ) : Fin n → Fin n → ℝ :=
  fun _ k => ∑ i : Fin n, |A i k|

/-- The scalar `‖ |A| |x| ‖₁` appearing in Problem 7.6(b). -/
noncomputable def ch7AbsMatrixAbsVecOneNorm (n : ℕ)
    (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ) : ℝ :=
  oneNormVec (fun i => ∑ k : Fin n, |A i k| * |x k|)

/-- Problem 7.6(b), columnwise data condition at `x`, with
`E = e eᵀ |A|` and `f = ‖b‖₁ e = ‖Ax‖₁ e`. -/
noncomputable def ch7ColumnwiseDataCondAtSolutionInf (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) : ℝ :=
  ch7CondEFAtSolutionInf n hn A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
    (fun _ => oneNormVec (matMulVec n A x)) x

lemma ch7AbsMatrixAbsVecOneNorm_nonneg (n : ℕ)
    (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ) :
    0 ≤ ch7AbsMatrixAbsVecOneNorm n A x :=
  oneNormVec_nonneg _

lemma ch7_oneNormVec_matMulVec_le_absMatrixAbsVecOneNorm
    (n : ℕ) (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ) :
    oneNormVec (matMulVec n A x) ≤ ch7AbsMatrixAbsVecOneNorm n A x := by
  unfold oneNormVec ch7AbsMatrixAbsVecOneNorm
  apply Finset.sum_le_sum
  intro i _
  have hrow_nonneg : 0 ≤ ∑ k : Fin n, |A i k| * |x k| := by
    exact Finset.sum_nonneg (by
      intro k _
      exact mul_nonneg (abs_nonneg (A i k)) (abs_nonneg (x k)))
  simpa [abs_of_nonneg hrow_nonneg]
    using ch7_abs_matMulVec_le_abs_matrix_mul_absVec n A x i

lemma ch7_columnwiseTolerance_mul_absVec_eq_absMatrixAbsVecOneNorm
    (n : ℕ) (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (i : Fin n) :
    ∑ k : Fin n, ch7ColumnwiseRelativeToleranceMatrix n A i k * |x k| =
      ch7AbsMatrixAbsVecOneNorm n A x := by
  unfold ch7ColumnwiseRelativeToleranceMatrix ch7AbsMatrixAbsVecOneNorm oneNormVec
  calc
    ∑ k : Fin n, (∑ i : Fin n, |A i k|) * |x k|
        = ∑ k : Fin n, ∑ i : Fin n, |A i k| * |x k| := by
          apply Finset.sum_congr rfl
          intro k _
          rw [Finset.sum_mul]
    _ = ∑ i : Fin n, ∑ k : Fin n, |A i k| * |x k| := by
          rw [Finset.sum_comm]
    _ = ∑ i : Fin n, |(fun i => ∑ k : Fin n, |A i k| * |x k|) i| := by
          apply Finset.sum_congr rfl
          intro i _
          rw [abs_of_nonneg]
          exact Finset.sum_nonneg (by
            intro k _
            exact mul_nonneg (abs_nonneg (A i k)) (abs_nonneg (x k)))

lemma ch7_columnwiseScaledInvRow_le_columnwiseDataAmplifiedRhs
    (n : ℕ) (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (i : Fin n) :
    ch7AbsMatrixAbsVecOneNorm n A x *
        (∑ j : Fin n, |A_inv i j|) ≤
      ch7AmplifiedRhsEF n A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
        (fun _ => oneNormVec (matMulVec n A x)) x i := by
  unfold ch7AmplifiedRhsEF
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro j _
  have hE :=
    ch7_columnwiseTolerance_mul_absVec_eq_absMatrixAbsVecOneNorm n A x j
  calc
    ch7AbsMatrixAbsVecOneNorm n A x * |A_inv i j|
        = |A_inv i j| * ch7AbsMatrixAbsVecOneNorm n A x := by
          ring
    _ = |A_inv i j| *
        (∑ k : Fin n, ch7ColumnwiseRelativeToleranceMatrix n A j k * |x k|) := by
          rw [hE]
    _ ≤ |A_inv i j| *
        (∑ k : Fin n, ch7ColumnwiseRelativeToleranceMatrix n A j k * |x k| +
          oneNormVec (matMulVec n A x)) :=
          mul_le_mul_of_nonneg_left
            (le_add_of_nonneg_right (oneNormVec_nonneg _))
            (abs_nonneg (A_inv i j))

lemma ch7_columnwiseDataAmplifiedRhs_le_two_absMatrixAbsVecOneNorm_mul_invRow
    (n : ℕ) (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (i : Fin n) :
    ch7AmplifiedRhsEF n A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
        (fun _ => oneNormVec (matMulVec n A x)) x i ≤
      2 * ch7AbsMatrixAbsVecOneNorm n A x *
        (∑ j : Fin n, |A_inv i j|) := by
  unfold ch7AmplifiedRhsEF
  calc
    ∑ j : Fin n, |A_inv i j| *
        (∑ k : Fin n, ch7ColumnwiseRelativeToleranceMatrix n A j k * |x k| +
          oneNormVec (matMulVec n A x))
        ≤ ∑ j : Fin n, |A_inv i j| *
          (2 * ch7AbsMatrixAbsVecOneNorm n A x) := by
          apply Finset.sum_le_sum
          intro j _
          apply mul_le_mul_of_nonneg_left ?_ (abs_nonneg (A_inv i j))
          have hE :=
            ch7_columnwiseTolerance_mul_absVec_eq_absMatrixAbsVecOneNorm n A x j
          have hb :
              oneNormVec (matMulVec n A x) ≤ ch7AbsMatrixAbsVecOneNorm n A x :=
            ch7_oneNormVec_matMulVec_le_absMatrixAbsVecOneNorm n A x
          calc
            ∑ k : Fin n, ch7ColumnwiseRelativeToleranceMatrix n A j k * |x k| +
                oneNormVec (matMulVec n A x)
                = ch7AbsMatrixAbsVecOneNorm n A x +
                  oneNormVec (matMulVec n A x) := by
                    rw [hE]
            _ ≤ ch7AbsMatrixAbsVecOneNorm n A x +
                ch7AbsMatrixAbsVecOneNorm n A x :=
                  add_le_add (le_refl _) hb
            _ = 2 * ch7AbsMatrixAbsVecOneNorm n A x := by
                  ring
    _ = 2 * ch7AbsMatrixAbsVecOneNorm n A x *
        (∑ j : Fin n, |A_inv i j|) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring

lemma ch7_columnwiseDataForwardBound_lower
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) :
    infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x ≤
      ch7ForwardBoundEF n hn A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
        (fun _ => oneNormVec (matMulVec n A x)) x := by
  let hne : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  let s := ch7AbsMatrixAbsVecOneNorm n A x
  have hs_nonneg : 0 ≤ s :=
    ch7AbsMatrixAbsVecOneNorm_nonneg n A x
  have hscale :
      s * infNorm A_inv =
        Finset.sup' Finset.univ hne
          (fun i : Fin n => s * ∑ j : Fin n, |A_inv i j|) := by
    rw [infNorm_eq_sup_row_sum n hn A_inv]
    exact Finset.mul₀_sup' (ha := hs_nonneg)
      (f := fun i : Fin n => ∑ j : Fin n, |A_inv i j|)
      (s := Finset.univ) hne
  calc
    infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x
        = s * infNorm A_inv := by
          dsimp [s]
          ring
    _ = Finset.sup' Finset.univ hne
          (fun i : Fin n => s * ∑ j : Fin n, |A_inv i j|) := hscale
    _ ≤ ch7ForwardBoundEF n hn A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
        (fun _ => oneNormVec (matMulVec n A x)) x := by
          unfold ch7ForwardBoundEF
          exact Finset.sup'_mono_fun (s := Finset.univ) (hs := hne)
            (fun i _ =>
              ch7_columnwiseScaledInvRow_le_columnwiseDataAmplifiedRhs n A A_inv x i)

lemma ch7_columnwiseDataForwardBound_upper
    (n : ℕ) (_hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ) :
    ch7ForwardBoundEF n _hn A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
        (fun _ => oneNormVec (matMulVec n A x)) x ≤
      2 * infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x := by
  unfold ch7ForwardBoundEF
  have hs_nonneg : 0 ≤ ch7AbsMatrixAbsVecOneNorm n A x :=
    ch7AbsMatrixAbsVecOneNorm_nonneg n A x
  have hscalar_nonneg : 0 ≤ 2 * ch7AbsMatrixAbsVecOneNorm n A x :=
    mul_nonneg (by norm_num) hs_nonneg
  apply Finset.sup'_le
  intro i _
  calc
    ch7AmplifiedRhsEF n A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
        (fun _ => oneNormVec (matMulVec n A x)) x i
        ≤ 2 * ch7AbsMatrixAbsVecOneNorm n A x *
          (∑ j : Fin n, |A_inv i j|) :=
          ch7_columnwiseDataAmplifiedRhs_le_two_absMatrixAbsVecOneNorm_mul_invRow
            n A A_inv x i
    _ ≤ 2 * ch7AbsMatrixAbsVecOneNorm n A x * infNorm A_inv :=
          mul_le_mul_of_nonneg_left (row_sum_le_infNorm A_inv i) hscalar_nonneg
    _ = 2 * infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x := by
          ring

/-- Problem 7.6(b), infinity-norm columnwise relative-data condition:
for `E = e eᵀ |A|` and `f = ‖b‖₁ e = ‖Ax‖₁ e`, the condition number lies
between `‖A⁻¹‖∞ ‖|A||x|‖₁ / ‖x‖∞` and twice that value. -/
theorem problem7_6b_columnwise_data_condition_bounds
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hx : 0 < infNormVec x) :
    infNorm A_inv * (ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) ≤
        ch7ColumnwiseDataCondAtSolutionInf n hn A A_inv x ∧
      ch7ColumnwiseDataCondAtSolutionInf n hn A A_inv x ≤
        2 * infNorm A_inv *
          (ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) := by
  have hx_ne : infNormVec x ≠ 0 := ne_of_gt hx
  constructor
  · unfold ch7ColumnwiseDataCondAtSolutionInf ch7CondEFAtSolutionInf
    rw [le_div_iff₀ hx]
    calc
      infNorm A_inv * (ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) *
          infNormVec x
          = infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x := by
            calc
              infNorm A_inv * (ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) *
                  infNormVec x
                  = infNorm A_inv *
                    ((ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) *
                      infNormVec x) := by
                    ring
              _ = infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x := by
                    rw [div_mul_cancel₀ (ch7AbsMatrixAbsVecOneNorm n A x) hx_ne]
      _ ≤ ch7ForwardBoundEF n hn A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
          (fun _ => oneNormVec (matMulVec n A x)) x :=
          ch7_columnwiseDataForwardBound_lower n hn A A_inv x
  · unfold ch7ColumnwiseDataCondAtSolutionInf ch7CondEFAtSolutionInf
    rw [div_le_iff₀ hx]
    calc
      ch7ForwardBoundEF n hn A_inv (ch7ColumnwiseRelativeToleranceMatrix n A)
          (fun _ => oneNormVec (matMulVec n A x)) x
          ≤ 2 * infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x :=
          ch7_columnwiseDataForwardBound_upper n hn A A_inv x
      _ = 2 * infNorm A_inv *
          (ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) * infNormVec x := by
          calc
            2 * infNorm A_inv * ch7AbsMatrixAbsVecOneNorm n A x
                = 2 * infNorm A_inv *
                  ((ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) *
                    infNormVec x) := by
                  rw [div_mul_cancel₀ (ch7AbsMatrixAbsVecOneNorm n A x) hx_ne]
            _ = 2 * infNorm A_inv *
                (ch7AbsMatrixAbsVecOneNorm n A x / infNormVec x) *
                  infNormVec x := by
                  ring

-- ============================================================
-- Chapter 7 finite sign helpers
-- ============================================================

/-- Chapter 7 sign wrapper used in the Appendix A.11 attaining perturbation. -/
noncomputable abbrev ch7AbsSign (a : ℝ) : ℝ := summationAbsSign a

lemma ch7AbsSign_mul_eq_abs (a : ℝ) :
    ch7AbsSign a * a = |a| :=
  summationAbsSign_mul_eq_abs a

lemma ch7_mul_ch7AbsSign_eq_abs (a : ℝ) :
    a * ch7AbsSign a = |a| :=
  mul_summationAbsSign_eq_abs a

lemma ch7_abs_ch7AbsSign (a : ℝ) :
    |ch7AbsSign a| = 1 :=
  abs_summationAbsSign a

-- ============================================================
-- Problem 7.9: linearized scalar-output componentwise condition
-- ============================================================

/-- The scalar functional `cᵀx` from Problem 7.9. -/
noncomputable def ch7LinearFunctional (n : ℕ)
    (c x : Fin n → ℝ) : ℝ :=
  ∑ i : Fin n, c i * x i

/-- The row vector `cᵀA⁻¹`, represented componentwise. -/
noncomputable def ch7Problem79AdjointWeight (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (c : Fin n → ℝ) : Fin n → ℝ :=
  fun j => ∑ i : Fin n, c i * A_inv i j

/-- The first-order change in `cᵀx` induced by perturbations
`ΔA`, `Δb`: `cᵀA⁻¹(Δb - ΔA x)`. -/
noncomputable def ch7Problem79FirstOrderChange (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ)
    (ΔA : Fin n → Fin n → ℝ) : ℝ :=
  ∑ j : Fin n,
    ch7Problem79AdjointWeight n A_inv c j *
      (Δb j - ∑ k : Fin n, ΔA j k * x k)

/-- The numerator `|cᵀA⁻¹|(E|x|+f)` in Problem 7.9. -/
noncomputable def ch7Problem79ComponentwiseSensitivity (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) : ℝ :=
  ∑ j : Fin n,
    |ch7Problem79AdjointWeight n A_inv c j| *
      (∑ k : Fin n, E j k * |x k| + f j)

/-- The finite linearized componentwise scalar-output condition
`|cᵀA⁻¹|(E|x|+f)/|cᵀx|` from Problem 7.9. -/
noncomputable def ch7Problem79LinearizedCond (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) : ℝ :=
  ch7Problem79ComponentwiseSensitivity n A_inv E f c x /
    |ch7LinearFunctional n c x|

/-- Relative first-order scalar-output change for a concrete admissible
perturbation pair. -/
noncomputable def ch7Problem79LinearizedRelativeChange (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ)
    (ΔA : Fin n → Fin n → ℝ) : ℝ :=
  |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| /
    |ch7LinearFunctional n c x|

lemma ch7Problem79ComponentwiseSensitivity_nonneg (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i) :
    0 ≤ ch7Problem79ComponentwiseSensitivity n A_inv E f c x := by
  unfold ch7Problem79ComponentwiseSensitivity
  exact Finset.sum_nonneg fun j _ =>
    mul_nonneg (abs_nonneg _)
      (add_nonneg
        (Finset.sum_nonneg fun k _ => mul_nonneg (hE j k) (abs_nonneg _))
        (hf j))

lemma ch7Problem79_firstOrder_abs_le (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x Δb : Fin n → ℝ)
    (ΔA : Fin n → Fin n → ℝ) (ε : ℝ)
    (_hε : 0 ≤ ε) (_hE : ∀ i j, 0 ≤ E i j) (_hf : ∀ i, 0 ≤ f i)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i) :
    |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| ≤
      ε * ch7Problem79ComponentwiseSensitivity n A_inv E f c x := by
  unfold ch7Problem79FirstOrderChange ch7Problem79ComponentwiseSensitivity
  have hinner :
      ∀ j : Fin n,
        |Δb j - ∑ k : Fin n, ΔA j k * x k| ≤
          ε * (∑ k : Fin n, E j k * |x k| + f j) := by
    intro j
    have hsum_abs :
        |∑ k : Fin n, ΔA j k * x k| ≤
          ∑ k : Fin n, |ΔA j k * x k| :=
      Finset.abs_sum_le_sum_abs _ _
    have hsum_bound :
        ∑ k : Fin n, |ΔA j k * x k| ≤
          ∑ k : Fin n, (ε * E j k) * |x k| := by
      apply Finset.sum_le_sum
      intro k _
      rw [abs_mul]
      exact mul_le_mul_of_nonneg_right (hΔA j k) (abs_nonneg (x k))
    calc
      |Δb j - ∑ k : Fin n, ΔA j k * x k|
          ≤ |Δb j| + |∑ k : Fin n, ΔA j k * x k| := by
            simpa [sub_eq_add_neg, abs_neg] using
              abs_add_le (Δb j) (-(∑ k : Fin n, ΔA j k * x k))
      _ ≤ ε * f j + ∑ k : Fin n, |ΔA j k * x k| :=
            add_le_add (hΔb j) hsum_abs
      _ ≤ ε * f j + ∑ k : Fin n, (ε * E j k) * |x k| :=
            add_le_add (le_refl (ε * f j)) hsum_bound
      _ = ε * (∑ k : Fin n, E j k * |x k| + f j) := by
            have hsum_eps :
                (∑ k : Fin n, (ε * E j k) * |x k|) =
                  ε * ∑ k : Fin n, E j k * |x k| := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro k _
              ring
            rw [hsum_eps]
            ring
  calc
    |∑ j : Fin n,
        ch7Problem79AdjointWeight n A_inv c j *
          (Δb j - ∑ k : Fin n, ΔA j k * x k)|
        ≤ ∑ j : Fin n,
            |ch7Problem79AdjointWeight n A_inv c j *
              (Δb j - ∑ k : Fin n, ΔA j k * x k)| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = ∑ j : Fin n,
            |ch7Problem79AdjointWeight n A_inv c j| *
              |Δb j - ∑ k : Fin n, ΔA j k * x k| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_mul]
    _ ≤ ∑ j : Fin n,
            |ch7Problem79AdjointWeight n A_inv c j| *
              (ε * (∑ k : Fin n, E j k * |x k| + f j)) := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left (hinner j) (abs_nonneg _)
    _ = ε * ∑ j : Fin n,
            |ch7Problem79AdjointWeight n A_inv c j| *
              (∑ k : Fin n, E j k * |x k| + f j) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring

lemma ch7Problem79_linearizedRelativeChange_le (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x Δb : Fin n → ℝ)
    (ΔA : Fin n → Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i) :
    ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA ≤
      ε * ch7Problem79LinearizedCond n A_inv E f c x := by
  unfold ch7Problem79LinearizedRelativeChange ch7Problem79LinearizedCond
  calc
    |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| /
        |ch7LinearFunctional n c x|
        ≤ (ε * ch7Problem79ComponentwiseSensitivity n A_inv E f c x) /
            |ch7LinearFunctional n c x| :=
          div_le_div_of_nonneg_right
            (ch7Problem79_firstOrder_abs_le n A_inv E f c x Δb ΔA ε
              hε hE hf hΔA hΔb)
            (le_of_lt hden)
    _ = ε *
        (ch7Problem79ComponentwiseSensitivity n A_inv E f c x /
          |ch7LinearFunctional n c x|) := by
          ring

/-- Problem 7.9 attaining matrix perturbation for the first-order
componentwise scalar-output formula. -/
noncomputable def ch7Problem79AttainingDeltaA (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (c x : Fin n → ℝ) (ε : ℝ) :
    Fin n → Fin n → ℝ :=
  fun j k => -ε * ch7AbsSign (ch7Problem79AdjointWeight n A_inv c j) *
    E j k * ch7AbsSign (x k)

/-- Problem 7.9 attaining right-hand-side perturbation for the first-order
componentwise scalar-output formula. -/
noncomputable def ch7Problem79AttainingDeltaB (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (f c : Fin n → ℝ) (ε : ℝ) :
    Fin n → ℝ :=
  fun j => ε * ch7AbsSign (ch7Problem79AdjointWeight n A_inv c j) * f j

lemma ch7Problem79_attainingDeltaA_bound (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (c x : Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : ∀ i j, 0 ≤ E i j) :
    ∀ j k,
      |ch7Problem79AttainingDeltaA n A_inv E c x ε j k| ≤ ε * E j k := by
  intro j k
  unfold ch7Problem79AttainingDeltaA
  rw [abs_mul, abs_mul, abs_mul, abs_neg, ch7_abs_ch7AbsSign,
    ch7_abs_ch7AbsSign]
  rw [abs_of_nonneg hε, abs_of_nonneg (hE j k)]
  ring_nf
  exact le_rfl

lemma ch7Problem79_attainingDeltaB_bound (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (f c : Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hf : ∀ i, 0 ≤ f i) :
    ∀ j,
      |ch7Problem79AttainingDeltaB n A_inv f c ε j| ≤ ε * f j := by
  intro j
  unfold ch7Problem79AttainingDeltaB
  rw [abs_mul, abs_mul, ch7_abs_ch7AbsSign]
  rw [abs_of_nonneg hε, abs_of_nonneg (hf j)]
  ring_nf
  exact le_rfl

lemma ch7Problem79_attaining_firstOrder_eq (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (ε : ℝ) :
    ch7Problem79FirstOrderChange n A_inv c x
        (ch7Problem79AttainingDeltaB n A_inv f c ε)
        (ch7Problem79AttainingDeltaA n A_inv E c x ε) =
      ε * ch7Problem79ComponentwiseSensitivity n A_inv E f c x := by
  unfold ch7Problem79FirstOrderChange ch7Problem79ComponentwiseSensitivity
    ch7Problem79AttainingDeltaA ch7Problem79AttainingDeltaB
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro j _
  let w : ℝ := ch7Problem79AdjointWeight n A_inv c j
  have hsum :
      (∑ k : Fin n,
          (-ε * ch7AbsSign w * E j k * ch7AbsSign (x k)) * x k) =
        -ε * ch7AbsSign w * ∑ k : Fin n, E j k * |x k| := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro k _
    calc
      (-ε * ch7AbsSign w * E j k * ch7AbsSign (x k)) * x k
          = (-ε * ch7AbsSign w) * (E j k * (ch7AbsSign (x k) * x k)) := by
            ring
      _ = (-ε * ch7AbsSign w) * (E j k * |x k|) := by
            rw [ch7AbsSign_mul_eq_abs]
      _ = -ε * ch7AbsSign w * (E j k * |x k|) := by
            ring
  calc
    ch7Problem79AdjointWeight n A_inv c j *
        (ε * ch7AbsSign (ch7Problem79AdjointWeight n A_inv c j) * f j -
          ∑ k : Fin n,
            (-ε * ch7AbsSign (ch7Problem79AdjointWeight n A_inv c j) *
              E j k * ch7AbsSign (x k)) * x k)
        = w *
          (ε * ch7AbsSign w * f j -
            ∑ k : Fin n,
              (-ε * ch7AbsSign w * E j k * ch7AbsSign (x k)) * x k) := by
            dsimp [w]
    _ = w * (ε * ch7AbsSign w *
          (∑ k : Fin n, E j k * |x k| + f j)) := by
            rw [hsum]
            ring
    _ = ε * (|w| * (∑ k : Fin n, E j k * |x k| + f j)) := by
            calc
              w * (ε * ch7AbsSign w *
                  (∑ k : Fin n, E j k * |x k| + f j))
                  = ε * ((w * ch7AbsSign w) *
                      (∑ k : Fin n, E j k * |x k| + f j)) := by
                    ring
              _ = ε * (|w| * (∑ k : Fin n, E j k * |x k| + f j)) := by
                    rw [ch7_mul_ch7AbsSign_eq_abs]
    _ = ε *
        (|ch7Problem79AdjointWeight n A_inv c j| *
          (∑ k : Fin n, E j k * |x k| + f j)) := by
            dsimp [w]

/-- Problem 7.9, finite first-order componentwise formula for the scalar
output `cᵀx`.  Every perturbation satisfying `|ΔA| ≤ εE` and `|Δb| ≤ εf`
is bounded by
`ε |cᵀA⁻¹|(E|x|+f)/|cᵀx|`, and an explicit sign perturbation attains the
linearized numerator. -/
theorem problem7_9_linearized_componentwise_functional_formula
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    (∀ ε ΔA Δb, 0 ≤ ε →
      (∀ i j, |ΔA i j| ≤ ε * E i j) →
      (∀ i, |Δb i| ≤ ε * f i) →
      ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA ≤
        ε * ch7Problem79LinearizedCond n A_inv E f c x) ∧
    (∀ ε, 0 ≤ ε →
      ∃ ΔA : Fin n → Fin n → ℝ, ∃ Δb : Fin n → ℝ,
        (∀ i j, |ΔA i j| ≤ ε * E i j) ∧
        (∀ i, |Δb i| ≤ ε * f i) ∧
        ch7Problem79FirstOrderChange n A_inv c x Δb ΔA =
          ε * ch7Problem79ComponentwiseSensitivity n A_inv E f c x ∧
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA =
          ε * ch7Problem79LinearizedCond n A_inv E f c x) := by
  constructor
  · intro ε ΔA Δb hε hΔA hΔb
    exact ch7Problem79_linearizedRelativeChange_le n A_inv E f c x Δb ΔA ε
      hε hE hf hden hΔA hΔb
  · intro ε hε
    let ΔA := ch7Problem79AttainingDeltaA n A_inv E c x ε
    let Δb := ch7Problem79AttainingDeltaB n A_inv f c ε
    have hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j := by
      intro i j
      exact ch7Problem79_attainingDeltaA_bound n A_inv E c x ε hε hE i j
    have hΔb : ∀ i, |Δb i| ≤ ε * f i := by
      intro i
      exact ch7Problem79_attainingDeltaB_bound n A_inv f c ε hε hf i
    have hsens_nonneg :
        0 ≤ ch7Problem79ComponentwiseSensitivity n A_inv E f c x :=
      ch7Problem79ComponentwiseSensitivity_nonneg n A_inv E f c x hE hf
    have hfirst :
        ch7Problem79FirstOrderChange n A_inv c x Δb ΔA =
          ε * ch7Problem79ComponentwiseSensitivity n A_inv E f c x := by
      dsimp [ΔA, Δb]
      exact ch7Problem79_attaining_firstOrder_eq n A_inv E f c x ε
    have hrel :
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA =
          ε * ch7Problem79LinearizedCond n A_inv E f c x := by
      unfold ch7Problem79LinearizedRelativeChange ch7Problem79LinearizedCond
      rw [hfirst]
      rw [abs_of_nonneg (mul_nonneg hε hsens_nonneg)]
      ring
    exact ⟨ΔA, Δb, hΔA, hΔb, hfirst, hrel⟩

lemma ch7Problem79_adjointWeight_mul_vec_eq_linearFunctional_matMulVec
    (n : ℕ) (A_inv : Fin n → Fin n → ℝ) (c y : Fin n → ℝ) :
    (∑ j : Fin n, ch7Problem79AdjointWeight n A_inv c j * y j) =
      ch7LinearFunctional n c (matMulVec n A_inv y) := by
  unfold ch7Problem79AdjointWeight ch7LinearFunctional matMulVec
  calc
    ∑ j : Fin n, (∑ i : Fin n, c i * A_inv i j) * y j
        = ∑ j : Fin n, ∑ i : Fin n, (c i * A_inv i j) * y j := by
          apply Finset.sum_congr rfl
          intro j _
          rw [Finset.sum_mul]
    _ = ∑ i : Fin n, ∑ j : Fin n, (c i * A_inv i j) * y j := by
          rw [Finset.sum_comm]
    _ = ∑ i : Fin n, c i * (∑ j : Fin n, A_inv i j * y j) := by
          apply Finset.sum_congr rfl
          intro i _
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring

lemma ch7Problem79_linearFunctional_eq_adjointWeight_mul_Ax (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (c x : Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv) :
    ch7LinearFunctional n c x =
      ∑ j : Fin n,
        ch7Problem79AdjointWeight n A_inv c j * matMulVec n A x j := by
  have hadj :=
    ch7Problem79_adjointWeight_mul_vec_eq_linearFunctional_matMulVec
      n A_inv c (matMulVec n A x)
  have hleft := rectMatMulVec_left_inverse_of_IsLeftInverse hLeft x
  have hmat : matMulVec n A_inv (matMulVec n A x) = x := by
    simpa [matMulVec, rectMatMulVec] using hleft
  calc
    ch7LinearFunctional n c x
        = ch7LinearFunctional n c
            (matMulVec n A_inv (matMulVec n A x)) := by
          rw [hmat]
    _ = ∑ j : Fin n,
          ch7Problem79AdjointWeight n A_inv c j * matMulVec n A x j := by
          rw [← hadj]

lemma ch7Problem79ComponentwiseSensitivity_ge_abs_functional_of_abs_matrix
    (n : ℕ) (A A_inv : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv) (hf : ∀ i, 0 ≤ f i) :
    |ch7LinearFunctional n c x| ≤
      ch7Problem79ComponentwiseSensitivity n A_inv
        (fun i j => |A i j|) f c x := by
  have hfunctional :=
    ch7Problem79_linearFunctional_eq_adjointWeight_mul_Ax n A A_inv c x hLeft
  unfold ch7Problem79ComponentwiseSensitivity
  calc
    |ch7LinearFunctional n c x|
        = |∑ j : Fin n,
            ch7Problem79AdjointWeight n A_inv c j * matMulVec n A x j| := by
          rw [hfunctional]
    _ ≤ ∑ j : Fin n,
          |ch7Problem79AdjointWeight n A_inv c j * matMulVec n A x j| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = ∑ j : Fin n,
          |ch7Problem79AdjointWeight n A_inv c j| *
            |matMulVec n A x j| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_mul]
    _ ≤ ∑ j : Fin n,
          |ch7Problem79AdjointWeight n A_inv c j| *
            (∑ k : Fin n, |A j k| * |x k|) := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left
            (ch7_abs_matMulVec_le_abs_matrix_mul_absVec n A x j)
            (abs_nonneg _)
    _ ≤ ∑ j : Fin n,
          |ch7Problem79AdjointWeight n A_inv c j| *
            (∑ k : Fin n, |A j k| * |x k| + f j) := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left
            (le_add_of_nonneg_right (hf j)) (abs_nonneg _)

lemma ch7Problem79ComponentwiseSensitivity_ge_abs_functional_of_abs_rhs
    (n : ℕ) (A A_inv E : Fin n → Fin n → ℝ) (b c x : Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv)
    (hAx : ∀ i, matMulVec n A x i = b i)
    (hE : ∀ i j, 0 ≤ E i j) :
    |ch7LinearFunctional n c x| ≤
      ch7Problem79ComponentwiseSensitivity n A_inv E (fun i => |b i|) c x := by
  have hfunctional :=
    ch7Problem79_linearFunctional_eq_adjointWeight_mul_Ax n A A_inv c x hLeft
  have hsum_eq :
      (∑ j : Fin n,
          ch7Problem79AdjointWeight n A_inv c j * matMulVec n A x j) =
        ∑ j : Fin n, ch7Problem79AdjointWeight n A_inv c j * b j := by
    apply Finset.sum_congr rfl
    intro j _
    rw [hAx j]
  unfold ch7Problem79ComponentwiseSensitivity
  calc
    |ch7LinearFunctional n c x|
        = |∑ j : Fin n, ch7Problem79AdjointWeight n A_inv c j * b j| := by
          rw [hfunctional, hsum_eq]
    _ ≤ ∑ j : Fin n, |ch7Problem79AdjointWeight n A_inv c j * b j| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = ∑ j : Fin n, |ch7Problem79AdjointWeight n A_inv c j| * |b j| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_mul]
    _ ≤ ∑ j : Fin n,
          |ch7Problem79AdjointWeight n A_inv c j| *
            (∑ k : Fin n, E j k * |x k| + |b j|) := by
          apply Finset.sum_le_sum
          intro j _
          apply mul_le_mul_of_nonneg_left ?_ (abs_nonneg _)
          exact le_add_of_nonneg_left
            (Finset.sum_nonneg fun k _ => mul_nonneg (hE j k) (abs_nonneg _))

/-- Problem 7.9 lower-bound specialization: the finite linearized
componentwise scalar-output condition satisfies `χ ≥ 1` when `E = |A|`. -/
theorem problem7_9_linearized_componentwise_functional_ge_one_of_abs_matrix
    (n : ℕ) (A A_inv : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv)
    (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    1 ≤ ch7Problem79LinearizedCond n A_inv (fun i j => |A i j|) f c x := by
  unfold ch7Problem79LinearizedCond
  have hle :=
    ch7Problem79ComponentwiseSensitivity_ge_abs_functional_of_abs_matrix
      n A A_inv f c x hLeft hf
  calc
    1 = |ch7LinearFunctional n c x| / |ch7LinearFunctional n c x| := by
          field_simp [ne_of_gt hden]
    _ ≤ ch7Problem79ComponentwiseSensitivity n A_inv
          (fun i j => |A i j|) f c x / |ch7LinearFunctional n c x| :=
          div_le_div_of_nonneg_right hle (le_of_lt hden)

/-- Problem 7.9 lower-bound specialization: the finite linearized
componentwise scalar-output condition satisfies `χ ≥ 1` when `f = |b|`. -/
theorem problem7_9_linearized_componentwise_functional_ge_one_of_abs_rhs
    (n : ℕ) (A A_inv E : Fin n → Fin n → ℝ) (b c x : Fin n → ℝ)
    (hLeft : IsLeftInverse n A A_inv)
    (hAx : ∀ i, matMulVec n A x i = b i)
    (hE : ∀ i j, 0 ≤ E i j)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    1 ≤ ch7Problem79LinearizedCond n A_inv E (fun i => |b i|) c x := by
  unfold ch7Problem79LinearizedCond
  have hle :=
    ch7Problem79ComponentwiseSensitivity_ge_abs_functional_of_abs_rhs
      n A A_inv E b c x hLeft hAx hE
  calc
    1 = |ch7LinearFunctional n c x| / |ch7LinearFunctional n c x| := by
          field_simp [ne_of_gt hden]
    _ ≤ ch7Problem79ComponentwiseSensitivity n A_inv E (fun i => |b i|) c x /
          |ch7LinearFunctional n c x| :=
          div_le_div_of_nonneg_right hle (le_of_lt hden)

-- ------------------------------------------------------------
-- Problem 7.9: finite normwise scalar-output formula
-- ------------------------------------------------------------

/-- The finite first-order normwise numerator
`‖cᵀA⁻¹‖₂(‖E‖₂‖x‖₂ + ‖f‖₂)` from Problem 7.9.  The matrix norm is supplied
as a value/certificate through the repository's `opNorm2Le` surface. -/
noncomputable def ch7Problem79NormwiseSensitivity (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) : ℝ :=
  vecNorm2 (ch7Problem79AdjointWeight n A_inv c) *
    (E_norm * vecNorm2 x + f_norm)

/-- The finite linearized normwise scalar-output condition
`‖cᵀA⁻¹‖₂(‖E‖₂‖x‖₂ + ‖f‖₂)/|cᵀx|`. -/
noncomputable def ch7Problem79NormwiseLinearizedCond (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) : ℝ :=
  ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x /
    |ch7LinearFunctional n c x|

lemma ch7Problem79NormwiseSensitivity_nonneg (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm) :
    0 ≤ ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x := by
  unfold ch7Problem79NormwiseSensitivity
  exact mul_nonneg (vecNorm2_nonneg _)
    (add_nonneg (mul_nonneg hE (vecNorm2_nonneg x)) hf)

lemma opNorm2Le_mono {n : ℕ} {M : Fin n → Fin n → ℝ} {c d : ℝ}
    (hM : opNorm2Le M c) (hcd : c ≤ d) : opNorm2Le M d := by
  intro x
  exact le_trans (hM x) (mul_le_mul_of_nonneg_right hcd (vecNorm2_nonneg x))

lemma ch7Problem79_normwise_firstOrder_abs_le (n : ℕ)
    (A_inv ΔA : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ)
    (E_norm f_norm ε : ℝ)
    (hΔA : opNorm2Le ΔA (ε * E_norm))
    (hΔb : vecNorm2 Δb ≤ ε * f_norm) :
    |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| ≤
      ε * ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x := by
  let w : Fin n → ℝ := ch7Problem79AdjointWeight n A_inv c
  have htri :
      vecNorm2 (fun j : Fin n => Δb j - matMulVec n ΔA x j) ≤
        ε * f_norm + (ε * E_norm) * vecNorm2 x := by
    calc
      vecNorm2 (fun j : Fin n => Δb j - matMulVec n ΔA x j)
          ≤ vecNorm2 Δb + vecNorm2 (matMulVec n ΔA x) := by
            have h :=
              vecNorm2_add_le Δb (fun j : Fin n => -matMulVec n ΔA x j)
            simpa [sub_eq_add_neg, vecNorm2_neg] using h
      _ ≤ ε * f_norm + (ε * E_norm) * vecNorm2 x :=
            add_le_add hΔb (hΔA x)
  calc
    |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA|
        = |∑ j : Fin n, w j * (Δb j - matMulVec n ΔA x j)| := by
          unfold ch7Problem79FirstOrderChange matMulVec
          rfl
    _ ≤ vecNorm2 w *
          vecNorm2 (fun j : Fin n => Δb j - matMulVec n ΔA x j) :=
          abs_vecInnerProduct_le_vecNorm2_mul w
            (fun j : Fin n => Δb j - matMulVec n ΔA x j)
    _ ≤ vecNorm2 w * (ε * f_norm + (ε * E_norm) * vecNorm2 x) :=
          mul_le_mul_of_nonneg_left htri (vecNorm2_nonneg w)
    _ = ε * ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x := by
          dsimp [w]
          unfold ch7Problem79NormwiseSensitivity
          ring

lemma ch7Problem79_normwiseLinearizedRelativeChange_le (n : ℕ)
    (A_inv ΔA : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ)
    (E_norm f_norm ε : ℝ)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hΔA : opNorm2Le ΔA (ε * E_norm))
    (hΔb : vecNorm2 Δb ≤ ε * f_norm) :
    ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA ≤
      ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x := by
  unfold ch7Problem79LinearizedRelativeChange
    ch7Problem79NormwiseLinearizedCond
  calc
    |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| /
        |ch7LinearFunctional n c x|
        ≤ (ε * ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x) /
            |ch7LinearFunctional n c x| :=
          div_le_div_of_nonneg_right
            (ch7Problem79_normwise_firstOrder_abs_le n A_inv ΔA c x Δb
              E_norm f_norm ε hΔA hΔb)
            (le_of_lt hden)
    _ = ε *
        (ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x /
          |ch7LinearFunctional n c x|) := by
          ring

/-- Constant componentwise matrix envelope used internally to turn a normwise
matrix perturbation radius into the local inverse smallness surface from
Problem 7.11.  It is only a conservative bridge; the first-order condition
value remains the normwise formula. -/
noncomputable def ch7Problem79NormwiseConstantEnvelopeMatrix (n : ℕ)
    (E_norm : ℝ) : Fin n → Fin n → ℝ :=
  fun _ _ => E_norm

/-- Constant componentwise right-hand-side envelope corresponding to the
normwise scalar radius `‖f‖₂`. -/
noncomputable def ch7Problem79NormwiseConstantEnvelopeVector (n : ℕ)
    (f_norm : ℝ) : Fin n → ℝ :=
  fun _ => f_norm

lemma ch7Problem79_vecNorm2_finiteBasisVec {n : ℕ} (j : Fin n) :
    vecNorm2 (finiteBasisVec j) = 1 := by
  unfold vecNorm2 vecNorm2Sq finiteBasisVec
  simp

lemma ch7Problem79_matMulVec_finiteBasisVec {n : ℕ}
    (A : Fin n → Fin n → ℝ) (j : Fin n) :
    matMulVec n A (finiteBasisVec j) = fun i : Fin n => A i j := by
  ext i
  unfold matMulVec finiteBasisVec
  simp

lemma ch7Problem79_normwise_deltaA_componentwise_bound (n : ℕ)
    (ΔA : Fin n → Fin n → ℝ) (E_norm ε : ℝ)
    (hΔA : opNorm2Le ΔA (ε * E_norm)) :
    ∀ i j, |ΔA i j| ≤ ε * E_norm := by
  intro i j
  have htest := hΔA (finiteBasisVec j)
  rw [ch7Problem79_matMulVec_finiteBasisVec ΔA j,
    ch7Problem79_vecNorm2_finiteBasisVec j, mul_one] at htest
  exact (abs_coord_le_vecNorm2 (fun r : Fin n => ΔA r j) i).trans htest

lemma ch7Problem79_normwise_deltaB_componentwise_bound {n : ℕ}
    (Δb : Fin n → ℝ) (f_norm ε : ℝ)
    (hΔb : vecNorm2 Δb ≤ ε * f_norm) :
    ∀ i, |Δb i| ≤ ε * f_norm := by
  intro i
  exact (abs_coord_le_vecNorm2 Δb i).trans hΔb

lemma ch7Problem79_normwise_delta_rhs_infNormVec_le_envelope (n : ℕ)
    (ΔA : Fin n → Fin n → ℝ) (x Δb : Fin n → ℝ)
    (E_norm f_norm ε : ℝ)
    (hε : 0 ≤ ε) (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hΔA : opNorm2Le ΔA (ε * E_norm))
    (hΔb : vecNorm2 Δb ≤ ε * f_norm) :
    infNormVec (fun i => Δb i - matMulVec n ΔA x i) ≤
      ε * (f_norm + E_norm * vecNorm2 x) := by
  have hvec :
      vecNorm2 (fun i : Fin n => Δb i - matMulVec n ΔA x i) ≤
        ε * (f_norm + E_norm * vecNorm2 x) := by
    calc
      vecNorm2 (fun i : Fin n => Δb i - matMulVec n ΔA x i)
          ≤ vecNorm2 Δb + vecNorm2 (matMulVec n ΔA x) := by
            have h :=
              vecNorm2_add_le Δb (fun i : Fin n => -matMulVec n ΔA x i)
            simpa [sub_eq_add_neg, vecNorm2_neg] using h
      _ ≤ ε * f_norm + (ε * E_norm) * vecNorm2 x :=
            add_le_add hΔb (hΔA x)
      _ = ε * (f_norm + E_norm * vecNorm2 x) := by
            ring
  apply infNormVec_le_of_abs_le
  · intro i
    exact (abs_coord_le_vecNorm2
      (fun i : Fin n => Δb i - matMulVec n ΔA x i) i).trans hvec
  · exact mul_nonneg hε
      (add_nonneg hf (mul_nonneg hE (vecNorm2_nonneg x)))

/-- Attaining right-hand-side perturbation for the finite normwise scalar-output
formula. -/
noncomputable def ch7Problem79NormwiseAttainingDeltaB (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (f_norm : ℝ) (c : Fin n → ℝ) (ε : ℝ) :
    Fin n → ℝ :=
  fun j =>
    (ε * f_norm / vecNorm2 (ch7Problem79AdjointWeight n A_inv c)) *
      ch7Problem79AdjointWeight n A_inv c j

/-- The target vector for the rank-one attaining matrix perturbation in the
finite normwise scalar-output formula. -/
noncomputable def ch7Problem79NormwiseAttainingMatrixTarget (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm : ℝ) (c x : Fin n → ℝ) (ε : ℝ) :
    Fin n → ℝ :=
  fun j =>
    -(ε * E_norm * vecNorm2 x /
        vecNorm2 (ch7Problem79AdjointWeight n A_inv c)) *
      ch7Problem79AdjointWeight n A_inv c j

/-- Attaining matrix perturbation for the finite normwise scalar-output formula,
chosen as a rank-one perturbation that maps `x` to the desired target vector. -/
noncomputable def ch7Problem79NormwiseAttainingDeltaA (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm : ℝ) (c x : Fin n → ℝ) (ε : ℝ) :
    Fin n → Fin n → ℝ :=
  residualRankOnePerturbation n
    (ch7Problem79NormwiseAttainingMatrixTarget n A_inv E_norm c x ε) x

lemma ch7Problem79_normwiseAttainingDeltaB_bound (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (f_norm : ℝ) (c : Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hf : 0 ≤ f_norm)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0) :
    vecNorm2 (ch7Problem79NormwiseAttainingDeltaB n A_inv f_norm c ε) ≤
      ε * f_norm := by
  let w : Fin n → ℝ := ch7Problem79AdjointWeight n A_inv c
  have hwpos : 0 < vecNorm2 w :=
    lt_of_le_of_ne (vecNorm2_nonneg w) (Ne.symm (by simpa [w] using hw))
  unfold ch7Problem79NormwiseAttainingDeltaB
  change vecNorm2 (fun j : Fin n => (ε * f_norm / vecNorm2 w) * w j) ≤
    ε * f_norm
  rw [vecNorm2_smul]
  have hscale_nonneg : 0 ≤ ε * f_norm / vecNorm2 w :=
    div_nonneg (mul_nonneg hε hf) (le_of_lt hwpos)
  rw [abs_of_nonneg hscale_nonneg]
  field_simp [hwpos.ne']
  exact le_rfl

lemma ch7Problem79_normwiseAttainingMatrixTarget_norm (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm : ℝ) (c x : Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : 0 ≤ E_norm)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0) :
    vecNorm2
        (ch7Problem79NormwiseAttainingMatrixTarget n A_inv E_norm c x ε) =
      ε * E_norm * vecNorm2 x := by
  let w : Fin n → ℝ := ch7Problem79AdjointWeight n A_inv c
  have hwpos : 0 < vecNorm2 w :=
    lt_of_le_of_ne (vecNorm2_nonneg w) (Ne.symm (by simpa [w] using hw))
  unfold ch7Problem79NormwiseAttainingMatrixTarget
  change vecNorm2
      (fun j : Fin n => -(ε * E_norm * vecNorm2 x / vecNorm2 w) * w j) =
    ε * E_norm * vecNorm2 x
  rw [vecNorm2_smul]
  have hscale_nonneg :
      0 ≤ ε * E_norm * vecNorm2 x / vecNorm2 w :=
    div_nonneg
      (mul_nonneg (mul_nonneg hε hE) (vecNorm2_nonneg x))
      (le_of_lt hwpos)
  rw [abs_neg, abs_of_nonneg hscale_nonneg]
  field_simp [hwpos.ne']

lemma ch7Problem79_normwiseAttainingDeltaA_bound (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm : ℝ) (c x : Fin n → ℝ) (ε : ℝ)
    (hε : 0 ≤ ε) (hE : 0 ≤ E_norm)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0) :
    opNorm2Le
      (ch7Problem79NormwiseAttainingDeltaA n A_inv E_norm c x ε)
      (ε * E_norm) := by
  let target :=
    ch7Problem79NormwiseAttainingMatrixTarget n A_inv E_norm c x ε
  have htarget_norm :
      vecNorm2 target / vecNorm2 x = ε * E_norm := by
    dsimp [target]
    rw [ch7Problem79_normwiseAttainingMatrixTarget_norm n A_inv E_norm c x ε
      hε hE hw]
    field_simp [hx]
  have hop := opNorm2Le_residualRankOnePerturbation n target x hx
  simpa [ch7Problem79NormwiseAttainingDeltaA, target, htarget_norm] using hop

lemma ch7Problem79_normwise_attaining_firstOrder_eq (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (ε : ℝ)
    (hx : vecNorm2 x ≠ 0) :
    ch7Problem79FirstOrderChange n A_inv c x
        (ch7Problem79NormwiseAttainingDeltaB n A_inv f_norm c ε)
        (ch7Problem79NormwiseAttainingDeltaA n A_inv E_norm c x ε) =
      ε * ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x := by
  let w : Fin n → ℝ := ch7Problem79AdjointWeight n A_inv c
  have hsum_sq : (∑ j : Fin n, w j ^ 2) = vecNorm2 w ^ 2 := by
    simpa [vecNorm2Sq] using (vecNorm2_sq w).symm
  unfold ch7Problem79FirstOrderChange ch7Problem79NormwiseAttainingDeltaB
    ch7Problem79NormwiseAttainingDeltaA
    ch7Problem79NormwiseAttainingMatrixTarget
    ch7Problem79NormwiseSensitivity
  change
    (∑ j : Fin n,
        w j *
          ((ε * f_norm / vecNorm2 w) * w j -
            matMulVec n
              (residualRankOnePerturbation n
                (fun j : Fin n =>
                  -(ε * E_norm * vecNorm2 x / vecNorm2 w) * w j) x)
              x j)) =
      ε * (vecNorm2 w * (E_norm * vecNorm2 x + f_norm))
  have hmat' :
      matMulVec n
          (residualRankOnePerturbation n
            (fun j : Fin n =>
              -(ε * E_norm * vecNorm2 x / vecNorm2 w) * w j) x)
          x =
        fun j : Fin n => -(ε * E_norm * vecNorm2 x / vecNorm2 w) * w j := by
    exact residualRankOnePerturbation_mul_vec n
      (fun j : Fin n => -(ε * E_norm * vecNorm2 x / vecNorm2 w) * w j) x hx
  calc
    (∑ j : Fin n,
        w j *
          ((ε * f_norm / vecNorm2 w) * w j -
            matMulVec n
              (residualRankOnePerturbation n
                (fun j : Fin n =>
                  -(ε * E_norm * vecNorm2 x / vecNorm2 w) * w j) x)
              x j))
        = ∑ j : Fin n,
            ((ε * f_norm / vecNorm2 w) +
              (ε * E_norm * vecNorm2 x / vecNorm2 w)) * (w j ^ 2) := by
          apply Finset.sum_congr rfl
          intro j _
          rw [hmat']
          ring
    _ = ((ε * f_norm / vecNorm2 w) +
          (ε * E_norm * vecNorm2 x / vecNorm2 w)) *
        ∑ j : Fin n, w j ^ 2 := by
          rw [Finset.mul_sum]
    _ = ε * (vecNorm2 w * (E_norm * vecNorm2 x + f_norm)) := by
          rw [hsum_sq]
          field_simp
          ring

/-- Problem 7.9, finite first-order normwise formula for the scalar output
`cᵀx`, using the repository's operator-2 certificate surface for the matrix
perturbation constraint.  This is the finite linearized normwise analogue of
the componentwise formula; it does not assert the nonlinear `lim sup` bridge. -/
theorem problem7_9_linearized_normwise_functional_formula
    (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ) (c x : Fin n → ℝ)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0) :
    (∀ ε ΔA Δb, 0 ≤ ε →
      opNorm2Le ΔA (ε * E_norm) →
      vecNorm2 Δb ≤ ε * f_norm →
      ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA ≤
        ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x) ∧
    (∀ ε, 0 ≤ ε →
      ∃ ΔA : Fin n → Fin n → ℝ, ∃ Δb : Fin n → ℝ,
        opNorm2Le ΔA (ε * E_norm) ∧
        vecNorm2 Δb ≤ ε * f_norm ∧
        ch7Problem79FirstOrderChange n A_inv c x Δb ΔA =
          ε * ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x ∧
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA =
          ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x) := by
  constructor
  · intro ε ΔA Δb _hε hΔA hΔb
    exact ch7Problem79_normwiseLinearizedRelativeChange_le n A_inv ΔA c x Δb
      E_norm f_norm ε hden hΔA hΔb
  · intro ε hε
    let ΔA := ch7Problem79NormwiseAttainingDeltaA n A_inv E_norm c x ε
    let Δb := ch7Problem79NormwiseAttainingDeltaB n A_inv f_norm c ε
    have hΔA : opNorm2Le ΔA (ε * E_norm) := by
      dsimp [ΔA]
      exact ch7Problem79_normwiseAttainingDeltaA_bound n A_inv E_norm c x ε
        hε hE hx hw
    have hΔb : vecNorm2 Δb ≤ ε * f_norm := by
      dsimp [Δb]
      exact ch7Problem79_normwiseAttainingDeltaB_bound n A_inv f_norm c ε
        hε hf hw
    have hsens_nonneg :
        0 ≤ ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x :=
      ch7Problem79NormwiseSensitivity_nonneg n A_inv E_norm f_norm c x hE hf
    have hfirst :
        ch7Problem79FirstOrderChange n A_inv c x Δb ΔA =
          ε * ch7Problem79NormwiseSensitivity n A_inv E_norm f_norm c x := by
      dsimp [ΔA, Δb]
      exact ch7Problem79_normwise_attaining_firstOrder_eq n A_inv E_norm f_norm
        c x ε hx
    have hrel :
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA =
          ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x := by
      unfold ch7Problem79LinearizedRelativeChange
        ch7Problem79NormwiseLinearizedCond
      rw [hfirst]
      rw [abs_of_nonneg (mul_nonneg hε hsens_nonneg)]
      ring
    exact ⟨ΔA, Δb, hΔA, hΔb, hfirst, hrel⟩

-- ------------------------------------------------------------
-- Problem 7.9: first-order source-radius condition values
-- ------------------------------------------------------------

/-- Radius-feasible first-order componentwise scalar-output values for Problem
7.9.  This packages the already proved finite linearized formula as a
source-radius supremum; the set is intentionally named `Linearized` because it
does not include the nonlinear equation
`(A + ΔA)(x + Δx) = b + Δb`. -/
def Ch7Problem79ComponentwiseLinearizedRadiusSet
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ℝ) : Set ℝ :=
  { q | ∃ ε : ℝ, ∃ ΔA : Fin n → Fin n → ℝ, ∃ Δb : Fin n → ℝ,
      0 < ε ∧
      ε ≤ rho ∧
      (∀ i j, |ΔA i j| ≤ ε * E i j) ∧
      (∀ i, |Δb i| ≤ ε * f i) ∧
      q = ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA / ε }

/-- Supremum over the first-order componentwise radius set for Problem 7.9. -/
noncomputable def ch7Problem79ComponentwiseLinearizedRadiusSup
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ℝ) : ℝ :=
  sSup (Ch7Problem79ComponentwiseLinearizedRadiusSet n A_inv E f c x rho)

/-- Limit-value predicate for the first-order componentwise scalar-output
condition number in Problem 7.9. -/
def IsCh7Problem79ComponentwiseLinearizedRadiusLimitValue
    {ι : Type*} (l : Filter ι)
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ι → ℝ)
    (κ : ℝ) : Prop :=
  Filter.Tendsto
    (fun t => ch7Problem79ComponentwiseLinearizedRadiusSup
      n A_inv E f c x (rho t))
    l (nhds κ)

/-- Value predicate for the checked first-order componentwise scalar-output
condition number in Problem 7.9. -/
def IsCh7Problem79ComponentwiseLinearizedCondValue
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (κ : ℝ) : Prop :=
  κ = ch7Problem79LinearizedCond n A_inv E f c x

theorem ch7Problem79ComponentwiseLinearizedRadiusSet_value_le
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) {rho q : ℝ}
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hq :
      q ∈ Ch7Problem79ComponentwiseLinearizedRadiusSet n A_inv E f c x rho) :
    q ≤ ch7Problem79LinearizedCond n A_inv E f c x := by
  rcases hq with ⟨ε, ΔA, Δb, hεpos, _hερ, hΔA, hΔb, rfl⟩
  have hupper :=
    (problem7_9_linearized_componentwise_functional_formula
      n A_inv E f c x hE hf hden).1 ε ΔA Δb (le_of_lt hεpos) hΔA hΔb
  have hε_ne : ε ≠ 0 := ne_of_gt hεpos
  calc
    ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA / ε
        ≤ (ε * ch7Problem79LinearizedCond n A_inv E f c x) / ε :=
          div_le_div_of_nonneg_right hupper (le_of_lt hεpos)
    _ = ch7Problem79LinearizedCond n A_inv E f c x := by
          field_simp [hε_ne]

theorem exists_ch7Problem79ComponentwiseLinearizedRadiusSet_exact_witness
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) {rho : ℝ}
    (hrho : 0 < rho)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    ch7Problem79LinearizedCond n A_inv E f c x ∈
      Ch7Problem79ComponentwiseLinearizedRadiusSet n A_inv E f c x rho := by
  rcases
    (problem7_9_linearized_componentwise_functional_formula
      n A_inv E f c x hE hf hden).2 rho (le_of_lt hrho) with
    ⟨ΔA, Δb, hΔA, hΔb, _hfirst, hrel⟩
  refine ⟨rho, ΔA, Δb, hrho, le_rfl, hΔA, hΔb, ?_⟩
  rw [hrel]
  field_simp [ne_of_gt hrho]

/-- For every positive radius, the first-order componentwise Problem 7.9
radius supremum is exactly the finite formula
`|cᵀA⁻¹|(E|x|+f)/|cᵀx|`. -/
theorem ch7Problem79ComponentwiseLinearizedRadiusSup_eq
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) {rho : ℝ}
    (hrho : 0 < rho)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    ch7Problem79ComponentwiseLinearizedRadiusSup n A_inv E f c x rho =
      ch7Problem79LinearizedCond n A_inv E f c x := by
  let S := Ch7Problem79ComponentwiseLinearizedRadiusSet n A_inv E f c x rho
  let κ := ch7Problem79LinearizedCond n A_inv E f c x
  have hκmem : κ ∈ S := by
    dsimp [S, κ]
    exact
      exists_ch7Problem79ComponentwiseLinearizedRadiusSet_exact_witness
        n A_inv E f c x hrho hE hf hden
  have hupper : ∀ q : ℝ, q ∈ S → q ≤ κ := by
    intro q hq
    dsimp [S, κ] at hq ⊢
    exact
      ch7Problem79ComponentwiseLinearizedRadiusSet_value_le
        n A_inv E f c x hE hf hden hq
  change sSup S = κ
  exact le_antisymm (csSup_le ⟨κ, hκmem⟩ hupper) (le_csSup ⟨κ, hupper⟩ hκmem)

/-- Source-radius limit packaging of the first-order componentwise Problem 7.9
formula.  The radius supremum is constant for all positive radii, so it tends
to the finite formula along every eventually positive radius scale. -/
theorem problem7_9_componentwise_linearized_radiusSup_tendsto_formula
    {ι : Type*} {l : Filter ι}
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    IsCh7Problem79ComponentwiseLinearizedRadiusLimitValue l
      n A_inv E f c x rho (ch7Problem79LinearizedCond n A_inv E f c x) := by
  dsimp [IsCh7Problem79ComponentwiseLinearizedRadiusLimitValue]
  have heq :
      (fun t =>
          ch7Problem79ComponentwiseLinearizedRadiusSup
            n A_inv E f c x (rho t)) =ᶠ[l]
        fun _ : ι => ch7Problem79LinearizedCond n A_inv E f c x := by
    filter_upwards [hrho_pos] with t ht
    exact
      ch7Problem79ComponentwiseLinearizedRadiusSup_eq
        n A_inv E f c x ht hE hf hden
  exact Filter.Tendsto.congr' heq.symm tendsto_const_nhds

/-- Product-plus-limit packaging for the first-order componentwise scalar-output
condition number in Problem 7.9. -/
theorem problem7_9_componentwise_linearized_condition_of_positive_radii
    {ι : Type*} {l : Filter ι}
    (n : ℕ)
    (A_inv E : Fin n → Fin n → ℝ) (f c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    ∃ κ : ℝ,
      IsCh7Problem79ComponentwiseLinearizedCondValue n A_inv E f c x κ ∧
        IsCh7Problem79ComponentwiseLinearizedRadiusLimitValue l
          n A_inv E f c x rho κ := by
  refine ⟨ch7Problem79LinearizedCond n A_inv E f c x, rfl, ?_⟩
  exact
    problem7_9_componentwise_linearized_radiusSup_tendsto_formula
      n A_inv E f c x rho hrho_pos hE hf hden

