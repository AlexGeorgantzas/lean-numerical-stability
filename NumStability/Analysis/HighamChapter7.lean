  if i = 0 then 1 else (11 / 20 : ℝ)

private lemma theorem7_5_literalRowInfCounterexample_infNorm_A_identity :
    infNormRect
        (ch7RectLeftScale theorem7_5_literalRowInfCounterexampleIdentityScale
          theorem7_5_literalRowInfCounterexampleA) = 2 := by
  have hle :
      infNormRect
          (ch7RectLeftScale theorem7_5_literalRowInfCounterexampleIdentityScale
            theorem7_5_literalRowInfCounterexampleA) ≤ 2 := by
    apply infNormRect_le_of_row_sum_le
    · intro i
      fin_cases i
      · norm_num [ch7RectLeftScale,
          theorem7_5_literalRowInfCounterexampleIdentityScale,
          theorem7_5_literalRowInfCounterexampleA, Fin.sum_univ_two]
      · norm_num [ch7RectLeftScale,
          theorem7_5_literalRowInfCounterexampleIdentityScale,
          theorem7_5_literalRowInfCounterexampleA, Fin.sum_univ_two]
    · norm_num
  have hge :
      2 ≤ infNormRect
          (ch7RectLeftScale theorem7_5_literalRowInfCounterexampleIdentityScale
            theorem7_5_literalRowInfCounterexampleA) := by
    have h := row_sum_le_infNormRect
      (ch7RectLeftScale theorem7_5_literalRowInfCounterexampleIdentityScale
        theorem7_5_literalRowInfCounterexampleA) (0 : Fin 2)
    norm_num [ch7RectLeftScale,
      theorem7_5_literalRowInfCounterexampleIdentityScale,
      theorem7_5_literalRowInfCounterexampleA, Fin.sum_univ_two] at h
    exact h
  exact le_antisymm hle hge

