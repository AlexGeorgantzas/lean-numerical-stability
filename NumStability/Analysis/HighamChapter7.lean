/-- Source audit for Theorem 7.5 row-scale notation.  If the printed
`D_R := diag(‖A(i,:)‖_p)⁻¹` is read literally at `p = ∞` as scaling by the
maximum absolute row entry, then the statement is false: the matrix below has
row max-entry norm one in every row, so that literal scale is the identity, but
another reciprocal row scaling gives a strictly smaller infinity-norm condition
product.  This is why the formal `p = ∞` row theorem above uses the row
`1`-norm scale obtained from the duality proof. -/
theorem theorem7_5_literal_printed_row_inf_scale_counterexample :
    (∀ i j : Fin 2, |theorem7_5_literalRowInfCounterexampleA i j| ≤ 1) ∧
    (∀ i : Fin 2, ∃ j : Fin 2,
      |theorem7_5_literalRowInfCounterexampleA i j| = 1) ∧
    (∀ i j : Fin 2,
      ∑ k : Fin 2,
        theorem7_5_literalRowInfCounterexampleA i k *
          theorem7_5_literalRowInfCounterexampleAplus k j =
            if i = j then 1 else 0) ∧
    (∀ i : Fin 2,
      theorem7_5_literalRowInfCounterexampleBetterScale i *
        theorem7_5_literalRowInfCounterexampleBetterInvScale i = 1) ∧
    ch7InfNormLeftScaledCond theorem7_5_literalRowInfCounterexampleA
      theorem7_5_literalRowInfCounterexampleAplus
      theorem7_5_literalRowInfCounterexampleIdentityScale
      theorem7_5_literalRowInfCounterexampleIdentityScale = (40 / 9 : ℝ) ∧
    ch7InfNormLeftScaledCond theorem7_5_literalRowInfCounterexampleA
      theorem7_5_literalRowInfCounterexampleAplus
      theorem7_5_literalRowInfCounterexampleBetterScale
      theorem7_5_literalRowInfCounterexampleBetterInvScale = (31 / 9 : ℝ) ∧
    ch7InfNormLeftScaledCond theorem7_5_literalRowInfCounterexampleA
      theorem7_5_literalRowInfCounterexampleAplus
      theorem7_5_literalRowInfCounterexampleBetterScale
      theorem7_5_literalRowInfCounterexampleBetterInvScale <
    ch7InfNormLeftScaledCond theorem7_5_literalRowInfCounterexampleA
      theorem7_5_literalRowInfCounterexampleAplus
      theorem7_5_literalRowInfCounterexampleIdentityScale
      theorem7_5_literalRowInfCounterexampleIdentityScale := by
  constructor
  · intro i j
    fin_cases i <;> fin_cases j <;>
      norm_num [theorem7_5_literalRowInfCounterexampleA]
  constructor
  · intro i
    fin_cases i
    · exact ⟨0, by norm_num [theorem7_5_literalRowInfCounterexampleA]⟩
    · exact ⟨1, by norm_num [theorem7_5_literalRowInfCounterexampleA]⟩
  constructor
  · intro i j
    fin_cases i <;> fin_cases j <;>
      norm_num [theorem7_5_literalRowInfCounterexampleA,
        theorem7_5_literalRowInfCounterexampleAplus, Fin.sum_univ_two] <;> rfl
  constructor
  · intro i
    fin_cases i
    · norm_num [theorem7_5_literalRowInfCounterexampleBetterScale,
        theorem7_5_literalRowInfCounterexampleBetterInvScale]
    · norm_num [theorem7_5_literalRowInfCounterexampleBetterScale,
        theorem7_5_literalRowInfCounterexampleBetterInvScale]
      rfl
  constructor
  · exact theorem7_5_literalRowInfCounterexample_cond_identity
  constructor
  · exact theorem7_5_literalRowInfCounterexample_cond_better
  · rw [theorem7_5_literalRowInfCounterexample_cond_better,
      theorem7_5_literalRowInfCounterexample_cond_identity]
    norm_num

/-- Theorem 7.5, `p = 1` column minimum-attainment form with the source
full-column-rank hypothesis stated as injectivity of the rectangular map
`x ↦ A*x`.  The proof constructs a concrete left inverse and then reuses the
