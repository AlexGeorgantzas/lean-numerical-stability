/-- Problem 7.10(e)'s absolute-value reduction for the one-norm condition
product. -/
lemma ch7TwoSidedScaledOneKappa_eq_abs_scaledOneCond {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁ : ∀ i : Fin n, 0 ≤ d₁ i)
    (hd₁Inv : ∀ i : Fin n, 0 ≤ d₁Inv i)
    (hd₂ : ∀ i : Fin n, 0 ≤ d₂ i)
    (hd₂Inv : ∀ i : Fin n, 0 ≤ d₂Inv i) :
    ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv =
      ch7TwoSidedScaledOneCond (absMatrix n A) (absMatrix n A_inv)
        d₁ d₁Inv d₂ d₂Inv := by
  unfold ch7TwoSidedScaledOneKappa ch7TwoSidedScaledOneCond oneNorm
  rw [show (fun i j => ch7TwoSidedScale d₁ A d₂ j i) =
      ch7TwoSidedScale d₂ (matTranspose A) d₁ by
        change matTranspose (ch7TwoSidedScale d₁ A d₂) =
          ch7TwoSidedScale d₂ (matTranspose A) d₁
        rw [ch7_matTranspose_twoSidedScale],
    show (fun i j => ch7TwoSidedScale d₁ (absMatrix n A) d₂ j i) =
      ch7TwoSidedScale d₂ (matTranspose (absMatrix n A)) d₁ by
        change matTranspose (ch7TwoSidedScale d₁ (absMatrix n A) d₂) =
          ch7TwoSidedScale d₂ (matTranspose (absMatrix n A)) d₁
        rw [ch7_matTranspose_twoSidedScale],
    show (fun i j => ch7TwoSidedScale d₂Inv A_inv d₁Inv j i) =
      ch7TwoSidedScale d₁Inv (matTranspose A_inv) d₂Inv by
        change matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv) =
          ch7TwoSidedScale d₁Inv (matTranspose A_inv) d₂Inv
        rw [ch7_matTranspose_twoSidedScale],
    show (fun i j => ch7TwoSidedScale d₂Inv (absMatrix n A_inv) d₁Inv j i) =
      ch7TwoSidedScale d₁Inv (matTranspose (absMatrix n A_inv)) d₂Inv by
        change matTranspose (ch7TwoSidedScale d₂Inv (absMatrix n A_inv) d₁Inv) =
          ch7TwoSidedScale d₁Inv (matTranspose (absMatrix n A_inv)) d₂Inv
        rw [ch7_matTranspose_twoSidedScale]]
  change infNorm (ch7TwoSidedScale d₂ (matTranspose A) d₁) *
      infNorm (ch7TwoSidedScale d₁Inv (matTranspose A_inv) d₂Inv) =
    infNorm (ch7TwoSidedScale d₂ (absMatrix n (matTranspose A)) d₁) *
      infNorm (ch7TwoSidedScale d₁Inv (absMatrix n (matTranspose A_inv)) d₂Inv)
  rw [ch7_infNorm_twoSidedScale_absMatrix_eq hn d₂ (matTranspose A) d₁ hd₂ hd₁,
    ch7_infNorm_twoSidedScale_absMatrix_eq hn
      d₁Inv (matTranspose A_inv) d₂Inv hd₁Inv hd₂Inv]

