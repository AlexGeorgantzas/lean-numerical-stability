-- ============================================================
-- Corollary 7.6 dependency: SPD diagonal scaling via Cholesky factors
-- ============================================================

/-- Corollary 7.6's symmetric positive-definite diagonal scaling
`D* = diag(a_ii^{-1/2})`, represented by its diagonal entries. -/
noncomputable def ch7SymmetricDiagEquilibratingScale2 {n : ℕ}
    (A : Fin n → Fin n → ℝ) (j : Fin n) : ℝ :=
  1 / Real.sqrt (A j j)

/-- Inverse diagonal entries for `ch7SymmetricDiagEquilibratingScale2`. -/
noncomputable def ch7SymmetricDiagEquilibratingInvScale2 {n : ℕ}
    (A : Fin n → Fin n → ℝ) (j : Fin n) : ℝ :=
  Real.sqrt (A j j)

/-- Corollary 7.6 Cholesky bridge: if `A = RᵀR` on diagonal entries, then the
diagonal entry `a_jj` is the squared Euclidean norm of column `j` of `R`. -/
theorem corollary7_6_cholesky_diag_eq_column_norm_sq {n : ℕ}
    (A R : Fin n → Fin n → ℝ)
    (hGramDiag : ∀ j : Fin n, ∑ k : Fin n, R k j * R k j = A j j)
    (j : Fin n) :
    ch7RectColumnNorm2 R j ^ 2 = A j j := by
  calc
    ch7RectColumnNorm2 R j ^ 2 = vecNorm2Sq (fun i : Fin n => R i j) := by
      simpa [ch7RectColumnNorm2] using (vecNorm2_sq (fun i : Fin n => R i j))
    _ = A j j := by
      simpa [vecNorm2Sq, pow_two] using hGramDiag j

/-- Under positive diagonal entries, Corollary 7.6's inverse scale
`sqrt(a_jj)` is exactly the Euclidean column norm of the Cholesky factor. -/
theorem corollary7_6_cholesky_diag_invScale_eq_column_norm {n : ℕ}
    (A R : Fin n → Fin n → ℝ)
    (hGramDiag : ∀ j : Fin n, ∑ k : Fin n, R k j * R k j = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    ch7SymmetricDiagEquilibratingInvScale2 A =
      fun j : Fin n => ch7RectColumnNorm2 R j := by
  ext j
  have hsq := corollary7_6_cholesky_diag_eq_column_norm_sq A R hGramDiag j
  have hsqrt_sq : Real.sqrt (A j j) ^ 2 = A j j := by
    rw [sq, Real.mul_self_sqrt (le_of_lt (hdiag j))]
  exact (sq_eq_sq₀ (Real.sqrt_nonneg _) (ch7RectColumnNorm2_nonneg R j)).mp
    (by rw [hsqrt_sq, hsq])

/-- Corollary 7.6's symmetric scaling is the same diagonal as the
column-equilibrating scaling of the Cholesky factor `R`. -/
theorem corollary7_6_cholesky_diag_scale_eq_column_equilibrating {n : ℕ}
    (A R : Fin n → Fin n → ℝ)
    (hGramDiag : ∀ j : Fin n, ∑ k : Fin n, R k j * R k j = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    ch7SymmetricDiagEquilibratingScale2 A = ch7ColumnEquilibratingScale2 R := by
  have hinv := corollary7_6_cholesky_diag_invScale_eq_column_norm A R hGramDiag hdiag
  ext j
  unfold ch7SymmetricDiagEquilibratingScale2 ch7ColumnEquilibratingScale2
  have hnorm : Real.sqrt (A j j) = ch7RectColumnNorm2 R j := by
    simpa [ch7SymmetricDiagEquilibratingInvScale2] using congrFun hinv j
  rw [hnorm]

/-- Positive diagonal entries of `A = RᵀR` imply all Cholesky-factor columns
have positive Euclidean norm, the nonzero-column side condition required by
Theorem 7.5's `p = 2` column-equilibration route. -/
theorem corollary7_6_cholesky_column_norm_pos {n : ℕ}
    (A R : Fin n → Fin n → ℝ)
    (hGramDiag : ∀ j : Fin n, ∑ k : Fin n, R k j * R k j = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    ∀ j : Fin n, 0 < ch7RectColumnNorm2 R j := by
  intro j
  have hinv := corollary7_6_cholesky_diag_invScale_eq_column_norm A R hGramDiag hdiag
  have h : ch7RectColumnNorm2 R j = Real.sqrt (A j j) := by
    simpa [ch7SymmetricDiagEquilibratingInvScale2] using congrFun hinv.symm j
  rw [h]
  exact Real.sqrt_pos.2 (hdiag j)

/-- Applying Corollary 7.6's `D*` to the Cholesky factor equilibrates every
column of `R` to Euclidean norm one. -/
theorem corollary7_6_cholesky_factor_column_equilibrated {n : ℕ}
    (A R : Fin n → Fin n → ℝ)
    (hGramDiag : ∀ j : Fin n, ∑ k : Fin n, R k j * R k j = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    ∀ j : Fin n,
      ch7RectColumnNorm2
        (ch7RectRightScale R (ch7SymmetricDiagEquilibratingScale2 A)) j = 1 := by
  intro j
  have hscale := corollary7_6_cholesky_diag_scale_eq_column_equilibrating A R
    hGramDiag hdiag
  have hcol := corollary7_6_cholesky_column_norm_pos A R hGramDiag hdiag
  rw [hscale]
  exact ch7RectColumnNorm2_rightScale_equilibrating R hcol j

/-- Corollary 7.6 dependency: the Cholesky factor scaled by the source
diagonal `D*` has rectangular operator-2 norm at most `sqrt(n)`. -/
theorem corollary7_6_cholesky_factor_op2Le_sqrt_card {n : ℕ}
    (A R : Fin n → Fin n → ℝ)
    (hGramDiag : ∀ j : Fin n, ∑ k : Fin n, R k j * R k j = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    rectOpNorm2Le
      (ch7RectRightScale R (ch7SymmetricDiagEquilibratingScale2 A))
      (Real.sqrt (n : ℝ)) := by
  have hscale := corollary7_6_cholesky_diag_scale_eq_column_equilibrating A R
    hGramDiag hdiag
  have hcol := corollary7_6_cholesky_column_norm_pos A R hGramDiag hdiag
  rw [hscale]
  exact eq_7_21_rectOpNorm2Le_column_equilibrated R hcol

/-- Corollary 7.6 dependency: applying the closed `p = 2` van der Sluis
`sInf` wrapper to a Cholesky factor `R`, with the source diagonal
`D* = diag(a_jj^{-1/2})`.  This proves the Theorem 7.5 part of Corollary 7.6;
the remaining source equality `κ₂(DAD)=κ₂(RD)^2` is kept as a separate open
condition-number bridge. -/
theorem corollary7_6_cholesky_factor_column_scaling_le_sqrt_card_sInf_right_scalings
    {n : ℕ} (hn : 0 < n)
    (A R Rplus : Fin n → Fin n → ℝ)
    (hGramDiag : ∀ j : Fin n, ∑ k : Fin n, R k j * R k j = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    ch7Op2RightScaledCond R Rplus
        (ch7SymmetricDiagEquilibratingScale2 A)
        (ch7SymmetricDiagEquilibratingInvScale2 A) ≤
      Real.sqrt (n : ℝ) * sInf (ch7Op2RightScaledCondSet R Rplus) := by
  have hscale := corollary7_6_cholesky_diag_scale_eq_column_equilibrating A R
    hGramDiag hdiag
  have hinv := corollary7_6_cholesky_diag_invScale_eq_column_norm A R hGramDiag hdiag
  have hcol := corollary7_6_cholesky_column_norm_pos A R hGramDiag hdiag
  rw [hscale, hinv]
  exact theorem7_5_p2_column_equilibration_le_sqrt_card_sInf_right_scalings
    hn R Rplus hcol

-- ============================================================
-- Theorem 7.7: Stewart-Sun Frobenius right scaling
-- ============================================================

/-- Euclidean norm of column `j` in the source notation `‖a_j‖₂`. -/
noncomputable def ch7ColumnNorm2 {n : ℕ}
    (A : Fin n → Fin n → ℝ) (j : Fin n) : ℝ :=
  vecNorm2 (fun i : Fin n => A i j)

/-- Euclidean norm of row `j` of the inverse in the source notation
`‖b_j‖₂`, where `A⁻¹ = [b_1, ..., b_n]^T`. -/
noncomputable def ch7InverseRowNorm2 {n : ℕ}
    (A_inv : Fin n → Fin n → ℝ) (j : Fin n) : ℝ :=
  vecNorm2 (fun k : Fin n => A_inv j k)

/-- The Stewart-Sun Frobenius lower value `Σ_j ‖a_j‖₂ ‖b_j‖₂`. -/
noncomputable def ch7StewartSunFrobeniusValue {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) : ℝ :=
  ∑ j : Fin n, ch7ColumnNorm2 A j * ch7InverseRowNorm2 A_inv j

/-- Frobenius condition product for the right-scaled matrix `A D` and its
inverse-side factor `D⁻¹ A⁻¹`, with the diagonal entries supplied separately. -/
noncomputable def ch7FrobeniusRightScaledCond {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ) : ℝ :=
  frobNorm (matMul n A (diagMatrix d)) *
    frobNorm (matMul n (diagMatrix dInv) A_inv)

/-- The canonical Stewart-Sun diagonal scaling
`D_C = diag((‖b_j‖₂ / ‖a_j‖₂)^(1/2))`. -/
noncomputable def ch7StewartSunScale {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) (j : Fin n) : ℝ :=
  Real.sqrt (ch7InverseRowNorm2 A_inv j / ch7ColumnNorm2 A j)

/-- The inverse diagonal entries for `ch7StewartSunScale`. -/
noncomputable def ch7StewartSunInvScale {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) (j : Fin n) : ℝ :=
  Real.sqrt (ch7ColumnNorm2 A j / ch7InverseRowNorm2 A_inv j)

lemma ch7ColumnNorm2_nonneg {n : ℕ}
    (A : Fin n → Fin n → ℝ) (j : Fin n) :
    0 ≤ ch7ColumnNorm2 A j :=
  vecNorm2_nonneg _

lemma ch7InverseRowNorm2_nonneg {n : ℕ}
    (A_inv : Fin n → Fin n → ℝ) (j : Fin n) :
    0 ≤ ch7InverseRowNorm2 A_inv j :=
  vecNorm2_nonneg _

lemma ch7ColumnNorm2_pos_of_left_inverse {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv) (j : Fin n) :
    0 < ch7ColumnNorm2 A j := by
  have hne : ch7ColumnNorm2 A j ≠ 0 := by
    intro hzero
    have hentries : ∀ i : Fin n, A i j = 0 :=
      (vecNorm2_eq_zero_iff (fun i : Fin n => A i j)).mp hzero
    have hsum_one :
        (∑ k : Fin n, A_inv j k * A k j) = 1 := by
      simpa using hInv j j
    have hsum_zero :
        (∑ k : Fin n, A_inv j k * A k j) = 0 := by
      simp [hentries]
    linarith
  exact lt_of_le_of_ne (ch7ColumnNorm2_nonneg A j) (Ne.symm hne)

lemma ch7InverseRowNorm2_pos_of_left_inverse {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv) (j : Fin n) :
    0 < ch7InverseRowNorm2 A_inv j := by
  have hne : ch7InverseRowNorm2 A_inv j ≠ 0 := by
    intro hzero
    have hentries : ∀ k : Fin n, A_inv j k = 0 :=
      (vecNorm2_eq_zero_iff (fun k : Fin n => A_inv j k)).mp hzero
    have hsum_one :
        (∑ k : Fin n, A_inv j k * A k j) = 1 := by
      simpa using hInv j j
    have hsum_zero :
        (∑ k : Fin n, A_inv j k * A k j) = 0 := by
      simp [hentries]
    linarith
  exact lt_of_le_of_ne (ch7InverseRowNorm2_nonneg A_inv j) (Ne.symm hne)

lemma ch7StewartSunFrobeniusValue_nonneg {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    0 ≤ ch7StewartSunFrobeniusValue A A_inv := by
  unfold ch7StewartSunFrobeniusValue
  exact Finset.sum_nonneg fun j _ =>
    mul_nonneg (ch7ColumnNorm2_nonneg A j) (ch7InverseRowNorm2_nonneg A_inv j)

lemma ch7_frobNorm_rightDiagScale_eq_vecNorm2_column_scales {n : ℕ}
    (A : Fin n → Fin n → ℝ) (d : Fin n → ℝ) :
    frobNorm (matMul n A (diagMatrix d)) =
      vecNorm2 (fun j : Fin n => d j * ch7ColumnNorm2 A j) := by
  refine (sq_eq_sq₀ (frobNorm_nonneg _) (vecNorm2_nonneg _)).mp ?_
  rw [frobNorm_sq, vecNorm2_sq]
  unfold frobNormSq vecNorm2Sq ch7ColumnNorm2
  calc
    (∑ i : Fin n, ∑ j : Fin n, matMul n A (diagMatrix d) i j ^ 2)
        = ∑ i : Fin n, ∑ j : Fin n, (A i j * d j) ^ 2 := by
          apply Finset.sum_congr rfl
          intro i _
          apply Finset.sum_congr rfl
          intro j _
          rw [matMul_diagMatrix_right A d i j]
    _ = ∑ j : Fin n, ∑ i : Fin n, (A i j * d j) ^ 2 := by
          rw [Finset.sum_comm]
    _ = ∑ j : Fin n, d j ^ 2 * ∑ i : Fin n, A i j ^ 2 := by
          apply Finset.sum_congr rfl
          intro j _
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro i _
          ring
      _ = ∑ j : Fin n, (d j * Real.sqrt (∑ i : Fin n, A i j ^ 2)) ^ 2 := by
            apply Finset.sum_congr rfl
            intro j _
            rw [mul_pow, Real.sq_sqrt (Finset.sum_nonneg fun i _ => sq_nonneg (A i j))]
    _ = ∑ j : Fin n,
          (d j * vecNorm2 (fun i : Fin n => A i j)) ^ 2 := by
          rfl

lemma ch7_frobNorm_leftDiagScale_eq_vecNorm2_row_scales {n : ℕ}
    (A_inv : Fin n → Fin n → ℝ) (dInv : Fin n → ℝ) :
    frobNorm (matMul n (diagMatrix dInv) A_inv) =
      vecNorm2 (fun j : Fin n => dInv j * ch7InverseRowNorm2 A_inv j) := by
  refine (sq_eq_sq₀ (frobNorm_nonneg _) (vecNorm2_nonneg _)).mp ?_
  rw [frobNorm_sq, vecNorm2_sq]
  unfold frobNormSq vecNorm2Sq ch7InverseRowNorm2
  calc
    (∑ i : Fin n, ∑ j : Fin n, matMul n (diagMatrix dInv) A_inv i j ^ 2)
        = ∑ i : Fin n, ∑ j : Fin n, (dInv i * A_inv i j) ^ 2 := by
          apply Finset.sum_congr rfl
          intro i _
          apply Finset.sum_congr rfl
          intro j _
          rw [matMul_diagMatrix_left dInv A_inv i j]
    _ = ∑ i : Fin n, dInv i ^ 2 * ∑ j : Fin n, A_inv i j ^ 2 := by
          apply Finset.sum_congr rfl
          intro i _
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring
      _ = ∑ i : Fin n, (dInv i * Real.sqrt (∑ j : Fin n, A_inv i j ^ 2)) ^ 2 := by
            apply Finset.sum_congr rfl
            intro i _
            rw [mul_pow, Real.sq_sqrt
              (Finset.sum_nonneg fun j _ => sq_nonneg (A_inv i j))]
    _ = ∑ i : Fin n,
          (dInv i * vecNorm2 (fun j : Fin n => A_inv i j)) ^ 2 := by
          rfl

/-- Theorem 7.7 lower-bound half: every nonsingular diagonal right scaling has
Frobenius condition product at least `Σ_j ‖a_j‖₂ ‖b_j‖₂`. -/
theorem theorem7_7_frobenius_right_scaling_lower_bound {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7StewartSunFrobeniusValue A A_inv ≤
      ch7FrobeniusRightScaledCond A A_inv d dInv := by
  let u : Fin n → ℝ := fun j => d j * ch7ColumnNorm2 A j
  let v : Fin n → ℝ := fun j => dInv j * ch7InverseRowNorm2 A_inv j
  have hsum :
      ch7StewartSunFrobeniusValue A A_inv =
        ∑ j : Fin n, u j * v j := by
    unfold ch7StewartSunFrobeniusValue
    apply Finset.sum_congr rfl
    intro j _
    dsimp [u, v]
    calc
      ch7ColumnNorm2 A j * ch7InverseRowNorm2 A_inv j
          = (d j * dInv j) *
              (ch7ColumnNorm2 A j * ch7InverseRowNorm2 A_inv j) := by
            rw [hdiag j]
            ring
      _ = (d j * ch7ColumnNorm2 A j) *
            (dInv j * ch7InverseRowNorm2 A_inv j) := by
            ring
  calc
    ch7StewartSunFrobeniusValue A A_inv
        = ∑ j : Fin n, u j * v j := hsum
    _ ≤ |∑ j : Fin n, u j * v j| := le_abs_self _
    _ ≤ vecNorm2 u * vecNorm2 v :=
        abs_vecInnerProduct_le_vecNorm2_mul u v
    _ = ch7FrobeniusRightScaledCond A A_inv d dInv := by
        unfold ch7FrobeniusRightScaledCond
        rw [ch7_frobNorm_rightDiagScale_eq_vecNorm2_column_scales A d,
          ch7_frobNorm_leftDiagScale_eq_vecNorm2_row_scales A_inv dInv]

lemma ch7StewartSunScale_sq_mul_colNorm_sq {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7ColumnNorm2 A j)
    (hrow : ∀ j : Fin n, 0 < ch7InverseRowNorm2 A_inv j)
    (j : Fin n) :
    (ch7StewartSunScale A A_inv j * ch7ColumnNorm2 A j) ^ 2 =
    ch7ColumnNorm2 A j * ch7InverseRowNorm2 A_inv j := by
    unfold ch7StewartSunScale
    rw [mul_pow, Real.sq_sqrt
      (div_nonneg (le_of_lt (hrow j)) (le_of_lt (hcol j)))]
    field_simp [ne_of_gt (hcol j)]

lemma ch7StewartSunInvScale_sq_mul_rowNorm_sq {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7ColumnNorm2 A j)
    (hrow : ∀ j : Fin n, 0 < ch7InverseRowNorm2 A_inv j)
    (j : Fin n) :
    (ch7StewartSunInvScale A A_inv j * ch7InverseRowNorm2 A_inv j) ^ 2 =
    ch7ColumnNorm2 A j * ch7InverseRowNorm2 A_inv j := by
    unfold ch7StewartSunInvScale
    rw [mul_pow, Real.sq_sqrt
      (div_nonneg (le_of_lt (hcol j)) (le_of_lt (hrow j)))]
    field_simp [ne_of_gt (hrow j)]

/-- Higham, 2nd ed., Chapter 7, Theorem 7.7 (Stewart and Sun), source-shaped
finite Frobenius scaling package: the canonical diagonal
`diag((‖b_j‖₂ / ‖a_j‖₂)^(1/2))` attains the lower bound
`Σ_j ‖a_j‖₂ ‖b_j‖₂`, and every inverse diagonal pair is bounded below by it. -/
theorem theorem7_7_stewart_sun_frobenius_scaling {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7ColumnNorm2 A j)
    (hrow : ∀ j : Fin n, 0 < ch7InverseRowNorm2 A_inv j) :
    (∀ d dInv : Fin n → ℝ,
      (∀ j : Fin n, d j * dInv j = 1) →
        ch7StewartSunFrobeniusValue A A_inv ≤
          ch7FrobeniusRightScaledCond A A_inv d dInv) ∧
    ch7FrobeniusRightScaledCond A A_inv
      (ch7StewartSunScale A A_inv) (ch7StewartSunInvScale A A_inv) =
        ch7StewartSunFrobeniusValue A A_inv := by
  constructor
  · intro d dInv hdiag
    exact theorem7_7_frobenius_right_scaling_lower_bound A A_inv d dInv hdiag
  · let S := ch7StewartSunFrobeniusValue A A_inv
    have hS_nonneg : 0 ≤ S := by
      dsimp [S]
      exact ch7StewartSunFrobeniusValue_nonneg A A_inv
    have hA_sq :
        frobNorm (matMul n A (diagMatrix (ch7StewartSunScale A A_inv))) ^ 2 = S := by
      rw [ch7_frobNorm_rightDiagScale_eq_vecNorm2_column_scales A
        (ch7StewartSunScale A A_inv), vecNorm2_sq]
      unfold vecNorm2Sq S ch7StewartSunFrobeniusValue
      apply Finset.sum_congr rfl
      intro j _
      exact ch7StewartSunScale_sq_mul_colNorm_sq A A_inv hcol hrow j
    have hB_sq :
        frobNorm (matMul n (diagMatrix (ch7StewartSunInvScale A A_inv)) A_inv) ^ 2 =
          S := by
      rw [ch7_frobNorm_leftDiagScale_eq_vecNorm2_row_scales A_inv
        (ch7StewartSunInvScale A A_inv), vecNorm2_sq]
      unfold vecNorm2Sq S ch7StewartSunFrobeniusValue
      apply Finset.sum_congr rfl
      intro j _
      exact ch7StewartSunInvScale_sq_mul_rowNorm_sq A A_inv hcol hrow j
    have hA :
        frobNorm (matMul n A (diagMatrix (ch7StewartSunScale A A_inv))) =
          Real.sqrt S := by
      exact (sq_eq_sq₀ (frobNorm_nonneg _) (Real.sqrt_nonneg _)).mp
        (by rw [hA_sq, sq, Real.mul_self_sqrt hS_nonneg])
    have hB :
        frobNorm (matMul n (diagMatrix (ch7StewartSunInvScale A A_inv)) A_inv) =
          Real.sqrt S := by
      exact (sq_eq_sq₀ (frobNorm_nonneg _) (Real.sqrt_nonneg _)).mp
        (by rw [hB_sq, sq, Real.mul_self_sqrt hS_nonneg])
    unfold ch7FrobeniusRightScaledCond
    rw [hA, hB]
    change Real.sqrt S * Real.sqrt S = S
    exact Real.mul_self_sqrt hS_nonneg

/-- Higham, 2nd ed., Chapter 7, Theorem 7.7 in nonsingular-matrix form:
if `A_inv * A = I`, the Stewart-Sun diagonal scaling attains the Frobenius
condition-number lower bound over all inverse diagonal right-scalings. -/
theorem theorem7_7_stewart_sun_frobenius_scaling_of_left_inverse {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv) :
    (∀ d dInv : Fin n → ℝ,
      (∀ j : Fin n, d j * dInv j = 1) →
        ch7StewartSunFrobeniusValue A A_inv ≤
          ch7FrobeniusRightScaledCond A A_inv d dInv) ∧
    ch7FrobeniusRightScaledCond A A_inv
      (ch7StewartSunScale A A_inv) (ch7StewartSunInvScale A A_inv) =
        ch7StewartSunFrobeniusValue A A_inv :=
  theorem7_7_stewart_sun_frobenius_scaling A A_inv
    (ch7ColumnNorm2_pos_of_left_inverse A A_inv hInv)
    (ch7InverseRowNorm2_pos_of_left_inverse A A_inv hInv)

-- ============================================================
-- Theorem 7.8 / Problem 7.10: Bauer two-sided scaling algebraic core
-- ============================================================

/-- Two-sided diagonal scaling `D₁ A D₂`, written entrywise for source-facing
Chapter 7 scaling statements. -/
noncomputable def ch7TwoSidedScale {n : ℕ}
    (dLeft : Fin n → ℝ) (A : Fin n → Fin n → ℝ) (dRight : Fin n → ℝ) :
    Fin n → Fin n → ℝ :=
  fun i j => dLeft i * A i j * dRight j

lemma ch7_matTranspose_twoSidedScale {n : ℕ}
    (dLeft : Fin n → ℝ) (A : Fin n → Fin n → ℝ) (dRight : Fin n → ℝ) :
    matTranspose (ch7TwoSidedScale dLeft A dRight) =
      ch7TwoSidedScale dRight (matTranspose A) dLeft := by
  ext i j
  unfold matTranspose ch7TwoSidedScale
  ring

/-- Corollary 7.6's symmetric operator-2 condition product for `DAD`,
with inverse-side entries supplied as `D⁻¹ A_inv D⁻¹`. -/
noncomputable def ch7SymmetricOp2ScaledCond {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ) : ℝ :=
  complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d A d)) *
    complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale dInv A_inv dInv))

/-- Values of Corollary 7.6's symmetric operator-2 condition product over
reciprocal nonsingular diagonal two-sided scalings.  This is the infimum model
for the source minimization over `DAD`; it intentionally records an `sInf`
surface rather than asserting existence of an attaining diagonal scaling. -/
noncomputable def ch7SymmetricOp2ScaledCondSet {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin n → ℝ,
    (∀ j : Fin n, d j * dInv j = 1) ∧
    κ = ch7SymmetricOp2ScaledCond A A_inv d dInv}

/-- Membership helper for the two-sided symmetric scaling value set. -/
theorem ch7SymmetricOp2ScaledCond_mem_set {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7SymmetricOp2ScaledCond A A_inv d dInv ∈
      ch7SymmetricOp2ScaledCondSet A A_inv := by
  exact ⟨d, dInv, hdiag, rfl⟩

/-- The symmetric two-sided operator-2 scaling value set is nonempty, using the
identity diagonal scaling. -/
theorem ch7SymmetricOp2ScaledCondSet_nonempty {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    (ch7SymmetricOp2ScaledCondSet A A_inv).Nonempty := by
  refine ⟨ch7SymmetricOp2ScaledCond A A_inv (fun _ => 1) (fun _ => 1), ?_⟩
  exact ⟨fun _ => 1, fun _ => 1, (by intro j; norm_num), rfl⟩

/-- Every symmetric two-sided operator-2 condition product is nonnegative. -/
theorem ch7SymmetricOp2ScaledCond_nonneg {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ) :
    0 ≤ ch7SymmetricOp2ScaledCond A A_inv d dInv := by
  unfold ch7SymmetricOp2ScaledCond
  exact mul_nonneg (complexMatrixOp2_nonneg _) (complexMatrixOp2_nonneg _)

/-- The symmetric two-sided operator-2 scaling value set is bounded below by
zero. -/
theorem ch7SymmetricOp2ScaledCondSet_bddBelow {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    BddBelow (ch7SymmetricOp2ScaledCondSet A A_inv) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
  exact ch7SymmetricOp2ScaledCond_nonneg A A_inv d dInv

/-- The infimum of the symmetric two-sided operator-2 scaling value set is
nonnegative. -/
theorem ch7SymmetricOp2ScaledCondSet_sInf_nonneg {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    0 ≤ sInf (ch7SymmetricOp2ScaledCondSet A A_inv) := by
  let S : Set ℝ := ch7SymmetricOp2ScaledCondSet A A_inv
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7SymmetricOp2ScaledCondSet_nonempty A A_inv
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
    exact ch7SymmetricOp2ScaledCond_nonneg A A_inv d dInv
  exact le_csInf hS_nonempty hlower

/-- Cholesky inverse-side Gram candidate `R⁻¹(R⁻¹)ᵀ`. -/
noncomputable def ch7CholeskyInverseGram {n : ℕ}
    (Rinv : Fin n → Fin n → ℝ) : Fin n → Fin n → ℝ :=
  matMul n Rinv (matTranspose Rinv)

/-- If `A = RᵀR`, then `DAD = (RD)ᵀ(RD)`. -/
theorem corollary7_6_cholesky_scaled_gram_eq {n : ℕ}
    (A R : Fin n → Fin n → ℝ) (d : Fin n → ℝ)
    (hGram : ∀ i j : Fin n, (∑ k : Fin n, R k i * R k j) = A i j) :
    ch7TwoSidedScale d A d =
      matMul n (matTranspose (ch7RectRightScale R d)) (ch7RectRightScale R d) := by
  ext i j
  unfold ch7TwoSidedScale matMul matTranspose ch7RectRightScale
  rw [← hGram i j]
  rw [Finset.mul_sum, Finset.sum_mul]
  apply Finset.sum_congr rfl
  intro k _
  ring

/-- The inverse-side Cholesky Gram candidate scales as
`D⁻¹R⁻¹(R⁻¹)ᵀD⁻¹ = (D⁻¹R⁻¹)(D⁻¹R⁻¹)ᵀ`. -/
theorem corollary7_6_cholesky_scaled_inverse_gram_eq {n : ℕ}
    (Rinv : Fin n → Fin n → ℝ) (dInv : Fin n → ℝ) :
    ch7TwoSidedScale dInv (ch7CholeskyInverseGram Rinv) dInv =
      matMul n (ch7RectLeftScale dInv Rinv)
        (matTranspose (ch7RectLeftScale dInv Rinv)) := by
  ext i j
  unfold ch7CholeskyInverseGram ch7TwoSidedScale matMul matTranspose ch7RectLeftScale
  rw [Finset.mul_sum, Finset.sum_mul]
  apply Finset.sum_congr rfl
  intro k _
  ring

/-- Corollary 7.6 condition-number bridge for the explicit Cholesky inverse-side
candidate: the symmetric scaled operator-2 condition product is the square of
the Cholesky-factor right-scaled condition product. -/
theorem corollary7_6_cholesky_scaled_cond_eq_factor_cond_sq {n : ℕ}
    (A R Rinv : Fin n → Fin n → ℝ)
    (d dInv : Fin n → ℝ)
    (hGram : ∀ i j : Fin n, (∑ k : Fin n, R k i * R k j) = A i j) :
    ch7SymmetricOp2ScaledCond A (ch7CholeskyInverseGram Rinv) d dInv =
      ch7Op2RightScaledCond R Rinv d dInv ^ 2 := by
  have hscaled := corollary7_6_cholesky_scaled_gram_eq A R d hGram
  have hinvScaled := corollary7_6_cholesky_scaled_inverse_gram_eq Rinv dInv
  simp only [ch7SymmetricOp2ScaledCond, ch7Op2RightScaledCond]
  rw [hscaled, hinvScaled]
  rw [complexMatrixOp2_realRectToCMatrix_transpose_mul_self_eq_sq,
    complexMatrixOp2_realRectToCMatrix_mul_transpose_self_eq_sq]
  ring

/-- Corollary 7.6 Cholesky-factor squared infimum bridge.  The source scale
`D* = diag(a_jj^(-1/2))` gives a symmetric scaled condition product bounded by
`n` times the square of the best explicit right-scaled Cholesky-factor
condition product.  The remaining source step for full `(7.23)` is to identify
this squared factor infimum with the global two-sided SPD scaling infimum. -/
theorem corollary7_6_cholesky_scaled_cond_le_card_sInf_right_scalings_sq
    {n : ℕ} (hn : 0 < n)
    (A R Rinv : Fin n → Fin n → ℝ)
    (hGram : ∀ i j : Fin n, (∑ k : Fin n, R k i * R k j) = A i j)
    (hGramDiag : ∀ j : Fin n, (∑ k : Fin n, R k j * R k j) = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    ch7SymmetricOp2ScaledCond A (ch7CholeskyInverseGram Rinv)
        (ch7SymmetricDiagEquilibratingScale2 A)
        (ch7SymmetricDiagEquilibratingInvScale2 A) ≤
      (n : ℝ) * (sInf (ch7Op2RightScaledCondSet R Rinv)) ^ 2 := by
  let d : Fin n → ℝ := ch7SymmetricDiagEquilibratingScale2 A
  let dInv : Fin n → ℝ := ch7SymmetricDiagEquilibratingInvScale2 A
  let c : ℝ := ch7Op2RightScaledCond R Rinv d dInv
  let S : Set ℝ := ch7Op2RightScaledCondSet R Rinv
  have hfactor : c ≤ Real.sqrt (n : ℝ) * sInf S := by
    dsimp [c, d, dInv, S]
    exact corollary7_6_cholesky_factor_column_scaling_le_sqrt_card_sInf_right_scalings
      hn A R Rinv hGramDiag hdiag
  have hc_nonneg : 0 ≤ c := by
    dsimp [c]
    exact ch7Op2RightScaledCond_nonneg R Rinv d dInv
  have hsInf_nonneg : 0 ≤ sInf S := by
    simpa [S] using ch7Op2RightScaledCondSet_sInf_nonneg R Rinv
  have hrhs_nonneg : 0 ≤ Real.sqrt (n : ℝ) * sInf S :=
    mul_nonneg (Real.sqrt_nonneg _) hsInf_nonneg
  have hsq :
      c ^ 2 ≤ (Real.sqrt (n : ℝ) * sInf S) ^ 2 :=
    (sq_le_sq₀ hc_nonneg hrhs_nonneg).mpr hfactor
  have hcond :
      ch7SymmetricOp2ScaledCond A (ch7CholeskyInverseGram Rinv) d dInv =
        c ^ 2 := by
    dsimp [c]
    exact corollary7_6_cholesky_scaled_cond_eq_factor_cond_sq
      A R Rinv d dInv hGram
  have hsqrt_sq :
      (Real.sqrt (n : ℝ) * sInf S) ^ 2 =
        (n : ℝ) * (sInf S) ^ 2 := by
    rw [mul_pow, Real.sq_sqrt (Nat.cast_nonneg n)]
  rw [hcond]
  rw [hsqrt_sq] at hsq
  simpa [S] using hsq

/-- Corollary 7.6 infimum-transfer dependency: for a Cholesky representation
`A = RᵀR`, the square of the best explicit right-scaled Cholesky-factor
condition product is a lower bound for the infimum over two-sided SPD scalings
of `DAD`. -/
theorem corollary7_6_cholesky_right_sInf_sq_le_symmetric_sInf {n : ℕ}
    (A R Rinv : Fin n → Fin n → ℝ)
    (hGram : ∀ i j : Fin n, (∑ k : Fin n, R k i * R k j) = A i j) :
    (sInf (ch7Op2RightScaledCondSet R Rinv)) ^ 2 ≤
      sInf (ch7SymmetricOp2ScaledCondSet A (ch7CholeskyInverseGram Rinv)) := by
  let S : Set ℝ := ch7Op2RightScaledCondSet R Rinv
  let T : Set ℝ := ch7SymmetricOp2ScaledCondSet A (ch7CholeskyInverseGram Rinv)
  have hT_nonempty : T.Nonempty := by
    simpa [T] using ch7SymmetricOp2ScaledCondSet_nonempty
      A (ch7CholeskyInverseGram Rinv)
  have hS_bdd : BddBelow S := by
    simpa [S] using ch7Op2RightScaledCondSet_bddBelow R Rinv
  have hsInf_nonneg : 0 ≤ sInf S := by
    simpa [S] using ch7Op2RightScaledCondSet_sInf_nonneg R Rinv
  have hlower : ∀ κ : ℝ, κ ∈ T → (sInf S) ^ 2 ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    let c : ℝ := ch7Op2RightScaledCond R Rinv d dInv
    have hc_mem : c ∈ S := by
      dsimp [c, S]
      exact ch7Op2RightScaledCond_mem_set R Rinv d dInv hdiag
    have hsInf_le_c : sInf S ≤ c := csInf_le hS_bdd hc_mem
    have hc_nonneg : 0 ≤ c := by
      dsimp [c]
      exact ch7Op2RightScaledCond_nonneg R Rinv d dInv
    have hsq : (sInf S) ^ 2 ≤ c ^ 2 :=
      (sq_le_sq₀ hsInf_nonneg hc_nonneg).mpr hsInf_le_c
    have hcond :
        ch7SymmetricOp2ScaledCond A (ch7CholeskyInverseGram Rinv) d dInv =
          c ^ 2 := by
      dsimp [c]
      exact corollary7_6_cholesky_scaled_cond_eq_factor_cond_sq
        A R Rinv d dInv hGram
    simpa [hcond]
  exact le_csInf hT_nonempty hlower

/-- Higham, 2nd ed., Chapter 7, Corollary 7.6 / equation `(7.23)`, in the
repository's explicit inverse-Gram and `sInf` model: the source diagonal scaling
`D* = diag(a_jj^(-1/2))` gives a two-sided SPD operator-2 condition product at
most `n` times the infimum over reciprocal diagonal two-sided scalings of
`DAD`. -/
theorem corollary7_6_cholesky_scaled_cond_le_card_sInf_symmetric_scalings
    {n : ℕ} (hn : 0 < n)
    (A R Rinv : Fin n → Fin n → ℝ)
    (hGram : ∀ i j : Fin n, (∑ k : Fin n, R k i * R k j) = A i j)
    (hGramDiag : ∀ j : Fin n, (∑ k : Fin n, R k j * R k j) = A j j)
    (hdiag : ∀ j : Fin n, 0 < A j j) :
    ch7SymmetricOp2ScaledCond A (ch7CholeskyInverseGram Rinv)
        (ch7SymmetricDiagEquilibratingScale2 A)
        (ch7SymmetricDiagEquilibratingInvScale2 A) ≤
      (n : ℝ) *
        sInf (ch7SymmetricOp2ScaledCondSet A (ch7CholeskyInverseGram Rinv)) := by
  let S : Set ℝ := ch7Op2RightScaledCondSet R Rinv
  let T : Set ℝ := ch7SymmetricOp2ScaledCondSet A (ch7CholeskyInverseGram Rinv)
  have hfactor :
      ch7SymmetricOp2ScaledCond A (ch7CholeskyInverseGram Rinv)
          (ch7SymmetricDiagEquilibratingScale2 A)
          (ch7SymmetricDiagEquilibratingInvScale2 A) ≤
        (n : ℝ) * (sInf S) ^ 2 := by
    simpa [S] using
      corollary7_6_cholesky_scaled_cond_le_card_sInf_right_scalings_sq
        hn A R Rinv hGram hGramDiag hdiag
  have htransfer : (sInf S) ^ 2 ≤ sInf T := by
    simpa [S, T] using
      corollary7_6_cholesky_right_sInf_sq_le_symmetric_sInf A R Rinv hGram
  have hmul : (n : ℝ) * (sInf S) ^ 2 ≤ (n : ℝ) * sInf T :=
    mul_le_mul_of_nonneg_left htransfer (Nat.cast_nonneg n)
  exact hfactor.trans hmul

/-- If `Rinv` is a two-sided inverse of `R`, then
`Rinv Rinvᵀ` is a two-sided inverse of the Cholesky Gram matrix `RᵀR`. -/
theorem corollary7_6_cholesky_inverse_gram_isInverse {n : ℕ}
    (R Rinv : Fin n → Fin n → ℝ)
    (hInv : IsInverse n R Rinv) :
    IsInverse n (matMul n (matTranspose R) R) (ch7CholeskyInverseGram Rinv) := by
  have hRinvR : matMul n Rinv R = idMatrix n :=
    ch7_matMul_of_IsLeftInverse n R Rinv hInv.1
  have hRRinv : matMul n R Rinv = idMatrix n :=
    ch7_matMul_of_IsRightInverse n R Rinv hInv.2
  have hRinvTRT : matMul n (matTranspose Rinv) (matTranspose R) = idMatrix n := by
    rw [← matTranspose_matMul R Rinv, hRRinv, matTranspose_id]
  have hRTRinvT : matMul n (matTranspose R) (matTranspose Rinv) = idMatrix n := by
    rw [← matTranspose_matMul Rinv R, hRinvR, matTranspose_id]
  constructor
  · have hleft :
        matMul n (ch7CholeskyInverseGram Rinv) (matMul n (matTranspose R) R) =
          idMatrix n := by
      unfold ch7CholeskyInverseGram
      calc
        matMul n (matMul n Rinv (matTranspose Rinv)) (matMul n (matTranspose R) R)
            = matMul n Rinv
                (matMul n (matTranspose Rinv) (matMul n (matTranspose R) R)) := by
              rw [matMul_assoc]
        _ = matMul n Rinv
                (matMul n (matMul n (matTranspose Rinv) (matTranspose R)) R) := by
              rw [← matMul_assoc n (matTranspose Rinv) (matTranspose R) R]
        _ = matMul n Rinv (matMul n (idMatrix n) R) := by
              rw [hRinvTRT]
        _ = matMul n Rinv R := by
              rw [matMul_id_left]
        _ = idMatrix n := hRinvR
    intro i j
    exact congrFun (congrFun hleft i) j
  · have hright :
        matMul n (matMul n (matTranspose R) R) (ch7CholeskyInverseGram Rinv) =
          idMatrix n := by
      unfold ch7CholeskyInverseGram
      calc
        matMul n (matMul n (matTranspose R) R) (matMul n Rinv (matTranspose Rinv))
            = matMul n (matTranspose R)
                (matMul n R (matMul n Rinv (matTranspose Rinv))) := by
              rw [matMul_assoc]
        _ = matMul n (matTranspose R)
                (matMul n (matMul n R Rinv) (matTranspose Rinv)) := by
              rw [← matMul_assoc n R Rinv (matTranspose Rinv)]
        _ = matMul n (matTranspose R) (matMul n (idMatrix n) (matTranspose Rinv)) := by
              rw [hRRinv]
        _ = matMul n (matTranspose R) (matTranspose Rinv) := by
              rw [matMul_id_left]
        _ = idMatrix n := hRTRinvT
    intro i j
    exact congrFun (congrFun hright i) j

/-- The infinity-norm product in Problem 7.10(a), with inverse diagonal
entries supplied separately. -/
noncomputable def ch7TwoSidedScaledInfCond {n : ℕ}
    (B C : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) : ℝ :=
  infNorm (ch7TwoSidedScale d₁ B d₂) *
    infNorm (ch7TwoSidedScale d₂Inv C d₁Inv)

/-- Problem 7.10(a)'s infinity-norm Bauer product values over positive
reciprocal two-sided diagonal scalings.  This is the repository `sInf` model of
the source minimization over `D₁,D₂ ∈ D_n`. -/
noncomputable def ch7TwoSidedScaledInfCondSet {n : ℕ}
    (B C : Fin n → Fin n → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ,
    (∀ i : Fin n, 0 < d₁ i) ∧
    (∀ i : Fin n, 0 < d₁Inv i) ∧
    (∀ i : Fin n, 0 < d₂ i) ∧
    (∀ i : Fin n, 0 < d₂Inv i) ∧
    (∀ i : Fin n, d₁ i * d₁Inv i = 1) ∧
    (∀ i : Fin n, d₂ i * d₂Inv i = 1) ∧
    κ = ch7TwoSidedScaledInfCond B C d₁ d₁Inv d₂ d₂Inv}

/-- Membership helper for Problem 7.10(a)'s positive two-sided
infinity-norm Bauer value set. -/
theorem ch7TwoSidedScaledInfCond_mem_set {n : ℕ}
    (B C : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ch7TwoSidedScaledInfCond B C d₁ d₁Inv d₂ d₂Inv ∈
      ch7TwoSidedScaledInfCondSet B C := by
  refine ⟨d₁, d₁Inv, d₂, d₂Inv,
    hd₁pos, hd₁Invpos, hd₂pos, hd₂Invpos, hd₁, hd₂, ?_⟩
  rfl

/-- The Bauer infinity-norm product value set is nonempty by the identity
scaling. -/
theorem ch7TwoSidedScaledInfCondSet_nonempty {n : ℕ}
    (B C : Fin n → Fin n → ℝ) :
    (ch7TwoSidedScaledInfCondSet B C).Nonempty := by
  refine ⟨infNorm B * infNorm C, ?_⟩
  refine ⟨fun _ => 1, fun _ => 1, fun _ => 1, fun _ => 1,
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num), ?_⟩
  have hB :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) B
        (fun _ : Fin n => (1 : ℝ)) = B := by
    ext i j
    simp [ch7TwoSidedScale]
  have hC :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) C
        (fun _ : Fin n => (1 : ℝ)) = C := by
    ext i j
    simp [ch7TwoSidedScale]
  simp [ch7TwoSidedScaledInfCond, hB, hC]

/-- Problem 7.10(a)'s Bauer infinity-norm value set is bounded below by zero. -/
theorem ch7TwoSidedScaledInfCondSet_bddBelow {n : ℕ}
    (B C : Fin n → Fin n → ℝ) :
    BddBelow (ch7TwoSidedScaledInfCondSet B C) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with
    ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
      _hd₂pos, _hd₂Invpos, _hd₁, _hd₂, rfl⟩
  exact mul_nonneg (infNorm_nonneg _) (infNorm_nonneg _)

/-- The infimum of Problem 7.10(a)'s Bauer infinity-norm value set is
nonnegative. -/
theorem ch7TwoSidedScaledInfCondSet_sInf_nonneg {n : ℕ}
    (B C : Fin n → Fin n → ℝ) :
    0 ≤ sInf (ch7TwoSidedScaledInfCondSet B C) := by
  let S : Set ℝ := ch7TwoSidedScaledInfCondSet B C
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledInfCondSet_nonempty B C
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
        _hd₂pos, _hd₂Invpos, _hd₁, _hd₂, rfl⟩
    exact mul_nonneg (infNorm_nonneg _) (infNorm_nonneg _)
  exact le_csInf hS_nonempty hlower

lemma ch7_infNormVec_const_mul_of_nonneg {n : ℕ} {a : ℝ}
    (ha : 0 ≤ a) (x : Fin n → ℝ) :
    infNormVec (fun i : Fin n => a * x i) = a * infNormVec x := by
  unfold infNormVec
  have hfun : (fun i : Fin n => a * x i) = a • x := by
    ext i
    simp [Pi.smul_apply, smul_eq_mul]
  rw [hfun, norm_smul, Real.norm_eq_abs, abs_of_nonneg ha]

lemma ch7_infNormVec_pos_of_pos {n : ℕ} (hn : 0 < n)
    (x : Fin n → ℝ) (hx : ∀ i : Fin n, 0 < x i) :
    0 < infNormVec x := by
  let i0 : Fin n := ⟨0, hn⟩
  have hle := abs_le_infNormVec x i0
  exact lt_of_lt_of_le (abs_pos.mpr (ne_of_gt (hx i0))) hle

lemma ch7_infNormVec_mono_of_nonneg_le {n : ℕ}
    {u v : Fin n → ℝ}
    (hu : ∀ i : Fin n, 0 ≤ u i)
    (hv : ∀ i : Fin n, 0 ≤ v i)
    (huv : ∀ i : Fin n, u i ≤ v i) :
    infNormVec u ≤ infNormVec v := by
  apply infNormVec_le_of_abs_le
  · intro i
    rw [abs_of_nonneg (hu i)]
    exact le_trans (huv i)
      (by simpa [abs_of_nonneg (hv i)] using abs_le_infNormVec v i)
  · exact infNormVec_nonneg v

theorem ch7_infNorm_ge_of_positive_right_subeigenvector {n : ℕ} (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n, ρ * x i ≤ matMulVec n A x i) :
    ρ ≤ infNorm A := by
  have hxnorm_pos : 0 < infNormVec x := ch7_infNormVec_pos_of_pos hn x hx
  have hleft_nonneg : ∀ i : Fin n, 0 ≤ ρ * x i :=
    fun i => mul_nonneg hρ (le_of_lt (hx i))
  have hAx_nonneg : ∀ i : Fin n, 0 ≤ matMulVec n A x i :=
    fun i => le_trans (hleft_nonneg i) (hsub i)
  have hnorm_lower :
      infNormVec (fun i : Fin n => ρ * x i) ≤
        infNormVec (matMulVec n A x) :=
    ch7_infNormVec_mono_of_nonneg_le hleft_nonneg hAx_nonneg hsub
  have hnorm_upper := infNormVec_matMulVec_le hn A x
  rw [ch7_infNormVec_const_mul_of_nonneg hρ x] at hnorm_lower
  nlinarith [hxnorm_pos, hnorm_lower, hnorm_upper]

lemma ch7_perronScalar_nonneg_of_nonneg_eigenvector {n : ℕ} (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n A x i = ρ * x i) :
    0 ≤ ρ := by
  let i0 : Fin n := ⟨0, hn⟩
  have hAx_nonneg : 0 ≤ matMulVec n A x i0 := by
    unfold matMulVec
    exact Finset.sum_nonneg fun j _ => mul_nonneg (hA i0 j) (le_of_lt (hx j))
  have hprod : 0 ≤ ρ * x i0 := by
    simpa [heig i0] using hAx_nonneg
  nlinarith [hx i0, hprod]

lemma ch7_exists_pos_entry_of_nonzero_nonneg {n : ℕ} (x : Fin n → ℝ)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0) :
    ∃ i : Fin n, 0 < x i := by
  by_contra hnone
  apply hx_ne
  ext i
  have hi_le : x i ≤ 0 := le_of_not_gt (fun hi => hnone ⟨i, hi⟩)
  exact le_antisymm hi_le (hx_nonneg i)

lemma ch7_perronScalar_nonneg_of_nonzero_nonneg_eigenvector {n : ℕ}
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (heig : ∀ i : Fin n, matMulVec n A x i = ρ * x i) :
    0 ≤ ρ := by
  obtain ⟨i0, hxi0⟩ :=
    ch7_exists_pos_entry_of_nonzero_nonneg x hx_nonneg hx_ne
  have hAx_nonneg : 0 ≤ matMulVec n A x i0 := by
    unfold matMulVec
    exact Finset.sum_nonneg fun j _ => mul_nonneg (hA i0 j) (hx_nonneg j)
  have hprod : 0 ≤ ρ * x i0 := by
    simpa [heig i0] using hAx_nonneg
  nlinarith [hxi0, hprod]

/-- A positive right eigenvector for a nonnegative matrix with at least one
positive entry has a positive eigenvalue.  This is the strict-positivity
version needed by Bauer's irreducible `Cx` transfer; it is not a
Perron-Frobenius existence theorem. -/
lemma ch7_perronScalar_pos_of_nonneg_eigenvector_entry_pos {n : ℕ}
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n A x i = ρ * x i)
    (hentry : ∃ i j : Fin n, 0 < A i j) :
    0 < ρ := by
  obtain ⟨i, j, hij⟩ := hentry
  have hterms_nonneg :
      ∀ k : Fin n, 0 ≤ A i k * x k := by
    intro k
    exact mul_nonneg (hA i k) (le_of_lt (hx k))
  have hterm_pos : 0 < A i j * x j := mul_pos hij (hx j)
  have hAx_pos : 0 < matMulVec n A x i := by
    unfold matMulVec
    exact Finset.sum_pos' (fun k _ => hterms_nonneg k)
      ⟨j, Finset.mem_univ j, hterm_pos⟩
  have hprod : 0 < ρ * x i := by
    simpa [heig i] using hAx_pos
  nlinarith [hx i, hprod]

/-- If a nonnegative matrix has a positive right eigenvector with eigenvalue
`ρ`, then `ρ` is bounded by the infinity norm.  This is the finite-dimensional
norm half used in Bauer's scaling proof; it does not assert Perron-Frobenius
existence. -/
theorem ch7_infNorm_ge_of_nonneg_right_eigenvector {n : ℕ} (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n A x i = ρ * x i) :
    ρ ≤ infNorm A := by
  have hρ : 0 ≤ ρ :=
    ch7_perronScalar_nonneg_of_nonneg_eigenvector hn A ρ x hA hx heig
  have hxnorm_pos : 0 < infNormVec x := ch7_infNormVec_pos_of_pos hn x hx
  have hAx :
      matMulVec n A x = fun i : Fin n => ρ * x i := by
    ext i
    exact heig i
  have hnorm := infNormVec_matMulVec_le hn A x
  rw [hAx, ch7_infNormVec_const_mul_of_nonneg hρ x] at hnorm
  nlinarith [hxnorm_pos, hnorm]

/-- Local finite-dimensional eigenvalue-radius predicate for the Chapter 7
Bauer/Perron row.  It records that `ρ` is attained by a complexified
eigenvector and bounds the modulus of every complex eigenvalue certificate.
This is not Mathlib's Banach-algebra `spectralRadius`; it is the finite
eigenvalue-radius bridge needed before that API identification. -/
def ch7IsComplexEigenvalueRadius {n : ℕ}
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) : Prop :=
  0 ≤ ρ ∧
    (∃ z : CVec n, z ≠ 0 ∧
      ∀ i : Fin n, complexMatrixVecMul (realRectToCMatrix A) z i = (ρ : ℂ) * z i) ∧
    ∀ (mu : ℂ) (z : CVec n), z ≠ 0 →
      (∀ i : Fin n, complexMatrixVecMul (realRectToCMatrix A) z i = mu * z i) →
        ‖mu‖ ≤ ρ

/-- The finite set-like value surface for the local Chapter 7 spectral-radius
bridge: all moduli of complex eigenvalue certificates of the complexification
of a real matrix.  This is a local finite-dimensional model of spectral
radius, not Mathlib's Banach-algebra `spectralRadius`. -/
def ch7ComplexEigenvalueModulusSet {n : ℕ}
    (A : Fin n → Fin n → ℝ) : Set ℝ :=
  {r : ℝ | ∃ mu : ℂ, ∃ z : CVec n,
    z ≠ 0 ∧
      (∀ i : Fin n, complexMatrixVecMul (realRectToCMatrix A) z i = mu * z i) ∧
      r = ‖mu‖}

/-- The local radius predicate says exactly that `ρ` is a greatest element of
the finite complex-eigenvalue-modulus value set. -/
theorem ch7_complexEigenvalueModulusSet_isGreatest_of_isComplexEigenvalueRadius
    {n : ℕ} {A : Fin n → Fin n → ℝ} {ρ : ℝ}
    (hρ : ch7IsComplexEigenvalueRadius A ρ) :
    IsGreatest (ch7ComplexEigenvalueModulusSet A) ρ := by
  rcases hρ with ⟨hρ_nonneg, ⟨z, hz_ne, hz_eig⟩, hbound⟩
  constructor
  · refine ⟨(ρ : ℂ), z, hz_ne, ?_, ?_⟩
    · simpa using hz_eig
    · exact (Complex.norm_of_nonneg hρ_nonneg).symm
  · intro r hr
    rcases hr with ⟨mu, z, hz_ne, hz_eig, rfl⟩
    exact hbound mu z hz_ne hz_eig

/-- Local finite-dimensional spectral-radius equality in `sSup` form:
`ρ` is the supremum of the complex eigenvalue moduli whenever
`ch7IsComplexEigenvalueRadius A ρ` holds.  This is the source-shaped bridge
toward Higham's `ρ(A)`; the `toLin_spectralRadius` lemmas below identify the
same maximum with Mathlib's Banach-algebra `spectralRadius`. -/
theorem ch7_complexEigenvalueModulusSet_sSup_eq_of_isComplexEigenvalueRadius
    {n : ℕ} {A : Fin n → Fin n → ℝ} {ρ : ℝ}
    (hρ : ch7IsComplexEigenvalueRadius A ρ) :
    sSup (ch7ComplexEigenvalueModulusSet A) = ρ := by
  have hgreatest :=
    ch7_complexEigenvalueModulusSet_isGreatest_of_isComplexEigenvalueRadius
      (A := A) (ρ := ρ) hρ
  exact le_antisymm
    (csSup_le ⟨ρ, hgreatest.1⟩ hgreatest.2)
    (le_csSup ⟨ρ, hgreatest.2⟩ hgreatest.1)

/-- Chapter 7's local real-matrix eigenvalue-modulus carrier is exactly the
generic Split 1 complex-matrix carrier after real complexification. -/
theorem ch7_complexEigenvalueModulusSet_eq_complexMatrixEigenvalueModulusSet
    {n : ℕ} (A : Fin n → Fin n → ℝ) :
    ch7ComplexEigenvalueModulusSet A =
      ComplexMatrixEigenvalueModulusSet (realRectToCMatrix A) := by
  ext r
  constructor
  · intro hr
    rcases hr with ⟨mu, z, hz_ne, hz_eig, rfl⟩
    refine ⟨mu, z, hz_ne, ?_, rfl⟩
    ext i
    simpa [complexVecSMul] using hz_eig i
  · intro hr
    rcases hr with ⟨mu, z, hz_ne, hz_eig, rfl⟩
    refine ⟨mu, z, hz_ne, ?_, rfl⟩
    intro i
    exact congrFun hz_eig i

/-- Chapter 7's local real-matrix eigenvalue-modulus carrier is also exactly
the moduli of Mathlib spectrum elements of the complexified `toLin'` matrix. -/
theorem ch7_complexEigenvalueModulusSet_eq_toLin_spectrum_modulusSet
    {n : ℕ} (A : Fin n → Fin n → ℝ) :
    ch7ComplexEigenvalueModulusSet A =
      {r : ℝ | ∃ lam : ℂ,
        lam ∈ spectrum ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)) ∧
        r = ‖lam‖} := by
  rw [ch7_complexEigenvalueModulusSet_eq_complexMatrixEigenvalueModulusSet A,
    complexMatrixEigenvalueModulusSet_eq_toLin_spectrum_modulusSet]

/-- A Chapter 7 local finite spectral-radius certificate exports to the generic
Split 1 maximum-eigenvalue-modulus interface for the complexified matrix. -/
theorem ch7_isMaxComplexMatrixEigenvalueModulus_of_isComplexEigenvalueRadius
    {n : ℕ} {A : Fin n → Fin n → ℝ} {ρ : ℝ}
    (hρ : ch7IsComplexEigenvalueRadius A ρ) :
    IsMaxComplexMatrixEigenvalueModulus (realRectToCMatrix A) ρ := by
  have hgreatest :=
    ch7_complexEigenvalueModulusSet_isGreatest_of_isComplexEigenvalueRadius
      (A := A) (ρ := ρ) hρ
  constructor
  · simpa [ch7_complexEigenvalueModulusSet_eq_complexMatrixEigenvalueModulusSet A]
      using hgreatest.1
  · intro r hr
    exact hgreatest.2
      (by
        simpa [ch7_complexEigenvalueModulusSet_eq_complexMatrixEigenvalueModulusSet A]
          using hr)

/-- A Chapter 7 local finite spectral-radius certificate also gives a greatest
element of the Mathlib-spectrum-modulus set for the complexified `toLin'`
matrix. -/
theorem ch7_toLin_spectrum_modulusSet_isGreatest_of_isComplexEigenvalueRadius
    {n : ℕ} {A : Fin n → Fin n → ℝ} {ρ : ℝ}
    (hρ : ch7IsComplexEigenvalueRadius A ρ) :
    IsGreatest
      {r : ℝ | ∃ lam : ℂ,
        lam ∈ spectrum ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)) ∧
        r = ‖lam‖} ρ := by
  have hgreatest :=
    ch7_complexEigenvalueModulusSet_isGreatest_of_isComplexEigenvalueRadius
      (A := A) (ρ := ρ) hρ
  simpa [ch7_complexEigenvalueModulusSet_eq_toLin_spectrum_modulusSet A]
    using hgreatest

/-- Chapter 7 local finite spectral-radius equality in Mathlib-spectrum
modulus `sSup` form. -/
theorem ch7_toLin_spectrum_modulusSet_sSup_eq_of_isComplexEigenvalueRadius
    {n : ℕ} {A : Fin n → Fin n → ℝ} {ρ : ℝ}
    (hρ : ch7IsComplexEigenvalueRadius A ρ) :
    sSup
      {r : ℝ | ∃ lam : ℂ,
        lam ∈ spectrum ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)) ∧
        r = ‖lam‖} = ρ := by
  have hgreatest :=
    ch7_toLin_spectrum_modulusSet_isGreatest_of_isComplexEigenvalueRadius
      (A := A) (ρ := ρ) hρ
  exact le_antisymm
    (csSup_le ⟨ρ, hgreatest.1⟩ hgreatest.2)
    (le_csSup ⟨ρ, hgreatest.2⟩ hgreatest.1)

/-- Chapter 7 local finite spectral-radius equality in Mathlib's
Banach-algebra `spectralRadius` representation. -/
theorem ch7_toLin_spectralRadius_eq_of_isComplexEigenvalueRadius
    {n : ℕ} {A : Fin n → Fin n → ℝ} {ρ : ℝ}
    (hρ : ch7IsComplexEigenvalueRadius A ρ) :
    spectralRadius ℂ
      (Matrix.toLin'
        (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)) =
      ENNReal.ofReal ρ := by
  exact toLin_spectralRadius_eq_of_spectrum_modulusSet_isGreatest
    (realRectToCMatrix A)
    (ch7_toLin_spectrum_modulusSet_isGreatest_of_isComplexEigenvalueRadius hρ)

/-- Real-valued form of
`ch7_toLin_spectralRadius_eq_of_isComplexEigenvalueRadius`. -/
theorem ch7_toLin_spectralRadius_toReal_eq_of_isComplexEigenvalueRadius
    {n : ℕ} {A : Fin n → Fin n → ℝ} {ρ : ℝ}
    (hρ : ch7IsComplexEigenvalueRadius A ρ) :
    (spectralRadius ℂ
      (Matrix.toLin'
        (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A))).toReal =
      ρ := by
  exact toLin_spectralRadius_toReal_eq_of_spectrum_modulusSet_isGreatest
    (realRectToCMatrix A)
    (ch7_toLin_spectrum_modulusSet_isGreatest_of_isComplexEigenvalueRadius hρ)

/-- Problem 7.10(e) spectral-radius infrastructure: finite complex matrices
have the same `toLin'` spectrum after transposition.  This proves the source
fact `ρ(A) = ρ(Aᵀ)` at the spectrum level; it does not supply a Perron vector. -/
theorem ch7_toLin_spectrum_transpose_iff {n : ℕ}
    (A : Matrix (Fin n) (Fin n) ℂ) (lam : ℂ) :
    lam ∈ spectrum ℂ (Matrix.toLin' A.transpose) ↔
      lam ∈ spectrum ℂ (Matrix.toLin' A) := by
  rw [← Module.End.hasEigenvalue_iff_mem_spectrum,
    ← Module.End.hasEigenvalue_iff_mem_spectrum]
  rw [Module.End.hasEigenvalue_iff_isRoot_charpoly,
    Module.End.hasEigenvalue_iff_isRoot_charpoly]
  rw [Matrix.charpoly_toLin', Matrix.charpoly_toLin', Matrix.charpoly_transpose]

/-- Problem 7.10(e) spectral-radius infrastructure: finite complex square
products have the same `toLin'` spectrum after commuting the two factors.  This
is the source fact `ρ(AB) = ρ(BA)` at the spectrum level. -/
theorem ch7_toLin_spectrum_mul_comm_iff {n : ℕ}
    (A B : Matrix (Fin n) (Fin n) ℂ) (lam : ℂ) :
    lam ∈ spectrum ℂ (Matrix.toLin' (A * B)) ↔
      lam ∈ spectrum ℂ (Matrix.toLin' (B * A)) := by
  rw [← Module.End.hasEigenvalue_iff_mem_spectrum,
    ← Module.End.hasEigenvalue_iff_mem_spectrum]
  rw [Module.End.hasEigenvalue_iff_isRoot_charpoly,
    Module.End.hasEigenvalue_iff_isRoot_charpoly]
  rw [Matrix.charpoly_toLin', Matrix.charpoly_toLin', Matrix.charpoly_mul_comm]

/-- Problem 7.10(e) source fact `ρ(Aᵀ) = ρ(A)` for the Mathlib
Banach-algebra spectral radius of a finite complex matrix endomorphism. -/
theorem ch7_toLin_spectralRadius_transpose_eq {n : ℕ}
    (A : Matrix (Fin n) (Fin n) ℂ) :
    spectralRadius ℂ (Matrix.toLin' A.transpose) =
      spectralRadius ℂ (Matrix.toLin' A) := by
  unfold spectralRadius
  apply le_antisymm
  · apply iSup₂_le
    intro lam hlam
    exact le_iSup₂ (α := ENNReal) lam
      ((ch7_toLin_spectrum_transpose_iff A lam).mp hlam)
  · apply iSup₂_le
    intro lam hlam
    exact le_iSup₂ (α := ENNReal) lam
      ((ch7_toLin_spectrum_transpose_iff A lam).mpr hlam)

/-- Problem 7.10(e) source fact `ρ(AB) = ρ(BA)` for the Mathlib
Banach-algebra spectral radius of finite complex matrix endomorphisms. -/
theorem ch7_toLin_spectralRadius_mul_comm_eq {n : ℕ}
    (A B : Matrix (Fin n) (Fin n) ℂ) :
    spectralRadius ℂ (Matrix.toLin' (A * B)) =
      spectralRadius ℂ (Matrix.toLin' (B * A)) := by
  unfold spectralRadius
  apply le_antisymm
  · apply iSup₂_le
    intro lam hlam
    exact le_iSup₂ (α := ENNReal) lam
      ((ch7_toLin_spectrum_mul_comm_iff A B lam).mp hlam)
  · apply iSup₂_le
    intro lam hlam
    exact le_iSup₂ (α := ENNReal) lam
      ((ch7_toLin_spectrum_mul_comm_iff A B lam).mpr hlam)

/-- Problem 7.10(e), repository real-matrix transpose form of
`ρ(Aᵀ) = ρ(A)` after complexification. -/
theorem ch7_toLin_spectralRadius_realRectToCMatrix_matTranspose_eq {n : ℕ}
    (A : Fin n → Fin n → ℝ) :
    spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from
            realRectToCMatrix (matTranspose A))) =
      spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)) := by
  let M : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)
  have hT :
      (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix (matTranspose A)) =
        M.transpose := by
    ext i j
    simp [M, realRectToCMatrix, matTranspose]
  rw [hT]
  exact ch7_toLin_spectralRadius_transpose_eq M

/-- Finite complex matrix endomorphisms have a nonzero complex eigenpair whose
eigenvalue attains Mathlib's algebraic `spectralRadius`.  This closes the
finite-dimensional complex spectral-radius existence half of the Chapter 7
Bauer/Perron bridge; it does not supply a nonnegative real Perron vector. -/
theorem ch7_toLin_exists_spectralRadius_attaining_eigenpair {n : ℕ}
    (hn : 0 < n) (A : Matrix (Fin n) (Fin n) ℂ) :
    ∃ lam : ℂ, ∃ z : Fin n → ℂ,
      z ≠ 0 ∧ Matrix.toLin' A z = lam • z ∧
      (nnnorm lam : ENNReal) = spectralRadius ℂ (Matrix.toLin' A) := by
  classical
  haveI : Nonempty (Fin n) := ⟨⟨0, hn⟩⟩
  have hs_nonempty : (spectrum ℂ (Matrix.toLin' A)).Nonempty := by
    exact spectrum.nonempty_of_isAlgClosed_of_finiteDimensional ℂ (Matrix.toLin' A)
  have hs_finite : (spectrum ℂ (Matrix.toLin' A)).Finite := by
    exact Module.End.finite_spectrum (Matrix.toLin' A)
  have hmem := hs_nonempty.ciSup_mem_image
    (s := spectrum ℂ (Matrix.toLin' A))
    (f := fun lam : ℂ => (nnnorm lam : ENNReal)) hs_finite
  rcases hmem with ⟨lam, hlam, hEq⟩
  have heig : Module.End.HasEigenvalue (Matrix.toLin' A) lam :=
    Module.End.HasEigenvalue.of_mem_spectrum hlam
  rcases Module.End.HasEigenvalue.exists_hasEigenvector heig with ⟨z, hz⟩
  refine ⟨lam, z, (Module.End.hasEigenvector_iff.mp hz).2, ?_, ?_⟩
  · exact Module.End.HasEigenvector.apply_eq_smul hz
  · simpa [spectralRadius] using hEq

/-- Taking componentwise moduli of a complex eigenvector of a nonnegative real
matrix gives a nonzero nonnegative real subeigenvector.  This is the
source-facing Collatz-Wielandt/Perron-Frobenius bridge used by the Chapter 7
Bauer row: it proves the elementary inequality step, while the remaining PF
gate is the upgrade from subeigenvector to a positive real Perron eigenvector
under irreducibility. -/
lemma ch7_abs_complex_eigenvector_subeigenvector_of_nonneg_matrix {n : ℕ}
    (A : Fin n → Fin n → ℝ) (mu : ℂ) (z : CVec n)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hz_ne : z ≠ 0)
    (heig : ∀ i : Fin n,
      complexMatrixVecMul (realRectToCMatrix A) z i = mu * z i) :
    let x : Fin n → ℝ := fun i : Fin n => ‖z i‖
    x ≠ 0 ∧ (∀ i : Fin n, 0 ≤ x i) ∧
      ∀ i : Fin n, ‖mu‖ * x i ≤ matMulVec n A x i := by
  classical
  let x : Fin n → ℝ := fun i : Fin n => ‖z i‖
  have hx_ne : x ≠ 0 := by
    intro hx_zero
    apply hz_ne
    ext i
    have hi := congrFun hx_zero i
    dsimp [x] at hi
    exact norm_eq_zero.mp hi
  refine ⟨hx_ne, ?_, ?_⟩
  · intro i
    exact norm_nonneg (z i)
  · intro i
    have htri :
        ‖mu * z i‖ ≤ ∑ j : Fin n, ‖(A i j : ℂ) * z j‖ := by
      calc
        ‖mu * z i‖ = ‖complexMatrixVecMul (realRectToCMatrix A) z i‖ := by
          rw [heig i]
        _ ≤ ∑ j : Fin n, ‖(A i j : ℂ) * z j‖ := by
          unfold complexMatrixVecMul realRectToCMatrix
          simpa using
            norm_sum_le Finset.univ (fun j : Fin n => (A i j : ℂ) * z j)
    have hterms_eq :
        (∑ j : Fin n, ‖(A i j : ℂ) * z j‖) =
          ∑ j : Fin n, A i j * x j := by
      apply Finset.sum_congr rfl
      intro j _
      rw [norm_mul]
      have hAnorm : ‖(A i j : ℂ)‖ = A i j := by
        rw [Complex.norm_of_nonneg (hA i j)]
      rw [hAnorm]
    calc
      ‖mu‖ * x i = ‖mu * z i‖ := by
        rw [norm_mul]
      _ ≤ ∑ j : Fin n, ‖(A i j : ℂ) * z j‖ := htri
      _ = ∑ j : Fin n, A i j * x j := hterms_eq
      _ = matMulVec n A x i := by rfl

/-- A nonnegative real matrix has a complex spectral-radius-attaining
eigenpair whose componentwise modulus vector is a nonzero nonnegative
subeigenvector.  This packages finite-dimensional spectral-radius attainment
with the elementary absolute-value inequality needed before the final
Perron-Frobenius positivity upgrade. -/
theorem ch7_exists_spectralRadius_attaining_nonneg_subeigenvector {n : ℕ}
    (hn : 0 < n) (A : Fin n → Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j) :
    ∃ mu : ℂ, ∃ z : CVec n, ∃ x : Fin n → ℝ,
      z ≠ 0 ∧ x ≠ 0 ∧ (∀ i : Fin n, 0 ≤ x i) ∧
      (∀ i : Fin n,
        complexMatrixVecMul (realRectToCMatrix A) z i = mu * z i) ∧
      (nnnorm mu : ENNReal) =
        spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)) ∧
      (∀ i : Fin n, ‖mu‖ * x i ≤ matMulVec n A x i) := by
  let M : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix A)
  obtain ⟨mu, z, hz_ne, hz_lin, hrad⟩ :=
    ch7_toLin_exists_spectralRadius_attaining_eigenpair hn M
  have heig : ∀ i : Fin n,
      complexMatrixVecMul (realRectToCMatrix A) z i = mu * z i := by
    intro i
    have hi := congrFun hz_lin i
    simpa [M, complexMatrixVecMul, Matrix.toLin'_apply, Matrix.mulVec,
      dotProduct, Pi.smul_apply, smul_eq_mul] using hi
  let x : Fin n → ℝ := fun i : Fin n => ‖z i‖
  have hsub :=
    ch7_abs_complex_eigenvector_subeigenvector_of_nonneg_matrix
      A mu z hA hz_ne heig
  rcases hsub with ⟨hx_ne, hx_nonneg, hsubeig⟩
  refine ⟨mu, z, x, hz_ne, hx_ne, hx_nonneg, heig, ?_, hsubeig⟩
  simpa [M] using hrad

/-- If Chapter 7's local eigenvalue-radius certificate is available, the
integrated Split 1 Problem 6.8 norm-existence theorem applies to the
complexified real matrix. -/
theorem ch7_exists_mixedSubordinateMatrixNormValue_le_of_isComplexEigenvalueRadius
    {n : ℕ} (hn : 0 < n) (A : Fin n → Fin n → ℝ)
    {ρ δ : ℝ} (hρ : ch7IsComplexEigenvalueRadius A ρ) (hδ : 0 < δ) :
    ∃ (ν : CVec n → ℝ) (c : ℝ),
      IsComplexVectorNorm ν ∧
        IsMixedSubordinateMatrixNormValue ν ν (realRectToCMatrix A) c ∧
        c ≤ ρ + δ := by
  exact exists_mixedSubordinateMatrixNormValue_le_of_maxComplexMatrixEigenvalueModulus
    hn (realRectToCMatrix A)
    (ch7_isMaxComplexMatrixEigenvalueModulus_of_isComplexEigenvalueRadius hρ)
    hδ

/-- A positive real eigenvector for a nonnegative real matrix bounds every
complex eigenvalue certificate by the same real scalar.  This is the elementary
finite-dimensional spectral-radius half of the Bauer/Perron-Frobenius bridge:
choose an index maximizing `‖zᵢ‖ / xᵢ` and compare `|Az|` with `Ax`. -/
theorem ch7_complex_eigenvalue_norm_le_of_positive_real_eigenvector {n : ℕ}
    (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ) (mu : ℂ) (z : CVec n)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig_real : ∀ i : Fin n, matMulVec n A x i = ρ * x i)
    (hz_ne : z ≠ 0)
    (heig_complex : ∀ i : Fin n,
      complexMatrixVecMul (realRectToCMatrix A) z i = mu * z i) :
    ‖mu‖ ≤ ρ := by
  classical
  let ratios : Fin n → ℝ := fun i => ‖z i‖ / x i
  let R : ℝ := Finset.univ.sup'
    (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩) ratios
  obtain ⟨imax, _himem, hR_eq⟩ :=
    Finset.exists_mem_eq_sup' (s := (Finset.univ : Finset (Fin n)))
      (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩) ratios
  have hratio_le : ∀ j : Fin n, ratios j ≤ R := by
    intro j
    exact Finset.le_sup' (s := (Finset.univ : Finset (Fin n))) (f := ratios)
      (Finset.mem_univ j)
  have hz_bound : ∀ j : Fin n, ‖z j‖ ≤ R * x j := by
    intro j
    have h := hratio_le j
    dsimp [ratios] at h
    exact (div_le_iff₀ (hx j)).mp h
  have hz_exists : ∃ i : Fin n, z i ≠ 0 := by
    by_contra hnone
    apply hz_ne
    ext i
    by_contra hzi
    exact hnone ⟨i, hzi⟩
  have hR_pos : 0 < R := by
    obtain ⟨i, hzi⟩ := hz_exists
    have hpos_ratio : 0 < ratios i := div_pos (norm_pos_iff.mpr hzi) (hx i)
    exact lt_of_lt_of_le hpos_ratio (hratio_le i)
  have hleft : ‖mu‖ * ‖z imax‖ ≤ R * (ρ * x imax) := by
    have htri :
        ‖mu * z imax‖ ≤ ∑ j : Fin n, ‖(A imax j : ℂ) * z j‖ := by
      calc
        ‖mu * z imax‖ =
            ‖complexMatrixVecMul (realRectToCMatrix A) z imax‖ := by
          rw [heig_complex imax]
        _ ≤ ∑ j : Fin n, ‖(A imax j : ℂ) * z j‖ := by
          unfold complexMatrixVecMul realRectToCMatrix
          simpa using
            norm_sum_le Finset.univ (fun j : Fin n => (A imax j : ℂ) * z j)
    have hterms_eq :
        (∑ j : Fin n, ‖(A imax j : ℂ) * z j‖) =
          ∑ j : Fin n, A imax j * ‖z j‖ := by
      apply Finset.sum_congr rfl
      intro j _
      rw [norm_mul]
      have hAnorm : ‖(A imax j : ℂ)‖ = A imax j := by
        rw [Complex.norm_of_nonneg (hA imax j)]
      rw [hAnorm]
    have hsum_bound :
        (∑ j : Fin n, A imax j * ‖z j‖) ≤
          ∑ j : Fin n, A imax j * (R * x j) := by
      exact Finset.sum_le_sum fun j _ =>
        mul_le_mul_of_nonneg_left (hz_bound j) (hA imax j)
    have hsum_eq :
        (∑ j : Fin n, A imax j * (R * x j)) =
          R * (ρ * x imax) := by
      calc
        (∑ j : Fin n, A imax j * (R * x j)) =
            R * (∑ j : Fin n, A imax j * x j) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring
        _ = R * matMulVec n A x imax := by rfl
        _ = R * (ρ * x imax) := by rw [heig_real imax]
    calc
      ‖mu‖ * ‖z imax‖ = ‖mu * z imax‖ := by rw [norm_mul]
      _ ≤ ∑ j : Fin n, ‖(A imax j : ℂ) * z j‖ := htri
      _ = ∑ j : Fin n, A imax j * ‖z j‖ := hterms_eq
      _ ≤ ∑ j : Fin n, A imax j * (R * x j) := hsum_bound
      _ = R * (ρ * x imax) := hsum_eq
  have hright_eq : R * (ρ * x imax) = ρ * (R * x imax) := by ring
  have hleft_eq : ‖z imax‖ = R * x imax := by
    have hratio_eq : ratios imax = R := hR_eq.symm
    dsimp [ratios] at hratio_eq
    exact (div_eq_iff (ne_of_gt (hx imax))).mp hratio_eq
  have hcancel : ‖mu‖ * (R * x imax) ≤ ρ * (R * x imax) := by
    simpa [hleft_eq, hright_eq] using hleft
  have hden_pos : 0 < R * x imax := mul_pos hR_pos (hx imax)
  nlinarith [hden_pos, hcancel]

lemma ch7_real_positive_eigenvector_complexified {n : ℕ}
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (heig_real : ∀ i : Fin n, matMulVec n A x i = ρ * x i) :
    ∀ i : Fin n,
      complexMatrixVecMul (realRectToCMatrix A) (fun j : Fin n => (x j : ℂ)) i =
        (ρ : ℂ) * (x i : ℂ) := by
  intro i
  have h := congrArg (fun r : ℝ => (r : ℂ)) (heig_real i)
  simpa [complexMatrixVecMul, realRectToCMatrix, matMulVec, Complex.ofReal_sum,
    Complex.ofReal_mul] using h

/-- A positive real eigenvector for a nonnegative real matrix makes `ρ` the
attained finite complex-eigenvalue radius in the local Chapter 7 sense.  Full
Perron-Frobenius existence of such a vector remains a separate source-facing
target. -/
theorem ch7_isComplexEigenvalueRadius_of_positive_real_eigenvector {n : ℕ}
    (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig_real : ∀ i : Fin n, matMulVec n A x i = ρ * x i) :
    ch7IsComplexEigenvalueRadius A ρ := by
  refine ⟨?_, ?_, ?_⟩
  · exact ch7_perronScalar_nonneg_of_nonneg_eigenvector
      hn A ρ x hA hx heig_real
  · let z : CVec n := fun j : Fin n => (x j : ℂ)
    refine ⟨z, ?_, ?_⟩
    · intro hz
      have h0 := congrFun hz ⟨0, hn⟩
      have hx0_ne : (x ⟨0, hn⟩ : ℂ) ≠ 0 := by
        exact_mod_cast ne_of_gt (hx ⟨0, hn⟩)
      exact hx0_ne h0
    · simpa [z] using
        ch7_real_positive_eigenvector_complexified A ρ x heig_real
  · intro mu z hz_ne heig_complex
    exact ch7_complex_eigenvalue_norm_le_of_positive_real_eigenvector
      hn A ρ x mu z hA hx heig_real hz_ne heig_complex

/-- Problem 7.10(a), spectral-dominance bridge for `BC`: once a positive
right eigenvector of the nonnegative product `BC` is supplied, its scalar is
the attained finite complex-eigenvalue radius for `BC`. -/
theorem problem7_10a_product_isComplexEigenvalueRadius_of_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
