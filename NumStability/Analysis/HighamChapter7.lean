/-- Row scaling by a positive diagonal vector, source notation `D A`. -/
def ch7RowScale (n : ℕ) (d : Fin n → ℝ)
    (A : Fin n → Fin n → ℝ) : Fin n → Fin n → ℝ :=
  fun i j => d i * A i j

/-- The corresponding inverse scaling, source notation `A⁻¹ D⁻¹`. -/
def ch7InverseRowScale (n : ℕ) (dInv : Fin n → ℝ)
    (A_inv : Fin n → Fin n → ℝ) : Fin n → Fin n → ℝ :=
  fun i j => A_inv i j * dInv j

/-- Row equilibration in the infinity-norm sense: `|A|e = e`. -/
def ch7RowsEquilibratedInf (n : ℕ) (A : Fin n → Fin n → ℝ) : Prop :=
  ∀ i : Fin n, ∑ j : Fin n, |A i j| = 1

/-- Left-inverse certificate transported through a diagonal row scaling. -/
theorem ch7RowScale_left_inverse (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1) :
    IsLeftInverse n (ch7RowScale n d A)
      (ch7InverseRowScale n dInv A_inv) := by
  intro i j
  unfold IsLeftInverse ch7RowScale ch7InverseRowScale at *
  calc
    ∑ k : Fin n, (A_inv i k * dInv k) * (d k * A k j)
        = ∑ k : Fin n, A_inv i k * A k j := by
          apply Finset.sum_congr rfl
          intro k _
          calc
            A_inv i k * dInv k * (d k * A k j)
                = A_inv i k * (dInv k * d k) * A k j := by ring
            _ = A_inv i k * A k j := by
                  rw [hdInv k]
                  ring
    _ = (if i = j then 1 else 0) := hInv i j

/-- Right-inverse certificate transported through a diagonal row scaling. -/
theorem ch7RowScale_right_inverse (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hInv : IsRightInverse n A A_inv)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1) :
    IsRightInverse n (ch7RowScale n d A)
      (ch7InverseRowScale n dInv A_inv) := by
  intro i j
  unfold IsRightInverse ch7RowScale ch7InverseRowScale at *
  calc
    ∑ k : Fin n, (d i * A i k) * (A_inv k j * dInv j)
        = d i * dInv j * (∑ k : Fin n, A i k * A_inv k j) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro k _
          ring
    _ = (if i = j then 1 else 0) := by
      by_cases hij : i = j
      · subst j
        have hii := hInv i i
        simp at hii
        rw [hii]
        have hprod : d i * dInv i = 1 := by
          rw [mul_comm, hdInv i]
        rw [hprod]
        simp
      · rw [hInv i j]
        simp [hij]

/-- Full inverse certificate transported through a diagonal row scaling. -/
theorem ch7RowScale_inverse (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hInv : IsInverse n A A_inv)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1) :
    IsInverse n (ch7RowScale n d A)
      (ch7InverseRowScale n dInv A_inv) :=
  ⟨ch7RowScale_left_inverse n A A_inv d dInv hInv.1 hdInv,
    ch7RowScale_right_inverse n A A_inv d dInv hInv.2 hdInv⟩

/-- The source prose before `(7.15)`: Skeel's `cond(A)` is invariant under
positive diagonal row scaling. -/
theorem ch7_condSkeel_rowScale_eq (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hd : ∀ i : Fin n, 0 < d i)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1) :
    condSkeel n hn (ch7RowScale n d A)
      (ch7InverseRowScale n dInv A_inv) =
    condSkeel n hn A A_inv := by
  have hdInv_pos : ∀ i : Fin n, 0 < dInv i := by
    intro i
    have hprod_pos : 0 < dInv i * d i := by
      rw [hdInv i]
      norm_num
    by_contra hnot
    have hle : dInv i ≤ 0 := le_of_not_gt hnot
    have hnonpos : dInv i * d i ≤ 0 :=
      mul_nonpos_of_nonpos_of_nonneg hle (le_of_lt (hd i))
    linarith
  unfold condSkeel ch7RowScale ch7InverseRowScale
  exact Finset.sup'_congr (s := Finset.univ) (t := Finset.univ)
    (H := Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩) rfl (by
      intro i _
      apply Finset.sum_congr rfl
      intro j _
      have hrow :
          (∑ k : Fin n, |d j * A j k|) =
            d j * ∑ k : Fin n, |A j k| := by
        calc
          ∑ k : Fin n, |d j * A j k|
              = ∑ k : Fin n, d j * |A j k| := by
                apply Finset.sum_congr rfl
                intro k _
                rw [abs_mul, abs_of_pos (hd j)]
          _ = d j * ∑ k : Fin n, |A j k| := by rw [Finset.mul_sum]
      calc
        |A_inv i j * dInv j| * (∑ k : Fin n, |d j * A j k|)
            = (|A_inv i j| * dInv j) *
              (d j * ∑ k : Fin n, |A j k|) := by
              rw [abs_mul, abs_of_pos (hdInv_pos j), hrow]
        _ = |A_inv i j| * ((dInv j * d j) *
              ∑ k : Fin n, |A j k|) := by
              ring
        _ = |A_inv i j| * ∑ k : Fin n, |A j k| := by
              rw [hdInv j]
              ring)

/-- Appendix A.3 row-equilibration identity:
if `B` has rows of unit 1-norm, then `cond(B) = κ∞(B)`. -/
theorem ch7_condSkeel_eq_kappaInf_of_rowsEquilibratedInf
    (n : ℕ) (hn : 0 < n) (B B_inv : Fin n → Fin n → ℝ)
    (hrow : ch7RowsEquilibratedInf n B) :
    condSkeel n hn B B_inv = kappaInf n hn B B_inv := by
  let hne : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  have hrow' : ∀ i : Fin n, ∑ j : Fin n, |B i j| = 1 := by
    simpa [ch7RowsEquilibratedInf] using hrow
  have hBsup :
      Finset.sup' Finset.univ hne (fun i : Fin n => ∑ j : Fin n, |B i j|) = 1 := by
    apply le_antisymm
    · apply Finset.sup'_le
      intro i _
      exact le_of_eq (hrow' i)
    · have i0 : Fin n := ⟨0, hn⟩
      calc
        1 = ∑ j : Fin n, |B i0 j| := (hrow' i0).symm
        _ ≤ Finset.sup' Finset.univ hne
            (fun i : Fin n => ∑ j : Fin n, |B i j|) :=
            Finset.le_sup'
              (fun i : Fin n => ∑ j : Fin n, |B i j|)
              (Finset.mem_univ i0)
  unfold condSkeel kappaInf
  have hcond :
      Finset.sup' Finset.univ hne
          (fun i : Fin n => ∑ j : Fin n, |B_inv i j| * ∑ k : Fin n, |B j k|) =
        Finset.sup' Finset.univ hne
          (fun i : Fin n => ∑ j : Fin n, |B_inv i j|) := by
    exact Finset.sup'_congr (s := Finset.univ) (t := Finset.univ) (H := hne) rfl (by
      intro i _
      apply Finset.sum_congr rfl
      intro j _
      rw [hrow' j]
      ring)
  rw [hcond, hBsup]
  ring

/-- Appendix A.3 / row-equilibrated part of equations `(7.15)`-`(7.16)`:
after positive diagonal row equilibration, the scaled standard infinity-norm
condition number equals the original Skeel condition number. -/
theorem problem7_3_rowEquilibrated_scaling_condition_eq
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hd : ∀ i : Fin n, 0 < d i)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1)
    (hrow : ch7RowsEquilibratedInf n (ch7RowScale n d A)) :
    kappaInf n hn (ch7RowScale n d A)
      (ch7InverseRowScale n dInv A_inv) =
    condSkeel n hn A A_inv := by
  calc
    kappaInf n hn (ch7RowScale n d A)
        (ch7InverseRowScale n dInv A_inv)
        = condSkeel n hn (ch7RowScale n d A)
          (ch7InverseRowScale n dInv A_inv) :=
          (ch7_condSkeel_eq_kappaInf_of_rowsEquilibratedInf n hn
            (ch7RowScale n d A) (ch7InverseRowScale n dInv A_inv) hrow).symm
    _ = condSkeel n hn A A_inv :=
          ch7_condSkeel_rowScale_eq n hn A A_inv d dInv hd hdInv

/-- Submultiplicativity of Higham's `κ∞` under compatible multiplication. -/
theorem ch7_kappaInf_matMul_le (n : ℕ) (hn : 0 < n)
    (L L_inv A A_inv : Fin n → Fin n → ℝ) :
    kappaInf n hn (matMul n L A) (matMul n A_inv L_inv) ≤
      kappaInf n hn L L_inv * kappaInf n hn A A_inv := by
  rw [kappaInf_eq_infNorm_mul_infNorm n hn (matMul n L A) (matMul n A_inv L_inv),
    kappaInf_eq_infNorm_mul_infNorm n hn L L_inv,
    kappaInf_eq_infNorm_mul_infNorm n hn A A_inv]
  have hleft : infNorm (matMul n L A) ≤ infNorm L * infNorm A :=
    infNorm_matMul_le hn L A
  have hright : infNorm (matMul n A_inv L_inv) ≤ infNorm A_inv * infNorm L_inv :=
    infNorm_matMul_le hn A_inv L_inv
  calc
    infNorm (matMul n L A) * infNorm (matMul n A_inv L_inv)
        ≤ (infNorm L * infNorm A) * (infNorm A_inv * infNorm L_inv) :=
        mul_le_mul hleft hright
          (infNorm_nonneg (matMul n A_inv L_inv))
          (mul_nonneg (infNorm_nonneg L) (infNorm_nonneg A))
    _ = (infNorm L * infNorm L_inv) * (infNorm A * infNorm A_inv) := by
        ring

/-- Row-scaling form of `κ∞` submultiplicativity. -/
theorem ch7_kappaInf_rowScale_le_diagKappa_mul_kappaInf
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ) :
    kappaInf n hn (ch7RowScale n d A) (ch7InverseRowScale n dInv A_inv) ≤
      kappaInf n hn (diagMatrix d) (diagMatrix dInv) *
        kappaInf n hn A A_inv := by
  have hrow : ch7RowScale n d A = matMul n (diagMatrix d) A := by
    funext i j
    simpa [ch7RowScale] using (matMul_diagMatrix_left d A i j).symm
  have hinv : ch7InverseRowScale n dInv A_inv = matMul n A_inv (diagMatrix dInv) := by
    funext i j
    simpa [ch7InverseRowScale] using (matMul_diagMatrix_right A_inv dInv i j).symm
  rw [hrow, hinv]
  exact ch7_kappaInf_matMul_le n hn (diagMatrix d) (diagMatrix dInv) A A_inv

/-- The diagonal condition number is unchanged by swapping a diagonal scaling
with its inverse on the two `κ∞` arguments. -/
theorem ch7_kappaInf_diag_comm (n : ℕ) (hn : 0 < n)
    (d dInv : Fin n → ℝ) :
    kappaInf n hn (diagMatrix dInv) (diagMatrix d) =
      kappaInf n hn (diagMatrix d) (diagMatrix dInv) := by
  rw [kappaInf_eq_infNorm_mul_infNorm n hn (diagMatrix dInv) (diagMatrix d),
    kappaInf_eq_infNorm_mul_infNorm n hn (diagMatrix d) (diagMatrix dInv)]
  ring

/-- Positive diagonal factors give a positive diagonal `κ∞`. -/
lemma ch7_kappaInf_diag_pos (n : ℕ) (hn : 0 < n)
    (d dInv : Fin n → ℝ)
    (hd : ∀ i : Fin n, 0 < d i)
    (hdInv_pos : ∀ i : Fin n, 0 < dInv i) :
    0 < kappaInf n hn (diagMatrix d) (diagMatrix dInv) := by
  let hne : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  let i0 : Fin n := ⟨0, hn⟩
  have hdiag_pos :
      0 < Finset.sup' Finset.univ hne
        (fun i : Fin n => ∑ j : Fin n, |diagMatrix d i j|) := by
    have hsingle : |diagMatrix d i0 i0| ≤
        ∑ j : Fin n, |diagMatrix d i0 j| :=
      Finset.single_le_sum
        (s := Finset.univ) (f := fun j : Fin n => |diagMatrix d i0 j|)
        (fun j _ => abs_nonneg _) (Finset.mem_univ i0)
    have hdiag : |diagMatrix d i0 i0| = d i0 := by
      simp [diagMatrix, abs_of_pos (hd i0)]
    have hrow_pos : 0 < ∑ j : Fin n, |diagMatrix d i0 j| :=
      lt_of_lt_of_le (by simpa [hdiag] using hd i0) hsingle
    exact lt_of_lt_of_le hrow_pos
      (Finset.le_sup'
        (fun i : Fin n => ∑ j : Fin n, |diagMatrix d i j|)
        (Finset.mem_univ i0))
  have hdiagInv_pos :
      0 < Finset.sup' Finset.univ hne
        (fun i : Fin n => ∑ j : Fin n, |diagMatrix dInv i j|) := by
    have hsingle : |diagMatrix dInv i0 i0| ≤
        ∑ j : Fin n, |diagMatrix dInv i0 j| :=
      Finset.single_le_sum
        (s := Finset.univ) (f := fun j : Fin n => |diagMatrix dInv i0 j|)
        (fun j _ => abs_nonneg _) (Finset.mem_univ i0)
    have hdiag : |diagMatrix dInv i0 i0| = dInv i0 := by
      simp [diagMatrix, abs_of_pos (hdInv_pos i0)]
    have hrow_pos : 0 < ∑ j : Fin n, |diagMatrix dInv i0 j| :=
      lt_of_lt_of_le (by simpa [hdiag] using hdInv_pos i0) hsingle
    exact lt_of_lt_of_le hrow_pos
      (Finset.le_sup'
        (fun i : Fin n => ∑ j : Fin n, |diagMatrix dInv i j|)
        (Finset.mem_univ i0))
  unfold kappaInf
  exact mul_pos hdiag_pos hdiagInv_pos

/-- Appendix A.3 consequence: row equilibration gives the multiplicative
lower-bound form `κ∞(A) ≤ κ∞(D_R) cond(A)`. -/
theorem problem7_3_rowEquilibrated_kappaInf_le_diagKappa_mul_condSkeel
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hd : ∀ i : Fin n, 0 < d i)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1)
    (hrow : ch7RowsEquilibratedInf n (ch7RowScale n d A)) :
    kappaInf n hn A A_inv ≤
      kappaInf n hn (diagMatrix d) (diagMatrix dInv) *
        condSkeel n hn A A_inv := by
  let B := ch7RowScale n d A
  let B_inv := ch7InverseRowScale n dInv A_inv
  have hA_eq : A = ch7RowScale n dInv B := by
    funext i j
    dsimp [B, ch7RowScale]
    calc
      A i j = (dInv i * d i) * A i j := by
        rw [hdInv i]
        ring
      _ = dInv i * (d i * A i j) := by
        ring
  have hAinv_eq : A_inv = ch7InverseRowScale n d B_inv := by
    funext i j
    dsimp [B_inv, ch7InverseRowScale]
    calc
      A_inv i j = A_inv i j * (dInv j * d j) := by
        rw [hdInv j]
        ring
      _ = A_inv i j * dInv j * d j := by
        ring
  have hBcond :
      kappaInf n hn B B_inv = condSkeel n hn A A_inv := by
    simpa [B, B_inv] using
      problem7_3_rowEquilibrated_scaling_condition_eq n hn A A_inv d dInv hd hdInv hrow
  calc
    kappaInf n hn A A_inv
        = kappaInf n hn (ch7RowScale n dInv B) (ch7InverseRowScale n d B_inv) := by
          rw [hA_eq, hAinv_eq]
    _ ≤ kappaInf n hn (diagMatrix dInv) (diagMatrix d) * kappaInf n hn B B_inv :=
          ch7_kappaInf_rowScale_le_diagKappa_mul_kappaInf n hn B B_inv dInv d
    _ = kappaInf n hn (diagMatrix d) (diagMatrix dInv) *
        condSkeel n hn A A_inv := by
          rw [ch7_kappaInf_diag_comm n hn d dInv, hBcond]

/-- Equation `(7.16)`, left inequality, for a row-equilibrating positive
diagonal scaling. -/
theorem problem7_3_rowEquilibrated_lower_bound
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hd : ∀ i : Fin n, 0 < d i)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1)
    (hrow : ch7RowsEquilibratedInf n (ch7RowScale n d A)) :
    kappaInf n hn A A_inv / kappaInf n hn (diagMatrix d) (diagMatrix dInv) ≤
      condSkeel n hn A A_inv := by
  have hdInv_pos : ∀ i : Fin n, 0 < dInv i := by
    intro i
    have hprod_pos : 0 < dInv i * d i := by
      rw [hdInv i]
      norm_num
    by_contra hnot
    have hle : dInv i ≤ 0 := le_of_not_gt hnot
    have hnonpos : dInv i * d i ≤ 0 :=
      mul_nonpos_of_nonpos_of_nonneg hle (le_of_lt (hd i))
    linarith
  have hdiag_pos : 0 < kappaInf n hn (diagMatrix d) (diagMatrix dInv) :=
    ch7_kappaInf_diag_pos n hn d dInv hd hdInv_pos
  have hmul :=
    problem7_3_rowEquilibrated_kappaInf_le_diagKappa_mul_condSkeel
      n hn A A_inv d dInv hd hdInv hrow
  rw [div_le_iff₀ hdiag_pos]
  simpa [mul_comm] using hmul

/-- Equation `(7.16)` for a row-equilibrating positive diagonal scaling:
`κ∞(A)/κ∞(D_R) ≤ cond(A) ≤ κ∞(A)`. -/
theorem eq_7_16_rowEquilibrated_bounds
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hd : ∀ i : Fin n, 0 < d i)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1)
    (hrow : ch7RowsEquilibratedInf n (ch7RowScale n d A)) :
    kappaInf n hn A A_inv / kappaInf n hn (diagMatrix d) (diagMatrix dInv) ≤
        condSkeel n hn A A_inv ∧
      condSkeel n hn A A_inv ≤ kappaInf n hn A A_inv :=
  ⟨problem7_3_rowEquilibrated_lower_bound n hn A A_inv d dInv hd hdInv hrow,
    condSkeel_le_kappaInf n hn A A_inv⟩

-- ============================================================
-- Equation (7.17): Kahan's symbolic 3 × 3 example
-- ============================================================

/-- The matrix `A` in Kahan's parameterized example (7.17). -/
noncomputable def ch7KahanMatrix (ε : ℝ) (i j : Fin 3) : ℝ :=
  if i = 0 then
    if j = 0 then 2 else if j = 1 then -1 else 1
  else if i = 1 then
    if j = 0 then -1 else ε
  else
    if j = 0 then 1 else ε

/-- The right-hand side `b` in Kahan's parameterized example (7.17). -/
noncomputable def ch7KahanRhs (ε : ℝ) (i : Fin 3) : ℝ :=
  if i = 0 then 2 * (1 + ε) else if i = 1 then -ε else ε

/-- The exact solution `x = [ε, -1, 1]ᵀ` following (7.17). -/
noncomputable def ch7KahanSolution (ε : ℝ) (i : Fin 3) : ℝ :=
  if i = 0 then ε else if i = 1 then -1 else 1

/-- The inverse of `ch7KahanMatrix ε` for `ε ≠ 0`. -/
noncomputable def ch7KahanInverse (ε : ℝ) (i j : Fin 3) : ℝ :=
  if i = 0 then
    if j = 0 then 0 else if j = 1 then -(1 / 2 : ℝ) else (1 / 2 : ℝ)
  else if i = 1 then
    if j = 0 then -(1 / 2 : ℝ)
    else if j = 1 then (1 - 2 * ε) / (4 * ε)
    else (2 * ε + 1) / (4 * ε)
  else
    if j = 0 then (1 / 2 : ℝ)
    else if j = 1 then (2 * ε + 1) / (4 * ε)
    else (1 - 2 * ε) / (4 * ε)

/-- The displayed matrix `|A⁻¹||A|` following Kahan's example (7.17). -/
noncomputable def ch7KahanAbsInverseMulAbsMatrix (ε : ℝ)
    (i j : Fin 3) : ℝ :=
  if i = 0 then
    if j = 0 then 1 else ε
  else
    if j = 0 then (2 * ε + 1) / (2 * ε) else 1

private theorem ch7_kahan_solution (ε : ℝ) :
    matMulVec 3 (ch7KahanMatrix ε) (ch7KahanSolution ε) = ch7KahanRhs ε := by
  ext i
  fin_cases i <;>
    simp [matMulVec, ch7KahanMatrix, ch7KahanSolution, ch7KahanRhs,
      Fin.sum_univ_three] <;> ring

private theorem ch7_kahan_inverse (ε : ℝ) (hε : 0 < ε) :
    IsInverse 3 (ch7KahanMatrix ε) (ch7KahanInverse ε) := by
  have hε0 : ε ≠ 0 := ne_of_gt hε
  constructor <;> intro i j <;> fin_cases i <;> fin_cases j <;>
    simp [ch7KahanMatrix, ch7KahanInverse, Fin.sum_univ_three] <;>
    field_simp <;> ring

private theorem ch7_kahan_abs_inverse_mul_abs_matrix
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    matMul 3 (absMatrix 3 (ch7KahanInverse ε))
        (absMatrix 3 (ch7KahanMatrix ε)) =
      ch7KahanAbsInverseMulAbsMatrix ε := by
  have hε0 : 0 ≤ ε := le_of_lt hε
  have h1 : 0 ≤ 1 - 2 * ε := by linarith
  have h2 : 0 ≤ 2 * ε + 1 := by positivity
  ext i j
  fin_cases i <;> fin_cases j <;>
    simp [matMul, absMatrix, ch7KahanMatrix, ch7KahanInverse,
      ch7KahanAbsInverseMulAbsMatrix, Fin.sum_univ_three,
      abs_of_nonneg hε0, abs_of_nonneg h1, abs_of_nonneg h2,
      abs_div, abs_mul] <;>
    field_simp <;> ring

private theorem ch7_kahan_matrix_infNorm
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    infNorm (ch7KahanMatrix ε) = 4 := by
  have hε0 : 0 ≤ ε := le_of_lt hε
  apply le_antisymm
  · apply infNorm_le_of_row_sum_le
    · intro i
      fin_cases i <;>
        simp [ch7KahanMatrix, Fin.sum_univ_three, abs_of_nonneg hε0] <;>
        linarith
    · norm_num
  · have h := row_sum_le_infNorm (ch7KahanMatrix ε) (0 : Fin 3)
    simp [ch7KahanMatrix, Fin.sum_univ_three,
      show (2 : Fin 3) ≠ 0 by decide,
      show (2 : Fin 3) ≠ 1 by decide] at h
    norm_num at h
    exact h

private theorem ch7_kahan_inverse_infNorm
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    infNorm (ch7KahanInverse ε) = (1 + ε) / (2 * ε) := by
  have h1 : 0 ≤ 1 - 2 * ε := by linarith
  have h2 : 0 ≤ 2 * ε + 1 := by positivity
  have hden : 0 ≤ 4 * ε := by positivity
  apply le_antisymm
  · apply infNorm_le_of_row_sum_le
    · intro i
      fin_cases i <;>
        simp [ch7KahanInverse, Fin.sum_univ_three,
          abs_of_nonneg h1, abs_of_nonneg h2, abs_of_nonneg hden,
          abs_div] <;>
        field_simp <;> nlinarith
    · positivity
  · have h := row_sum_le_infNorm (ch7KahanInverse ε) (1 : Fin 3)
    simp [ch7KahanInverse, Fin.sum_univ_three,
      abs_of_nonneg h1, abs_of_nonneg h2, abs_of_nonneg hden,
      abs_div] at h
    field_simp at h ⊢
    nlinarith

private theorem ch7_kahan_kappaInf
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    kappaInf 3 (by norm_num) (ch7KahanMatrix ε) (ch7KahanInverse ε) =
      2 * (1 + ε⁻¹) := by
  rw [kappaInf_eq_infNorm_mul_infNorm,
    ch7_kahan_matrix_infNorm ε hε hεhalf,
    ch7_kahan_inverse_infNorm ε hε hεhalf]
  field_simp
  ring

private theorem ch7_kahan_condSkeel
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    condSkeel 3 (by norm_num) (ch7KahanMatrix ε) (ch7KahanInverse ε) =
      3 + (2 * ε)⁻¹ := by
  have hε0 : 0 ≤ ε := le_of_lt hε
  have h1 : 0 ≤ 1 - 2 * ε := by linarith
  have h2 : 0 ≤ 2 * ε + 1 := by positivity
  have hden : 0 ≤ 4 * ε := by positivity
  unfold condSkeel
  apply le_antisymm
  · apply Finset.sup'_le
    intro i _hi
    fin_cases i <;>
      simp [ch7KahanMatrix, ch7KahanInverse, Fin.sum_univ_three,
        abs_of_nonneg hε0, abs_of_nonneg h1, abs_of_nonneg h2,
        abs_of_nonneg hden, abs_div] <;>
      field_simp <;> nlinarith
  · have h := Finset.le_sup'
        (fun i : Fin 3 =>
          ∑ j : Fin 3, |ch7KahanInverse ε i j| *
            ∑ k : Fin 3, |ch7KahanMatrix ε j k|)
        (Finset.mem_univ (1 : Fin 3))
    have hrow :
        (∑ j : Fin 3, |ch7KahanInverse ε (1 : Fin 3) j| *
          ∑ k : Fin 3, |ch7KahanMatrix ε j k|) =
            3 + (2 * ε)⁻¹ := by
      simp [ch7KahanMatrix, ch7KahanInverse, Fin.sum_univ_three,
        abs_of_nonneg hε0, abs_of_nonneg h1, abs_of_nonneg h2,
        abs_of_nonneg hden, abs_div]
      field_simp
      ring
    rw [hrow] at h
    exact h

private theorem ch7_kahan_solution_infNorm
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    infNormVec (ch7KahanSolution ε) = 1 := by
  have hε0 : 0 ≤ ε := le_of_lt hε
  apply le_antisymm
  · apply infNormVec_le_of_abs_le
    · intro i
      fin_cases i <;>
        simp [ch7KahanSolution, abs_of_nonneg hε0] <;> linarith
    · norm_num
  · have h := abs_le_infNormVec (ch7KahanSolution ε) (1 : Fin 3)
    simpa [ch7KahanSolution] using h

private theorem ch7_kahan_cond_at_solution
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    ch7SkeelCondAtSolutionInf 3 (by norm_num)
      (ch7KahanMatrix ε) (ch7KahanInverse ε) (ch7KahanSolution ε) =
        5 / 2 + ε := by
  have hε0 : 0 ≤ ε := le_of_lt hε
  have h1 : 0 ≤ 1 - 2 * ε := by linarith
  have h2 : 0 ≤ 2 * ε + 1 := by positivity
  have hden : 0 ≤ 4 * ε := by positivity
  unfold ch7SkeelCondAtSolutionInf ch7CondEFAtSolutionInf
  rw [ch7_kahan_solution_infNorm ε hε hεhalf, div_one]
  unfold ch7ForwardBoundEF
  apply le_antisymm
  · apply Finset.sup'_le
    intro i _hi
    fin_cases i <;>
      simp [ch7AmplifiedRhsEF, ch7KahanMatrix, ch7KahanInverse,
        ch7KahanSolution, Fin.sum_univ_three, abs_of_nonneg hε0,
        abs_of_nonneg h1, abs_of_nonneg h2, abs_of_nonneg hden,
        abs_div] <;>
      field_simp <;> nlinarith
  · have h := Finset.le_sup'
        (ch7AmplifiedRhsEF 3 (ch7KahanInverse ε)
          (fun i j => |ch7KahanMatrix ε i j|) (fun _ => 0)
          (ch7KahanSolution ε))
        (Finset.mem_univ (1 : Fin 3))
    have hrow :
        ch7AmplifiedRhsEF 3 (ch7KahanInverse ε)
          (fun i j => |ch7KahanMatrix ε i j|) (fun _ => 0)
          (ch7KahanSolution ε) (1 : Fin 3) = 5 / 2 + ε := by
      simp [ch7AmplifiedRhsEF, ch7KahanMatrix, ch7KahanInverse,
        ch7KahanSolution, Fin.sum_univ_three, abs_of_nonneg hε0,
        abs_of_nonneg h1, abs_of_nonneg h2, abs_of_nonneg hden,
        abs_div]
      field_simp
      ring
    rw [hrow] at h
    exact h

/-- Equation (7.17), Kahan's exact symbolic example.  The source assumption
`0 < ε ≪ 1` is represented by the explicit sufficient range
`0 < ε ≤ 1/2`.  In this range the displayed matrix and right-hand side have
the stated exact solution; the supplied inverse produces the printed
`|A⁻¹||A|`; and the three condition numbers have the source values
`κ∞(A) = 2(1 + ε⁻¹)`, `cond(A) = 3 + (2ε)⁻¹`, and
`cond(A,x) = 5/2 + ε`.  The final strict chain is the precise content behind
the source's qualitative contrast. -/
theorem eq_7_17_kahan_symbolic_example
    (ε : ℝ) (hε : 0 < ε) (hεhalf : ε ≤ 1 / 2) :
    matMulVec 3 (ch7KahanMatrix ε) (ch7KahanSolution ε) = ch7KahanRhs ε ∧
    IsInverse 3 (ch7KahanMatrix ε) (ch7KahanInverse ε) ∧
    kappaInf 3 (by norm_num) (ch7KahanMatrix ε) (ch7KahanInverse ε) =
      2 * (1 + ε⁻¹) ∧
    matMul 3 (absMatrix 3 (ch7KahanInverse ε))
        (absMatrix 3 (ch7KahanMatrix ε)) =
      ch7KahanAbsInverseMulAbsMatrix ε ∧
    condSkeel 3 (by norm_num) (ch7KahanMatrix ε) (ch7KahanInverse ε) =
      3 + (2 * ε)⁻¹ ∧
    ch7SkeelCondAtSolutionInf 3 (by norm_num)
        (ch7KahanMatrix ε) (ch7KahanInverse ε) (ch7KahanSolution ε) =
      5 / 2 + ε ∧
    ch7SkeelCondAtSolutionInf 3 (by norm_num)
        (ch7KahanMatrix ε) (ch7KahanInverse ε) (ch7KahanSolution ε) <
      condSkeel 3 (by norm_num) (ch7KahanMatrix ε) (ch7KahanInverse ε) ∧
    condSkeel 3 (by norm_num) (ch7KahanMatrix ε) (ch7KahanInverse ε) <
      kappaInf 3 (by norm_num) (ch7KahanMatrix ε) (ch7KahanInverse ε) := by
  have hkappa := ch7_kahan_kappaInf ε hε hεhalf
  have hcond := ch7_kahan_condSkeel ε hε hεhalf
  have hcondx := ch7_kahan_cond_at_solution ε hε hεhalf
  refine ⟨ch7_kahan_solution ε, ch7_kahan_inverse ε hε, hkappa,
    ch7_kahan_abs_inverse_mul_abs_matrix ε hε hεhalf, hcond, hcondx, ?_, ?_⟩
  · rw [hcondx, hcond]
    field_simp
    nlinarith
  · rw [hcond, hkappa]
    field_simp
    nlinarith

/-- The values `κ∞(DA)` over positive diagonal row scalings.  This is the
positive-scaling infimum model for the source minimum in `(7.15)`. -/
noncomputable def ch7PositiveRowScaledKappaInfSet
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin n → ℝ,
    (∀ i : Fin n, 0 < d i) ∧
    (∀ i : Fin n, dInv i * d i = 1) ∧
    κ = kappaInf n hn (ch7RowScale n d A) (ch7InverseRowScale n dInv A_inv)}

/-- Every positive diagonal row scaling has `cond(A) ≤ κ∞(DA)`. -/
theorem ch7_condSkeel_le_kappaInf_rowScale
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hd : ∀ i : Fin n, 0 < d i)
    (hdInv : ∀ i : Fin n, dInv i * d i = 1) :
    condSkeel n hn A A_inv ≤
      kappaInf n hn (ch7RowScale n d A)
        (ch7InverseRowScale n dInv A_inv) := by
  calc
    condSkeel n hn A A_inv =
        condSkeel n hn (ch7RowScale n d A)
          (ch7InverseRowScale n dInv A_inv) :=
        (ch7_condSkeel_rowScale_eq n hn A A_inv d dInv hd hdInv).symm
    _ ≤ kappaInf n hn (ch7RowScale n d A)
        (ch7InverseRowScale n dInv A_inv) :=
        condSkeel_le_kappaInf n hn
          (ch7RowScale n d A) (ch7InverseRowScale n dInv A_inv)

/-- Equation `(7.15)`, positive-row-scaling infimum form: if a positive
row-equilibrating diagonal scaling exists, the infimum of `κ∞(DA)` over
positive row scalings is `cond(A)`. -/
theorem eq_7_15_positive_rowScaling_sInf_eq_condSkeel
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (dR dRInv : Fin n → ℝ)
    (hdR : ∀ i : Fin n, 0 < dR i)
    (hdRInv : ∀ i : Fin n, dRInv i * dR i = 1)
    (hrow : ch7RowsEquilibratedInf n (ch7RowScale n dR A)) :
    sInf (ch7PositiveRowScaledKappaInfSet n hn A A_inv) =
      condSkeel n hn A A_inv := by
  let S : Set ℝ := ch7PositiveRowScaledKappaInfSet n hn A A_inv
  have hmem : condSkeel n hn A A_inv ∈ S := by
    refine ⟨dR, dRInv, hdR, hdRInv, ?_⟩
    exact (problem7_3_rowEquilibrated_scaling_condition_eq
      n hn A A_inv dR dRInv hdR hdRInv hrow).symm
  have hS_nonempty : S.Nonempty := ⟨condSkeel n hn A A_inv, hmem⟩
  have hlower : ∀ κ : ℝ, κ ∈ S → condSkeel n hn A A_inv ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hd, hdInv, rfl⟩
    exact ch7_condSkeel_le_kappaInf_rowScale n hn A A_inv d dInv hd hdInv
  have hbddBelow : BddBelow S := ⟨condSkeel n hn A A_inv, hlower⟩
  change sInf S = condSkeel n hn A A_inv
  exact le_antisymm (csInf_le hbddBelow hmem) (le_csInf hS_nonempty hlower)

/-- Canonical positive row-equilibrating scale `D_R`: reciprocal row
one-norms. -/
noncomputable def ch7RowEquilibratingScale (n : ℕ)
    (A : Fin n → Fin n → ℝ) : Fin n → ℝ :=
  fun i => 1 / ∑ j : Fin n, |A i j|

/-- Inverse diagonal for `ch7RowEquilibratingScale`. -/
noncomputable def ch7RowEquilibratingScaleInv (n : ℕ)
    (A : Fin n → Fin n → ℝ) : Fin n → ℝ :=
  fun i => ∑ j : Fin n, |A i j|

/-- A matrix with a right inverse has no zero row, hence every row one-norm is
positive. -/
lemma ch7_rowAbsSum_pos_of_right_inverse (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ)
    (hRight : IsRightInverse n A A_inv) :
    ∀ i : Fin n, 0 < ∑ j : Fin n, |A i j| := by
  intro i
  have hnonneg : 0 ≤ ∑ j : Fin n, |A i j| :=
    Finset.sum_nonneg fun j _ => abs_nonneg _
  by_contra hnot
  have hsum_zero : ∑ j : Fin n, |A i j| = 0 :=
    le_antisymm (le_of_not_gt hnot) hnonneg
  have hA_zero : ∀ k : Fin n, A i k = 0 := by
    intro k
    have hsingle : |A i k| ≤ ∑ j : Fin n, |A i j| :=
      Finset.single_le_sum
        (s := Finset.univ) (f := fun j : Fin n => |A i j|)
        (fun j _ => abs_nonneg _) (Finset.mem_univ k)
    have habs_zero : |A i k| = 0 := by
      exact le_antisymm (by simpa [hsum_zero] using hsingle) (abs_nonneg _)
    exact abs_eq_zero.mp habs_zero
  have hprod_zero : (∑ k : Fin n, A i k * A_inv k i) = 0 := by
    apply Finset.sum_eq_zero
    intro k _
    rw [hA_zero k]
    ring
  have hdiag := hRight i i
  simp at hdiag
  rw [hprod_zero] at hdiag
  norm_num at hdiag

/-- The canonical row-equilibrating scale is positive for a right-invertible
matrix. -/
lemma ch7RowEquilibratingScale_pos_of_right_inverse (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ)
    (hRight : IsRightInverse n A A_inv) :
    ∀ i : Fin n, 0 < ch7RowEquilibratingScale n A i := by
  intro i
  unfold ch7RowEquilibratingScale
  exact one_div_pos.mpr (ch7_rowAbsSum_pos_of_right_inverse n A A_inv hRight i)

/-- The canonical row-equilibrating inverse diagonal is the inverse of the
canonical positive scale. -/
lemma ch7RowEquilibratingScaleInv_mul_scale (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ)
    (hRight : IsRightInverse n A A_inv) :
    ∀ i : Fin n,
      ch7RowEquilibratingScaleInv n A i *
        ch7RowEquilibratingScale n A i = 1 := by
  intro i
  have hpos := ch7_rowAbsSum_pos_of_right_inverse n A A_inv hRight i
  unfold ch7RowEquilibratingScaleInv ch7RowEquilibratingScale
  field_simp [ne_of_gt hpos]

/-- The canonical reciprocal-row-sum diagonal scaling equilibrates the rows. -/
theorem ch7RowsEquilibratedInf_rowEquilibratingScale_of_right_inverse
    (n : ℕ) (A A_inv : Fin n → Fin n → ℝ)
    (hRight : IsRightInverse n A A_inv) :
    ch7RowsEquilibratedInf n (ch7RowScale n (ch7RowEquilibratingScale n A) A) := by
  intro i
  have hpos := ch7_rowAbsSum_pos_of_right_inverse n A A_inv hRight i
  unfold ch7RowScale ch7RowEquilibratingScale
  calc
    ∑ j : Fin n, |(1 / ∑ k : Fin n, |A i k|) * A i j|
        = ∑ j : Fin n, (1 / ∑ k : Fin n, |A i k|) * |A i j| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_mul, abs_of_pos (one_div_pos.mpr hpos)]
    _ = (1 / ∑ k : Fin n, |A i k|) * ∑ j : Fin n, |A i j| := by
          rw [Finset.mul_sum]
    _ = 1 := by
          field_simp [ne_of_gt hpos]

/-- Equation `(7.15)`, positive-row-scaling infimum form, with the
row-equilibrating diagonal constructed from reciprocal row one-norms. -/
theorem eq_7_15_positive_rowScaling_sInf_eq_condSkeel_of_right_inverse
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (hRight : IsRightInverse n A A_inv) :
    sInf (ch7PositiveRowScaledKappaInfSet n hn A A_inv) =
      condSkeel n hn A A_inv :=
  eq_7_15_positive_rowScaling_sInf_eq_condSkeel n hn A A_inv
    (ch7RowEquilibratingScale n A) (ch7RowEquilibratingScaleInv n A)
    (ch7RowEquilibratingScale_pos_of_right_inverse n A A_inv hRight)
    (ch7RowEquilibratingScaleInv_mul_scale n A A_inv hRight)
    (ch7RowsEquilibratedInf_rowEquilibratingScale_of_right_inverse n A A_inv hRight)

-- ============================================================
-- Problem 7.4: unit-diagonal SPD scaling core bound
-- ============================================================

lemma problem7_4_rowAbsSum_le_card_of_abs_entry_le_one {n : ℕ}
    (H : Fin n → Fin n → ℝ)
    (hentry : ∀ i j : Fin n, |H i j| ≤ 1) :
    ∀ i : Fin n, ∑ j : Fin n, |H i j| ≤ (n : ℝ) := by
  intro i
  calc
    ∑ j : Fin n, |H i j| ≤ ∑ _j : Fin n, (1 : ℝ) := by
      exact Finset.sum_le_sum fun j _ => hentry i j
    _ = (n : ℝ) := by
      simp

lemma problem7_4_one_le_rowAbsSum_of_diag_one {n : ℕ}
    (H : Fin n → Fin n → ℝ)
    (hdiag : ∀ i : Fin n, H i i = 1) :
    ∀ i : Fin n, 1 ≤ ∑ j : Fin n, |H i j| := by
  intro i
  have hsingle : |H i i| ≤ ∑ j : Fin n, |H i j| :=
    Finset.single_le_sum
      (s := Finset.univ) (f := fun j : Fin n => |H i j|)
      (fun j _ => abs_nonneg _) (Finset.mem_univ i)
  have hdiag_abs : |H i i| = 1 := by
    rw [hdiag i]
    norm_num
  simpa [hdiag_abs] using hsingle

lemma problem7_4_infNorm_le_card_of_abs_entry_le_one {n : ℕ}
    (H : Fin n → Fin n → ℝ)
    (hentry : ∀ i j : Fin n, |H i j| ≤ 1) :
    infNorm H ≤ (n : ℝ) := by
  exact infNorm_le_of_row_sum_le H
    (problem7_4_rowAbsSum_le_card_of_abs_entry_le_one H hentry)
    (Nat.cast_nonneg n)

lemma problem7_4_condSkeel_ge_infNorm_inv_of_rowAbsSum_ge_one
    (n : ℕ) (hn : 0 < n)
    (H H_inv : Fin n → Fin n → ℝ)
    (hrow_ge : ∀ j : Fin n, 1 ≤ ∑ k : Fin n, |H j k|) :
    infNorm H_inv ≤ condSkeel n hn H H_inv := by
  rw [infNorm_eq_sup_row_sum n hn H_inv]
  apply Finset.sup'_le
  intro i _
  calc
    ∑ j : Fin n, |H_inv i j| =
        ∑ j : Fin n, |H_inv i j| * 1 := by
          simp
    _ ≤ ∑ j : Fin n, |H_inv i j| * (∑ k : Fin n, |H j k|) := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left (hrow_ge j) (abs_nonneg _)
    _ ≤ condSkeel n hn H H_inv := by
          unfold condSkeel
          exact Finset.le_sup'
            (fun i' : Fin n => ∑ j : Fin n, |H_inv i' j| *
              (∑ k : Fin n, |H j k|))
            (Finset.mem_univ i)

lemma problem7_4_finiteQuadraticForm_basis_add_basis
    {ι : Type*} [Fintype ι] [DecidableEq ι]
    (M : ι → ι → ℝ) (i j : ι) :
    finiteQuadraticForm M
        (fun k : ι => finiteBasisVec i k + finiteBasisVec j k) =
      M i i + M i j + M j i + M j j := by
  unfold finiteQuadraticForm finiteMatVec finiteBasisVec
  simp [Finset.sum_add_distrib, add_mul, mul_add]
  ring

lemma problem7_4_finiteQuadraticForm_basis_sub_basis
    {ι : Type*} [Fintype ι] [DecidableEq ι]
    (M : ι → ι → ℝ) (i j : ι) :
    finiteQuadraticForm M
        (fun k : ι => finiteBasisVec i k - finiteBasisVec j k) =
      M i i - M i j - M j i + M j j := by
  unfold finiteQuadraticForm finiteMatVec finiteBasisVec
  simp [Finset.sum_sub_distrib, sub_mul, mul_sub]
  ring

lemma problem7_4_abs_entry_le_one_of_finitePSD_diag_one {n : ℕ}
    (H : Fin n → Fin n → ℝ)
    (hsym : IsSymmetricFiniteMatrix H)
    (hPSD : finitePSD H)
    (hdiag : ∀ i : Fin n, H i i = 1) :
    ∀ i j : Fin n, |H i j| ≤ 1 := by
  intro i j
  by_cases hij_eq : i = j
  · subst j
    simp [hdiag i]
  · have hplus_nonneg :
        0 ≤ finiteQuadraticForm H
          (fun k : Fin n => finiteBasisVec i k + finiteBasisVec j k) :=
      hPSD _
    have hplus_expr :=
      problem7_4_finiteQuadraticForm_basis_add_basis H i j
    have hplus_bound : -1 ≤ H i j := by
      rw [hplus_expr, hdiag i, hdiag j, ← hsym i j] at hplus_nonneg
      linarith
    have hminus_nonneg :
        0 ≤ finiteQuadraticForm H
          (fun k : Fin n => finiteBasisVec i k - finiteBasisVec j k) :=
      hPSD _
    have hminus_expr :=
      problem7_4_finiteQuadraticForm_basis_sub_basis H i j
    have hminus_bound : H i j ≤ 1 := by
      rw [hminus_expr, hdiag i, hdiag j, ← hsym i j] at hminus_nonneg
      linarith
    exact abs_le.mpr ⟨hplus_bound, hminus_bound⟩

/-- Higham Chapter 7, Problem 7.4, finite core inequality.

If the scaled symmetric positive-definite factor `H` has unit diagonal and the
standard SPD Cauchy entry bound `|Hᵢⱼ| ≤ 1`, then its componentwise condition
number and standard infinity-norm condition number satisfy
`cond(H) ≤ κ∞(H) ≤ n cond(H)`. -/
theorem problem7_4_unitDiagonal_entryBound_condition_bounds
    (n : ℕ) (hn : 0 < n)
    (H H_inv : Fin n → Fin n → ℝ)
    (hdiag : ∀ i : Fin n, H i i = 1)
    (hentry : ∀ i j : Fin n, |H i j| ≤ 1) :
    condSkeel n hn H H_inv ≤ kappaInf n hn H H_inv ∧
      kappaInf n hn H H_inv ≤ (n : ℝ) * condSkeel n hn H H_inv := by
  constructor
  · exact condSkeel_le_kappaInf n hn H H_inv
  · have hH : infNorm H ≤ (n : ℝ) :=
      problem7_4_infNorm_le_card_of_abs_entry_le_one H hentry
    have hInv : infNorm H_inv ≤ condSkeel n hn H H_inv :=
      problem7_4_condSkeel_ge_infNorm_inv_of_rowAbsSum_ge_one n hn H H_inv
        (problem7_4_one_le_rowAbsSum_of_diag_one H hdiag)
    rw [kappaInf_eq_infNorm_mul_infNorm n hn H H_inv]
    calc
      infNorm H * infNorm H_inv ≤ (n : ℝ) * infNorm H_inv :=
        mul_le_mul_of_nonneg_right hH (infNorm_nonneg H_inv)
      _ ≤ (n : ℝ) * condSkeel n hn H H_inv :=
        mul_le_mul_of_nonneg_left hInv (Nat.cast_nonneg n)

/-- Higham Chapter 7, Problem 7.4, source-facing PSD form.

For a unit-diagonal symmetric positive-semidefinite scaled factor `H`, the
entry bound `|Hᵢⱼ| ≤ 1` follows from positivity on `eᵢ ± eⱼ`, and therefore
`cond(H) ≤ κ∞(H) ≤ n cond(H)`. -/
theorem problem7_4_unitDiagonal_finitePSD_condition_bounds
    (n : ℕ) (hn : 0 < n)
    (H H_inv : Fin n → Fin n → ℝ)
    (hsym : IsSymmetricFiniteMatrix H)
    (hPSD : finitePSD H)
    (hdiag : ∀ i : Fin n, H i i = 1) :
    condSkeel n hn H H_inv ≤ kappaInf n hn H H_inv ∧
      kappaInf n hn H H_inv ≤ (n : ℝ) * condSkeel n hn H H_inv :=
  problem7_4_unitDiagonal_entryBound_condition_bounds n hn H H_inv hdiag
    (problem7_4_abs_entry_le_one_of_finitePSD_diag_one H hsym hPSD hdiag)

-- ============================================================
-- Theorem 7.5 dependency: Euclidean column-equilibration bounds
-- ============================================================

/-- Finite-real `p`-norm of rectangular column `j`, matching Higham's
source notation `‖A(:,j)‖_p` in Theorem 7.5 for `1 ≤ p < ∞`. -/
noncomputable def ch7RectColumnLpNormOfReal {m n : ℕ} (p : ℝ)
    (A : Fin m → Fin n → ℝ) (j : Fin n) : ℝ :=
  complexVecLpNorm (n := m) (ENNReal.ofReal p)
    (fun i : Fin m => (A i j : ℂ))

lemma ch7RectColumnLpNormOfReal_nonneg {m n : ℕ} {p : ℝ}
    (hp : 1 ≤ p) (A : Fin m → Fin n → ℝ) (j : Fin n) :
    0 ≤ ch7RectColumnLpNormOfReal p A j := by
  haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hp⟩
  exact (complexVecLpNorm_isComplexVectorNorm (n := m) (ENNReal.ofReal p)).nonneg _

/-- Full-column-rank side condition for Theorem 7.5, in explicit rectangular
left-inverse form: if `Aplus A = I`, then no source column of `A` has zero
finite-real `p`-norm. -/
lemma ch7RectColumnLpNormOfReal_pos_of_rect_left_inverse {m n : ℕ} {p : ℝ}
    (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0)
    (j : Fin n) :
    0 < ch7RectColumnLpNormOfReal p A j := by
  have hne : ch7RectColumnLpNormOfReal p A j ≠ 0 := by
    intro hzero
    haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
      rw [ENNReal.one_le_ofReal]
      exact hp⟩
    have hzeroC :
        complexVecLpNorm (n := m) (ENNReal.ofReal p)
            (fun k : Fin m => (A k j : ℂ)) = 0 := by
      simpa [ch7RectColumnLpNormOfReal] using hzero
    have hentriesC :
        (fun k : Fin m => (A k j : ℂ)) = (0 : CVec m) :=
      ((complexVecLpNorm_isComplexVectorNorm (n := m) (ENNReal.ofReal p)).eq_zero_iff
        (fun k : Fin m => (A k j : ℂ))).mp hzeroC
    have hentries : ∀ k : Fin m, A k j = 0 := by
      intro k
      exact Complex.ofReal_injective (congrFun hentriesC k)
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hleft j j
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectColumnLpNormOfReal_nonneg hp A j) (Ne.symm hne)

/-- Strictly positive finite-real column `p`-norms give a strictly positive
lower bound for the average-normalized column factors. -/
lemma ch7_exists_pos_le_all_inv_card_mul_column_lpNormOfReal {m n : ℕ}
    (hn : 0 < n) {p : ℝ}
    (A : Fin m → Fin n → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnLpNormOfReal p A k) :
    ∃ c : ℝ, 0 < c ∧
      ∀ k : Fin n, c ≤ (n : ℝ)⁻¹ * ch7RectColumnLpNormOfReal p A k := by
  let f : Fin n → ℝ := fun k =>
    (n : ℝ)⁻¹ * ch7RectColumnLpNormOfReal p A k
  have hnonempty : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  rcases Finset.exists_min_image (Finset.univ : Finset (Fin n)) f hnonempty with
    ⟨k, _hk, hkmin⟩
  refine ⟨f k, ?_, ?_⟩
  · exact mul_pos (inv_pos.mpr (Nat.cast_pos.mpr hn)) (hcol k)
  · intro i
    exact hkmin i (Finset.mem_univ i)

/-- Equation `(7.20)`, lower side for finite real `p`: the local least
matrix `p`-norm of `A` bounds every column `p`-norm. -/
theorem eq_7_20_column_lpNorm_le_matrixLpNormOfReal {m n : ℕ}
    (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (j : Fin n) :
    ch7RectColumnLpNormOfReal p A j ≤
      complexMatrixLpNormOfReal hn p hp (realRectToCMatrix A) := by
  haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hp⟩
  have hval :=
    complexMatrixLpNormOfReal_isComplexMatrixLpNormValue hn p hp
      (realRectToCMatrix A)
  have hbound := hval.1 (standardBasisCVec j)
  rw [complexMatrixVecMul_standardBasisCVec,
    complexVecLpNorm_standardBasisCVec, mul_one] at hbound
  simpa [ch7RectColumnLpNormOfReal, realRectToCMatrix] using hbound

/-- Column expansion estimate for the finite-real `p` vector norm.  This is
the triangle-inequality core used in the upper side of Higham `(7.20)`. -/
lemma ch7_complexVecLpNorm_realRect_matVec_le_sum_column_lpNorm
    {m n : ℕ} {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (x : CVec n) :
    complexVecLpNorm (ENNReal.ofReal p)
        (complexMatrixVecMul (realRectToCMatrix A) x) ≤
      ∑ j : Fin n, ‖x j‖ * ch7RectColumnLpNormOfReal p A j := by
  haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hp⟩
  let ν : CVec m → ℝ := complexVecLpNorm (n := m) (ENNReal.ofReal p)
  have hν : IsComplexVectorNorm ν :=
    complexVecLpNorm_isComplexVectorNorm (n := m) (ENNReal.ofReal p)
  have hvec :
      complexMatrixVecMul (realRectToCMatrix A) x =
        fun i : Fin m => ∑ j : Fin n, x j * (A i j : ℂ) := by
    ext i
    unfold complexMatrixVecMul realRectToCMatrix
    apply Finset.sum_congr rfl
    intro j _
    ring
  rw [hvec]
  calc
    ν (fun i : Fin m => ∑ j : Fin n, x j * (A i j : ℂ))
        ≤ ∑ j : Fin n, ν (fun i : Fin m => x j * (A i j : ℂ)) :=
          hν.sum_le (fun j : Fin n => fun i : Fin m => x j * (A i j : ℂ))
    _ = ∑ j : Fin n, ‖x j‖ * ch7RectColumnLpNormOfReal p A j := by
          apply Finset.sum_congr rfl
          intro j _
          have hsmul := hν.smul (x j) (fun i : Fin m => (A i j : ℂ))
          simpa [ν, complexVecSMul, ch7RectColumnLpNormOfReal] using hsmul

/-- Equation `(7.20)`, upper side for finite real `p`: if every column has
`p`-norm at most `B`, then `‖A‖_p ≤ n^(1-1/p) B`.  Taking `B` to be the
finite maximum of the column norms gives the printed maximum form. -/
theorem eq_7_20_matrixLpNormOfReal_le_card_rpow_mul_column_bound
    {m n : ℕ} (hn : 0 < n) {p B : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ)
    (hB : ∀ j : Fin n, ch7RectColumnLpNormOfReal p A j ≤ B) :
    complexMatrixLpNormOfReal hn p hp (realRectToCMatrix A) ≤
      (n : ℝ) ^ (1 - p⁻¹) * B := by
  have hB_nonneg : 0 ≤ B := by
    exact (ch7RectColumnLpNormOfReal_nonneg (m := m) (n := n) hp A ⟨0, hn⟩).trans
      (hB ⟨0, hn⟩)
  have hC_nonneg : 0 ≤ (n : ℝ) ^ (1 - p⁻¹) * B :=
    mul_nonneg (Real.rpow_nonneg (Nat.cast_nonneg n) _) hB_nonneg
  apply isComplexMatrixLpNormValue_le_of_hasComplexMatrixLpBound
    (complexMatrixLpNormOfReal_isComplexMatrixLpNormValue hn p hp
      (realRectToCMatrix A))
  refine hasComplexMatrixLpBound_of_nonneg_mixedSubordinateMatrixBound
    hC_nonneg ?_
  intro x
  have hsum :=
    ch7_complexVecLpNorm_realRect_matVec_le_sum_column_lpNorm
      (m := m) (n := n) hp A x
  have hsumB :
      (∑ j : Fin n, ‖x j‖ * ch7RectColumnLpNormOfReal p A j) ≤
        ∑ j : Fin n, ‖x j‖ * B := by
    apply Finset.sum_le_sum
    intro j _
    exact mul_le_mul_of_nonneg_left (hB j) (norm_nonneg (x j))
  have hone :=
    complexVecOneNorm_le_card_rpow_mul_complexVecLpNorm
      (n := n) (p := p) hp x
  calc
    complexVecLpNorm (ENNReal.ofReal p)
        (complexMatrixVecMul (realRectToCMatrix A) x)
        ≤ ∑ j : Fin n, ‖x j‖ * ch7RectColumnLpNormOfReal p A j := hsum
    _ ≤ ∑ j : Fin n, ‖x j‖ * B := hsumB
    _ = complexVecOneNorm x * B := by
          simp [complexVecOneNorm, Finset.sum_mul]
    _ = B * complexVecOneNorm x := by ring
    _ ≤ B * ((n : ℝ) ^ (1 - p⁻¹) *
        complexVecLpNorm (ENNReal.ofReal p) x) :=
          mul_le_mul_of_nonneg_left hone hB_nonneg
    _ = ((n : ℝ) ^ (1 - p⁻¹) * B) *
        complexVecLpNorm (ENNReal.ofReal p) x := by ring

/-- Euclidean norm of rectangular column `j`, the `p = 2` instance of
Higham's source notation `‖A(:, j)‖_p` in Theorem 7.5. -/
noncomputable def ch7RectColumnNorm2 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) : ℝ :=
  vecNorm2 (fun i : Fin m => A i j)

/-- Rectangular right diagonal scaling, written entrywise to avoid introducing
a duplicate rectangular diagonal-matrix API. -/
noncomputable def ch7RectRightScale {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin n → ℝ) : Fin m → Fin n → ℝ :=
  fun i j => A i j * d j

/-- The column-equilibrating reciprocal scale `d_j = 1 / ‖A(:,j)‖₂`. -/
noncomputable def ch7ColumnEquilibratingScale2 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) : ℝ :=
  1 / ch7RectColumnNorm2 A j

/-- The finite-real `p` column-equilibrating reciprocal scale
`d_j = 1 / ‖A(:,j)‖_p`.  Positivity of the column norms is supplied in the
theorems that use this scale, matching the full-rank side condition in
Higham's Theorem 7.5. -/
noncomputable def ch7ColumnEquilibratingScaleLpOfReal {m n : ℕ} (p : ℝ)
    (A : Fin m → Fin n → ℝ) (j : Fin n) : ℝ :=
  1 / ch7RectColumnLpNormOfReal p A j

lemma ch7RectColumnLpNormOfReal_rightScale {m n : ℕ} {p : ℝ}
    (hp : 1 ≤ p) (A : Fin m → Fin n → ℝ) (d : Fin n → ℝ) (j : Fin n) :
    ch7RectColumnLpNormOfReal p (ch7RectRightScale A d) j =
      ‖(d j : ℂ)‖ * ch7RectColumnLpNormOfReal p A j := by
  haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hp⟩
  let ν : CVec m → ℝ := complexVecLpNorm (n := m) (ENNReal.ofReal p)
  have hν : IsComplexVectorNorm ν :=
    complexVecLpNorm_isComplexVectorNorm (n := m) (ENNReal.ofReal p)
  have hcol :
      (fun i : Fin m => ((ch7RectRightScale A d) i j : ℂ)) =
        complexVecSMul (d j : ℂ) (fun i : Fin m => (A i j : ℂ)) := by
    ext i
    simp [ch7RectRightScale, complexVecSMul]
    ring
  calc
    ch7RectColumnLpNormOfReal p (ch7RectRightScale A d) j
        = ν (complexVecSMul (d j : ℂ) (fun i : Fin m => (A i j : ℂ))) := by
            simp [ch7RectColumnLpNormOfReal, ν, hcol]
    _ = ‖(d j : ℂ)‖ * ch7RectColumnLpNormOfReal p A j := by
            simpa [ch7RectColumnLpNormOfReal, ν] using
              hν.smul (d j : ℂ) (fun i : Fin m => (A i j : ℂ))

lemma ch7RectColumnLpNormOfReal_rightScale_equilibrating {m n : ℕ}
    {p : ℝ} (hp : 1 ≤ p) (A : Fin m → Fin n → ℝ)
    (hpos : ∀ j : Fin n, 0 < ch7RectColumnLpNormOfReal p A j)
    (j : Fin n) :
    ch7RectColumnLpNormOfReal p
      (ch7RectRightScale A (ch7ColumnEquilibratingScaleLpOfReal p A)) j = 1 := by
  rw [ch7RectColumnLpNormOfReal_rightScale hp]
  have hnorm :
      ‖((ch7ColumnEquilibratingScaleLpOfReal p A j : ℝ) : ℂ)‖ =
        (ch7RectColumnLpNormOfReal p A j)⁻¹ := by
    unfold ch7ColumnEquilibratingScaleLpOfReal
    rw [one_div]
    exact Complex.norm_of_nonneg (inv_nonneg.mpr (le_of_lt (hpos j)))
  rw [hnorm]
  field_simp [ne_of_gt (hpos j)]

/-- Equation `(7.21)` for finite real `p`: after right-scaling each nonzero
column by the reciprocal of its `p`-norm, the local least matrix `p`-norm is
bounded by `n^(1-1/p)`. -/
theorem eq_7_21_matrixLpNormOfReal_column_equilibrated {m n : ℕ}
    (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ)
    (hpos : ∀ j : Fin n, 0 < ch7RectColumnLpNormOfReal p A j) :
    complexMatrixLpNormOfReal hn p hp
        (realRectToCMatrix
          (ch7RectRightScale A (ch7ColumnEquilibratingScaleLpOfReal p A))) ≤
      (n : ℝ) ^ (1 - p⁻¹) := by
  have hbound : ∀ j : Fin n,
      ch7RectColumnLpNormOfReal p
        (ch7RectRightScale A (ch7ColumnEquilibratingScaleLpOfReal p A)) j ≤
        (1 : ℝ) := by
    intro j
    rw [ch7RectColumnLpNormOfReal_rightScale_equilibrating hp A hpos j]
  simpa [mul_one] using
    eq_7_20_matrixLpNormOfReal_le_card_rpow_mul_column_bound
      (m := m) (n := n) hn hp
      (ch7RectRightScale A (ch7ColumnEquilibratingScaleLpOfReal p A))
      hbound

lemma ch7RectColumnNorm2_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) :
    0 ≤ ch7RectColumnNorm2 A j :=
  vecNorm2_nonneg _

/-- Full-column-rank side condition for the `p = 2` column route in
Theorem 7.5, stated with an explicit rectangular left inverse. -/
lemma ch7RectColumnNorm2_pos_of_rect_left_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0)
    (j : Fin n) :
    0 < ch7RectColumnNorm2 A j := by
  have hne : ch7RectColumnNorm2 A j ≠ 0 := by
    intro hzero
    have hentries : ∀ k : Fin m, A k j = 0 :=
      (vecNorm2_eq_zero_iff (fun k : Fin m => A k j)).mp hzero
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hleft j j
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectColumnNorm2_nonneg A j) (Ne.symm hne)

lemma ch7_vecNorm2_basisVec {n : ℕ} (j : Fin n) :
    vecNorm2 (basisVec (n := n) j) = 1 := by
  unfold vecNorm2 vecNorm2Sq basisVec
  simp

lemma ch7_rectMatMulVec_basisVec {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) :
    rectMatMulVec A (basisVec (n := n) j) = fun i : Fin m => A i j := by
  ext i
  unfold rectMatMulVec basisVec
  simp

/-- The rectangular matrix-vector action, as a Mathlib linear map.  This is
the bridge from source full-rank hypotheses stated as injectivity or
surjectivity of `x ↦ A*x` to the repository's explicit one-sided inverse
matrix predicates used in Theorem 7.5. -/
noncomputable def ch7RectMatMulVecLinearMap {m n : ℕ}
    (A : Fin m → Fin n → ℝ) :
    (Fin n → ℝ) →ₗ[ℝ] (Fin m → ℝ) where
  toFun := rectMatMulVec A
  map_add' := by
    intro x y
    ext i
    simp [rectMatMulVec, Pi.add_apply, mul_add, Finset.sum_add_distrib]
  map_smul' := by
    intro c x
    ext i
    change ∑ j : Fin n, A i j * (c * x j) = c * ∑ j : Fin n, A i j * x j
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro j _
    ring

/-- Extract a concrete rectangular left-inverse matrix from a linear left
inverse of the rectangular matrix-vector action. -/
lemma ch7_exists_rect_left_inverse_of_linear_left_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (S : (Fin m → ℝ) →ₗ[ℝ] (Fin n → ℝ))
    (hS : S.comp (ch7RectMatMulVecLinearMap A) = LinearMap.id) :
    ∃ Aplus : Fin n → Fin m → ℝ,
      ∀ i j : Fin n,
        ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0 := by
  let Aplus : Fin n → Fin m → ℝ :=
    fun i k => S ((Pi.single k (1 : ℝ) : Fin m → ℝ)) i
  refine ⟨Aplus, ?_⟩
  intro i j
  have hbasis := LinearMap.congr_fun hS ((Pi.single j (1 : ℝ) : Fin n → ℝ))
  have hcol :
      ch7RectMatMulVecLinearMap A ((Pi.single j (1 : ℝ) : Fin n → ℝ)) =
        fun k : Fin m => A k j := by
    ext k
    simp [ch7RectMatMulVecLinearMap, rectMatMulVec, Pi.single_apply]
  have hsingle_m : ∀ k : Fin m,
      (fun r : Fin m => if k = r then (1 : ℝ) else 0) =
        (Pi.single k (1 : ℝ) : Fin m → ℝ) := by
    intro k
    ext r
    by_cases h : k = r <;> simp [Pi.single_apply, h]
  have hexp :=
    congrFun (LinearMap.pi_apply_eq_sum_univ S (fun k : Fin m => A k j)) i
  calc
    ∑ k : Fin m, Aplus i k * A k j =
        ∑ k : Fin m, A k j * S (Pi.single k (1 : ℝ)) i := by
          apply Finset.sum_congr rfl
          intro k _
          simp [Aplus, mul_comm]
    _ = S (fun k : Fin m => A k j) i := by
          simpa [hsingle_m, Finset.sum_apply, Pi.smul_apply, smul_eq_mul,
            mul_comm] using hexp.symm
    _ = S (ch7RectMatMulVecLinearMap A ((Pi.single j (1 : ℝ) : Fin n → ℝ))) i := by
          rw [hcol]
    _ = (Pi.single j (1 : ℝ) : Fin n → ℝ) i := by
          simpa using congrFun hbasis i
    _ = if i = j then 1 else 0 := by
          by_cases h : i = j <;> simp [Pi.single_apply, h]

/-- Extract a concrete rectangular right-inverse matrix from a linear right
inverse of the rectangular matrix-vector action. -/
lemma ch7_exists_rect_right_inverse_of_linear_right_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (S : (Fin m → ℝ) →ₗ[ℝ] (Fin n → ℝ))
    (hS : (ch7RectMatMulVecLinearMap A).comp S = LinearMap.id) :
    ∃ Aplus : Fin n → Fin m → ℝ,
      ∀ i j : Fin m,
        ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0 := by
  let Aplus : Fin n → Fin m → ℝ :=
    fun k j => S ((Pi.single j (1 : ℝ) : Fin m → ℝ)) k
  refine ⟨Aplus, ?_⟩
  intro i j
  have hbasis := LinearMap.congr_fun hS ((Pi.single j (1 : ℝ) : Fin m → ℝ))
  calc
    ∑ k : Fin n, A i k * Aplus k j =
        ch7RectMatMulVecLinearMap A
          (S ((Pi.single j (1 : ℝ) : Fin m → ℝ))) i := by
          simp [ch7RectMatMulVecLinearMap, rectMatMulVec, Aplus]
    _ = (Pi.single j (1 : ℝ) : Fin m → ℝ) i := by
          simpa using congrFun hbasis i
    _ = if i = j then 1 else 0 := by
          by_cases h : i = j <;> simp [Pi.single_apply, h]

/-- Source full-column-rank bridge for Theorem 7.5: injectivity of the
rectangular map `x ↦ A*x` supplies an explicit left-inverse matrix
`Aplus*A = I`. -/
lemma ch7_exists_rect_left_inverse_of_rectMatMulVec_injective {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hA : Function.Injective (rectMatMulVec A)) :
    ∃ Aplus : Fin n → Fin m → ℝ,
      ∀ i j : Fin n,
        ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0 := by
  have hTinj : Function.Injective (ch7RectMatMulVecLinearMap A) := by
    simpa [ch7RectMatMulVecLinearMap] using hA
  have hker : LinearMap.ker (ch7RectMatMulVecLinearMap A) = ⊥ :=
    LinearMap.ker_eq_bot.mpr hTinj
  obtain ⟨S, hS⟩ :=
    LinearMap.exists_leftInverse_of_injective (ch7RectMatMulVecLinearMap A) hker
  exact ch7_exists_rect_left_inverse_of_linear_left_inverse A S hS

/-- Source full-row-rank bridge for Theorem 7.5: surjectivity of the
rectangular map `x ↦ A*x` supplies an explicit right-inverse matrix
`A*Aplus = I`. -/
lemma ch7_exists_rect_right_inverse_of_rectMatMulVec_surjective {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hA : Function.Surjective (rectMatMulVec A)) :
    ∃ Aplus : Fin n → Fin m → ℝ,
      ∀ i j : Fin m,
        ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0 := by
  have hTsurj : Function.Surjective (ch7RectMatMulVecLinearMap A) := by
    simpa [ch7RectMatMulVecLinearMap] using hA
  let S : (Fin m → ℝ) →ₗ[ℝ] (Fin n → ℝ) :=
    (ch7RectMatMulVecLinearMap A).splittingOfFunOnFintypeSurjective hTsurj
  have hS : (ch7RectMatMulVecLinearMap A).comp S = LinearMap.id := by
    exact LinearMap.splittingOfFunOnFintypeSurjective_splits
      (ch7RectMatMulVecLinearMap A) hTsurj
  exact ch7_exists_rect_right_inverse_of_linear_right_inverse A S hS

/-- Matrix-rank source bridge for Theorem 7.5: if the real rectangular
matrix has full column rank, then its matrix-vector action is injective. -/
lemma ch7_rectMatMulVec_injective_of_matrix_rank_eq_width {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrank : (Matrix.of A).rank = n) :
    Function.Injective (rectMatMulVec A) := by
  let T : (Fin n → ℝ) →ₗ[ℝ] (Fin m → ℝ) := (Matrix.of A).mulVecLin
  have hdim : Module.finrank ℝ (Fin n → ℝ) = n := by
    simp
  have hsum : Module.finrank ℝ T.range + Module.finrank ℝ T.ker = n := by
    simpa [T, hdim] using (LinearMap.finrank_range_add_finrank_ker T)
  have hrange : Module.finrank ℝ T.range = n := by
    simpa [T, Matrix.rank] using hrank
  have hsum' : n + Module.finrank ℝ T.ker = n := by
    simpa [hrange] using hsum
  have hkerfin : Module.finrank ℝ T.ker = 0 :=
    Nat.add_eq_left.mp hsum'
  have hker : T.ker = ⊥ := Submodule.finrank_eq_zero.mp hkerfin
  have htinj : Function.Injective T := LinearMap.ker_eq_bot.mp hker
  intro x y hxy
  apply htinj
  ext i
  have hi := congrFun hxy i
  simpa [T, rectMatMulVec, Matrix.mulVecLin, Matrix.mulVec, dotProduct, Matrix.of] using hi

/-- Matrix-rank source bridge for Theorem 7.5: if the real rectangular
matrix has full row rank, then its matrix-vector action is surjective. -/
lemma ch7_rectMatMulVec_surjective_of_matrix_rank_eq_height {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrank : (Matrix.of A).rank = m) :
    Function.Surjective (rectMatMulVec A) := by
  let T : (Fin n → ℝ) →ₗ[ℝ] (Fin m → ℝ) := (Matrix.of A).mulVecLin
  have hdim : Module.finrank ℝ (Fin m → ℝ) = m := by
    simp
  have hrange : Module.finrank ℝ T.range = Module.finrank ℝ (Fin m → ℝ) := by
    simpa [T, Matrix.rank, hdim] using hrank
  have htop : T.range = ⊤ := Submodule.eq_top_of_finrank_eq hrange
  have hsurjT : Function.Surjective T := LinearMap.range_eq_top.mp htop
  intro y
  obtain ⟨x, hx⟩ := hsurjT y
  refine ⟨x, ?_⟩
  ext i
  have hi := congrFun hx i
  simpa [T, rectMatMulVec, Matrix.mulVecLin, Matrix.mulVec, dotProduct, Matrix.of] using hi

/-- Theorem 7.5 Moore-Penrose construction, full-column-rank side: if the
rectangular action `x ↦ A*x` is injective, the normal-equations candidate
`A⁺ = (Aᵀ A)⁻¹ Aᵀ` is an explicit left inverse and has symmetric range
projection `A A⁺`.  This is the constructive dependency needed to remove the
source-facing `Aplus` hypothesis from the full-column-rank Penrose packages. -/
theorem theorem7_5_exists_rect_left_inverse_symmetric_range_of_rectMatMulVec_injective
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hA : Function.Injective (rectMatMulVec A)) :
    ∃ Aplus : Fin n → Fin m → ℝ,
      (∀ i j : Fin n,
        ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) ∧
      IsSymmetricFiniteMatrix (rectMatMul A Aplus) := by
  let M : Matrix (Fin m) (Fin n) ℝ := Matrix.of A
  have hMinj : Function.Injective M.mulVec := by
    intro x y hxy
    apply hA
    ext i
    have hi := congrFun hxy i
    simpa [M, rectMatMulVec, Matrix.mulVec, dotProduct, Matrix.of] using hi
  let G : Matrix (Fin n) (Fin n) ℝ := M.conjTranspose * M
  have hGpos : G.PosDef := by
    simpa [G] using Matrix.PosDef.conjTranspose_mul_self M hMinj
  have hGunit : IsUnit G.det := (Matrix.isUnit_iff_isUnit_det G).mp hGpos.isUnit
  let AplusM : Matrix (Fin n) (Fin m) ℝ := G⁻¹ * M.conjTranspose
  let Aplus : Fin n → Fin m → ℝ := fun i k => AplusM i k
  refine ⟨Aplus, ?_, ?_⟩
  · intro i j
    have hleftM : AplusM * M = 1 := by
      calc
        AplusM * M = G⁻¹ * (M.conjTranspose * M) := by
          simp [AplusM, Matrix.mul_assoc]
        _ = G⁻¹ * G := by rfl
        _ = 1 := Matrix.nonsing_inv_mul G hGunit
    have hij := congrFun (congrFun hleftM i) j
    simpa [Aplus, AplusM, M, G, Matrix.mul_apply, Matrix.one_apply, Matrix.of] using hij
  · have hGinvHerm : (G⁻¹).IsHermitian := by
      exact (Matrix.isHermitian_conjTranspose_mul_self M).inv
    have hPherm : (M * G⁻¹ * M.conjTranspose).IsHermitian := by
      exact Matrix.isHermitian_mul_mul_conjTranspose M hGinvHerm
    have hAplus :
        Matrix.of (rectMatMul A Aplus) = M * G⁻¹ * M.conjTranspose := by
      ext i j
      simp only [rectMatMul, Aplus, AplusM, M, Matrix.of_apply, Matrix.mul_apply,
        Matrix.conjTranspose_apply, RCLike.star_def]
      calc
        ∑ k : Fin n, A i k * (∑ x : Fin n, G⁻¹ k x * A j x)
            = ∑ k : Fin n, ∑ x : Fin n, A i k * (G⁻¹ k x * A j x) := by
              apply Finset.sum_congr rfl
              intro k _
              rw [Finset.mul_sum]
        _ = ∑ x : Fin n, ∑ k : Fin n, A i k * (G⁻¹ k x * A j x) := by
              rw [Finset.sum_comm]
        _ = ∑ x : Fin n, (∑ k : Fin n, A i k * G⁻¹ k x) * A j x := by
              apply Finset.sum_congr rfl
              intro x _
              rw [Finset.sum_mul]
              apply Finset.sum_congr rfl
              intro k _
              ring
    apply Matrix_isHermitian.to_IsSymmetricFiniteMatrix (rectMatMul A Aplus)
    change Matrix.IsHermitian (Matrix.of (rectMatMul A Aplus))
    rw [hAplus]
    exact hPherm

/-- Matrix-rank source form of the full-column-rank Moore-Penrose
construction: `rank(A)=n` constructs a left inverse with symmetric range
projection. -/
theorem theorem7_5_exists_rect_left_inverse_symmetric_range_of_matrix_rank_eq_width
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrank : (Matrix.of A).rank = n) :
    ∃ Aplus : Fin n → Fin m → ℝ,
      (∀ i j : Fin n,
        ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) ∧
      IsSymmetricFiniteMatrix (rectMatMul A Aplus) :=
  theorem7_5_exists_rect_left_inverse_symmetric_range_of_rectMatMulVec_injective A
    (ch7_rectMatMulVec_injective_of_matrix_rank_eq_width A hrank)

/-- Theorem 7.5 Moore-Penrose construction, full-row-rank side: if
`rank(A)=m`, transpose the full-column-rank construction for `Aᵀ` to obtain
an explicit right inverse and symmetric domain projection `A⁺ A`. -/
theorem theorem7_5_exists_rect_right_inverse_symmetric_domain_of_matrix_rank_eq_height
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrank : (Matrix.of A).rank = m) :
    ∃ Aplus : Fin n → Fin m → ℝ,
      (∀ i j : Fin m,
        ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0) ∧
      IsSymmetricFiniteMatrix (rectMatMul Aplus A) := by
  let B : Fin n → Fin m → ℝ := fun j i => A i j
  have hBrank : (Matrix.of B).rank = m := by
    have hBMat : Matrix.of B = (Matrix.of A).transpose := by
      ext j i
      rfl
    rw [hBMat, Matrix.rank_transpose, hrank]
  obtain ⟨Bplus, hleftB, hSymB⟩ :=
    theorem7_5_exists_rect_left_inverse_symmetric_range_of_matrix_rank_eq_width B hBrank
  let Aplus : Fin n → Fin m → ℝ := fun j i => Bplus i j
  refine ⟨Aplus, ?_, ?_⟩
  · intro i j
    have h := hleftB j i
    simpa [B, Aplus, eq_comm, mul_comm] using h
  · intro j k
    have h := hSymB k j
    simpa [B, Aplus, rectMatMul, mul_comm] using h

/-- A strictly positive finite family over a nonempty `Fin n` has a strictly
positive lower bound. -/
lemma ch7_exists_pos_le_all_fin {n : ℕ} (hn : 0 < n)
    (f : Fin n → ℝ) (hpos : ∀ i : Fin n, 0 < f i) :
    ∃ c : ℝ, 0 < c ∧ ∀ i : Fin n, c ≤ f i := by
  have hnonempty : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  rcases Finset.exists_min_image (Finset.univ : Finset (Fin n)) f hnonempty with
    ⟨k, _hk, hkmin⟩
  exact ⟨f k, hpos k, fun i => hkmin i (Finset.mem_univ i)⟩

/-- Equation `(7.20)`, lower side in the `p = 2` rectangular operator-norm
certificate form: every admissible operator bound for `A` bounds each column. -/
theorem eq_7_20_column_norm_le_of_rectOpNorm2Le {m n : ℕ}
    (A : Fin m → Fin n → ℝ) {c : ℝ}
    (hA : rectOpNorm2Le A c) (j : Fin n) :
    ch7RectColumnNorm2 A j ≤ c := by
  have htest := hA (basisVec (n := n) j)
  rw [ch7_rectMatMulVec_basisVec A j, ch7_vecNorm2_basisVec j, mul_one] at htest
  simpa [ch7RectColumnNorm2] using htest

/-- A real rectangular column norm is bounded by the complex Euclidean
operator-2 norm of the complexified matrix. -/
theorem ch7RectColumnNorm2_le_complexMatrixOp2_realRectToCMatrix {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) :
    ch7RectColumnNorm2 A j ≤ complexMatrixOp2 (realRectToCMatrix A) := by
  exact eq_7_20_column_norm_le_of_rectOpNorm2Le A
    (rectOpNorm2Le_of_complexMatrixOp2_realRectToCMatrix_le A le_rfl) j

/-- Strictly positive rectangular column norms give a strictly positive lower
bound for the average-normalized column factors. -/
lemma ch7_exists_pos_le_all_inv_card_mul_column_norm2 {m n : ℕ}
    (hn : 0 < n) (A : Fin m → Fin n → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnNorm2 A k) :
    ∃ c : ℝ, 0 < c ∧
      ∀ k : Fin n, c ≤ (n : ℝ)⁻¹ * ch7RectColumnNorm2 A k := by
  apply ch7_exists_pos_le_all_fin hn
  intro k
  exact mul_pos (inv_pos.mpr (Nat.cast_pos.mpr hn)) (hcol k)

/-- A single rectangular column's Euclidean norm is bounded by the Frobenius
norm.  This is the Frobenius analogue of the lower side of `(7.20)`. -/
theorem ch7RectColumnNorm2_le_frobNormRect {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) :
    ch7RectColumnNorm2 A j ≤ frobNormRect A := by
  have hsq :
      ch7RectColumnNorm2 A j ^ 2 ≤ frobNormRect A ^ 2 := by
    unfold ch7RectColumnNorm2
    rw [vecNorm2_sq, frobNormRect_sq]
    unfold vecNorm2Sq frobNormSqRect
    calc
      (∑ i : Fin m, A i j ^ 2)
          ≤ ∑ j' : Fin n, ∑ i : Fin m, A i j' ^ 2 := by
            exact Finset.single_le_sum
              (fun j' _ => Finset.sum_nonneg fun i _ => sq_nonneg (A i j'))
              (Finset.mem_univ j)
      _ = ∑ i : Fin m, ∑ j' : Fin n, A i j' ^ 2 := by
            rw [Finset.sum_comm]
  have habs := (sq_le_sq).mp hsq
  simpa [abs_of_nonneg (ch7RectColumnNorm2_nonneg A j),
    abs_of_nonneg (frobNormRect_nonneg A)] using habs

/-- The Frobenius/cardinality upper side behind equation `(7.20)` for
Euclidean column bounds.  If every column has Euclidean norm at most `B`, then
`‖A‖_F ≤ sqrt(n) B`. -/
theorem ch7_frobNormRect_le_sqrt_card_mul_column_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) {B : ℝ}
    (hB_nonneg : 0 ≤ B) (hB : ∀ j : Fin n, ch7RectColumnNorm2 A j ≤ B) :
    frobNormRect A ≤ Real.sqrt (n : ℝ) * B := by
  have hsq_col : ∀ j : Fin n, (∑ i : Fin m, A i j ^ 2) ≤ B ^ 2 := by
    intro j
    have hnorm_sq :
        ch7RectColumnNorm2 A j ^ 2 ≤ B ^ 2 := by
      have habs : |ch7RectColumnNorm2 A j| ≤ |B| := by
        simpa [abs_of_nonneg (ch7RectColumnNorm2_nonneg A j),
          abs_of_nonneg hB_nonneg] using hB j
      exact (sq_le_sq).mpr habs
    simpa [ch7RectColumnNorm2, vecNorm2_sq, vecNorm2Sq] using hnorm_sq
  have hsq :
      frobNormSqRect A ≤ (n : ℝ) * B ^ 2 := by
    unfold frobNormSqRect
    calc
      (∑ i : Fin m, ∑ j : Fin n, A i j ^ 2)
          = ∑ j : Fin n, ∑ i : Fin m, A i j ^ 2 := by
            rw [Finset.sum_comm]
      _ ≤ ∑ _j : Fin n, B ^ 2 := by
            exact Finset.sum_le_sum fun j _ => hsq_col j
      _ = (n : ℝ) * B ^ 2 := by
            simp [Finset.sum_const, Fintype.card_fin, nsmul_eq_mul]
  calc
    frobNormRect A = Real.sqrt (frobNormSqRect A) := rfl
    _ ≤ Real.sqrt ((n : ℝ) * B ^ 2) := Real.sqrt_le_sqrt hsq
    _ = Real.sqrt (n : ℝ) * B := by
          rw [Real.sqrt_mul (Nat.cast_nonneg n), Real.sqrt_sq_eq_abs,
            abs_of_nonneg hB_nonneg]

/-- Equation `(7.20)`, upper side in `p = 2` operator-certificate form:
if every column has Euclidean norm at most `B`, then `A` has rectangular
operator-2 bound at most `sqrt(n) B`. -/
theorem eq_7_20_rectOpNorm2Le_of_column_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) {B : ℝ}
    (hB_nonneg : 0 ≤ B) (hB : ∀ j : Fin n, ch7RectColumnNorm2 A j ≤ B) :
    rectOpNorm2Le A (Real.sqrt (n : ℝ) * B) :=
  rectOpNorm2Le_of_frobNormRect_le A
    (ch7_frobNormRect_le_sqrt_card_mul_column_bound A hB_nonneg hB)

lemma ch7RectColumnNorm2_rightScale_eq {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin n → ℝ) (j : Fin n) :
    ch7RectColumnNorm2 (ch7RectRightScale A d) j =
      |d j| * ch7RectColumnNorm2 A j := by
  unfold ch7RectColumnNorm2 ch7RectRightScale
  have hfun :
      (fun i : Fin m => A i j * d j) =
        fun i : Fin m => d j * A i j := by
    ext i
    ring
  rw [hfun, vecNorm2_smul]

/-- Lower bound for the operator-2 norm of a right-scaled real matrix by any
scaled column norm. -/
theorem ch7RectRightScale_column_norm_le_complexMatrixOp2 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin n → ℝ) (j : Fin n) :
    |d j| * ch7RectColumnNorm2 A j ≤
      complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale A d)) := by
  have h := ch7RectColumnNorm2_le_complexMatrixOp2_realRectToCMatrix
    (ch7RectRightScale A d) j
  simpa [ch7RectColumnNorm2_rightScale_eq] using h

lemma ch7RectColumnNorm2_rightScale_equilibrating {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j) (j : Fin n) :
    ch7RectColumnNorm2
        (ch7RectRightScale A (ch7ColumnEquilibratingScale2 A)) j = 1 := by
  rw [ch7RectColumnNorm2_rightScale_eq]
  unfold ch7ColumnEquilibratingScale2
  rw [abs_of_pos (one_div_pos.mpr (hcol j))]
  field_simp [ne_of_gt (hcol j)]

/-- Equation `(7.21)`, `p = 2` operator-certificate form: after scaling every
nonzero column of `A` to Euclidean norm one, the rectangular operator-2 bound is
at most `sqrt(n)`.  This is the local finite-dimensional dependency used by the
van der Sluis scaling route. -/
theorem eq_7_21_rectOpNorm2Le_column_equilibrated {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j) :
    rectOpNorm2Le (ch7RectRightScale A (ch7ColumnEquilibratingScale2 A))
      (Real.sqrt (n : ℝ)) := by
  have hB :
      ∀ j : Fin n,
        ch7RectColumnNorm2
          (ch7RectRightScale A (ch7ColumnEquilibratingScale2 A)) j ≤ 1 := by
    intro j
    rw [ch7RectColumnNorm2_rightScale_equilibrating A hcol j]
  simpa [mul_one] using
    eq_7_20_rectOpNorm2Le_of_column_bound
      (ch7RectRightScale A (ch7ColumnEquilibratingScale2 A))
      (by norm_num : 0 ≤ (1 : ℝ)) hB

/-- Rectangular column 1-norm, the `p = 1` instance of
Higham's notation `‖A(:, j)‖_p`. -/
noncomputable def ch7RectColumnNorm1 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) : ℝ :=
  ∑ i : Fin m, |A i j|

/-- Rectangular left diagonal scaling, used for the inverse-side factor
`D^{-1} A⁺` in Theorem 7.5. -/
noncomputable def ch7RectLeftScale {m n : ℕ}
    (d : Fin m → ℝ) (A : Fin m → Fin n → ℝ) : Fin m → Fin n → ℝ :=
  fun i j => d i * A i j

/-- Entrywise continuity of the complexified right diagonal scaling map. -/
theorem continuous_realRectToCMatrix_ch7RectRightScale {m n : ℕ}
    (A : Fin m → Fin n → ℝ) :
    Continuous (fun d : Fin n → ℝ =>
      realRectToCMatrix (ch7RectRightScale A d)) := by
  apply continuous_matrix
  intro i j
  simpa [realRectToCMatrix, ch7RectRightScale] using
    Complex.continuous_ofReal.comp ((continuous_const.mul (continuous_apply j)) :
      Continuous (fun d : Fin n → ℝ => A i j * d j))

/-- Entrywise continuity of the complexified left diagonal scaling map. -/
theorem continuous_realRectToCMatrix_ch7RectLeftScale {m n : ℕ}
    (A : Fin m → Fin n → ℝ) :
    Continuous (fun d : Fin m → ℝ =>
      realRectToCMatrix (ch7RectLeftScale d A)) := by
  apply continuous_matrix
  intro i j
  simpa [realRectToCMatrix, ch7RectLeftScale] using
    Complex.continuous_ofReal.comp (((continuous_apply i).mul continuous_const) :
      Continuous (fun d : Fin m → ℝ => d i * A i j))

/-- The column-equilibrating reciprocal scale for the matrix 1-norm:
`d_j = 1 / ‖A(:,j)‖₁`. -/
noncomputable def ch7ColumnEquilibratingScale1 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) : ℝ :=
  1 / ch7RectColumnNorm1 A j

lemma ch7RectColumnNorm1_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (j : Fin n) :
    0 ≤ ch7RectColumnNorm1 A j := by
  unfold ch7RectColumnNorm1
  exact Finset.sum_nonneg fun i _ => abs_nonneg (A i j)

/-- Full-column-rank side condition for the `p = 1` column route in
Theorem 7.5, stated with an explicit rectangular left inverse. -/
lemma ch7RectColumnNorm1_pos_of_rect_left_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0)
    (j : Fin n) :
    0 < ch7RectColumnNorm1 A j := by
  have hne : ch7RectColumnNorm1 A j ≠ 0 := by
    intro hzero
    have hsum :
        (∑ k : Fin m, |A k j|) = 0 := by
      simpa [ch7RectColumnNorm1] using hzero
    have hterms :
        ∀ k ∈ (Finset.univ : Finset (Fin m)), |A k j| = 0 :=
      (Finset.sum_eq_zero_iff_of_nonneg (s := Finset.univ)
        (fun k _ => abs_nonneg (A k j))).mp hsum
    have hentries : ∀ k : Fin m, A k j = 0 := by
      intro k
      exact abs_eq_zero.mp (hterms k (Finset.mem_univ k))
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hleft j j
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectColumnNorm1_nonneg A j) (Ne.symm hne)

lemma ch7RectRightScale_column_sum_abs {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin n → ℝ) (j : Fin n) :
    (∑ i : Fin m, |ch7RectRightScale A d i j|) =
      |d j| * ch7RectColumnNorm1 A j := by
  unfold ch7RectRightScale ch7RectColumnNorm1
  calc
    (∑ i : Fin m, |A i j * d j|)
        = ∑ i : Fin m, |d j| * |A i j| := by
          apply Finset.sum_congr rfl
          intro i _
          rw [abs_mul, mul_comm]
    _ = |d j| * ∑ i : Fin m, |A i j| := by
          rw [Finset.mul_sum]

lemma ch7RectColumnNorm1_rightScale_equilibrating {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm1 A j) (j : Fin n) :
    (∑ i : Fin m,
        |ch7RectRightScale A (ch7ColumnEquilibratingScale1 A) i j|) = 1 := by
  rw [ch7RectRightScale_column_sum_abs]
  unfold ch7ColumnEquilibratingScale1
  rw [abs_of_pos (one_div_pos.mpr (hcol j))]
  field_simp [ne_of_gt (hcol j)]

/-- Equation `(7.21)`, `p = 1` source specialization: after scaling every
nonzero column of `A` to 1-norm one, the rectangular matrix 1-norm is at most
one. -/
theorem eq_7_21_oneNormRect_column_equilibrated {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm1 A j) :
    oneNormRect (ch7RectRightScale A (ch7ColumnEquilibratingScale1 A)) ≤ 1 := by
  apply oneNormRect_le_of_col_sum_le
  · intro j
    rw [ch7RectColumnNorm1_rightScale_equilibrating A hcol j]
  · norm_num

/-- One-norm condition-product for the right-scaled rectangular matrix and
the corresponding inverse-side factor.  In the source this is
`‖AD‖₁ ‖D⁻¹A⁺‖₁`; the matrix `Aplus` is kept explicit so this algebraic
scaling step does not assert a Moore-Penrose construction. -/
noncomputable def ch7OneNormRightScaledCond {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) : ℝ :=
  oneNormRect (ch7RectRightScale A d) *
    oneNormRect (ch7RectLeftScale dInv Aplus)

/-- Values of the explicit one-norm condition product
`‖AD‖₁ ‖D⁻¹A⁺‖₁` over reciprocal nonsingular diagonal right scalings.  This
is the infimum model for the `p = 1` specialization of the source minimum in
Theorem 7.5, while keeping `Aplus` explicit. -/
noncomputable def ch7OneNormRightScaledCondSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin n → ℝ,
    (∀ j : Fin n, d j * dInv j = 1) ∧
    κ = ch7OneNormRightScaledCond A Aplus d dInv}

/-- Membership helper for the one-norm right-scaling value set. -/
theorem ch7OneNormRightScaledCond_mem_set {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7OneNormRightScaledCond A Aplus d dInv ∈
      ch7OneNormRightScaledCondSet A Aplus := by
  exact ⟨d, dInv, hdiag, rfl⟩

/-- Equation `(7.22)`, `p = 1` algebraic core.  The proof uses only column-sum
norm algebra and the inverse diagonal relation `d_j d_j^{-1} = 1`; the
Moore-Penrose property of `A⁺` is not needed for this inequality. -/
theorem eq_7_22_oneNormRect_inverseSide_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    oneNormRect
        (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm1 A j) Aplus) ≤
      oneNormRect (ch7RectRightScale A d) *
        oneNormRect (ch7RectLeftScale dInv Aplus) := by
  apply oneNormRect_le_of_col_sum_le
  · intro k
    have hAD_nonneg : 0 ≤ oneNormRect (ch7RectRightScale A d) :=
      oneNormRect_nonneg _
    have hcolBound :
        ∀ j : Fin n,
          |d j| * ch7RectColumnNorm1 A j ≤
            oneNormRect (ch7RectRightScale A d) := by
      intro j
      rw [← ch7RectRightScale_column_sum_abs A d j]
      exact col_sum_le_oneNormRect (ch7RectRightScale A d) j
    calc
      (∑ j : Fin n,
          |ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm1 A j)
            Aplus j k|)
          = ∑ j : Fin n,
              (|d j| * ch7RectColumnNorm1 A j) *
                |ch7RectLeftScale dInv Aplus j k| := by
            apply Finset.sum_congr rfl
            intro j _
            unfold ch7RectLeftScale
            have hprod :
                ch7RectColumnNorm1 A j * Aplus j k =
                  (d j * ch7RectColumnNorm1 A j) *
                    (dInv j * Aplus j k) := by
              calc
                ch7RectColumnNorm1 A j * Aplus j k =
                    (d j * dInv j) *
                      (ch7RectColumnNorm1 A j * Aplus j k) := by
                      rw [hdiag j]
                      ring
                _ = (d j * ch7RectColumnNorm1 A j) *
                    (dInv j * Aplus j k) := by
                      ring
            rw [hprod, abs_mul, abs_mul,
              abs_of_nonneg (ch7RectColumnNorm1_nonneg A j)]
      _ ≤ ∑ j : Fin n,
              oneNormRect (ch7RectRightScale A d) *
                |ch7RectLeftScale dInv Aplus j k| := by
            apply Finset.sum_le_sum
            intro j _
            exact mul_le_mul_of_nonneg_right
              (hcolBound j) (abs_nonneg _)
      _ = oneNormRect (ch7RectRightScale A d) *
            ∑ j : Fin n, |ch7RectLeftScale dInv Aplus j k| := by
            rw [Finset.mul_sum]
      _ ≤ oneNormRect (ch7RectRightScale A d) *
            oneNormRect (ch7RectLeftScale dInv Aplus) :=
          mul_le_mul_of_nonneg_left
            (col_sum_le_oneNormRect (ch7RectLeftScale dInv Aplus) k)
            hAD_nonneg
  · exact mul_nonneg (oneNormRect_nonneg _)
      (oneNormRect_nonneg _)

/-- Theorem 7.5, equation `(7.18)`, `p = 1` pairwise column-scaling
specialization.  Column equilibration has no larger 1-norm condition product
than any nonsingular diagonal right scaling, once the inverse-side matrix
`Aplus` is fixed. -/
theorem theorem7_5_p1_column_equilibration_le_right_scaling {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm1 A j)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7OneNormRightScaledCond A Aplus
        (ch7ColumnEquilibratingScale1 A)
        (fun j : Fin n => ch7RectColumnNorm1 A j) ≤
      ch7OneNormRightScaledCond A Aplus d dInv := by
  unfold ch7OneNormRightScaledCond
  have hADc :
      oneNormRect (ch7RectRightScale A (ch7ColumnEquilibratingScale1 A)) ≤ 1 :=
    eq_7_21_oneNormRect_column_equilibrated A hcol
  have hside :
      oneNormRect
          (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm1 A j) Aplus) ≤
        oneNormRect (ch7RectRightScale A d) *
          oneNormRect (ch7RectLeftScale dInv Aplus) :=
    eq_7_22_oneNormRect_inverseSide_bound A Aplus d dInv hdiag
  calc
    oneNormRect (ch7RectRightScale A (ch7ColumnEquilibratingScale1 A)) *
        oneNormRect
          (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm1 A j) Aplus)
        ≤ 1 *
            oneNormRect
              (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm1 A j) Aplus) :=
          mul_le_mul_of_nonneg_right hADc (oneNormRect_nonneg _)
    _ = oneNormRect
          (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm1 A j) Aplus) := by
          ring
    _ ≤ oneNormRect (ch7RectRightScale A d) *
          oneNormRect (ch7RectLeftScale dInv Aplus) := hside

/-- Theorem 7.5, `p = 1` infimum form over all reciprocal diagonal right
scalings for the explicit condition product `‖AD‖₁ ‖D⁻¹A⁺‖₁`.  This packages
the pairwise inequality as the source minimum/infimum statement for this
specialized model; it still does not assert a Moore-Penrose construction. -/
theorem theorem7_5_p1_column_equilibration_sInf_eq_right_scalings {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm1 A j) :
    sInf (ch7OneNormRightScaledCondSet A Aplus) =
      ch7OneNormRightScaledCond A Aplus
        (ch7ColumnEquilibratingScale1 A)
        (fun j : Fin n => ch7RectColumnNorm1 A j) := by
  let c : ℝ :=
    ch7OneNormRightScaledCond A Aplus
      (ch7ColumnEquilibratingScale1 A)
      (fun j : Fin n => ch7RectColumnNorm1 A j)
  let S : Set ℝ := ch7OneNormRightScaledCondSet A Aplus
  have hdiagC :
      ∀ j : Fin n,
        ch7ColumnEquilibratingScale1 A j *
          ch7RectColumnNorm1 A j = 1 := by
    intro j
    unfold ch7ColumnEquilibratingScale1
    field_simp [ne_of_gt (hcol j)]
  have hmem : c ∈ S := by
    dsimp [c, S]
    exact ch7OneNormRightScaledCond_mem_set A Aplus
      (ch7ColumnEquilibratingScale1 A)
      (fun j : Fin n => ch7RectColumnNorm1 A j) hdiagC
  have hS_nonempty : S.Nonempty := ⟨c, hmem⟩
  have hlower : ∀ κ : ℝ, κ ∈ S → c ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    exact theorem7_5_p1_column_equilibration_le_right_scaling
      A Aplus hcol d dInv hdiag
  have hbddBelow : BddBelow S := ⟨c, hlower⟩
  change sInf S = c
  exact le_antisymm (csInf_le hbddBelow hmem) (le_csInf hS_nonempty hlower)

/-- Theorem 7.5, `p = 1` minimum-attainment form over all reciprocal right
diagonal scalings in the explicit `Aplus` model.  The equilibrating column
scaling is a genuine least element of the condition-product value set, not
only an infimum value. -/
theorem theorem7_5_p1_column_equilibration_isLeast_right_scalings {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm1 A j) :
    IsLeast (ch7OneNormRightScaledCondSet A Aplus)
      (ch7OneNormRightScaledCond A Aplus
        (ch7ColumnEquilibratingScale1 A)
        (fun j : Fin n => ch7RectColumnNorm1 A j)) := by
  constructor
  · exact ch7OneNormRightScaledCond_mem_set A Aplus
      (ch7ColumnEquilibratingScale1 A)
      (fun j : Fin n => ch7RectColumnNorm1 A j) (by
        intro j
        unfold ch7ColumnEquilibratingScale1
        field_simp [ne_of_gt (hcol j)])
  · intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    exact theorem7_5_p1_column_equilibration_le_right_scaling
      A Aplus hcol d dInv hdiag

/-- Theorem 7.5, `p = 1` column minimum-attainment form with the source
full-column-rank side condition discharged by an explicit rectangular left
inverse witness `Aplus A = I`. -/
theorem theorem7_5_p1_column_equilibration_isLeast_right_scalings_of_rect_left_inverse
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) :
    IsLeast (ch7OneNormRightScaledCondSet A Aplus)
      (ch7OneNormRightScaledCond A Aplus
        (ch7ColumnEquilibratingScale1 A)
        (fun j : Fin n => ch7RectColumnNorm1 A j)) := by
  exact theorem7_5_p1_column_equilibration_isLeast_right_scalings A Aplus
    (ch7RectColumnNorm1_pos_of_rect_left_inverse A Aplus hleft)

/-- Coordinatewise multiplication by a bounded real vector is bounded on the
Euclidean norm. -/
lemma ch7_vecNorm2_mul_le_of_abs_le {n : ℕ}
    (s y : Fin n → ℝ) {B : ℝ}
    (hB : 0 ≤ B) (hs : ∀ j : Fin n, |s j| ≤ B) :
    vecNorm2 (fun j : Fin n => s j * y j) ≤ B * vecNorm2 y := by
  have habs :
      ∀ j : Fin n, |s j * y j| ≤ B * |y j| := by
    intro j
    rw [abs_mul]
    exact mul_le_mul_of_nonneg_right (hs j) (abs_nonneg (y j))
  calc
    vecNorm2 (fun j : Fin n => s j * y j)
        ≤ vecNorm2 (fun j : Fin n => B * |y j|) :=
          vecNorm2_le_of_abs_le (fun j : Fin n => s j * y j)
            (fun j : Fin n => B * |y j|) habs
    _ = |B| * vecNorm2 (fun j : Fin n => |y j|) := by
          rw [vecNorm2_smul]
    _ = B * vecNorm2 y := by
          rw [abs_of_nonneg hB, vecNorm2_abs]

/-- Left row-scaling a rectangular matrix by entries bounded by `B` multiplies
any Euclidean operator certificate by at most `B`. -/
theorem ch7RectLeftScale_rectOpNorm2Le_of_abs_le {m n : ℕ}
    (M : Fin n → Fin m → ℝ) (s : Fin n → ℝ) {B C : ℝ}
    (hB : 0 ≤ B) (hs : ∀ j : Fin n, |s j| ≤ B)
    (hM : rectOpNorm2Le M C) :
    rectOpNorm2Le (ch7RectLeftScale s M) (B * C) := by
  intro x
  let y : Fin n → ℝ := rectMatMulVec M x
  have hscaled :
      rectMatMulVec (ch7RectLeftScale s M) x =
        fun j : Fin n => s j * y j := by
    ext j
    unfold rectMatMulVec ch7RectLeftScale y
    calc
      (∑ k : Fin m, s j * M j k * x k)
          = ∑ k : Fin m, s j * (M j k * x k) := by
              apply Finset.sum_congr rfl
              intro k _
              ring
      _ = s j * ∑ k : Fin m, M j k * x k := by
              rw [Finset.mul_sum]
  calc
    vecNorm2 (rectMatMulVec (ch7RectLeftScale s M) x)
        = vecNorm2 (fun j : Fin n => s j * y j) := by rw [hscaled]
    _ ≤ B * vecNorm2 y :=
        ch7_vecNorm2_mul_le_of_abs_le s y hB hs
    _ ≤ B * (C * vecNorm2 x) :=
        mul_le_mul_of_nonneg_left (hM x) hB
    _ = (B * C) * vecNorm2 x := by ring

/-- Right column-scaling a rectangular matrix by entries bounded by `B`
multiplies any nonnegative Euclidean operator certificate by at most `B`. -/
theorem ch7RectRightScale_rectOpNorm2Le_of_abs_le {m n : ℕ}
    (M : Fin m → Fin n → ℝ) (s : Fin n → ℝ) {B C : ℝ}
    (hB : 0 ≤ B) (hC : 0 ≤ C) (hs : ∀ j : Fin n, |s j| ≤ B)
    (hM : rectOpNorm2Le M C) :
    rectOpNorm2Le (ch7RectRightScale M s) (C * B) := by
  intro x
  let y : Fin n → ℝ := fun j => s j * x j
  have hscaled :
      rectMatMulVec (ch7RectRightScale M s) x =
        rectMatMulVec M y := by
    ext i
    unfold rectMatMulVec ch7RectRightScale y
    apply Finset.sum_congr rfl
    intro j _
    ring
  calc
    vecNorm2 (rectMatMulVec (ch7RectRightScale M s) x)
        = vecNorm2 (rectMatMulVec M y) := by rw [hscaled]
    _ ≤ C * vecNorm2 y := hM y
    _ ≤ C * (B * vecNorm2 x) :=
        mul_le_mul_of_nonneg_left
          (ch7_vecNorm2_mul_le_of_abs_le s x hB hs) hC
    _ = (C * B) * vecNorm2 x := by ring

/-- Euclidean operator-2 condition product for the right-scaled rectangular
matrix and the corresponding inverse-side factor.  This is the `p = 2`
counterpart of `ch7OneNormRightScaledCond`, with `Aplus` kept explicit so the
statement does not assert a Moore-Penrose construction. -/
noncomputable def ch7Op2RightScaledCond {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) : ℝ :=
  complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale A d)) *
    complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale dInv Aplus))

/-- Values of the explicit Euclidean operator-2 condition product
`‖AD‖₂ ‖D⁻¹A⁺‖₂` over reciprocal nonsingular diagonal right scalings.  This is
the infimum model for the `p = 2` specialization of Theorem 7.5, with `Aplus`
kept explicit. -/
noncomputable def ch7Op2RightScaledCondSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin n → ℝ,
    (∀ j : Fin n, d j * dInv j = 1) ∧
    κ = ch7Op2RightScaledCond A Aplus d dInv}

/-- Absolute-sum-one slice of the explicit Euclidean right-scaling value set.
This is the normalized set used for compactness/attainment work; equality with
the unrestricted reciprocal value set is proved below for nonempty index sets. -/
noncomputable def ch7Op2RightScaledCondNormalizedSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin n → ℝ,
    (∀ j : Fin n, d j * dInv j = 1) ∧
    (∑ j : Fin n, |d j|) = 1 ∧
    κ = ch7Op2RightScaledCond A Aplus d dInv}

/-- Equivalent one-diagonal model of the normalized right-scaling value set:
the inverse diagonal is forced to be the pointwise reciprocal of `d`.  This is
the compactness-facing form used in the Theorem 7.5 minimizer route. -/
noncomputable def ch7Op2RightScaledCondReciprocalNormalizedSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d : Fin n → ℝ,
    (∀ j : Fin n, d j ≠ 0) ∧
    (∑ j : Fin n, |d j|) = 1 ∧
    κ = ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹)}

theorem ch7Op2RightScaledCond_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) :
    0 ≤ ch7Op2RightScaledCond A Aplus d dInv := by
  unfold ch7Op2RightScaledCond
  exact mul_nonneg (complexMatrixOp2_nonneg _) (complexMatrixOp2_nonneg _)

/-- The operator-2 right-scaling value set is nonempty: the identity scaling is
admissible. -/
theorem ch7Op2RightScaledCondSet_nonempty {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    (ch7Op2RightScaledCondSet A Aplus).Nonempty := by
  refine ⟨ch7Op2RightScaledCond A Aplus (fun _ => 1) (fun _ => 1), ?_⟩
  exact ⟨fun _ => 1, fun _ => 1, (by intro j; norm_num), rfl⟩

/-- Membership helper for the operator-2 right-scaling value set. -/
theorem ch7Op2RightScaledCond_mem_set {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7Op2RightScaledCond A Aplus d dInv ∈
      ch7Op2RightScaledCondSet A Aplus := by
  exact ⟨d, dInv, hdiag, rfl⟩

/-- The Euclidean right-scaling condition product is invariant under a global
rescaling of the diagonal factor and the reciprocal inverse rescaling.  This is
the normalization step needed before compactness/attainment arguments for the
`p = 2` specialization of Theorem 7.5. -/
theorem ch7Op2RightScaledCond_global_scale {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) {t : ℝ} (ht : t ≠ 0) :
    ch7Op2RightScaledCond A Aplus (fun j : Fin n => t * d j)
        (fun j : Fin n => t⁻¹ * dInv j) =
      ch7Op2RightScaledCond A Aplus d dInv := by
  have hright :
      realRectToCMatrix
          (ch7RectRightScale A (fun j : Fin n => t * d j)) =
        ((t : ℂ) • realRectToCMatrix (ch7RectRightScale A d) :
          Matrix (Fin m) (Fin n) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectRightScale]
    ring
  have hleft :
      realRectToCMatrix
          (ch7RectLeftScale (fun j : Fin n => t⁻¹ * dInv j) Aplus) =
        (((t : ℂ)⁻¹) • realRectToCMatrix (ch7RectLeftScale dInv Aplus) :
          Matrix (Fin n) (Fin m) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectLeftScale]
    ring
  have htC : (t : ℂ) ≠ 0 := by
    exact_mod_cast ht
  have hunit : ‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖ = 1 := by
    rw [norm_inv]
    exact mul_inv_cancel₀ (norm_ne_zero_iff.mpr htC)
  dsimp [ch7Op2RightScaledCond]
  rw [hright, hleft, complexMatrixOp2_smul, complexMatrixOp2_smul]
  let B : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale A d))
  let C : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale dInv Aplus))
  change (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C) = B * C
  calc
    (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C)
        = (‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖) * (B * C) := by ring
    _ = B * C := by rw [hunit]; ring

/-- A globally rescaled reciprocal diagonal pair gives an equivalent witness
for the Euclidean right-scaling condition value set. -/
theorem ch7Op2RightScaledCond_mem_set_global_scale {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) {t : ℝ}
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) (ht : t ≠ 0) :
    ch7Op2RightScaledCond A Aplus d dInv ∈
      ch7Op2RightScaledCondSet A Aplus := by
  refine ⟨fun j : Fin n => t * d j, fun j : Fin n => t⁻¹ * dInv j, ?_, ?_⟩
  · intro j
    calc
      (t * d j) * (t⁻¹ * dInv j)
          = (t * t⁻¹) * (d j * dInv j) := by ring
      _ = 1 := by rw [mul_inv_cancel₀ ht, hdiag j]; ring
  · exact (ch7Op2RightScaledCond_global_scale A Aplus d dInv ht).symm

/-- A reciprocal diagonal on a nonempty finite index set has strictly positive
sum of absolute diagonal entries. -/
lemma ch7_sum_abs_pos_of_reciprocal {n : ℕ} (hn : 0 < n)
    (d dInv : Fin n → ℝ) (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    0 < ∑ j : Fin n, |d j| := by
  let j0 : Fin n := ⟨0, hn⟩
  have hd0 : d j0 ≠ 0 := by
    intro hd
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hd] using hdiag j0
    norm_num at hcontr
  have hpos : 0 < |d j0| := abs_pos.mpr hd0
  have hle : |d j0| ≤ ∑ j : Fin n, |d j| := by
    exact Finset.single_le_sum (fun j _ => abs_nonneg (d j)) (Finset.mem_univ j0)
  exact lt_of_lt_of_le hpos hle

/-- On an absolute-sum-one diagonal slice, at least one coordinate has
magnitude at least the reciprocal of the number of coordinates. -/
lemma ch7_exists_inv_card_le_abs_of_sum_abs_eq_one {n : ℕ} (hn : 0 < n)
    (d : Fin n → ℝ) (hsum : (∑ j : Fin n, |d j|) = 1) :
    ∃ k : Fin n, (n : ℝ)⁻¹ ≤ |d k| := by
  have hnonempty : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  have hle : (∑ _k : Fin n, (n : ℝ)⁻¹) ≤ ∑ j : Fin n, |d j| := by
    rw [hsum]
    calc
      (∑ _k : Fin n, (n : ℝ)⁻¹) = (n : ℝ) * (n : ℝ)⁻¹ := by
        simp [Finset.sum_const, nsmul_eq_mul]
      _ = 1 := by
        exact mul_inv_cancel₀ (Nat.cast_ne_zero.mpr (ne_of_gt hn))
      _ ≤ 1 := le_rfl
  rcases Finset.exists_le_of_sum_le (s := Finset.univ)
      (f := fun _k : Fin n => (n : ℝ)⁻¹) (g := fun j : Fin n => |d j|)
      hnonempty hle with ⟨k, _hk_mem, hk⟩
  exact ⟨k, hk⟩

lemma ch7_left_factor_ne_zero_of_mul_eq_one {a b : ℝ} (h : a * b = 1) :
    a ≠ 0 := by
  intro ha
  have hcontr : (0 : ℝ) = 1 := by
    calc
      (0 : ℝ) = 0 * b := by ring
      _ = a * b := by rw [ha]
      _ = 1 := h
  norm_num at hcontr

/-- Normalize a reciprocal right diagonal pair to the absolute-sum-one slice
without changing the Euclidean condition product.  This is the concrete
compact-slice normalization used in the `p = 2` attainment route for
Theorem 7.5. -/
theorem ch7Op2RightScaledCond_sum_abs_normalized_witness {m n : ℕ}
    (hn : 0 < n) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    let s : ℝ := ∑ j : Fin n, |d j|
    (∀ j : Fin n, (s⁻¹ * d j) * (s * dInv j) = 1) ∧
      ch7Op2RightScaledCond A Aplus (fun j : Fin n => s⁻¹ * d j)
          (fun j : Fin n => s * dInv j) =
        ch7Op2RightScaledCond A Aplus d dInv ∧
      (∑ j : Fin n, |s⁻¹ * d j|) = 1 := by
  intro s
  have hspos : 0 < s := by
    simpa [s] using ch7_sum_abs_pos_of_reciprocal hn d dInv hdiag
  have hsne : s ≠ 0 := ne_of_gt hspos
  refine ⟨?_, ?_, ?_⟩
  · intro j
    calc
      (s⁻¹ * d j) * (s * dInv j)
          = (s⁻¹ * s) * (d j * dInv j) := by ring
      _ = 1 := by rw [inv_mul_cancel₀ hsne, hdiag j]; ring
  · simpa [inv_inv] using
      (ch7Op2RightScaledCond_global_scale A Aplus d dInv (t := s⁻¹)
        (inv_ne_zero hsne))
  · calc
      (∑ j : Fin n, |s⁻¹ * d j|)
          = ∑ j : Fin n, |s⁻¹| * |d j| := by
            apply Finset.sum_congr rfl
            intro j _
            rw [abs_mul]
      _ = |s⁻¹| * ∑ j : Fin n, |d j| := by
            rw [Finset.mul_sum]
      _ = s⁻¹ * s := by
            rw [abs_of_nonneg (inv_nonneg.mpr hspos.le)]
      _ = 1 := inv_mul_cancel₀ hsne

/-- On a nonempty right-scaling index type, the explicit p=2 reciprocal value
set is exactly its absolute-sum-one normalized slice. -/
theorem ch7Op2RightScaledCondSet_eq_sum_abs_normalized {m n : ℕ}
    (hn : 0 < n) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7Op2RightScaledCondSet A Aplus =
      ch7Op2RightScaledCondNormalizedSet A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    rcases ch7Op2RightScaledCond_sum_abs_normalized_witness
        hn A Aplus d dInv hdiag with
      ⟨hdiagN, hcondN, hsumN⟩
    refine ⟨fun j : Fin n => (∑ k : Fin n, |d k|)⁻¹ * d j,
      fun j : Fin n => (∑ k : Fin n, |d k|) * dInv j, hdiagN, hsumN, ?_⟩
    exact hcondN.symm
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, _hsum, rfl⟩
    exact ch7Op2RightScaledCond_mem_set A Aplus d dInv hdiag

/-- On a nonempty right-scaling index type, a least value for the unrestricted
explicit p=2 reciprocal value set is exactly a least value for the
absolute-sum-one normalized slice. -/
theorem ch7Op2RightScaledCondSet_isLeast_iff_sum_abs_normalized {m n : ℕ}
    (hn : 0 < n) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7Op2RightScaledCondSet A Aplus) μ ↔
      IsLeast (ch7Op2RightScaledCondNormalizedSet A Aplus) μ := by
  rw [ch7Op2RightScaledCondSet_eq_sum_abs_normalized hn A Aplus]

/-- The normalized right-scaling value set can be represented using only one
nonzero diagonal; the reciprocal side is then definitionally `(d j)⁻¹`. -/
theorem ch7Op2RightScaledCondNormalizedSet_eq_reciprocal_normalized {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7Op2RightScaledCondNormalizedSet A Aplus =
      ch7Op2RightScaledCondReciprocalNormalizedSet A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, hsum, rfl⟩
    have hdne : ∀ j : Fin n, d j ≠ 0 := by
      intro j
      exact ch7_left_factor_ne_zero_of_mul_eq_one (hdiag j)
    have hdInv : dInv = fun j : Fin n => (d j)⁻¹ := by
      funext j
      exact eq_inv_of_mul_eq_one_right (hdiag j)
    refine ⟨d, hdne, hsum, ?_⟩
    simp [hdInv]
  · intro hκ
    rcases hκ with ⟨d, hdne, hsum, rfl⟩
    refine ⟨d, (fun j : Fin n => (d j)⁻¹), ?_, hsum, rfl⟩
    intro j
    exact mul_inv_cancel₀ (hdne j)

/-- Least-value certificates are unchanged by replacing the explicit inverse
diagonal by the pointwise reciprocal in the normalized right-scaling set. -/
theorem ch7Op2RightScaledCondNormalizedSet_isLeast_iff_reciprocal_normalized
    {m n : ℕ} (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7Op2RightScaledCondNormalizedSet A Aplus) μ ↔
      IsLeast (ch7Op2RightScaledCondReciprocalNormalizedSet A Aplus) μ := by
  rw [ch7Op2RightScaledCondNormalizedSet_eq_reciprocal_normalized A Aplus]

/-- On any set where the right scaling diagonal stays nonzero coordinatewise,
the reciprocal one-diagonal `p = 2` condition product is continuous. -/
theorem continuousOn_ch7Op2RightScaledCond_reciprocal {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (s : Set (Fin n → ℝ)) (h0 : ∀ d ∈ s, ∀ j : Fin n, d j ≠ 0) :
    ContinuousOn (fun d : Fin n → ℝ =>
      ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹)) s := by
  have hAD : Continuous fun d : Fin n → ℝ =>
      complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale A d)) :=
    (continuous_complexMatrixOp2 (m := m) (n := n)).comp
      (continuous_realRectToCMatrix_ch7RectRightScale A)
  have hAplusMat : ContinuousOn (fun d : Fin n → ℝ =>
      realRectToCMatrix (ch7RectLeftScale (fun j : Fin n => (d j)⁻¹) Aplus)) s := by
    rw [continuousOn_pi]
    intro i
    rw [continuousOn_pi]
    intro j
    have hinv : ContinuousOn (fun d : Fin n → ℝ => (d i)⁻¹) s :=
      (continuous_apply i).continuousOn.inv₀ (fun d hd => h0 d hd i)
    have hcoord : ContinuousOn (fun d : Fin n → ℝ => (d i)⁻¹ * Aplus i j) s :=
      hinv.mul continuous_const.continuousOn
    simpa [realRectToCMatrix, ch7RectLeftScale, Function.comp_def] using
      Complex.continuous_ofReal.comp_continuousOn hcoord
  have hAplus : ContinuousOn (fun d : Fin n → ℝ =>
      complexMatrixOp2
        (realRectToCMatrix (ch7RectLeftScale (fun j : Fin n => (d j)⁻¹) Aplus))) s :=
    (continuous_complexMatrixOp2 (m := n) (n := m)).comp_continuousOn hAplusMat
  have hprod : ContinuousOn (fun d : Fin n → ℝ =>
      complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale A d)) *
        complexMatrixOp2
          (realRectToCMatrix (ch7RectLeftScale (fun j : Fin n => (d j)⁻¹) Aplus))) s :=
    hAD.continuousOn.mul hAplus
  simpa [ch7Op2RightScaledCond] using hprod

/-- The operator-2 right-scaling value set is bounded below by zero. -/
theorem ch7Op2RightScaledCondSet_bddBelow {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    BddBelow (ch7Op2RightScaledCondSet A Aplus) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
  exact ch7Op2RightScaledCond_nonneg A Aplus d dInv

/-- The infimum of the explicit operator-2 right-scaling condition products is
nonnegative, since every admissible value is a product of operator norms. -/
theorem ch7Op2RightScaledCondSet_sInf_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    0 ≤ sInf (ch7Op2RightScaledCondSet A Aplus) := by
  let S : Set ℝ := ch7Op2RightScaledCondSet A Aplus
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7Op2RightScaledCondSet_nonempty A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
    exact ch7Op2RightScaledCond_nonneg A Aplus d dInv
  exact le_csInf hS_nonempty hlower

/-- Equation `(7.22)`, `p = 2` operator-2 analogue.  The proof uses only the
column operator certificate for `AD`, a diagonal inverse relation, and the
Euclidean norm bound for row scaling. -/
theorem eq_7_22_op2_inverseSide_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    complexMatrixOp2
        (realRectToCMatrix
          (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm2 A j) Aplus)) ≤
      complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale A d)) *
        complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale dInv Aplus)) := by
  let B : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale A d))
  let C : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale dInv Aplus))
  have hB_nonneg : 0 ≤ B := by
    dsimp [B]
    exact complexMatrixOp2_nonneg _
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact complexMatrixOp2_nonneg _
  have hAD :
      rectOpNorm2Le (ch7RectRightScale A d) B :=
    rectOpNorm2Le_of_complexMatrixOp2_realRectToCMatrix_le
      (ch7RectRightScale A d) le_rfl
  have hside :
      rectOpNorm2Le (ch7RectLeftScale dInv Aplus) C :=
    rectOpNorm2Le_of_complexMatrixOp2_realRectToCMatrix_le
      (ch7RectLeftScale dInv Aplus) le_rfl
  have hfactor :
      ∀ j : Fin n, |d j * ch7RectColumnNorm2 A j| ≤ B := by
    intro j
    have hcol :=
      eq_7_20_column_norm_le_of_rectOpNorm2Le
        (ch7RectRightScale A d) hAD j
    rw [ch7RectColumnNorm2_rightScale_eq] at hcol
    simpa [abs_mul, abs_of_nonneg (ch7RectColumnNorm2_nonneg A j)] using hcol
  have hrewrite :
      ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm2 A j) Aplus =
        ch7RectLeftScale (fun j : Fin n => d j * ch7RectColumnNorm2 A j)
          (ch7RectLeftScale dInv Aplus) := by
    ext j k
    unfold ch7RectLeftScale
    calc
      ch7RectColumnNorm2 A j * Aplus j k =
          (d j * dInv j) * (ch7RectColumnNorm2 A j * Aplus j k) := by
            rw [hdiag j]
            ring
      _ = (d j * ch7RectColumnNorm2 A j) * (dInv j * Aplus j k) := by
            ring
  have htarget :
      rectOpNorm2Le
        (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm2 A j) Aplus)
        (B * C) := by
    rw [hrewrite]
    exact ch7RectLeftScale_rectOpNorm2Le_of_abs_le
      (ch7RectLeftScale dInv Aplus)
      (fun j : Fin n => d j * ch7RectColumnNorm2 A j)
      hB_nonneg hfactor hside
  have htargetC :
      complexMatrixOp2
          (realRectToCMatrix
            (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm2 A j) Aplus)) ≤
        B * C :=
    complexMatrixOp2_realRectToCMatrix_le_of_rectOpNorm2Le
      (ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm2 A j) Aplus)
      (mul_nonneg hB_nonneg hC_nonneg) htarget
  simpa [B, C] using htargetC

/-- Theorem 7.5, equation `(7.18)`, `p = 2` pairwise column-equilibration
specialization.  Column equilibration is within the source factor `sqrt(n)` of
any nonsingular diagonal right scaling, for a fixed explicit inverse-side
matrix `Aplus`. -/
theorem theorem7_5_p2_column_equilibration_le_sqrt_card_right_scaling {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7Op2RightScaledCond A Aplus
        (ch7ColumnEquilibratingScale2 A)
        (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
      Real.sqrt (n : ℝ) * ch7Op2RightScaledCond A Aplus d dInv := by
  unfold ch7Op2RightScaledCond
  let ADc : Fin m → Fin n → ℝ :=
    ch7RectRightScale A (ch7ColumnEquilibratingScale2 A)
  let AplusDcInv : Fin n → Fin m → ℝ :=
    ch7RectLeftScale (fun j : Fin n => ch7RectColumnNorm2 A j) Aplus
  let AD : Fin m → Fin n → ℝ := ch7RectRightScale A d
  let DinvAplus : Fin n → Fin m → ℝ := ch7RectLeftScale dInv Aplus
  have hADc :
      complexMatrixOp2 (realRectToCMatrix ADc) ≤ Real.sqrt (n : ℝ) :=
    complexMatrixOp2_realRectToCMatrix_le_of_rectOpNorm2Le ADc
      (Real.sqrt_nonneg _)
      (by
        dsimp [ADc]
        exact eq_7_21_rectOpNorm2Le_column_equilibrated A hcol)
  have hside :
      complexMatrixOp2 (realRectToCMatrix AplusDcInv) ≤
        complexMatrixOp2 (realRectToCMatrix AD) *
          complexMatrixOp2 (realRectToCMatrix DinvAplus) := by
    dsimp [AplusDcInv, AD, DinvAplus]
    exact eq_7_22_op2_inverseSide_bound A Aplus d dInv hdiag
  have hAplusDcInv_nonneg :
      0 ≤ complexMatrixOp2 (realRectToCMatrix AplusDcInv) :=
    complexMatrixOp2_nonneg _
  calc
    complexMatrixOp2 (realRectToCMatrix ADc) *
        complexMatrixOp2 (realRectToCMatrix AplusDcInv)
        ≤ Real.sqrt (n : ℝ) *
            complexMatrixOp2 (realRectToCMatrix AplusDcInv) :=
          mul_le_mul_of_nonneg_right hADc hAplusDcInv_nonneg
    _ ≤ Real.sqrt (n : ℝ) *
          (complexMatrixOp2 (realRectToCMatrix AD) *
            complexMatrixOp2 (realRectToCMatrix DinvAplus)) :=
          mul_le_mul_of_nonneg_left hside (Real.sqrt_nonneg _)
    _ = Real.sqrt (n : ℝ) *
          (complexMatrixOp2 (realRectToCMatrix AD) *
            complexMatrixOp2 (realRectToCMatrix DinvAplus)) := rfl

/-- Theorem 7.5, equation `(7.18)`, `p = 2` infimum form over reciprocal
diagonal right scalings for the explicit condition product.  It packages the
pairwise estimate as
`κ₂(AD_C) ≤ sqrt(n) inf_D ‖AD‖₂ ‖D⁻¹A⁺‖₂`, while keeping the still-open
Moore-Penrose/general-`p` source theorem separate. -/
theorem theorem7_5_p2_column_equilibration_le_sqrt_card_sInf_right_scalings
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j) :
    ch7Op2RightScaledCond A Aplus
        (ch7ColumnEquilibratingScale2 A)
        (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
      Real.sqrt (n : ℝ) * sInf (ch7Op2RightScaledCondSet A Aplus) := by
  let c : ℝ :=
    ch7Op2RightScaledCond A Aplus
      (ch7ColumnEquilibratingScale2 A)
      (fun j : Fin n => ch7RectColumnNorm2 A j)
  let S : Set ℝ := ch7Op2RightScaledCondSet A Aplus
  let α : ℝ := Real.sqrt (n : ℝ)
  have hnR : 0 < (n : ℝ) := by exact_mod_cast hn
  have hαpos : 0 < α := by
    dsimp [α]
    exact Real.sqrt_pos.2 hnR
  have hαnonneg : 0 ≤ α := le_of_lt hαpos
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7Op2RightScaledCondSet_nonempty A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → c / α ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    have hpair :
        c ≤ α * ch7Op2RightScaledCond A Aplus d dInv := by
      dsimp [c, α]
      exact theorem7_5_p2_column_equilibration_le_sqrt_card_right_scaling
        A Aplus hcol d dInv hdiag
    rw [div_le_iff₀ hαpos]
    simpa [mul_comm] using hpair
  have hsInf : c / α ≤ sInf S := le_csInf hS_nonempty hlower
  have hmul : α * (c / α) ≤ α * sInf S :=
    mul_le_mul_of_nonneg_left hsInf hαnonneg
  have hrewrite : α * (c / α) = c := by
    field_simp [ne_of_gt hαpos]
  change c ≤ α * sInf S
  exact hrewrite ▸ hmul

/-- Theorem 7.5, `p = 2` column form with the source `min` value made
explicit.  The theorem does not prove that the non-endpoint value set attains
its infimum; it converts such an `IsLeast` certificate into the book's
minimum-value inequality. -/
theorem theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j) {μ : ℝ}
    (hmin : IsLeast (ch7Op2RightScaledCondSet A Aplus) μ) :
    ch7Op2RightScaledCond A Aplus
        (ch7ColumnEquilibratingScale2 A)
        (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
      Real.sqrt (n : ℝ) * μ := by
  simpa [hmin.csInf_eq] using
    theorem7_5_p2_column_equilibration_le_sqrt_card_sInf_right_scalings
      hn A Aplus hcol

/-- Theorem 7.5, `p = 2` column source-`min` wrapper using a least-value
certificate on the absolute-sum-one normalized slice.  This is the normalized
form needed by the compact-slice minimizer route. -/
theorem theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings_of_normalized
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j) {μ : ℝ}
    (hmin : IsLeast (ch7Op2RightScaledCondNormalizedSet A Aplus) μ) :
    ch7Op2RightScaledCond A Aplus
        (ch7ColumnEquilibratingScale2 A)
        (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
      Real.sqrt (n : ℝ) * μ := by
  exact theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings
    hn A Aplus hcol
    ((ch7Op2RightScaledCondSet_isLeast_iff_sum_abs_normalized
      hn A Aplus).mpr hmin)

/-- Theorem 7.5, `p = 2` column infimum form with the source
full-column-rank side condition discharged by an explicit rectangular left
inverse witness `Aplus A = I`. -/
theorem theorem7_5_p2_column_equilibration_le_sqrt_card_sInf_right_scalings_of_rect_left_inverse
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) :
    ch7Op2RightScaledCond A Aplus
        (ch7ColumnEquilibratingScale2 A)
        (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
      Real.sqrt (n : ℝ) * sInf (ch7Op2RightScaledCondSet A Aplus) := by
  exact theorem7_5_p2_column_equilibration_le_sqrt_card_sInf_right_scalings hn
    A Aplus (ch7RectColumnNorm2_pos_of_rect_left_inverse A Aplus hleft)

/-- Theorem 7.5, `p = 2` column minimum-value wrapper with the source
full-column-rank side condition discharged by an explicit rectangular left
inverse witness. -/
theorem theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings_of_rect_left_inverse
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0)
    {μ : ℝ} (hmin : IsLeast (ch7Op2RightScaledCondSet A Aplus) μ) :
    ch7Op2RightScaledCond A Aplus
        (ch7ColumnEquilibratingScale2 A)
        (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
      Real.sqrt (n : ℝ) * μ := by
  exact theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings
    hn A Aplus (ch7RectColumnNorm2_pos_of_rect_left_inverse A Aplus hleft)
    hmin

/-- Theorem 7.5, `p = 2` column normalized-slice minimum wrapper with the
source full-column-rank side condition discharged by an explicit rectangular
left inverse witness. -/
theorem theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings_of_rect_left_inverse_of_normalized
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0)
    {μ : ℝ} (hmin : IsLeast (ch7Op2RightScaledCondNormalizedSet A Aplus) μ) :
    ch7Op2RightScaledCond A Aplus
        (ch7ColumnEquilibratingScale2 A)
        (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
      Real.sqrt (n : ℝ) * μ := by
  exact theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings_of_normalized
    hn A Aplus (ch7RectColumnNorm2_pos_of_rect_left_inverse A Aplus hleft)
    hmin

/-- Matrix `p`-norm nonnegativity for the finite-real source-facing wrapper. -/
lemma ch7_complexMatrixLpNormOfReal_nonneg {m n : ℕ} (hn : 0 < n)
    {p : ℝ} (hp : 1 ≤ p) (A : CMatrix m n) :
    0 ≤ complexMatrixLpNormOfReal hn p hp A := by
  have hvalue :=
    complexMatrixLpNormOfReal_isComplexMatrixLpNormValue hn p hp A
  exact (hasComplexMatrixLpBound_of_complexMatrixLpNormValue_ofReal
    (m := m) (n := n) hn hp hvalue).1

/-- Matrix-vector multiplication by an entrywise scalar multiple is the
corresponding scalar multiple of the matrix-vector map. -/
lemma ch7_complexMatrixVecMul_smul {m n : ℕ} (z : ℂ) (A : CMatrix m n) :
    complexMatrixVecMul ((z • A : Matrix (Fin m) (Fin n) ℂ) : CMatrix m n) =
      complexVectorMapSMul z (complexMatrixVecMul A) := by
  ext x i
  unfold complexMatrixVecMul complexVectorMapSMul complexVecSMul
  calc
    (∑ j : Fin n, (z • A : Matrix (Fin m) (Fin n) ℂ) i j * x j)
        = ∑ j : Fin n, z * (A i j * x j) := by
          apply Finset.sum_congr rfl
          intro j _
          simp
          ring
    _ = z * ∑ j : Fin n, A i j * x j := by
          rw [Finset.mul_sum]

/-- The chosen finite-real matrix `p`-norm is homogeneous under a nonzero
complex scalar.  This is proved from the least-bound predicate rather than
from any topological representation of the norm. -/
theorem ch7_complexMatrixLpNormOfReal_smul {m n : ℕ} (hn : 0 < n)
    {p : ℝ} (hp : 1 ≤ p) {z : ℂ} (hz : z ≠ 0) (A : CMatrix m n) :
    complexMatrixLpNormOfReal hn p hp
        ((z • A : Matrix (Fin m) (Fin n) ℂ) : CMatrix m n) =
      ‖z‖ * complexMatrixLpNormOfReal hn p hp A := by
  haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hp⟩
  let νsrc : CVec n → ℝ := complexVecLpNorm (n := n) (ENNReal.ofReal p)
  let νtgt : CVec m → ℝ := complexVecLpNorm (n := m) (ENNReal.ofReal p)
  let N : ℝ := complexMatrixLpNormOfReal hn p hp A
  let Nz : ℝ := complexMatrixLpNormOfReal hn p hp
    ((z • A : Matrix (Fin m) (Fin n) ℂ) : CMatrix m n)
  have hνtgt : IsComplexVectorNorm νtgt :=
    complexVecLpNorm_isComplexVectorNorm (n := m) (ENNReal.ofReal p)
  have hAvalue :
      IsMixedSubordinateNormValue νsrc νtgt (complexMatrixVecMul A) N := by
    simpa [N, νsrc, νtgt, IsComplexMatrixLpNormValue,
      IsMixedSubordinateMatrixNormValue] using
      complexMatrixLpNormOfReal_isComplexMatrixLpNormValue
        (m := m) (n := n) hn p hp A
  have hZAvalue :
      IsMixedSubordinateNormValue νsrc νtgt
        (complexMatrixVecMul
          (((z • A : Matrix (Fin m) (Fin n) ℂ) : CMatrix m n))) Nz := by
    simpa [Nz, νsrc, νtgt, IsComplexMatrixLpNormValue,
      IsMixedSubordinateMatrixNormValue] using
      complexMatrixLpNormOfReal_isComplexMatrixLpNormValue
        (m := m) (n := n) hn p hp
        (((z • A : Matrix (Fin m) (Fin n) ℂ) : CMatrix m n))
  have hZAvalue_smul :
      IsMixedSubordinateNormValue νsrc νtgt
        (complexVectorMapSMul z (complexMatrixVecMul A)) Nz := by
    simpa [ch7_complexMatrixVecMul_smul z A] using hZAvalue
  have hle_forward : Nz ≤ ‖z‖ * N :=
    mixedSubordinateNormValue_smul_le hνtgt z hZAvalue_smul hAvalue
  have hZA_inv :
      complexMatrixVecMul A =
        complexVectorMapSMul z⁻¹
          (complexMatrixVecMul
            (((z • A : Matrix (Fin m) (Fin n) ℂ) : CMatrix m n))) := by
    ext x i
    unfold complexMatrixVecMul complexVectorMapSMul complexVecSMul
    calc
      ∑ j : Fin n, A i j * x j
          = z⁻¹ * (z * ∑ j : Fin n, A i j * x j) := by
            calc
              ∑ j : Fin n, A i j * x j =
                  1 * ∑ j : Fin n, A i j * x j := by ring
              _ = (z⁻¹ * z) * ∑ j : Fin n, A i j * x j := by
                    rw [inv_mul_cancel₀ hz]
              _ = z⁻¹ * (z * ∑ j : Fin n, A i j * x j) := by ring
      _ = z⁻¹ *
            (∑ j : Fin n,
              (z • A : Matrix (Fin m) (Fin n) ℂ) i j * x j) := by
            congr 1
            calc
              z * ∑ j : Fin n, A i j * x j
                  = ∑ j : Fin n, z * (A i j * x j) := by
                    rw [Finset.mul_sum]
              _ = ∑ j : Fin n,
                    (z • A : Matrix (Fin m) (Fin n) ℂ) i j * x j := by
                    apply Finset.sum_congr rfl
                    intro j _
                    simp
                    ring
  have hAvalue_inv_smul :
      IsMixedSubordinateNormValue νsrc νtgt
        (complexVectorMapSMul z⁻¹
          (complexMatrixVecMul
            (((z • A : Matrix (Fin m) (Fin n) ℂ) : CMatrix m n)))) N := by
    simpa [hZA_inv] using hAvalue
  have hle_reverse_raw : N ≤ ‖z⁻¹‖ * Nz :=
    mixedSubordinateNormValue_smul_le hνtgt z⁻¹ hAvalue_inv_smul hZAvalue
  have hz_norm_pos : 0 < ‖z‖ := norm_pos_iff.mpr hz
  have hle_reverse : ‖z‖ * N ≤ Nz := by
    calc
      ‖z‖ * N ≤ ‖z‖ * (‖z⁻¹‖ * Nz) :=
        mul_le_mul_of_nonneg_left hle_reverse_raw (norm_nonneg z)
      _ = Nz := by
        rw [norm_inv]
        calc
          ‖z‖ * (‖z‖⁻¹ * Nz) =
              (‖z‖ * ‖z‖⁻¹) * Nz := by ring
          _ = Nz := by rw [mul_inv_cancel₀ (ne_of_gt hz_norm_pos)]; ring
  exact le_antisymm hle_forward hle_reverse

/-- Coordinatewise multiplication by a bounded complex vector is bounded on
finite-real complex `Lp` norms. -/
lemma ch7_complexVecLpNormOfReal_diagScale_le_of_norm_le {n : ℕ}
    {p B : ℝ} (hp : 1 ≤ p) (hB : 0 ≤ B)
    (s : Fin n → ℂ) (y : CVec n)
    (hs : ∀ j : Fin n, ‖s j‖ ≤ B) :
    complexVecLpNorm (n := n) (ENNReal.ofReal p) (fun j : Fin n => s j * y j) ≤
      B * complexVecLpNorm (n := n) (ENNReal.ofReal p) y := by
  haveI : Fact (1 ≤ ENNReal.ofReal p) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hp⟩
  let ν : CVec n → ℝ := complexVecLpNorm (n := n) (ENNReal.ofReal p)
  have hν : IsComplexVectorNorm ν :=
    complexVecLpNorm_isComplexVectorNorm (n := n) (ENNReal.ofReal p)
  have hmono : IsMonotoneComplexVectorNorm ν := by
    simpa [ν] using complexVecLpNorm_ofReal_monotone (n := n) (p := p) hp
  have hcomponent :
      componentwiseAbsLe (fun j : Fin n => s j * y j)
        (complexVecSMul (B : ℂ) y) := by
    intro j
    calc
      ‖s j * y j‖ = ‖s j‖ * ‖y j‖ := norm_mul _ _
      _ ≤ B * ‖y j‖ :=
            mul_le_mul_of_nonneg_right (hs j) (norm_nonneg _)
      _ = ‖(B : ℂ) * y j‖ := by
            rw [norm_mul, Complex.norm_of_nonneg hB]
      _ = ‖complexVecSMul (B : ℂ) y j‖ := by
            rfl
  calc
    ν (fun j : Fin n => s j * y j)
        ≤ ν (complexVecSMul (B : ℂ) y) :=
          hmono _ _ hcomponent
    _ = B * ν y := by
          have hsmul := hν.smul (B : ℂ) y
          rw [Complex.norm_of_nonneg hB] at hsmul
          simpa [ν] using hsmul

/-- Equation `(7.22)`, finite-real `p` inverse-side bound.  The proof uses
the lower side of `(7.20)` for `AD`, the reciprocal diagonal relation, and the
finite-real `Lp` diagonal multiplier bound above. -/
theorem eq_7_22_matrixLpNormOfReal_inverseSide_bound {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    complexMatrixLpNormOfReal hm p hp
        (realRectToCMatrix
          (ch7RectLeftScale (fun j : Fin n => ch7RectColumnLpNormOfReal p A j)
            Aplus)) ≤
      complexMatrixLpNormOfReal hn p hp
          (realRectToCMatrix (ch7RectRightScale A d)) *
        complexMatrixLpNormOfReal hm p hp
          (realRectToCMatrix (ch7RectLeftScale dInv Aplus)) := by
  let B : ℝ :=
    complexMatrixLpNormOfReal hn p hp
      (realRectToCMatrix (ch7RectRightScale A d))
  let C : ℝ :=
    complexMatrixLpNormOfReal hm p hp
      (realRectToCMatrix (ch7RectLeftScale dInv Aplus))
  let target : Fin n → Fin m → ℝ :=
    ch7RectLeftScale (fun j : Fin n => ch7RectColumnLpNormOfReal p A j) Aplus
  let side : Fin n → Fin m → ℝ := ch7RectLeftScale dInv Aplus
  have hB_nonneg : 0 ≤ B := by
    dsimp [B]
    exact ch7_complexMatrixLpNormOfReal_nonneg hn hp _
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact ch7_complexMatrixLpNormOfReal_nonneg hm hp _
  have htargetValue :
      IsComplexMatrixLpNormValue (ENNReal.ofReal p) (realRectToCMatrix target)
        (complexMatrixLpNormOfReal hm p hp (realRectToCMatrix target)) := by
    exact complexMatrixLpNormOfReal_isComplexMatrixLpNormValue
      (m := n) (n := m) hm p hp (realRectToCMatrix target)
  have hsideValue :
      IsComplexMatrixLpNormValue (ENNReal.ofReal p) (realRectToCMatrix side) C := by
    simpa [C, side] using
      complexMatrixLpNormOfReal_isComplexMatrixLpNormValue
        (m := n) (n := m) hm p hp (realRectToCMatrix side)
  have hsideBound : HasComplexMatrixLpBound (ENNReal.ofReal p)
      (realRectToCMatrix side) C :=
    hasComplexMatrixLpBound_of_complexMatrixLpNormValue_ofReal
      (m := n) (n := m) hm hp hsideValue
  have hfactor :
      ∀ j : Fin n,
        ‖(d j : ℂ)‖ * ch7RectColumnLpNormOfReal p A j ≤ B := by
    intro j
    have hcol :=
      eq_7_20_column_lpNorm_le_matrixLpNormOfReal
        (m := m) (n := n) hn hp (ch7RectRightScale A d) j
    rw [ch7RectColumnLpNormOfReal_rightScale hp A d j] at hcol
    simpa [B] using hcol
  have hdiagFactor :
      ∀ j : Fin n,
        ‖(d j : ℂ) * (ch7RectColumnLpNormOfReal p A j : ℂ)‖ ≤ B := by
    intro j
    rw [norm_mul,
      Complex.norm_of_nonneg (ch7RectColumnLpNormOfReal_nonneg hp A j)]
    exact hfactor j
  have hrewrite :
      target =
        ch7RectLeftScale
          (fun j : Fin n => d j * ch7RectColumnLpNormOfReal p A j) side := by
    ext j k
    dsimp [target, side, ch7RectLeftScale]
    calc
      ch7RectColumnLpNormOfReal p A j * Aplus j k =
          (d j * dInv j) * (ch7RectColumnLpNormOfReal p A j * Aplus j k) := by
            rw [hdiag j]
            ring
      _ = (d j * ch7RectColumnLpNormOfReal p A j) * (dInv j * Aplus j k) := by
            ring
  have htargetBound : HasComplexMatrixLpBound (ENNReal.ofReal p)
      (realRectToCMatrix target) (B * C) := by
    refine hasComplexMatrixLpBound_of_nonneg_mixedSubordinateMatrixBound
      (mul_nonneg hB_nonneg hC_nonneg) ?_
    intro x
    have hvec :
        complexMatrixVecMul
            (realRectToCMatrix
              (ch7RectLeftScale
                (fun j : Fin n => d j * ch7RectColumnLpNormOfReal p A j) side)) x =
          fun j : Fin n =>
            ((d j : ℂ) * (ch7RectColumnLpNormOfReal p A j : ℂ)) *
              complexMatrixVecMul (realRectToCMatrix side) x j := by
      ext j
      unfold complexMatrixVecMul realRectToCMatrix ch7RectLeftScale side
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro k _
      rw [show
        ((d j * ch7RectColumnLpNormOfReal p A j *
            ch7RectLeftScale dInv Aplus j k : ℝ) : ℂ) =
          (d j : ℂ) * (ch7RectColumnLpNormOfReal p A j : ℂ) *
            (ch7RectLeftScale dInv Aplus j k : ℂ) by
        rw [Complex.ofReal_mul, Complex.ofReal_mul]]
      ring_nf
    calc
      complexVecLpNorm (ENNReal.ofReal p)
          (complexMatrixVecMul (realRectToCMatrix target) x)
          = complexVecLpNorm (ENNReal.ofReal p)
              (complexMatrixVecMul
                (realRectToCMatrix
                  (ch7RectLeftScale
                    (fun j : Fin n => d j * ch7RectColumnLpNormOfReal p A j)
                    side)) x) := by
                rw [hrewrite]
      _ = complexVecLpNorm (ENNReal.ofReal p)
            (fun j : Fin n =>
              ((d j : ℂ) * (ch7RectColumnLpNormOfReal p A j : ℂ)) *
                complexMatrixVecMul (realRectToCMatrix side) x j) := by
                rw [hvec]
      _ ≤ B * complexVecLpNorm (ENNReal.ofReal p)
            (complexMatrixVecMul (realRectToCMatrix side) x) :=
          ch7_complexVecLpNormOfReal_diagScale_le_of_norm_le
            (n := n) hp hB_nonneg
            (fun j : Fin n =>
              (d j : ℂ) * (ch7RectColumnLpNormOfReal p A j : ℂ))
            (complexMatrixVecMul (realRectToCMatrix side) x)
            hdiagFactor
      _ ≤ B * (C * complexVecLpNorm (ENNReal.ofReal p) x) :=
          mul_le_mul_of_nonneg_left (hsideBound.2 x) hB_nonneg
      _ = (B * C) * complexVecLpNorm (ENNReal.ofReal p) x := by ring
  simpa [B, C, target, side] using
    isComplexMatrixLpNormValue_le_of_hasComplexMatrixLpBound
      htargetValue htargetBound

/-- Finite-real `p` condition product for a right diagonal scaling and an
explicit inverse-side matrix. -/
noncomputable def ch7LpRightScaledCondOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) : ℝ :=
  complexMatrixLpNormOfReal hn p hp (realRectToCMatrix (ch7RectRightScale A d)) *
    complexMatrixLpNormOfReal hm p hp (realRectToCMatrix (ch7RectLeftScale dInv Aplus))

/-- Values of the finite-real `p` right-scaling condition product over
reciprocal nonsingular diagonal right scalings. -/
noncomputable def ch7LpRightScaledCondSetOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin n → ℝ,
    (∀ j : Fin n, d j * dInv j = 1) ∧
    κ = ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv}

/-- Finite-real `p` right-scaling value set restricted to the
absolute-sum-one diagonal slice. -/
noncomputable def ch7LpRightScaledCondNormalizedSetOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin n → ℝ,
    (∀ j : Fin n, d j * dInv j = 1) ∧
    (∑ j : Fin n, |d j|) = 1 ∧
    κ = ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv}

/-- Finite-real `p` right-scaling normalized value set represented with a
single nonzero diagonal and the pointwise reciprocal inverse side. -/
noncomputable def ch7LpRightScaledCondReciprocalNormalizedSetOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d : Fin n → ℝ,
    (∀ j : Fin n, d j ≠ 0) ∧
    (∑ j : Fin n, |d j|) = 1 ∧
    κ = ch7LpRightScaledCondOfReal hm hn p hp A Aplus d
      (fun j : Fin n => (d j)⁻¹)}

theorem ch7LpRightScaledCondOfReal_nonneg {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) :
    0 ≤ ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv := by
  unfold ch7LpRightScaledCondOfReal
  exact mul_nonneg
    (ch7_complexMatrixLpNormOfReal_nonneg hn hp _)
    (ch7_complexMatrixLpNormOfReal_nonneg hm hp _)

/-- Membership helper for the finite-real `p` right-scaling value set. -/
theorem ch7LpRightScaledCondOfReal_mem_set {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv ∈
      ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus := by
  exact ⟨d, dInv, hdiag, rfl⟩

/-- The finite-real `p` right-scaling value set is nonempty. -/
theorem ch7LpRightScaledCondSetOfReal_nonempty {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    (ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus).Nonempty := by
  refine ⟨ch7LpRightScaledCondOfReal hm hn p hp A Aplus (fun _ => 1) (fun _ => 1), ?_⟩
  exact ch7LpRightScaledCondOfReal_mem_set hm hn hp A Aplus
    (fun _ => 1) (fun _ => 1) (by intro j; norm_num)

/-- The finite-real `p` right-scaling condition product is invariant under a
global nonzero rescaling of the diagonal and reciprocal inverse diagonal. -/
theorem ch7LpRightScaledCondOfReal_global_scale {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ) {t : ℝ} (ht : t ≠ 0) :
    ch7LpRightScaledCondOfReal hm hn p hp A Aplus
        (fun j : Fin n => t * d j) (fun j : Fin n => t⁻¹ * dInv j) =
      ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv := by
  have hright :
      realRectToCMatrix
          (ch7RectRightScale A (fun j : Fin n => t * d j)) =
        ((t : ℂ) • realRectToCMatrix (ch7RectRightScale A d) :
          Matrix (Fin m) (Fin n) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectRightScale]
    ring
  have hleft :
      realRectToCMatrix
          (ch7RectLeftScale (fun j : Fin n => t⁻¹ * dInv j) Aplus) =
        (((t : ℂ)⁻¹) • realRectToCMatrix (ch7RectLeftScale dInv Aplus) :
          Matrix (Fin n) (Fin m) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectLeftScale]
    ring
  have htC : (t : ℂ) ≠ 0 := by
    exact_mod_cast ht
  have hunit : ‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖ = 1 := by
    rw [norm_inv]
    exact mul_inv_cancel₀ (norm_ne_zero_iff.mpr htC)
  dsimp [ch7LpRightScaledCondOfReal]
  rw [hright, hleft,
    ch7_complexMatrixLpNormOfReal_smul hn hp htC,
    ch7_complexMatrixLpNormOfReal_smul hm hp (inv_ne_zero htC)]
  let B : ℝ :=
    complexMatrixLpNormOfReal hn p hp (realRectToCMatrix (ch7RectRightScale A d))
  let C : ℝ :=
    complexMatrixLpNormOfReal hm p hp (realRectToCMatrix (ch7RectLeftScale dInv Aplus))
  change (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C) = B * C
  calc
    (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C)
        = (‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖) * (B * C) := by ring
    _ = B * C := by rw [hunit]; ring

/-- Normalize a finite-real `p` reciprocal right diagonal pair to the
absolute-sum-one slice without changing the condition product. -/
theorem ch7LpRightScaledCondOfReal_sum_abs_normalized_witness {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    let s : ℝ := ∑ j : Fin n, |d j|
    (∀ j : Fin n, (s⁻¹ * d j) * (s * dInv j) = 1) ∧
      ch7LpRightScaledCondOfReal hm hn p hp A Aplus
          (fun j : Fin n => s⁻¹ * d j) (fun j : Fin n => s * dInv j) =
        ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv ∧
      (∑ j : Fin n, |s⁻¹ * d j|) = 1 := by
  intro s
  have hspos : 0 < s := by
    simpa [s] using ch7_sum_abs_pos_of_reciprocal hn d dInv hdiag
  have hsne : s ≠ 0 := ne_of_gt hspos
  refine ⟨?_, ?_, ?_⟩
  · intro j
    calc
      (s⁻¹ * d j) * (s * dInv j)
          = (s⁻¹ * s) * (d j * dInv j) := by ring
      _ = 1 := by rw [inv_mul_cancel₀ hsne, hdiag j]; ring
  · simpa [inv_inv] using
      (ch7LpRightScaledCondOfReal_global_scale hm hn hp A Aplus d dInv
        (t := s⁻¹) (inv_ne_zero hsne))
  · calc
      (∑ j : Fin n, |s⁻¹ * d j|)
          = ∑ j : Fin n, |s⁻¹| * |d j| := by
            apply Finset.sum_congr rfl
            intro j _
            rw [abs_mul]
      _ = |s⁻¹| * ∑ j : Fin n, |d j| := by
            rw [Finset.mul_sum]
      _ = s⁻¹ * s := by
            rw [abs_of_nonneg (inv_nonneg.mpr hspos.le)]
      _ = 1 := inv_mul_cancel₀ hsne

/-- On a nonempty right-scaling index type, the finite-real `p` value set is
exactly its absolute-sum-one normalized slice. -/
theorem ch7LpRightScaledCondSetOfReal_eq_sum_abs_normalized {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus =
      ch7LpRightScaledCondNormalizedSetOfReal hm hn p hp A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    rcases ch7LpRightScaledCondOfReal_sum_abs_normalized_witness
        hm hn hp A Aplus d dInv hdiag with
      ⟨hdiagN, hcondN, hsumN⟩
    refine ⟨fun j : Fin n => (∑ k : Fin n, |d k|)⁻¹ * d j,
      fun j : Fin n => (∑ k : Fin n, |d k|) * dInv j, hdiagN, hsumN, ?_⟩
    exact hcondN.symm
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, _hsum, rfl⟩
    exact ch7LpRightScaledCondOfReal_mem_set hm hn hp A Aplus d dInv hdiag

/-- Least values for unrestricted finite-real `p` right scalings are exactly
least values for the absolute-sum-one normalized slice. -/
theorem ch7LpRightScaledCondSetOfReal_isLeast_iff_sum_abs_normalized {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus) μ ↔
      IsLeast (ch7LpRightScaledCondNormalizedSetOfReal hm hn p hp A Aplus) μ := by
  rw [ch7LpRightScaledCondSetOfReal_eq_sum_abs_normalized hm hn hp A Aplus]

/-- The normalized finite-real `p` right-scaling set can be represented using
only one nonzero diagonal and pointwise reciprocal inverse diagonal. -/
theorem ch7LpRightScaledCondNormalizedSetOfReal_eq_reciprocal_normalized
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7LpRightScaledCondNormalizedSetOfReal hm hn p hp A Aplus =
      ch7LpRightScaledCondReciprocalNormalizedSetOfReal hm hn p hp A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, hsum, rfl⟩
    have hdne : ∀ j : Fin n, d j ≠ 0 := by
      intro j
      exact ch7_left_factor_ne_zero_of_mul_eq_one (hdiag j)
    have hdInv : dInv = fun j : Fin n => (d j)⁻¹ := by
      funext j
      exact eq_inv_of_mul_eq_one_right (hdiag j)
    refine ⟨d, hdne, hsum, ?_⟩
    simp [hdInv]
  · intro hκ
    rcases hκ with ⟨d, hdne, hsum, rfl⟩
    refine ⟨d, (fun j : Fin n => (d j)⁻¹), ?_, hsum, rfl⟩
    intro j
    exact mul_inv_cancel₀ (hdne j)

/-- Least values are unchanged by replacing the normalized explicit inverse
diagonal with the pointwise reciprocal in the finite-real `p` right-scaling set. -/
theorem ch7LpRightScaledCondNormalizedSetOfReal_isLeast_iff_reciprocal_normalized
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7LpRightScaledCondNormalizedSetOfReal hm hn p hp A Aplus) μ ↔
      IsLeast
        (ch7LpRightScaledCondReciprocalNormalizedSetOfReal hm hn p hp A Aplus)
        μ := by
  rw [ch7LpRightScaledCondNormalizedSetOfReal_eq_reciprocal_normalized
    hm hn hp A Aplus]

/-- On any set where the right scaling diagonal stays nonzero coordinatewise,
the reciprocal one-diagonal finite-real `p` condition product is continuous. -/
theorem continuousOn_ch7LpRightScaledCondOfReal_reciprocal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (s : Set (Fin n → ℝ)) (h0 : ∀ d ∈ s, ∀ j : Fin n, d j ≠ 0) :
    ContinuousOn (fun d : Fin n → ℝ =>
      ch7LpRightScaledCondOfReal hm hn p hp A Aplus d
        (fun j : Fin n => (d j)⁻¹)) s := by
  have hAD : Continuous fun d : Fin n → ℝ =>
      complexMatrixLpNormOfReal hn p hp
        (realRectToCMatrix (ch7RectRightScale A d)) :=
    (continuous_complexMatrixLpNormOfReal (m := m) (n := n) hn p hp).comp
      (continuous_realRectToCMatrix_ch7RectRightScale A)
  have hAplusMat : ContinuousOn (fun d : Fin n → ℝ =>
      realRectToCMatrix (ch7RectLeftScale (fun j : Fin n => (d j)⁻¹) Aplus)) s := by
    rw [continuousOn_pi]
    intro i
    rw [continuousOn_pi]
    intro j
    have hinv : ContinuousOn (fun d : Fin n → ℝ => (d i)⁻¹) s :=
      (continuous_apply i).continuousOn.inv₀ (fun d hd => h0 d hd i)
    have hcoord : ContinuousOn (fun d : Fin n → ℝ => (d i)⁻¹ * Aplus i j) s :=
      hinv.mul continuous_const.continuousOn
    simpa [realRectToCMatrix, ch7RectLeftScale, Function.comp_def] using
      Complex.continuous_ofReal.comp_continuousOn hcoord
  have hAplus : ContinuousOn (fun d : Fin n → ℝ =>
      complexMatrixLpNormOfReal hm p hp
        (realRectToCMatrix (ch7RectLeftScale (fun j : Fin n => (d j)⁻¹) Aplus))) s :=
    (continuous_complexMatrixLpNormOfReal (m := n) (n := m) hm p hp).comp_continuousOn
      hAplusMat
  have hprod : ContinuousOn (fun d : Fin n → ℝ =>
      complexMatrixLpNormOfReal hn p hp
          (realRectToCMatrix (ch7RectRightScale A d)) *
        complexMatrixLpNormOfReal hm p hp
          (realRectToCMatrix
            (ch7RectLeftScale (fun j : Fin n => (d j)⁻¹) Aplus))) s :=
    hAD.continuousOn.mul hAplus
  simpa [ch7LpRightScaledCondOfReal] using hprod

/-- The finite-real `p` right-scaling condition-product value set is bounded
below by zero. -/
theorem ch7LpRightScaledCondSetOfReal_bddBelow {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    BddBelow (ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
  exact ch7LpRightScaledCondOfReal_nonneg hm hn hp A Aplus d dInv

/-- The finite-real `p` right-scaling condition-product infimum is nonnegative
because every admissible value is a product of matrix `p`-norms. -/
theorem ch7LpRightScaledCondSetOfReal_sInf_nonneg {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    0 ≤ sInf (ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus) := by
  let S : Set ℝ := ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7LpRightScaledCondSetOfReal_nonempty hm hn hp A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
    exact ch7LpRightScaledCondOfReal_nonneg hm hn hp A Aplus d dInv
  exact le_csInf hS_nonempty hlower

/-- Theorem 7.5, equation `(7.18)`, finite-real `p` pairwise
column-equilibration form for the explicit condition product. -/
theorem theorem7_5_lp_column_equilibration_le_card_rpow_right_scaling
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnLpNormOfReal p A j)
    (d dInv : Fin n → ℝ)
    (hdiag : ∀ j : Fin n, d j * dInv j = 1) :
    ch7LpRightScaledCondOfReal hm hn p hp A Aplus
        (ch7ColumnEquilibratingScaleLpOfReal p A)
        (fun j : Fin n => ch7RectColumnLpNormOfReal p A j) ≤
      (n : ℝ) ^ (1 - p⁻¹) *
        ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv := by
  unfold ch7LpRightScaledCondOfReal
  let ADc : Fin m → Fin n → ℝ :=
    ch7RectRightScale A (ch7ColumnEquilibratingScaleLpOfReal p A)
  let AplusDcInv : Fin n → Fin m → ℝ :=
    ch7RectLeftScale (fun j : Fin n => ch7RectColumnLpNormOfReal p A j) Aplus
  let AD : Fin m → Fin n → ℝ := ch7RectRightScale A d
  let DinvAplus : Fin n → Fin m → ℝ := ch7RectLeftScale dInv Aplus
  have hADc :
      complexMatrixLpNormOfReal hn p hp (realRectToCMatrix ADc) ≤
        (n : ℝ) ^ (1 - p⁻¹) := by
    dsimp [ADc]
    exact eq_7_21_matrixLpNormOfReal_column_equilibrated hn hp A hcol
  have hside :
      complexMatrixLpNormOfReal hm p hp (realRectToCMatrix AplusDcInv) ≤
        complexMatrixLpNormOfReal hn p hp (realRectToCMatrix AD) *
          complexMatrixLpNormOfReal hm p hp (realRectToCMatrix DinvAplus) := by
    dsimp [AplusDcInv, AD, DinvAplus]
    exact eq_7_22_matrixLpNormOfReal_inverseSide_bound
      hm hn hp A Aplus d dInv hdiag
  have hAplusDcInv_nonneg :
      0 ≤ complexMatrixLpNormOfReal hm p hp (realRectToCMatrix AplusDcInv) :=
    ch7_complexMatrixLpNormOfReal_nonneg hm hp _
  have hfactor_nonneg : 0 ≤ (n : ℝ) ^ (1 - p⁻¹) :=
    Real.rpow_nonneg (Nat.cast_nonneg n) _
  calc
    complexMatrixLpNormOfReal hn p hp (realRectToCMatrix ADc) *
        complexMatrixLpNormOfReal hm p hp (realRectToCMatrix AplusDcInv)
        ≤ (n : ℝ) ^ (1 - p⁻¹) *
            complexMatrixLpNormOfReal hm p hp (realRectToCMatrix AplusDcInv) :=
          mul_le_mul_of_nonneg_right hADc hAplusDcInv_nonneg
    _ ≤ (n : ℝ) ^ (1 - p⁻¹) *
          (complexMatrixLpNormOfReal hn p hp (realRectToCMatrix AD) *
            complexMatrixLpNormOfReal hm p hp (realRectToCMatrix DinvAplus)) :=
          mul_le_mul_of_nonneg_left hside hfactor_nonneg
    _ = (n : ℝ) ^ (1 - p⁻¹) *
          (complexMatrixLpNormOfReal hn p hp (realRectToCMatrix AD) *
            complexMatrixLpNormOfReal hm p hp (realRectToCMatrix DinvAplus)) := rfl

/-- Theorem 7.5, equation `(7.18)`, finite-real `p` infimum form over
reciprocal diagonal right scalings for the explicit condition product. -/
theorem theorem7_5_lp_column_equilibration_le_card_rpow_sInf_right_scalings
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ j : Fin n, 0 < ch7RectColumnLpNormOfReal p A j) :
    ch7LpRightScaledCondOfReal hm hn p hp A Aplus
        (ch7ColumnEquilibratingScaleLpOfReal p A)
        (fun j : Fin n => ch7RectColumnLpNormOfReal p A j) ≤
      (n : ℝ) ^ (1 - p⁻¹) *
        sInf (ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus) := by
  let c : ℝ :=
    ch7LpRightScaledCondOfReal hm hn p hp A Aplus
      (ch7ColumnEquilibratingScaleLpOfReal p A)
      (fun j : Fin n => ch7RectColumnLpNormOfReal p A j)
  let S : Set ℝ := ch7LpRightScaledCondSetOfReal hm hn p hp A Aplus
  let α : ℝ := (n : ℝ) ^ (1 - p⁻¹)
  have hnR : 0 < (n : ℝ) := by exact_mod_cast hn
  have hαpos : 0 < α := by
    dsimp [α]
    exact Real.rpow_pos_of_pos hnR (1 - p⁻¹)
  have hαnonneg : 0 ≤ α := le_of_lt hαpos
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7LpRightScaledCondSetOfReal_nonempty hm hn hp A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → c / α ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    have hpair :
        c ≤ α * ch7LpRightScaledCondOfReal hm hn p hp A Aplus d dInv := by
      dsimp [c, α]
      exact theorem7_5_lp_column_equilibration_le_card_rpow_right_scaling
        hm hn hp A Aplus hcol d dInv hdiag
    rw [div_le_iff₀ hαpos]
    simpa [mul_comm] using hpair
  have hsInf : c / α ≤ sInf S := le_csInf hS_nonempty hlower
  have hmul : α * (c / α) ≤ α * sInf S :=
    mul_le_mul_of_nonneg_left hsInf hαnonneg
  have hrewrite : α * (c / α) = c := by
    field_simp [ne_of_gt hαpos]
  change c ≤ α * sInf S
  exact hrewrite ▸ hmul

/-- Theorem 7.5, finite-real `p` column form with the source `min` value made
explicit.  This is a proved rewrite of the infimum theorem through a supplied
least-value certificate, not a proof of non-endpoint minimizer existence. -/
theorem theorem7_5_lp_column_equilibration_le_card_rpow_min_right_scalings
