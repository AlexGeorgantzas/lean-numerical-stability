/-- Problem 7.10(a), lower-bound half under the explicit positive Perron
certificate.  The missing source-facing foundation is Perron-Frobenius
existence of such `ρ` and `x`; this theorem proves the diagonal-scaling algebra
once that certificate is available. -/
theorem problem7_10a_scaled_infCond_ge_perron_of_positive_eigenvector {n : ℕ}
    (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ρ ≤ ch7TwoSidedScaledInfCond B C d₁ d₁Inv d₂ d₂Inv := by
  let M : Fin n → Fin n → ℝ := ch7TwoSidedScale d₁ B d₂
  let N : Fin n → Fin n → ℝ := ch7TwoSidedScale d₂Inv C d₁Inv
  let y : Fin n → ℝ := fun i => d₁ i * x i
  have hM : ∀ i j : Fin n, 0 ≤ M i j :=
    ch7TwoSidedScale_nonneg d₁ B d₂
      (fun i => le_of_lt (hd₁pos i)) hB (fun j => le_of_lt (hd₂pos j))
  have hN : ∀ i j : Fin n, 0 ≤ N i j :=
    ch7TwoSidedScale_nonneg d₂Inv C d₁Inv
      (fun i => le_of_lt (hd₂Invpos i)) hC (fun j => le_of_lt (hd₁Invpos j))
  have hMN_nonneg : ∀ i j : Fin n, 0 ≤ matMul n M N i j := by
    intro i j
    unfold matMul
    exact Finset.sum_nonneg fun k _ => mul_nonneg (hM i k) (hN k j)
  have hy : ∀ i : Fin n, 0 < y i := fun i => mul_pos (hd₁pos i) (hx i)
  have heigMN :
      ∀ i : Fin n, matMulVec n (matMul n M N) y i = ρ * y i := by
    have h :=
      ch7_bauer_scaled_product_eigenvector B C ρ x d₁ d₁Inv d₂ d₂Inv hd₁ hd₂ heig
    intro i
    simpa [M, N, y] using congrFun h i
  have hlower : ρ ≤ infNorm (matMul n M N) :=
    ch7_infNorm_ge_of_nonneg_right_eigenvector hn (matMul n M N) ρ y
      hMN_nonneg hy heigMN
  have hsub : infNorm (matMul n M N) ≤ infNorm M * infNorm N :=
    infNorm_matMul_le hn M N
  exact le_trans hlower hsub

/-- Problem 7.10(a), lower-bound half under a positive subeigenvector.
This is the part of Bauer's lower-bound argument already available from the
spectral-radius absolute-value construction; the attaining canonical scaling
still requires the stronger Perron eigenvector equation. -/
theorem problem7_10a_scaled_infCond_ge_perron_of_positive_subeigenvector {n : ℕ}
    (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n, ρ * x i ≤ matMulVec n (matMul n B C) x i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (_hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (_hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (_hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ρ ≤ ch7TwoSidedScaledInfCond B C d₁ d₁Inv d₂ d₂Inv := by
  let M : Fin n → Fin n → ℝ := ch7TwoSidedScale d₁ B d₂
  let N : Fin n → Fin n → ℝ := ch7TwoSidedScale d₂Inv C d₁Inv
  let y : Fin n → ℝ := fun i => d₁ i * x i
  have hy : ∀ i : Fin n, 0 < y i := fun i => mul_pos (hd₁pos i) (hx i)
  have hsubMN :
      ∀ i : Fin n, ρ * y i ≤ matMulVec n (matMul n M N) y i := by
    intro i
    simpa [M, N, y] using
      ch7_bauer_scaled_product_subeigenvector B C ρ x d₁ d₁Inv d₂ d₂Inv
        hd₁pos hd₁ hd₂ hsub i
  have hlower : ρ ≤ infNorm (matMul n M N) :=
    ch7_infNorm_ge_of_positive_right_subeigenvector
      hn (matMul n M N) ρ y hρ hy hsubMN
  have hsubnorm : infNorm (matMul n M N) ≤ infNorm M * infNorm N :=
    infNorm_matMul_le hn M N
  exact le_trans hlower hsubnorm

/-- Problem 7.10(a), value-set lower bound from a positive subeigenvector.
This closes the `ρ ≤ inf` half for the spectral-radius subeigenvector already
proved from irreducibility, without asserting the missing canonical
attainment/equality half. -/
theorem problem7_10a_scaledInfCondSet_sInf_ge_perron_of_positive_subeigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n, ρ * x i ≤ matMulVec n (matMul n B C) x i) :
    ρ ≤ sInf (ch7TwoSidedScaledInfCondSet B C) := by
  let S : Set ℝ := ch7TwoSidedScaledInfCondSet B C
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledInfCondSet_nonempty B C
  have hlower : ∀ κ : ℝ, κ ∈ S → ρ ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, hd₁pos, hd₁Invpos,
        hd₂pos, hd₂Invpos, hd₁, hd₂, rfl⟩
    exact problem7_10a_scaled_infCond_ge_perron_of_positive_subeigenvector
      hn B C ρ x hρ hx hsub d₁ d₁Inv d₂ d₂Inv
      hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  exact le_csInf hS_nonempty hlower

lemma ch7_bauer_Cx_pos_of_pos {n : ℕ} (hn : 0 < n)
    (C : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hCpos : ∀ i j : Fin n, 0 < C i j)
    (hx : ∀ i : Fin n, 0 < x i) :
    ∀ i : Fin n, 0 < matMulVec n C x i := by
  intro i
  unfold matMulVec
  exact Finset.sum_pos
    (fun j _ => mul_pos (hCpos i j) (hx j))
    ⟨⟨0, hn⟩, Finset.mem_univ _⟩

/-- Problem 7.10(c): if `x` is a right eigenvector of `BC`, then `Cx` is a
right eigenvector of `CB` with the same eigenvalue.  This is the algebraic
part of Higham's Perron-vector transfer; positivity of `Cx` is proved
separately by `ch7_bauer_Cx_pos_of_pos`. -/
lemma ch7_bauer_Cx_eigenvector_CB {n : ℕ}
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    ∀ i : Fin n,
      matMulVec n (matMul n C B) (matMulVec n C x) i =
        ρ * matMulVec n C x i := by
  intro i
  rw [matMulVec_matMul]
  have hBC :
      matMulVec n B (matMulVec n C x) = fun i : Fin n => ρ * x i := by
    ext i
    rw [← matMulVec_matMul n B C x i]
    exact heig i
  rw [hBC]
  unfold matMulVec
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro j _
  ring

lemma ch7_matrix_mulVec_eq_matMulVec {n : ℕ}
    (M : Fin n → Fin n → ℝ) (x : Fin n → ℝ) :
    Matrix.mulVec (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) x =
      matMulVec n M x := by
  ext i
  simp [Matrix.mulVec, dotProduct, matMulVec]

lemma ch7_matrix_pow_mulVec_eigen {n : ℕ}
    (M : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (heig : ∀ i : Fin n, matMulVec n M x i = ρ * x i) :
    ∀ k : ℕ,
      Matrix.mulVec ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x =
        fun i : Fin n => ρ ^ k * x i := by
  intro k
  induction k with
  | zero =>
      ext i
      simp
  | succ k ih =>
      ext i
      rw [pow_succ']
      rw [← Matrix.mulVec_mulVec]
      rw [ih]
      have hvec : (fun i : Fin n => ρ ^ k * x i) = (ρ ^ k) • x := by
        ext j
        simp [Pi.smul_apply, smul_eq_mul]
      rw [hvec]
      rw [Matrix.mulVec_smul]
      simp [ch7_matrix_mulVec_eq_matMulVec, heig, Pi.smul_apply, smul_eq_mul]
      ring

/-- A positive right eigenvector for a nonnegative irreducible matrix has a
positive eigenvalue.  This is still certificate-level Bauer infrastructure: it
uses irreducibility to prove strict positivity of an already supplied
eigenvalue/eigenvector pair, but does not assert Perron-Frobenius existence. -/
lemma ch7_perronScalar_pos_of_nonneg_irreducible_eigenvector {n : ℕ}
    (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hIrred : Matrix.IsIrreducible
      (Matrix.of A : Matrix (Fin n) (Fin n) ℝ))
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n A x i = ρ * x i) :
    0 < ρ := by
  classical
  have hρ_nonneg : 0 ≤ ρ :=
    ch7_perronScalar_nonneg_of_nonneg_eigenvector hn A ρ x hA hx heig
  let i0 : Fin n := ⟨0, hn⟩
  have hA_nonneg : ∀ i j : Fin n,
      0 ≤ (Matrix.of A : Matrix (Fin n) (Fin n) ℝ) i j := hA
  have hpow_exists : ∀ i j : Fin n,
      ∃ k > 0, 0 < ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) i j :=
    (Matrix.isIrreducible_iff_exists_pow_pos hA_nonneg).mp hIrred
  obtain ⟨k, hk_pos, hpow_i0⟩ := hpow_exists i0 i0
  have hterms_nonneg : ∀ l : Fin n,
      0 ≤ ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) i0 l * x l := by
    intro l
    exact mul_nonneg (Matrix.pow_apply_nonneg hA_nonneg k i0 l) (le_of_lt (hx l))
  have hterm_pos :
      0 < ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) i0 i0 * x i0 :=
    mul_pos hpow_i0 (hx i0)
  have hmul_pos :
      0 <
        Matrix.mulVec
          ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) x i0 := by
    unfold Matrix.mulVec dotProduct
    exact Finset.sum_pos' (fun l _ => hterms_nonneg l)
      ⟨i0, Finset.mem_univ i0, hterm_pos⟩
  have hpow_eig := congrFun (ch7_matrix_pow_mulVec_eigen A ρ x heig k) i0
  have hprod_pos : 0 < ρ ^ k * x i0 := by
    simpa [hpow_eig] using hmul_pos
  have hρ_pow_pos : 0 < ρ ^ k := by
    nlinarith [hx i0, hprod_pos]
  have hρ_ne : ρ ≠ 0 := by
    intro hzero
    subst ρ
    simp [Nat.ne_of_gt hk_pos] at hρ_pow_pos
  exact lt_of_le_of_ne hρ_nonneg (Ne.symm hρ_ne)

/-- A nonzero nonnegative right eigenvector for a nonnegative irreducible
matrix has a positive eigenvalue.  This is the certificate-level positivity
part of Perron-Frobenius used by Bauer scaling; it still assumes the
eigenpair is supplied explicitly. -/
lemma ch7_perronScalar_pos_of_nonzero_nonneg_irreducible_eigenvector {n : ℕ}
    (A : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hIrred : Matrix.IsIrreducible
      (Matrix.of A : Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (heig : ∀ i : Fin n, matMulVec n A x i = ρ * x i) :
    0 < ρ := by
  classical
  have hρ_nonneg : 0 ≤ ρ :=
    ch7_perronScalar_nonneg_of_nonzero_nonneg_eigenvector
      A ρ x hA hx_nonneg hx_ne heig
  obtain ⟨j, hxj⟩ :=
    ch7_exists_pos_entry_of_nonzero_nonneg x hx_nonneg hx_ne
  have hA_nonneg : ∀ i j : Fin n,
      0 ≤ (Matrix.of A : Matrix (Fin n) (Fin n) ℝ) i j := hA
  have hpow_exists : ∀ i j : Fin n,
      ∃ k > 0, 0 < ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) i j :=
    (Matrix.isIrreducible_iff_exists_pow_pos hA_nonneg).mp hIrred
  obtain ⟨k, hk_pos, hpow_jj⟩ := hpow_exists j j
  have hterms_nonneg : ∀ l : Fin n,
      0 ≤ ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) j l * x l := by
    intro l
    exact mul_nonneg (Matrix.pow_apply_nonneg hA_nonneg k j l) (hx_nonneg l)
  have hterm_pos :
      0 < ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) j j * x j :=
    mul_pos hpow_jj hxj
  have hmul_pos :
      0 <
        Matrix.mulVec
          ((Matrix.of A : Matrix (Fin n) (Fin n) ℝ) ^ k) x j := by
    unfold Matrix.mulVec dotProduct
    exact Finset.sum_pos' (fun l _ => hterms_nonneg l)
      ⟨j, Finset.mem_univ j, hterm_pos⟩
  have hpow_eig := congrFun (ch7_matrix_pow_mulVec_eigen A ρ x heig k) j
  have hprod_pos : 0 < ρ ^ k * x j := by
    simpa [hpow_eig] using hmul_pos
  have hρ_pow_pos : 0 < ρ ^ k := by
    nlinarith [hxj, hprod_pos]
  have hρ_ne : ρ ≠ 0 := by
    intro hzero
    subst ρ
    simp [Nat.ne_of_gt hk_pos] at hρ_pow_pos
  exact lt_of_le_of_ne hρ_nonneg (Ne.symm hρ_ne)

/-- Irreducibility propagates any nonzero nonnegative vector to every
coordinate after some positive matrix power.  This is the reusable
support-propagation dependency for the Perron-Frobenius route behind
Theorem 7.8 / Problem 7.10; it does not assert existence of a Perron
eigenvector. -/
lemma ch7_irreducible_pow_mulVec_pos_of_nonzero_nonneg {n : ℕ}
    (M : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0) :
    ∀ i : Fin n, ∃ k > 0,
      0 <
        Matrix.mulVec
          ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i := by
  classical
  have hA_nonneg : ∀ i j : Fin n,
      0 ≤ (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) i j := hM.1
  have hpow_exists : ∀ i j : Fin n,
      ∃ k > 0, 0 < ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) i j :=
    (Matrix.isIrreducible_iff_exists_pow_pos hA_nonneg).mp hM
  obtain ⟨j, hxj⟩ :=
    ch7_exists_pos_entry_of_nonzero_nonneg x hx_nonneg hx_ne
  intro i
  obtain ⟨k, hk_pos, hpow_ij⟩ := hpow_exists i j
  have hterms_nonneg : ∀ l : Fin n,
      0 ≤ ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) i l * x l := by
    intro l
    exact mul_nonneg (Matrix.pow_apply_nonneg hA_nonneg k i l) (hx_nonneg l)
  have hterm_pos :
      0 < ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) i j * x j :=
    mul_pos hpow_ij hxj
  refine ⟨k, hk_pos, ?_⟩
  unfold Matrix.mulVec dotProduct
  exact Finset.sum_pos' (fun l _ => hterms_nonneg l)
    ⟨j, Finset.mem_univ j, hterm_pos⟩

/-- Powers of a nonnegative matrix send nonnegative vectors to nonnegative
vectors.  This is kept in Chapter 7 because the current Perron-Frobenius
closure uses it only for the Bauer-scaling irreducibility path. -/
lemma ch7_matrix_pow_mulVec_nonneg_of_nonneg {n : ℕ}
    (M : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hM_nonneg : ∀ i j : Fin n,
      0 ≤ (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) i j)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i) :
    ∀ k : ℕ, ∀ i : Fin n,
      0 ≤
        Matrix.mulVec
          ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i := by
  intro k i
  unfold Matrix.mulVec dotProduct
  exact Finset.sum_nonneg fun j _ =>
    mul_nonneg (Matrix.pow_apply_nonneg hM_nonneg k i j) (hx_nonneg j)

/-- Nonnegative matrices are monotone for componentwise vector order.  This is
the local order adapter needed to iterate the nonnegative subeigenvector
inequality on the Perron-Frobenius route. -/
lemma ch7_matrix_mulVec_mono_of_nonneg {n : ℕ}
    (A : Matrix (Fin n) (Fin n) ℝ) {u v : Fin n → ℝ}
    (hA_nonneg : ∀ i j : Fin n, 0 ≤ A i j)
    (huv : ∀ j : Fin n, u j ≤ v j) :
    ∀ i : Fin n, Matrix.mulVec A u i ≤ Matrix.mulVec A v i := by
  intro i
  unfold Matrix.mulVec
  exact dotProduct_le_dotProduct_of_nonneg_left
    (u := u) (v := v) (w := fun j : Fin n => A i j)
    (show u ≤ v from fun j => huv j)
    (show 0 ≤ fun j : Fin n => A i j from fun j => hA_nonneg i j)

/-- A componentwise subeigenvector inequality for a nonnegative matrix
iterates through every matrix power.  This is a dependency for the
spectral-radius-attaining nonnegative subeigenvector stage of the
Perron-Frobenius route in Theorem 7.8 / Problem 7.10. -/
lemma ch7_matrix_pow_mulVec_subeigen_le_of_nonneg {n : ℕ}
    (A : Matrix (Fin n) (Fin n) ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hA_nonneg : ∀ i j : Fin n, 0 ≤ A i j)
    (hlam : 0 ≤ lam)
    (hsub : ∀ i : Fin n, lam * x i ≤ Matrix.mulVec A x i) :
    ∀ k : ℕ, ∀ i : Fin n,
      lam ^ k * x i ≤ Matrix.mulVec (A ^ k) x i := by
  intro k
  induction k with
  | zero =>
      intro i
      simp
  | succ k ih =>
      intro i
      have hlamk : 0 ≤ lam ^ k := pow_nonneg hlam k
      have hscaled :
          lam ^ k * (lam * x i) ≤ lam ^ k * Matrix.mulVec A x i :=
        mul_le_mul_of_nonneg_left (hsub i) hlamk
      have hleft : lam ^ Nat.succ k * x i = lam ^ k * (lam * x i) := by
        rw [pow_succ]
        ring
      have hscale_mulVec :
          Matrix.mulVec A (fun j : Fin n => lam ^ k * x j) i =
            lam ^ k * Matrix.mulVec A x i := by
        have hvec : (fun j : Fin n => lam ^ k * x j) = (lam ^ k) • x := by
          ext j
          simp [Pi.smul_apply, smul_eq_mul]
        rw [hvec, Matrix.mulVec_smul]
        simp [Pi.smul_apply, smul_eq_mul]
      have hmono :
          Matrix.mulVec A (fun j : Fin n => lam ^ k * x j) i ≤
            Matrix.mulVec A (Matrix.mulVec (A ^ k) x) i :=
        ch7_matrix_mulVec_mono_of_nonneg A hA_nonneg (fun j => ih j) i
      have hpow_mulVec :
          Matrix.mulVec A (Matrix.mulVec (A ^ k) x) i =
            Matrix.mulVec (A ^ Nat.succ k) x i := by
        rw [pow_succ']
        rw [← Matrix.mulVec_mulVec]
      calc
        lam ^ Nat.succ k * x i = lam ^ k * (lam * x i) := hleft
        _ ≤ lam ^ k * Matrix.mulVec A x i := hscaled
        _ = Matrix.mulVec A (fun j : Fin n => lam ^ k * x j) i :=
          hscale_mulVec.symm
        _ ≤ Matrix.mulVec A (Matrix.mulVec (A ^ k) x) i := hmono
        _ = Matrix.mulVec (A ^ Nat.succ k) x i := hpow_mulVec

/-- A nonempty finite complex vector attains its supremum norm at a coordinate. -/
lemma ch7_complexVec_norm_eq_coord_of_nonempty {n : ℕ} (hn : 0 < n)
    (x : Fin n → ℂ) :
    ∃ i : Fin n, ‖x‖ = ‖x i‖ := by
  classical
  have huniv : (Finset.univ : Finset (Fin n)).Nonempty :=
    ⟨⟨0, hn⟩, Finset.mem_univ _⟩
  obtain ⟨i, _hi, hsup⟩ :=
    Finset.exists_mem_eq_sup
      (s := (Finset.univ : Finset (Fin n))) huniv
      (fun i : Fin n => ‖x i‖₊)
  refine ⟨i, ?_⟩
  have hnn : ‖x‖₊ = ‖x i‖₊ := by
    simpa [Pi.nnnorm_def] using hsup
  exact congrArg (fun a : NNReal => (a : ℝ)) hnn

/-- Complexification commutes with matrix powers for Chapter 7 square real
matrices. -/
lemma ch7_realRectToCMatrix_matrix_pow {n : ℕ}
    (M : Fin n → Fin n → ℝ) :
    ∀ k : ℕ,
      (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M) ^ k =
        fun i j => (((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) i j : ℂ) := by
  intro k
  induction k with
  | zero =>
      ext i j
      by_cases hij : i = j
      · subst j
        simp
      · simp [hij]
  | succ k ih =>
      rw [pow_succ', pow_succ', ih]
      ext i j
      simp [Matrix.mul_apply, realRectToCMatrix, Complex.ofReal_sum,
        Complex.ofReal_mul]

/-- Applying a complexified real matrix power to a complexified real vector is
the complexification of the corresponding real powered matrix-vector product. -/
lemma ch7_realRectToCMatrix_pow_mulVec_complexified {n : ℕ}
    (M : Fin n → Fin n → ℝ) (x : Fin n → ℝ) (k : ℕ) :
    Matrix.mulVec
        ((show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M) ^ k)
        (fun i : Fin n => (x i : ℂ)) =
      fun i : Fin n =>
        ((Matrix.mulVec ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i : ℝ) : ℂ) := by
  ext i
  rw [ch7_realRectToCMatrix_matrix_pow M k]
  simp [Matrix.mulVec, dotProduct, Complex.ofReal_sum, Complex.ofReal_mul]

section Ch7MatrixOperatorNorm

open scoped Matrix.Norms.Operator

/-- A positive real subeigenvector gives a lower bound on every power's
matrix operator norm.  The norm is Mathlib's scoped `L∞` operator norm on
finite matrices, used only internally to invoke Gelfand's formula. -/
lemma ch7_matrix_pow_opNorm_ge_pow_subeigen {n : ℕ} (hn : 0 < n)
    (M : Fin n → Fin n → ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j)
    (hlam : 0 ≤ lam)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ∀ k : ℕ,
      lam ^ k ≤
        ‖(show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M) ^ k‖ := by
  classical
  intro k
  let A : Matrix (Fin n) (Fin n) ℝ :=
    (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)
  let C : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)
  let xc : Fin n → ℂ := fun i => (x i : ℂ)
  obtain ⟨i0, hnorm_eq⟩ := ch7_complexVec_norm_eq_coord_of_nonempty hn xc
  have hxnorm_eq : ‖xc‖ = x i0 := by
    rw [hnorm_eq]
    simp [xc, Complex.norm_real, abs_of_nonneg (le_of_lt (hx i0))]
  have hA_nonneg : ∀ i j : Fin n, 0 ≤ A i j := by
    intro i j
    simpa [A, Matrix.of] using hM_nonneg i j
  have hsub_matrix : ∀ i : Fin n, lam * x i ≤ Matrix.mulVec A x i := by
    intro i
    simpa [A, ch7_matrix_mulVec_eq_matMulVec M x] using hsub i
  have hpow_sub :
      lam ^ k * x i0 ≤ Matrix.mulVec (A ^ k) x i0 :=
    ch7_matrix_pow_mulVec_subeigen_le_of_nonneg
      A lam x hA_nonneg hlam hsub_matrix k i0
  have hx_nonneg : ∀ i : Fin n, 0 ≤ x i := fun i => le_of_lt (hx i)
  have hpow_nonneg :
      0 ≤ Matrix.mulVec (A ^ k) x i0 := by
    simpa [A] using
      ch7_matrix_pow_mulVec_nonneg_of_nonneg M x hA_nonneg hx_nonneg k i0
  have hcoord :
      ‖Matrix.mulVec (C ^ k) xc i0‖ = Matrix.mulVec (A ^ k) x i0 := by
    have happ_i := congrFun
      (ch7_realRectToCMatrix_pow_mulVec_complexified M x k) i0
    simpa [C, A, xc, Complex.norm_real, abs_of_nonneg hpow_nonneg]
      using congrArg norm happ_i
  have hcoord_le_vec :
      ‖Matrix.mulVec (C ^ k) xc i0‖ ≤ ‖Matrix.mulVec (C ^ k) xc‖ :=
    norm_le_pi_norm (Matrix.mulVec (C ^ k) xc) i0
  have hop : ‖Matrix.mulVec (C ^ k) xc‖ ≤ ‖C ^ k‖ * ‖xc‖ :=
    Matrix.linfty_opNorm_mulVec (C ^ k) xc
  have hscaled : lam ^ k * x i0 ≤ ‖C ^ k‖ * x i0 := by
    calc
      lam ^ k * x i0 ≤ Matrix.mulVec (A ^ k) x i0 := hpow_sub
      _ = ‖Matrix.mulVec (C ^ k) xc i0‖ := hcoord.symm
      _ ≤ ‖Matrix.mulVec (C ^ k) xc‖ := hcoord_le_vec
      _ ≤ ‖C ^ k‖ * ‖xc‖ := hop
      _ = ‖C ^ k‖ * x i0 := by rw [hxnorm_eq]
  have hxpos := hx i0
  have hnorm_nonneg : 0 ≤ ‖C ^ k‖ := norm_nonneg _
  nlinarith

/-- A nonzero nonnegative real subeigenvector gives the same power-norm lower
bound as the positive version.  The proof chooses a coordinate attaining the
supremum norm; nonzero nonnegativity makes that coordinate strictly positive. -/
lemma ch7_matrix_pow_opNorm_ge_pow_nonzero_nonneg_subeigen {n : ℕ} (hn : 0 < n)
    (M : Fin n → Fin n → ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j)
    (hlam : 0 ≤ lam)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ∀ k : ℕ,
      lam ^ k ≤
        ‖(show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M) ^ k‖ := by
  classical
  intro k
  let A : Matrix (Fin n) (Fin n) ℝ :=
    (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)
  let C : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)
  let xc : Fin n → ℂ := fun i => (x i : ℂ)
  obtain ⟨i0, hnorm_eq⟩ := ch7_complexVec_norm_eq_coord_of_nonempty hn xc
  have hx_pos_exists : ∃ i : Fin n, 0 < x i := by
    by_contra hnone
    have hx_zero : x = 0 := by
      ext i
      have hle : x i ≤ 0 := le_of_not_gt fun hpos => hnone ⟨i, hpos⟩
      exact le_antisymm hle (hx_nonneg i)
    exact hx_ne hx_zero
  obtain ⟨ipos, hipos⟩ := hx_pos_exists
  have hipos_norm_pos : 0 < ‖xc ipos‖ := by
    simpa [xc, Complex.norm_real, abs_of_pos hipos]
  have hi0_norm_pos : 0 < ‖xc i0‖ := by
    exact lt_of_lt_of_le hipos_norm_pos
      (by
        calc
          ‖xc ipos‖ ≤ ‖xc‖ := norm_le_pi_norm xc ipos
          _ = ‖xc i0‖ := hnorm_eq)
  have hx_i0_pos : 0 < x i0 := by
    have hxi0_abs_pos : 0 < |x i0| := by
      simpa [xc, Complex.norm_real] using hi0_norm_pos
    have hxi0_ne : x i0 ≠ 0 := by
      intro hzero
      simp [hzero] at hxi0_abs_pos
    exact lt_of_le_of_ne (hx_nonneg i0) hxi0_ne.symm
  have hxnorm_eq : ‖xc‖ = x i0 := by
    rw [hnorm_eq]
    simp [xc, Complex.norm_real, abs_of_nonneg (hx_nonneg i0)]
  have hA_nonneg : ∀ i j : Fin n, 0 ≤ A i j := by
    intro i j
    simpa [A, Matrix.of] using hM_nonneg i j
  have hsub_matrix : ∀ i : Fin n, lam * x i ≤ Matrix.mulVec A x i := by
    intro i
    simpa [A, ch7_matrix_mulVec_eq_matMulVec M x] using hsub i
  have hpow_sub :
      lam ^ k * x i0 ≤ Matrix.mulVec (A ^ k) x i0 :=
    ch7_matrix_pow_mulVec_subeigen_le_of_nonneg
      A lam x hA_nonneg hlam hsub_matrix k i0
  have hpow_nonneg :
      0 ≤ Matrix.mulVec (A ^ k) x i0 := by
    simpa [A] using
      ch7_matrix_pow_mulVec_nonneg_of_nonneg M x hA_nonneg hx_nonneg k i0
  have hcoord :
      ‖Matrix.mulVec (C ^ k) xc i0‖ = Matrix.mulVec (A ^ k) x i0 := by
    have happ_i := congrFun
      (ch7_realRectToCMatrix_pow_mulVec_complexified M x k) i0
    simpa [C, A, xc, Complex.norm_real, abs_of_nonneg hpow_nonneg]
      using congrArg norm happ_i
  have hcoord_le_vec :
      ‖Matrix.mulVec (C ^ k) xc i0‖ ≤ ‖Matrix.mulVec (C ^ k) xc‖ :=
    norm_le_pi_norm (Matrix.mulVec (C ^ k) xc) i0
  have hop : ‖Matrix.mulVec (C ^ k) xc‖ ≤ ‖C ^ k‖ * ‖xc‖ :=
    Matrix.linfty_opNorm_mulVec (C ^ k) xc
  have hscaled : lam ^ k * x i0 ≤ ‖C ^ k‖ * x i0 := by
    calc
      lam ^ k * x i0 ≤ Matrix.mulVec (A ^ k) x i0 := hpow_sub
      _ = ‖Matrix.mulVec (C ^ k) xc i0‖ := hcoord.symm
      _ ≤ ‖Matrix.mulVec (C ^ k) xc‖ := hcoord_le_vec
      _ ≤ ‖C ^ k‖ * ‖xc‖ := hop
      _ = ‖C ^ k‖ * x i0 := by rw [hxnorm_eq]
  have hnorm_nonneg : 0 ≤ ‖C ^ k‖ := norm_nonneg _
  nlinarith

/-- Collatz/Gelfand lower bound: a positive right subeigenvector of a
nonnegative finite real matrix forces its scalar below the Mathlib
spectral radius of the complexified matrix algebra. -/
theorem ch7_matrix_spectralRadius_ge_of_positive_right_subeigenvector {n : ℕ}
    (hn : 0 < n) (M : Fin n → Fin n → ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j)
    (hlam : 0 ≤ lam)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ENNReal.ofReal lam ≤
      spectralRadius ℂ
        (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M) := by
  classical
  let C : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)
  by_cases hlam_zero : lam = 0
  · simp [hlam_zero]
  have hpow_bound :
      ∀ k : ℕ, lam ^ k ≤ ‖C ^ k‖ := by
    intro k
    simpa [C] using
      ch7_matrix_pow_opNorm_ge_pow_subeigen
        hn M lam x hM_nonneg hlam hx hsub k
  letI : CompleteSpace (Matrix (Fin n) (Fin n) ℂ) :=
    FiniteDimensional.complete ℂ _
  have hcomplete_check : CompleteSpace (Matrix (Fin n) (Fin n) ℂ) := inferInstance
  have hlim :=
    @spectrum.pow_norm_pow_one_div_tendsto_nhds_spectralRadius
      (Matrix (Fin n) (Fin n) ℂ) inferInstance inferInstance hcomplete_check C
  refine ge_of_tendsto hlim ?_
  refine Filter.eventually_atTop.2 ⟨1, ?_⟩
  intro k hk
  have hk_pos_nat : 0 < k := Nat.pos_of_ne_zero (Nat.ne_zero_of_lt hk)
  have hk_pos : 0 < (k : ℝ) := Nat.cast_pos.mpr hk_pos_nat
  have hpow_nonneg : 0 ≤ lam ^ k := pow_nonneg hlam k
  have hroot :=
    Real.rpow_le_rpow hpow_nonneg (hpow_bound k)
      (le_of_lt (one_div_pos.mpr hk_pos))
  have hroot' :
      (lam ^ k) ^ (1 / (k : ℝ)) ≤
        ‖C ^ k‖ ^ (1 / (k : ℝ)) := by
    simpa [one_div] using hroot
  have hleft : (lam ^ k) ^ (1 / (k : ℝ)) = lam := by
    rw [← Real.rpow_natCast lam k]
    rw [← Real.rpow_mul hlam]
    have hmul : (k : ℝ) * (1 / (k : ℝ)) = 1 := by
      field_simp [ne_of_gt hk_pos]
    rw [hmul, Real.rpow_one]
  have hleft' : (lam ^ k) ^ ((k : ℝ)⁻¹) = lam := by
    simpa [one_div] using hleft
  have hreal : lam ≤ ‖C ^ k‖ ^ (1 / (k : ℝ)) := by
    simpa [one_div, hleft'] using hroot'
  exact ENNReal.ofReal_le_ofReal hreal

/-- Collatz/Gelfand lower bound for a nonzero nonnegative right
subeigenvector.  This avoids an irreducibility hypothesis when the
Barrlund--Sun route only needs to rule out nonzero nonnegative domination. -/
theorem ch7_matrix_spectralRadius_ge_of_nonzero_nonneg_right_subeigenvector
    {n : ℕ} (hn : 0 < n) (M : Fin n → Fin n → ℝ) (lam : ℝ)
    (x : Fin n → ℝ)
    (hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j)
    (hlam : 0 ≤ lam)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ENNReal.ofReal lam ≤
      spectralRadius ℂ
        (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M) := by
  classical
  let C : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)
  by_cases hlam_zero : lam = 0
  · simp [hlam_zero]
  have hpow_bound :
      ∀ k : ℕ, lam ^ k ≤ ‖C ^ k‖ := by
    intro k
    simpa [C] using
      ch7_matrix_pow_opNorm_ge_pow_nonzero_nonneg_subeigen
        hn M lam x hM_nonneg hlam hx_nonneg hx_ne hsub k
  letI : CompleteSpace (Matrix (Fin n) (Fin n) ℂ) :=
    FiniteDimensional.complete ℂ _
  have hcomplete_check : CompleteSpace (Matrix (Fin n) (Fin n) ℂ) := inferInstance
  have hlim :=
    @spectrum.pow_norm_pow_one_div_tendsto_nhds_spectralRadius
      (Matrix (Fin n) (Fin n) ℂ) inferInstance inferInstance hcomplete_check C
  refine ge_of_tendsto hlim ?_
  refine Filter.eventually_atTop.2 ⟨1, ?_⟩
  intro k hk
  have hk_pos_nat : 0 < k := Nat.pos_of_ne_zero (Nat.ne_zero_of_lt hk)
  have hk_pos : 0 < (k : ℝ) := Nat.cast_pos.mpr hk_pos_nat
  have hpow_nonneg : 0 ≤ lam ^ k := pow_nonneg hlam k
  have hroot :=
    Real.rpow_le_rpow hpow_nonneg (hpow_bound k)
      (le_of_lt (one_div_pos.mpr hk_pos))
  have hroot' :
      (lam ^ k) ^ (1 / (k : ℝ)) ≤
        ‖C ^ k‖ ^ (1 / (k : ℝ)) := by
    simpa [one_div] using hroot
  have hleft : (lam ^ k) ^ (1 / (k : ℝ)) = lam := by
    rw [← Real.rpow_natCast lam k]
    rw [← Real.rpow_mul hlam]
    have hmul : (k : ℝ) * (1 / (k : ℝ)) = 1 := by
      field_simp [ne_of_gt hk_pos]
    rw [hmul, Real.rpow_one]
  have hleft' : (lam ^ k) ^ ((k : ℝ)⁻¹) = lam := by
    simpa [one_div] using hleft
  have hreal : lam ≤ ‖C ^ k‖ ^ (1 / (k : ℝ)) := by
    simpa [one_div, hleft'] using hroot'
  exact ENNReal.ofReal_le_ofReal hreal

end Ch7MatrixOperatorNorm

/-- The algebraic spectral radius is unchanged by Mathlib's finite
`Matrix.toLin'` algebra equivalence. -/
theorem ch7_toLin_spectralRadius_eq_matrix_spectralRadius {n : ℕ}
    (C : Matrix (Fin n) (Fin n) ℂ) :
    spectralRadius ℂ (Matrix.toLin' C) = spectralRadius ℂ C := by
  unfold spectralRadius
  rw [Matrix.spectrum_toLin' C]

/-- Finite-dimensional spectral shift for the matrix `I - C`: zero is in the
spectrum of `I - C` exactly when one is in the spectrum of `C`. -/
theorem ch7_spectrum_zero_mem_one_sub_iff {n : ℕ}
    (C : Matrix (Fin n) (Fin n) ℂ) :
    ((0 : ℂ) ∈ spectrum ℂ ((1 : Matrix (Fin n) (Fin n) ℂ) - C)) ↔
      ((1 : ℂ) ∈ spectrum ℂ C) := by
  rw [spectrum.mem_iff, spectrum.mem_iff]
  simp
  constructor
  · intro h hunit
    apply h
    simpa [neg_sub] using hunit.neg
  · intro h hunit
    apply h
    simpa [neg_sub] using hunit.neg

/-- If a finite complex matrix has spectral radius below one, then `I - C`
is nonsingular.  This is the algebraic resolvent nonsingularity bridge behind
Chapter 7/9 spectral-radius contraction arguments. -/
theorem ch7_complex_det_one_sub_ne_zero_of_spectralRadius_lt_one {n : ℕ}
    (C : Matrix (Fin n) (Fin n) ℂ)
    (hrho : spectralRadius ℂ C < 1) :
    Matrix.det ((1 : Matrix (Fin n) (Fin n) ℂ) - C) ≠ 0 := by
  classical
  have hzero_not :
      (0 : ℂ) ∉ spectrum ℂ ((1 : Matrix (Fin n) (Fin n) ℂ) - C) := by
    intro hzero
    have hone_spec : (1 : ℂ) ∈ spectrum ℂ C :=
      (ch7_spectrum_zero_mem_one_sub_iff C).mp hzero
    have hone_le : (1 : ENNReal) ≤ spectralRadius ℂ C := by
      unfold spectralRadius
      have h :=
        @le_iSup₂ ENNReal ℂ (fun k : ℂ => k ∈ spectrum ℂ C) _
          (fun k _ => (nnnorm k : ENNReal)) (1 : ℂ) hone_spec
      simpa using h
    exact (not_lt_of_ge hone_le) hrho
  have hunit : IsUnit ((1 : Matrix (Fin n) (Fin n) ℂ) - C) :=
    spectrum.isUnit_of_zero_notMem ℂ hzero_not
  have hdet_unit :
      IsUnit (Matrix.det ((1 : Matrix (Fin n) (Fin n) ℂ) - C)) :=
    (Matrix.isUnit_iff_isUnit_det
      ((1 : Matrix (Fin n) (Fin n) ℂ) - C)).mp hunit
  exact isUnit_iff_ne_zero.mp hdet_unit

/-- Complexification commutes with the repository's real matrix `I - M`
surface. -/
lemma ch7_realRectToCMatrix_matSub_id {n : ℕ}
    (M : Fin n → Fin n → ℝ) :
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix (matSub_id n M)) =
      (1 : Matrix (Fin n) (Fin n) ℂ) -
        (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M) := by
  ext i j
  by_cases h : i = j <;> simp [h, realRectToCMatrix, matSub_id, idMatrix]

/-- Determinant compatibility for the repository's real-to-complex matrix
complexification. -/
lemma ch7_realRectToCMatrix_det {n : ℕ}
    (M : Fin n → Fin n → ℝ) :
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M).det =
      (((Matrix.of M : Matrix (Fin n) (Fin n) ℝ).det : ℝ) : ℂ) := by
  have h :=
    RingHom.map_det Complex.ofRealHom
      (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)
  simpa [realRectToCMatrix, RingHom.mapMatrix_apply] using h.symm

/-- Real-matrix form of the spectral resolvent nonsingularity bridge:
`rho(M) < 1`, represented through the complexified `toLin'` spectral radius,
implies `det(I - M) ≠ 0`. -/
theorem ch7_matSub_id_det_ne_zero_of_toLin_spectralRadius_lt_one {n : ℕ}
    (M : Fin n → Fin n → ℝ)
    (hrho :
      spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) < 1) :
    (Matrix.of (matSub_id n M) : Matrix (Fin n) (Fin n) ℝ).det ≠ 0 := by
  classical
  let C : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)
  have hrho_matrix : spectralRadius ℂ C < 1 := by
    have h := hrho
    rw [ch7_toLin_spectralRadius_eq_matrix_spectralRadius C] at h
    simpa [C] using h
  have hdet_one_sub :
      Matrix.det ((1 : Matrix (Fin n) (Fin n) ℂ) - C) ≠ 0 :=
    ch7_complex_det_one_sub_ne_zero_of_spectralRadius_lt_one C hrho_matrix
  have hdet_complex_sub :
      (show Matrix (Fin n) (Fin n) ℂ from
        realRectToCMatrix (matSub_id n M)).det ≠ 0 := by
    rw [ch7_realRectToCMatrix_matSub_id M]
    simpa [C] using hdet_one_sub
  have hdet_coe :
      (((Matrix.of (matSub_id n M) : Matrix (Fin n) (Fin n) ℝ).det : ℝ) :
          ℂ) ≠ 0 := by
    rwa [ch7_realRectToCMatrix_det (matSub_id n M)] at hdet_complex_sub
  intro hzero
  exact hdet_coe (by simp [hzero])

/-- Canonical inverse certificate for `I - M` under spectral-radius
contraction. -/
theorem ch7_matSub_id_nonsingInv_isInverse_of_toLin_spectralRadius_lt_one
    {n : ℕ} (M : Fin n → Fin n → ℝ)
    (hrho :
      spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) < 1) :
    IsInverse n (matSub_id n M) (nonsingInv n (matSub_id n M)) := by
  exact isInverse_nonsingInv_of_det_ne_zero n (matSub_id n M)
    (by
      simpa using
        ch7_matSub_id_det_ne_zero_of_toLin_spectralRadius_lt_one M hrho)

/-- `toLin'`-facing form of the Collatz/Gelfand lower bound used to close the
Perron-Frobenius equality gate. -/
theorem ch7_toLin_spectralRadius_ge_of_positive_right_subeigenvector {n : ℕ}
    (hn : 0 < n) (M : Fin n → Fin n → ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j)
    (hlam : 0 ≤ lam)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ENNReal.ofReal lam ≤
      spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) := by
  rw [ch7_toLin_spectralRadius_eq_matrix_spectralRadius]
  exact ch7_matrix_spectralRadius_ge_of_positive_right_subeigenvector
    hn M lam x hM_nonneg hlam hx hsub

/-- `toLin'`-facing form of the nonzero-nonnegative Collatz/Gelfand lower
bound. -/
theorem ch7_toLin_spectralRadius_ge_of_nonzero_nonneg_right_subeigenvector
    {n : ℕ} (hn : 0 < n) (M : Fin n → Fin n → ℝ) (lam : ℝ)
    (x : Fin n → ℝ)
    (hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j)
    (hlam : 0 ≤ lam)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ENNReal.ofReal lam ≤
      spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) := by
  rw [ch7_toLin_spectralRadius_eq_matrix_spectralRadius]
  exact ch7_matrix_spectralRadius_ge_of_nonzero_nonneg_right_subeigenvector
    hn M lam x hM_nonneg hlam hx_nonneg hx_ne hsub

/-- If `M ≥ 0` and the complexified Mathlib spectral radius of `M` is below
one, then every solution of `(I-M)w = v` with `v ≥ 0` is nonnegative.  This is
the spectral-radius analogue of `ch7_nonnegative_solution_of_nonnegative_contraction`.
-/
theorem ch7_nonnegative_solution_of_nonnegative_spectralRadius_lt_one
    {n : ℕ} (hn : 0 < n)
    (M : Fin n → Fin n → ℝ)
    (hM : ∀ i j : Fin n, 0 ≤ M i j)
    (hrho :
      spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) < 1)
    (v w : Fin n → ℝ)
    (hv : ∀ i : Fin n, 0 ≤ v i)
    (hsolve : ∀ i : Fin n, w i - ∑ j : Fin n, M i j * w j = v i) :
    ∀ i : Fin n, 0 ≤ w i := by
  let p : Fin n → ℝ := fun i => max 0 (-w i)
  have hp_nonneg : ∀ i : Fin n, 0 ≤ p i := by
    intro i
    exact le_max_left 0 (-w i)
  have hneg_le_p : ∀ i : Fin n, -w i ≤ p i := by
    intro i
    exact le_max_right 0 (-w i)
  have hpineq : ∀ i : Fin n, p i ≤ matMulVec n M p i := by
    intro i
    by_cases hwi : 0 ≤ w i
    · have hpi : p i = 0 := by
        dsimp [p]
        exact max_eq_left (neg_nonpos.mpr hwi)
      calc
        p i = 0 := hpi
        _ ≤ matMulVec n M p i := by
          unfold matMulVec
          exact Finset.sum_nonneg fun j _ =>
            mul_nonneg (hM i j) (hp_nonneg j)
    · have hwi_lt : w i < 0 := lt_of_not_ge hwi
      have hpi : p i = -w i := by
        dsimp [p]
        exact max_eq_right (le_of_lt (neg_pos.mpr hwi_lt))
      have hw_eq : w i = v i + ∑ j : Fin n, M i j * w j := by
        linarith [hsolve i]
      calc
        p i = -w i := hpi
        _ = -v i - ∑ j : Fin n, M i j * w j := by
          rw [hw_eq]
          ring
        _ ≤ -(∑ j : Fin n, M i j * w j) := by
          linarith [hv i]
        _ = ∑ j : Fin n, M i j * (-w j) := by
          rw [← Finset.sum_neg_distrib]
          apply Finset.sum_congr rfl
          intro j _
          ring
        _ ≤ ∑ j : Fin n, M i j * p j := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left (hneg_le_p j) (hM i j)
        _ = matMulVec n M p i := rfl
  have hp_zero : p = 0 := by
    by_contra hp_ne
    have hle :
        (1 : ENNReal) ≤
          spectralRadius ℂ
            (Matrix.toLin'
              (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) := by
      have hsub : ∀ i : Fin n, (1 : ℝ) * p i ≤ matMulVec n M p i := by
        intro i
        simpa [one_mul] using hpineq i
      have h :=
        ch7_toLin_spectralRadius_ge_of_nonzero_nonneg_right_subeigenvector
          hn M 1 p hM (by norm_num) hp_nonneg hp_ne hsub
      simpa using h
    exact (not_lt_of_ge hle) hrho
  intro i
  have hneg : -w i ≤ 0 := by
    exact le_trans (hneg_le_p i) (by simp [hp_zero])
  linarith

/-- The canonical inverse of `I-M` is a nonnegative resolvent whenever
`M ≥ 0` and `rho(M) < 1`. -/
theorem ch7NonnegativeResolvent_nonsingInv_of_spectralRadius_lt_one
    {n : ℕ} (hn : 0 < n)
    (M : Fin n → Fin n → ℝ)
    (hM : ∀ i j : Fin n, 0 ≤ M i j)
    (hrho :
      spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) < 1) :
    ch7NonnegativeResolvent n M (nonsingInv n (matSub_id n M)) := by
  have hInv : IsInverse n (matSub_id n M) (nonsingInv n (matSub_id n M)) :=
    ch7_matSub_id_nonsingInv_isInverse_of_toLin_spectralRadius_lt_one M hrho
  refine ⟨?_, hInv.1⟩
  intro i j
  let w : Fin n → ℝ := fun k => nonsingInv n (matSub_id n M) k j
  let e : Fin n → ℝ := fun k => if k = j then (1 : ℝ) else 0
  have he_nonneg : ∀ k : Fin n, 0 ≤ e k := by
    intro k
    dsimp [e]
    split <;> norm_num
  have hsolve : ∀ k : Fin n, w k - ∑ l : Fin n, M k l * w l = e k := by
    intro k
    have hk := hInv.2 k j
    dsimp [w, e]
    have hid :
        (∑ l : Fin n, (if k = l then (1 : ℝ) else 0) *
            nonsingInv n (matSub_id n M) l j) =
          nonsingInv n (matSub_id n M) k j := by
      simp
    calc
      nonsingInv n (matSub_id n M) k j -
          ∑ l : Fin n, M k l * nonsingInv n (matSub_id n M) l j
          =
        (∑ l : Fin n, (if k = l then (1 : ℝ) else 0) *
            nonsingInv n (matSub_id n M) l j) -
          ∑ l : Fin n, M k l * nonsingInv n (matSub_id n M) l j := by
            rw [hid]
      _ = ∑ l : Fin n, ((if k = l then (1 : ℝ) else 0) - M k l) *
            nonsingInv n (matSub_id n M) l j := by
            rw [← Finset.sum_sub_distrib]
            apply Finset.sum_congr rfl
            intro l _
            ring
      _ = ∑ l : Fin n, matSub_id n M k l *
            nonsingInv n (matSub_id n M) l j := by
            apply Finset.sum_congr rfl
            intro l _
            unfold matSub_id idMatrix
            ring
      _ = if k = j then (1 : ℝ) else 0 := by
            simpa using hk
  have hw_nonneg :=
    ch7_nonnegative_solution_of_nonnegative_spectralRadius_lt_one
      hn M hM hrho e w he_nonneg hsolve
  exact hw_nonneg i

/-- Finite-sum form of `ch7_matrix_pow_mulVec_subeigen_le_of_nonneg`.  This
connects the subeigenvector iteration to the finite positive power sums
supplied by irreducibility. -/
lemma ch7_pow_sum_mulVec_subeigen_le_of_nonneg {n : ℕ}
    (A : Matrix (Fin n) (Fin n) ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hA_nonneg : ∀ i j : Fin n, 0 ≤ A i j)
    (hlam : 0 ≤ lam)
    (hsub : ∀ i : Fin n, lam * x i ≤ Matrix.mulVec A x i)
    (s : Finset ℕ) :
    ∀ i : Fin n,
      (∑ k ∈ s, lam ^ k * x i) ≤
        ∑ k ∈ s, Matrix.mulVec (A ^ k) x i := by
  intro i
  exact Finset.sum_le_sum fun k _hk =>
    ch7_matrix_pow_mulVec_subeigen_le_of_nonneg A lam x hA_nonneg hlam hsub k i

/-- A one-step subeigenvector inequality propagates from `x` to every powered
iterate `A^k x` when `A` is nonnegative. -/
lemma ch7_matrix_pow_mulVec_subeigen_step_of_nonneg {n : ℕ}
    (A : Matrix (Fin n) (Fin n) ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hA_nonneg : ∀ i j : Fin n, 0 ≤ A i j)
    (hsub : ∀ i : Fin n, lam * x i ≤ Matrix.mulVec A x i) :
    ∀ k : ℕ, ∀ i : Fin n,
      lam * Matrix.mulVec (A ^ k) x i ≤
        Matrix.mulVec (A ^ Nat.succ k) x i := by
  intro k
  induction k with
  | zero =>
      intro i
      simpa using hsub i
  | succ k ih =>
      intro i
      have hmono :
          Matrix.mulVec A
              (fun j : Fin n => lam * Matrix.mulVec (A ^ k) x j) i ≤
            Matrix.mulVec A (Matrix.mulVec (A ^ Nat.succ k) x) i :=
        ch7_matrix_mulVec_mono_of_nonneg A hA_nonneg (fun j => ih j) i
      have hleft :
          Matrix.mulVec A
              (fun j : Fin n => lam * Matrix.mulVec (A ^ k) x j) i =
            lam * Matrix.mulVec (A ^ Nat.succ k) x i := by
        have hvec :
            (fun j : Fin n => lam * Matrix.mulVec (A ^ k) x j) =
              lam • Matrix.mulVec (A ^ k) x := by
          ext j
          simp [Pi.smul_apply, smul_eq_mul]
        have hpow_mulVec :
            Matrix.mulVec A (Matrix.mulVec (A ^ k) x) i =
              Matrix.mulVec (A ^ Nat.succ k) x i := by
          calc
            Matrix.mulVec A (Matrix.mulVec (A ^ k) x) i =
                Matrix.mulVec (A * A ^ k) x i := by
                  rw [← Matrix.mulVec_mulVec]
            _ = Matrix.mulVec (A ^ Nat.succ k) x i := by
                  rw [← pow_succ']
        calc
          Matrix.mulVec A
              (fun j : Fin n => lam * Matrix.mulVec (A ^ k) x j) i =
              (lam • Matrix.mulVec A (Matrix.mulVec (A ^ k) x)) i := by
                rw [hvec, Matrix.mulVec_smul]
          _ = lam * Matrix.mulVec A (Matrix.mulVec (A ^ k) x) i := by
                simp [Pi.smul_apply, smul_eq_mul]
          _ = lam * Matrix.mulVec (A ^ Nat.succ k) x i := by
                rw [hpow_mulVec]
      have hright :
          Matrix.mulVec A (Matrix.mulVec (A ^ Nat.succ k) x) i =
            Matrix.mulVec (A ^ Nat.succ (Nat.succ k)) x i := by
        calc
          Matrix.mulVec A (Matrix.mulVec (A ^ Nat.succ k) x) i =
              Matrix.mulVec (A * A ^ Nat.succ k) x i := by
                rw [← Matrix.mulVec_mulVec]
          _ = Matrix.mulVec (A ^ Nat.succ (Nat.succ k)) x i := by
                rw [← pow_succ']
      calc
        lam * Matrix.mulVec (A ^ Nat.succ k) x i =
            Matrix.mulVec A
              (fun j : Fin n => lam * Matrix.mulVec (A ^ k) x j) i :=
              hleft.symm
        _ ≤ Matrix.mulVec A (Matrix.mulVec (A ^ Nat.succ k) x) i := hmono
        _ = Matrix.mulVec (A ^ Nat.succ (Nat.succ k)) x i := hright

/-- Irreducibility supplies a finite positive polynomial in the matrix: a
finite sum of positive powers whose every entry is strictly positive.  This is
the matrix-level companion to the vector support-propagation lemma and is a
standard finite-dimensional Perron-Frobenius reduction step. -/
lemma ch7_exists_irreducible_pow_sum_pos {n : ℕ}
    (M : Fin n → Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)) :
    ∃ s : Finset ℕ, (∀ k ∈ s, 0 < k) ∧
      ∀ i j : Fin n,
        0 <
          ∑ k ∈ s,
            ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) i j := by
  classical
  have hM_nonneg : ∀ i j : Fin n,
      0 ≤ (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) i j := hM.1
  have hpow_exists : ∀ i j : Fin n,
      ∃ k > 0, 0 < ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) i j :=
    (Matrix.isIrreducible_iff_exists_pow_pos hM_nonneg).mp hM
  let kOf : Fin n × Fin n → ℕ :=
    fun p => Classical.choose (hpow_exists p.1 p.2)
  have hk_pos : ∀ p : Fin n × Fin n, 0 < kOf p := by
    intro p
    exact (Classical.choose_spec (hpow_exists p.1 p.2)).1
  have hk_entry_pos : ∀ p : Fin n × Fin n,
      0 <
        ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ kOf p) p.1 p.2 := by
    intro p
    exact (Classical.choose_spec (hpow_exists p.1 p.2)).2
  refine ⟨Finset.univ.image kOf, ?_, ?_⟩
  · intro k hk
    rcases Finset.mem_image.mp hk with ⟨p, _hp, hpk⟩
    simpa [← hpk] using hk_pos p
  · intro i j
    have hterms_nonneg : ∀ k : ℕ, k ∈ Finset.univ.image kOf →
        0 ≤ ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) i j := by
      intro k _hk
      exact Matrix.pow_apply_nonneg hM_nonneg k i j
    have hmem : kOf (i, j) ∈ Finset.univ.image kOf :=
      Finset.mem_image.mpr ⟨(i, j), Finset.mem_univ (i, j), rfl⟩
    exact Finset.sum_pos' hterms_nonneg
      ⟨kOf (i, j), hmem, hk_entry_pos (i, j)⟩

/-- A finite sum of positive powers of an irreducible nonnegative matrix sends
any nonzero nonnegative vector to a strictly positive vector.  This uniformizes
the coordinate-by-coordinate support-propagation lemma and is a local
dependency for the remaining Perron-Frobenius existence route in Theorem 7.8 /
Problem 7.10. -/
lemma ch7_exists_irreducible_pow_sum_mulVec_pos_of_nonzero_nonneg {n : ℕ}
    (M : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0) :
    ∃ s : Finset ℕ, (∀ k ∈ s, 0 < k) ∧
      ∀ i : Fin n,
        0 <
          ∑ k ∈ s,
            Matrix.mulVec
              ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i := by
  classical
  have hcoord :
      ∀ i : Fin n, ∃ k > 0,
        0 <
          Matrix.mulVec
            ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i :=
    ch7_irreducible_pow_mulVec_pos_of_nonzero_nonneg M x hM hx_nonneg hx_ne
  let kOf : Fin n → ℕ := fun i => Classical.choose (hcoord i)
  have hk_pos : ∀ i : Fin n, 0 < kOf i := by
    intro i
    exact (Classical.choose_spec (hcoord i)).1
  have hk_mulVec_pos : ∀ i : Fin n,
      0 <
        Matrix.mulVec
          ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ kOf i) x i := by
    intro i
    exact (Classical.choose_spec (hcoord i)).2
  refine ⟨Finset.univ.image kOf, ?_, ?_⟩
  · intro k hk
    rcases Finset.mem_image.mp hk with ⟨i, _hi, hik⟩
    simpa [← hik] using hk_pos i
  · intro i
    have hterms_nonneg : ∀ k : ℕ, k ∈ Finset.univ.image kOf →
        0 ≤
          Matrix.mulVec
            ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i := by
      intro k _hk
      exact ch7_matrix_pow_mulVec_nonneg_of_nonneg M x hM.1 hx_nonneg k i
    have hk_mem : kOf i ∈ Finset.univ.image kOf :=
      Finset.mem_image.mpr ⟨i, Finset.mem_univ i, rfl⟩
    exact Finset.sum_pos' hterms_nonneg
      ⟨kOf i, hk_mem, hk_mulVec_pos i⟩

/-- Combined finite-power certificate for the Perron-Frobenius route: an
irreducible nonnegative matrix sends every nonzero nonnegative subeigenvector
to a strictly positive finite powered-iterate sum, and the subeigenvector
inequality iterates under the same sum.  This is still below the full
Perron-Frobenius existence theorem. -/
lemma ch7_exists_irreducible_pow_sum_mulVec_pos_and_subeigen_le
    {n : ℕ}
    (M : Fin n → Fin n → ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hlam : 0 ≤ lam)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ∃ s : Finset ℕ, (∀ k ∈ s, 0 < k) ∧
      ∀ i : Fin n,
        0 <
          ∑ k ∈ s,
            Matrix.mulVec
              ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i ∧
        (∑ k ∈ s, lam ^ k * x i) ≤
          ∑ k ∈ s,
            Matrix.mulVec
              ((Matrix.of M : Matrix (Fin n) (Fin n) ℝ) ^ k) x i := by
  obtain ⟨s, hs_pos, hs_mulVec_pos⟩ :=
    ch7_exists_irreducible_pow_sum_mulVec_pos_of_nonzero_nonneg
      M x hM hx_nonneg hx_ne
  have hsub_matrix :
      ∀ i : Fin n,
        lam * x i ≤
          Matrix.mulVec
            (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) x i := by
    intro i
    simpa [ch7_matrix_mulVec_eq_matMulVec M x] using hsub i
  refine ⟨s, hs_pos, fun i => ⟨hs_mulVec_pos i, ?_⟩⟩
  exact
    ch7_pow_sum_mulVec_subeigen_le_of_nonneg
      (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) lam x hM.1
      hlam hsub_matrix s i

/-- Irreducibility upgrades a nonzero nonnegative subeigenvector into a
strictly positive subeigenvector by summing positive powered iterates.  This is
a local Perron-Frobenius route dependency; it still does not assert existence
of an eigenvector or equality at the spectral radius. -/
lemma ch7_exists_positive_subeigenvector_of_irreducible_nonzero_nonneg_subeigen
    {n : ℕ}
    (M : Fin n → Fin n → ℝ) (lam : ℝ) (x : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (hsub : ∀ i : Fin n, lam * x i ≤ matMulVec n M x i) :
    ∃ y : Fin n → ℝ,
      (∀ i : Fin n, 0 < y i) ∧
        ∀ i : Fin n, lam * y i ≤ matMulVec n M y i := by
  classical
  let A : Matrix (Fin n) (Fin n) ℝ :=
    (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)
  obtain ⟨s, _hs_pos, hs_mulVec_pos⟩ :=
    ch7_exists_irreducible_pow_sum_mulVec_pos_of_nonzero_nonneg
      M x hM hx_nonneg hx_ne
  let y : Fin n → ℝ :=
    fun i => ∑ k ∈ s, Matrix.mulVec (A ^ k) x i
  have hsub_matrix : ∀ i : Fin n, lam * x i ≤ Matrix.mulVec A x i := by
    intro i
    simpa [A, ch7_matrix_mulVec_eq_matMulVec M x] using hsub i
  have hstep : ∀ k : ℕ, ∀ i : Fin n,
      lam * Matrix.mulVec (A ^ k) x i ≤
        Matrix.mulVec (A ^ Nat.succ k) x i :=
    ch7_matrix_pow_mulVec_subeigen_step_of_nonneg A lam x hM.1 hsub_matrix
  refine ⟨y, ?_, ?_⟩
  · intro i
    simpa [y, A] using hs_mulVec_pos i
  · intro i
    have hleft :
        lam * y i =
          ∑ k ∈ s, lam * Matrix.mulVec (A ^ k) x i := by
      simp [y, Finset.mul_sum]
    have hright :
        Matrix.mulVec A y i =
          ∑ k ∈ s, Matrix.mulVec (A ^ Nat.succ k) x i := by
      have hy_sum : y = ∑ k ∈ s, Matrix.mulVec (A ^ k) x := by
        ext j
        simp [y]
      rw [hy_sum, Matrix.mulVec_sum]
      rw [Finset.sum_apply]
      apply Finset.sum_congr rfl
      intro k _hk
      calc
        Matrix.mulVec A (Matrix.mulVec (A ^ k) x) i =
            Matrix.mulVec (A * A ^ k) x i := by
              rw [← Matrix.mulVec_mulVec]
        _ = Matrix.mulVec (A ^ Nat.succ k) x i := by
              rw [← pow_succ']
    have hmat :
        lam * y i ≤ Matrix.mulVec A y i := by
      calc
        lam * y i =
            ∑ k ∈ s, lam * Matrix.mulVec (A ^ k) x i := hleft
        _ ≤ ∑ k ∈ s, Matrix.mulVec (A ^ Nat.succ k) x i :=
            Finset.sum_le_sum fun k _hk => hstep k i
        _ = Matrix.mulVec A y i := hright.symm
    simpa [A, ch7_matrix_mulVec_eq_matMulVec M y] using hmat

/-- Strict Collatz step for the remaining Perron-Frobenius closure: if a
strictly positive subeigenvector has a strict defect in at least one
coordinate, irreducibility propagates that defect and yields a strictly larger
positive subeigenvalue.  This is still below the full spectral-radius
contradiction, but removes the local propagation bottleneck. -/
lemma ch7_exists_stronger_positive_subeigenvector_of_strict_subeigen
    {n : ℕ} (hn : 0 < n)
    (M : Fin n → Fin n → ℝ) (lam : ℝ) (y : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hy_pos : ∀ i : Fin n, 0 < y i)
    (hsub : ∀ i : Fin n, lam * y i ≤ matMulVec n M y i)
    (hstrict : ∃ i : Fin n, lam * y i < matMulVec n M y i) :
    ∃ eps : ℝ, ∃ v : Fin n → ℝ,
      0 < eps ∧
      (∀ i : Fin n, 0 < v i) ∧
      ∀ i : Fin n, (lam + eps) * v i ≤ matMulVec n M v i := by
  classical
  let A : Matrix (Fin n) (Fin n) ℝ :=
    (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)
  let w : Fin n → ℝ := fun i => Matrix.mulVec A y i - lam * y i
  have hsub_matrix :
      ∀ i : Fin n, lam * y i ≤ Matrix.mulVec A y i := by
    intro i
    simpa [A, ch7_matrix_mulVec_eq_matMulVec M y] using hsub i
  have hw_nonneg : ∀ i : Fin n, 0 ≤ w i := by
    intro i
    exact sub_nonneg.mpr (hsub_matrix i)
  obtain ⟨i0, hstrict_i0⟩ := hstrict
  have hw_pos_i0 : 0 < w i0 := by
    dsimp [w]
    exact sub_pos.mpr (by
      simpa [A, ch7_matrix_mulVec_eq_matMulVec M y] using hstrict_i0)
  have hw_ne : w ≠ 0 := by
    intro hw_eq
    have : w i0 = 0 := by simp [hw_eq]
    linarith
  obtain ⟨s, _hs_pos, hsum_w_pos⟩ :=
    ch7_exists_irreducible_pow_sum_mulVec_pos_of_nonzero_nonneg
      M w hM hw_nonneg hw_ne
  let ysum : Fin n → ℝ := ∑ k ∈ s, Matrix.mulVec (A ^ k) y
  let v : Fin n → ℝ := y + ysum
  have hy_nonneg : ∀ i : Fin n, 0 ≤ y i := fun i => le_of_lt (hy_pos i)
  have hysum_nonneg : ∀ i : Fin n, 0 ≤ ysum i := by
    intro i
    dsimp [ysum]
    rw [Finset.sum_apply]
    exact Finset.sum_nonneg fun k _hk =>
      ch7_matrix_pow_mulVec_nonneg_of_nonneg M y hM.1 hy_nonneg k i
  have hv_pos : ∀ i : Fin n, 0 < v i := by
    intro i
    dsimp [v]
    nlinarith [hy_pos i, hysum_nonneg i]
  have hpow_defect : ∀ k : ℕ, ∀ i : Fin n,
      Matrix.mulVec (A ^ k) w i =
        Matrix.mulVec (A ^ Nat.succ k) y i -
          lam * Matrix.mulVec (A ^ k) y i := by
    intro k i
    have hw_vec : w = Matrix.mulVec A y - lam • y := by
      ext j
      simp [w, Pi.smul_apply, smul_eq_mul]
    have hpow_mul :
        Matrix.mulVec (A ^ k) (Matrix.mulVec A y) i =
          Matrix.mulVec (A ^ Nat.succ k) y i := by
      calc
        Matrix.mulVec (A ^ k) (Matrix.mulVec A y) i =
            Matrix.mulVec (A ^ k * A) y i := by
              rw [← Matrix.mulVec_mulVec]
        _ = Matrix.mulVec (A ^ Nat.succ k) y i := by
              rw [← pow_succ]
    calc
      Matrix.mulVec (A ^ k) w i =
          Matrix.mulVec (A ^ k) (Matrix.mulVec A y - lam • y) i := by
            rw [hw_vec]
      _ = Matrix.mulVec (A ^ k) (Matrix.mulVec A y) i -
            Matrix.mulVec (A ^ k) (lam • y) i := by
            rw [Matrix.mulVec_sub]
            rfl
      _ = Matrix.mulVec (A ^ Nat.succ k) y i -
            lam * Matrix.mulVec (A ^ k) y i := by
            rw [hpow_mul, Matrix.mulVec_smul]
            simp [Pi.smul_apply, smul_eq_mul]
  have hAv_sum : ∀ i : Fin n,
      Matrix.mulVec A ysum i =
        ∑ k ∈ s, Matrix.mulVec (A ^ Nat.succ k) y i := by
    intro i
    dsimp [ysum]
    rw [Matrix.mulVec_sum]
    rw [Finset.sum_apply]
    apply Finset.sum_congr rfl
    intro k _hk
    calc
      Matrix.mulVec A (Matrix.mulVec (A ^ k) y) i =
          Matrix.mulVec (A * A ^ k) y i := by
            rw [← Matrix.mulVec_mulVec]
      _ = Matrix.mulVec (A ^ Nat.succ k) y i := by
            rw [← pow_succ']
  have hlam_ysum : ∀ i : Fin n,
      lam * ysum i =
        ∑ k ∈ s, lam * Matrix.mulVec (A ^ k) y i := by
    intro i
    dsimp [ysum]
    rw [Finset.sum_apply]
    rw [Finset.mul_sum]
  have hsum_defect : ∀ i : Fin n,
      (∑ k ∈ s, Matrix.mulVec (A ^ Nat.succ k) y i) -
          (∑ k ∈ s, lam * Matrix.mulVec (A ^ k) y i) =
        ∑ k ∈ s, Matrix.mulVec (A ^ k) w i := by
    intro i
    rw [← Finset.sum_sub_distrib]
    apply Finset.sum_congr rfl
    intro k _hk
    exact (hpow_defect k i).symm
  have hdefect_eq : ∀ i : Fin n,
      Matrix.mulVec A v i - lam * v i =
        w i + ∑ k ∈ s, Matrix.mulVec (A ^ k) w i := by
    intro i
    have hAv :
        Matrix.mulVec A v i =
          Matrix.mulVec A y i +
            ∑ k ∈ s, Matrix.mulVec (A ^ Nat.succ k) y i := by
      dsimp [v]
      rw [Matrix.mulVec_add]
      rw [Pi.add_apply]
      rw [hAv_sum i]
    have hlamv :
        lam * v i =
          lam * y i + ∑ k ∈ s, lam * Matrix.mulVec (A ^ k) y i := by
      dsimp [v]
      rw [mul_add]
      rw [hlam_ysum i]
    calc
      Matrix.mulVec A v i - lam * v i =
          (Matrix.mulVec A y i +
              ∑ k ∈ s, Matrix.mulVec (A ^ Nat.succ k) y i) -
            (lam * y i +
              ∑ k ∈ s, lam * Matrix.mulVec (A ^ k) y i) := by
            rw [hAv, hlamv]
      _ = (Matrix.mulVec A y i - lam * y i) +
            ((∑ k ∈ s, Matrix.mulVec (A ^ Nat.succ k) y i) -
              (∑ k ∈ s, lam * Matrix.mulVec (A ^ k) y i)) := by
            ring
      _ = w i + ∑ k ∈ s, Matrix.mulVec (A ^ k) w i := by
            rw [hsum_defect i]
  have hdefect_pos : ∀ i : Fin n,
      0 < Matrix.mulVec A v i - lam * v i := by
    intro i
    rw [hdefect_eq i]
    exact add_pos_of_nonneg_of_pos (hw_nonneg i) (hsum_w_pos i)
  let ratio : Fin n → ℝ :=
    fun i => (Matrix.mulVec A v i - lam * v i) / v i
  have hratio_pos : ∀ i : Fin n, 0 < ratio i := by
    intro i
    exact div_pos (hdefect_pos i) (hv_pos i)
  obtain ⟨c, hc_pos, hc_le⟩ := ch7_exists_pos_le_all_fin hn ratio hratio_pos
  let eps : ℝ := c / 2
  have heps_pos : 0 < eps := by
    dsimp [eps]
    linarith
  refine ⟨eps, v, heps_pos, hv_pos, ?_⟩
  intro i
  have heps_le_ratio : eps ≤ ratio i := by
    dsimp [eps]
    linarith [hc_pos, hc_le i]
  have heps_mul_le :
      eps * v i ≤ Matrix.mulVec A v i - lam * v i := by
    exact (le_div_iff₀ (hv_pos i)).mp heps_le_ratio
  have hmat :
      (lam + eps) * v i ≤ Matrix.mulVec A v i := by
    calc
      (lam + eps) * v i = lam * v i + eps * v i := by ring
      _ ≤ lam * v i + (Matrix.mulVec A v i - lam * v i) :=
          add_le_add le_rfl heps_mul_le
      _ = Matrix.mulVec A v i := by ring
  simpa [A, ch7_matrix_mulVec_eq_matMulVec M v] using hmat

/-- Dichotomy form of the strict Collatz step: a strictly positive
subeigenvector of an irreducible nonnegative matrix is either already a right
eigenvector, or it can be upgraded to a positive subeigenvector for a strictly
larger scalar. -/
lemma ch7_positive_subeigenvector_eigen_or_exists_stronger
    {n : ℕ} (hn : 0 < n)
    (M : Fin n → Fin n → ℝ) (lam : ℝ) (y : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hy_pos : ∀ i : Fin n, 0 < y i)
    (hsub : ∀ i : Fin n, lam * y i ≤ matMulVec n M y i) :
    (∀ i : Fin n, matMulVec n M y i = lam * y i) ∨
      ∃ eps : ℝ, ∃ v : Fin n → ℝ,
        0 < eps ∧
        (∀ i : Fin n, 0 < v i) ∧
        ∀ i : Fin n, (lam + eps) * v i ≤ matMulVec n M v i := by
  by_cases heig : ∀ i : Fin n, matMulVec n M y i = lam * y i
  · exact Or.inl heig
  · right
    apply ch7_exists_stronger_positive_subeigenvector_of_strict_subeigen
      hn M lam y hM hy_pos hsub
    by_contra hnostrict
    apply heig
    intro i
    have hnot_lt : ¬ lam * y i < matMulVec n M y i := by
      intro hlt
      exact hnostrict ⟨i, hlt⟩
    exact le_antisymm (not_lt.mp hnot_lt) (hsub i)

/-- A nonnegative irreducible matrix has a spectral-radius-attaining complex
eigenpair whose absolute-value subeigenvector can be upgraded to a strictly
positive subeigenvector.  This is the positive subeigenvector stage of the
Bauer/Perron route; it still does not assert the real eigenvector equation. -/
theorem ch7_exists_spectralRadius_attaining_positive_subeigenvector
    {n : ℕ} (hn : 0 < n) (M : Fin n → Fin n → ℝ)
    (hM : Matrix.IsIrreducible
      (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)) :
    ∃ mu : ℂ, ∃ z : CVec n, ∃ x : Fin n → ℝ, ∃ y : Fin n → ℝ,
      z ≠ 0 ∧ x ≠ 0 ∧ (∀ i : Fin n, 0 ≤ x i) ∧
      (∀ i : Fin n, 0 < y i) ∧
      (∀ i : Fin n,
        complexMatrixVecMul (realRectToCMatrix M) z i = mu * z i) ∧
      (nnnorm mu : ENNReal) =
        spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) ∧
      (∀ i : Fin n, ‖mu‖ * x i ≤ matMulVec n M x i) ∧
      (∀ i : Fin n, ‖mu‖ * y i ≤ matMulVec n M y i) := by
  have hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j := by
    intro i j
    simpa [Matrix.of] using hM.1 i j
  obtain ⟨mu, z, x, hz_ne, hx_ne, hx_nonneg, heig, hrad, hsub⟩ :=
    ch7_exists_spectralRadius_attaining_nonneg_subeigenvector hn M hM_nonneg
  obtain ⟨y, hy_pos, hy_sub⟩ :=
    ch7_exists_positive_subeigenvector_of_irreducible_nonzero_nonneg_subeigen
      M ‖mu‖ x hM hx_nonneg hx_ne hsub
  exact ⟨mu, z, x, y, hz_ne, hx_ne, hx_nonneg, hy_pos, heig, hrad, hsub, hy_sub⟩

/-- Nonnegative irreducible matrices have a strictly positive real
right-eigenvector at the complexified Mathlib spectral radius.  The proof
combines the spectral-radius-attaining complex eigenpair, absolute-value
subeigenvector construction, irreducible positivity propagation, the strict
Collatz improvement step, and the Gelfand lower bound above. -/
theorem ch7_exists_spectralRadius_attaining_positive_eigenvector
    {n : ℕ} (hn : 0 < n) (M : Fin n → Fin n → ℝ)
    (hM : Matrix.IsIrreducible
      (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)) :
    ∃ mu : ℂ, ∃ z : CVec n, ∃ x : Fin n → ℝ, ∃ y : Fin n → ℝ,
      z ≠ 0 ∧ x ≠ 0 ∧ (∀ i : Fin n, 0 ≤ x i) ∧
      (∀ i : Fin n, 0 < y i) ∧
      (∀ i : Fin n,
        complexMatrixVecMul (realRectToCMatrix M) z i = mu * z i) ∧
      (nnnorm mu : ENNReal) =
        spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) ∧
      (∀ i : Fin n, ‖mu‖ * x i ≤ matMulVec n M x i) ∧
      (∀ i : Fin n, matMulVec n M y i = ‖mu‖ * y i) := by
  obtain ⟨mu, z, x, y, hz_ne, hx_ne, hx_nonneg, hy_pos, heig, hrad,
    hsubx, hsuby⟩ :=
    ch7_exists_spectralRadius_attaining_positive_subeigenvector hn M hM
  rcases ch7_positive_subeigenvector_eigen_or_exists_stronger
      hn M ‖mu‖ y hM hy_pos hsuby with heig_real | hstrong
  · exact ⟨mu, z, x, y, hz_ne, hx_ne, hx_nonneg, hy_pos, heig, hrad,
      hsubx, heig_real⟩
  · rcases hstrong with ⟨eps, v, heps_pos, hv_pos, hsub_strong⟩
    have hM_nonneg : ∀ i j : Fin n, 0 ≤ M i j := by
      intro i j
      simpa [Matrix.of] using hM.1 i j
    have hlam_strong : 0 ≤ ‖mu‖ + eps :=
      add_nonneg (norm_nonneg mu) (le_of_lt heps_pos)
    have hle_radius :
        ENNReal.ofReal (‖mu‖ + eps) ≤
          spectralRadius ℂ
            (Matrix.toLin'
              (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) :=
      ch7_toLin_spectralRadius_ge_of_positive_right_subeigenvector
        hn M (‖mu‖ + eps) v hM_nonneg hlam_strong hv_pos hsub_strong
    have hle_ofReal :
        ENNReal.ofReal (‖mu‖ + eps) ≤ ENNReal.ofReal ‖mu‖ := by
      calc
        ENNReal.ofReal (‖mu‖ + eps) ≤
            spectralRadius ℂ
              (Matrix.toLin'
                (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix M)) :=
          hle_radius
        _ = (nnnorm mu : ENNReal) := hrad.symm
        _ = ENNReal.ofReal ‖mu‖ := by
          simp [ENNReal.coe_nnreal_eq]
    have hreal_le : ‖mu‖ + eps ≤ ‖mu‖ :=
      (ENNReal.ofReal_le_ofReal_iff (norm_nonneg mu)).mp hle_ofReal
    exfalso
    nlinarith

/-- Nonnegative irreducible matrices cannot have a nonzero nonnegative right
eigenvector with a positive eigenvalue whose support is only partial.  This is
the Mathlib-powered positivity propagation step used in Problem 7.10(d); it is
not a Perron-Frobenius existence theorem. -/
lemma ch7_nonneg_irreducible_right_eigenvector_pos {n : ℕ}
    (M : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hρ : 0 < ρ)
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (heig : ∀ i : Fin n, matMulVec n M x i = ρ * x i) :
    ∀ i : Fin n, 0 < x i := by
  classical
  intro i
  obtain ⟨k, _hk_pos, hmul_pos⟩ :=
    ch7_irreducible_pow_mulVec_pos_of_nonzero_nonneg
      M x hM hx_nonneg hx_ne i
  have hpow_eig := congrFun (ch7_matrix_pow_mulVec_eigen M ρ x heig k) i
  have hrho_pow_pos : 0 < ρ ^ k := pow_pos hρ k
  have hprod_pos : 0 < ρ ^ k * x i := by
    simpa [hpow_eig] using hmul_pos
  nlinarith [hrho_pow_pos, hprod_pos]

/-- Nonzero nonnegative right eigenvectors of nonnegative irreducible matrices
are strictly positive once the eigenpair is supplied.  This combines the
positive-eigenvalue certificate with the support-propagation lemma. -/
lemma ch7_nonzero_nonneg_irreducible_right_eigenvector_pos {n : ℕ}
    (M : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hM : Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (heig : ∀ i : Fin n, matMulVec n M x i = ρ * x i) :
    ∀ i : Fin n, 0 < x i := by
  have hρ : 0 < ρ :=
    ch7_perronScalar_pos_of_nonzero_nonneg_irreducible_eigenvector
      M ρ x hM.1 hM hx_nonneg hx_ne heig
  exact ch7_nonneg_irreducible_right_eigenvector_pos
    M ρ x hM hρ hx_nonneg hx_ne heig

/-- Problem 7.10(a), Mathlib `spectralRadius` form for `BC` from the
source-shaped irreducibility plus a supplied nonzero nonnegative eigenpair.
This removes the separate strict-positivity side condition; it still does not
prove Perron-Frobenius existence of the eigenpair. -/
theorem problem7_10a_product_toLin_spectralRadius_eq_of_irreducible_nonzero_nonneg_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n B C) : Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    spectralRadius ℂ
      (Matrix.toLin'
        (show Matrix (Fin n) (Fin n) ℂ from
          realRectToCMatrix (matMul n B C))) =
      ENNReal.ofReal ρ := by
  have hx : ∀ i : Fin n, 0 < x i :=
    ch7_nonzero_nonneg_irreducible_right_eigenvector_pos
      (matMul n B C) ρ x hBC hx_nonneg hx_ne heig
  exact problem7_10a_product_toLin_spectralRadius_eq_of_positive_eigenvector
    hn B C ρ x hB hC hx heig

/-- Problem 7.10(b) / Theorem 7.8, Mathlib `spectralRadius` form for
`|A||A⁻¹|` from irreducibility plus a supplied nonzero nonnegative eigenpair.
The remaining source-facing gap is existence of such a Perron eigenpair from
irreducibility. -/
theorem problem7_10b_abs_product_toLin_spectralRadius_eq_of_irreducible_nonzero_nonneg_eigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n (absMatrix n A) (absMatrix n A_inv)) :
        Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i = ρ * x i) :
    spectralRadius ℂ
      (Matrix.toLin'
        (show Matrix (Fin n) (Fin n) ℂ from
          realRectToCMatrix
            (matMul n (absMatrix n A) (absMatrix n A_inv)))) =
      ENNReal.ofReal ρ := by
  have hx : ∀ i : Fin n, 0 < x i :=
    ch7_nonzero_nonneg_irreducible_right_eigenvector_pos
      (matMul n (absMatrix n A) (absMatrix n A_inv)) ρ x
      hBC hx_nonneg hx_ne heig
  exact problem7_10b_abs_product_toLin_spectralRadius_eq_of_positive_eigenvector
    hn A A_inv ρ x hx heig

/-- Problem 7.10(a), Mathlib `spectralRadius` form for every positive
reciprocal two-sided scaling of the Bauer product, with strict positivity
derived from source-shaped irreducibility and a supplied nonzero nonnegative
eigenpair. -/
theorem problem7_10a_scaled_product_toLin_spectralRadius_eq_of_irreducible_nonzero_nonneg_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n B C) : Matrix (Fin n) (Fin n) ℝ))
    (hx_nonneg : ∀ i : Fin n, 0 ≤ x i)
    (hx_ne : x ≠ 0)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    spectralRadius ℂ
      (Matrix.toLin'
        (show Matrix (Fin n) (Fin n) ℂ from
          realRectToCMatrix
            (matMul n (ch7TwoSidedScale d₁ B d₂)
              (ch7TwoSidedScale d₂Inv C d₁Inv)))) =
      ENNReal.ofReal ρ := by
  have hx : ∀ i : Fin n, 0 < x i :=
    ch7_nonzero_nonneg_irreducible_right_eigenvector_pos
      (matMul n B C) ρ x hBC hx_nonneg hx_ne heig
  exact problem7_10a_scaled_product_toLin_spectralRadius_eq_of_positive_eigenvector
    hn B C ρ x hB hC hx heig d₁ d₁Inv d₂ d₂Inv
    hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂

/-- Problem 7.10(d), Appendix positivity-transfer step.  If `x > 0` is a
right eigenvector of `BC` for a positive eigenvalue and `CB` is nonnegative
irreducible, then the transferred eigenvector `Cx` is strictly positive. -/
lemma problem7_10d_Cx_pos_of_irreducible_CB {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hCB : Matrix.IsIrreducible
      (Matrix.of (matMul n C B) : Matrix (Fin n) (Fin n) ℝ))
    (hρ : 0 < ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    ∀ i : Fin n, 0 < matMulVec n C x i := by
  have hCx_nonneg : ∀ i : Fin n, 0 ≤ matMulVec n C x i := by
    intro i
    unfold matMulVec
    exact Finset.sum_nonneg fun j _ => mul_nonneg (hC i j) (le_of_lt (hx j))
  have hCx_ne : matMulVec n C x ≠ 0 := by
    intro hzero
    let i0 : Fin n := ⟨0, hn⟩
    have hBC_zero : matMulVec n (matMul n B C) x i0 = 0 := by
      rw [matMulVec_matMul]
      rw [hzero]
      simp [matMulVec]
    have hprod_zero : ρ * x i0 = 0 := by
      simpa [heig i0] using hBC_zero
    have hprod_pos : 0 < ρ * x i0 := mul_pos hρ (hx i0)
    linarith
  exact ch7_nonneg_irreducible_right_eigenvector_pos
    (matMul n C B) ρ (matMulVec n C x) hCB hρ hCx_nonneg hCx_ne
    (ch7_bauer_Cx_eigenvector_CB B C ρ x heig)

/-- Problem 7.10(d), same irreducible `Cx > 0` transfer but deriving the
positive-eigenvalue side condition from a positive entry in `BC`.  This keeps
the remaining Perron-Frobenius gap focused on producing the positive
eigenvector/spectral-radius certificate, not on an extra standalone `ρ > 0`
hypothesis. -/
lemma problem7_10d_Cx_pos_of_irreducible_CB_of_positive_BC_entry {n : ℕ}
    (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hBC_entry : ∃ i j : Fin n, 0 < matMul n B C i j)
    (hCB : Matrix.IsIrreducible
      (Matrix.of (matMul n C B) : Matrix (Fin n) (Fin n) ℝ))
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    ∀ i : Fin n, 0 < matMulVec n C x i := by
  have hBC_nonneg : ∀ i j : Fin n, 0 ≤ matMul n B C i j :=
    ch7_matMul_nonneg n B C hB hC
  have hρ : 0 < ρ :=
    ch7_perronScalar_pos_of_nonneg_eigenvector_entry_pos
      (matMul n B C) ρ x hBC_nonneg hx heig hBC_entry
  exact problem7_10d_Cx_pos_of_irreducible_CB
    hn B C ρ x hC hCB hρ hx heig

/-- Problem 7.10(d), source-shaped irreducible-product positivity transfer.
If `x > 0` is a supplied right eigenvector of `BC` and both products satisfy
Higham's irreducibility side conditions, then `Cx > 0`.  The proof derives the
previous positive-eigenvalue side condition from irreducibility of `BC`; it does
not prove existence of the Perron vector or identify the spectral radius. -/
lemma problem7_10d_Cx_pos_of_irreducible_BC_CB {n : ℕ}
    (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n B C) : Matrix (Fin n) (Fin n) ℝ))
    (hCB : Matrix.IsIrreducible
      (Matrix.of (matMul n C B) : Matrix (Fin n) (Fin n) ℝ))
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    ∀ i : Fin n, 0 < matMulVec n C x i := by
  have hBC_nonneg : ∀ i j : Fin n, 0 ≤ matMul n B C i j :=
    ch7_matMul_nonneg n B C hB hC
  have hρ : 0 < ρ :=
    ch7_perronScalar_pos_of_nonneg_irreducible_eigenvector
      hn (matMul n B C) ρ x hBC_nonneg hBC hx heig
  exact problem7_10d_Cx_pos_of_irreducible_CB
    hn B C ρ x hC hCB hρ hx heig

/-- A strictly positive square matrix is primitive in Mathlib's matrix
connectivity API. -/
lemma ch7_matrix_isPrimitive_of_pos_entries {n : ℕ}
    (M : Fin n → Fin n → ℝ)
    (hM : ∀ i j : Fin n, 0 < M i j) :
    Matrix.IsPrimitive (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) := by
  refine ⟨fun i j => le_of_lt (hM i j), 1, by norm_num, ?_⟩
  intro i j
  simpa using hM i j

/-- Strictly positive entries imply the irreducibility side condition used in
Higham Theorem 7.8 and Problem 7.10(d). -/
lemma ch7_matrix_isIrreducible_of_pos_entries {n : ℕ}
    (M : Fin n → Fin n → ℝ)
    (hM : ∀ i j : Fin n, 0 < M i j) :
    Matrix.IsIrreducible (Matrix.of M : Matrix (Fin n) (Fin n) ℝ) :=
  (ch7_matrix_isPrimitive_of_pos_entries M hM).isIrreducible

lemma ch7_matMul_pos_of_pos {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ)
    (hBpos : ∀ i j : Fin n, 0 < B i j)
    (hCpos : ∀ i j : Fin n, 0 < C i j) :
    ∀ i j : Fin n, 0 < matMul n B C i j := by
  intro i j
  unfold matMul
  exact Finset.sum_pos
    (fun k _ => mul_pos (hBpos i k) (hCpos k j))
    ⟨⟨0, hn⟩, Finset.mem_univ _⟩

/-- Positive-entry Bauer factors satisfy the two irreducibility hypotheses that
appear in the irreducible version of Problem 7.10(d). -/
theorem ch7_bauer_positive_products_irreducible {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ)
    (hBpos : ∀ i j : Fin n, 0 < B i j)
    (hCpos : ∀ i j : Fin n, 0 < C i j) :
    Matrix.IsIrreducible
        (Matrix.of (matMul n B C) : Matrix (Fin n) (Fin n) ℝ) ∧
      Matrix.IsIrreducible
        (Matrix.of (matMul n C B) : Matrix (Fin n) (Fin n) ℝ) :=
  ⟨ch7_matrix_isIrreducible_of_pos_entries (matMul n B C)
      (ch7_matMul_pos_of_pos hn B C hBpos hCpos),
    ch7_matrix_isIrreducible_of_pos_entries (matMul n C B)
      (ch7_matMul_pos_of_pos hn C B hCpos hBpos)⟩

/-- Problem 7.10(a), attainment half under an explicit positive Perron-vector
certificate.  The canonical scaling from Higham's hint,
`D₁ = diag(x)⁻¹` and `D₂ = diag(Cx)`, attains the certificate value `ρ`. -/
theorem problem7_10a_canonical_scaled_infCond_eq_perron_of_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (hCx : ∀ i : Fin n, 0 < matMulVec n C x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    ch7TwoSidedScaledInfCond B C
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n C x i)
        (fun i => (matMulVec n C x i)⁻¹) =
      ρ := by
  have hBC : ∀ i j : Fin n, 0 ≤ matMul n B C i j :=
    ch7_matMul_nonneg n B C hB hC
  have hρ : 0 ≤ ρ :=
    ch7_perronScalar_nonneg_of_nonneg_eigenvector hn (matMul n B C) ρ x
      hBC hx heig
  have hleft :
      infNorm
          (ch7TwoSidedScale (fun i => (x i)⁻¹) B
            (fun i => matMulVec n C x i)) ≤ ρ := by
    apply infNorm_le_of_row_sum_le
    · intro i
      calc
        ∑ j : Fin n,
            |ch7TwoSidedScale (fun i => (x i)⁻¹) B
              (fun i => matMulVec n C x i) i j|
            = ∑ j : Fin n, (x i)⁻¹ * B i j * matMulVec n C x j := by
              apply Finset.sum_congr rfl
              intro j _
              change |(x i)⁻¹ * B i j * matMulVec n C x j| =
                (x i)⁻¹ * B i j * matMulVec n C x j
              exact abs_of_nonneg
                (mul_nonneg
                  (mul_nonneg (inv_nonneg.mpr (le_of_lt (hx i))) (hB i j))
                  (le_of_lt (hCx j)))
        _ = (x i)⁻¹ * matMulVec n B (matMulVec n C x) i := by
              unfold matMulVec
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro j _
              ring
        _ = (x i)⁻¹ * matMulVec n (matMul n B C) x i := by
              rw [← matMulVec_matMul n B C x i]
        _ = (x i)⁻¹ * (ρ * x i) := by
              rw [heig i]
        _ ≤ ρ := by
              have heq : (x i)⁻¹ * (ρ * x i) = ρ := by
                field_simp [ne_of_gt (hx i)]
              rw [heq]
    · exact hρ
  have hright :
      infNorm
          (ch7TwoSidedScale (fun i => (matMulVec n C x i)⁻¹) C x) ≤ 1 := by
    apply infNorm_le_of_row_sum_le
    · intro i
      calc
        ∑ j : Fin n,
            |ch7TwoSidedScale (fun i => (matMulVec n C x i)⁻¹) C x i j|
            = ∑ j : Fin n, (matMulVec n C x i)⁻¹ * C i j * x j := by
              apply Finset.sum_congr rfl
              intro j _
              change |(matMulVec n C x i)⁻¹ * C i j * x j| =
                (matMulVec n C x i)⁻¹ * C i j * x j
              exact abs_of_nonneg
                (mul_nonneg
                  (mul_nonneg (inv_nonneg.mpr (le_of_lt (hCx i))) (hC i j))
                  (le_of_lt (hx j)))
        _ = (matMulVec n C x i)⁻¹ * matMulVec n C x i := by
              unfold matMulVec
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro j _
              ring
        _ ≤ 1 := by
              rw [inv_mul_cancel₀ (ne_of_gt (hCx i))]
    · norm_num
  have hlower :
      ρ ≤ ch7TwoSidedScaledInfCond B C
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n C x i)
        (fun i => (matMulVec n C x i)⁻¹) := by
    apply problem7_10a_scaled_infCond_ge_perron_of_positive_eigenvector
      hn B C ρ x hB hC hx heig
    · intro i
      exact inv_pos.mpr (hx i)
    · exact hx
    · exact hCx
    · intro i
      exact inv_pos.mpr (hCx i)
    · intro i
      exact inv_mul_cancel₀ (ne_of_gt (hx i))
    · intro i
      exact mul_inv_cancel₀ (ne_of_gt (hCx i))
  have hupper :
      ch7TwoSidedScaledInfCond B C
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n C x i)
        (fun i => (matMulVec n C x i)⁻¹) ≤ ρ := by
    unfold ch7TwoSidedScaledInfCond
    calc
      infNorm
          (ch7TwoSidedScale (fun i => (x i)⁻¹) B
            (fun i => matMulVec n C x i)) *
          infNorm
            (ch7TwoSidedScale (fun i => (matMulVec n C x i)⁻¹) C x)
          ≤ ρ * 1 := by
            exact mul_le_mul hleft hright
              (infNorm_nonneg _)
              hρ
      _ = ρ := by ring
  exact le_antisymm hupper hlower

/-- Problem 7.10(a), source-positive-entry wrapper for the canonical Bauer
scaling algebra under a positive Perron-vector certificate for `BC`. -/
theorem problem7_10a_positive_entries_canonical_scaled_infCond_eq_perron
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hBpos : ∀ i j : Fin n, 0 < B i j)
    (hCpos : ∀ i j : Fin n, 0 < C i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    ch7TwoSidedScaledInfCond B C
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n C x i)
        (fun i => (matMulVec n C x i)⁻¹) =
      ρ :=
  problem7_10a_canonical_scaled_infCond_eq_perron_of_positive_eigenvector
    hn B C ρ x
    (fun i j => le_of_lt (hBpos i j))
    (fun i j => le_of_lt (hCpos i j))
    hx (ch7_bauer_Cx_pos_of_pos hn C x hCpos hx) heig

/-- Problem 7.10(a), source-shaped infimum version under an explicit positive
right Perron-vector certificate.  This upgrades the pointwise Bauer lower
bound and canonical-scaling equality to the `sInf` model of the source
minimization; Perron-Frobenius existence of the certificate remains separate. -/
theorem problem7_10a_scaledInfCondSet_sInf_eq_perron_of_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (hCx : ∀ i : Fin n, 0 < matMulVec n C x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    sInf (ch7TwoSidedScaledInfCondSet B C) = ρ := by
  let S : Set ℝ := ch7TwoSidedScaledInfCondSet B C
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledInfCondSet_nonempty B C
  have hS_bdd : BddBelow S := by
    simpa [S] using ch7TwoSidedScaledInfCondSet_bddBelow B C
  have hlower : ∀ κ : ℝ, κ ∈ S → ρ ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, hd₁pos, hd₁Invpos,
        hd₂pos, hd₂Invpos, hd₁, hd₂, rfl⟩
    exact problem7_10a_scaled_infCond_ge_perron_of_positive_eigenvector
      hn B C ρ x hB hC hx heig d₁ d₁Inv d₂ d₂Inv
      hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  have hle_sInf : ρ ≤ sInf S := le_csInf hS_nonempty hlower
  let d₁ : Fin n → ℝ := fun i => (x i)⁻¹
  let d₁Inv : Fin n → ℝ := x
  let d₂ : Fin n → ℝ := fun i => matMulVec n C x i
  let d₂Inv : Fin n → ℝ := fun i => (matMulVec n C x i)⁻¹
  have hcan :
      ch7TwoSidedScaledInfCond B C d₁ d₁Inv d₂ d₂Inv = ρ := by
    dsimp [d₁, d₁Inv, d₂, d₂Inv]
    exact problem7_10a_canonical_scaled_infCond_eq_perron_of_positive_eigenvector
      hn B C ρ x hB hC hx hCx heig
  have hmem :
      ch7TwoSidedScaledInfCond B C d₁ d₁Inv d₂ d₂Inv ∈ S := by
    dsimp [S, d₁, d₁Inv, d₂, d₂Inv]
    exact ch7TwoSidedScaledInfCond_mem_set B C
      (fun i => (x i)⁻¹) x
      (fun i => matMulVec n C x i)
      (fun i => (matMulVec n C x i)⁻¹)
      (fun i => inv_pos.mpr (hx i))
      hx hCx
      (fun i => inv_pos.mpr (hCx i))
      (fun i => inv_mul_cancel₀ (ne_of_gt (hx i)))
      (fun i => mul_inv_cancel₀ (ne_of_gt (hCx i)))
  have hρmem : ρ ∈ S := by
    simpa [hcan] using hmem
  have hsInf_le : sInf S ≤ ρ := csInf_le hS_bdd hρmem
  exact le_antisymm hsInf_le hle_sInf

/-- Problem 7.10(a), genuine minimum-attainment form over the positive
two-sided Bauer value set, under the same explicit positive Perron-vector
certificate as the `sInf` wrapper.  The canonical scaling from the source hint
