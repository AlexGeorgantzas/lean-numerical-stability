/-- Theorem 7.5, `p = 2` row route with the source minimum value extracted
from the compact normalized reciprocal sublevel, under an explicit rectangular
right-inverse side condition. -/
theorem theorem7_5_p2_row_equilibration_exists_min_left_scalings_of_rect_right_inverse
    {m n : ℕ} (hm : 0 < m)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hright : ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0) :
