            (matTranspose (absMatrix n A_inv))) y i = ρ * y i) :
    sInf (ch7TwoSidedScaledOneKappaSet A A_inv) = ρ := by
  let S : Set ℝ := ch7TwoSidedScaledOneKappaSet A A_inv
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledOneKappaSet_nonempty A A_inv
  have hS_bdd : BddBelow S := by
    simpa [S] using ch7TwoSidedScaledOneKappaSet_bddBelow A A_inv
  have hlower : ∀ κ : ℝ, κ ∈ S → ρ ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, hd₁pos, hd₁Invpos,
        hd₂pos, hd₂Invpos, hd₁, hd₂, rfl⟩
    exact
      problem7_10e_scaled_oneKappa_ge_perron_of_abs_inverse_transpose_positive_eigenvector
        hn A A_inv ρ y hy heigT d₁ d₁Inv d₂ d₂Inv
        hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  have hle_sInf : ρ ≤ sInf S := le_csInf hS_nonempty hlower
  let d₁ : Fin n → ℝ :=
    fun i => matMulVec n (matTranspose (absMatrix n A_inv)) y i
  let d₁Inv : Fin n → ℝ :=
    fun i => (matMulVec n (matTranspose (absMatrix n A_inv)) y i)⁻¹
  let d₂ : Fin n → ℝ := fun i => (y i)⁻¹
  let d₂Inv : Fin n → ℝ := y
  have hcan :
      ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv = ρ := by
    dsimp [d₁, d₁Inv, d₂, d₂Inv]
    exact
      problem7_10e_canonical_scaled_oneKappa_eq_perron_of_abs_inverse_transpose_positive_eigenvector
        hn A A_inv ρ y hy hCt_y heigT
  have hmem :
      ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv ∈ S := by
    dsimp [S, d₁, d₁Inv, d₂, d₂Inv]
    exact ch7TwoSidedScaledOneKappa_mem_set A A_inv
      (fun i => matMulVec n (matTranspose (absMatrix n A_inv)) y i)
