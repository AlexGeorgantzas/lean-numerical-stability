/-- The repository function-level transpose agrees with Mathlib matrix
transpose after coercing through `Matrix.of`. -/
lemma ch7_matrix_of_matTranspose {n : ℕ} (M : Fin n → Fin n → ℝ) :
    (Matrix.of (matTranspose M) : Matrix (Fin n) (Fin n) ℝ) =
      (Matrix.of M : Matrix (Fin n) (Fin n) ℝ).transpose := by
  ext i j
  rfl

/-- Irreducibility is preserved by the repository function-level transpose. -/
lemma ch7_irreducible_matTranspose {n : ℕ} (M : Fin n → Fin n → ℝ)
    (hM : Matrix.IsIrreducible
      (Matrix.of M : Matrix (Fin n) (Fin n) ℝ)) :
    Matrix.IsIrreducible
      (Matrix.of (matTranspose M) : Matrix (Fin n) (Fin n) ℝ) := by
  rw [ch7_matrix_of_matTranspose M]
  exact Matrix.IsIrreducible.transpose hM

/-- Source-product irreducibility for `BC` supplies transpose-product
irreducibility for `CᵀBᵀ`. -/
lemma ch7_irreducible_transpose_product_of_irreducible_product {n : ℕ}
    (B C : Fin n → Fin n → ℝ)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n B C) : Matrix (Fin n) (Fin n) ℝ)) :
    Matrix.IsIrreducible
      (Matrix.of (matMul n (matTranspose C) (matTranspose B)) :
        Matrix (Fin n) (Fin n) ℝ) := by
  have hT := ch7_irreducible_matTranspose (matMul n B C) hBC
  simpa [matTranspose_matMul] using hT

/-- Problem 7.10(e), source spectral-radius fact
`ρ((|A⁻¹||A|)ᵀ) = ρ(|A⁻¹||A|)` for the transpose product used by the
one-norm branch. -/
theorem problem7_10e_abs_transpose_product_toLin_spectralRadius_eq_reverse_abs_product
    {n : ℕ} (A A_inv : Fin n → Fin n → ℝ) :
    spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from
            realRectToCMatrix
              (matMul n (matTranspose (absMatrix n A))
                (matTranspose (absMatrix n A_inv))))) =
      spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from
            realRectToCMatrix
              (matMul n (absMatrix n A_inv) (absMatrix n A)))) := by
  have hprod :
      matMul n (matTranspose (absMatrix n A))
          (matTranspose (absMatrix n A_inv)) =
        matTranspose (matMul n (absMatrix n A_inv) (absMatrix n A)) := by
    rw [matTranspose_matMul]
  rw [hprod]
  exact ch7_toLin_spectralRadius_realRectToCMatrix_matTranspose_eq
    (matMul n (absMatrix n A_inv) (absMatrix n A))

/-- Problem 7.10(e), source spectral-radius fact
`ρ(|A||A⁻¹|) = ρ(|A⁻¹||A|)`.  This closes the algebraic product-order
spectral-radius dependency used to put the one-norm and infinity-norm Bauer
branches at the same scalar value; Perron-Frobenius eigenpair existence remains
separate. -/
theorem problem7_10e_abs_products_toLin_spectralRadius_mul_comm_eq {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from
            realRectToCMatrix
              (matMul n (absMatrix n A) (absMatrix n A_inv)))) =
      spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from
            realRectToCMatrix
              (matMul n (absMatrix n A_inv) (absMatrix n A)))) := by
  let B : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix (absMatrix n A))
  let C : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix (absMatrix n A_inv))
  have hBC :
      (show Matrix (Fin n) (Fin n) ℂ from
        realRectToCMatrix (matMul n (absMatrix n A) (absMatrix n A_inv))) =
        B * C := by
    ext i j
    simp [B, C, realRectToCMatrix, matMul, Matrix.mul_apply]
  have hCB :
      (show Matrix (Fin n) (Fin n) ℂ from
        realRectToCMatrix (matMul n (absMatrix n A_inv) (absMatrix n A))) =
        C * B := by
    ext i j
    simp [B, C, realRectToCMatrix, matMul, Matrix.mul_apply]
  rw [hBC, hCB]
  exact ch7_toLin_spectralRadius_mul_comm_eq B C

/-- Problem 7.10(e), combined source spectral-radius fact for the one-norm
transpose product: `ρ(|A|ᵀ|A⁻¹|ᵀ) = ρ(|A||A⁻¹|)`.  This packages
`ρ(Aᵀ)=ρ(A)` and `ρ(AB)=ρ(BA)` in the exact absolute-product orientation used
by Bauer's infinity-norm branch. -/
theorem problem7_10e_abs_transpose_product_toLin_spectralRadius_eq_abs_product
    {n : ℕ} (A A_inv : Fin n → Fin n → ℝ) :
    spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from
            realRectToCMatrix
              (matMul n (matTranspose (absMatrix n A))
                (matTranspose (absMatrix n A_inv))))) =
      spectralRadius ℂ
        (Matrix.toLin'
          (show Matrix (Fin n) (Fin n) ℂ from
            realRectToCMatrix
              (matMul n (absMatrix n A) (absMatrix n A_inv)))) := by
  rw [problem7_10e_abs_transpose_product_toLin_spectralRadius_eq_reverse_abs_product
    A A_inv]
  exact (problem7_10e_abs_products_toLin_spectralRadius_mul_comm_eq
    A A_inv).symm

/-- Problem 7.10(a), finite complex spectral-radius eigenpair for the product
`BC`.  This supplies the algebraic complex eigenpair at `ρ(BC)`; Bauer's
Perron-Frobenius row still needs the source positive real Perron vector under
irreducibility. -/
theorem problem7_10a_product_toLin_exists_spectralRadius_attaining_eigenpair
    {n : ℕ} (hn : 0 < n) (B C : Fin n → Fin n → ℝ) :
    ∃ lam : ℂ, ∃ z : CVec n,
      z ≠ 0 ∧
      (∀ i : Fin n,
        complexMatrixVecMul (realRectToCMatrix (matMul n B C)) z i =
          lam * z i) ∧
      (nnnorm lam : ENNReal) =
        spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from
              realRectToCMatrix (matMul n B C))) := by
  let M : Matrix (Fin n) (Fin n) ℂ :=
    (show Matrix (Fin n) (Fin n) ℂ from realRectToCMatrix (matMul n B C))
  obtain ⟨lam, z, hz_ne, hz_lin, hrad⟩ :=
    ch7_toLin_exists_spectralRadius_attaining_eigenpair hn M
  refine ⟨lam, z, hz_ne, ?_, by simpa [M] using hrad⟩
  intro i
  have hi := congrFun hz_lin i
  simpa [M, complexMatrixVecMul, Matrix.toLin'_apply, Matrix.mulVec,
    dotProduct, Pi.smul_apply, smul_eq_mul] using hi

