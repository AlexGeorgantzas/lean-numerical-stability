theorem exists_ch7Problem79NormwiseLinearizedRadiusSet_exact_witness
    (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) {rho : ℝ}
    (hrho : 0 < rho)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
