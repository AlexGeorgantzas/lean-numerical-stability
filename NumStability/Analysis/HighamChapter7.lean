  rcases hκ with
    ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
      _hd₂pos, _hd₂Invpos, hd₁, hd₂, rfl⟩
  have hHad :
      opNorm2Le (ch7HadamardProduct A (matTranspose A_inv))
        (complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₁ A d₂)) *
          complexMatrixOp2
            (realRectToCMatrix (ch7TwoSidedScale d₂Inv A_inv d₁Inv))) :=
    problem7_15_scaled_inverse_hadamard_opNorm2Le A A_inv
      d₁ d₁Inv d₂ d₂Inv
      (complexMatrixOp2_nonneg _)
      (complexMatrixOp2_nonneg _)
      hd₁ hd₂
