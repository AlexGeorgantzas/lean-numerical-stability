/-- Theorem 7.5 Moore-Penrose bridge, full-column-rank side: the first
Penrose equation `A A⁺ A = A`, together with injectivity of `x ↦ A*x`, forces
the explicit rectangular left-inverse identity `A⁺ A = I` used by the existing
projection wrappers. -/
theorem theorem7_5_rect_left_inverse_of_penrose1_rectMatMulVec_injective
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hPenrose1 : rectMatMul (rectMatMul A Aplus) A = A)
    (hAinj : Function.Injective (rectMatMulVec A)) :
    ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0 := by
  intro i j
  have hfix :
      rectMatMulVec (rectMatMul Aplus A) (basisVec (n := n) j) =
        basisVec (n := n) j := by
    apply hAinj
    calc
      rectMatMulVec A (rectMatMulVec (rectMatMul Aplus A) (basisVec (n := n) j))
          = rectMatMulVec (rectMatMul A (rectMatMul Aplus A))
              (basisVec (n := n) j) := by
            rw [← rectMatMulVec_rectMatMul]
      _ = rectMatMulVec (rectMatMul (rectMatMul A Aplus) A)
              (basisVec (n := n) j) := by
            rw [← rectMatMul_assoc A Aplus A]
      _ = rectMatMulVec A (basisVec (n := n) j) := by
            rw [hPenrose1]
  have hi := congrFun hfix i
  simpa [rectMatMulVec, rectMatMul, basisVec] using hi

/-- Theorem 7.5 Moore-Penrose bridge, full-row-rank side: the first Penrose
equation `A A⁺ A = A`, together with surjectivity of `x ↦ A*x`, forces the
explicit rectangular right-inverse identity `A A⁺ = I` used by the existing
projection wrappers. -/
theorem theorem7_5_rect_right_inverse_of_penrose1_rectMatMulVec_surjective
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hPenrose1 : rectMatMul (rectMatMul A Aplus) A = A)
    (hAsurj : Function.Surjective (rectMatMulVec A)) :
    ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0 := by
  intro i j
  obtain ⟨x, hx⟩ := hAsurj (basisVec (n := m) j)
  have hfix :
      rectMatMulVec (rectMatMul A Aplus) (basisVec (n := m) j) =
        basisVec (n := m) j := by
    calc
      rectMatMulVec (rectMatMul A Aplus) (basisVec (n := m) j)
          = rectMatMulVec (rectMatMul A Aplus) (rectMatMulVec A x) := by
            rw [hx]
      _ = rectMatMulVec (rectMatMul (rectMatMul A Aplus) A) x := by
            rw [← rectMatMulVec_rectMatMul]
      _ = rectMatMulVec A x := by
            rw [hPenrose1]
      _ = basisVec (n := m) j := hx
  have hi := congrFun hfix i
  simpa [rectMatMulVec, rectMatMul, basisVec] using hi

