/-- The complexified real matrix one-norm is bounded by the repository real
one-norm.  This bridges the Chapter 6 complex `p`-norm interpolation theorem
to Chapter 7's real condition-number notation. -/
lemma ch7_complexMatrixOneNorm_realRectToCMatrix_le_oneNorm {n : ℕ}
    (A : Fin n → Fin n → ℝ) :
    complexMatrixOneNorm (realRectToCMatrix A) ≤ oneNorm A := by
  apply complexMatrixOneNorm_le_of_col_sum_le (oneNorm_nonneg A)
  intro j
  have hsum :
      (∑ i : Fin n, ‖realRectToCMatrix A i j‖) =
        ∑ i : Fin n, |A i j| := by
    apply Finset.sum_congr rfl
    intro i _hi
    simp [realRectToCMatrix]
  simpa [hsum] using col_sum_le_oneNorm A j

/-- The complexified real matrix infinity-norm is bounded by the repository
real infinity-norm. -/
lemma ch7_complexMatrixInfNorm_realRectToCMatrix_le_infNorm {n : ℕ}
    (A : Fin n → Fin n → ℝ) :
    complexMatrixInfNorm (realRectToCMatrix A) ≤ infNorm A := by
  apply complexMatrixInfNorm_le_of_row_sum_le (infNorm_nonneg A)
  intro i
  have hsum :
      (∑ j : Fin n, ‖realRectToCMatrix A i j‖) =
        ∑ j : Fin n, |A i j| := by
    apply Finset.sum_congr rfl
    intro j _hj
    simp [realRectToCMatrix]
  simpa [hsum] using row_sum_le_infNorm A i

/-- Higham Problem 7.10(e)'s norm-interpolation ingredient:
`||A||₂ <= sqrt(||A||₁ ||A||∞)` for the repository's exact Euclidean
operator norm on a complexified real square matrix. -/
theorem problem7_10e_complexMatrixOp2_realRectToCMatrix_le_sqrt_one_mul_inf
    {n : ℕ} (hn : 0 < n) (A : Fin n → Fin n → ℝ) :
    complexMatrixOp2 (realRectToCMatrix A) ≤
      Real.sqrt (oneNorm A * infNorm A) := by
  let C : CMatrix n n := realRectToCMatrix A
  have hinterp :=
    complexMatrixLpNormOfReal_rieszThorin_one_top
      (m := n) (n := n) hn (p := (2 : ℝ)) (by norm_num) C
  have htwo :
      complexMatrixOp2 C ≤
        complexMatrixOneNorm C ^ (2 : ℝ)⁻¹ *
          complexMatrixInfNorm C ^ (1 - (2 : ℝ)⁻¹) := by
    simpa [complexMatrixLpNormOfReal_two_eq_complexMatrixOp2 hn C] using hinterp
  have hhalf : 1 - (2 : ℝ)⁻¹ = (2 : ℝ)⁻¹ := by norm_num
  rw [hhalf] at htwo
  have hone :
      complexMatrixOneNorm C ^ (2 : ℝ)⁻¹ ≤ oneNorm A ^ (2 : ℝ)⁻¹ := by
    exact Real.rpow_le_rpow (complexMatrixOneNorm_nonneg C)
      (by simpa [C] using ch7_complexMatrixOneNorm_realRectToCMatrix_le_oneNorm A)
      (by norm_num)
  have hinf :
      complexMatrixInfNorm C ^ (2 : ℝ)⁻¹ ≤ infNorm A ^ (2 : ℝ)⁻¹ := by
    exact Real.rpow_le_rpow (complexMatrixInfNorm_nonneg C)
      (by simpa [C] using ch7_complexMatrixInfNorm_realRectToCMatrix_le_infNorm A)
      (by norm_num)
  have hprod :
      complexMatrixOneNorm C ^ (2 : ℝ)⁻¹ *
          complexMatrixInfNorm C ^ (2 : ℝ)⁻¹ ≤
        oneNorm A ^ (2 : ℝ)⁻¹ * infNorm A ^ (2 : ℝ)⁻¹ :=
    mul_le_mul hone hinf
      (Real.rpow_nonneg (complexMatrixInfNorm_nonneg C) _)
      (Real.rpow_nonneg (oneNorm_nonneg A) _)
  have hsqrt :
      oneNorm A ^ (2 : ℝ)⁻¹ * infNorm A ^ (2 : ℝ)⁻¹ =
        Real.sqrt (oneNorm A * infNorm A) := by
    rw [Real.sqrt_eq_rpow, Real.mul_rpow (oneNorm_nonneg A) (infNorm_nonneg A)]
    congr 1 <;> norm_num
  exact htwo.trans (hprod.trans (le_of_eq hsqrt))

/-- Row-wise weighted Cauchy--Schwarz in the zero-safe form needed for
Bauer's operator-2 Schur test. -/
lemma ch7_weighted_row_cauchy_sum_sq {n : ℕ}
    (M : Fin n → Fin n → ℝ) (c x : Fin n → ℝ)
    (hM : ∀ i j : Fin n, 0 ≤ M i j)
    (hc : ∀ j : Fin n, 0 < c j) (i : Fin n) :
    (∑ j : Fin n, M i j * |x j|) ^ 2 ≤
      (∑ j : Fin n, M i j * x j ^ 2 / c j) *
        (∑ j : Fin n, M i j * c j) := by
  have hf : ∀ j ∈ (Finset.univ : Finset (Fin n)),
      0 ≤ M i j * x j ^ 2 / c j := by
    intro j _
    exact div_nonneg (mul_nonneg (hM i j) (sq_nonneg (x j))) (le_of_lt (hc j))
  have hg : ∀ j ∈ (Finset.univ : Finset (Fin n)),
      0 ≤ M i j * c j := by
    intro j _
    exact mul_nonneg (hM i j) (le_of_lt (hc j))
  have ht : ∀ j ∈ (Finset.univ : Finset (Fin n)),
      (M i j * |x j|) ^ 2 = (M i j * x j ^ 2 / c j) * (M i j * c j) := by
    intro j _
    have hcne : c j ≠ 0 := ne_of_gt (hc j)
    field_simp [hcne]
    exact by rw [sq_abs]
  simpa using
    (Finset.sum_sq_le_sum_mul_sum_of_sq_eq_mul
      (s := (Finset.univ : Finset (Fin n))) (r := fun j => M i j * |x j|)
      (f := fun j => M i j * x j ^ 2 / c j)
      (g := fun j => M i j * c j) hf hg ht)

/-- For positive `u,v`, the normalization `u / sqrt(u*v)` sends `v` to
`sqrt(u*v)`. -/
lemma ch7_div_sqrt_mul_mul_eq_sqrt_mul {u v : ℝ} (hu : 0 < u) (hv : 0 < v) :
    u / Real.sqrt (u * v) * v = Real.sqrt (u * v) := by
  have hspos : 0 < Real.sqrt (u * v) := Real.sqrt_pos.2 (mul_pos hu hv)
  have hsqr : Real.sqrt (u * v) ^ 2 = u * v :=
    Real.sq_sqrt (le_of_lt (mul_pos hu hv))
  field_simp [ne_of_gt hspos]
  rw [hsqr]

/-- Symmetric form of `ch7_div_sqrt_mul_mul_eq_sqrt_mul`. -/
lemma ch7_div_sqrt_mul_mul_eq_sqrt_mul_comm {u v : ℝ}
    (hu : 0 < u) (hv : 0 < v) :
    v / Real.sqrt (u * v) * u = Real.sqrt (u * v) := by
  rw [mul_comm u v]
  simpa [mul_comm] using ch7_div_sqrt_mul_mul_eq_sqrt_mul hv hu

/-- Reciprocal product for the positive normalization by `sqrt(u*v)`. -/
lemma ch7_div_sqrt_mul_mul_div_sqrt_eq_one {u v : ℝ}
    (hu : 0 < u) (hv : 0 < v) :
    (u / Real.sqrt (u * v)) * (v / Real.sqrt (u * v)) = 1 := by
  have hspos : 0 < Real.sqrt (u * v) := Real.sqrt_pos.2 (mul_pos hu hv)
  have hsqr : Real.sqrt (u * v) ^ 2 = u * v :=
    Real.sq_sqrt (le_of_lt (mul_pos hu hv))
  field_simp [ne_of_gt hspos]
  rw [hsqr]

/-- Squared Schur-test estimate for nonnegative matrices with positive
left/right weights. -/
lemma ch7_vecNorm2Sq_matMulVec_le_of_schur_bounds {n : ℕ}
    (M : Fin n → Fin n → ℝ) (r c : Fin n → ℝ) {α β : ℝ}
    (hM : ∀ i j : Fin n, 0 ≤ M i j)
    (_hr : ∀ i : Fin n, 0 ≤ r i) (hc : ∀ j : Fin n, 0 < c j)
    (hα : 0 ≤ α) (_hβ : 0 ≤ β)
    (hrow : ∀ i : Fin n, ∑ j : Fin n, M i j * c j ≤ α * r i)
    (hcol : ∀ j : Fin n, ∑ i : Fin n, r i * M i j ≤ β * c j)
    (x : Fin n → ℝ) :
    vecNorm2Sq (matMulVec n M x) ≤ α * β * vecNorm2Sq x := by
  have hrowabs_nonneg : ∀ i : Fin n, 0 ≤ ∑ j : Fin n, M i j * |x j| := by
    intro i
    exact Finset.sum_nonneg fun j _ => mul_nonneg (hM i j) (abs_nonneg (x j))
  have h_abs_sq :
      vecNorm2Sq (matMulVec n M x) ≤
        ∑ i : Fin n, (∑ j : Fin n, M i j * |x j|) ^ 2 := by
    unfold vecNorm2Sq
    apply Finset.sum_le_sum
    intro i _
    have habs : |matMulVec n M x i| ≤ ∑ j : Fin n, M i j * |x j| := by
      calc
        |matMulVec n M x i| ≤ ∑ j : Fin n, |M i j| * |x j| :=
          abs_matMulVec_le n M x i
        _ = ∑ j : Fin n, M i j * |x j| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_of_nonneg (hM i j)]
    have hsq := (sq_le_sq₀ (abs_nonneg _) (hrowabs_nonneg i)).mpr habs
    simpa [sq_abs] using hsq
  have h_rows :
      (∑ i : Fin n, (∑ j : Fin n, M i j * |x j|) ^ 2) ≤
        ∑ i : Fin n, (∑ j : Fin n, M i j * x j ^ 2 / c j) * (α * r i) := by
    apply Finset.sum_le_sum
    intro i _
    have hcauchy := ch7_weighted_row_cauchy_sum_sq M c x hM hc i
    have hf_nonneg : 0 ≤ ∑ j : Fin n, M i j * x j ^ 2 / c j := by
      exact Finset.sum_nonneg fun j _ =>
        div_nonneg (mul_nonneg (hM i j) (sq_nonneg (x j))) (le_of_lt (hc j))
    exact hcauchy.trans (mul_le_mul_of_nonneg_left (hrow i) hf_nonneg)
  have h_rearrange :
      (∑ i : Fin n, (∑ j : Fin n, M i j * x j ^ 2 / c j) * (α * r i)) =
        α * ∑ j : Fin n, (x j ^ 2 / c j) * (∑ i : Fin n, r i * M i j) := by
    calc
      (∑ i : Fin n, (∑ j : Fin n, M i j * x j ^ 2 / c j) * (α * r i))
          = ∑ i : Fin n, α * (r i * (∑ j : Fin n, M i j * x j ^ 2 / c j)) := by
            apply Finset.sum_congr rfl
            intro i _
            ring
      _ = α * ∑ i : Fin n, r i * (∑ j : Fin n, M i j * x j ^ 2 / c j) := by
            rw [Finset.mul_sum]
      _ = α * ∑ i : Fin n, ∑ j : Fin n, (x j ^ 2 / c j) * (r i * M i j) := by
            congr 1
            apply Finset.sum_congr rfl
            intro i _
            rw [Finset.mul_sum]
            apply Finset.sum_congr rfl
            intro j _
            ring
      _ = α * ∑ j : Fin n, ∑ i : Fin n, (x j ^ 2 / c j) * (r i * M i j) := by
            rw [Finset.sum_comm]
      _ = α * ∑ j : Fin n, (x j ^ 2 / c j) * (∑ i : Fin n, r i * M i j) := by
            congr 1
            apply Finset.sum_congr rfl
            intro j _
            rw [Finset.mul_sum]
  have h_col_bound :
      α * (∑ j : Fin n, (x j ^ 2 / c j) * (∑ i : Fin n, r i * M i j)) ≤
        α * (∑ j : Fin n, (x j ^ 2 / c j) * (β * c j)) := by
    apply mul_le_mul_of_nonneg_left
    · apply Finset.sum_le_sum
      intro j _
      have hxnonneg : 0 ≤ x j ^ 2 / c j :=
        div_nonneg (sq_nonneg _) (le_of_lt (hc j))
      exact mul_le_mul_of_nonneg_left (hcol j) hxnonneg
    · exact hα
  have h_simplify :
      α * (∑ j : Fin n, (x j ^ 2 / c j) * (β * c j)) =
        α * β * vecNorm2Sq x := by
    unfold vecNorm2Sq
    calc
      α * (∑ j : Fin n, (x j ^ 2 / c j) * (β * c j))
          = α * (∑ j : Fin n, β * x j ^ 2) := by
            congr 1
            apply Finset.sum_congr rfl
            intro j _
            have hcne : c j ≠ 0 := ne_of_gt (hc j)
            field_simp [hcne]
      _ = α * (β * ∑ j : Fin n, x j ^ 2) := by rw [← Finset.mul_sum]
      _ = α * β * ∑ j : Fin n, x j ^ 2 := by ring
  calc
    vecNorm2Sq (matMulVec n M x) ≤
        ∑ i : Fin n, (∑ j : Fin n, M i j * |x j|) ^ 2 := h_abs_sq
    _ ≤ ∑ i : Fin n, (∑ j : Fin n, M i j * x j ^ 2 / c j) * (α * r i) :=
        h_rows
    _ = α * ∑ j : Fin n, (x j ^ 2 / c j) * (∑ i : Fin n, r i * M i j) :=
        h_rearrange
    _ ≤ α * (∑ j : Fin n, (x j ^ 2 / c j) * (β * c j)) :=
        h_col_bound
    _ = α * β * vecNorm2Sq x := h_simplify

/-- Finite Schur-test certificate for the repository's real operator-2 bound. -/
lemma ch7_opNorm2Le_of_schur_bounds {n : ℕ}
    (M : Fin n → Fin n → ℝ) (r c : Fin n → ℝ) {α β : ℝ}
    (hM : ∀ i j : Fin n, 0 ≤ M i j)
    (hr : ∀ i : Fin n, 0 ≤ r i) (hc : ∀ j : Fin n, 0 < c j)
    (hα : 0 ≤ α) (hβ : 0 ≤ β)
    (hrow : ∀ i : Fin n, ∑ j : Fin n, M i j * c j ≤ α * r i)
    (hcol : ∀ j : Fin n, ∑ i : Fin n, r i * M i j ≤ β * c j) :
    opNorm2Le M (Real.sqrt (α * β)) := by
  intro x
  have hsq :=
    ch7_vecNorm2Sq_matMulVec_le_of_schur_bounds M r c hM hr hc hα hβ
      hrow hcol x
  unfold vecNorm2
  have hαβ : 0 ≤ α * β := mul_nonneg hα hβ
  calc
    Real.sqrt (vecNorm2Sq (matMulVec n M x)) ≤
        Real.sqrt ((α * β) * vecNorm2Sq x) := Real.sqrt_le_sqrt hsq
    _ = Real.sqrt (α * β) * Real.sqrt (vecNorm2Sq x) := by
        rw [Real.sqrt_mul hαβ]

/-- Bauer op-2 Schur certificate for the first scaled nonnegative factor.
The weights are `r_i = sqrt(a_i*x_i)` and `s_j = sqrt(y_j*b_j)`, giving
`||D₁ B D₂||₂ <= rho` from the right and left Perron-vector equations. -/
lemma ch7_bauer_left_scaled_opNorm2Le_of_left_right_vectors {n : ℕ}
    (B : Fin n → Fin n → ℝ) (ρ : ℝ)
    (x y a b : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hy : ∀ i : Fin n, 0 < y i)
    (ha : ∀ i : Fin n, 0 < a i)
    (hb : ∀ i : Fin n, 0 < b i)
    (hBy : ∀ i : Fin n, matMulVec n B y i = ρ * x i)
    (hBta : ∀ j : Fin n, matMulVec n (matTranspose B) a j = ρ * b j) :
    opNorm2Le
      (ch7TwoSidedScale
        (fun i : Fin n => a i / Real.sqrt (a i * x i)) B
        (fun j : Fin n => y j / Real.sqrt (y j * b j))) ρ := by
  let r : Fin n → ℝ := fun i => Real.sqrt (a i * x i)
  let s : Fin n → ℝ := fun j => Real.sqrt (y j * b j)
  let d₁ : Fin n → ℝ := fun i => a i / r i
  let d₂ : Fin n → ℝ := fun j => y j / s j
  have hr_nonneg : ∀ i : Fin n, 0 ≤ r i := fun i => Real.sqrt_nonneg _
  have hs_pos : ∀ j : Fin n, 0 < s j := by
    intro j
    exact Real.sqrt_pos.2 (mul_pos (hy j) (hb j))
  have hd₁_pos : ∀ i : Fin n, 0 < d₁ i := by
    intro i
    exact div_pos (ha i) (Real.sqrt_pos.2 (mul_pos (ha i) (hx i)))
  have hd₂_pos : ∀ j : Fin n, 0 < d₂ j := by
    intro j
    exact div_pos (hy j) (hs_pos j)
  have hM_nonneg :
      ∀ i j : Fin n, 0 ≤ ch7TwoSidedScale d₁ B d₂ i j := by
    intro i j
    unfold ch7TwoSidedScale
    exact mul_nonneg (mul_nonneg (le_of_lt (hd₁_pos i)) (hB i j))
      (le_of_lt (hd₂_pos j))
  have hrow :
      ∀ i : Fin n, ∑ j : Fin n, ch7TwoSidedScale d₁ B d₂ i j * s j ≤
        ρ * r i := by
    intro i
    exact le_of_eq <| by
      have hsqr : r i ^ 2 = a i * x i := by
        dsimp [r]
        exact Real.sq_sqrt (le_of_lt (mul_pos (ha i) (hx i)))
      have hrpos : 0 < r i := by
        dsimp [r]
        exact Real.sqrt_pos.2 (mul_pos (ha i) (hx i))
      have hBy_sum : ∑ j : Fin n, B i j * y j = ρ * x i := by
        simpa [matMulVec] using hBy i
      calc
        ∑ j : Fin n, ch7TwoSidedScale d₁ B d₂ i j * s j
            = (a i / r i) * (∑ j : Fin n, B i j * y j) := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro j _
              have hsne : s j ≠ 0 := ne_of_gt (hs_pos j)
              unfold ch7TwoSidedScale d₁ d₂
              field_simp [hsne]
        _ = (a i / r i) * (ρ * x i) := by rw [hBy_sum]
        _ = ρ * r i := by
              rw [show (a i / r i) * (ρ * x i) =
                    ρ * ((a i / r i) * x i) by ring]
              dsimp [r] at hrpos hsqr ⊢
              rw [ch7_div_sqrt_mul_mul_eq_sqrt_mul (ha i) (hx i)]
  have hcol :
      ∀ j : Fin n, ∑ i : Fin n, r i * ch7TwoSidedScale d₁ B d₂ i j ≤
        ρ * s j := by
    intro j
    exact le_of_eq <| by
      have hspos : 0 < s j := hs_pos j
      have hBta_sum : ∑ i : Fin n, a i * B i j = ρ * b j := by
        calc
          ∑ i : Fin n, a i * B i j = ∑ i : Fin n, B i j * a i := by
            apply Finset.sum_congr rfl
            intro i _
            ring
          _ = ρ * b j := by
            simpa [matMulVec, matTranspose] using hBta j
      calc
        ∑ i : Fin n, r i * ch7TwoSidedScale d₁ B d₂ i j
            = (y j / s j) * (∑ i : Fin n, a i * B i j) := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro i _
              have hrne : r i ≠ 0 := by
                dsimp [r]
                exact ne_of_gt (Real.sqrt_pos.2 (mul_pos (ha i) (hx i)))
              unfold ch7TwoSidedScale d₁ d₂
              field_simp [hrne]
        _ = (y j / s j) * (ρ * b j) := by rw [hBta_sum]
        _ = ρ * s j := by
              rw [show (y j / s j) * (ρ * b j) =
                    ρ * ((y j / s j) * b j) by ring]
              dsimp [s] at hspos ⊢
              rw [ch7_div_sqrt_mul_mul_eq_sqrt_mul (hy j) (hb j)]
  have hschur :
      opNorm2Le (ch7TwoSidedScale d₁ B d₂) (Real.sqrt (ρ * ρ)) :=
    ch7_opNorm2Le_of_schur_bounds
      (ch7TwoSidedScale d₁ B d₂) r s hM_nonneg hr_nonneg hs_pos hρ hρ hrow hcol
  have hsqrtrho : Real.sqrt (ρ * ρ) = ρ := by
    rw [show ρ * ρ = ρ ^ 2 by ring, Real.sqrt_sq_eq_abs, abs_of_nonneg hρ]
  exact opNorm2Le_mono hschur (le_of_eq hsqrtrho)

/-- Bauer op-2 Schur certificate for the inverse-side scaled nonnegative
factor.  With the same weights as the left factor, the compatible inverse
scaling gives `||D₂⁻¹ C D₁⁻¹||₂ <= 1`. -/
lemma ch7_bauer_right_scaled_opNorm2Le_of_left_right_vectors {n : ℕ}
    (C : Fin n → Fin n → ℝ) (x y a b : Fin n → ℝ)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (hy : ∀ i : Fin n, 0 < y i)
    (ha : ∀ i : Fin n, 0 < a i)
    (hb : ∀ i : Fin n, 0 < b i)
    (hCx : ∀ i : Fin n, matMulVec n C x i = y i)
    (hCtb : ∀ i : Fin n, matMulVec n (matTranspose C) b i = a i) :
    opNorm2Le
      (ch7TwoSidedScale
        (fun j : Fin n => b j / Real.sqrt (y j * b j)) C
        (fun i : Fin n => x i / Real.sqrt (a i * x i))) 1 := by
  let r : Fin n → ℝ := fun i => Real.sqrt (a i * x i)
  let s : Fin n → ℝ := fun j => Real.sqrt (y j * b j)
  let d₁Inv : Fin n → ℝ := fun i => x i / r i
  let d₂Inv : Fin n → ℝ := fun j => b j / s j
  have hr_pos : ∀ i : Fin n, 0 < r i := by
    intro i
    exact Real.sqrt_pos.2 (mul_pos (ha i) (hx i))
  have hr_nonneg : ∀ i : Fin n, 0 ≤ r i := fun i => le_of_lt (hr_pos i)
  have hs_pos : ∀ j : Fin n, 0 < s j := by
    intro j
    exact Real.sqrt_pos.2 (mul_pos (hy j) (hb j))
  have hd₁Inv_pos : ∀ i : Fin n, 0 < d₁Inv i := by
    intro i
    exact div_pos (hx i) (hr_pos i)
  have hd₂Inv_pos : ∀ j : Fin n, 0 < d₂Inv j := by
    intro j
    exact div_pos (hb j) (hs_pos j)
  have hM_nonneg :
      ∀ j i : Fin n, 0 ≤ ch7TwoSidedScale d₂Inv C d₁Inv j i := by
    intro j i
    unfold ch7TwoSidedScale
    exact mul_nonneg (mul_nonneg (le_of_lt (hd₂Inv_pos j)) (hC j i))
      (le_of_lt (hd₁Inv_pos i))
  have hrow :
      ∀ j : Fin n, ∑ i : Fin n, ch7TwoSidedScale d₂Inv C d₁Inv j i * r i ≤
        1 * s j := by
    intro j
    exact le_of_eq <| by
      have hCx_sum : ∑ i : Fin n, C j i * x i = y j := by
        simpa [matMulVec] using hCx j
      calc
        ∑ i : Fin n, ch7TwoSidedScale d₂Inv C d₁Inv j i * r i
            = (b j / s j) * (∑ i : Fin n, C j i * x i) := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro i _
              have hrne : r i ≠ 0 := ne_of_gt (hr_pos i)
              unfold ch7TwoSidedScale d₁Inv d₂Inv
              field_simp [hrne]
        _ = (b j / s j) * y j := by rw [hCx_sum]
        _ = s j := by
              dsimp [s]
              rw [ch7_div_sqrt_mul_mul_eq_sqrt_mul_comm (hy j) (hb j)]
        _ = 1 * s j := by ring
  have hcol :
      ∀ i : Fin n, ∑ j : Fin n, s j * ch7TwoSidedScale d₂Inv C d₁Inv j i ≤
        1 * r i := by
    intro i
    exact le_of_eq <| by
      have hCtb_sum : ∑ j : Fin n, b j * C j i = a i := by
        calc
          ∑ j : Fin n, b j * C j i = ∑ j : Fin n, C j i * b j := by
            apply Finset.sum_congr rfl
            intro j _
            ring
          _ = a i := by
            simpa [matMulVec, matTranspose] using hCtb i
      calc
        ∑ j : Fin n, s j * ch7TwoSidedScale d₂Inv C d₁Inv j i
            = (x i / r i) * (∑ j : Fin n, b j * C j i) := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro j _
              have hsne : s j ≠ 0 := ne_of_gt (hs_pos j)
              unfold ch7TwoSidedScale d₁Inv d₂Inv
              field_simp [hsne]
        _ = (x i / r i) * a i := by rw [hCtb_sum]
        _ = r i := by
              dsimp [r]
              rw [ch7_div_sqrt_mul_mul_eq_sqrt_mul_comm (ha i) (hx i)]
        _ = 1 * r i := by ring
  simpa using
    ch7_opNorm2Le_of_schur_bounds
      (ch7TwoSidedScale d₂Inv C d₁Inv) s r hM_nonneg
      (fun j => le_of_lt (hs_pos j)) hr_pos (by norm_num) (by norm_num)
      hrow hcol

/-- The exact Euclidean operator-2 condition product for a fixed reciprocal
two-sided scaling. -/
noncomputable def ch7TwoSidedScaledOp2Kappa {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) : ℝ :=
  complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₁ A d₂)) *
    complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₂Inv A_inv d₁Inv))

/-- Problem 7.10(e), fixed-scaling op-2 Bauer upper bound from compatible
left and right Perron-vector data.  The scaling is
`d₁ᵢ = aᵢ / sqrt(aᵢ*xᵢ)` and `d₂ⱼ = yⱼ / sqrt(yⱼ*bⱼ)`, with inverse-side
partners `xᵢ / sqrt(aᵢ*xᵢ)` and `bⱼ / sqrt(yⱼ*bⱼ)`. -/
theorem problem7_10e_scaled_op2Kappa_le_perron_of_abs_left_right_vectors
    {n : ℕ} (A A_inv : Fin n → Fin n → ℝ) {ρ : ℝ}
    (x y a b : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hy : ∀ i : Fin n, 0 < y i)
    (ha : ∀ i : Fin n, 0 < a i)
    (hb : ∀ i : Fin n, 0 < b i)
    (hBy : ∀ i : Fin n,
      matMulVec n (absMatrix n A) y i = ρ * x i)
    (hCx : ∀ i : Fin n,
      matMulVec n (absMatrix n A_inv) x i = y i)
    (hCtb : ∀ i : Fin n,
      matMulVec n (matTranspose (absMatrix n A_inv)) b i = a i)
    (hBta : ∀ j : Fin n,
      matMulVec n (matTranspose (absMatrix n A)) a j = ρ * b j) :
    ch7TwoSidedScaledOp2Kappa A A_inv
        (fun i : Fin n => a i / Real.sqrt (a i * x i))
        (fun i : Fin n => x i / Real.sqrt (a i * x i))
        (fun j : Fin n => y j / Real.sqrt (y j * b j))
        (fun j : Fin n => b j / Real.sqrt (y j * b j)) ≤ ρ := by
  let B : Fin n → Fin n → ℝ := absMatrix n A
  let C : Fin n → Fin n → ℝ := absMatrix n A_inv
  let d₁ : Fin n → ℝ := fun i => a i / Real.sqrt (a i * x i)
  let d₁Inv : Fin n → ℝ := fun i => x i / Real.sqrt (a i * x i)
  let d₂ : Fin n → ℝ := fun j => y j / Real.sqrt (y j * b j)
  let d₂Inv : Fin n → ℝ := fun j => b j / Real.sqrt (y j * b j)
  have hB_nonneg : ∀ i j : Fin n, 0 ≤ B i j := by
    intro i j
    dsimp [B, absMatrix]
    exact abs_nonneg _
  have hC_nonneg : ∀ i j : Fin n, 0 ≤ C i j := by
    intro i j
    dsimp [C, absMatrix]
    exact abs_nonneg _
  have hd₁_nonneg : ∀ i : Fin n, 0 ≤ d₁ i := by
    intro i
    exact le_of_lt (div_pos (ha i) (Real.sqrt_pos.2 (mul_pos (ha i) (hx i))))
  have hd₂_nonneg : ∀ j : Fin n, 0 ≤ d₂ j := by
    intro j
    exact le_of_lt (div_pos (hy j) (Real.sqrt_pos.2 (mul_pos (hy j) (hb j))))
  have hd₁Inv_nonneg : ∀ i : Fin n, 0 ≤ d₁Inv i := by
    intro i
    exact le_of_lt (div_pos (hx i) (Real.sqrt_pos.2 (mul_pos (ha i) (hx i))))
  have hd₂Inv_nonneg : ∀ j : Fin n, 0 ≤ d₂Inv j := by
    intro j
    exact le_of_lt (div_pos (hb j) (Real.sqrt_pos.2 (mul_pos (hy j) (hb j))))
  have hBop_abs :
      opNorm2Le (ch7TwoSidedScale d₁ B d₂) ρ := by
    simpa [B, d₁, d₂] using
      ch7_bauer_left_scaled_opNorm2Le_of_left_right_vectors
        (absMatrix n A) ρ x y a b
        (fun i j => by simp [absMatrix])
        hρ hx hy ha hb hBy hBta
  have hCop_abs :
      opNorm2Le (ch7TwoSidedScale d₂Inv C d₁Inv) 1 := by
    simpa [C, d₁Inv, d₂Inv] using
      ch7_bauer_right_scaled_opNorm2Le_of_left_right_vectors
        (absMatrix n A_inv) x y a b
        (fun i j => by simp [absMatrix])
        hx hy ha hb hCx hCtb
  have hBrect :
      rectOpNorm2Le (ch7TwoSidedScale d₁ A d₂) ρ := by
    apply rectOpNorm2Le_of_abs_entry_le
      (B := ch7TwoSidedScale d₁ B d₂)
    · intro i j
      unfold ch7TwoSidedScale B absMatrix
      rw [abs_mul, abs_mul, abs_of_nonneg (hd₁_nonneg i),
        abs_of_nonneg (hd₂_nonneg j)]
    · exact opNorm2Le_to_rectOpNorm2Le hBop_abs
  have hCrect :
      rectOpNorm2Le (ch7TwoSidedScale d₂Inv A_inv d₁Inv) 1 := by
    apply rectOpNorm2Le_of_abs_entry_le
      (B := ch7TwoSidedScale d₂Inv C d₁Inv)
    · intro i j
      unfold ch7TwoSidedScale C absMatrix
      rw [abs_mul, abs_mul, abs_of_nonneg (hd₂Inv_nonneg i),
        abs_of_nonneg (hd₁Inv_nonneg j)]
    · exact opNorm2Le_to_rectOpNorm2Le hCop_abs
  have hBop :
      complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₁ A d₂)) ≤ ρ :=
    complexMatrixOp2_realRectToCMatrix_le_of_rectOpNorm2Le
      (ch7TwoSidedScale d₁ A d₂) hρ hBrect
  have hCop :
      complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₂Inv A_inv d₁Inv)) ≤ 1 :=
    complexMatrixOp2_realRectToCMatrix_le_of_rectOpNorm2Le
      (ch7TwoSidedScale d₂Inv A_inv d₁Inv) (by norm_num) hCrect
  change
    complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₁ A d₂)) *
        complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₂Inv A_inv d₁Inv)) ≤ ρ
  calc
    complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₁ A d₂)) *
        complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₂Inv A_inv d₁Inv))
        ≤ ρ * 1 := by
          exact mul_le_mul hBop hCop (complexMatrixOp2_nonneg _) hρ
    _ = ρ := by ring

/-- Problem 7.10(e), pointwise two-norm interpolation for a fixed two-sided
scaling: the `κ₂` value is bounded by the geometric mean of the corresponding
`κ₁` and `κ∞` products. -/
theorem problem7_10e_scaled_op2Kappa_le_sqrt_oneKappa_mul_infKappa
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) :
    ch7TwoSidedScaledOp2Kappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤
      Real.sqrt
        (ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv *
          ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv) := by
  let M : Fin n → Fin n → ℝ := ch7TwoSidedScale d₁ A d₂
  let N : Fin n → Fin n → ℝ := ch7TwoSidedScale d₂Inv A_inv d₁Inv
  have hM :=
    problem7_10e_complexMatrixOp2_realRectToCMatrix_le_sqrt_one_mul_inf hn M
  have hN :=
    problem7_10e_complexMatrixOp2_realRectToCMatrix_le_sqrt_one_mul_inf hn N
  have hprod :
      complexMatrixOp2 (realRectToCMatrix M) *
          complexMatrixOp2 (realRectToCMatrix N) ≤
        Real.sqrt (oneNorm M * infNorm M) *
          Real.sqrt (oneNorm N * infNorm N) :=
    mul_le_mul hM hN (complexMatrixOp2_nonneg _) (Real.sqrt_nonneg _)
  have hMrad : 0 ≤ oneNorm M * infNorm M :=
    mul_nonneg (oneNorm_nonneg M) (infNorm_nonneg M)
  have hsqrts :
      Real.sqrt (oneNorm M * infNorm M) *
          Real.sqrt (oneNorm N * infNorm N) =
        Real.sqrt ((oneNorm M * oneNorm N) * (infNorm M * infNorm N)) := by
    rw [← Real.sqrt_mul hMrad]
    congr 1
    ring
  exact hprod.trans (by
    rw [hsqrts]
    rfl)

/-- Problem 7.10(e), fixed-scaling consequence of the source interpolation
step: if the same two-sided scaling has both its `κ₁` and `κ∞` products
bounded by `ρ`, then its exact Euclidean `κ₂` product is also bounded by `ρ`.
The remaining global Bauer/Perron work is to supply such a scaling at
`ρ = ρ(|A||A⁻¹|)`. -/
theorem problem7_10e_scaled_op2Kappa_le_of_one_inf_bounds
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) {ρ : ℝ}
    (hρ : 0 ≤ ρ)
    (hone :
      ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤ ρ)
    (hinf :
      ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤ ρ) :
    ch7TwoSidedScaledOp2Kappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤ ρ := by
  have hinterp :=
    problem7_10e_scaled_op2Kappa_le_sqrt_oneKappa_mul_infKappa
      hn A A_inv d₁ d₁Inv d₂ d₂Inv
  have hone_nonneg :
      0 ≤ ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv := by
    unfold ch7TwoSidedScaledOneKappa
    exact mul_nonneg (oneNorm_nonneg _) (oneNorm_nonneg _)
  have hinf_nonneg :
      0 ≤ ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv := by
    unfold ch7TwoSidedScaledInfKappa
    exact mul_nonneg (infNorm_nonneg _) (infNorm_nonneg _)
  have hrad_le :
      ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv *
          ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤ ρ * ρ :=
    mul_le_mul hone hinf hinf_nonneg hρ
  have hsqrt_le :=
    Real.sqrt_le_sqrt hrad_le
  have hsqrtρ : Real.sqrt (ρ * ρ) = ρ := by
    rw [show ρ * ρ = ρ ^ 2 by ring, Real.sqrt_sq_eq_abs, abs_of_nonneg hρ]
  exact hinterp.trans (hsqrt_le.trans (le_of_eq hsqrtρ))

/-- Problem 7.10(e), product-bound form of the fixed-scaling interpolation
step.  It is enough for one admissible scaling to satisfy
`κ₁(D₁AD₂) * κ∞(D₁AD₂) <= ρ^2`; the stronger API requiring each factor to be
separately bounded by `ρ` is a convenient specialization of this statement. -/
theorem problem7_10e_scaled_op2Kappa_le_of_one_inf_product_bound
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) {ρ : ℝ}
    (hρ : 0 ≤ ρ)
    (hprod :
      ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv *
          ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤
        ρ * ρ) :
    ch7TwoSidedScaledOp2Kappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤ ρ := by
  have hinterp :=
    problem7_10e_scaled_op2Kappa_le_sqrt_oneKappa_mul_infKappa
      hn A A_inv d₁ d₁Inv d₂ d₂Inv
  have hsqrt_le := Real.sqrt_le_sqrt hprod
  have hsqrtρ : Real.sqrt (ρ * ρ) = ρ := by
    rw [show ρ * ρ = ρ ^ 2 by ring, Real.sqrt_sq_eq_abs, abs_of_nonneg hρ]
  exact hinterp.trans (hsqrt_le.trans (le_of_eq hsqrtρ))

-- ============================================================
-- Problem 7.15: Hadamard product algebra under two-sided scaling
-- ============================================================

/-- Entrywise Hadamard product, written in the Chapter 7 source notation. -/
noncomputable def ch7HadamardProduct {m n : ℕ}
    (A B : Fin m → Fin n → ℝ) : Fin m → Fin n → ℝ :=
  fun i j => A i j * B i j

lemma ch7HadamardProduct_twoSidedScale_transpose_inverse_eq {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ch7HadamardProduct
        (ch7TwoSidedScale d₁ A d₂)
        (matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv)) =
      ch7HadamardProduct A (matTranspose A_inv) := by
  ext i j
  unfold ch7HadamardProduct matTranspose ch7TwoSidedScale
  have h₁ : d₁Inv i * d₁ i = 1 := by
    rw [mul_comm, hd₁ i]
  have h₂ : d₂Inv j * d₂ j = 1 := by
    rw [mul_comm, hd₂ j]
  rw [show (d₁ i * A i j * d₂ j) * (d₂Inv j * A_inv j i * d₁Inv i) =
        (d₁Inv i * d₁ i) * (d₂Inv j * d₂ j) * (A i j * A_inv j i) by ring,
      h₁, h₂]
  ring

/-- Problem 7.15's diagonal-scaling algebraic core: the matrix
`A ∘ A^{-T}` is unchanged by reciprocal two-sided diagonal scaling, when the
inverse partner is scaled compatibly.  The remaining source inequality is the
Horn-Johnson operator-2 Hadamard bound, not this scaling algebra. -/
theorem problem7_15_twoSidedScale_hadamard_transpose_inverse_invariant {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ch7HadamardProduct
        (ch7TwoSidedScale d₁ A d₂)
        (matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv)) =
      ch7HadamardProduct A (matTranspose A_inv) :=
  ch7HadamardProduct_twoSidedScale_transpose_inverse_eq A A_inv
    d₁ d₁Inv d₂ d₂Inv hd₁ hd₂

/-- Problem 7.15 operator-2 transpose side condition: the compatible
inverse-scaled partner has the same real Euclidean operator-2 certificate after
transpose.  This closes the transpose/norm-identification part of the
Hadamard lower-bound route; the Horn-Johnson Hadamard inequality remains the
separate missing foundation. -/
theorem problem7_15_transpose_inverse_partner_opNorm2Le {n : ℕ}
    (A_inv : Fin n → Fin n → ℝ)
    (d₁Inv d₂Inv : Fin n → ℝ) {c : ℝ}
    (hc : 0 ≤ c)
    (hInvPartner :
      opNorm2Le (ch7TwoSidedScale d₂Inv A_inv d₁Inv) c) :
    opNorm2Le
      (matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv)) c :=
  opNorm2Le_transpose (ch7TwoSidedScale d₂Inv A_inv d₁Inv) hc hInvPartner

/-- Problem 7.15 / Horn-Johnson inequality in the repository's real
Euclidean operator-2 certificate form:
`||A ∘ B||₂ <= ||A||₂ ||B||₂`. -/
theorem problem7_15_hornJohnson_hadamard_opNorm2Le {n : ℕ}
    (A B : Fin n → Fin n → ℝ) {a b : ℝ}
    (ha : 0 ≤ a) (hb : 0 ≤ b)
    (hA : opNorm2Le A a) (hB : opNorm2Le B b) :
    opNorm2Le (ch7HadamardProduct A B) (a * b) := by
  simpa [ch7HadamardProduct] using
    opNorm2Le_hadamard A B ha hb hA hB

/-- Problem 7.15 scaled inverse-partner consequence: for every compatible
reciprocal two-sided scaling, the source matrix `A ∘ A_invᵀ` has operator-2
certificate bounded by the product of the scaled matrix and scaled inverse
partner certificates.  This combines the Horn-Johnson Schur-product bound with
the diagonal-scaling invariance already proved for `A ∘ A_invᵀ`. -/
theorem problem7_15_scaled_inverse_hadamard_opNorm2Le {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) {a b : ℝ}
    (ha : 0 ≤ a) (hb : 0 ≤ b)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1)
    (hScaled : opNorm2Le (ch7TwoSidedScale d₁ A d₂) a)
    (hInvPartner :
      opNorm2Le (ch7TwoSidedScale d₂Inv A_inv d₁Inv) b) :
    opNorm2Le (ch7HadamardProduct A (matTranspose A_inv)) (a * b) := by
  have hInvT :
      opNorm2Le
        (matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv)) b :=
    problem7_15_transpose_inverse_partner_opNorm2Le A_inv d₁Inv d₂Inv hb
      hInvPartner
  have hHadScaled :
      opNorm2Le
        (ch7HadamardProduct
          (ch7TwoSidedScale d₁ A d₂)
          (matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv))) (a * b) :=
    problem7_15_hornJohnson_hadamard_opNorm2Le
      (ch7TwoSidedScale d₁ A d₂)
      (matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv))
      ha hb hScaled hInvT
  have hInvariant :
      ch7HadamardProduct
          (ch7TwoSidedScale d₁ A d₂)
          (matTranspose (ch7TwoSidedScale d₂Inv A_inv d₁Inv)) =
        ch7HadamardProduct A (matTranspose A_inv) :=
    problem7_15_twoSidedScale_hadamard_transpose_inverse_invariant
      A A_inv d₁ d₁Inv d₂ d₂Inv hd₁ hd₂
  simpa [hInvariant] using hHadScaled

/-- Problem 7.15's exact Euclidean operator-2 condition values over positive
two-sided diagonal scalings.  Each element is
`||D₁ A D₂||₂ * ||D₂⁻¹ A_inv D₁⁻¹||₂`, with the exact norm represented as
`complexMatrixOp2` of the real matrix's complexification.  When `A_inv` is a
genuine inverse of `A`, `ch7TwoSidedScale_isInverse` identifies the second
factor as the inverse-scaled partner, so this is the source `κ₂(D₁ A D₂)`
value set. -/
noncomputable def ch7TwoSidedScaledOp2KappaSet {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ,
    (∀ i : Fin n, 0 < d₁ i) ∧
    (∀ i : Fin n, 0 < d₁Inv i) ∧
    (∀ i : Fin n, 0 < d₂ i) ∧
    (∀ i : Fin n, 0 < d₂Inv i) ∧
    (∀ i : Fin n, d₁ i * d₁Inv i = 1) ∧
    (∀ i : Fin n, d₂ i * d₂Inv i = 1) ∧
    κ =
      complexMatrixOp2 (realRectToCMatrix (ch7TwoSidedScale d₁ A d₂)) *
        complexMatrixOp2
          (realRectToCMatrix (ch7TwoSidedScale d₂Inv A_inv d₁Inv))}

/-- The positive two-sided scaling value set in Problem 7.15 is nonempty:
the identity scaling is admissible. -/
theorem ch7TwoSidedScaledOp2KappaSet_nonempty {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    (ch7TwoSidedScaledOp2KappaSet A A_inv).Nonempty := by
  refine ⟨complexMatrixOp2 (realRectToCMatrix A) *
      complexMatrixOp2 (realRectToCMatrix A_inv), ?_⟩
  refine ⟨fun _ => 1, fun _ => 1, fun _ => 1, fun _ => 1,
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num), ?_⟩
  have hA :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) A
        (fun _ : Fin n => (1 : ℝ)) = A := by
    ext i j
    simp [ch7TwoSidedScale]
  have hAinv :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) A_inv
        (fun _ : Fin n => (1 : ℝ)) = A_inv := by
    ext i j
    simp [ch7TwoSidedScale]
  rw [hA, hAinv]

/-- Membership helper for the positive two-sided operator-2 scaling value set.
This is the source `κ₂(D₁ A D₂)` value for a supplied reciprocal positive
scaling. -/
theorem ch7TwoSidedScaledOp2Kappa_mem_set {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ch7TwoSidedScaledOp2Kappa A A_inv d₁ d₁Inv d₂ d₂Inv ∈
      ch7TwoSidedScaledOp2KappaSet A A_inv := by
  refine ⟨d₁, d₁Inv, d₂, d₂Inv,
    hd₁pos, hd₁Invpos, hd₂pos, hd₂Invpos, hd₁, hd₂, ?_⟩
  rfl

/-- The positive two-sided operator-2 condition-product value set is bounded
below by zero. -/
theorem ch7TwoSidedScaledOp2KappaSet_bddBelow {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    BddBelow (ch7TwoSidedScaledOp2KappaSet A A_inv) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with
    ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
      _hd₂pos, _hd₂Invpos, _hd₁, _hd₂, rfl⟩
  exact mul_nonneg (complexMatrixOp2_nonneg _) (complexMatrixOp2_nonneg _)

/-- The infimum of the exact operator-2 two-sided condition products is
nonnegative, since every admissible value is a product of operator norms. -/
theorem ch7TwoSidedScaledOp2KappaSet_sInf_nonneg {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    0 ≤ sInf (ch7TwoSidedScaledOp2KappaSet A A_inv) := by
  let S : Set ℝ := ch7TwoSidedScaledOp2KappaSet A A_inv
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledOp2KappaSet_nonempty A A_inv
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
        _hd₂pos, _hd₂Invpos, _hd₁, _hd₂, rfl⟩
    exact mul_nonneg (complexMatrixOp2_nonneg _) (complexMatrixOp2_nonneg _)
  exact le_csInf hS_nonempty hlower

/-- Problem 7.10(e), global-infimum packaging of the interpolation step:
if one admissible positive reciprocal two-sided scaling has both its `κ₁` and
`κ∞` products bounded by `ρ`, then the infimum of the exact `κ₂` products over
all positive two-sided scalings is bounded by `ρ`.  The remaining source work
is to prove, from Perron-Frobenius/spectral-radius data, that such a common
one-norm and infinity-norm scaling exists for `ρ = ρ(|A||A⁻¹|)`. -/
theorem problem7_10e_twoSidedScaledOp2Kappa_sInf_le_of_one_inf_bounds
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) {ρ : ℝ}
    (hρ : 0 ≤ ρ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1)
    (hone :
      ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤ ρ)
    (hinf :
      ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤ ρ) :
    sInf (ch7TwoSidedScaledOp2KappaSet A A_inv) ≤ ρ := by
  let κ := ch7TwoSidedScaledOp2Kappa A A_inv d₁ d₁Inv d₂ d₂Inv
  let S : Set ℝ := ch7TwoSidedScaledOp2KappaSet A A_inv
  have hκmem : κ ∈ S := by
    simpa [κ, S] using
      ch7TwoSidedScaledOp2Kappa_mem_set A A_inv d₁ d₁Inv d₂ d₂Inv
        hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  have hκle : κ ≤ ρ := by
    simpa [κ] using
      problem7_10e_scaled_op2Kappa_le_of_one_inf_bounds
        hn A A_inv d₁ d₁Inv d₂ d₂Inv hρ hone hinf
  have hbddBelow : BddBelow S := by
    simpa [S] using ch7TwoSidedScaledOp2KappaSet_bddBelow A A_inv
  exact (csInf_le hbddBelow hκmem).trans hκle

/-- Problem 7.10(e), global-infimum packaging of the product-bound
interpolation step: if one admissible positive reciprocal two-sided scaling
has `κ₁ * κ∞ <= ρ^2`, then the exact operator-2 infimum over all positive
two-sided scalings is bounded by `ρ`. -/
theorem problem7_10e_twoSidedScaledOp2Kappa_sInf_le_of_one_inf_product_bound
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) {ρ : ℝ}
    (hρ : 0 ≤ ρ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1)
    (hprod :
      ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv *
          ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ≤
        ρ * ρ) :
    sInf (ch7TwoSidedScaledOp2KappaSet A A_inv) ≤ ρ := by
  let κ := ch7TwoSidedScaledOp2Kappa A A_inv d₁ d₁Inv d₂ d₂Inv
  let S : Set ℝ := ch7TwoSidedScaledOp2KappaSet A A_inv
  have hκmem : κ ∈ S := by
    simpa [κ, S] using
      ch7TwoSidedScaledOp2Kappa_mem_set A A_inv d₁ d₁Inv d₂ d₂Inv
        hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  have hκle : κ ≤ ρ := by
    simpa [κ] using
      problem7_10e_scaled_op2Kappa_le_of_one_inf_product_bound
        hn A A_inv d₁ d₁Inv d₂ d₂Inv hρ hprod
  have hbddBelow : BddBelow S := by
    simpa [S] using ch7TwoSidedScaledOp2KappaSet_bddBelow A A_inv
  exact (csInf_le hbddBelow hκmem).trans hκle

/-- Problem 7.10(e), global-infimum form of the compatible left/right
Perron-vector Schur scaling.  The constructed positive reciprocal scaling
proves the source two-norm upper bound whenever the right data
`C*x = y`, `B*y = ρ*x` and left data `Cᵀ*b = a`, `Bᵀ*a = ρ*b` are available
for `B = |A|` and `C = |A⁻¹|`. -/
theorem problem7_10e_twoSidedScaledOp2Kappa_sInf_le_perron_of_abs_left_right_vectors
    {n : ℕ} (A A_inv : Fin n → Fin n → ℝ) {ρ : ℝ}
    (x y a b : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hy : ∀ i : Fin n, 0 < y i)
    (ha : ∀ i : Fin n, 0 < a i)
    (hb : ∀ i : Fin n, 0 < b i)
    (hBy : ∀ i : Fin n,
      matMulVec n (absMatrix n A) y i = ρ * x i)
    (hCx : ∀ i : Fin n,
      matMulVec n (absMatrix n A_inv) x i = y i)
    (hCtb : ∀ i : Fin n,
      matMulVec n (matTranspose (absMatrix n A_inv)) b i = a i)
    (hBta : ∀ j : Fin n,
      matMulVec n (matTranspose (absMatrix n A)) a j = ρ * b j) :
    sInf (ch7TwoSidedScaledOp2KappaSet A A_inv) ≤ ρ := by
  let d₁ : Fin n → ℝ := fun i => a i / Real.sqrt (a i * x i)
  let d₁Inv : Fin n → ℝ := fun i => x i / Real.sqrt (a i * x i)
  let d₂ : Fin n → ℝ := fun j => y j / Real.sqrt (y j * b j)
  let d₂Inv : Fin n → ℝ := fun j => b j / Real.sqrt (y j * b j)
  let κ := ch7TwoSidedScaledOp2Kappa A A_inv d₁ d₁Inv d₂ d₂Inv
  let S : Set ℝ := ch7TwoSidedScaledOp2KappaSet A A_inv
  have hd₁pos : ∀ i : Fin n, 0 < d₁ i := by
    intro i
    exact div_pos (ha i) (Real.sqrt_pos.2 (mul_pos (ha i) (hx i)))
  have hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i := by
    intro i
    exact div_pos (hx i) (Real.sqrt_pos.2 (mul_pos (ha i) (hx i)))
  have hd₂pos : ∀ j : Fin n, 0 < d₂ j := by
    intro j
    exact div_pos (hy j) (Real.sqrt_pos.2 (mul_pos (hy j) (hb j)))
  have hd₂Invpos : ∀ j : Fin n, 0 < d₂Inv j := by
    intro j
    exact div_pos (hb j) (Real.sqrt_pos.2 (mul_pos (hy j) (hb j)))
  have hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1 := by
    intro i
    dsimp [d₁, d₁Inv]
    exact ch7_div_sqrt_mul_mul_div_sqrt_eq_one (ha i) (hx i)
  have hd₂ : ∀ j : Fin n, d₂ j * d₂Inv j = 1 := by
    intro j
    dsimp [d₂, d₂Inv]
    exact ch7_div_sqrt_mul_mul_div_sqrt_eq_one (hy j) (hb j)
  have hκmem : κ ∈ S := by
    simpa [κ, S] using
      ch7TwoSidedScaledOp2Kappa_mem_set A A_inv d₁ d₁Inv d₂ d₂Inv
        hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  have hκle : κ ≤ ρ := by
    simpa [κ, d₁, d₁Inv, d₂, d₂Inv] using
      problem7_10e_scaled_op2Kappa_le_perron_of_abs_left_right_vectors
        A A_inv x y a b hρ hx hy ha hb hBy hCx hCtb hBta
  have hbddBelow : BddBelow S := by
    simpa [S] using ch7TwoSidedScaledOp2KappaSet_bddBelow A A_inv
  exact (csInf_le hbddBelow hκmem).trans hκle

/-- Problem 7.10(e), irreducible-product source wrapper for the two-norm
Bauer upper bound.  The right Perron vector for `|A||A⁻¹|` and the left
Perron vector obtained from the transpose product are generated from the
repository's Perron-Frobenius closure, their spectral-radius values are
identified by `ρ(AB)=ρ(BA)` and transpose invariance, and the compatible
Schur scaling proves
`inf_D₁,D₂ κ₂(D₁ A D₂) <= ρ(|A||A⁻¹|)`. -/
theorem problem7_10e_irreducible_products_twoSidedScaledOp2KappaSet_sInf_le_spectralRadius
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n (absMatrix n A) (absMatrix n A_inv)) :
        Matrix (Fin n) (Fin n) ℝ))
    (hCB : Matrix.IsIrreducible
      (Matrix.of (matMul n (absMatrix n A_inv) (absMatrix n A)) :
        Matrix (Fin n) (Fin n) ℝ)) :
    ∃ mu nu : ℂ, ∃ x y a b : Fin n → ℝ,
      (nnnorm mu : ENNReal) =
        spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from
              realRectToCMatrix
                (matMul n (absMatrix n A) (absMatrix n A_inv)))) ∧
      (nnnorm nu : ENNReal) =
        spectralRadius ℂ
          (Matrix.toLin'
            (show Matrix (Fin n) (Fin n) ℂ from
              realRectToCMatrix
                (matMul n (matTranspose (absMatrix n A))
                  (matTranspose (absMatrix n A_inv))))) ∧
      ‖nu‖ = ‖mu‖ ∧
      (∀ i : Fin n, 0 < x i) ∧
      (∀ i : Fin n, 0 < y i) ∧
      (∀ i : Fin n, 0 < a i) ∧
      (∀ i : Fin n, 0 < b i) ∧
      (∀ i : Fin n,
        matMulVec n (absMatrix n A) y i = ‖mu‖ * x i) ∧
      (∀ i : Fin n,
        matMulVec n (absMatrix n A_inv) x i = y i) ∧
      (∀ i : Fin n,
        matMulVec n (matTranspose (absMatrix n A_inv)) b i = a i) ∧
      (∀ j : Fin n,
        matMulVec n (matTranspose (absMatrix n A)) a j = ‖mu‖ * b j) ∧
      sInf (ch7TwoSidedScaledOp2KappaSet A A_inv) ≤ ‖mu‖ := by
  obtain ⟨mu, _z, _x₀, x, _hz_ne, _hx₀_ne, _hx₀_nonneg, hx_pos,
    _heig_complex, hrad_mu, _hsubx₀, heigBC⟩ :=
    problem7_10b_abs_product_exists_spectralRadius_attaining_positive_eigenvector
      hn A A_inv hBC
  obtain ⟨nu, _w, _u₀, b, _hw_ne, _hu₀_ne, _hu₀_nonneg, hb_pos,
    _heigT_complex, hrad_nu, _hsubu₀, heigT⟩ :=
    problem7_10e_abs_transpose_product_exists_spectralRadius_attaining_positive_eigenvector
      hn A A_inv hCB
  let y : Fin n → ℝ := matMulVec n (absMatrix n A_inv) x
  let a : Fin n → ℝ := matMulVec n (matTranspose (absMatrix n A_inv)) b
  have hy_pos : ∀ i : Fin n, 0 < y i := by
    dsimp [y]
    exact problem7_10d_abs_inverse_Cx_pos_of_irreducible_products
      hn A A_inv ‖mu‖ x hBC hCB hx_pos heigBC
  have hTBC : Matrix.IsIrreducible
      (Matrix.of
        (matMul n (matTranspose (absMatrix n A))
