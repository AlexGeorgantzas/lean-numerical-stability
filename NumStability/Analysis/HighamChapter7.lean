        (fun j : Fin n => ch7RectColumnLpNormOfReal p A j) ≤
      (n : ℝ) ^ (1 - p⁻¹) * μ := by
  simpa [hmin.csInf_eq] using
    theorem7_5_lp_column_equilibration_le_card_rpow_sInf_right_scalings
