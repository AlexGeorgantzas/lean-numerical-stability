lemma ch7TwoSidedScale_nonneg {n : ℕ}
    (dLeft : Fin n → ℝ) (A : Fin n → Fin n → ℝ) (dRight : Fin n → ℝ)
    (hdLeft : ∀ i : Fin n, 0 ≤ dLeft i)
    (hA : ∀ i j : Fin n, 0 ≤ A i j)
    (hdRight : ∀ j : Fin n, 0 ≤ dRight j) :
    ∀ i j : Fin n, 0 ≤ ch7TwoSidedScale dLeft A dRight i j := by
  intro i j
  exact mul_nonneg (mul_nonneg (hdLeft i) (hA i j)) (hdRight j)

lemma ch7TwoSidedScale_matMulVec {n : ℕ}
    (dLeft : Fin n → ℝ) (A : Fin n → Fin n → ℝ)
    (dRight : Fin n → ℝ) (x : Fin n → ℝ) :
    matMulVec n (ch7TwoSidedScale dLeft A dRight) x =
      fun i : Fin n => dLeft i * matMulVec n A (fun j => dRight j * x j) i := by
  ext i
  unfold matMulVec ch7TwoSidedScale
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro j _
  ring

lemma ch7_bauer_scaled_product_eigenvector {n : ℕ}
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i) :
    matMulVec n
        (matMul n (ch7TwoSidedScale d₁ B d₂)
          (ch7TwoSidedScale d₂Inv C d₁Inv))
        (fun i => d₁ i * x i) =
      fun i => ρ * (d₁ i * x i) := by
  ext i
  rw [matMulVec_matMul]
  rw [ch7TwoSidedScale_matMulVec]
  have hinner :
      matMulVec n (ch7TwoSidedScale d₂Inv C d₁Inv)
          (fun i : Fin n => d₁ i * x i) =
        fun j : Fin n => d₂Inv j * matMulVec n C x j := by
    ext j
    rw [ch7TwoSidedScale_matMulVec]
    change d₂Inv j *
        (∑ k : Fin n, C j k * (d₁Inv k * (d₁ k * x k))) =
      d₂Inv j * (∑ k : Fin n, C j k * x k)
    congr 1
    apply Finset.sum_congr rfl
    intro k _
    congr 1
    calc
      d₁Inv k * (d₁ k * x k) = (d₁ k * d₁Inv k) * x k := by ring
      _ = x k := by rw [hd₁ k]; ring
  rw [hinner]
  change d₁ i *
      (∑ j : Fin n, B i j *
        (d₂ j * (d₂Inv j * (∑ k : Fin n, C j k * x k)))) =
    ρ * (d₁ i * x i)
  rw [Finset.mul_sum]
  calc
    ∑ j : Fin n, d₁ i * (B i j * (d₂ j *
        (d₂Inv j * ∑ k : Fin n, C j k * x k)
        ))
        = d₁ i * ∑ j : Fin n, B i j * (∑ k : Fin n, C j k * x k) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          calc
            d₁ i * (B i j * (d₂ j *
                (d₂Inv j * ∑ k : Fin n, C j k * x k)
                ))
                = d₁ i * (B i j * ((d₂ j * d₂Inv j) *
                    ∑ k : Fin n, C j k * x k)) := by ring
            _ = d₁ i * (B i j * ∑ k : Fin n, C j k * x k) := by
                  rw [hd₂ j]
                  ring
    _ = d₁ i * matMulVec n B (matMulVec n C x) i := by
          rfl
    _ = d₁ i * matMulVec n (matMul n B C) x i := by
          rw [← matMulVec_matMul n B C x i]
    _ = d₁ i * (ρ * x i) := by rw [heig i]
    _ = ρ * (d₁ i * x i) := by ring

lemma ch7_bauer_scaled_product_mulVec_eq {n : ℕ}
    (B C : Fin n → Fin n → ℝ) (x : Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    matMulVec n
        (matMul n (ch7TwoSidedScale d₁ B d₂)
          (ch7TwoSidedScale d₂Inv C d₁Inv))
        (fun i => d₁ i * x i) =
      fun i => d₁ i * matMulVec n (matMul n B C) x i := by
  ext i
  rw [matMulVec_matMul]
  rw [ch7TwoSidedScale_matMulVec]
  have hinner :
      matMulVec n (ch7TwoSidedScale d₂Inv C d₁Inv)
          (fun i : Fin n => d₁ i * x i) =
        fun j : Fin n => d₂Inv j * matMulVec n C x j := by
    ext j
    rw [ch7TwoSidedScale_matMulVec]
    change d₂Inv j *
        (∑ k : Fin n, C j k * (d₁Inv k * (d₁ k * x k))) =
      d₂Inv j * (∑ k : Fin n, C j k * x k)
    congr 1
    apply Finset.sum_congr rfl
    intro k _
    congr 1
    calc
      d₁Inv k * (d₁ k * x k) = (d₁ k * d₁Inv k) * x k := by ring
      _ = x k := by rw [hd₁ k]; ring
  rw [hinner]
  change d₁ i *
      (∑ j : Fin n, B i j *
        (d₂ j * (d₂Inv j * (∑ k : Fin n, C j k * x k)))) =
    d₁ i * matMulVec n (matMul n B C) x i
  rw [Finset.mul_sum]
  calc
    ∑ j : Fin n, d₁ i * (B i j * (d₂ j *
        (d₂Inv j * ∑ k : Fin n, C j k * x k)
        ))
        = d₁ i * ∑ j : Fin n, B i j * (∑ k : Fin n, C j k * x k) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          calc
            d₁ i * (B i j * (d₂ j *
                (d₂Inv j * ∑ k : Fin n, C j k * x k)
                ))
                = d₁ i * (B i j * ((d₂ j * d₂Inv j) *
                    ∑ k : Fin n, C j k * x k)) := by ring
            _ = d₁ i * (B i j * ∑ k : Fin n, C j k * x k) := by
                  rw [hd₂ j]
                  ring
    _ = d₁ i * matMulVec n B (matMulVec n C x) i := by
          rfl
    _ = d₁ i * matMulVec n (matMul n B C) x i := by
          rw [← matMulVec_matMul n B C x i]

lemma ch7_bauer_scaled_product_subeigenvector {n : ℕ}
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1)
    (hsub : ∀ i : Fin n, ρ * x i ≤ matMulVec n (matMul n B C) x i) :
    ∀ i : Fin n,
      ρ * (d₁ i * x i) ≤
        matMulVec n
          (matMul n (ch7TwoSidedScale d₁ B d₂)
            (ch7TwoSidedScale d₂Inv C d₁Inv))
          (fun i => d₁ i * x i) i := by
  intro i
  have hmul := congrFun
    (ch7_bauer_scaled_product_mulVec_eq B C x d₁ d₁Inv d₂ d₂Inv hd₁ hd₂) i
  calc
    ρ * (d₁ i * x i) = d₁ i * (ρ * x i) := by ring
    _ ≤ d₁ i * matMulVec n (matMul n B C) x i :=
      mul_le_mul_of_nonneg_left (hsub i) (le_of_lt (hd₁pos i))
    _ =
        matMulVec n
          (matMul n (ch7TwoSidedScale d₁ B d₂)
            (ch7TwoSidedScale d₂Inv C d₁Inv))
          (fun i => d₁ i * x i) i := by
      rw [hmul]

/-- Problem 7.10(a), local finite spectral-radius bridge for an arbitrary
positive reciprocal two-sided scaling of the Bauer product.  The scaled product
has the same attained local complex-eigenvalue radius `ρ` as the source
product `BC`, once the positive Perron-vector certificate for `BC` is
supplied.  Perron-Frobenius existence remains a separate source-facing target. -/
theorem problem7_10a_scaled_product_isComplexEigenvalueRadius_of_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n, matMulVec n (matMul n B C) x i = ρ * x i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ch7IsComplexEigenvalueRadius
      (matMul n (ch7TwoSidedScale d₁ B d₂)
        (ch7TwoSidedScale d₂Inv C d₁Inv)) ρ := by
  let M : Fin n → Fin n → ℝ := ch7TwoSidedScale d₁ B d₂
  let N : Fin n → Fin n → ℝ := ch7TwoSidedScale d₂Inv C d₁Inv
  let y : Fin n → ℝ := fun i => d₁ i * x i
  have hM : ∀ i j : Fin n, 0 ≤ M i j :=
    ch7TwoSidedScale_nonneg d₁ B d₂
      (fun i => le_of_lt (hd₁pos i)) hB (fun j => le_of_lt (hd₂pos j))
  have hN : ∀ i j : Fin n, 0 ≤ N i j :=
    ch7TwoSidedScale_nonneg d₂Inv C d₁Inv
      (fun i => le_of_lt (hd₂Invpos i)) hC (fun j => le_of_lt (hd₁Invpos j))
  have hMN_nonneg : ∀ i j : Fin n, 0 ≤ matMul n M N i j := by
    intro i j
    unfold matMul
    exact Finset.sum_nonneg fun k _ => mul_nonneg (hM i k) (hN k j)
  have hy : ∀ i : Fin n, 0 < y i := fun i => mul_pos (hd₁pos i) (hx i)
  have heigMN : ∀ i : Fin n, matMulVec n (matMul n M N) y i = ρ * y i := by
    have h :=
      ch7_bauer_scaled_product_eigenvector B C ρ x d₁ d₁Inv d₂ d₂Inv hd₁ hd₂ heig
    intro i
    simpa [M, N, y] using congrFun h i
  change ch7IsComplexEigenvalueRadius (matMul n M N) ρ
  exact ch7_isComplexEigenvalueRadius_of_positive_real_eigenvector
    hn (matMul n M N) ρ y hMN_nonneg hy heigMN

