noncomputable def ch7RowEquilibratingScale2Rect {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (i : Fin m) : ℝ :=
  1 / ch7RectRowNorm2 A i

lemma ch7RectRowNorm2_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (i : Fin m) :
    0 ≤ ch7RectRowNorm2 A i :=
  vecNorm2_nonneg _

/-- Full-row-rank side condition for the `p = 2` row route in Theorem 7.5,
stated with an explicit rectangular right inverse. -/
lemma ch7RectRowNorm2_pos_of_rect_right_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hright : ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0)
    (i : Fin m) :
    0 < ch7RectRowNorm2 A i := by
  have hne : ch7RectRowNorm2 A i ≠ 0 := by
    intro hzero
    have hentries : ∀ k : Fin n, A i k = 0 :=
      (vecNorm2_eq_zero_iff (fun k : Fin n => A i k)).mp hzero
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hright i i
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectRowNorm2_nonneg A i) (Ne.symm hne)

lemma ch7RectColumnNorm2_finiteTranspose_eq_rowNorm2 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (i : Fin m) :
    ch7RectColumnNorm2 (finiteTranspose A) i = ch7RectRowNorm2 A i := by
  rfl

/-- A real rectangular row norm is bounded by the complex Euclidean
operator-2 norm of the complexified matrix. -/
theorem ch7RectRowNorm2_le_complexMatrixOp2_realRectToCMatrix {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (i : Fin m) :
    ch7RectRowNorm2 A i ≤ complexMatrixOp2 (realRectToCMatrix A) := by
  have hrect : rectOpNorm2Le A (complexMatrixOp2 (realRectToCMatrix A)) :=
    rectOpNorm2Le_of_complexMatrixOp2_realRectToCMatrix_le A le_rfl
  have hnonneg : 0 ≤ complexMatrixOp2 (realRectToCMatrix A) :=
    complexMatrixOp2_nonneg _
  have htrans := rectOpNorm2Le_finiteTranspose_of_rectOpNorm2Le A hnonneg hrect
  have hcol := eq_7_20_column_norm_le_of_rectOpNorm2Le (finiteTranspose A) htrans i
  simpa [ch7RectColumnNorm2_finiteTranspose_eq_rowNorm2] using hcol

/-- Strictly positive rectangular row norms give a strictly positive lower
bound for the average-normalized row factors. -/
lemma ch7_exists_pos_le_all_inv_card_mul_row_norm2 {m n : ℕ}
    (hm : 0 < m) (A : Fin m → Fin n → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm2 A i) :
    ∃ c : ℝ, 0 < c ∧
      ∀ i : Fin m, c ≤ (m : ℝ)⁻¹ * ch7RectRowNorm2 A i := by
  apply ch7_exists_pos_le_all_fin hm
  intro i
  exact mul_pos (inv_pos.mpr (Nat.cast_pos.mpr hm)) (hrow i)

lemma ch7RectRowNorm2_leftScale_eq {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin m → ℝ) (i : Fin m) :
    ch7RectRowNorm2 (ch7RectLeftScale d A) i =
      |d i| * ch7RectRowNorm2 A i := by
  unfold ch7RectRowNorm2 ch7RectLeftScale
  rw [vecNorm2_smul]

/-- Lower bound for the operator-2 norm of a left-scaled real matrix by any
scaled row norm. -/
theorem ch7RectLeftScale_row_norm_le_complexMatrixOp2 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin m → ℝ) (i : Fin m) :
    |d i| * ch7RectRowNorm2 A i ≤
      complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale d A)) := by
  have h := ch7RectRowNorm2_le_complexMatrixOp2_realRectToCMatrix
    (ch7RectLeftScale d A) i
  simpa [ch7RectRowNorm2_leftScale_eq] using h

/-- Pointwise lower bound for the reciprocal right-scaling condition product.
It combines a scaled column lower bound for `AD` with a scaled row lower bound
for `D⁻¹A⁺`, and is the local coercivity estimate used near the boundary of
the normalized diagonal slice. -/
theorem ch7Op2RightScaledCond_reciprocal_lower_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin n → ℝ) (j k : Fin n) :
    (|d k| * ch7RectColumnNorm2 A k) *
      (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) ≤
        ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹) := by
  have hAD := ch7RectRightScale_column_norm_le_complexMatrixOp2 A d k
  have hAplus := ch7RectLeftScale_row_norm_le_complexMatrixOp2
    Aplus (fun j : Fin n => (d j)⁻¹) j
  unfold ch7Op2RightScaledCond
  exact mul_le_mul hAD hAplus
    (mul_nonneg (abs_nonneg _) (ch7RectRowNorm2_nonneg Aplus j))
    (complexMatrixOp2_nonneg _)

/-- Boundary-facing lower bound for normalized reciprocal right scalings: for
each reciprocal coordinate `j`, some normalized scaling coordinate contributes
at least the average-magnitude column factor. -/
theorem ch7Op2RightScaledCond_reciprocal_normalized_lower_exists {m n : ℕ}
    (hn : 0 < n) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin n → ℝ) (hsum : (∑ j : Fin n, |d j|) = 1) (j : Fin n) :
    ∃ k : Fin n,
      ((n : ℝ)⁻¹ * ch7RectColumnNorm2 A k) *
        (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) ≤
          ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹) := by
  rcases ch7_exists_inv_card_le_abs_of_sum_abs_eq_one hn d hsum with ⟨k, hk⟩
  refine ⟨k, ?_⟩
  have hcol :
      (n : ℝ)⁻¹ * ch7RectColumnNorm2 A k ≤
        |d k| * ch7RectColumnNorm2 A k :=
    mul_le_mul_of_nonneg_right hk (ch7RectColumnNorm2_nonneg A k)
  have hright_nonneg :
      0 ≤ |(d j)⁻¹| * ch7RectRowNorm2 Aplus j :=
    mul_nonneg (abs_nonneg _) (ch7RectRowNorm2_nonneg Aplus j)
  exact (mul_le_mul_of_nonneg_right hcol hright_nonneg).trans
    (ch7Op2RightScaledCond_reciprocal_lower_bound A Aplus d j k)

/-- A bounded normalized reciprocal right-scaling condition product bounds each
inverse diagonal coordinate away from infinity.  This is the sublevel
coercivity estimate needed before extracting a compact minimizer sublevel. -/
theorem ch7Op2RightScaledCond_reciprocal_normalized_inv_abs_le_of_le {m n : ℕ}
    (hn : 0 < n) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnNorm2 A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j)
    (d : Fin n → ℝ) (hsum : (∑ j : Fin n, |d j|) = 1)
    {K : ℝ} (hK :
      ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹) ≤ K)
    (j : Fin n) :
    ∃ c : ℝ, 0 < c ∧
      |(d j)⁻¹| ≤ K / (c * ch7RectRowNorm2 Aplus j) := by
  rcases ch7_exists_pos_le_all_inv_card_mul_column_norm2 hn A hcol with
    ⟨c, hc, hcA⟩
  rcases ch7Op2RightScaledCond_reciprocal_normalized_lower_exists
      hn A Aplus d hsum j with ⟨k, hkprod⟩
  have hright_nonneg : 0 ≤ |(d j)⁻¹| * ch7RectRowNorm2 Aplus j :=
    mul_nonneg (abs_nonneg _) (le_of_lt (hrowAplus j))
  have hck :
      c * (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) ≤
        ((n : ℝ)⁻¹ * ch7RectColumnNorm2 A k) *
          (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) :=
    mul_le_mul_of_nonneg_right (hcA k) hright_nonneg
  have hleK :
      c * (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) ≤ K :=
    hck.trans (hkprod.trans hK)
  have hden : 0 < c * ch7RectRowNorm2 Aplus j :=
    mul_pos hc (hrowAplus j)
  refine ⟨c, hc, ?_⟩
  exact (le_div_iff₀ hden).2 (by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hleK)

/-- Fixed-constant form of
`ch7Op2RightScaledCond_reciprocal_normalized_inv_abs_le_of_le`.  The constant
`c` is chosen once from the strictly positive column norms of `A`, so all
coordinates in a bounded reciprocal sublevel share the same compact-core lower
bound. -/
theorem ch7Op2RightScaledCond_reciprocal_normalized_inv_abs_le_of_le_of_const
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {c : ℝ} (hc : 0 < c)
    (hcA : ∀ k : Fin n, c ≤ (n : ℝ)⁻¹ * ch7RectColumnNorm2 A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j)
    (d : Fin n → ℝ) (hsum : (∑ j : Fin n, |d j|) = 1)
    {K : ℝ} (hK :
      ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹) ≤ K)
    (j : Fin n) :
    |(d j)⁻¹| ≤ K / (c * ch7RectRowNorm2 Aplus j) := by
  rcases ch7Op2RightScaledCond_reciprocal_normalized_lower_exists
      hn A Aplus d hsum j with ⟨k, hkprod⟩
  have hright_nonneg : 0 ≤ |(d j)⁻¹| * ch7RectRowNorm2 Aplus j :=
    mul_nonneg (abs_nonneg _) (le_of_lt (hrowAplus j))
  have hck :
      c * (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) ≤
        ((n : ℝ)⁻¹ * ch7RectColumnNorm2 A k) *
          (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) :=
    mul_le_mul_of_nonneg_right (hcA k) hright_nonneg
  have hleK :
      c * (|(d j)⁻¹| * ch7RectRowNorm2 Aplus j) ≤ K :=
    hck.trans (hkprod.trans hK)
  have hden : 0 < c * ch7RectRowNorm2 Aplus j :=
    mul_pos hc (hrowAplus j)
  exact (le_div_iff₀ hden).2 (by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hleK)

lemma ch7_abs_le_one_of_sum_abs_eq_one {n : ℕ}
    (d : Fin n → ℝ) (hsum : (∑ j : Fin n, |d j|) = 1)
    (j : Fin n) :
    |d j| ≤ 1 := by
  have hle : |d j| ≤ ∑ k : Fin n, |d k| :=
    Finset.single_le_sum (fun k _ => abs_nonneg (d k)) (Finset.mem_univ j)
  simpa [hsum] using hle

/-- Compact core for the normalized reciprocal right-scaling slice.  It is the
absolute-sum-one simplex with every coordinate bounded away from zero by the
coercivity constant attached to a fixed sublevel. -/
noncomputable def ch7Op2RightScaledCondReciprocalCompactCore {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) : Set (Fin n → ℝ) :=
  {d : Fin n → ℝ |
    (∑ j : Fin n, |d j|) = 1 ∧
    ∀ j : Fin n,
      (K / (c * ch7RectRowNorm2 Aplus j))⁻¹ ≤ |d j|}

/-- Bounded reciprocal sublevel inside the compact core used for minimizer
extraction in the non-endpoint `p = 2` column route of Theorem 7.5. -/
noncomputable def ch7Op2RightScaledCondReciprocalCompactSublevel {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (K c : ℝ) : Set (Fin n → ℝ) :=
  ch7Op2RightScaledCondReciprocalCompactCore Aplus K c ∩
    {d : Fin n → ℝ |
      ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹) ≤ K}

theorem isClosed_ch7Op2RightScaledCondReciprocalCompactCore {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsClosed (ch7Op2RightScaledCondReciprocalCompactCore Aplus K c) := by
  have hsum_cont : Continuous fun d : Fin n → ℝ => ∑ j : Fin n, |d j| := by
    simpa using
      continuous_finset_sum (s := Finset.univ)
        (fun j _ => (continuous_apply j).abs)
  have hsum_closed :
      IsClosed {d : Fin n → ℝ | (∑ j : Fin n, |d j|) = 1} :=
    isClosed_eq hsum_cont continuous_const
  have hlower_closed :
      IsClosed {d : Fin n → ℝ |
        ∀ j : Fin n,
          (K / (c * ch7RectRowNorm2 Aplus j))⁻¹ ≤ |d j|} := by
    rw [show
      {d : Fin n → ℝ |
        ∀ j : Fin n,
          (K / (c * ch7RectRowNorm2 Aplus j))⁻¹ ≤ |d j|} =
        ⋂ j : Fin n,
          {d : Fin n → ℝ |
            (K / (c * ch7RectRowNorm2 Aplus j))⁻¹ ≤ |d j|} by
        ext d
        simp]
    exact isClosed_iInter (fun j : Fin n =>
      isClosed_le
        (continuous_const :
          Continuous fun _d : Fin n → ℝ =>
            (K / (c * ch7RectRowNorm2 Aplus j))⁻¹)
        ((continuous_apply j : Continuous fun d : Fin n → ℝ => d j).abs))
  simpa [ch7Op2RightScaledCondReciprocalCompactCore] using
    hsum_closed.inter hlower_closed

theorem ch7Op2RightScaledCondReciprocalCompactCore_subset_Icc {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    ch7Op2RightScaledCondReciprocalCompactCore Aplus K c ⊆
      Set.Icc (fun _ : Fin n => (-1 : ℝ)) (fun _ : Fin n => (1 : ℝ)) := by
  intro d hd
  have habs : ∀ j : Fin n, |d j| ≤ 1 := by
    intro j
    exact ch7_abs_le_one_of_sum_abs_eq_one d hd.1 j
  constructor
  · intro j
    exact (abs_le.mp (habs j)).1
  · intro j
    exact (abs_le.mp (habs j)).2

theorem isCompact_ch7Op2RightScaledCondReciprocalCompactCore {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsCompact (ch7Op2RightScaledCondReciprocalCompactCore Aplus K c) := by
  exact IsCompact.of_isClosed_subset isCompact_Icc
    (isClosed_ch7Op2RightScaledCondReciprocalCompactCore Aplus K c)
    (ch7Op2RightScaledCondReciprocalCompactCore_subset_Icc Aplus K c)

lemma ch7Op2RightScaledCondReciprocalCompactCore_ne_zero {m n : ℕ}
    {Aplus : Fin n → Fin m → ℝ} {K c : ℝ}
    (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j)
    {d : Fin n → ℝ}
    (hd : d ∈ ch7Op2RightScaledCondReciprocalCompactCore Aplus K c)
    (j : Fin n) :
    d j ≠ 0 := by
  have hden : 0 < c * ch7RectRowNorm2 Aplus j :=
    mul_pos hc (hrowAplus j)
  have hquot : 0 < K / (c * ch7RectRowNorm2 Aplus j) :=
    div_pos hK hden
  have hlower_pos :
      0 < (K / (c * ch7RectRowNorm2 Aplus j))⁻¹ :=
    inv_pos.mpr hquot
  have h_abs_pos : 0 < |d j| := lt_of_lt_of_le hlower_pos (hd.2 j)
  exact abs_pos.mp h_abs_pos

theorem continuousOn_ch7Op2RightScaledCond_reciprocal_compactCore {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j) :
    ContinuousOn (fun d : Fin n → ℝ =>
      ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹))
      (ch7Op2RightScaledCondReciprocalCompactCore Aplus K c) := by
  exact continuousOn_ch7Op2RightScaledCond_reciprocal A Aplus
    (ch7Op2RightScaledCondReciprocalCompactCore Aplus K c)
    (fun d hd j =>
      ch7Op2RightScaledCondReciprocalCompactCore_ne_zero
        hK hc hrowAplus hd j)

theorem isClosed_ch7Op2RightScaledCondReciprocalCompactSublevel {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j) :
    IsClosed (ch7Op2RightScaledCondReciprocalCompactSublevel A Aplus K c) := by
  let core : Set (Fin n → ℝ) :=
    ch7Op2RightScaledCondReciprocalCompactCore Aplus K c
  let f : (Fin n → ℝ) → ℝ := fun d =>
    ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹)
  have hcore_closed : IsClosed core := by
    dsimp [core]
    exact isClosed_ch7Op2RightScaledCondReciprocalCompactCore Aplus K c
  have hf : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7Op2RightScaledCond_reciprocal_compactCore
      A Aplus hK hc hrowAplus
  have hpre : IsClosed (core ∩ f ⁻¹' Set.Iic K) :=
    ContinuousOn.preimage_isClosed_of_isClosed hf hcore_closed isClosed_Iic
  simpa [ch7Op2RightScaledCondReciprocalCompactSublevel, core, f, Set.Iic]
    using hpre

theorem isCompact_ch7Op2RightScaledCondReciprocalCompactSublevel {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j) :
    IsCompact (ch7Op2RightScaledCondReciprocalCompactSublevel A Aplus K c) := by
  exact IsCompact.of_isClosed_subset
    (isCompact_ch7Op2RightScaledCondReciprocalCompactCore Aplus K c)
    (isClosed_ch7Op2RightScaledCondReciprocalCompactSublevel
      A Aplus hK hc hrowAplus)
    (by
      intro d hd
      exact hd.1)

/-- The normalized reciprocal right-scaling operator-2 value set attains a
least value once both the source columns of `A` and the inverse-side rows of
`Aplus` are nonzero.  This is the compact-sublevel minimizer extraction needed
to replace the source-facing `min` certificate in the `p = 2` column route of
Theorem 7.5. -/
theorem ch7Op2RightScaledCondReciprocalNormalizedSet_exists_isLeast {m n : ℕ}
    (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnNorm2 A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j) :
    ∃ μ : ℝ, IsLeast
      (ch7Op2RightScaledCondReciprocalNormalizedSet A Aplus) μ := by
  let d0 : Fin n → ℝ := fun _ => (n : ℝ)⁻¹
  let f : (Fin n → ℝ) → ℝ := fun d =>
    ch7Op2RightScaledCond A Aplus d (fun j : Fin n => (d j)⁻¹)
  let K : ℝ := f d0
  have hnR : 0 < (n : ℝ) := by exact_mod_cast hn
  have hn_ne : (n : ℝ) ≠ 0 := ne_of_gt hnR
  have hd0_pos : ∀ j : Fin n, 0 < d0 j := by
    intro j
    exact inv_pos.mpr hnR
  have hd0_ne : ∀ j : Fin n, d0 j ≠ 0 := fun j => ne_of_gt (hd0_pos j)
  have hd0_sum : (∑ j : Fin n, |d0 j|) = 1 := by
    calc
      (∑ j : Fin n, |d0 j|)
          = ∑ _j : Fin n, (n : ℝ)⁻¹ := by
            apply Finset.sum_congr rfl
            intro j _
            exact abs_of_pos (hd0_pos j)
      _ = (n : ℝ) * (n : ℝ)⁻¹ := by
            simp [Finset.sum_const, nsmul_eq_mul]
      _ = 1 := mul_inv_cancel₀ hn_ne
  have hKpos : 0 < K := by
    let j0 : Fin n := ⟨0, hn⟩
    rcases ch7Op2RightScaledCond_reciprocal_normalized_lower_exists
        hn A Aplus d0 hd0_sum j0 with ⟨k, hkprod⟩
    have hleft_pos : 0 < (n : ℝ)⁻¹ * ch7RectColumnNorm2 A k :=
      mul_pos (inv_pos.mpr hnR) (hcol k)
    have hright_pos :
        0 < |(d0 j0)⁻¹| * ch7RectRowNorm2 Aplus j0 := by
      exact mul_pos (abs_pos.mpr (inv_ne_zero (hd0_ne j0))) (hrowAplus j0)
    exact lt_of_lt_of_le (mul_pos hleft_pos hright_pos) hkprod
  rcases ch7_exists_pos_le_all_inv_card_mul_column_norm2 hn A hcol with
    ⟨c, hc, hcA⟩
  let core : Set (Fin n → ℝ) :=
    ch7Op2RightScaledCondReciprocalCompactCore Aplus K c
  let S : Set (Fin n → ℝ) :=
    ch7Op2RightScaledCondReciprocalCompactSublevel A Aplus K c
  have hd0_core : d0 ∈ core := by
    refine ⟨hd0_sum, ?_⟩
    intro j
    have hM : 0 < K / (c * ch7RectRowNorm2 Aplus j) :=
      div_pos hKpos (mul_pos hc (hrowAplus j))
    have hinv_le :
        |(d0 j)⁻¹| ≤ K / (c * ch7RectRowNorm2 Aplus j) := by
      dsimp [K, f]
      exact ch7Op2RightScaledCond_reciprocal_normalized_inv_abs_le_of_le_of_const
        hn A Aplus hc hcA hrowAplus d0 hd0_sum le_rfl j
    exact ch7_inv_bound_le_abs_of_inv_abs_le (hd0_ne j) hM hinv_le
  have hd0S : d0 ∈ S := by
    refine ⟨?_, ?_⟩
    · exact hd0_core
    · dsimp [S, K, f, ch7Op2RightScaledCondReciprocalCompactSublevel]
      exact le_rfl
  have hS_nonempty : S.Nonempty := ⟨d0, hd0S⟩
  have hScompact : IsCompact S := by
    dsimp [S]
    exact isCompact_ch7Op2RightScaledCondReciprocalCompactSublevel
      A Aplus hKpos hc hrowAplus
  have hfcore : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7Op2RightScaledCond_reciprocal_compactCore
      A Aplus hKpos hc hrowAplus
  have hfS : ContinuousOn f S := by
    exact hfcore.mono (by
      intro d hd
      exact hd.1)
  rcases hScompact.exists_isMinOn hS_nonempty hfS with
    ⟨dmin, hdminS, hminS⟩
  refine ⟨f dmin, ?_⟩
  constructor
  · refine ⟨dmin, ?_, ?_, rfl⟩
    · intro j
      exact ch7Op2RightScaledCondReciprocalCompactCore_ne_zero
        hKpos hc hrowAplus hdminS.1 j
    · exact hdminS.1.1
  · intro μ hμ
    rcases hμ with ⟨d, hdne, hsum, rfl⟩
    rcases le_total (f d) K with hfdK | hKfd
    · have hd_core : d ∈ core := by
        refine ⟨hsum, ?_⟩
        intro j
        have hM : 0 < K / (c * ch7RectRowNorm2 Aplus j) :=
          div_pos hKpos (mul_pos hc (hrowAplus j))
        have hinv_le :
            |(d j)⁻¹| ≤ K / (c * ch7RectRowNorm2 Aplus j) := by
          dsimp [K, f] at hfdK
          exact
            ch7Op2RightScaledCond_reciprocal_normalized_inv_abs_le_of_le_of_const
              hn A Aplus hc hcA hrowAplus d hsum hfdK j
        exact ch7_inv_bound_le_abs_of_inv_abs_le (hdne j) hM hinv_le
      have hdS : d ∈ S := ⟨hd_core, hfdK⟩
      exact hminS hdS
    · exact hdminS.2.trans hKfd

theorem ch7Op2RightScaledCondNormalizedSet_exists_isLeast {m n : ℕ}
    (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnNorm2 A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j) :
    ∃ μ : ℝ, IsLeast (ch7Op2RightScaledCondNormalizedSet A Aplus) μ := by
  rcases ch7Op2RightScaledCondReciprocalNormalizedSet_exists_isLeast
      hn A Aplus hcol hrowAplus with ⟨μ, hμ⟩
  exact ⟨μ,
    (ch7Op2RightScaledCondNormalizedSet_isLeast_iff_reciprocal_normalized
      A Aplus).mpr hμ⟩

theorem ch7Op2RightScaledCondSet_exists_isLeast {m n : ℕ}
    (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnNorm2 A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j) :
    ∃ μ : ℝ, IsLeast (ch7Op2RightScaledCondSet A Aplus) μ := by
  rcases ch7Op2RightScaledCondNormalizedSet_exists_isLeast
      hn A Aplus hcol hrowAplus with ⟨μ, hμ⟩
  exact ⟨μ,
    (ch7Op2RightScaledCondSet_isLeast_iff_sum_abs_normalized
      hn A Aplus).mpr hμ⟩

/-- If `Aplus` is a rectangular left inverse of `A`, every row of `Aplus`
that participates in the inverse-side `D⁻¹A⁺` factor is nonzero. -/
lemma ch7RectRowNorm2_Aplus_pos_of_rect_left_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0)
    (j : Fin n) :
    0 < ch7RectRowNorm2 Aplus j := by
  have hne : ch7RectRowNorm2 Aplus j ≠ 0 := by
    intro hzero
    have hentries : ∀ k : Fin m, Aplus j k = 0 :=
      (vecNorm2_eq_zero_iff (fun k : Fin m => Aplus j k)).mp hzero
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hleft j j
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectRowNorm2_nonneg Aplus j) (Ne.symm hne)

/-- Theorem 7.5, `p = 2` column route with the source minimum value now
extracted from the compact normalized reciprocal sublevel, under an explicit
rectangular left-inverse side condition. -/
theorem theorem7_5_p2_column_equilibration_exists_min_right_scalings_of_rect_left_inverse
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) :
    ∃ μ : ℝ,
      IsLeast (ch7Op2RightScaledCondSet A Aplus) μ ∧
      ch7Op2RightScaledCond A Aplus
          (ch7ColumnEquilibratingScale2 A)
          (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
        Real.sqrt (n : ℝ) * μ := by
  have hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j :=
    ch7RectColumnNorm2_pos_of_rect_left_inverse A Aplus hleft
  have hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j :=
    ch7RectRowNorm2_Aplus_pos_of_rect_left_inverse A Aplus hleft
  rcases ch7Op2RightScaledCondSet_exists_isLeast
      hn A Aplus hcol hrowAplus with ⟨μ, hmin⟩
  exact ⟨μ, hmin,
    theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings_of_rect_left_inverse
      hn A Aplus hleft hmin⟩

/-- Normalized-slice version of the compactness-backed Theorem 7.5 `p = 2`
column minimum wrapper under an explicit rectangular left inverse. -/
theorem theorem7_5_p2_column_equilibration_exists_min_right_scalings_of_rect_left_inverse_of_normalized
    {m n : ℕ} (hn : 0 < n)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) :
    ∃ μ : ℝ,
      IsLeast (ch7Op2RightScaledCondNormalizedSet A Aplus) μ ∧
      ch7Op2RightScaledCond A Aplus
          (ch7ColumnEquilibratingScale2 A)
          (fun j : Fin n => ch7RectColumnNorm2 A j) ≤
        Real.sqrt (n : ℝ) * μ := by
  have hcol : ∀ j : Fin n, 0 < ch7RectColumnNorm2 A j :=
    ch7RectColumnNorm2_pos_of_rect_left_inverse A Aplus hleft
  have hrowAplus : ∀ j : Fin n, 0 < ch7RectRowNorm2 Aplus j :=
    ch7RectRowNorm2_Aplus_pos_of_rect_left_inverse A Aplus hleft
  rcases ch7Op2RightScaledCondNormalizedSet_exists_isLeast
      hn A Aplus hcol hrowAplus with ⟨μ, hmin⟩
  exact ⟨μ, hmin,
    theorem7_5_p2_column_equilibration_le_sqrt_card_min_right_scalings_of_rect_left_inverse_of_normalized
      hn A Aplus hleft hmin⟩

lemma ch7RectColumnNorm2_finiteTranspose_leftScale_eq {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin m → ℝ) (i : Fin m) :
    ch7RectColumnNorm2 (finiteTranspose (ch7RectLeftScale d A)) i =
      |d i| * ch7RectRowNorm2 A i := by
  rw [ch7RectColumnNorm2_finiteTranspose_eq_rowNorm2,
    ch7RectRowNorm2_leftScale_eq]

lemma ch7RectRowNorm2_leftScale_equilibrating {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm2 A i) (i : Fin m) :
    ch7RectRowNorm2
        (ch7RectLeftScale (ch7RowEquilibratingScale2Rect A) A) i = 1 := by
  rw [ch7RectRowNorm2_leftScale_eq]
  unfold ch7RowEquilibratingScale2Rect
  rw [abs_of_pos (one_div_pos.mpr (hrow i))]
  field_simp [ne_of_gt (hrow i)]

/-- Frobenius/cardinality upper side for Euclidean row bounds.  If every row
has Euclidean norm at most `B`, then `‖A‖_F ≤ sqrt(m) B`. -/
theorem ch7_frobNormRect_le_sqrt_card_mul_row_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) {B : ℝ}
    (hB_nonneg : 0 ≤ B) (hB : ∀ i : Fin m, ch7RectRowNorm2 A i ≤ B) :
    frobNormRect A ≤ Real.sqrt (m : ℝ) * B := by
  have hsq_row : ∀ i : Fin m, (∑ j : Fin n, A i j ^ 2) ≤ B ^ 2 := by
    intro i
    have hnorm_sq :
        ch7RectRowNorm2 A i ^ 2 ≤ B ^ 2 := by
      have habs : |ch7RectRowNorm2 A i| ≤ |B| := by
        simpa [abs_of_nonneg (ch7RectRowNorm2_nonneg A i),
          abs_of_nonneg hB_nonneg] using hB i
      exact (sq_le_sq).mpr habs
    simpa [ch7RectRowNorm2, vecNorm2_sq, vecNorm2Sq] using hnorm_sq
  have hsq :
      frobNormSqRect A ≤ (m : ℝ) * B ^ 2 := by
    unfold frobNormSqRect
    calc
      (∑ i : Fin m, ∑ j : Fin n, A i j ^ 2)
          ≤ ∑ _i : Fin m, B ^ 2 := by
            exact Finset.sum_le_sum fun i _ => hsq_row i
      _ = (m : ℝ) * B ^ 2 := by
            simp [Finset.sum_const, Fintype.card_fin, nsmul_eq_mul]
  calc
    frobNormRect A = Real.sqrt (frobNormSqRect A) := rfl
    _ ≤ Real.sqrt ((m : ℝ) * B ^ 2) := Real.sqrt_le_sqrt hsq
    _ = Real.sqrt (m : ℝ) * B := by
          rw [Real.sqrt_mul (Nat.cast_nonneg m), Real.sqrt_sq_eq_abs,
            abs_of_nonneg hB_nonneg]

/-- Equation `(7.19)`, `p = 2` first-factor operator-certificate form:
after scaling every nonzero row of `A` to Euclidean norm one, the rectangular
operator-2 bound is at most `sqrt(m)`. -/
theorem eq_7_19_rectOpNorm2Le_row_equilibrated {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm2 A i) :
    rectOpNorm2Le (ch7RectLeftScale (ch7RowEquilibratingScale2Rect A) A)
      (Real.sqrt (m : ℝ)) := by
  have hB :
      ∀ i : Fin m,
        ch7RectRowNorm2
          (ch7RectLeftScale (ch7RowEquilibratingScale2Rect A) A) i ≤ 1 := by
    intro i
    rw [ch7RectRowNorm2_leftScale_equilibrating A hrow i]
  simpa [mul_one] using
    rectOpNorm2Le_of_frobNormRect_le
      (ch7RectLeftScale (ch7RowEquilibratingScale2Rect A) A)
      (ch7_frobNormRect_le_sqrt_card_mul_row_bound
        (ch7RectLeftScale (ch7RowEquilibratingScale2Rect A) A)
        (by norm_num : 0 ≤ (1 : ℝ)) hB)

/-- Euclidean operator-2 condition product for the left-scaled rectangular
matrix and the corresponding inverse-side factor.  In the source this is
`‖DA‖₂ ‖A⁺D⁻¹‖₂`; `Aplus` remains explicit so no Moore-Penrose construction is
asserted. -/
noncomputable def ch7Op2LeftScaledCond {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) : ℝ :=
  complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale d A)) *
    complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale Aplus dInv))

/-- Values of the explicit Euclidean operator-2 condition product
`‖DA‖₂ ‖A⁺D⁻¹‖₂` over reciprocal nonsingular diagonal left scalings. -/
noncomputable def ch7Op2LeftScaledCondSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin m → ℝ,
    (∀ i : Fin m, d i * dInv i = 1) ∧
    κ = ch7Op2LeftScaledCond A Aplus d dInv}

/-- Absolute-sum-one slice of the explicit Euclidean left-scaling value set. -/
noncomputable def ch7Op2LeftScaledCondNormalizedSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin m → ℝ,
    (∀ i : Fin m, d i * dInv i = 1) ∧
    (∑ i : Fin m, |d i|) = 1 ∧
    κ = ch7Op2LeftScaledCond A Aplus d dInv}

/-- Equivalent one-diagonal model of the normalized left-scaling value set. -/
noncomputable def ch7Op2LeftScaledCondReciprocalNormalizedSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d : Fin m → ℝ,
    (∀ i : Fin m, d i ≠ 0) ∧
    (∑ i : Fin m, |d i|) = 1 ∧
    κ = ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹)}

theorem ch7Op2LeftScaledCond_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) :
    0 ≤ ch7Op2LeftScaledCond A Aplus d dInv := by
  unfold ch7Op2LeftScaledCond
  exact mul_nonneg (complexMatrixOp2_nonneg _) (complexMatrixOp2_nonneg _)

/-- The operator-2 left-scaling value set is nonempty: the identity scaling is
admissible. -/
theorem ch7Op2LeftScaledCondSet_nonempty {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    (ch7Op2LeftScaledCondSet A Aplus).Nonempty := by
  refine ⟨ch7Op2LeftScaledCond A Aplus (fun _ => 1) (fun _ => 1), ?_⟩
  exact ⟨fun _ => 1, fun _ => 1, (by intro i; norm_num), rfl⟩

/-- Membership helper for the operator-2 left-scaling value set. -/
theorem ch7Op2LeftScaledCond_mem_set {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    ch7Op2LeftScaledCond A Aplus d dInv ∈
      ch7Op2LeftScaledCondSet A Aplus := by
  exact ⟨d, dInv, hdiag, rfl⟩

/-- The Euclidean left-scaling condition product is invariant under a global
rescaling of the row diagonal factor and the reciprocal inverse rescaling. -/
theorem ch7Op2LeftScaledCond_global_scale {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) {t : ℝ} (ht : t ≠ 0) :
    ch7Op2LeftScaledCond A Aplus (fun i : Fin m => t * d i)
        (fun i : Fin m => t⁻¹ * dInv i) =
      ch7Op2LeftScaledCond A Aplus d dInv := by
  have hleft :
      realRectToCMatrix
          (ch7RectLeftScale (fun i : Fin m => t * d i) A) =
        ((t : ℂ) • realRectToCMatrix (ch7RectLeftScale d A) :
          Matrix (Fin m) (Fin n) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectLeftScale]
    ring
  have hright :
      realRectToCMatrix
          (ch7RectRightScale Aplus (fun i : Fin m => t⁻¹ * dInv i)) =
        (((t : ℂ)⁻¹) • realRectToCMatrix (ch7RectRightScale Aplus dInv) :
          Matrix (Fin n) (Fin m) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectRightScale]
    ring
  have htC : (t : ℂ) ≠ 0 := by
    exact_mod_cast ht
  have hunit : ‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖ = 1 := by
    rw [norm_inv]
    exact mul_inv_cancel₀ (norm_ne_zero_iff.mpr htC)
  dsimp [ch7Op2LeftScaledCond]
  rw [hleft, hright, complexMatrixOp2_smul, complexMatrixOp2_smul]
  let B : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale d A))
  let C : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale Aplus dInv))
  change (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C) = B * C
  calc
    (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C)
        = (‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖) * (B * C) := by ring
    _ = B * C := by rw [hunit]; ring

/-- A globally rescaled reciprocal row diagonal pair gives an equivalent
witness for the Euclidean left-scaling condition value set. -/
theorem ch7Op2LeftScaledCond_mem_set_global_scale {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) {t : ℝ}
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) (ht : t ≠ 0) :
    ch7Op2LeftScaledCond A Aplus d dInv ∈
      ch7Op2LeftScaledCondSet A Aplus := by
  refine ⟨fun i : Fin m => t * d i, fun i : Fin m => t⁻¹ * dInv i, ?_, ?_⟩
  · intro i
    calc
      (t * d i) * (t⁻¹ * dInv i)
          = (t * t⁻¹) * (d i * dInv i) := by ring
      _ = 1 := by rw [mul_inv_cancel₀ ht, hdiag i]; ring
  · exact (ch7Op2LeftScaledCond_global_scale A Aplus d dInv ht).symm

/-- Normalize a reciprocal left diagonal pair to the absolute-sum-one slice
without changing the Euclidean condition product. -/
theorem ch7Op2LeftScaledCond_sum_abs_normalized_witness {m n : ℕ}
    (hm : 0 < m) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    let s : ℝ := ∑ i : Fin m, |d i|
    (∀ i : Fin m, (s⁻¹ * d i) * (s * dInv i) = 1) ∧
      ch7Op2LeftScaledCond A Aplus (fun i : Fin m => s⁻¹ * d i)
          (fun i : Fin m => s * dInv i) =
        ch7Op2LeftScaledCond A Aplus d dInv ∧
      (∑ i : Fin m, |s⁻¹ * d i|) = 1 := by
  intro s
  have hspos : 0 < s := by
    simpa [s] using ch7_sum_abs_pos_of_reciprocal hm d dInv hdiag
  have hsne : s ≠ 0 := ne_of_gt hspos
  refine ⟨?_, ?_, ?_⟩
  · intro i
    calc
      (s⁻¹ * d i) * (s * dInv i)
          = (s⁻¹ * s) * (d i * dInv i) := by ring
      _ = 1 := by rw [inv_mul_cancel₀ hsne, hdiag i]; ring
  · simpa [inv_inv] using
      (ch7Op2LeftScaledCond_global_scale A Aplus d dInv (t := s⁻¹)
        (inv_ne_zero hsne))
  · calc
      (∑ i : Fin m, |s⁻¹ * d i|)
          = ∑ i : Fin m, |s⁻¹| * |d i| := by
            apply Finset.sum_congr rfl
            intro i _
            rw [abs_mul]
      _ = |s⁻¹| * ∑ i : Fin m, |d i| := by
            rw [Finset.mul_sum]
      _ = s⁻¹ * s := by
            rw [abs_of_nonneg (inv_nonneg.mpr hspos.le)]
      _ = 1 := inv_mul_cancel₀ hsne

/-- On a nonempty left-scaling index type, the explicit p=2 reciprocal value
set is exactly its absolute-sum-one normalized slice. -/
theorem ch7Op2LeftScaledCondSet_eq_sum_abs_normalized {m n : ℕ}
    (hm : 0 < m) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7Op2LeftScaledCondSet A Aplus =
      ch7Op2LeftScaledCondNormalizedSet A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    rcases ch7Op2LeftScaledCond_sum_abs_normalized_witness
        hm A Aplus d dInv hdiag with
      ⟨hdiagN, hcondN, hsumN⟩
    refine ⟨fun i : Fin m => (∑ k : Fin m, |d k|)⁻¹ * d i,
      fun i : Fin m => (∑ k : Fin m, |d k|) * dInv i, hdiagN, hsumN, ?_⟩
    exact hcondN.symm
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, _hsum, rfl⟩
    exact ch7Op2LeftScaledCond_mem_set A Aplus d dInv hdiag

/-- On a nonempty left-scaling index type, a least value for the unrestricted
explicit p=2 reciprocal value set is exactly a least value for the
absolute-sum-one normalized slice. -/
theorem ch7Op2LeftScaledCondSet_isLeast_iff_sum_abs_normalized {m n : ℕ}
    (hm : 0 < m) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7Op2LeftScaledCondSet A Aplus) μ ↔
      IsLeast (ch7Op2LeftScaledCondNormalizedSet A Aplus) μ := by
  rw [ch7Op2LeftScaledCondSet_eq_sum_abs_normalized hm A Aplus]

/-- The normalized left-scaling value set can be represented using only one
nonzero diagonal; the reciprocal side is then definitionally `(d i)⁻¹`. -/
theorem ch7Op2LeftScaledCondNormalizedSet_eq_reciprocal_normalized {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7Op2LeftScaledCondNormalizedSet A Aplus =
      ch7Op2LeftScaledCondReciprocalNormalizedSet A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, hsum, rfl⟩
    have hdne : ∀ i : Fin m, d i ≠ 0 := by
      intro i
      exact ch7_left_factor_ne_zero_of_mul_eq_one (hdiag i)
    have hdInv : dInv = fun i : Fin m => (d i)⁻¹ := by
      funext i
      exact eq_inv_of_mul_eq_one_right (hdiag i)
    refine ⟨d, hdne, hsum, ?_⟩
    simp [hdInv]
  · intro hκ
    rcases hκ with ⟨d, hdne, hsum, rfl⟩
    refine ⟨d, (fun i : Fin m => (d i)⁻¹), ?_, hsum, rfl⟩
    intro i
    exact mul_inv_cancel₀ (hdne i)

/-- Least-value certificates are unchanged by replacing the explicit inverse
diagonal by the pointwise reciprocal in the normalized left-scaling set. -/
theorem ch7Op2LeftScaledCondNormalizedSet_isLeast_iff_reciprocal_normalized
    {m n : ℕ} (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7Op2LeftScaledCondNormalizedSet A Aplus) μ ↔
      IsLeast (ch7Op2LeftScaledCondReciprocalNormalizedSet A Aplus) μ := by
  rw [ch7Op2LeftScaledCondNormalizedSet_eq_reciprocal_normalized A Aplus]

/-- On any set where the left scaling diagonal stays nonzero coordinatewise,
the reciprocal one-diagonal `p = 2` condition product is continuous. -/
theorem continuousOn_ch7Op2LeftScaledCond_reciprocal {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (s : Set (Fin m → ℝ)) (h0 : ∀ d ∈ s, ∀ i : Fin m, d i ≠ 0) :
    ContinuousOn (fun d : Fin m → ℝ =>
      ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹)) s := by
  have hA : Continuous fun d : Fin m → ℝ =>
      complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale d A)) :=
    (continuous_complexMatrixOp2 (m := m) (n := n)).comp
      (continuous_realRectToCMatrix_ch7RectLeftScale A)
  have hAplusMat : ContinuousOn (fun d : Fin m → ℝ =>
      realRectToCMatrix (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹))) s := by
    rw [continuousOn_pi]
    intro i
    rw [continuousOn_pi]
    intro j
    have hinv : ContinuousOn (fun d : Fin m → ℝ => (d j)⁻¹) s :=
      (continuous_apply j).continuousOn.inv₀ (fun d hd => h0 d hd j)
    have hcoord : ContinuousOn (fun d : Fin m → ℝ => Aplus i j * (d j)⁻¹) s :=
      continuous_const.continuousOn.mul hinv
    simpa [realRectToCMatrix, ch7RectRightScale, Function.comp_def] using
      Complex.continuous_ofReal.comp_continuousOn hcoord
  have hAplus : ContinuousOn (fun d : Fin m → ℝ =>
      complexMatrixOp2
        (realRectToCMatrix (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹)))) s :=
    (continuous_complexMatrixOp2 (m := n) (n := m)).comp_continuousOn hAplusMat
  have hprod : ContinuousOn (fun d : Fin m → ℝ =>
      complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale d A)) *
        complexMatrixOp2
          (realRectToCMatrix (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹)))) s :=
    hA.continuousOn.mul hAplus
  simpa [ch7Op2LeftScaledCond] using hprod

/-- Pointwise lower bound for the reciprocal left-scaling condition product. -/
theorem ch7Op2LeftScaledCond_reciprocal_lower_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin m → ℝ) (i k : Fin m) :
    (|d k| * ch7RectRowNorm2 A k) *
      (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) ≤
        ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹) := by
  have hA := ch7RectLeftScale_row_norm_le_complexMatrixOp2 A d k
  have hAplus := ch7RectRightScale_column_norm_le_complexMatrixOp2
    Aplus (fun i : Fin m => (d i)⁻¹) i
  unfold ch7Op2LeftScaledCond
  exact mul_le_mul hA hAplus
    (mul_nonneg (abs_nonneg _) (ch7RectColumnNorm2_nonneg Aplus i))
    (complexMatrixOp2_nonneg _)

/-- Boundary-facing lower bound for normalized reciprocal left scalings. -/
theorem ch7Op2LeftScaledCond_reciprocal_normalized_lower_exists {m n : ℕ}
    (hm : 0 < m) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin m → ℝ) (hsum : (∑ i : Fin m, |d i|) = 1) (i : Fin m) :
    ∃ k : Fin m,
      ((m : ℝ)⁻¹ * ch7RectRowNorm2 A k) *
        (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) ≤
          ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹) := by
  rcases ch7_exists_inv_card_le_abs_of_sum_abs_eq_one hm d hsum with ⟨k, hk⟩
  refine ⟨k, ?_⟩
  have hrow :
      (m : ℝ)⁻¹ * ch7RectRowNorm2 A k ≤
        |d k| * ch7RectRowNorm2 A k :=
    mul_le_mul_of_nonneg_right hk (ch7RectRowNorm2_nonneg A k)
  have hright_nonneg :
      0 ≤ |(d i)⁻¹| * ch7RectColumnNorm2 Aplus i :=
    mul_nonneg (abs_nonneg _) (ch7RectColumnNorm2_nonneg Aplus i)
  exact (mul_le_mul_of_nonneg_right hrow hright_nonneg).trans
    (ch7Op2LeftScaledCond_reciprocal_lower_bound A Aplus d i k)

/-- A bounded normalized reciprocal left-scaling condition product bounds each
inverse diagonal coordinate away from infinity. -/
theorem ch7Op2LeftScaledCond_reciprocal_normalized_inv_abs_le_of_le {m n : ℕ}
    (hm : 0 < m) (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ k : Fin m, 0 < ch7RectRowNorm2 A k)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i)
    (d : Fin m → ℝ) (hsum : (∑ i : Fin m, |d i|) = 1)
    {K : ℝ} (hK :
      ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹) ≤ K)
    (i : Fin m) :
    ∃ c : ℝ, 0 < c ∧
      |(d i)⁻¹| ≤ K / (c * ch7RectColumnNorm2 Aplus i) := by
  rcases ch7_exists_pos_le_all_inv_card_mul_row_norm2 hm A hrow with
    ⟨c, hc, hcA⟩
  rcases ch7Op2LeftScaledCond_reciprocal_normalized_lower_exists
      hm A Aplus d hsum i with ⟨k, hkprod⟩
  have hright_nonneg : 0 ≤ |(d i)⁻¹| * ch7RectColumnNorm2 Aplus i :=
    mul_nonneg (abs_nonneg _) (le_of_lt (hcolAplus i))
  have hck :
      c * (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) ≤
        ((m : ℝ)⁻¹ * ch7RectRowNorm2 A k) *
          (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) :=
    mul_le_mul_of_nonneg_right (hcA k) hright_nonneg
  have hleK :
      c * (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) ≤ K :=
    hck.trans (hkprod.trans hK)
  have hden : 0 < c * ch7RectColumnNorm2 Aplus i :=
    mul_pos hc (hcolAplus i)
  refine ⟨c, hc, ?_⟩
  exact (le_div_iff₀ hden).2 (by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hleK)

/-- Fixed-constant form of the reciprocal left-scaling coercivity estimate.
The row-side constant `c` is chosen once from the strictly positive row norms
of `A`, so all coordinates in a bounded reciprocal left-scaling sublevel share
one compact-core lower bound. -/
theorem ch7Op2LeftScaledCond_reciprocal_normalized_inv_abs_le_of_le_of_const
    {m n : ℕ} (hm : 0 < m)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {c : ℝ} (hc : 0 < c)
    (hcA : ∀ k : Fin m, c ≤ (m : ℝ)⁻¹ * ch7RectRowNorm2 A k)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i)
    (d : Fin m → ℝ) (hsum : (∑ i : Fin m, |d i|) = 1)
    {K : ℝ} (hK :
      ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹) ≤ K)
    (i : Fin m) :
    |(d i)⁻¹| ≤ K / (c * ch7RectColumnNorm2 Aplus i) := by
  rcases ch7Op2LeftScaledCond_reciprocal_normalized_lower_exists
      hm A Aplus d hsum i with ⟨k, hkprod⟩
  have hright_nonneg : 0 ≤ |(d i)⁻¹| * ch7RectColumnNorm2 Aplus i :=
    mul_nonneg (abs_nonneg _) (le_of_lt (hcolAplus i))
  have hck :
      c * (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) ≤
        ((m : ℝ)⁻¹ * ch7RectRowNorm2 A k) *
          (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) :=
    mul_le_mul_of_nonneg_right (hcA k) hright_nonneg
  have hleK :
      c * (|(d i)⁻¹| * ch7RectColumnNorm2 Aplus i) ≤ K :=
    hck.trans (hkprod.trans hK)
  have hden : 0 < c * ch7RectColumnNorm2 Aplus i :=
    mul_pos hc (hcolAplus i)
  exact (le_div_iff₀ hden).2 (by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hleK)

/-- Compact core for the normalized reciprocal left-scaling slice. -/
noncomputable def ch7Op2LeftScaledCondReciprocalCompactCore {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) : Set (Fin m → ℝ) :=
  {d : Fin m → ℝ |
    (∑ i : Fin m, |d i|) = 1 ∧
    ∀ i : Fin m,
      (K / (c * ch7RectColumnNorm2 Aplus i))⁻¹ ≤ |d i|}

/-- Bounded reciprocal sublevel inside the compact left-scaling core used for
row-side minimizer extraction. -/
noncomputable def ch7Op2LeftScaledCondReciprocalCompactSublevel {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (K c : ℝ) : Set (Fin m → ℝ) :=
  ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c ∩
    {d : Fin m → ℝ |
      ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹) ≤ K}

theorem isClosed_ch7Op2LeftScaledCondReciprocalCompactCore {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsClosed (ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c) := by
  have hsum_cont : Continuous fun d : Fin m → ℝ => ∑ i : Fin m, |d i| := by
    simpa using
      continuous_finset_sum (s := Finset.univ)
        (fun i _ => (continuous_apply i).abs)
  have hsum_closed :
      IsClosed {d : Fin m → ℝ | (∑ i : Fin m, |d i|) = 1} :=
    isClosed_eq hsum_cont continuous_const
  have hlower_closed :
      IsClosed {d : Fin m → ℝ |
        ∀ i : Fin m,
          (K / (c * ch7RectColumnNorm2 Aplus i))⁻¹ ≤ |d i|} := by
    rw [show
      {d : Fin m → ℝ |
        ∀ i : Fin m,
          (K / (c * ch7RectColumnNorm2 Aplus i))⁻¹ ≤ |d i|} =
        ⋂ i : Fin m,
          {d : Fin m → ℝ |
            (K / (c * ch7RectColumnNorm2 Aplus i))⁻¹ ≤ |d i|} by
        ext d
        simp]
    exact isClosed_iInter (fun i : Fin m =>
      isClosed_le
        (continuous_const :
          Continuous fun _d : Fin m → ℝ =>
            (K / (c * ch7RectColumnNorm2 Aplus i))⁻¹)
        ((continuous_apply i : Continuous fun d : Fin m → ℝ => d i).abs))
  simpa [ch7Op2LeftScaledCondReciprocalCompactCore] using
    hsum_closed.inter hlower_closed

theorem ch7Op2LeftScaledCondReciprocalCompactCore_subset_Icc {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c ⊆
      Set.Icc (fun _ : Fin m => (-1 : ℝ)) (fun _ : Fin m => (1 : ℝ)) := by
  intro d hd
  have habs : ∀ i : Fin m, |d i| ≤ 1 := by
    intro i
    exact ch7_abs_le_one_of_sum_abs_eq_one d hd.1 i
  constructor
  · intro i
    exact (abs_le.mp (habs i)).1
  · intro i
    exact (abs_le.mp (habs i)).2

theorem isCompact_ch7Op2LeftScaledCondReciprocalCompactCore {m n : ℕ}
    (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsCompact (ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c) := by
  exact IsCompact.of_isClosed_subset isCompact_Icc
    (isClosed_ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c)
    (ch7Op2LeftScaledCondReciprocalCompactCore_subset_Icc Aplus K c)

lemma ch7Op2LeftScaledCondReciprocalCompactCore_ne_zero {m n : ℕ}
    {Aplus : Fin n → Fin m → ℝ} {K c : ℝ}
    (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i)
    {d : Fin m → ℝ}
    (hd : d ∈ ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c)
    (i : Fin m) :
    d i ≠ 0 := by
  have hden : 0 < c * ch7RectColumnNorm2 Aplus i :=
    mul_pos hc (hcolAplus i)
  have hquot : 0 < K / (c * ch7RectColumnNorm2 Aplus i) :=
    div_pos hK hden
  have hlower_pos :
      0 < (K / (c * ch7RectColumnNorm2 Aplus i))⁻¹ :=
    inv_pos.mpr hquot
  have h_abs_pos : 0 < |d i| := lt_of_lt_of_le hlower_pos (hd.2 i)
  exact abs_pos.mp h_abs_pos

theorem continuousOn_ch7Op2LeftScaledCond_reciprocal_compactCore {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i) :
    ContinuousOn (fun d : Fin m → ℝ =>
      ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹))
      (ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c) := by
  exact continuousOn_ch7Op2LeftScaledCond_reciprocal A Aplus
    (ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c)
    (fun d hd i =>
      ch7Op2LeftScaledCondReciprocalCompactCore_ne_zero
        hK hc hcolAplus hd i)

theorem isClosed_ch7Op2LeftScaledCondReciprocalCompactSublevel {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i) :
    IsClosed (ch7Op2LeftScaledCondReciprocalCompactSublevel A Aplus K c) := by
  let core : Set (Fin m → ℝ) :=
    ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c
  let f : (Fin m → ℝ) → ℝ := fun d =>
    ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹)
  have hcore_closed : IsClosed core := by
    dsimp [core]
    exact isClosed_ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c
  have hf : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7Op2LeftScaledCond_reciprocal_compactCore
      A Aplus hK hc hcolAplus
  have hpre : IsClosed (core ∩ f ⁻¹' Set.Iic K) :=
    ContinuousOn.preimage_isClosed_of_isClosed hf hcore_closed isClosed_Iic
  simpa [ch7Op2LeftScaledCondReciprocalCompactSublevel, core, f, Set.Iic]
    using hpre

theorem isCompact_ch7Op2LeftScaledCondReciprocalCompactSublevel {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i) :
    IsCompact (ch7Op2LeftScaledCondReciprocalCompactSublevel A Aplus K c) := by
  exact IsCompact.of_isClosed_subset
    (isCompact_ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c)
    (isClosed_ch7Op2LeftScaledCondReciprocalCompactSublevel
      A Aplus hK hc hcolAplus)
    (by
      intro d hd
      exact hd.1)

/-- The normalized reciprocal left-scaling operator-2 value set attains a
least value once the source rows of `A` and inverse-side columns of `Aplus`
are nonzero. -/
theorem ch7Op2LeftScaledCondReciprocalNormalizedSet_exists_isLeast {m n : ℕ}
    (hm : 0 < m)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ k : Fin m, 0 < ch7RectRowNorm2 A k)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i) :
    ∃ μ : ℝ, IsLeast
      (ch7Op2LeftScaledCondReciprocalNormalizedSet A Aplus) μ := by
  let d0 : Fin m → ℝ := fun _ => (m : ℝ)⁻¹
  let f : (Fin m → ℝ) → ℝ := fun d =>
    ch7Op2LeftScaledCond A Aplus d (fun i : Fin m => (d i)⁻¹)
  let K : ℝ := f d0
  have hmR : 0 < (m : ℝ) := by exact_mod_cast hm
  have hm_ne : (m : ℝ) ≠ 0 := ne_of_gt hmR
  have hd0_pos : ∀ i : Fin m, 0 < d0 i := by
    intro i
    exact inv_pos.mpr hmR
  have hd0_ne : ∀ i : Fin m, d0 i ≠ 0 := fun i => ne_of_gt (hd0_pos i)
  have hd0_sum : (∑ i : Fin m, |d0 i|) = 1 := by
    calc
      (∑ i : Fin m, |d0 i|)
          = ∑ _i : Fin m, (m : ℝ)⁻¹ := by
            apply Finset.sum_congr rfl
            intro i _
            exact abs_of_pos (hd0_pos i)
      _ = (m : ℝ) * (m : ℝ)⁻¹ := by
            simp [Finset.sum_const, nsmul_eq_mul]
      _ = 1 := mul_inv_cancel₀ hm_ne
  have hKpos : 0 < K := by
    let i0 : Fin m := ⟨0, hm⟩
    rcases ch7Op2LeftScaledCond_reciprocal_normalized_lower_exists
        hm A Aplus d0 hd0_sum i0 with ⟨k, hkprod⟩
    have hleft_pos : 0 < (m : ℝ)⁻¹ * ch7RectRowNorm2 A k :=
      mul_pos (inv_pos.mpr hmR) (hrow k)
    have hright_pos :
        0 < |(d0 i0)⁻¹| * ch7RectColumnNorm2 Aplus i0 := by
      exact mul_pos (abs_pos.mpr (inv_ne_zero (hd0_ne i0))) (hcolAplus i0)
    exact lt_of_lt_of_le (mul_pos hleft_pos hright_pos) hkprod
  rcases ch7_exists_pos_le_all_inv_card_mul_row_norm2 hm A hrow with
    ⟨c, hc, hcA⟩
  let core : Set (Fin m → ℝ) :=
    ch7Op2LeftScaledCondReciprocalCompactCore Aplus K c
  let S : Set (Fin m → ℝ) :=
    ch7Op2LeftScaledCondReciprocalCompactSublevel A Aplus K c
  have hd0_core : d0 ∈ core := by
    refine ⟨hd0_sum, ?_⟩
    intro i
    have hM : 0 < K / (c * ch7RectColumnNorm2 Aplus i) :=
      div_pos hKpos (mul_pos hc (hcolAplus i))
    have hinv_le :
        |(d0 i)⁻¹| ≤ K / (c * ch7RectColumnNorm2 Aplus i) := by
      dsimp [K, f]
      exact ch7Op2LeftScaledCond_reciprocal_normalized_inv_abs_le_of_le_of_const
        hm A Aplus hc hcA hcolAplus d0 hd0_sum le_rfl i
    exact ch7_inv_bound_le_abs_of_inv_abs_le (hd0_ne i) hM hinv_le
  have hd0S : d0 ∈ S := by
    refine ⟨?_, ?_⟩
    · exact hd0_core
    · dsimp [S, K, f, ch7Op2LeftScaledCondReciprocalCompactSublevel]
      exact le_rfl
  have hS_nonempty : S.Nonempty := ⟨d0, hd0S⟩
  have hScompact : IsCompact S := by
    dsimp [S]
    exact isCompact_ch7Op2LeftScaledCondReciprocalCompactSublevel
      A Aplus hKpos hc hcolAplus
  have hfcore : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7Op2LeftScaledCond_reciprocal_compactCore
      A Aplus hKpos hc hcolAplus
  have hfS : ContinuousOn f S := by
    exact hfcore.mono (by
      intro d hd
      exact hd.1)
  rcases hScompact.exists_isMinOn hS_nonempty hfS with
    ⟨dmin, hdminS, hminS⟩
  refine ⟨f dmin, ?_⟩
  constructor
  · refine ⟨dmin, ?_, ?_, rfl⟩
    · intro i
      exact ch7Op2LeftScaledCondReciprocalCompactCore_ne_zero
        hKpos hc hcolAplus hdminS.1 i
    · exact hdminS.1.1
  · intro μ hμ
    rcases hμ with ⟨d, hdne, hsum, rfl⟩
    rcases le_total (f d) K with hfdK | hKfd
    · have hd_core : d ∈ core := by
        refine ⟨hsum, ?_⟩
        intro i
        have hM : 0 < K / (c * ch7RectColumnNorm2 Aplus i) :=
          div_pos hKpos (mul_pos hc (hcolAplus i))
        have hinv_le :
            |(d i)⁻¹| ≤ K / (c * ch7RectColumnNorm2 Aplus i) := by
          dsimp [K, f] at hfdK
          exact
            ch7Op2LeftScaledCond_reciprocal_normalized_inv_abs_le_of_le_of_const
              hm A Aplus hc hcA hcolAplus d hsum hfdK i
        exact ch7_inv_bound_le_abs_of_inv_abs_le (hdne i) hM hinv_le
      have hdS : d ∈ S := ⟨hd_core, hfdK⟩
      exact hminS hdS
    · exact hdminS.2.trans hKfd

theorem ch7Op2LeftScaledCondNormalizedSet_exists_isLeast {m n : ℕ}
    (hm : 0 < m)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ k : Fin m, 0 < ch7RectRowNorm2 A k)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i) :
    ∃ μ : ℝ, IsLeast (ch7Op2LeftScaledCondNormalizedSet A Aplus) μ := by
  rcases ch7Op2LeftScaledCondReciprocalNormalizedSet_exists_isLeast
      hm A Aplus hrow hcolAplus with ⟨μ, hμ⟩
  exact ⟨μ,
    (ch7Op2LeftScaledCondNormalizedSet_isLeast_iff_reciprocal_normalized
      A Aplus).mpr hμ⟩

theorem ch7Op2LeftScaledCondSet_exists_isLeast {m n : ℕ}
    (hm : 0 < m)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ k : Fin m, 0 < ch7RectRowNorm2 A k)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnNorm2 Aplus i) :
    ∃ μ : ℝ, IsLeast (ch7Op2LeftScaledCondSet A Aplus) μ := by
  rcases ch7Op2LeftScaledCondNormalizedSet_exists_isLeast
      hm A Aplus hrow hcolAplus with ⟨μ, hμ⟩
  exact ⟨μ,
    (ch7Op2LeftScaledCondSet_isLeast_iff_sum_abs_normalized
      hm A Aplus).mpr hμ⟩

/-- If `Aplus` is a rectangular right inverse of `A`, every column of
`Aplus` that participates in the inverse-side `A⁺D⁻¹` factor is nonzero. -/
lemma ch7RectColumnNorm2_Aplus_pos_of_rect_right_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hright : ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0)
    (i : Fin m) :
    0 < ch7RectColumnNorm2 Aplus i := by
  have hne : ch7RectColumnNorm2 Aplus i ≠ 0 := by
    intro hzero
    have hentries : ∀ k : Fin n, Aplus k i = 0 :=
      (vecNorm2_eq_zero_iff (fun k : Fin n => Aplus k i)).mp hzero
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hright i i
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectColumnNorm2_nonneg Aplus i) (Ne.symm hne)

/-- The operator-2 left-scaling value set is bounded below by zero. -/
theorem ch7Op2LeftScaledCondSet_bddBelow {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    BddBelow (ch7Op2LeftScaledCondSet A Aplus) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
  exact ch7Op2LeftScaledCond_nonneg A Aplus d dInv

/-- The infimum of the explicit operator-2 left-scaling condition products is
nonnegative, since every admissible value is a product of operator norms. -/
theorem ch7Op2LeftScaledCondSet_sInf_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    0 ≤ sInf (ch7Op2LeftScaledCondSet A Aplus) := by
  let S : Set ℝ := ch7Op2LeftScaledCondSet A Aplus
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7Op2LeftScaledCondSet_nonempty A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
    exact ch7Op2LeftScaledCond_nonneg A Aplus d dInv
  exact le_csInf hS_nonempty hlower

/-- Equation `(7.19)`, `p = 2` inverse-side algebraic core.  This is the
row-scaled analogue of `(7.22)` for Euclidean operator norms. -/
theorem eq_7_19_op2_inverseSide_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    complexMatrixOp2
        (realRectToCMatrix
          (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm2 A i))) ≤
      complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale d A)) *
        complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale Aplus dInv)) := by
  let B : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectLeftScale d A))
  let C : ℝ := complexMatrixOp2 (realRectToCMatrix (ch7RectRightScale Aplus dInv))
  have hB_nonneg : 0 ≤ B := by
    dsimp [B]
    exact complexMatrixOp2_nonneg _
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact complexMatrixOp2_nonneg _
  have hDA :
      rectOpNorm2Le (ch7RectLeftScale d A) B :=
    rectOpNorm2Le_of_complexMatrixOp2_realRectToCMatrix_le
      (ch7RectLeftScale d A) le_rfl
  have hside :
      rectOpNorm2Le (ch7RectRightScale Aplus dInv) C :=
    rectOpNorm2Le_of_complexMatrixOp2_realRectToCMatrix_le
      (ch7RectRightScale Aplus dInv) le_rfl
  have hDAT :
      rectOpNorm2Le (finiteTranspose (ch7RectLeftScale d A)) B :=
    rectOpNorm2Le_finiteTranspose_of_rectOpNorm2Le
      (ch7RectLeftScale d A) hB_nonneg hDA
  have hfactor :
      ∀ i : Fin m, |d i * ch7RectRowNorm2 A i| ≤ B := by
    intro i
    have hrow :=
      eq_7_20_column_norm_le_of_rectOpNorm2Le
        (finiteTranspose (ch7RectLeftScale d A)) hDAT i
    rw [ch7RectColumnNorm2_finiteTranspose_leftScale_eq] at hrow
    simpa [abs_mul, abs_of_nonneg (ch7RectRowNorm2_nonneg A i)] using hrow
  have hrewrite :
      ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm2 A i) =
        ch7RectRightScale
          (ch7RectRightScale Aplus dInv)
          (fun i : Fin m => d i * ch7RectRowNorm2 A i) := by
    ext k i
    unfold ch7RectRightScale
    calc
      Aplus k i * ch7RectRowNorm2 A i =
          Aplus k i * ((dInv i * d i) * ch7RectRowNorm2 A i) := by
            rw [mul_comm (dInv i) (d i), hdiag i]
            ring
      _ = (Aplus k i * dInv i) * (d i * ch7RectRowNorm2 A i) := by
            ring
  have htarget :
      rectOpNorm2Le
        (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm2 A i))
        (C * B) := by
    rw [hrewrite]
    exact ch7RectRightScale_rectOpNorm2Le_of_abs_le
      (ch7RectRightScale Aplus dInv)
      (fun i : Fin m => d i * ch7RectRowNorm2 A i)
      hB_nonneg hC_nonneg hfactor hside
  have htargetC :
      complexMatrixOp2
          (realRectToCMatrix
            (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm2 A i))) ≤
        C * B :=
    complexMatrixOp2_realRectToCMatrix_le_of_rectOpNorm2Le
      (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm2 A i))
      (mul_nonneg hC_nonneg hB_nonneg) htarget
  simpa [B, C, mul_comm] using htargetC

/-- Theorem 7.5, equation `(7.19)`, `p = 2` pairwise row-equilibration
specialization.  Row equilibration is within the source factor `sqrt(m)` of
any nonsingular diagonal left scaling, for a fixed explicit inverse-side
matrix `Aplus`. -/
theorem theorem7_5_p2_row_equilibration_le_sqrt_card_left_scaling {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm2 A i)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    ch7Op2LeftScaledCond A Aplus
        (ch7RowEquilibratingScale2Rect A)
        (fun i : Fin m => ch7RectRowNorm2 A i) ≤
      Real.sqrt (m : ℝ) * ch7Op2LeftScaledCond A Aplus d dInv := by
  unfold ch7Op2LeftScaledCond
  let DAc : Fin m → Fin n → ℝ :=
    ch7RectLeftScale (ch7RowEquilibratingScale2Rect A) A
  let AplusDcInv : Fin n → Fin m → ℝ :=
    ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm2 A i)
  let DA : Fin m → Fin n → ℝ := ch7RectLeftScale d A
  let AplusDinv : Fin n → Fin m → ℝ := ch7RectRightScale Aplus dInv
  have hDAc :
      complexMatrixOp2 (realRectToCMatrix DAc) ≤ Real.sqrt (m : ℝ) :=
    complexMatrixOp2_realRectToCMatrix_le_of_rectOpNorm2Le DAc
      (Real.sqrt_nonneg _)
      (by
        dsimp [DAc]
        exact eq_7_19_rectOpNorm2Le_row_equilibrated A hrow)
  have hside :
      complexMatrixOp2 (realRectToCMatrix AplusDcInv) ≤
        complexMatrixOp2 (realRectToCMatrix DA) *
          complexMatrixOp2 (realRectToCMatrix AplusDinv) := by
    dsimp [AplusDcInv, DA, AplusDinv]
    exact eq_7_19_op2_inverseSide_bound A Aplus d dInv hdiag
  have hAplusDcInv_nonneg :
      0 ≤ complexMatrixOp2 (realRectToCMatrix AplusDcInv) :=
    complexMatrixOp2_nonneg _
  calc
    complexMatrixOp2 (realRectToCMatrix DAc) *
        complexMatrixOp2 (realRectToCMatrix AplusDcInv)
        ≤ Real.sqrt (m : ℝ) *
            complexMatrixOp2 (realRectToCMatrix AplusDcInv) :=
          mul_le_mul_of_nonneg_right hDAc hAplusDcInv_nonneg
    _ ≤ Real.sqrt (m : ℝ) *
          (complexMatrixOp2 (realRectToCMatrix DA) *
            complexMatrixOp2 (realRectToCMatrix AplusDinv)) :=
          mul_le_mul_of_nonneg_left hside (Real.sqrt_nonneg _)
    _ = Real.sqrt (m : ℝ) *
          (complexMatrixOp2 (realRectToCMatrix DA) *
            complexMatrixOp2 (realRectToCMatrix AplusDinv)) := rfl

/-- Theorem 7.5, equation `(7.19)`, `p = 2` infimum form over reciprocal
diagonal left scalings for the explicit condition product.  It packages the
pairwise row estimate as
`κ₂(D_R A) ≤ sqrt(m) inf_D ‖DA‖₂ ‖A⁺D⁻¹‖₂`, while keeping the full
Moore-Penrose/general-`p` source theorem separate. -/
theorem theorem7_5_p2_row_equilibration_le_sqrt_card_sInf_left_scalings
    {m n : ℕ} (hm : 0 < m)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm2 A i) :
    ch7Op2LeftScaledCond A Aplus
        (ch7RowEquilibratingScale2Rect A)
        (fun i : Fin m => ch7RectRowNorm2 A i) ≤
      Real.sqrt (m : ℝ) * sInf (ch7Op2LeftScaledCondSet A Aplus) := by
  let c : ℝ :=
    ch7Op2LeftScaledCond A Aplus
      (ch7RowEquilibratingScale2Rect A)
      (fun i : Fin m => ch7RectRowNorm2 A i)
  let S : Set ℝ := ch7Op2LeftScaledCondSet A Aplus
  let α : ℝ := Real.sqrt (m : ℝ)
  have hmR : 0 < (m : ℝ) := by exact_mod_cast hm
  have hαpos : 0 < α := by
    dsimp [α]
    exact Real.sqrt_pos.2 hmR
  have hαnonneg : 0 ≤ α := le_of_lt hαpos
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7Op2LeftScaledCondSet_nonempty A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → c / α ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    have hpair :
        c ≤ α * ch7Op2LeftScaledCond A Aplus d dInv := by
      dsimp [c, α]
      exact theorem7_5_p2_row_equilibration_le_sqrt_card_left_scaling
        A Aplus hrow d dInv hdiag
    rw [div_le_iff₀ hαpos]
    simpa [mul_comm] using hpair
  have hsInf : c / α ≤ sInf S := le_csInf hS_nonempty hlower
  have hmul : α * (c / α) ≤ α * sInf S :=
    mul_le_mul_of_nonneg_left hsInf hαnonneg
  have hrewrite : α * (c / α) = c := by
    field_simp [ne_of_gt hαpos]
  change c ≤ α * sInf S
  exact hrewrite ▸ hmul

/-- Theorem 7.5, `p = 2` row form with the source `min` value made explicit.
As in the finite-real row wrapper, minimizer existence is represented by the
separate `IsLeast` certificate. -/
theorem theorem7_5_p2_row_equilibration_le_sqrt_card_min_left_scalings
