/-- Taking absolute values commutes with a two-sided diagonal scaling whose
diagonal entries are nonnegative. -/
lemma ch7TwoSidedScale_absMatrix_eq {n : ℕ}
    (dLeft : Fin n → ℝ) (A : Fin n → Fin n → ℝ) (dRight : Fin n → ℝ)
    (hdLeft : ∀ i : Fin n, 0 ≤ dLeft i)
    (hdRight : ∀ j : Fin n, 0 ≤ dRight j) :
    absMatrix n (ch7TwoSidedScale dLeft A dRight) =
      ch7TwoSidedScale dLeft (absMatrix n A) dRight := by
  ext i j
  unfold absMatrix ch7TwoSidedScale
  rw [abs_mul, abs_mul, abs_of_nonneg (hdLeft i), abs_of_nonneg (hdRight j)]

/-- The infinity norm of a nonnegative diagonal two-sided scaling depends only
on the componentwise absolute values of the unscaled matrix. -/
lemma ch7_infNorm_twoSidedScale_absMatrix_eq {n : ℕ} (hn : 0 < n)
    (dLeft : Fin n → ℝ) (A : Fin n → Fin n → ℝ) (dRight : Fin n → ℝ)
    (hdLeft : ∀ i : Fin n, 0 ≤ dLeft i)
    (hdRight : ∀ j : Fin n, 0 ≤ dRight j) :
    infNorm (ch7TwoSidedScale dLeft (absMatrix n A) dRight) =
      infNorm (ch7TwoSidedScale dLeft A dRight) := by
  rw [← ch7TwoSidedScale_absMatrix_eq dLeft A dRight hdLeft hdRight,
    infNorm_absMatrix hn]

/-- The infinity-norm condition product for the two-sidedly scaled matrix
`D₁ A D₂`, with the inverse-scaled partner `D₂⁻¹ A_inv D₁⁻¹` supplied
entrywise.  When `A_inv` is an inverse of `A` and the diagonal entries are
reciprocal pairs, this is the source `κ∞(D₁ A D₂)`. -/
noncomputable def ch7TwoSidedScaledInfKappa {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) : ℝ :=
  infNorm (ch7TwoSidedScale d₁ A d₂) *
    infNorm (ch7TwoSidedScale d₂Inv A_inv d₁Inv)

/-- Problem 7.10(b)'s infinity-norm condition-product values
`κ∞(D₁AD₂)` over positive reciprocal two-sided diagonal scalings, represented
with an explicit inverse-side matrix `A_inv`. -/
noncomputable def ch7TwoSidedScaledInfKappaSet {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ,
    (∀ i : Fin n, 0 < d₁ i) ∧
    (∀ i : Fin n, 0 < d₁Inv i) ∧
    (∀ i : Fin n, 0 < d₂ i) ∧
    (∀ i : Fin n, 0 < d₂Inv i) ∧
    (∀ i : Fin n, d₁ i * d₁Inv i = 1) ∧
    (∀ i : Fin n, d₂ i * d₂Inv i = 1) ∧
    κ = ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv}

/-- Membership helper for the positive two-sided infinity-norm condition
product value set. -/
theorem ch7TwoSidedScaledInfKappa_mem_set {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv ∈
      ch7TwoSidedScaledInfKappaSet A A_inv := by
  refine ⟨d₁, d₁Inv, d₂, d₂Inv,
    hd₁pos, hd₁Invpos, hd₂pos, hd₂Invpos, hd₁, hd₂, ?_⟩
  rfl

/-- The positive infinity-norm condition-product scaling value set is
nonempty by the identity scaling. -/
theorem ch7TwoSidedScaledInfKappaSet_nonempty {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    (ch7TwoSidedScaledInfKappaSet A A_inv).Nonempty := by
  refine ⟨infNorm A * infNorm A_inv, ?_⟩
  refine ⟨fun _ => 1, fun _ => 1, fun _ => 1, fun _ => 1,
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num), ?_⟩
  have hA :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) A
        (fun _ : Fin n => (1 : ℝ)) = A := by
    ext i j
    simp [ch7TwoSidedScale]
  have hAinv :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) A_inv
        (fun _ : Fin n => (1 : ℝ)) = A_inv := by
    ext i j
    simp [ch7TwoSidedScale]
  simp [ch7TwoSidedScaledInfKappa, hA, hAinv]

/-- The positive infinity-norm condition-product scaling value set is bounded
below by zero. -/
theorem ch7TwoSidedScaledInfKappaSet_bddBelow {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    BddBelow (ch7TwoSidedScaledInfKappaSet A A_inv) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with
    ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
      _hd₂pos, _hd₂Invpos, _hd₁, _hd₂, rfl⟩
  exact mul_nonneg (infNorm_nonneg _) (infNorm_nonneg _)

/-- The infimum of the positive infinity-norm condition-product scaling value
set is nonnegative. -/
theorem ch7TwoSidedScaledInfKappaSet_sInf_nonneg {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    0 ≤ sInf (ch7TwoSidedScaledInfKappaSet A A_inv) := by
  let S : Set ℝ := ch7TwoSidedScaledInfKappaSet A A_inv
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledInfKappaSet_nonempty A A_inv
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
        _hd₂pos, _hd₂Invpos, _hd₁, _hd₂, rfl⟩
    exact mul_nonneg (infNorm_nonneg _) (infNorm_nonneg _)
  exact le_csInf hS_nonempty hlower

/-- Two-sided diagonal scaling transports a left-inverse certificate:
if `A_inv * A = I` and `d₁`, `d₂` are paired with reciprocal diagonal
entries, then `D₂⁻¹ A_inv D₁⁻¹` is a left inverse of `D₁ A D₂`. -/
lemma ch7TwoSidedScale_isLeftInverse {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    IsLeftInverse n
      (ch7TwoSidedScale d₁ A d₂)
      (ch7TwoSidedScale d₂Inv A_inv d₁Inv) := by
  intro i j
  calc
    ∑ k : Fin n,
        ch7TwoSidedScale d₂Inv A_inv d₁Inv i k *
          ch7TwoSidedScale d₁ A d₂ k j
        = ∑ k : Fin n, d₂Inv i * d₂ j * (A_inv i k * A k j) := by
            apply Finset.sum_congr rfl
            intro k _
            unfold ch7TwoSidedScale
            have hdiag : d₁Inv k * d₁ k = 1 := by
              rw [mul_comm, hd₁ k]
            rw [show d₂Inv i * A_inv i k * d₁Inv k *
                    (d₁ k * A k j * d₂ j) =
                  d₂Inv i * d₂ j * ((d₁Inv k * d₁ k) *
                    (A_inv i k * A k j)) by ring, hdiag]
            ring
    _ = d₂Inv i * d₂ j * ∑ k : Fin n, A_inv i k * A k j := by
          rw [Finset.mul_sum]
    _ = d₂Inv i * d₂ j * (if i = j then 1 else 0) := by
          rw [hInv i j]
    _ = (if i = j then 1 else 0) := by
          by_cases hij : i = j
          · subst j
            have hdiag : d₂Inv i * d₂ i = 1 := by
              rw [mul_comm, hd₂ i]
            simp [hdiag]
          · simp [hij]

/-- Two-sided diagonal scaling transports a right-inverse certificate:
if `A * A_inv = I` and `d₁`, `d₂` are paired with reciprocal diagonal
entries, then `D₂⁻¹ A_inv D₁⁻¹` is a right inverse of `D₁ A D₂`. -/
lemma ch7TwoSidedScale_isRightInverse {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hInv : IsRightInverse n A A_inv)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    IsRightInverse n
      (ch7TwoSidedScale d₁ A d₂)
      (ch7TwoSidedScale d₂Inv A_inv d₁Inv) := by
  intro i j
  calc
    ∑ k : Fin n,
        ch7TwoSidedScale d₁ A d₂ i k *
          ch7TwoSidedScale d₂Inv A_inv d₁Inv k j
        = ∑ k : Fin n, d₁ i * d₁Inv j * (A i k * A_inv k j) := by
            apply Finset.sum_congr rfl
            intro k _
            unfold ch7TwoSidedScale
            have hdiag : d₂ k * d₂Inv k = 1 := hd₂ k
            rw [show d₁ i * A i k * d₂ k *
                    (d₂Inv k * A_inv k j * d₁Inv j) =
                  d₁ i * d₁Inv j * ((d₂ k * d₂Inv k) *
                    (A i k * A_inv k j)) by ring, hdiag]
            ring
    _ = d₁ i * d₁Inv j * ∑ k : Fin n, A i k * A_inv k j := by
          rw [Finset.mul_sum]
    _ = d₁ i * d₁Inv j * (if i = j then 1 else 0) := by
          rw [hInv i j]
    _ = (if i = j then 1 else 0) := by
          by_cases hij : i = j
          · subst j
            simp [hd₁ i]
          · simp [hij]

/-- Two-sided diagonal scaling preserves inverse witnesses. -/
theorem ch7TwoSidedScale_isInverse {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hInv : IsInverse n A A_inv)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    IsInverse n
      (ch7TwoSidedScale d₁ A d₂)
      (ch7TwoSidedScale d₂Inv A_inv d₁Inv) :=
  ⟨ch7TwoSidedScale_isLeftInverse A A_inv d₁ d₁Inv d₂ d₂Inv hInv.1 hd₁ hd₂,
    ch7TwoSidedScale_isRightInverse A A_inv d₁ d₁Inv d₂ d₂Inv hInv.2 hd₁ hd₂⟩

/-- Corollary 7.6 scaled inverse-side certificate: if `A = RᵀR` and `Rinv`
is a two-sided inverse of `R`, then `D⁻¹(Rinv Rinvᵀ)D⁻¹` is a two-sided
inverse of `DAD` for every reciprocal diagonal pair `D`, `D⁻¹`. -/
theorem corollary7_6_cholesky_scaled_inverse_gram_isInverse {n : ℕ}
    (A R Rinv : Fin n → Fin n → ℝ) (d dInv : Fin n → ℝ)
    (hGram : ∀ i j : Fin n, (∑ k : Fin n, R k i * R k j) = A i j)
    (hRinv : IsInverse n R Rinv)
    (hdiag : ∀ i : Fin n, d i * dInv i = 1) :
    IsInverse n
      (ch7TwoSidedScale d A d)
      (ch7TwoSidedScale dInv (ch7CholeskyInverseGram Rinv) dInv) := by
  have hAeq : A = matMul n (matTranspose R) R := by
    ext i j
    unfold matMul matTranspose
    exact (hGram i j).symm
  rw [hAeq]
  exact ch7TwoSidedScale_isInverse
    (matMul n (matTranspose R) R) (ch7CholeskyInverseGram Rinv)
    d dInv d dInv
    (corollary7_6_cholesky_inverse_gram_isInverse R Rinv hRinv)
    hdiag hdiag

/-- The source `κ∞(D₁ A D₂)` interpretation of `ch7TwoSidedScaledInfKappa`.
Under a genuine inverse certificate for `A`, the supplied inverse-scaled
partner is an inverse of the scaled matrix, and the product agrees with the
repository's `kappaInf` definition. -/
theorem ch7TwoSidedScaledInfKappa_eq_kappaInf_of_inverse {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hInv : IsInverse n A A_inv)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    IsInverse n
        (ch7TwoSidedScale d₁ A d₂)
        (ch7TwoSidedScale d₂Inv A_inv d₁Inv) ∧
      ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv =
        kappaInf n hn
          (ch7TwoSidedScale d₁ A d₂)
          (ch7TwoSidedScale d₂Inv A_inv d₁Inv) := by
  refine ⟨ch7TwoSidedScale_isInverse A A_inv d₁ d₁Inv d₂ d₂Inv hInv hd₁ hd₂, ?_⟩
  rw [kappaInf_eq_infNorm_mul_infNorm]
  rfl

/-- Problem 7.10(b)'s absolute-value reduction:
`κ∞(D₁ A D₂)` is the Problem 7.10(a) product for
`B = |A|` and `C = |A⁻¹|`, under nonnegative diagonal factors. -/
lemma ch7TwoSidedScaledInfKappa_eq_abs_scaledInfCond {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁ : ∀ i : Fin n, 0 ≤ d₁ i)
    (hd₁Inv : ∀ i : Fin n, 0 ≤ d₁Inv i)
    (hd₂ : ∀ i : Fin n, 0 ≤ d₂ i)
    (hd₂Inv : ∀ i : Fin n, 0 ≤ d₂Inv i) :
    ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv =
      ch7TwoSidedScaledInfCond (absMatrix n A) (absMatrix n A_inv)
        d₁ d₁Inv d₂ d₂Inv := by
  unfold ch7TwoSidedScaledInfKappa ch7TwoSidedScaledInfCond
  rw [ch7_infNorm_twoSidedScale_absMatrix_eq hn d₁ A d₂ hd₁ hd₂,
    ch7_infNorm_twoSidedScale_absMatrix_eq hn d₂Inv A_inv d₁Inv hd₂Inv hd₁Inv]

/-- Problem 7.10(b), lower-bound half under the explicit positive Perron-vector
certificate for `|A||A⁻¹|`.  This reuses the proved Problem 7.10(a) algebraic
core after proving the source absolute-value reduction. -/
theorem problem7_10b_scaled_infKappa_ge_perron_of_abs_inverse_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i =
        ρ * x i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ρ ≤ ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv := by
  rw [ch7TwoSidedScaledInfKappa_eq_abs_scaledInfCond hn
    A A_inv d₁ d₁Inv d₂ d₂Inv
    (fun i => le_of_lt (hd₁pos i)) (fun i => le_of_lt (hd₁Invpos i))
    (fun i => le_of_lt (hd₂pos i)) (fun i => le_of_lt (hd₂Invpos i))]
  exact problem7_10a_scaled_infCond_ge_perron_of_positive_eigenvector
    hn (absMatrix n A) (absMatrix n A_inv) ρ x
    (by intro i j; exact abs_nonneg _)
    (by intro i j; exact abs_nonneg _)
    hx heig d₁ d₁Inv d₂ d₂Inv
    hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂

/-- Problem 7.10(b), lower-bound half under a positive subeigenvector for
`|A||A⁻¹|`.  This is the absolute-value condition-number counterpart of
`problem7_10a_scaled_infCond_ge_perron_of_positive_subeigenvector`. -/
theorem problem7_10b_scaled_infKappa_ge_perron_of_abs_inverse_positive_subeigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n,
      ρ * x i ≤
        matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ρ ≤ ch7TwoSidedScaledInfKappa A A_inv d₁ d₁Inv d₂ d₂Inv := by
  rw [ch7TwoSidedScaledInfKappa_eq_abs_scaledInfCond hn
    A A_inv d₁ d₁Inv d₂ d₂Inv
    (fun i => le_of_lt (hd₁pos i)) (fun i => le_of_lt (hd₁Invpos i))
    (fun i => le_of_lt (hd₂pos i)) (fun i => le_of_lt (hd₂Invpos i))]
  exact problem7_10a_scaled_infCond_ge_perron_of_positive_subeigenvector
    hn (absMatrix n A) (absMatrix n A_inv) ρ x hρ hx hsub
    d₁ d₁Inv d₂ d₂Inv
    hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂

/-- Problem 7.10(b), `κ∞` value-set lower bound from a positive
subeigenvector for `|A||A⁻¹|`. -/
theorem problem7_10b_scaledInfKappaSet_sInf_ge_perron_of_abs_inverse_positive_subeigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hsub : ∀ i : Fin n,
      ρ * x i ≤
        matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i) :
    ρ ≤ sInf (ch7TwoSidedScaledInfKappaSet A A_inv) := by
  let S : Set ℝ := ch7TwoSidedScaledInfKappaSet A A_inv
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7TwoSidedScaledInfKappaSet_nonempty A A_inv
  have hlower : ∀ κ : ℝ, κ ∈ S → ρ ≤ κ := by
    intro κ hκ
    rcases hκ with
      ⟨d₁, d₁Inv, d₂, d₂Inv, hd₁pos, hd₁Invpos,
        hd₂pos, hd₂Invpos, hd₁, hd₂, rfl⟩
    exact problem7_10b_scaled_infKappa_ge_perron_of_abs_inverse_positive_subeigenvector
      hn A A_inv ρ x hρ hx hsub d₁ d₁Inv d₂ d₂Inv
      hd₁pos hd₁Invpos hd₂pos hd₂Invpos hd₁ hd₂
  exact le_csInf hS_nonempty hlower

/-- Problem 7.10(b), canonical scaling for `B = |A|`, `C = |A⁻¹|` under an
explicit positive Perron-vector certificate.  The diagonal choice is
`D₁ = diag(x)⁻¹`, `D₂ = diag(|A⁻¹|x)`, matching Higham's hint. -/
theorem problem7_10b_canonical_scaled_infKappa_eq_perron_of_abs_inverse_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hx : ∀ i : Fin n, 0 < x i)
    (hAinvx : ∀ i : Fin n, 0 < matMulVec n (absMatrix n A_inv) x i)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i =
        ρ * x i) :
    ch7TwoSidedScaledInfKappa A A_inv
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n (absMatrix n A_inv) x i)
        (fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹) =
      ρ := by
  rw [ch7TwoSidedScaledInfKappa_eq_abs_scaledInfCond hn A A_inv
    (fun i => (x i)⁻¹) x
    (fun i => matMulVec n (absMatrix n A_inv) x i)
    (fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹)
    (fun i => inv_nonneg.mpr (le_of_lt (hx i)))
    (fun i => le_of_lt (hx i))
    (fun i => le_of_lt (hAinvx i))
    (fun i => inv_nonneg.mpr (le_of_lt (hAinvx i)))]
  exact problem7_10a_canonical_scaled_infCond_eq_perron_of_positive_eigenvector
    hn (absMatrix n A) (absMatrix n A_inv) ρ x
    (by intro i j; exact abs_nonneg _)
    (by intro i j; exact abs_nonneg _)
    hx hAinvx heig

/-- Problem 7.10(d), `B = |A|`, `C = |A⁻¹|` specialization of the
irreducible-product `Cx > 0` transfer.  This is the source side condition
needed to use the canonical Bauer scaling in Problem 7.10(b) when positivity of
`|A⁻¹|x` is obtained from irreducibility of both products rather than assumed
directly. -/
lemma problem7_10d_abs_inverse_Cx_pos_of_irreducible_products {n : ℕ}
    (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n (absMatrix n A) (absMatrix n A_inv)) :
        Matrix (Fin n) (Fin n) ℝ))
    (hCB : Matrix.IsIrreducible
      (Matrix.of (matMul n (absMatrix n A_inv) (absMatrix n A)) :
        Matrix (Fin n) (Fin n) ℝ))
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i =
        ρ * x i) :
    ∀ i : Fin n, 0 < matMulVec n (absMatrix n A_inv) x i :=
  problem7_10d_Cx_pos_of_irreducible_BC_CB hn
    (absMatrix n A) (absMatrix n A_inv) ρ x
    (by intro i j; exact abs_nonneg _)
    (by intro i j; exact abs_nonneg _)
    hBC hCB hx heig

/-- Problem 7.10(b), canonical scaled-`κ∞` equality from the source-shaped
irreducible-product hypotheses of Problem 7.10(d).  This removes the explicit
`|A⁻¹|x > 0` side condition by proving it from irreducibility of both
`|A||A⁻¹|` and `|A⁻¹||A|`; Perron-Frobenius existence and spectral-radius
identification are still separate source-facing targets. -/
theorem problem7_10b_irreducible_products_canonical_scaled_infKappa_eq_perron
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hBC : Matrix.IsIrreducible
      (Matrix.of (matMul n (absMatrix n A) (absMatrix n A_inv)) :
        Matrix (Fin n) (Fin n) ℝ))
    (hCB : Matrix.IsIrreducible
      (Matrix.of (matMul n (absMatrix n A_inv) (absMatrix n A)) :
        Matrix (Fin n) (Fin n) ℝ))
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i =
        ρ * x i) :
    ch7TwoSidedScaledInfKappa A A_inv
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n (absMatrix n A_inv) x i)
        (fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹) =
      ρ :=
  problem7_10b_canonical_scaled_infKappa_eq_perron_of_abs_inverse_positive_eigenvector
    hn A A_inv ρ x hx
    (problem7_10d_abs_inverse_Cx_pos_of_irreducible_products
      hn A A_inv ρ x hBC hCB hx heig)
    heig

/-- Problem 7.10(b), source-positive-entry wrapper for the canonical
`B = |A|`, `C = |A⁻¹|` scaling.  This keeps the Perron-vector certificate
explicit; Perron-Frobenius existence and spectral-radius identification remain
separate source-facing targets. -/
theorem problem7_10b_positive_abs_entries_canonical_scaled_infKappa_eq_perron
    {n : ℕ} (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hApos : ∀ i j : Fin n, 0 < absMatrix n A i j)
    (hAinvpos : ∀ i j : Fin n, 0 < absMatrix n A_inv i j)
    (hx : ∀ i : Fin n, 0 < x i)
    (heig : ∀ i : Fin n,
      matMulVec n (matMul n (absMatrix n A) (absMatrix n A_inv)) x i =
        ρ * x i) :
    ch7TwoSidedScaledInfKappa A A_inv
        (fun i => (x i)⁻¹) x
        (fun i => matMulVec n (absMatrix n A_inv) x i)
        (fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹) =
      ρ := by
  rw [ch7TwoSidedScaledInfKappa_eq_abs_scaledInfCond hn A A_inv
    (fun i => (x i)⁻¹) x
    (fun i => matMulVec n (absMatrix n A_inv) x i)
    (fun i => (matMulVec n (absMatrix n A_inv) x i)⁻¹)
    (fun i => inv_nonneg.mpr (le_of_lt (hx i)))
    (fun i => le_of_lt (hx i))
    (fun i => le_of_lt (ch7_bauer_Cx_pos_of_pos hn (absMatrix n A_inv) x hAinvpos hx i))
    (fun i => inv_nonneg.mpr
      (le_of_lt (ch7_bauer_Cx_pos_of_pos hn (absMatrix n A_inv) x hAinvpos hx i)))]
