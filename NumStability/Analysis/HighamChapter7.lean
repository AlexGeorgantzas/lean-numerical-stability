-- ============================================================
-- Problem 7.10(e): one-norm Bauer transpose reductions
-- ============================================================

/-- The one-norm product in Problem 7.10(e), with inverse diagonal entries
supplied separately.  It is the transpose analogue of
`ch7TwoSidedScaledInfCond`. -/
noncomputable def ch7TwoSidedScaledOneCond {n : ℕ}
    (B C : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) : ℝ :=
  oneNorm (ch7TwoSidedScale d₁ B d₂) *
    oneNorm (ch7TwoSidedScale d₂Inv C d₁Inv)

/-- Problem 7.10(e)'s source reduction `‖M‖₁ = ‖Mᵀ‖∞` for the two-sided
Bauer product. -/
lemma ch7TwoSidedScaledOneCond_eq_transpose_infCond {n : ℕ}
    (B C : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) :
    ch7TwoSidedScaledOneCond B C d₁ d₁Inv d₂ d₂Inv =
      ch7TwoSidedScaledInfCond (matTranspose B) (matTranspose C)
        d₂ d₂Inv d₁ d₁Inv := by
  unfold ch7TwoSidedScaledOneCond ch7TwoSidedScaledInfCond oneNorm
  rw [show (fun i j => ch7TwoSidedScale d₁ B d₂ j i) =
      ch7TwoSidedScale d₂ (matTranspose B) d₁ by
        change matTranspose (ch7TwoSidedScale d₁ B d₂) =
          ch7TwoSidedScale d₂ (matTranspose B) d₁
        rw [ch7_matTranspose_twoSidedScale],
    show (fun i j => ch7TwoSidedScale d₂Inv C d₁Inv j i) =
      ch7TwoSidedScale d₁Inv (matTranspose C) d₂Inv by
        change matTranspose (ch7TwoSidedScale d₂Inv C d₁Inv) =
          ch7TwoSidedScale d₁Inv (matTranspose C) d₂Inv
        rw [ch7_matTranspose_twoSidedScale]]

/-- Problem 7.10(e), one-norm lower-bound half under an explicit positive
Perron-vector certificate for `BᵀCᵀ`.  This is the source transpose reduction
from the proved infinity-norm Bauer core. -/
theorem problem7_10e_scaled_oneCond_ge_perron_of_transpose_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (y : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hy : ∀ i : Fin n, 0 < y i)
    (heigT : ∀ i : Fin n,
      matMulVec n (matMul n (matTranspose B) (matTranspose C)) y i = ρ * y i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ρ ≤ ch7TwoSidedScaledOneCond B C d₁ d₁Inv d₂ d₂Inv := by
  rw [ch7TwoSidedScaledOneCond_eq_transpose_infCond B C d₁ d₁Inv d₂ d₂Inv]
  exact problem7_10a_scaled_infCond_ge_perron_of_positive_eigenvector
    hn (matTranspose B) (matTranspose C) ρ y
    (by intro i j; exact hB j i)
    (by intro i j; exact hC j i)
    hy heigT d₂ d₂Inv d₁ d₁Inv
    hd₂pos hd₂Invpos hd₁pos hd₁Invpos hd₂ hd₁

/-- Problem 7.10(e), one-norm lower-bound half under a positive
subeigenvector for the transpose product `BᵀCᵀ`. -/
theorem problem7_10e_scaled_oneCond_ge_perron_of_transpose_positive_subeigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (y : Fin n → ℝ)
    (hρ : 0 ≤ ρ)
    (hy : ∀ i : Fin n, 0 < y i)
    (hsubT : ∀ i : Fin n,
      ρ * y i ≤
        matMulVec n (matMul n (matTranspose B) (matTranspose C)) y i)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ρ ≤ ch7TwoSidedScaledOneCond B C d₁ d₁Inv d₂ d₂Inv := by
  rw [ch7TwoSidedScaledOneCond_eq_transpose_infCond B C d₁ d₁Inv d₂ d₂Inv]
  exact problem7_10a_scaled_infCond_ge_perron_of_positive_subeigenvector
    hn (matTranspose B) (matTranspose C) ρ y hρ hy hsubT
    d₂ d₂Inv d₁ d₁Inv
    hd₂pos hd₂Invpos hd₁pos hd₁Invpos hd₂ hd₁

/-- Problem 7.10(e), canonical one-norm Bauer scaling under an explicit
positive Perron-vector certificate for `BᵀCᵀ`.  The diagonal choice is the
transpose-side version of the scaling in Problem 7.10(a). -/
theorem problem7_10e_canonical_scaled_oneCond_eq_perron_of_transpose_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (y : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
    (hC : ∀ i j : Fin n, 0 ≤ C i j)
    (hy : ∀ i : Fin n, 0 < y i)
    (hCt_y : ∀ i : Fin n, 0 < matMulVec n (matTranspose C) y i)
    (heigT : ∀ i : Fin n,
      matMulVec n (matMul n (matTranspose B) (matTranspose C)) y i = ρ * y i) :
    ch7TwoSidedScaledOneCond B C
        (fun i => matMulVec n (matTranspose C) y i)
        (fun i => (matMulVec n (matTranspose C) y i)⁻¹)
        (fun i => (y i)⁻¹) y = ρ := by
  rw [ch7TwoSidedScaledOneCond_eq_transpose_infCond]
  exact problem7_10a_canonical_scaled_infCond_eq_perron_of_positive_eigenvector
    hn (matTranspose B) (matTranspose C) ρ y
    (by intro i j; exact hB j i)
    (by intro i j; exact hC j i)
    hy hCt_y heigT

/-- Problem 7.10(e), positive-entry wrapper for the canonical one-norm Bauer
scaling under a transpose-side positive Perron-vector certificate. -/
theorem problem7_10e_positive_entries_canonical_scaled_oneCond_eq_perron_of_transpose
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (y : Fin n → ℝ)
    (hBpos : ∀ i j : Fin n, 0 < B i j)
    (hCpos : ∀ i j : Fin n, 0 < C i j)
    (hy : ∀ i : Fin n, 0 < y i)
    (heigT : ∀ i : Fin n,
      matMulVec n (matMul n (matTranspose B) (matTranspose C)) y i = ρ * y i) :
    ch7TwoSidedScaledOneCond B C
        (fun i => matMulVec n (matTranspose C) y i)
        (fun i => (matMulVec n (matTranspose C) y i)⁻¹)
        (fun i => (y i)⁻¹) y = ρ :=
  problem7_10e_canonical_scaled_oneCond_eq_perron_of_transpose_positive_eigenvector
    hn B C ρ y
    (fun i j => le_of_lt (hBpos i j))
    (fun i j => le_of_lt (hCpos i j))
    hy
    (ch7_bauer_Cx_pos_of_pos hn (matTranspose C) y
      (fun i j => hCpos j i) hy)
    heigT

/-- The one-norm condition product for the two-sidedly scaled matrix
`D₁ A D₂`, with the inverse-scaled partner `D₂⁻¹ A_inv D₁⁻¹` supplied
entrywise. -/
noncomputable def ch7TwoSidedScaledOneKappa {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ) : ℝ :=
  oneNorm (ch7TwoSidedScale d₁ A d₂) *
    oneNorm (ch7TwoSidedScale d₂Inv A_inv d₁Inv)

/-- Problem 7.10(e)'s one-norm condition-product values over positive
reciprocal two-sided diagonal scalings, represented with an explicit
inverse-side matrix `A_inv`. -/
noncomputable def ch7TwoSidedScaledOneKappaSet {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ,
    (∀ i : Fin n, 0 < d₁ i) ∧
    (∀ i : Fin n, 0 < d₁Inv i) ∧
    (∀ i : Fin n, 0 < d₂ i) ∧
    (∀ i : Fin n, 0 < d₂Inv i) ∧
    (∀ i : Fin n, d₁ i * d₁Inv i = 1) ∧
    (∀ i : Fin n, d₂ i * d₂Inv i = 1) ∧
    κ = ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv}

/-- Membership helper for the positive two-sided one-norm condition-product
value set. -/
theorem ch7TwoSidedScaledOneKappa_mem_set {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ)
    (d₁ d₁Inv d₂ d₂Inv : Fin n → ℝ)
    (hd₁pos : ∀ i : Fin n, 0 < d₁ i)
    (hd₁Invpos : ∀ i : Fin n, 0 < d₁Inv i)
    (hd₂pos : ∀ i : Fin n, 0 < d₂ i)
    (hd₂Invpos : ∀ i : Fin n, 0 < d₂Inv i)
    (hd₁ : ∀ i : Fin n, d₁ i * d₁Inv i = 1)
    (hd₂ : ∀ i : Fin n, d₂ i * d₂Inv i = 1) :
    ch7TwoSidedScaledOneKappa A A_inv d₁ d₁Inv d₂ d₂Inv ∈
      ch7TwoSidedScaledOneKappaSet A A_inv := by
  refine ⟨d₁, d₁Inv, d₂, d₂Inv,
    hd₁pos, hd₁Invpos, hd₂pos, hd₂Invpos, hd₁, hd₂, ?_⟩
  rfl

/-- The positive one-norm condition-product scaling value set is nonempty by
the identity scaling. -/
theorem ch7TwoSidedScaledOneKappaSet_nonempty {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    (ch7TwoSidedScaledOneKappaSet A A_inv).Nonempty := by
  refine ⟨oneNorm A * oneNorm A_inv, ?_⟩
  refine ⟨fun _ => 1, fun _ => 1, fun _ => 1, fun _ => 1,
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num),
    (by intro i; norm_num), (by intro i; norm_num), ?_⟩
  have hA :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) A
        (fun _ : Fin n => (1 : ℝ)) = A := by
    ext i j
    simp [ch7TwoSidedScale]
  have hAinv :
      ch7TwoSidedScale (fun _ : Fin n => (1 : ℝ)) A_inv
        (fun _ : Fin n => (1 : ℝ)) = A_inv := by
    ext i j
    simp [ch7TwoSidedScale]
  simp [ch7TwoSidedScaledOneKappa, hA, hAinv]

/-- The positive one-norm condition-product scaling value set is bounded below
by zero. -/
theorem ch7TwoSidedScaledOneKappaSet_bddBelow {n : ℕ}
    (A A_inv : Fin n → Fin n → ℝ) :
    BddBelow (ch7TwoSidedScaledOneKappaSet A A_inv) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with
    ⟨d₁, d₁Inv, d₂, d₂Inv, _hd₁pos, _hd₁Invpos,
