  obtain ⟨Aplus, hleft⟩ :=
    ch7_exists_rect_left_inverse_of_rectMatMulVec_injective A hA
  exact ⟨Aplus, hleft,
    theorem7_5_p1_column_equilibration_isLeast_right_scalings_of_rect_left_inverse
      A Aplus hleft⟩

/-- Theorem 7.5, `p = 2` column infimum form with full-column-rank supplied
