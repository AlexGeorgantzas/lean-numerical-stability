      hm A Aplus hright hmin⟩

/-- Rectangular row 1-norm, the row-equilibration norm used by the
`p = ∞` specialization of Theorem 7.5 via the duality argument leading to
equation `(7.19)`. -/
noncomputable def ch7RectRowNorm1 {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (i : Fin m) : ℝ :=
  ∑ j : Fin n, |A i j|

/-- The row-equilibrating reciprocal scale for the matrix infinity norm:
`d_i = 1 / ‖A(i,:)‖₁`. -/
noncomputable def ch7RowEquilibratingScale1Rect {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (i : Fin m) : ℝ :=
  1 / ch7RectRowNorm1 A i

lemma ch7RectRowNorm1_nonneg {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (i : Fin m) :
    0 ≤ ch7RectRowNorm1 A i := by
  unfold ch7RectRowNorm1
  exact Finset.sum_nonneg fun j _ => abs_nonneg (A i j)

/-- Full-row-rank side condition for the `p = ∞` row route in Theorem 7.5,
stated with an explicit rectangular right inverse. -/
lemma ch7RectRowNorm1_pos_of_rect_right_inverse {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hright : ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0)
    (i : Fin m) :
    0 < ch7RectRowNorm1 A i := by
  have hne : ch7RectRowNorm1 A i ≠ 0 := by
    intro hzero
    have hsum :
        (∑ k : Fin n, |A i k|) = 0 := by
      simpa [ch7RectRowNorm1] using hzero
    have hterms :
        ∀ k ∈ (Finset.univ : Finset (Fin n)), |A i k| = 0 :=
      (Finset.sum_eq_zero_iff_of_nonneg (s := Finset.univ)
        (fun k _ => abs_nonneg (A i k))).mp hsum
    have hentries : ∀ k : Fin n, A i k = 0 := by
      intro k
      exact abs_eq_zero.mp (hterms k (Finset.mem_univ k))
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hright i i
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectRowNorm1_nonneg A i) (Ne.symm hne)

lemma ch7RectLeftScale_row_sum_abs {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (d : Fin m → ℝ) (i : Fin m) :
    (∑ j : Fin n, |ch7RectLeftScale d A i j|) =
      |d i| * ch7RectRowNorm1 A i := by
  unfold ch7RectLeftScale ch7RectRowNorm1
  calc
    (∑ j : Fin n, |d i * A i j|)
        = ∑ j : Fin n, |d i| * |A i j| := by
          apply Finset.sum_congr rfl
          intro j _
          rw [abs_mul]
    _ = |d i| * ∑ j : Fin n, |A i j| := by
          rw [Finset.mul_sum]

lemma ch7RectRowNorm1_leftScale_equilibrating {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm1 A i) (i : Fin m) :
    (∑ j : Fin n,
        |ch7RectLeftScale (ch7RowEquilibratingScale1Rect A) A i j|) = 1 := by
  rw [ch7RectLeftScale_row_sum_abs]
  unfold ch7RowEquilibratingScale1Rect
  rw [abs_of_pos (one_div_pos.mpr (hrow i))]
  field_simp [ne_of_gt (hrow i)]

/-- Equation `(7.19)`, `p = ∞` source specialization of the first matrix-norm
factor: after scaling every nonzero row of `A` to row 1-norm one, the
rectangular matrix infinity norm is at most one. -/
theorem eq_7_19_infNormRect_row_equilibrated {m n : ℕ}
    (A : Fin m → Fin n → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm1 A i) :
    infNormRect (ch7RectLeftScale (ch7RowEquilibratingScale1Rect A) A) ≤ 1 := by
  apply infNormRect_le_of_row_sum_le
  · intro i
    rw [ch7RectRowNorm1_leftScale_equilibrating A hrow i]
  · norm_num

/-- Infinity-norm condition-product for the left-scaled rectangular matrix and
the corresponding inverse-side factor.  In the source this is
`‖DA‖∞ ‖A⁺D⁻¹‖∞`; the matrix `Aplus` is kept explicit so this algebraic
scaling step does not assert a Moore-Penrose construction. -/
noncomputable def ch7InfNormLeftScaledCond {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) : ℝ :=
  infNormRect (ch7RectLeftScale d A) *
    infNormRect (ch7RectRightScale Aplus dInv)

/-- Values of the explicit infinity-norm condition product
`‖DA‖∞ ‖A⁺D⁻¹‖∞` over reciprocal nonsingular diagonal left scalings.  This is
the infimum model for the `p = ∞` specialization of the source row-scaling
minimum in Theorem 7.5. -/
noncomputable def ch7InfNormLeftScaledCondSet {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin m → ℝ,
    (∀ i : Fin m, d i * dInv i = 1) ∧
    κ = ch7InfNormLeftScaledCond A Aplus d dInv}

/-- Membership helper for the infinity-norm left-scaling value set. -/
theorem ch7InfNormLeftScaledCond_mem_set {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    ch7InfNormLeftScaledCond A Aplus d dInv ∈
      ch7InfNormLeftScaledCondSet A Aplus := by
  exact ⟨d, dInv, hdiag, rfl⟩

/-- Equation `(7.19)`, `p = ∞` inverse-side algebraic core.  This is the
row-scaled analogue of `(7.22)`: it uses only row-sum norm algebra and the
inverse diagonal relation `d_i d_i^{-1} = 1`. -/
theorem eq_7_19_infNormRect_inverseSide_bound {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    infNormRect
        (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm1 A i)) ≤
      infNormRect (ch7RectLeftScale d A) *
        infNormRect (ch7RectRightScale Aplus dInv) := by
  apply infNormRect_le_of_row_sum_le
  · intro k
    have hDA_nonneg : 0 ≤ infNormRect (ch7RectLeftScale d A) :=
      infNormRect_nonneg _
    have hrowBound :
        ∀ i : Fin m,
          |d i| * ch7RectRowNorm1 A i ≤
            infNormRect (ch7RectLeftScale d A) := by
      intro i
      rw [← ch7RectLeftScale_row_sum_abs A d i]
      exact row_sum_le_infNormRect (ch7RectLeftScale d A) i
    calc
      (∑ i : Fin m,
          |ch7RectRightScale Aplus
            (fun i : Fin m => ch7RectRowNorm1 A i) k i|)
          = ∑ i : Fin m,
              (|d i| * ch7RectRowNorm1 A i) *
                |ch7RectRightScale Aplus dInv k i| := by
            apply Finset.sum_congr rfl
            intro i _
            unfold ch7RectRightScale
            have hprod :
                Aplus k i * ch7RectRowNorm1 A i =
                  (Aplus k i * dInv i) *
                    (d i * ch7RectRowNorm1 A i) := by
              calc
                Aplus k i * ch7RectRowNorm1 A i =
                    (d i * dInv i) *
                      (Aplus k i * ch7RectRowNorm1 A i) := by
                      rw [hdiag i]
                      ring
                _ = (Aplus k i * dInv i) *
                    (d i * ch7RectRowNorm1 A i) := by
                      ring
            rw [hprod, abs_mul, abs_mul, abs_mul,
              abs_of_nonneg (ch7RectRowNorm1_nonneg A i)]
            ring
      _ ≤ ∑ i : Fin m,
              infNormRect (ch7RectLeftScale d A) *
                |ch7RectRightScale Aplus dInv k i| := by
            apply Finset.sum_le_sum
            intro i _
            exact mul_le_mul_of_nonneg_right
              (hrowBound i) (abs_nonneg _)
      _ = infNormRect (ch7RectLeftScale d A) *
            ∑ i : Fin m, |ch7RectRightScale Aplus dInv k i| := by
            rw [Finset.mul_sum]
      _ ≤ infNormRect (ch7RectLeftScale d A) *
            infNormRect (ch7RectRightScale Aplus dInv) :=
          mul_le_mul_of_nonneg_left
            (row_sum_le_infNormRect (ch7RectRightScale Aplus dInv) k)
            hDA_nonneg
  · exact mul_nonneg (infNormRect_nonneg _)
      (infNormRect_nonneg _)

/-- Theorem 7.5, equation `(7.19)`, `p = ∞` pairwise row-scaling
specialization.  Row equilibration has no larger infinity-norm condition
product than any nonsingular diagonal row scaling, once the inverse-side matrix
`Aplus` is fixed. -/
theorem theorem7_5_pinf_row_equilibration_le_left_scaling {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm1 A i)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    ch7InfNormLeftScaledCond A Aplus
        (ch7RowEquilibratingScale1Rect A)
        (fun i : Fin m => ch7RectRowNorm1 A i) ≤
      ch7InfNormLeftScaledCond A Aplus d dInv := by
  unfold ch7InfNormLeftScaledCond
  have hDAc :
      infNormRect (ch7RectLeftScale (ch7RowEquilibratingScale1Rect A) A) ≤ 1 :=
    eq_7_19_infNormRect_row_equilibrated A hrow
  have hside :
      infNormRect
          (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm1 A i)) ≤
        infNormRect (ch7RectLeftScale d A) *
          infNormRect (ch7RectRightScale Aplus dInv) :=
    eq_7_19_infNormRect_inverseSide_bound A Aplus d dInv hdiag
  calc
    infNormRect (ch7RectLeftScale (ch7RowEquilibratingScale1Rect A) A) *
        infNormRect
          (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm1 A i))
        ≤ 1 *
            infNormRect
              (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm1 A i)) :=
          mul_le_mul_of_nonneg_right hDAc (infNormRect_nonneg _)
    _ = infNormRect
          (ch7RectRightScale Aplus (fun i : Fin m => ch7RectRowNorm1 A i)) := by
          ring
    _ ≤ infNormRect (ch7RectLeftScale d A) *
          infNormRect (ch7RectRightScale Aplus dInv) := hside

/-- Theorem 7.5, `p = ∞` infimum form over all reciprocal diagonal left
scalings for the explicit condition product `‖DA‖∞ ‖A⁺D⁻¹‖∞`.  This packages
the pairwise row-scaling inequality as the source minimum/infimum statement
for this specialized model. -/
theorem theorem7_5_pinf_row_equilibration_sInf_eq_left_scalings {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm1 A i) :
    sInf (ch7InfNormLeftScaledCondSet A Aplus) =
      ch7InfNormLeftScaledCond A Aplus
        (ch7RowEquilibratingScale1Rect A)
        (fun i : Fin m => ch7RectRowNorm1 A i) := by
  let c : ℝ :=
    ch7InfNormLeftScaledCond A Aplus
      (ch7RowEquilibratingScale1Rect A)
      (fun i : Fin m => ch7RectRowNorm1 A i)
  let S : Set ℝ := ch7InfNormLeftScaledCondSet A Aplus
  have hdiagR :
      ∀ i : Fin m,
        ch7RowEquilibratingScale1Rect A i *
          ch7RectRowNorm1 A i = 1 := by
    intro i
    unfold ch7RowEquilibratingScale1Rect
    field_simp [ne_of_gt (hrow i)]
  have hmem : c ∈ S := by
    dsimp [c, S]
    exact ch7InfNormLeftScaledCond_mem_set A Aplus
      (ch7RowEquilibratingScale1Rect A)
      (fun i : Fin m => ch7RectRowNorm1 A i) hdiagR
  have hS_nonempty : S.Nonempty := ⟨c, hmem⟩
  have hlower : ∀ κ : ℝ, κ ∈ S → c ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    exact theorem7_5_pinf_row_equilibration_le_left_scaling
      A Aplus hrow d dInv hdiag
  have hbddBelow : BddBelow S := ⟨c, hlower⟩
  change sInf S = c
  exact le_antisymm (csInf_le hbddBelow hmem) (le_csInf hS_nonempty hlower)

/-- Theorem 7.5, `p = ∞` minimum-attainment form over all reciprocal left
diagonal scalings in the explicit `Aplus` model.  The equilibrating row
scaling is a genuine least element of the condition-product value set, not
only an infimum value. -/
theorem theorem7_5_pinf_row_equilibration_isLeast_left_scalings {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowNorm1 A i) :
    IsLeast (ch7InfNormLeftScaledCondSet A Aplus)
      (ch7InfNormLeftScaledCond A Aplus
        (ch7RowEquilibratingScale1Rect A)
        (fun i : Fin m => ch7RectRowNorm1 A i)) := by
  constructor
  · exact ch7InfNormLeftScaledCond_mem_set A Aplus
      (ch7RowEquilibratingScale1Rect A)
      (fun i : Fin m => ch7RectRowNorm1 A i) (by
        intro i
        unfold ch7RowEquilibratingScale1Rect
        field_simp [ne_of_gt (hrow i)])
  · intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    exact theorem7_5_pinf_row_equilibration_le_left_scaling
      A Aplus hrow d dInv hdiag

/-- Theorem 7.5, `p = ∞` row minimum-attainment form with the source
full-row-rank side condition discharged by an explicit rectangular right
inverse witness `A Aplus = I`. -/
theorem theorem7_5_pinf_row_equilibration_isLeast_left_scalings_of_rect_right_inverse
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hright : ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0) :
    IsLeast (ch7InfNormLeftScaledCondSet A Aplus)
      (ch7InfNormLeftScaledCond A Aplus
        (ch7RowEquilibratingScale1Rect A)
        (fun i : Fin m => ch7RectRowNorm1 A i)) := by
  exact theorem7_5_pinf_row_equilibration_isLeast_left_scalings A Aplus
    (ch7RectRowNorm1_pos_of_rect_right_inverse A Aplus hright)

/-- The `2 × 2` matrix used to audit the printed row-scale notation in
Theorem 7.5 at `p = ∞`.  Each row has maximum absolute entry one, so a literal
reading of `‖A(i,:)‖_∞` would choose the identity row scaling. -/
noncomputable def theorem7_5_literalRowInfCounterexampleA (i j : Fin 2) : ℝ :=
  if i = 0 then 1 else if j = 0 then (1 / 10 : ℝ) else 1

/-- The inverse-side witness for `theorem7_5_literalRowInfCounterexampleA`. -/
noncomputable def theorem7_5_literalRowInfCounterexampleAplus (i j : Fin 2) : ℝ :=
  if i = 0 then
    if j = 0 then (10 / 9 : ℝ) else (-10 / 9 : ℝ)
  else
    if j = 0 then (-1 / 9 : ℝ) else (10 / 9 : ℝ)

/-- Identity row scaling, the scaling selected by the literal row-`∞` reading
for `theorem7_5_literalRowInfCounterexampleA`. -/
def theorem7_5_literalRowInfCounterexampleIdentityScale : Fin 2 → ℝ :=
  fun _ => 1

/-- A better reciprocal row scaling for the literal row-`∞` counterexample. -/
noncomputable def theorem7_5_literalRowInfCounterexampleBetterScale (i : Fin 2) :
    ℝ :=
  if i = 0 then 1 else (20 / 11 : ℝ)

/-- The inverse diagonal scale paired with
`theorem7_5_literalRowInfCounterexampleBetterScale`. -/
noncomputable def theorem7_5_literalRowInfCounterexampleBetterInvScale
