-- Theorem 7.4, relative infinity-norm form of (7.10)
-- ============================================================

/-- Higham Theorem 7.4 / equation (7.10) in arbitrary absolute-norm form
    over complex matrices.

    If `Ax = b`, `(A + ΔA)y = b + Δb`, `|ΔA| <= ε |E|`, `|Δb| <= ε |f|`, and
    `ε || |A⁻¹| |E| || < 1` in an absolute norm `ν`, then
    `ν (x-y) / ν x <= ε / (1 - ε || |A⁻¹| |E| ||) *
      ν (|A⁻¹| (|E| |x| + |f|)) / ν x`. -/
theorem theorem7_4_absolute_forward_error_bound
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    (habs : IsAbsoluteComplexVectorNorm ν)
    {A Ainv E ΔA : CMatrix n n}
    {x y b f Δb : CVec n} {ε m : ℝ}
    (hε : 0 ≤ ε)
    (hM : IsMixedSubordinateMatrixNormValue ν ν
      (complexMatrixMul (complexAbsMatrix Ainv) (complexAbsMatrix E)) m)
    (hΔA : ∀ i j, ‖ΔA i j‖ ≤ ε * ‖E i j‖)
    (hΔb : ∀ i, ‖Δb i‖ ≤ ε * ‖f i‖)
    (hInv : IsComplexMatrixLeftInverse A Ainv)
    (hAx : complexMatrixVecMul A x = b)
    (hPerturbed : complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
      fun i => b i + Δb i)
    (hεm : ε * m < 1) (hx : 0 < ν x) :
    ν (fun i => x i - y i) / ν x ≤
      ε / (1 - ε * m) *
        (ν (complexMatrixVecMul (complexAbsMatrix Ainv)
              (complexVecAdd
                (complexMatrixVecMul (complexAbsMatrix E) (complexAbsVec x))
                (complexAbsVec f))) / ν x) := by
  have hmono : IsMonotoneComplexVectorNorm ν :=
    (absolute_norm_iff_monotone_norm hν).mp habs
  have hm_nonneg : 0 ≤ m :=
    mixedSubordinateMatrixNormValue_nonneg_of_nonempty hn hν hν hM
  have hadd_norm :
      ∀ {u v : CVec n},
        complexAbsVec u = u →
        complexAbsVec v = v →
        ∀ i : Fin n, ‖complexVecAdd u v i‖ = ‖u i‖ + ‖v i‖ := by
    intro u v hu hv i
    have hu' : u i = ((‖u i‖ : ℝ) : ℂ) := by
      simpa [complexAbsVec] using (congrFun hu i).symm
    have hv' : v i = ((‖v i‖ : ℝ) : ℂ) := by
      simpa [complexAbsVec] using (congrFun hv i).symm
    have hsum : 0 ≤ ‖u i‖ + ‖v i‖ :=
      add_nonneg (norm_nonneg _) (norm_nonneg _)
    calc
      ‖complexVecAdd u v i‖ = ‖(((‖u i‖ + ‖v i‖ : ℝ) : ℂ))‖ := by
            rw [complexVecAdd, hu', hv']
            simp [Complex.ofReal_add]
      _ = ‖u i‖ + ‖v i‖ := Complex.norm_of_nonneg hsum
  have hadd_abs :
      ∀ {u v : CVec n},
        complexAbsVec u = u →
        complexAbsVec v = v →
        complexAbsVec (complexVecAdd u v) = complexVecAdd u v := by
    intro u v hu hv
    ext i
    have hu' : u i = ((‖u i‖ : ℝ) : ℂ) := by
      simpa [complexAbsVec] using (congrFun hu i).symm
    have hv' : v i = ((‖v i‖ : ℝ) : ℂ) := by
      simpa [complexAbsVec] using (congrFun hv i).symm
    calc
      complexAbsVec (complexVecAdd u v) i
          = ((‖complexVecAdd u v i‖ : ℝ) : ℂ) := by rfl
      _ = (((‖u i‖ + ‖v i‖ : ℝ) : ℂ)) := by rw [hadd_norm hu hv i]
      _ = complexVecAdd u v i := by
            rw [complexVecAdd, hu', hv']
            simp [Complex.ofReal_add]
  have h_abs_row :
      ∀ (B : CMatrix n n) (u : CVec n), complexAbsVec u = u →
        ∀ i : Fin n, ‖complexMatrixVecMul (complexAbsMatrix B) u i‖ =
          Finset.univ.sum (fun j : Fin n => ‖B i j‖ * ‖u j‖) := by
    intro B u hu i
    calc
      ‖complexMatrixVecMul (complexAbsMatrix B) u i‖
          = ‖complexMatrixVecMul (complexAbsMatrix B) (complexAbsVec u) i‖ := by
              rw [hu]
      _ = Finset.univ.sum (fun j : Fin n => ‖B i j‖ * ‖u j‖) := by
              exact complexMatrixVecMul_absMatrix_absVec_norm_apply B u i
  let d : CVec n := fun i => x i - y i
  let r : CVec n := fun i => complexMatrixVecMul ΔA y i - Δb i
  let Ey : CVec n := complexMatrixVecMul (complexAbsMatrix E) (complexAbsVec y)
  let Ex : CVec n := complexMatrixVecMul (complexAbsMatrix E) (complexAbsVec x)
  let Ed : CVec n := complexMatrixVecMul (complexAbsMatrix E) (complexAbsVec d)
  let gy : CVec n := complexVecAdd Ey (complexAbsVec f)
  let gx : CVec n := complexVecAdd Ex (complexAbsVec f)
  let z : CVec n := complexMatrixVecMul (complexAbsMatrix Ainv) gy
  let w : CVec n := complexMatrixVecMul (complexAbsMatrix Ainv) gx
  let Bd : CVec n :=
    complexMatrixVecMul
      (complexMatrixMul (complexAbsMatrix Ainv) (complexAbsMatrix E))
      (complexAbsVec d)
  let δ : ℝ := ν d
  have hEy_abs : complexAbsVec Ey = Ey := by
    simp [Ey]
  have hEx_abs : complexAbsVec Ex = Ex := by
    simp [Ex]
  have hEd_abs : complexAbsVec Ed = Ed := by
    simp [Ed]
  have hgy_abs : complexAbsVec gy = gy := by
    simpa [gy] using hadd_abs hEy_abs (complexAbsVec_idem f)
  have hgx_abs : complexAbsVec gx = gx := by
    simpa [gx] using hadd_abs hEx_abs (complexAbsVec_idem f)
  have hBd_eq : Bd = complexMatrixVecMul (complexAbsMatrix Ainv) Ed := by
    ext i
    dsimp [Bd, Ed]
    rw [complexMatrixVecMul_mul]
  have hw_abs : complexAbsVec w = w := by
    simpa [w, hgx_abs] using
      complexAbsVec_complexMatrixVecMul_absMatrix_absVec Ainv gx
  have hBd_abs : complexAbsVec Bd = Bd := by
    rw [hBd_eq]
    simpa [hEd_abs] using
      complexAbsVec_complexMatrixVecMul_absMatrix_absVec Ainv Ed
  have hres : complexMatrixVecMul A d = r := by
    ext i
    have hAxi := congrFun hAx i
    have hPerti := congrFun hPerturbed i
    unfold complexMatrixVecMul at hAxi hPerti ⊢
    rw [← hAxi] at hPerti
    simp_rw [add_mul, Finset.sum_add_distrib] at hPerti
    have hmain :
        (∑ j : Fin n, A i j * x j) - (∑ j : Fin n, A i j * y j) =
          (∑ j : Fin n, ΔA i j * y j) - Δb i := by
      calc
        (∑ j : Fin n, A i j * x j) - (∑ j : Fin n, A i j * y j)
            = (((∑ j : Fin n, A i j * x j) + Δb i) - Δb i) -
                (∑ j : Fin n, A i j * y j) := by ring
        _ = (((∑ j : Fin n, A i j * y j) + ∑ j : Fin n, ΔA i j * y j) - Δb i) -
              (∑ j : Fin n, A i j * y j) := by rw [← hPerti]
        _ = (∑ j : Fin n, ΔA i j * y j) - Δb i := by ring
    simpa [d, r, complexMatrixVecMul, mul_sub, Finset.sum_sub_distrib] using hmain
  have hxy : d = complexMatrixVecMul Ainv r := by
    calc
      d = complexMatrixVecMul Ainv (complexMatrixVecMul A d) := by
            symm
            exact hInv d
      _ = complexMatrixVecMul Ainv r := by rw [hres]
  have hδ0 :
      δ ≤ ν (complexMatrixVecMul (complexAbsMatrix Ainv) (complexAbsVec r)) := by
    have hcomp :
        componentwiseAbsLe d
          (complexMatrixVecMul (complexAbsMatrix Ainv) (complexAbsVec r)) := by
      simpa [hxy] using complexMatrixVecMul_componentwiseAbsLe_absMatrix Ainv r
    simpa [δ] using hmono d _ hcomp
  have hgy_norm : ∀ j : Fin n, ‖gy j‖ = ‖Ey j‖ + ‖f j‖ := by
    intro j
    simpa [gy] using hadd_norm hEy_abs (complexAbsVec_idem f) j
  have hgx_norm : ∀ j : Fin n, ‖gx j‖ = ‖Ex j‖ + ‖f j‖ := by
    intro j
    simpa [gx] using hadd_norm hEx_abs (complexAbsVec_idem f) j
  have h_rj : ∀ j : Fin n, ‖r j‖ ≤ ε * ‖gy j‖ := by
    intro j
    have hΔAy : ‖complexMatrixVecMul ΔA y j‖ ≤ ε * ‖Ey j‖ := by
      calc
        ‖complexMatrixVecMul ΔA y j‖
            ≤ ‖complexMatrixVecMul (complexAbsMatrix ΔA) (complexAbsVec y) j‖ :=
              complexMatrixVecMul_componentwiseAbsLe_absMatrix ΔA y j
        _ = Finset.univ.sum (fun k : Fin n => ‖ΔA j k‖ * ‖y k‖) := by
              exact complexMatrixVecMul_absMatrix_absVec_norm_apply ΔA y j
        _ ≤ Finset.univ.sum (fun k : Fin n => (ε * ‖E j k‖) * ‖y k‖) := by
              apply Finset.sum_le_sum
              intro k _hk
              exact mul_le_mul_of_nonneg_right (hΔA j k) (norm_nonneg (y k))
        _ = ε * Finset.univ.sum (fun k : Fin n => ‖E j k‖ * ‖y k‖) := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro k _hk
              ring
        _ = ε * ‖Ey j‖ := by
              dsimp [Ey]
              rw [complexMatrixVecMul_absMatrix_absVec_norm_apply]
    calc
      ‖r j‖ = ‖complexMatrixVecMul ΔA y j - Δb j‖ := by rfl
      _ ≤ ‖complexMatrixVecMul ΔA y j‖ + ‖Δb j‖ := norm_sub_le _ _
      _ ≤ ε * ‖Ey j‖ + ε * ‖f j‖ := add_le_add hΔAy (hΔb j)
      _ = ε * ‖gy j‖ := by
            rw [hgy_norm j]
            ring
  have hz_bound : δ ≤ ε * ν z := by
    have hcomp :
        componentwiseAbsLe
          (complexMatrixVecMul (complexAbsMatrix Ainv) (complexAbsVec r))
          (complexVecSMul (ε : ℂ) z) := by
      intro i
      calc
        ‖complexMatrixVecMul (complexAbsMatrix Ainv) (complexAbsVec r) i‖
            = Finset.univ.sum (fun j : Fin n => ‖Ainv i j‖ * ‖r j‖) := by
                exact complexMatrixVecMul_absMatrix_absVec_norm_apply Ainv r i
        _ ≤ Finset.univ.sum (fun j : Fin n => ‖Ainv i j‖ * (ε * ‖gy j‖)) := by
              apply Finset.sum_le_sum
              intro j _hj
              exact mul_le_mul_of_nonneg_left (h_rj j) (norm_nonneg _)
        _ = ε * Finset.univ.sum (fun j : Fin n => ‖Ainv i j‖ * ‖gy j‖) := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro j _hj
              ring
        _ = ε * ‖z i‖ := by
              dsimp [z]
              rw [h_abs_row Ainv gy hgy_abs i]
        _ = ‖complexVecSMul (ε : ℂ) z i‖ := by
              simp [complexVecSMul, Complex.norm_real, Real.norm_eq_abs, abs_of_nonneg hε]
    calc
      δ ≤ ν (complexMatrixVecMul (complexAbsMatrix Ainv) (complexAbsVec r)) := hδ0
      _ ≤ ν (complexVecSMul (ε : ℂ) z) := hmono _ _ hcomp
      _ = ε * ν z := by
            rw [hν.smul]
            simp [Complex.norm_real, Real.norm_eq_abs, abs_of_nonneg hε]
  have hyk : ∀ k : Fin n, ‖y k‖ ≤ ‖x k‖ + ‖d k‖ := by
    intro k
    calc
      ‖y k‖ = ‖x k + (y k - x k)‖ := by ring_nf
      _ ≤ ‖x k‖ + ‖y k - x k‖ := norm_add_le _ _
      _ = ‖x k‖ + ‖d k‖ := by
            dsimp [d]
            rw [norm_sub_rev]
  have hEy_bound : ∀ j : Fin n, ‖Ey j‖ ≤ ‖Ex j‖ + ‖Ed j‖ := by
    intro j
    calc
      ‖Ey j‖ = Finset.univ.sum (fun k : Fin n => ‖E j k‖ * ‖y k‖) := by
            dsimp [Ey]
            rw [complexMatrixVecMul_absMatrix_absVec_norm_apply]
      _ ≤ Finset.univ.sum (fun k : Fin n => ‖E j k‖ * (‖x k‖ + ‖d k‖)) := by
            apply Finset.sum_le_sum
            intro k _hk
            exact mul_le_mul_of_nonneg_left (hyk k) (norm_nonneg _)
      _ = Finset.univ.sum (fun k : Fin n => ‖E j k‖ * ‖x k‖) +
            Finset.univ.sum (fun k : Fin n => ‖E j k‖ * ‖d k‖) := by
            simp_rw [mul_add, Finset.sum_add_distrib]
      _ = ‖Ex j‖ + ‖Ed j‖ := by
            dsimp [Ex, Ed]
            rw [complexMatrixVecMul_absMatrix_absVec_norm_apply,
              complexMatrixVecMul_absMatrix_absVec_norm_apply]
  have hgy_bound : ∀ j : Fin n, ‖gy j‖ ≤ ‖gx j‖ + ‖Ed j‖ := by
    intro j
    linarith [hgy_norm j, hgx_norm j, hEy_bound j]
  have hz_le : ν z ≤ ν (complexVecAdd w Bd) := by
    have hcomp : componentwiseAbsLe z (complexVecAdd w Bd) := by
      intro i
      calc
        ‖z i‖ = Finset.univ.sum (fun j : Fin n => ‖Ainv i j‖ * ‖gy j‖) := by
              dsimp [z]
              rw [h_abs_row Ainv gy hgy_abs i]
        _ ≤ Finset.univ.sum (fun j : Fin n => ‖Ainv i j‖ * (‖gx j‖ + ‖Ed j‖)) := by
              apply Finset.sum_le_sum
              intro j _hj
              exact mul_le_mul_of_nonneg_left (hgy_bound j) (norm_nonneg _)
        _ = (Finset.univ.sum (fun j : Fin n => ‖Ainv i j‖ * ‖gx j‖)) +
              (Finset.univ.sum (fun j : Fin n => ‖Ainv i j‖ * ‖Ed j‖)) := by
              simp_rw [mul_add, Finset.sum_add_distrib]
        _ = ‖w i‖ + ‖Bd i‖ := by
              dsimp [w]
              rw [h_abs_row Ainv gx hgx_abs i]
              rw [hBd_eq]
              rw [h_abs_row Ainv Ed hEd_abs i]
        _ = ‖complexVecAdd w Bd i‖ := by
              symm
              exact hadd_norm hw_abs hBd_abs i
    exact hmono _ _ hcomp
  have hBd_bound : ν Bd ≤ m * δ := by
    calc
      ν Bd ≤ m * ν (complexAbsVec d) := by
            simpa [Bd] using hM.1 (complexAbsVec d)
      _ = m * δ := by
            rw [habs d]
  have hδ :
      δ ≤ ε * (ν w + m * δ) := by
    calc
      δ ≤ ε * ν z := hz_bound
      _ ≤ ε * ν (complexVecAdd w Bd) := by
            exact mul_le_mul_of_nonneg_left hz_le hε
      _ ≤ ε * (ν w + ν Bd) := by
            exact mul_le_mul_of_nonneg_left (hν.add_le _ _) hε
      _ ≤ ε * (ν w + m * δ) := by
            exact mul_le_mul_of_nonneg_left
              (by simpa [add_comm, add_left_comm, add_assoc] using
                add_le_add_left hBd_bound (ν w))
              hε
  have hden_pos : 0 < 1 - ε * m := by
    nlinarith
  have hδ_bound :
      δ ≤ (ε * ν w) / (1 - ε * m) := by
    apply (le_div_iff₀ hden_pos).2
    nlinarith [hδ]
  have hx_ne : ν x ≠ 0 := ne_of_gt hx
  calc
    ν (fun i => x i - y i) / ν x = δ / ν x := by
      rfl
    _ ≤ ((ε * ν w) / (1 - ε * m)) / ν x :=
        div_le_div_of_nonneg_right hδ_bound (le_of_lt hx)
    _ = ε / (1 - ε * m) * (ν w / ν x) := by
        field_simp [hx_ne, ne_of_gt hden_pos]
    _ = ε / (1 - ε * m) *
        (ν (complexMatrixVecMul (complexAbsMatrix Ainv)
            (complexVecAdd
              (complexMatrixVecMul (complexAbsMatrix E) (complexAbsVec x))
              (complexAbsVec f))) / ν x) := by
        rfl

/-- Relative infinity-norm form of Higham Theorem 7.4/(7.10).

    This is the `∞`-norm specialization of the source statement, obtained from
    the componentwise exact theorem in `PerturbationTheory.lean` by taking a
    vector infinity norm and dividing by `‖x‖∞`. -/
theorem componentwise_forward_error_exact_relative_infNorm (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (ΔA : Fin n → Fin n → ℝ) (Δb : Fin n → ℝ)
    (E : Fin n → Fin n → ℝ) (f : Fin n → ℝ)
    (ε : ℝ) (hε : 0 ≤ ε)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * E i j)
    (hΔb : ∀ i, |Δb i| ≤ ε * f i)
    (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hPerturbed : ∀ i, ∑ j : Fin n, (A i j + ΔA i j) * y j = b i + Δb i)
    (M : ℝ) (hM : ∀ i, ∑ j : Fin n, |A_inv i j| * (∑ k : Fin n, E j k) ≤ M)
    (hεM : ε * M < 1) (hx : 0 < infNormVec x) :
    infNormVec (fun i => x i - y i) / infNormVec x ≤
      ε / (1 - ε * M) *
        (ch7ForwardBoundEF n hn A_inv E f x / infNormVec x) := by
  let C := ch7ForwardBoundEF n hn A_inv E f x
  have hcomp := componentwise_forward_error_exact n hn A A_inv x y b ΔA Δb E f
    ε hε hΔA hΔb hE hf hInv hAx hPerturbed M hM hεM
  have hC_nonneg : 0 ≤ C := ch7ForwardBoundEF_nonneg n hn A_inv E f x hE hf
  have hden_pos : 0 < 1 - ε * M := by linarith
  have hcoef_nonneg : 0 ≤ ε / (1 - ε * M) :=
    div_nonneg hε (le_of_lt hden_pos)
  have hB_nonneg : 0 ≤ ε / (1 - ε * M) * C :=
    mul_nonneg hcoef_nonneg hC_nonneg
  have hnorm :
      infNormVec (fun i => x i - y i) ≤ ε / (1 - ε * M) * C := by
    apply infNormVec_le_of_abs_le
    · intro i
      simpa [C, ch7ForwardBoundEF, ch7AmplifiedRhsEF] using hcomp i
    · exact hB_nonneg
  calc
    infNormVec (fun i => x i - y i) / infNormVec x
        ≤ (ε / (1 - ε * M) * C) / infNormVec x :=
          div_le_div_of_nonneg_right hnorm (le_of_lt hx)
    _ = ε / (1 - ε * M) * (C / infNormVec x) := by ring

/-- Standard `E = |A|`, `f = |b|` specialization of
    `componentwise_forward_error_exact_relative_infNorm`. -/
theorem normwise_forward_error_exact_relative_infNorm (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (ΔA : Fin n → Fin n → ℝ) (Δb : Fin n → ℝ)
    (ε : ℝ) (hε : 0 ≤ ε)
    (hΔA : ∀ i j, |ΔA i j| ≤ ε * |A i j|)
    (hΔb : ∀ i, |Δb i| ≤ ε * |b i|)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hPerturbed : ∀ i, ∑ j : Fin n, (A i j + ΔA i j) * y j = b i + Δb i)
    (M : ℝ) (hM : ∀ i, ∑ j : Fin n, |A_inv i j| * (∑ k : Fin n, |A j k|) ≤ M)
    (hεM : ε * M < 1) (hx : 0 < infNormVec x) :
    infNormVec (fun i => x i - y i) / infNormVec x ≤
      ε / (1 - ε * M) *
        (ch7ForwardBoundEF n hn A_inv (fun i j => |A i j|) (fun i => |b i|) x /
          infNormVec x) :=
  componentwise_forward_error_exact_relative_infNorm n hn A A_inv x y b ΔA Δb
    (fun i j => |A i j|) (fun i => |b i|) ε hε hΔA hΔb
    (fun _ _ => abs_nonneg _) (fun _ => abs_nonneg _) hInv hAx hPerturbed
    M hM hεM hx

-- ============================================================
-- Problem 7.2: residual/error sandwich in the infinity norm
-- ============================================================

/-- Problem 7.2, left inequality before scaling:
    `‖r‖∞ ≤ ‖A‖∞ ‖x-y‖∞` when `Ax=b` and `r=b-Ay`. -/
theorem problem7_2_infNorm_residual_lower (n : ℕ) (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i) :
    infNormVec (residualVec n A y b) ≤
      infNorm A * infNormVec (fun i => x i - y i) := by
  have hres :
      residualVec n A y b = matMulVec n A (fun i => x i - y i) := by
    ext i
    unfold residualVec matMulVec
    simp_rw [mul_sub, Finset.sum_sub_distrib]
    linarith [hAx i]
  simpa [hres] using
    (infNormVec_matMulVec_le hn A (fun i => x i - y i))

/-- Problem 7.2, right inequality before scaling:
    `‖x-y‖∞ ≤ ‖A⁻¹‖∞ ‖r‖∞` when `A_inv A = I`. -/
theorem problem7_2_infNorm_residual_upper (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i) :
    infNormVec (fun i => x i - y i) ≤
      infNorm A_inv * infNormVec (residualVec n A y b) := by
  let r := residualVec n A y b
  have hFwd := forward_error_from_residual n A A_inv x y b hInv hAx
  have hcomponent :
      infNormVec (fun i => x i - y i) ≤
        infNormVec (matMulVec n (absMatrix n A_inv) (absVec n r)) := by
    apply infNormVec_le_of_abs_le
    · intro i
      have hentry_nonneg :
          0 ≤ matMulVec n (absMatrix n A_inv) (absVec n r) i := by
        unfold matMulVec absMatrix absVec
        exact Finset.sum_nonneg fun j _ =>
          mul_nonneg (abs_nonneg _) (abs_nonneg _)
      calc
        |x i - y i| ≤ matMulVec n (absMatrix n A_inv) (absVec n r) i := by
          simpa [r, matMulVec, absMatrix, absVec] using hFwd i
        _ = |matMulVec n (absMatrix n A_inv) (absVec n r) i| :=
          (abs_of_nonneg hentry_nonneg).symm
        _ ≤ infNormVec (matMulVec n (absMatrix n A_inv) (absVec n r)) :=
          abs_le_infNormVec _ i
    · exact infNormVec_nonneg _
  calc
    infNormVec (fun i => x i - y i)
        ≤ infNormVec (matMulVec n (absMatrix n A_inv) (absVec n r)) := hcomponent
    _ ≤ infNorm (absMatrix n A_inv) * infNormVec (absVec n r) :=
        infNormVec_matMulVec_le hn (absMatrix n A_inv) (absVec n r)
    _ = infNorm A_inv * infNormVec (residualVec n A y b) := by
        rw [infNorm_absMatrix hn A_inv, infNormVec_absVec hn r]

/-- Problem 7.2, source-shaped lower bound in the infinity norm. -/
theorem problem7_2_infNorm_scaled_lower (n : ℕ) (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hA : 0 < infNorm A) (hx : 0 < infNormVec x) :
    infNormVec (residualVec n A y b) / (infNorm A * infNormVec x) ≤
      infNormVec (fun i => x i - y i) / infNormVec x := by
  have hraw := problem7_2_infNorm_residual_lower n hn A x y b hAx
  have hden_nonneg : 0 ≤ infNorm A * infNormVec x :=
    mul_nonneg (le_of_lt hA) (le_of_lt hx)
  have hA_ne : infNorm A ≠ 0 := ne_of_gt hA
  have hx_ne : infNormVec x ≠ 0 := ne_of_gt hx
  calc
    infNormVec (residualVec n A y b) / (infNorm A * infNormVec x)
        ≤ (infNorm A * infNormVec (fun i => x i - y i)) /
          (infNorm A * infNormVec x) :=
          div_le_div_of_nonneg_right hraw hden_nonneg
    _ = infNormVec (fun i => x i - y i) / infNormVec x := by
        field_simp [hA_ne, hx_ne]

/-- Problem 7.2, source-shaped upper bound in the infinity norm. -/
theorem problem7_2_infNorm_scaled_upper (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hA : 0 < infNorm A) (hx : 0 < infNormVec x) :
    infNormVec (fun i => x i - y i) / infNormVec x ≤
      kappaInf n hn A A_inv *
        (infNormVec (residualVec n A y b) / (infNorm A * infNormVec x)) := by
  have hraw := problem7_2_infNorm_residual_upper n hn A A_inv x y b hInv hAx
  have hA_ne : infNorm A ≠ 0 := ne_of_gt hA
  have hx_ne : infNormVec x ≠ 0 := ne_of_gt hx
  calc
    infNormVec (fun i => x i - y i) / infNormVec x
        ≤ (infNorm A_inv * infNormVec (residualVec n A y b)) /
          infNormVec x :=
          div_le_div_of_nonneg_right hraw (le_of_lt hx)
    _ = (infNorm A * infNorm A_inv) *
        (infNormVec (residualVec n A y b) / (infNorm A * infNormVec x)) := by
        field_simp [hA_ne, hx_ne]
    _ = kappaInf n hn A A_inv *
        (infNormVec (residualVec n A y b) / (infNorm A * infNormVec x)) := by
        rw [kappaInf_eq_infNorm_mul_infNorm n hn A A_inv]

/-- Problem 7.2, arbitrary subordinate-norm lower inequality over complex
    matrices:
    `‖r‖ ≤ ‖A‖ ‖x-y‖` when `Ax = b` and `r = b - Ay`. -/
theorem problem7_2_subordinate_residual_lower
    {n : ℕ} {ν : CVec n → ℝ}
    {A : CMatrix n n} {a : ℝ}
    (hA : IsMixedSubordinateMatrixNormValue ν ν A a)
    (x y b : CVec n) (hAx : complexMatrixVecMul A x = b) :
    ν (fun i => b i - complexMatrixVecMul A y i) ≤
      a * ν (fun i => x i - y i) := by
  have hres :
      (fun i => b i - complexMatrixVecMul A y i) =
        complexMatrixVecMul A (fun i => x i - y i) := by
    ext i
    have hAxi := congrFun hAx i
    unfold complexMatrixVecMul at hAxi ⊢
    rw [← hAxi]
    simp_rw [mul_sub, Finset.sum_sub_distrib]
  simpa [hres] using hA.1 (fun i => x i - y i)

/-- Problem 7.2, arbitrary subordinate-norm upper inequality over complex
    matrices:
    `‖x-y‖ ≤ ‖A⁻¹‖ ‖r‖` when `Ainv * A = I`, `Ax = b`, and `r = b - Ay`. -/
theorem problem7_2_subordinate_residual_upper
    {n : ℕ} {ν : CVec n → ℝ}
    {A Ainv : CMatrix n n} {s : ℝ}
    (hInv : IsComplexMatrixLeftInverse A Ainv)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (x y b : CVec n) (hAx : complexMatrixVecMul A x = b) :
    ν (fun i => x i - y i) ≤
      s * ν (fun i => b i - complexMatrixVecMul A y i) := by
  have hres :
      (fun i => b i - complexMatrixVecMul A y i) =
        complexMatrixVecMul A (fun i => x i - y i) := by
    ext i
    have hAxi := congrFun hAx i
    unfold complexMatrixVecMul at hAxi ⊢
    rw [← hAxi]
    simp_rw [mul_sub, Finset.sum_sub_distrib]
  have hxy :
      (fun i => x i - y i) =
        complexMatrixVecMul Ainv (fun i => b i - complexMatrixVecMul A y i) := by
    calc
      (fun i => x i - y i) =
          complexMatrixVecMul Ainv
            (complexMatrixVecMul A (fun i => x i - y i)) := by
            symm
            exact hInv (fun i => x i - y i)
      _ = complexMatrixVecMul Ainv (fun i => b i - complexMatrixVecMul A y i) := by
            rw [hres]
  simpa [hxy] using hAinv.1 (fun i => b i - complexMatrixVecMul A y i)

/-- Problem 7.2, source-shaped lower inequality for an arbitrary subordinate
    norm over complex matrices. -/
theorem problem7_2_subordinate_scaled_lower
    {n : ℕ} {ν : CVec n → ℝ}
    {A : CMatrix n n} {a : ℝ}
    (hA : IsMixedSubordinateMatrixNormValue ν ν A a)
    (x y b : CVec n) (hAx : complexMatrixVecMul A x = b)
    (ha : 0 < a) (hx : 0 < ν x) :
    ν (fun i => b i - complexMatrixVecMul A y i) / (a * ν x) ≤
      ν (fun i => x i - y i) / ν x := by
  have hraw := problem7_2_subordinate_residual_lower hA x y b hAx
  have hden_nonneg : 0 ≤ a * ν x :=
    mul_nonneg (le_of_lt ha) (le_of_lt hx)
  have ha_ne : a ≠ 0 := ne_of_gt ha
  have hx_ne : ν x ≠ 0 := ne_of_gt hx
  calc
    ν (fun i => b i - complexMatrixVecMul A y i) / (a * ν x)
        ≤ (a * ν (fun i => x i - y i)) / (a * ν x) :=
          div_le_div_of_nonneg_right hraw hden_nonneg
    _ = ν (fun i => x i - y i) / ν x := by
        field_simp [ha_ne, hx_ne]

/-- Problem 7.2, source-shaped upper inequality for an arbitrary subordinate
    norm over complex matrices. -/
theorem problem7_2_subordinate_scaled_upper
    {n : ℕ} {ν : CVec n → ℝ}
    {A Ainv : CMatrix n n} {a s : ℝ}
    (_hA : IsMixedSubordinateMatrixNormValue ν ν A a)
    (hInv : IsComplexMatrixLeftInverse A Ainv)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (x y b : CVec n) (hAx : complexMatrixVecMul A x = b)
    (ha : 0 < a) (hx : 0 < ν x) :
    ν (fun i => x i - y i) / ν x ≤
      (a * s) * (ν (fun i => b i - complexMatrixVecMul A y i) / (a * ν x)) := by
  have hraw := problem7_2_subordinate_residual_upper hInv hAinv x y b hAx
  have hx_ne : ν x ≠ 0 := ne_of_gt hx
  calc
    ν (fun i => x i - y i) / ν x
        ≤ (s * ν (fun i => b i - complexMatrixVecMul A y i)) / ν x :=
          div_le_div_of_nonneg_right hraw (le_of_lt hx)
    _ = (a * s) *
        (ν (fun i => b i - complexMatrixVecMul A y i) / (a * ν x)) := by
        field_simp [ne_of_gt ha, hx_ne]

-- ============================================================
-- Theorem 7.2: arbitrary subordinate-norm form of (7.4)
-- ============================================================

/-- Higham Theorem 7.2 / equation (7.4) in arbitrary subordinate-norm form
    over complex matrices.

    If `Ax = b`, `(A + ΔA)y = b + Δb`, `‖ΔA‖ ≤ ε ‖E‖`, `‖Δb‖ ≤ ε ‖f‖`,
    and `ε ‖A⁻¹‖ ‖E‖ < 1`, then
    `‖x-y‖ / ‖x‖ ≤ ε / (1 - ε ‖A⁻¹‖ ‖E‖) *
      (‖A⁻¹‖ ‖f‖ / ‖x‖ + ‖A⁻¹‖ ‖E‖)`. -/
theorem theorem7_2_subordinate_forward_error_bound
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A Ainv E ΔA : CMatrix n n}
    {x y b f Δb : CVec n} {ε e s : ℝ}
    (hε : 0 ≤ ε)
    (hE : IsMixedSubordinateMatrixNormValue ν ν E e)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (hΔA : MixedSubordinateMatrixBound ν ν ΔA (ε * e))
    (hΔb : ν Δb ≤ ε * ν f)
    (hInv : IsComplexMatrixLeftInverse A Ainv)
    (hAx : complexMatrixVecMul A x = b)
    (hPerturbed : complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
      fun i => b i + Δb i)
    (hεse : ε * s * e < 1) (hx : 0 < ν x) :
    ν (fun i => x i - y i) / ν x ≤
      ε / (1 - ε * s * e) * (s * (ν f / ν x) + s * e) := by
  let δ : ℝ := ν (fun i => x i - y i)
  have hs_nonneg : 0 ≤ s :=
    mixedSubordinateNormValue_nonneg_of_nonempty hn hν hν hAinv
  have he_nonneg : 0 ≤ e :=
    mixedSubordinateNormValue_nonneg_of_nonempty hn hν hν hE
  have hres :
      complexMatrixVecMul A (fun i => x i - y i) =
        (fun i => complexMatrixVecMul ΔA y i - Δb i) := by
    ext i
    have hAxi := congrFun hAx i
    have hPerti := congrFun hPerturbed i
    unfold complexMatrixVecMul at hAxi hPerti ⊢
    rw [← hAxi] at hPerti
    simp_rw [add_mul, Finset.sum_add_distrib] at hPerti
    have hmain :
        (∑ j : Fin n, A i j * x j) - (∑ j : Fin n, A i j * y j) =
          (∑ j : Fin n, ΔA i j * y j) - Δb i := by
      calc
        (∑ j : Fin n, A i j * x j) - (∑ j : Fin n, A i j * y j)
            = (((∑ j : Fin n, A i j * x j) + Δb i) - Δb i) -
                (∑ j : Fin n, A i j * y j) := by ring
        _ = (((∑ j : Fin n, A i j * y j) + ∑ j : Fin n, ΔA i j * y j) - Δb i) -
              (∑ j : Fin n, A i j * y j) := by rw [← hPerti]
        _ = (∑ j : Fin n, ΔA i j * y j) - Δb i := by ring
    simpa [complexMatrixVecMul, mul_sub, Finset.sum_sub_distrib] using hmain
  have hxy :
      (fun i => x i - y i) =
        complexMatrixVecMul Ainv (fun i => complexMatrixVecMul ΔA y i - Δb i) := by
    calc
      (fun i => x i - y i)
          = complexMatrixVecMul Ainv
              (complexMatrixVecMul A (fun i => x i - y i)) := by
              symm
              exact hInv (fun i => x i - y i)
      _ = complexMatrixVecMul Ainv
            (fun i => complexMatrixVecMul ΔA y i - Δb i) := by
            rw [hres]
  have hsub :
      ν (fun i => complexMatrixVecMul ΔA y i - Δb i) ≤
        ν (complexMatrixVecMul ΔA y) + ν Δb := by
    have hsub_eq :
        (fun i => complexMatrixVecMul ΔA y i - Δb i) =
          complexVecAdd (complexMatrixVecMul ΔA y) (complexVecSMul (-1 : ℂ) Δb) := by
      ext i
      simp [complexVecAdd, complexVecSMul, sub_eq_add_neg]
    calc
      ν (fun i => complexMatrixVecMul ΔA y i - Δb i)
          = ν (complexVecAdd (complexMatrixVecMul ΔA y)
              (complexVecSMul (-1 : ℂ) Δb)) := by rw [hsub_eq]
      _ ≤ ν (complexMatrixVecMul ΔA y) + ν (complexVecSMul (-1 : ℂ) Δb) :=
          hν.add_le _ _
      _ = ν (complexMatrixVecMul ΔA y) + ν Δb := by
          rw [hν.smul (-1 : ℂ) Δb]
          norm_num
  have hy :
      ν y ≤ ν x + δ := by
    have hy_repr :
        y = complexVecAdd x (complexVecSMul (-1 : ℂ) (fun i => x i - y i)) := by
      ext i
      simp [complexVecAdd, complexVecSMul]
    rw [hy_repr]
    calc
      ν (complexVecAdd x (complexVecSMul (-1 : ℂ) (fun i => x i - y i)))
          ≤ ν x + ν (complexVecSMul (-1 : ℂ) (fun i => x i - y i)) :=
            hν.add_le _ _
      _ = ν x + δ := by
          rw [hν.smul (-1 : ℂ) (fun i => x i - y i)]
          unfold δ
          norm_num
  have hδ :
      δ ≤ s * (ε * e * (ν x + δ) + ε * ν f) := by
    have hδ0 : δ ≤ s * ν (fun i => complexMatrixVecMul ΔA y i - Δb i) := by
      simpa [δ, hxy] using hAinv.1 (fun i => complexMatrixVecMul ΔA y i - Δb i)
    calc
      δ ≤ s * ν (fun i => complexMatrixVecMul ΔA y i - Δb i) := hδ0
      _ ≤ s * (ν (complexMatrixVecMul ΔA y) + ν Δb) := by
          exact mul_le_mul_of_nonneg_left hsub hs_nonneg
      _ ≤ s * (ε * e * ν y + ε * ν f) := by
          apply mul_le_mul_of_nonneg_left (add_le_add ?_ hΔb) hs_nonneg
          calc
            ν (complexMatrixVecMul ΔA y) ≤ (ε * e) * ν y := hΔA y
            _ = ε * e * ν y := by ring
      _ ≤ s * (ε * e * (ν x + δ) + ε * ν f) := by
          exact mul_le_mul_of_nonneg_left
            (add_le_add (mul_le_mul_of_nonneg_left hy (mul_nonneg hε he_nonneg))
              (le_refl _))
            hs_nonneg
  have hden_pos : 0 < 1 - ε * s * e := by
    nlinarith
  have hδ_bound :
      δ ≤ (ε * s * (ν f + e * ν x)) / (1 - ε * s * e) := by
    apply (le_div_iff₀ hden_pos).2
    nlinarith [hδ]
  have hx_ne : ν x ≠ 0 := ne_of_gt hx
  calc
    ν (fun i => x i - y i) / ν x = δ / ν x := by
      rfl
    _ ≤ ((ε * s * (ν f + e * ν x)) / (1 - ε * s * e)) / ν x :=
        div_le_div_of_nonneg_right hδ_bound (le_of_lt hx)
    _ = ε / (1 - ε * s * e) * (s * (ν f / ν x) + s * e) := by
        field_simp [hx_ne, ne_of_gt hden_pos]

-- ============================================================
-- Equation (7.5): generic normwise condition number
-- ============================================================

/-- Source-radius feasible relative-error values for Higham equation (7.5) in
an arbitrary complex vector norm.  The matrix perturbation budget is tracked by
the scalar norm value `e = ‖E‖`; the actual witness `E` only re-enters when the
source-facing theorem packages this scalar back into the Chapter 7 statement. -/
def Ch7NormwiseCondEFRadiusSet
    {n : ℕ} (ν : CVec n → ℝ) (A : CMatrix n n)
    (x b f : CVec n) (e rho : ℝ) : Set ℝ :=
  { q | ∃ ε : ℝ, ∃ ΔA : CMatrix n n, ∃ Δb y : CVec n,
      0 < ε ∧
      ε ≤ rho ∧
      MixedSubordinateMatrixBound ν ν ΔA (ε * e) ∧
      ν Δb ≤ ε * ν f ∧
      (complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i) ∧
      q = (ν (fun i => x i - y i) / ν x) / ε }

/-- Concrete `sSup` of the source-radius feasible set for equation (7.5). -/
noncomputable def ch7NormwiseCondEFRadiusSup
    {n : ℕ} (ν : CVec n → ℝ) (A : CMatrix n n)
    (x b f : CVec n) (e rho : ℝ) : ℝ :=
  sSup (Ch7NormwiseCondEFRadiusSet ν A x b f e rho)

/-- Filter-valued source-radius condition-number limit for equation (7.5). -/
def IsCh7NormwiseCondEFRadiusLimitValue
    {ι : Type*} (l : Filter ι)
    {n : ℕ} (ν : CVec n → ℝ) (A : CMatrix n n)
    (x b f : CVec n) (e : ℝ) (rho : ι → ℝ) (κ : ℝ) : Prop :=
  Filter.Tendsto
    (fun i => ch7NormwiseCondEFRadiusSup ν A x b f e (rho i))
    l (nhds κ)

/-- Product-side source-facing value predicate for Higham equation (7.5). -/
def IsCh7NormwiseCondEFValue
    {n : ℕ} (ν : CVec n → ℝ) (Ainv : CMatrix n n)
    (f x : CVec n) (e κ : ℝ) : Prop :=
  ∃ s : ℝ,
    IsMixedSubordinateMatrixNormValue ν ν Ainv s ∧
      κ = s * (ν f / ν x) + s * e

/-- Every feasible source-radius value for equation (7.5) is controlled by the
scalar upper envelope supplied by Theorem 7.2. -/
theorem ch7NormwiseCondEFRadiusSet_value_le
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A Ainv E : CMatrix n n} {x b f : CVec n} {e s rho q : ℝ}
    (hE : IsMixedSubordinateMatrixNormValue ν ν E e)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (hInv : IsComplexMatrixLeftInverse A Ainv)
    (hAx : complexMatrixVecMul A x = b)
    (hx : 0 < ν x) (hrho_se : rho * s * e < 1)
    (hq : q ∈ Ch7NormwiseCondEFRadiusSet ν A x b f e rho) :
    q ≤ (s * (ν f / ν x) + s * e) / (1 - rho * s * e) := by
  rcases hq with ⟨ε, ΔA, Δb, y, hεpos, hερ, hΔA, hΔb, hPerturbed, rfl⟩
  have hε : 0 ≤ ε := le_of_lt hεpos
  have he_nonneg : 0 ≤ e :=
    mixedSubordinateMatrixNormValue_nonneg_of_nonempty hn hν hν hE
  have hs_nonneg : 0 ≤ s :=
    mixedSubordinateMatrixNormValue_nonneg_of_nonempty hn hν hν hAinv
  have hεse : ε * s * e < 1 := by
    have hεse_le : ε * s * e ≤ rho * s * e := by
      have hscale : ε * (s * e) ≤ rho * (s * e) :=
        mul_le_mul_of_nonneg_right hερ (mul_nonneg hs_nonneg he_nonneg)
      simpa [mul_assoc] using hscale
    exact lt_of_le_of_lt hεse_le hrho_se
  let K : ℝ := s * (ν f / ν x) + s * e
  have hmain :=
    theorem7_2_subordinate_forward_error_bound
      (hn := hn) (ν := ν) (A := A) (Ainv := Ainv) (E := E) (ΔA := ΔA)
      (x := x) (y := y) (b := b) (f := f) (Δb := Δb)
      (ε := ε) (e := e) (s := s)
      hν hε hE hAinv hΔA hΔb hInv hAx hPerturbed hεse hx
  have hden_eps : 0 < 1 - ε * s * e := by
    nlinarith
  have hden_rho : 0 < 1 - rho * s * e := by
    nlinarith
  have hK_nonneg : 0 ≤ K := by
    dsimp [K]
    have hfx_nonneg : 0 ≤ ν f / ν x :=
      div_nonneg (hν.nonneg f) (le_of_lt hx)
    nlinarith
  have hdiv :
      (ν (fun i => x i - y i) / ν x) / ε ≤ K / (1 - ε * s * e) := by
    calc
      (ν (fun i => x i - y i) / ν x) / ε
          ≤ (ε / (1 - ε * s * e) * K) / ε :=
            div_le_div_of_nonneg_right
              (by simpa [K] using hmain) hε
      _ = K / (1 - ε * s * e) := by
            field_simp [K, ne_of_gt hεpos, ne_of_gt hden_eps]
  have hden_order : 1 - rho * s * e ≤ 1 - ε * s * e := by
    have hscale : ε * s * e ≤ rho * s * e := by
      have hmul : ε * (s * e) ≤ rho * (s * e) :=
        mul_le_mul_of_nonneg_right hερ (mul_nonneg hs_nonneg he_nonneg)
      simpa [mul_assoc] using hmul
    nlinarith
  have hmono : K / (1 - ε * s * e) ≤ K / (1 - rho * s * e) := by
    apply (div_le_div_iff₀ hden_eps hden_rho).2
    nlinarith [mul_le_mul_of_nonneg_left hden_order hK_nonneg]
  exact hdiv.trans hmono

/-- Sharp lower witness for equation (7.5): once a norming vector for `A⁻¹`
and a dual functional for `x` are fixed, a rank-one perturbation family gives a
source-radius value within the printed first-order denominator. -/
theorem exists_ch7NormwiseCondEFRadiusSet_rankOne_lower_witness
    {n : ℕ} {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A Ainv : CMatrix n n} {x b f w : CVec n} {φ : CVec n → ℂ}
    {e s rho : ℝ}
    (hInv : IsComplexMatrixInverse A Ainv)
    (hAx : complexMatrixVecMul A x = b)
    (hw : ν w = 1)
    (hAinvw : ν (complexMatrixVecMul Ainv w) = s)
    (hφ : IsDualFunctionalNormValue ν φ 1)
    (hφx : φ x = (ν x : ℂ))
    (hx : 0 < ν x) (hs : 0 < s) (he : 0 ≤ e)
    (hrho_pos : 0 < rho)
    (hsmall : rho * e * ‖φ (complexMatrixVecMul Ainv w)‖ < 2) :
    ∃ q : ℝ,
      q ∈ Ch7NormwiseCondEFRadiusSet ν A x b f e rho ∧
      (s * (ν f / ν x) + s * e) /
          (1 + rho * e * ‖φ (complexMatrixVecMul Ainv w)‖) ≤ q := by
  let ε : ℝ := rho / 2
  let u : CVec n := complexMatrixVecMul Ainv w
  let c : ℂ := φ u
  let d : ℝ := e * ν x + ν f
  let γ : ℂ := 1 + (((ε * e) : ℝ) : ℂ) * c
  let α : ℂ := -((((ε * d) : ℝ) : ℂ) / γ)
  let y : CVec n := complexVecAdd x (complexVecSMul α u)
  let ΔA : CMatrix n n := fun i j =>
    (((ε * e) : ℝ) : ℂ) * rankOneCMatrixFromFunctional φ w i j
  let Δb : CVec n := complexVecSMul (-((ε * ν f : ℝ) : ℂ)) w
  let K : ℝ := s * (ν f / ν x) + s * e
  let q : ℝ := (ν (fun i => x i - y i) / ν x) / ε
  have hεpos : 0 < ε := by
    dsimp [ε]
    linarith
  have hε_le_rho : ε ≤ rho := by
    dsimp [ε]
    linarith
  have hwpos : 0 < ν w := by
    rw [hw]
    norm_num
  have hu_eq : ν u = s := hAinvw
  have hc_nonneg : 0 ≤ ‖c‖ := norm_nonneg _
  have hRankOne :
      IsMixedSubordinateMatrixNormValue ν ν
        (rankOneCMatrixFromFunctional φ w) 1 := by
    simpa [u, c, hw] using
      (rankOneCMatrix_isMixedSubordinateMatrixNormValue_of_dualFunctionalNormValue
        (να := ν) (νβ := ν) hν hφ hwpos)
  have hεe_nonneg : 0 ≤ ε * e := by
    exact mul_nonneg (le_of_lt hεpos) he
  have hγ_ne : γ ≠ 0 := by
    have hεec_lt : ε * e * ‖c‖ < 1 := by
      dsimp [ε, c] at hsmall ⊢
      nlinarith
    intro hγ0
    dsimp [γ] at hγ0
    have hz : (((ε * e) : ℝ) : ℂ) * c = (-1 : ℂ) :=
      eq_neg_of_add_eq_zero_left (by simpa [add_comm] using hγ0)
    have hnorm_lt : ‖(((ε * e) : ℝ) : ℂ) * c‖ < 1 := by
      calc
        ‖(((ε * e) : ℝ) : ℂ) * c‖ = (ε * e) * ‖c‖ := by
          rw [norm_mul, Complex.norm_real, Real.norm_of_nonneg hεe_nonneg]
        _ < 1 := hεec_lt
    have hnorm_eq : (ε * e) * ‖c‖ = 1 := by
      have hnorm_one : ‖(((ε * e) : ℝ) : ℂ) * c‖ = 1 := by
        calc
          ‖(((ε * e) : ℝ) : ℂ) * c‖ = ‖(-1 : ℂ)‖ := by
                rw [hz]
          _ = 1 := by
                norm_num
      have hnorm_real_eq : ‖ε * e‖ * ‖c‖ = 1 := by
        rw [norm_mul, Complex.norm_real] at hnorm_one
        exact hnorm_one
      rw [Real.norm_of_nonneg hεe_nonneg] at hnorm_real_eq
      exact hnorm_real_eq
    linarith
  have hΔA_bound : MixedSubordinateMatrixBound ν ν ΔA (ε * e) := by
    intro v
    calc
      ν (complexMatrixVecMul ΔA v)
          = ν (complexVecSMul (((ε * e : ℝ) : ℂ))
              (complexMatrixVecMul (rankOneCMatrixFromFunctional φ w) v)) := by
              congr 1
              ext i
              dsimp [ΔA, complexMatrixVecMul, complexVecSMul]
              rw [Finset.mul_sum]
              refine Finset.sum_congr rfl ?_
              intro j _hj
              ring
      _ = (ε * e) * ν (complexMatrixVecMul (rankOneCMatrixFromFunctional φ w) v) := by
            rw [hν.smul (((ε * e : ℝ) : ℂ))
              (complexMatrixVecMul (rankOneCMatrixFromFunctional φ w) v)]
            rw [Complex.norm_real, Real.norm_of_nonneg hεe_nonneg]
      _ ≤ (ε * e) * (1 * ν v) := by
            apply mul_le_mul_of_nonneg_left
            simpa using hRankOne.1 v
            exact hεe_nonneg
      _ = (ε * e) * ν v := by
            ring
  have hΔb_bound : ν Δb ≤ ε * ν f := by
    have hενf_nonneg : 0 ≤ ε * ν f :=
      mul_nonneg (le_of_lt hεpos) (hν.nonneg f)
    calc
      ν Δb = (ε * ν f) * ν w := by
        dsimp [Δb]
        rw [hν.smul (-((ε * ν f : ℝ) : ℂ)) w, norm_neg,
          Complex.norm_real, Real.norm_of_nonneg hενf_nonneg]
      _ = ε * ν f := by
        rw [hw]
        ring
      _ ≤ ε * ν f := le_rfl
  have hφy : φ y = (ν x : ℂ) + α * c := by
    calc
      φ y = φ x + α * φ u := by
        dsimp [y]
        rw [hφ.linear.map_add, hφ.linear.map_smul]
      _ = (ν x : ℂ) + α * c := by
        rw [hφx]
  have hAy :
      complexMatrixVecMul A y = complexVecAdd b (complexVecSMul α w) := by
    calc
      complexMatrixVecMul A y
          = complexMatrixVecMul A (complexVecAdd x (complexVecSMul α u)) := by
              rfl
      _ = complexVecAdd (complexMatrixVecMul A x)
            (complexMatrixVecMul A (complexVecSMul α u)) := by
              rw [(complexMatrixVecMul_linear A).map_add]
      _ = complexVecAdd (complexMatrixVecMul A x)
            (complexVecSMul α (complexMatrixVecMul A u)) := by
              rw [(complexMatrixVecMul_linear A).map_smul]
      _ = complexVecAdd b (complexVecSMul α w) := by
              rw [hAx, hInv.2 w]
  have hΔAy :
      complexMatrixVecMul ΔA y =
        complexVecSMul ((((ε * e : ℝ) : ℂ) * φ y)) w := by
    calc
      complexMatrixVecMul ΔA y
          = complexVecSMul (((ε * e : ℝ) : ℂ))
              (complexMatrixVecMul (rankOneCMatrixFromFunctional φ w) y) := by
              ext i
              dsimp [ΔA, complexVecSMul, complexMatrixVecMul]
              rw [Finset.mul_sum]
              refine Finset.sum_congr rfl ?_
              intro j _hj
              ring
      _ = complexVecSMul (((ε * e : ℝ) : ℂ)) (rankOneOperator φ w y) := by
            rw [complexMatrixVecMul_rankOneCMatrixFromFunctional hφ.linear]
      _ = complexVecSMul ((((ε * e : ℝ) : ℂ) * φ y)) w := by
            ext i
            simp [rankOneOperator, complexVecSMul]
            ring
  have hscalar :
      α + (((ε * e : ℝ) : ℂ) * ((ν x : ℂ) + α * c)) =
        -((ε * ν f : ℝ) : ℂ) := by
    have hαγ : α * γ = -((ε * d : ℝ) : ℂ) := by
      dsimp [α]
      field_simp [hγ_ne]
    have hcast_mul :
        (((ε * e : ℝ) : ℂ) * ((ν x : ℝ) : ℂ)) =
          (((ε * e * ν x : ℝ) : ℂ)) := by
      exact_mod_cast (by ring : ε * e * ν x = ε * e * ν x)
    calc
      α + (((ε * e : ℝ) : ℂ) * ((ν x : ℂ) + α * c))
          = α + (((ε * e : ℝ) : ℂ) * (ν x : ℂ)) +
              α * ((((ε * e : ℝ) : ℂ) * c)) := by
                ring
      _ = α + ((ε * e * ν x : ℝ) : ℂ) +
            α * ((((ε * e : ℝ) : ℂ) * c)) := by
              rw [hcast_mul]
      _ = α * γ + ((ε * e * ν x : ℝ) : ℂ) := by
            dsimp [γ]
            ring
      _ = -((ε * d : ℝ) : ℂ) + ((ε * e * ν x : ℝ) : ℂ) := by
            rw [hαγ]
      _ = -((ε * ν f : ℝ) : ℂ) := by
            exact_mod_cast (by
              dsimp [d]
              ring : -(ε * d) + (ε * e * ν x) = -(ε * ν f))
  have hExact :
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i := by
    ext i
    have hAy_i := congrFun hAy i
    have hΔAy_i := congrFun hΔAy i
    have hΔb_i : Δb i = -((ε * ν f : ℝ) : ℂ) * w i := by
      simp [Δb, complexVecSMul]
    calc
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y i
          = complexMatrixVecMul A y i + complexMatrixVecMul ΔA y i := by
              simp [complexMatrixVecMul, Finset.sum_add_distrib, add_mul]
      _ = b i + α * w i + ((((ε * e : ℝ) : ℂ) * φ y) * w i) := by
            rw [hAy_i, hΔAy_i]
            simp [complexVecAdd, complexVecSMul]
      _ = b i + (α + (((ε * e : ℝ) : ℂ) * ((ν x : ℂ) + α * c))) * w i := by
            rw [hφy]
            ring
      _ = b i + (-((ε * ν f : ℝ) : ℂ)) * w i := by
            rw [hscalar]
      _ = b i + Δb i := by
            rw [hΔb_i]
  have hxy :
      (fun i => x i - y i) = complexVecSMul (-α) u := by
    ext i
    simp [y, complexVecAdd, complexVecSMul]
  have hd_nonneg : 0 ≤ d := by
    dsimp [d]
    nlinarith [he, hν.nonneg f, le_of_lt hx]
  have hq_formula : q = K / ‖γ‖ := by
    have hγnorm_pos : 0 < ‖γ‖ := norm_pos_iff.mpr hγ_ne
    have hαnorm : ‖α‖ = (ε * d) / ‖γ‖ := by
      dsimp [α]
      rw [norm_neg, norm_div, Complex.norm_real,
        Real.norm_of_nonneg (mul_nonneg (le_of_lt hεpos) hd_nonneg)]
    have herr : ν (fun i => x i - y i) = ‖α‖ * s := by
      rw [hxy, hν.smul (-α) u, norm_neg, hu_eq]
    have hx_ne : ν x ≠ 0 := ne_of_gt hx
    have hε_ne : ε ≠ 0 := ne_of_gt hεpos
    calc
      q = (ν (fun i => x i - y i) / ν x) / ε := rfl
      _ = ((‖α‖ * s) / ν x) / ε := by
            rw [herr]
      _ = K / ‖γ‖ := by
            rw [hαnorm]
            dsimp [K, d]
            field_simp [hx_ne, hε_ne, hγnorm_pos.ne']
            ring
  have hγ_le : ‖γ‖ ≤ 1 + rho * e * ‖c‖ := by
    calc
      ‖γ‖ = ‖(1 : ℂ) + (((ε * e) : ℝ) : ℂ) * c‖ := by
            rfl
      _ ≤ ‖(1 : ℂ)‖ + ‖(((ε * e) : ℝ) : ℂ) * c‖ := norm_add_le _ _
      _ = 1 + (ε * e) * ‖c‖ := by
            rw [norm_one, norm_mul, Complex.norm_real, Real.norm_of_nonneg hεe_nonneg]
      _ ≤ 1 + rho * e * ‖c‖ := by
            have hεe_le : ε * e ≤ rho * e :=
              mul_le_mul_of_nonneg_right hε_le_rho he
            have hscale : (ε * e) * ‖c‖ ≤ (rho * e) * ‖c‖ :=
              mul_le_mul_of_nonneg_right hεe_le hc_nonneg
            nlinarith
  have hK_nonneg : 0 ≤ K := by
    dsimp [K]
    have hfx_nonneg : 0 ≤ ν f / ν x :=
      div_nonneg (hν.nonneg f) (le_of_lt hx)
    nlinarith
  refine ⟨q, ?_, ?_⟩
  · refine ⟨ε, ΔA, Δb, y, hεpos, hε_le_rho, hΔA_bound, hΔb_bound, hExact, rfl⟩
  · rw [hq_formula]
    have hγnorm_pos : 0 < ‖γ‖ := norm_pos_iff.mpr hγ_ne
    have hLden_pos : 0 < 1 + rho * e * ‖c‖ := by
      nlinarith [hrho_pos, he, hc_nonneg]
    apply (div_le_div_iff₀ hLden_pos hγnorm_pos).2
    nlinarith [mul_le_mul_of_nonneg_left hγ_le hK_nonneg]

/-- Higham equation (7.5), source-radius limit form in an arbitrary complex
vector norm.  The book's `κ_{E,f}(A,x)` is modeled as the limit of the
source-radius suprema over exact perturbed solutions. -/
theorem eq_7_5_subordinate_conditionNumberRadiusLimitValue_of_positive_radii
    {ι : Type*} {l : Filter ι}
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A Ainv E : CMatrix n n} {x b f : CVec n} {e s : ℝ} {rho : ι → ℝ}
    (hE : IsMixedSubordinateMatrixNormValue ν ν E e)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (hInv : IsComplexMatrixInverse A Ainv)
    (hAx : complexMatrixVecMul A x = b)
    (hx : 0 < ν x) (hs : 0 < s)
    (hrho_pos : Filter.Eventually (fun i => 0 < rho i) l)
    (hrho : Filter.Tendsto rho l (nhds 0)) :
    IsCh7NormwiseCondEFRadiusLimitValue l ν A x b f e rho
      (s * (ν f / ν x) + s * e) := by
  dsimp [IsCh7NormwiseCondEFRadiusLimitValue]
  have he : 0 ≤ e :=
    mixedSubordinateMatrixNormValue_nonneg_of_nonempty hn hν hν hE
  obtain ⟨w, hw, hAinvw⟩ :=
    exists_unit_vector_attaining_mixedSubordinateNormValue
      hν hν (complexMatrixVecMul_linear Ainv) hAinv hs
  obtain ⟨φ, hφ, hφx⟩ := exists_dualFunctionalNormValue_one_of_pos_vector hν hx
  let C : ℝ := ‖φ (complexMatrixVecMul Ainv w)‖
  let K : ℝ := s * (ν f / ν x) + s * e
  let L : ι → ℝ := fun i => K / (1 + rho i * e * C)
  let U : ι → ℝ := fun i => K / (1 - rho i * s * e)
  let Q : ι → ℝ := fun i => ch7NormwiseCondEFRadiusSup ν A x b f e (rho i)
  have hL : Filter.Tendsto L l (nhds K) := by
    have hden : Filter.Tendsto (fun i => 1 + rho i * e * C) l (nhds (1 : ℝ)) := by
      simpa [C, mul_assoc, mul_comm, mul_left_comm] using
        (tendsto_const_nhds.add (hrho.mul_const (e * C)))
    dsimp [L]
    simpa [div_eq_mul_inv] using
      (tendsto_const_nhds.mul (hden.inv₀ (by norm_num : (1 : ℝ) ≠ 0)))
  have hU : Filter.Tendsto U l (nhds K) := by
    have hden : Filter.Tendsto (fun i => 1 - rho i * s * e) l (nhds (1 : ℝ)) := by
      simpa [mul_assoc, mul_comm, mul_left_comm] using
        (tendsto_const_nhds.sub (hrho.mul_const (s * e)))
    dsimp [U]
    simpa [div_eq_mul_inv] using
      (tendsto_const_nhds.mul (hden.inv₀ (by norm_num : (1 : ℝ) ≠ 0)))
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact norm_nonneg _
  have hrho_se_small : Filter.Eventually (fun i => rho i * s * e < 1) l := by
    have hscaled : Filter.Tendsto (fun i => rho i * s * e) l (nhds 0) := by
      simpa [mul_assoc, mul_comm, mul_left_comm] using hrho.mul_const (s * e)
    have hraw := (Metric.tendsto_nhds.mp hscaled) 1 (by norm_num : (0 : ℝ) < 1)
    filter_upwards [hrho_pos, hraw] with i hρpos hi
    have hiabs : |rho i * s * e| < 1 := by
      simpa [Real.dist_eq] using hi
    have hnonneg : 0 ≤ rho i * s * e := by
      exact mul_nonneg (mul_nonneg (le_of_lt hρpos) (le_of_lt hs)) he
    rw [abs_of_nonneg hnonneg] at hiabs
    exact hiabs
  have hrho_C_small : Filter.Eventually (fun i => rho i * e * C < 2) l := by
    have hscaled : Filter.Tendsto (fun i => rho i * e * C) l (nhds 0) := by
      simpa [C, mul_assoc, mul_comm, mul_left_comm] using hrho.mul_const (e * C)
    have hraw := (Metric.tendsto_nhds.mp hscaled) 2 (by norm_num : (0 : ℝ) < 2)
    filter_upwards [hrho_pos, hraw] with i hρpos hi
    have hiabs : |rho i * e * C| < 2 := by
      simpa [Real.dist_eq] using hi
    have hnonneg : 0 ≤ rho i * e * C := by
      exact mul_nonneg (mul_nonneg (le_of_lt hρpos) he) hC_nonneg
    rw [abs_of_nonneg hnonneg] at hiabs
    exact hiabs
  have hbetween : Filter.Eventually (fun i => L i ≤ Q i ∧ Q i ≤ U i) l := by
    filter_upwards [hrho_pos, hrho_se_small, hrho_C_small] with
      i hρpos hse hCsmall
    obtain ⟨q, hqmem, hLle⟩ :=
      exists_ch7NormwiseCondEFRadiusSet_rankOne_lower_witness
        (hν := hν) (A := A) (Ainv := Ainv) (x := x) (b := b) (f := f)
        (w := w) (φ := φ) (e := e) (s := s)
        hInv hAx hw hAinvw hφ hφx hx hs he hρpos
        (by simpa [C] using hCsmall)
    have hUbound :
        ∀ r : ℝ, r ∈ Ch7NormwiseCondEFRadiusSet ν A x b f e (rho i) → r ≤ U i := by
      intro r hr
      simpa [U, K] using
        ch7NormwiseCondEFRadiusSet_value_le
          (hn := hn) (hν := hν) (A := A) (Ainv := Ainv) (E := E)
          (x := x) (b := b) (f := f) (e := e) (s := s) (rho := rho i)
          (q := r) hE hAinv hInv.1 hAx hx hse hr
    have hbdd :
        BddAbove (Ch7NormwiseCondEFRadiusSet ν A x b f e (rho i)) := ⟨U i, hUbound⟩
    have hq_le_sup :
        q ≤ ch7NormwiseCondEFRadiusSup ν A x b f e (rho i) :=
      le_csSup hbdd hqmem
    have hsup_le :
        ch7NormwiseCondEFRadiusSup ν A x b f e (rho i) ≤ U i :=
      csSup_le ⟨q, hqmem⟩ hUbound
    exact ⟨hLle.trans hq_le_sup, hsup_le⟩
  simpa [L, U, Q, K] using
    tendsto_of_eventually_between_tendsto hL hU hbetween

/-- Product-plus-limit packaging of Higham equation (7.5). -/
theorem eq_7_5_subordinate_conditionNumber_of_positive_radii
    {ι : Type*} {l : Filter ι}
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A Ainv E : CMatrix n n} {x b f : CVec n} {e s : ℝ} {rho : ι → ℝ}
    (hE : IsMixedSubordinateMatrixNormValue ν ν E e)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (hInv : IsComplexMatrixInverse A Ainv)
    (hAx : complexMatrixVecMul A x = b)
    (hx : 0 < ν x) (hs : 0 < s)
    (hrho_pos : Filter.Eventually (fun i => 0 < rho i) l)
    (hrho : Filter.Tendsto rho l (nhds 0)) :
    ∃ κ : ℝ,
      IsCh7NormwiseCondEFValue ν Ainv f x e κ ∧
        IsCh7NormwiseCondEFRadiusLimitValue l ν A x b f e rho κ := by
  refine ⟨s * (ν f / ν x) + s * e, ?_, ?_⟩
  · exact ⟨s, hAinv, rfl⟩
  · exact
      eq_7_5_subordinate_conditionNumberRadiusLimitValue_of_positive_radii
        (hn := hn) (hν := hν) (A := A) (Ainv := Ainv) (E := E)
        (x := x) (b := b) (f := f) (e := e) (s := s) (rho := rho)
        hE hAinv hInv hAx hx hs hrho_pos hrho

-- ============================================================
-- Problem 7.7: dropping the right-hand-side perturbation budget
-- ============================================================

/-- Problem 7.7, arbitrary subordinate-norm monotonicity.

    A feasible normwise backward error with no right-hand-side perturbation
    budget is automatically feasible when the budget `‖b‖` is allowed. This is
    the easy inequality `η_{A,b}(y) ≤ η_{A,0}(y)`. -/
theorem problem7_7_subordinate_abs_rhs_feasible_of_zero_rhs_feasible
    {n : ℕ} {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A : CMatrix n n} {a : ℝ}
    (y b : CVec n) (ε : ℝ) (hε : 0 ≤ ε)
    (hfeas : ∃ ΔA : CMatrix n n, ∃ Δb : CVec n,
      MixedSubordinateMatrixBound ν ν ΔA (ε * a) ∧
      ν Δb ≤ ε * (0 : ℝ) ∧
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i) :
    ∃ ΔA : CMatrix n n, ∃ Δb : CVec n,
      MixedSubordinateMatrixBound ν ν ΔA (ε * a) ∧
      ν Δb ≤ ε * ν b ∧
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i := by
  rcases hfeas with ⟨ΔA, Δb, hΔA, hΔb, hExact⟩
  refine ⟨ΔA, Δb, hΔA, ?_, hExact⟩
  calc
    ν Δb ≤ ε * (0 : ℝ) := hΔb
    _ = 0 := by ring
    _ ≤ ε * ν b := mul_nonneg hε (hν.nonneg b)

/-- Problem 7.7, arbitrary subordinate-norm core.

    If the residual is bounded by the standard Rigal-Gaches denominator
    `‖A‖ ‖y‖ + ‖b‖` and `ε < 1`, then it is bounded with no right-hand-side
    budget at the enlarged factor `2ε/(1-ε)`. This is the normwise analogue of
    the Appendix A proof of `η_{A,0}(y) ≤ 2η_{A,b}(y)/(1-η_{A,b}(y))`. -/
theorem problem7_7_subordinate_abs_rhs_to_zero_rhs_residual_bound
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A : CMatrix n n} {a : ℝ}
    (hA : IsMixedSubordinateMatrixNormValue ν ν A a)
    (y b : CVec n) (ε : ℝ) (hε : 0 ≤ ε) (hεlt : ε < 1)
    (hres : ν (fun i => b i - complexMatrixVecMul A y i) ≤
      ε * (a * ν y + ν b)) :
    ν (fun i => b i - complexMatrixVecMul A y i) ≤
      (2 * ε / (1 - ε)) * (a * ν y) := by
  let r : CVec n := fun i => b i - complexMatrixVecMul A y i
  have ha_nonneg : 0 ≤ a :=
    mixedSubordinateMatrixNormValue_nonneg_of_nonempty hn hν hν hA
  have hAy : ν (complexMatrixVecMul A y) ≤ a * ν y := hA.1 y
  have hb_step : ν b ≤ ν r + a * ν y := by
    have hb_repr : b = complexVecAdd r (complexMatrixVecMul A y) := by
      ext i
      simp [r, complexVecAdd]
    rw [hb_repr]
    calc
      ν (complexVecAdd r (complexMatrixVecMul A y))
          ≤ ν r + ν (complexMatrixVecMul A y) := hν.add_le _ _
      _ ≤ ν r + a * ν y := add_le_add (le_refl _) hAy
  have hres_r : ν r ≤ ε * (a * ν y + ν b) := by
    simpa [r] using hres
  have hmove : (1 - ε) * ν b ≤ (1 + ε) * (a * ν y) := by
    linarith [hres_r, hb_step]
  have hden_pos : 0 < 1 - ε := by
    linarith
  have hb_le : ν b ≤ ((1 + ε) / (1 - ε)) * (a * ν y) := by
    calc
      ν b ≤ ((1 + ε) * (a * ν y)) / (1 - ε) :=
        (le_div_iff₀ hden_pos).mpr (by
          simpa [mul_comm, mul_left_comm, mul_assoc] using hmove)
      _ = ((1 + ε) / (1 - ε)) * (a * ν y) := by
          ring
  have hres2 :
      ν r ≤ ε * (a * ν y + ((1 + ε) / (1 - ε)) * (a * ν y)) := by
    calc
      ν r ≤ ε * (a * ν y + ν b) := hres_r
      _ ≤ ε * (a * ν y + ((1 + ε) / (1 - ε)) * (a * ν y)) := by
          exact mul_le_mul_of_nonneg_left
            (add_le_add (le_refl _) hb_le) hε
  calc
    ν r ≤ ε * (a * ν y + ((1 + ε) / (1 - ε)) * (a * ν y)) := hres2
    _ = (2 * ε / (1 - ε)) * (a * ν y) := by
        field_simp [ne_of_gt hden_pos]
        ring

/-- Problem 7.7, arbitrary subordinate-norm feasibility form.

    A feasible normwise backward error with right-hand-side budget `‖b‖`
    implies a feasible normwise backward error with right-hand-side budget zero
    at factor `2ε/(1-ε)`, for `0 ≤ ε < 1`. -/
theorem problem7_7_subordinate_zero_rhs_feasible_of_abs_rhs_feasible
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A : CMatrix n n} {a : ℝ}
    (hA : IsMixedSubordinateMatrixNormValue ν ν A a)
    (y b : CVec n) (ε : ℝ) (hε : 0 ≤ ε) (hεlt : ε < 1)
    (hfeas : ∃ ΔA : CMatrix n n, ∃ Δb : CVec n,
      MixedSubordinateMatrixBound ν ν ΔA (ε * a) ∧
      ν Δb ≤ ε * ν b ∧
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i) :
    ∃ ΔA : CMatrix n n, ∃ Δb : CVec n,
      MixedSubordinateMatrixBound ν ν ΔA ((2 * ε / (1 - ε)) * a) ∧
      ν Δb ≤ (2 * ε / (1 - ε)) * (0 : ℝ) ∧
      complexMatrixVecMul (fun i j => A i j + ΔA i j) y =
        fun i => b i + Δb i := by
  have hres :
      ν (fun i => b i - complexMatrixVecMul A y i) ≤
        ε * (a * ν y + ν b) := by
    exact
      (theorem7_1_subordinate
        (n := n) (ν := ν) (A := A) (E := A) (y := y) (b := b) (f := b)
        (e := a) (ε := ε) hn hν hε hA).2 hfeas
  have hzero :=
    problem7_7_subordinate_abs_rhs_to_zero_rhs_residual_bound
      hn hν hA y b ε hε hεlt hres
  have hcoef : 0 ≤ 2 * ε / (1 - ε) := by
    exact div_nonneg (mul_nonneg (by norm_num) hε) (by linarith)
  have hzero_norm : ν (0 : CVec n) = 0 :=
    (hν.eq_zero_iff (0 : CVec n)).2 rfl
  have hbound_zero :
      ν (fun i => b i - complexMatrixVecMul A y i) ≤
        (2 * ε / (1 - ε)) * (a * ν y + ν (0 : CVec n)) := by
    calc
      ν (fun i => b i - complexMatrixVecMul A y i) ≤
          (2 * ε / (1 - ε)) * (a * ν y) := hzero
      _ = (2 * ε / (1 - ε)) * (a * ν y + ν (0 : CVec n)) := by
          rw [hzero_norm]
          ring
  obtain ⟨ΔA, Δb, hΔA, hΔb, hExact⟩ :=
    (theorem7_1_subordinate
      (n := n) (ν := ν) (A := A) (E := A) (y := y) (b := b) (f := (0 : CVec n))
      (e := a) (ε := 2 * ε / (1 - ε)) hn hν hcoef hA).1 hbound_zero
  refine ⟨ΔA, Δb, hΔA, ?_, hExact⟩
  calc
    ν Δb ≤ (2 * ε / (1 - ε)) * ν (0 : CVec n) := hΔb
    _ = (2 * ε / (1 - ε)) * (0 : ℝ) := by rw [hzero_norm]

/-- Problem 7.7, componentwise core.

    If the residual is bounded with the standard componentwise denominator
    `|A||y| + |b|` and `ε < 1`, then it is bounded with no right-hand-side
    budget at the enlarged factor `2ε/(1-ε)`. This is the local algebraic
    step in Appendix A's proof of
    `ω_{|A|,0}(y) ≤ 2ω_{|A|,|b|}(y)/(1-ω_{|A|,|b|}(y))`. -/
theorem problem7_7_componentwise_abs_rhs_to_zero_rhs_residual_bound (n : ℕ)
    (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (ε : ℝ) (hε : 0 ≤ ε) (hεlt : ε < 1)
    (hres : ∀ i, |residualVec n A y b i| ≤
      ε * (∑ j : Fin n, |A i j| * |y j| + |b i|)) :
    ∀ i, |residualVec n A y b i| ≤
      (2 * ε / (1 - ε)) *
        (∑ j : Fin n, |A i j| * |y j| + (0 : ℝ)) := by
  intro i
  let row : ℝ := ∑ j : Fin n, |A i j| * |y j|
  have hrow_nonneg : 0 ≤ row := by
    unfold row
    exact Finset.sum_nonneg fun j _ => mul_nonneg (abs_nonneg _) (abs_nonneg _)
  have hden_pos : 0 < 1 - ε := by linarith
  have hres_i :
      |residualVec n A y b i| ≤ ε * (row + |b i|) := by
    simpa [row] using hres i
  have hAy : |∑ j : Fin n, A i j * y j| ≤ row := by
    unfold row
    calc
      |∑ j : Fin n, A i j * y j|
          ≤ ∑ j : Fin n, |A i j * y j| := Finset.abs_sum_le_sum_abs _ _
      _ = ∑ j : Fin n, |A i j| * |y j| := by
          apply Finset.sum_congr rfl
          intro j _
          exact abs_mul (A i j) (y j)
  have hb_step : |b i| ≤ row + ε * (row + |b i|) := by
    have hb_repr :
        b i = residualVec n A y b i + ∑ j : Fin n, A i j * y j := by
      unfold residualVec
      ring
    calc
      |b i|
          = |residualVec n A y b i + ∑ j : Fin n, A i j * y j| := by
            rw [hb_repr]
      _ ≤ |residualVec n A y b i| + |∑ j : Fin n, A i j * y j| :=
          abs_add_le _ _
      _ ≤ ε * (row + |b i|) + row :=
          add_le_add hres_i hAy
      _ = row + ε * (row + |b i|) := by ring
  have hmove : (1 - ε) * |b i| ≤ (1 + ε) * row := by
    linarith
  have hb_le : |b i| ≤ ((1 + ε) / (1 - ε)) * row := by
    calc
      |b i| ≤ ((1 + ε) * row) / (1 - ε) :=
        (le_div_iff₀ hden_pos).mpr (by
          simpa [mul_comm, mul_left_comm, mul_assoc] using hmove)
      _ = ((1 + ε) / (1 - ε)) * row := by ring
  have hres2 :
      |residualVec n A y b i| ≤
        ε * (row + ((1 + ε) / (1 - ε)) * row) := by
    calc
      |residualVec n A y b i| ≤ ε * (row + |b i|) := hres_i
      _ ≤ ε * (row + ((1 + ε) / (1 - ε)) * row) := by
          exact mul_le_mul_of_nonneg_left (add_le_add (le_refl row) hb_le) hε
  calc
    |residualVec n A y b i|
        ≤ ε * (row + ((1 + ε) / (1 - ε)) * row) := hres2
    _ = (2 * ε / (1 - ε)) *
        (∑ j : Fin n, |A i j| * |y j| + (0 : ℝ)) := by
        rw [show row = ∑ j : Fin n, |A i j| * |y j| by rfl]
        field_simp [ne_of_gt hden_pos]
        ring

/-- Problem 7.7, componentwise feasibility form.

    A feasible componentwise backward error with right-hand-side budget `|b|`
    implies a feasible componentwise backward error with right-hand-side budget
    zero at factor `2ε/(1-ε)`, for `0 ≤ ε < 1`. -/
theorem problem7_7_componentwise_zero_rhs_feasible_of_abs_rhs_feasible (n : ℕ)
    (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (ε : ℝ) (hε : 0 ≤ ε) (hεlt : ε < 1)
    (hfeas : ∃ (ΔA : Fin n → Fin n → ℝ) (Δb : Fin n → ℝ),
      (∀ i j, |ΔA i j| ≤ ε * |A i j|) ∧
      (∀ i, |Δb i| ≤ ε * |b i|) ∧
      (∀ i, ∑ j : Fin n, (A i j + ΔA i j) * y j = b i + Δb i)) :
    ∃ (ΔA : Fin n → Fin n → ℝ) (Δb : Fin n → ℝ),
      (∀ i j, |ΔA i j| ≤ (2 * ε / (1 - ε)) * |A i j|) ∧
      (∀ i, |Δb i| ≤ (2 * ε / (1 - ε)) * (0 : ℝ)) ∧
      (∀ i, ∑ j : Fin n, (A i j + ΔA i j) * y j = b i + Δb i) := by
  have hres :
      ∀ i, |residualVec n A y b i| ≤
        ε * (∑ j : Fin n, |A i j| * |y j| + |b i|) :=
    (oettli_prager n A y b (fun i j => |A i j|) (fun i => |b i|)
      ε hε (fun _ _ => abs_nonneg _) (fun _ => abs_nonneg _)).2 hfeas
  have hzero :=
    problem7_7_componentwise_abs_rhs_to_zero_rhs_residual_bound
      n A y b ε hε hεlt hres
  have hcoef : 0 ≤ 2 * ε / (1 - ε) := by
    exact div_nonneg (mul_nonneg (by norm_num) hε) (by linarith)
  exact
    (oettli_prager n A y b (fun i j => |A i j|) (fun _ => (0 : ℝ))
      (2 * ε / (1 - ε)) hcoef
      (fun _ _ => abs_nonneg _) (fun _ => le_rfl)).1 hzero

/-- Problem 7.7, normwise infinity-norm core.

    This is the Rigal-Gaches analogue of
    `problem7_7_componentwise_abs_rhs_to_zero_rhs_residual_bound`: a residual
    bound with denominator `‖A‖∞ ‖y‖∞ + ‖b‖∞` implies one with denominator
    `‖A‖∞ ‖y‖∞` at factor `2ε/(1-ε)`. -/
theorem problem7_7_normwise_inf_residual_bound (n : ℕ) (hn : 0 < n)
    (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (ε : ℝ) (hε : 0 ≤ ε) (hεlt : ε < 1)
    (hres : ∀ i, |residualVec n A y b i| ≤
      ε * (infNorm A *
        Finset.sup' Finset.univ
          (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩) (fun j => |y j|) +
        infNormVec b)) :
    ∀ i, |residualVec n A y b i| ≤
      (2 * ε / (1 - ε)) *
        (infNorm A *
          Finset.sup' Finset.univ
            (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩) (fun j => |y j|) +
          (0 : ℝ)) := by
  let hne : (Finset.univ : Finset (Fin n)).Nonempty :=
    Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩
  let yNorm : ℝ := Finset.sup' Finset.univ hne (fun j : Fin n => |y j|)
  let C : ℝ := infNorm A * yNorm
  let β : ℝ := infNormVec b
  have hy_le : ∀ j : Fin n, |y j| ≤ yNorm := by
    intro j
    exact Finset.le_sup' (fun j : Fin n => |y j|) (Finset.mem_univ j)
  have hyNorm_nonneg : 0 ≤ yNorm :=
    le_trans (abs_nonneg (y ⟨0, hn⟩)) (hy_le ⟨0, hn⟩)
  have hC_nonneg : 0 ≤ C := by
    exact mul_nonneg (infNorm_nonneg A) hyNorm_nonneg
  have hβ_nonneg : 0 ≤ β := by
    unfold β
    exact infNormVec_nonneg b
  have hden_pos : 0 < 1 - ε := by linarith
  have hres_i : ∀ i, |residualVec n A y b i| ≤ ε * (C + β) := by
    intro i
    simpa [C, β, yNorm, hne] using hres i
  have hAy : ∀ i, |∑ j : Fin n, A i j * y j| ≤ C := by
    intro i
    calc
      |∑ j : Fin n, A i j * y j|
          ≤ ∑ j : Fin n, |A i j * y j| := Finset.abs_sum_le_sum_abs _ _
      _ = ∑ j : Fin n, |A i j| * |y j| := by
          apply Finset.sum_congr rfl
          intro j _
          exact abs_mul (A i j) (y j)
      _ ≤ ∑ j : Fin n, |A i j| * yNorm := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left (hy_le j) (abs_nonneg _)
      _ = (∑ j : Fin n, |A i j|) * yNorm := by rw [Finset.sum_mul]
      _ ≤ infNorm A * yNorm :=
          mul_le_mul_of_nonneg_right (row_sum_le_infNorm A i) hyNorm_nonneg
      _ = C := by rfl
  have hb_step : ∀ i, |b i| ≤ C + ε * (C + β) := by
    intro i
    have hb_repr :
        b i = residualVec n A y b i + ∑ j : Fin n, A i j * y j := by
      unfold residualVec
      ring
    calc
      |b i|
          = |residualVec n A y b i + ∑ j : Fin n, A i j * y j| := by
            rw [hb_repr]
      _ ≤ |residualVec n A y b i| + |∑ j : Fin n, A i j * y j| :=
          abs_add_le _ _
      _ ≤ ε * (C + β) + C :=
          add_le_add (hres_i i) (hAy i)
      _ = C + ε * (C + β) := by ring
  have hβ_step : β ≤ C + ε * (C + β) := by
    unfold β
    apply infNormVec_le_of_abs_le
    · intro i
      simpa [C, β] using hb_step i
    · exact add_nonneg hC_nonneg (mul_nonneg hε (add_nonneg hC_nonneg hβ_nonneg))
  have hmove : (1 - ε) * β ≤ (1 + ε) * C := by
    linarith
  have hβ_le : β ≤ ((1 + ε) / (1 - ε)) * C := by
    calc
      β ≤ ((1 + ε) * C) / (1 - ε) :=
        (le_div_iff₀ hden_pos).mpr (by
          simpa [mul_comm, mul_left_comm, mul_assoc] using hmove)
      _ = ((1 + ε) / (1 - ε)) * C := by ring
  intro i
  have hres2 :
      |residualVec n A y b i| ≤
        ε * (C + ((1 + ε) / (1 - ε)) * C) := by
    calc
      |residualVec n A y b i| ≤ ε * (C + β) := hres_i i
      _ ≤ ε * (C + ((1 + ε) / (1 - ε)) * C) := by
          exact mul_le_mul_of_nonneg_left (add_le_add (le_refl C) hβ_le) hε
  calc
    |residualVec n A y b i|
        ≤ ε * (C + ((1 + ε) / (1 - ε)) * C) := hres2
    _ = (2 * ε / (1 - ε)) *
        (infNorm A *
          Finset.sup' Finset.univ
            (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩) (fun j => |y j|) +
          (0 : ℝ)) := by
        simp only [C, yNorm]
        field_simp [ne_of_gt hden_pos]
        ring

/-- Problem 7.7, normwise infinity-norm feasibility form. -/
theorem problem7_7_normwise_zero_rhs_feasible_of_abs_rhs_feasible (n : ℕ)
    (hn : 0 < n) (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (ε : ℝ) (hε : 0 ≤ ε) (hεlt : ε < 1)
    (hfeas : ∃ (ΔA : Fin n → Fin n → ℝ) (Δb : Fin n → ℝ),
      (∀ i, ∑ j : Fin n, |ΔA i j| ≤ ε * infNorm A) ∧
      (∀ i, |Δb i| ≤ ε * infNormVec b) ∧
      (∀ i, ∑ j : Fin n, (A i j + ΔA i j) * y j = b i + Δb i)) :
    ∃ (ΔA : Fin n → Fin n → ℝ) (Δb : Fin n → ℝ),
      (∀ i, ∑ j : Fin n, |ΔA i j| ≤ (2 * ε / (1 - ε)) * infNorm A) ∧
      (∀ i, |Δb i| ≤ (2 * ε / (1 - ε)) * (0 : ℝ)) ∧
      (∀ i, ∑ j : Fin n, (A i j + ΔA i j) * y j = b i + Δb i) := by
  have hres :
      ∀ i, |residualVec n A y b i| ≤
        ε * (infNorm A *
          Finset.sup' Finset.univ
            (Finset.univ_nonempty_iff.mpr ⟨⟨0, hn⟩⟩) (fun j => |y j|) +
          infNormVec b) :=
    (rigal_gaches n hn A y b (infNorm A) (infNormVec b) ε
      (infNorm_nonneg A) (infNormVec_nonneg b) hε).2 hfeas
  have hzero :=
    problem7_7_normwise_inf_residual_bound n hn A y b ε hε hεlt hres
  have hcoef : 0 ≤ 2 * ε / (1 - ε) := by
    exact div_nonneg (mul_nonneg (by norm_num) hε) (by linarith)
  exact
    (rigal_gaches n hn A y b (infNorm A) 0 (2 * ε / (1 - ε))
      (infNorm_nonneg A) (by norm_num) hcoef).1 hzero

-- ============================================================
-- Problem 7.8: rectangular Frobenius backward error
-- ============================================================

/-- Residual for a rectangular system, `r = b - Ay`. -/
noncomputable def ch7RectResidual (m n : ℕ)
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ) :
    Fin m → ℝ :=
  fun i => b i - ∑ j : Fin n, A i j * y j

/-- Feasibility relation for Problem 7.8:
    `(A + ΔA)y = b + Δb`. -/
def ch7Problem78Feasible {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ)
    (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ) : Prop :=
  ∀ i, ∑ j : Fin n, (A i j + ΔA i j) * y j = b i + Δb i

/-- The augmented perturbation matrix `[ΔA, θ Δb]` with the weighted
right-hand-side perturbation in the first column. -/
noncomputable def ch7Problem78AugMatrix {m n : ℕ} (θ : ℝ)
    (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ) :
    Fin m → Fin (n + 1) → ℝ :=
  fun i => Fin.cases (θ * Δb i) (fun j => ΔA i j)

/-- The augmented vector `[-θ⁻¹; y]` used in Appendix A's proof of
Problem 7.8 for `θ > 0`. -/
noncomputable def ch7Problem78AugVector {n : ℕ} (θ : ℝ)
    (y : Fin n → ℝ) : Fin (n + 1) → ℝ :=
  Fin.cases (-(θ⁻¹)) y

/-- Squared norm of the augmented vector `[-θ⁻¹; y]`. -/
lemma ch7Problem78AugVector_norm_sq {n : ℕ} (θ : ℝ)
    (y : Fin n → ℝ) :
    vecNorm2Sq (ch7Problem78AugVector θ y) =
      θ⁻¹ ^ 2 + vecNorm2Sq y := by
  unfold vecNorm2Sq ch7Problem78AugVector
  rw [Fin.sum_univ_succ]
  simp only [Fin.cases_zero, Fin.cases_succ]
  ring

/-- For `θ > 0`, the augmented vector in Problem 7.8 has nonzero norm. -/
lemma ch7Problem78AugVector_norm_ne_zero_of_theta_pos {n : ℕ}
    {θ : ℝ} (hθ : 0 < θ) (y : Fin n → ℝ) :
    vecNorm2 (ch7Problem78AugVector θ y) ≠ 0 := by
  intro hzero
  have hzero_entries :=
    (vecNorm2_eq_zero_iff (ch7Problem78AugVector θ y)).mp hzero
  have hfirst := hzero_entries 0
  have hinv_ne : θ⁻¹ ≠ 0 := inv_ne_zero hθ.ne'
  exact hinv_ne (neg_eq_zero.mp (by simpa [ch7Problem78AugVector] using hfirst))

/-- Higham Problem 7.8 denominator identity:
`θ ‖[-θ⁻¹; y]‖₂ = sqrt(θ² ‖y‖₂² + 1)` for `θ > 0`. -/
theorem ch7Problem78_source_denominator_eq {n : ℕ}
    {θ : ℝ} (hθ : 0 < θ) (y : Fin n → ℝ) :
    θ * vecNorm2 (ch7Problem78AugVector θ y) =
      Real.sqrt (θ ^ 2 * vecNorm2Sq y + 1) := by
  let z := ch7Problem78AugVector θ y
  have hz_nonneg : 0 ≤ θ * vecNorm2 z :=
    mul_nonneg hθ.le (vecNorm2_nonneg z)
  have harg_nonneg : 0 ≤ θ ^ 2 * vecNorm2Sq y + 1 := by
    have hprod : 0 ≤ θ ^ 2 * vecNorm2Sq y :=
      mul_nonneg (sq_nonneg θ) (vecNorm2Sq_nonneg y)
    linarith
  symm
  rw [Real.sqrt_eq_iff_mul_self_eq harg_nonneg hz_nonneg]
  dsimp [z]
  rw [show (θ * vecNorm2 (ch7Problem78AugVector θ y)) *
        (θ * vecNorm2 (ch7Problem78AugVector θ y)) =
      θ ^ 2 * vecNorm2 (ch7Problem78AugVector θ y) ^ 2 by ring,
    vecNorm2_sq, ch7Problem78AugVector_norm_sq]
  field_simp [ne_of_gt hθ]
  ring

/-- Equivalence between the augmented-vector value and Higham's printed
Problem 7.8 value `θ‖r‖₂ / sqrt(θ²‖y‖₂² + 1)`. -/
theorem problem7_8_source_value_eq_augmented_value {m n : ℕ}
    {θ : ℝ} (hθ : 0 < θ) (y : Fin n → ℝ) (r : Fin m → ℝ) :
    θ * vecNorm2 r / Real.sqrt (θ ^ 2 * vecNorm2Sq y + 1) =
      vecNorm2 r / vecNorm2 (ch7Problem78AugVector θ y) := by
  have hz_ne := ch7Problem78AugVector_norm_ne_zero_of_theta_pos hθ y
  have hden := ch7Problem78_source_denominator_eq hθ y
  rw [← hden]
  field_simp [ne_of_gt hθ, hz_ne]

/-- The augmented feasibility equation in Appendix A:
    `[ΔA, θΔb] [-θ⁻¹; y] = b - Ay`. -/
theorem ch7Problem78_augMatrix_mul_augVector_of_feasible {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ)
    (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ)
    {θ : ℝ} (hθ : θ ≠ 0)
    (hfeas : ch7Problem78Feasible A y b ΔA Δb) :
    rectMatMulVec (ch7Problem78AugMatrix θ ΔA Δb)
        (ch7Problem78AugVector θ y) =
      ch7RectResidual m n A y b := by
  ext i
  unfold rectMatMulVec ch7Problem78AugMatrix ch7Problem78AugVector
    ch7RectResidual ch7Problem78Feasible at *
  rw [Fin.sum_univ_succ]
  simp only [Fin.cases_zero, Fin.cases_succ]
  have htheta : θ * Δb i * -θ⁻¹ = -Δb i := by
    field_simp [hθ]
  rw [htheta]
  have hsplit :
      ∑ j : Fin n, (A i j + ΔA i j) * y j =
        ∑ j : Fin n, A i j * y j + ∑ j : Fin n, ΔA i j * y j := by
    rw [← Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intro j _
    ring
  have hf := hfeas i
  rw [hsplit] at hf
  linarith

/-- Converse form of the augmented feasibility equation. -/
theorem ch7Problem78_feasible_of_augMatrix_mul_augVector {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ)
    (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ)
    {θ : ℝ} (hθ : θ ≠ 0)
    (hmul :
      rectMatMulVec (ch7Problem78AugMatrix θ ΔA Δb)
          (ch7Problem78AugVector θ y) =
        ch7RectResidual m n A y b) :
    ch7Problem78Feasible A y b ΔA Δb := by
  intro i
  have hentry := congrFun hmul i
  unfold rectMatMulVec ch7Problem78AugMatrix ch7Problem78AugVector
    ch7RectResidual at hentry
  rw [Fin.sum_univ_succ] at hentry
  simp only [Fin.cases_zero, Fin.cases_succ] at hentry
  have htheta : θ * Δb i * -θ⁻¹ = -Δb i := by
    field_simp [hθ]
  rw [htheta] at hentry
  have hsplit :
      ∑ j : Fin n, (A i j + ΔA i j) * y j =
        ∑ j : Fin n, A i j * y j + ∑ j : Fin n, ΔA i j * y j := by
    rw [← Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intro j _
    ring
  rw [hsplit]
  linarith

/-- Problem 7.8 lower-bound core.  Any feasible perturbation has augmented
Frobenius norm large enough to map `[-θ⁻¹; y]` to the residual. -/
theorem problem7_8_frobenius_lower_bound_core {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ)
    (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ)
    {θ : ℝ} (hθ : θ ≠ 0)
    (hfeas : ch7Problem78Feasible A y b ΔA Δb) :
    vecNorm2 (ch7RectResidual m n A y b) ≤
      frobNormRect (ch7Problem78AugMatrix θ ΔA Δb) *
        vecNorm2 (ch7Problem78AugVector θ y) := by
  rw [← ch7Problem78_augMatrix_mul_augVector_of_feasible
    A y b ΔA Δb hθ hfeas]
  exact vecNorm2_rectMatMulVec_le_frobNormRect_mul
    (ch7Problem78AugMatrix θ ΔA Δb) (ch7Problem78AugVector θ y)

/-- Problem 7.8 lower bound as a quotient by the augmented-vector norm. -/
theorem problem7_8_frobenius_lower_bound_pos {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ)
    (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ)
    {θ : ℝ} (hθ : 0 < θ)
    (hfeas : ch7Problem78Feasible A y b ΔA Δb) :
    vecNorm2 (ch7RectResidual m n A y b) /
        vecNorm2 (ch7Problem78AugVector θ y) ≤
      frobNormRect (ch7Problem78AugMatrix θ ΔA Δb) := by
  have hz_ne := ch7Problem78AugVector_norm_ne_zero_of_theta_pos hθ y
  have hz_pos : 0 < vecNorm2 (ch7Problem78AugVector θ y) :=
    lt_of_le_of_ne (vecNorm2_nonneg _) (Ne.symm hz_ne)
  have hcore :=
    problem7_8_frobenius_lower_bound_core A y b ΔA Δb
      (ne_of_gt hθ) hfeas
  exact (div_le_iff₀ hz_pos).mpr hcore

/-- Rectangular rank-one matrix `r zᵀ / ‖z‖₂²`. -/
noncomputable def ch7RectRankOneDivVecNorm2Sq {m n : ℕ}
    (r : Fin m → ℝ) (z : Fin n → ℝ) :
    Fin m → Fin n → ℝ :=
  fun i j => (1 / vecNorm2Sq z) * (r i * z j)

/-- The rank-one rectangular perturbation maps `z` to `r`. -/
theorem ch7RectRankOneDivVecNorm2Sq_mul_vec {m n : ℕ}
    (r : Fin m → ℝ) (z : Fin n → ℝ) (hz : vecNorm2 z ≠ 0) :
    rectMatMulVec (ch7RectRankOneDivVecNorm2Sq r z) z = r := by
  have hsq : vecNorm2Sq z ≠ 0 := by
    intro hzero
    have hnormsq : vecNorm2 z ^ 2 = 0 := by
      rw [vecNorm2_sq, hzero]
    exact hz (sq_eq_zero_iff.mp hnormsq)
  have hsq' : (∑ j : Fin n, z j ^ 2) ≠ 0 := by
    simpa [vecNorm2Sq] using hsq
  ext i
  unfold ch7RectRankOneDivVecNorm2Sq rectMatMulVec vecNorm2Sq
  calc
    (∑ j : Fin n, (1 / ∑ k : Fin n, z k ^ 2) * (r i * z j) * z j)
        = ∑ j : Fin n, ((1 / ∑ k : Fin n, z k ^ 2) * r i) * z j ^ 2 := by
          apply Finset.sum_congr rfl
          intro j _
          ring
    _ = ((1 / ∑ j : Fin n, z j ^ 2) * r i) *
        (∑ j : Fin n, z j ^ 2) := by
          rw [Finset.mul_sum]
    _ = r i := by
          field_simp [hsq']

/-- Frobenius norm of the rectangular rank-one perturbation
`r zᵀ / ‖z‖₂²`. -/
theorem frobNormRect_ch7RectRankOneDivVecNorm2Sq {m n : ℕ}
    (r : Fin m → ℝ) (z : Fin n → ℝ) (hz : vecNorm2 z ≠ 0) :
    frobNormRect (ch7RectRankOneDivVecNorm2Sq r z) =
      vecNorm2 r / vecNorm2 z := by
  unfold ch7RectRankOneDivVecNorm2Sq
  rw [frobNormRect_eq_frobNormFn, frobNorm_rankOne_smul]
  have hden_nonneg : 0 ≤ vecNorm2Sq z := vecNorm2Sq_nonneg z
  have hden_eq : vecNorm2Sq z = vecNorm2 z ^ 2 := (vecNorm2_sq z).symm
  rw [abs_of_nonneg (one_div_nonneg.mpr hden_nonneg), hden_eq]
  field_simp [hz]

/-- The rank-one augmented matrix used to attain the Problem 7.8 lower
bound for `θ > 0`. -/
noncomputable def ch7Problem78RankOneAugMatrix {m n : ℕ}
    (θ : ℝ) (y : Fin n → ℝ) (r : Fin m → ℝ) :
    Fin m → Fin (n + 1) → ℝ :=
  ch7RectRankOneDivVecNorm2Sq r (ch7Problem78AugVector θ y)

/-- The `ΔA` block extracted from the rank-one augmented perturbation. -/
noncomputable def ch7Problem78RankOneDeltaA {m n : ℕ}
    (θ : ℝ) (y : Fin n → ℝ) (r : Fin m → ℝ) :
    Fin m → Fin n → ℝ :=
  fun i j => ch7Problem78RankOneAugMatrix θ y r i j.succ

/-- The `Δb` vector extracted from the weighted first column of the rank-one
augmented perturbation. -/
noncomputable def ch7Problem78RankOneDeltaB {m n : ℕ}
    (θ : ℝ) (y : Fin n → ℝ) (r : Fin m → ℝ) : Fin m → ℝ :=
  fun i => θ⁻¹ * ch7Problem78RankOneAugMatrix θ y r i 0

/-- The extracted `ΔA, Δb` reassemble to the rank-one augmented matrix. -/
theorem ch7Problem78_augMatrix_rankOneDelta_eq {m n : ℕ}
    {θ : ℝ} (hθ : θ ≠ 0) (y : Fin n → ℝ) (r : Fin m → ℝ) :
    ch7Problem78AugMatrix θ
        (ch7Problem78RankOneDeltaA θ y r)
        (ch7Problem78RankOneDeltaB θ y r) =
      ch7Problem78RankOneAugMatrix θ y r := by
  ext i k
  refine Fin.cases ?_ ?_ k
  · unfold ch7Problem78AugMatrix ch7Problem78RankOneDeltaB
    simp only [Fin.cases_zero]
    field_simp [hθ]
  · intro j
    unfold ch7Problem78AugMatrix ch7Problem78RankOneDeltaA
    simp only [Fin.cases_succ]

/-- The rank-one augmented matrix maps `[-θ⁻¹; y]` exactly to `r`. -/
theorem ch7Problem78_rankOne_augMatrix_mul_augVector {m n : ℕ}
    {θ : ℝ} (hθ : 0 < θ) (y : Fin n → ℝ) (r : Fin m → ℝ) :
    rectMatMulVec (ch7Problem78RankOneAugMatrix θ y r)
        (ch7Problem78AugVector θ y) =
      r := by
  exact ch7RectRankOneDivVecNorm2Sq_mul_vec r
    (ch7Problem78AugVector θ y)
    (ch7Problem78AugVector_norm_ne_zero_of_theta_pos hθ y)

/-- The Frobenius norm of the rank-one augmented matrix is the Problem 7.8
lower-bound value. -/
theorem frobNormRect_ch7Problem78RankOneAugMatrix {m n : ℕ}
    {θ : ℝ} (hθ : 0 < θ) (y : Fin n → ℝ) (r : Fin m → ℝ) :
    frobNormRect (ch7Problem78RankOneAugMatrix θ y r) =
      vecNorm2 r / vecNorm2 (ch7Problem78AugVector θ y) := by
  exact frobNormRect_ch7RectRankOneDivVecNorm2Sq r
    (ch7Problem78AugVector θ y)
    (ch7Problem78AugVector_norm_ne_zero_of_theta_pos hθ y)

/-- Problem 7.8 attainment for `θ > 0`: the rank-one perturbation is feasible
and meets the lower bound. -/
theorem problem7_8_rankOne_attains_pos {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ)
    {θ : ℝ} (hθ : 0 < θ) :
    ∃ (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ),
      ch7Problem78Feasible A y b ΔA Δb ∧
      frobNormRect (ch7Problem78AugMatrix θ ΔA Δb) =
        vecNorm2 (ch7RectResidual m n A y b) /
          vecNorm2 (ch7Problem78AugVector θ y) := by
  let r := ch7RectResidual m n A y b
  let ΔA := ch7Problem78RankOneDeltaA θ y r
  let Δb := ch7Problem78RankOneDeltaB θ y r
  refine ⟨ΔA, Δb, ?_, ?_⟩
  · have hmul_rank :
        rectMatMulVec (ch7Problem78RankOneAugMatrix θ y r)
            (ch7Problem78AugVector θ y) =
          r :=
      ch7Problem78_rankOne_augMatrix_mul_augVector hθ y r
    have haug_eq :
        ch7Problem78AugMatrix θ ΔA Δb =
          ch7Problem78RankOneAugMatrix θ y r := by
      simpa [ΔA, Δb, r] using
        ch7Problem78_augMatrix_rankOneDelta_eq (ne_of_gt hθ) y r
    apply ch7Problem78_feasible_of_augMatrix_mul_augVector A y b ΔA Δb (ne_of_gt hθ)
    rw [haug_eq]
    simpa [r] using hmul_rank
  · have haug_eq :
        ch7Problem78AugMatrix θ ΔA Δb =
          ch7Problem78RankOneAugMatrix θ y r := by
      simpa [ΔA, Δb, r] using
        ch7Problem78_augMatrix_rankOneDelta_eq (ne_of_gt hθ) y r
    rw [haug_eq]
    simpa [r] using frobNormRect_ch7Problem78RankOneAugMatrix hθ y r

/-- Problem 7.8 for `θ > 0`, encoded as a lower bound for every feasible
perturbation plus an attaining feasible perturbation. -/
theorem problem7_8_frobenius_characterization_pos {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ)
    {θ : ℝ} (hθ : 0 < θ) :
    (∀ (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ),
      ch7Problem78Feasible A y b ΔA Δb →
        vecNorm2 (ch7RectResidual m n A y b) /
            vecNorm2 (ch7Problem78AugVector θ y) ≤
          frobNormRect (ch7Problem78AugMatrix θ ΔA Δb)) ∧
    ∃ (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ),
      ch7Problem78Feasible A y b ΔA Δb ∧
      frobNormRect (ch7Problem78AugMatrix θ ΔA Δb) =
        vecNorm2 (ch7RectResidual m n A y b) /
          vecNorm2 (ch7Problem78AugVector θ y) := by
  exact
    ⟨fun ΔA Δb hfeas =>
      problem7_8_frobenius_lower_bound_pos A y b ΔA Δb hθ hfeas,
      problem7_8_rankOne_attains_pos A y b hθ⟩

/-- Problem 7.8 at `θ = 0`: the weighted cost ignores `Δb`, so choosing
`ΔA = 0` and `Δb = Ay - b` makes the augmented Frobenius cost zero. -/
theorem problem7_8_zero_parameter_attains {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (y : Fin n → ℝ) (b : Fin m → ℝ) :
    ∃ (ΔA : Fin m → Fin n → ℝ) (Δb : Fin m → ℝ),
      ch7Problem78Feasible A y b ΔA Δb ∧
      frobNormRect (ch7Problem78AugMatrix 0 ΔA Δb) = 0 := by
  refine
    ⟨fun _ _ => 0,
      fun i => ∑ j : Fin n, A i j * y j - b i,
      ?_, ?_⟩
  · intro i
    simp
  · unfold frobNormRect
    have hsq :
        frobNormSqRect
            (ch7Problem78AugMatrix 0
              (fun (_ : Fin m) (_ : Fin n) => (0 : ℝ))
              (fun i => ∑ j : Fin n, A i j * y j - b i)) = 0 := by
      apply (frobNormSqRect_eq_zero_iff _).mpr
      intro i k
      refine Fin.cases ?_ ?_ k
      · simp [ch7Problem78AugMatrix]
      · intro j
        simp [ch7Problem78AugMatrix]
    rw [hsq]
    simp

-- ============================================================
-- Lemma 7.9: practical error bounds
-- ============================================================

/-- Lemma 7.9, componentwise core: if `ω(E|x̂|+f)` bounds the residual
    componentwise, then `ω |A⁻¹|(E|x̂|+f)` bounds `|A⁻¹||r|`. -/
theorem lemma7_9_componentwise_bound (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (E : Fin n → Fin n → ℝ) (f : Fin n → ℝ) (ω : ℝ)
    (hωres : ∀ j, |residualVec n A y b j| ≤
      ω * (∑ k : Fin n, E j k * |y k| + f j)) :
    ∀ i, ch7ResidualImage n A A_inv y b i ≤
      ω * ch7AmplifiedRhsEF n A_inv E f y i := by
  intro i
  unfold ch7ResidualImage ch7AmplifiedRhsEF
  calc
    ∑ j : Fin n, |A_inv i j| * |residualVec n A y b j|
        ≤ ∑ j : Fin n, |A_inv i j| *
          (ω * (∑ k : Fin n, E j k * |y k| + f j)) := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left (hωres j) (abs_nonneg _)
    _ = ω * ∑ j : Fin n, |A_inv i j| *
          (∑ k : Fin n, E j k * |y k| + f j) := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring

/-- Lemma 7.9, relative infinity-norm practical bound (7.29). -/
theorem lemma7_9_relative_infNorm_bound (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (E : Fin n → Fin n → ℝ) (f : Fin n → ℝ) (ω : ℝ)
    (hω : 0 ≤ ω) (hE : ∀ i j, 0 ≤ E i j) (hf : ∀ i, 0 ≤ f i)
    (hωres : ∀ j, |residualVec n A y b j| ≤
      ω * (∑ k : Fin n, E j k * |y k| + f j))
    (hy : 0 < infNormVec y) :
    infNormVec (ch7ResidualImage n A A_inv y b) / infNormVec y ≤
      ω * (ch7ForwardBoundEF n hn A_inv E f y / infNormVec y) := by
  let C := ch7ForwardBoundEF n hn A_inv E f y
  have hC_nonneg : 0 ≤ C := ch7ForwardBoundEF_nonneg n hn A_inv E f y hE hf
  have hcomp := lemma7_9_componentwise_bound n A A_inv y b E f ω hωres
  have hnorm :
      infNormVec (ch7ResidualImage n A A_inv y b) ≤ ω * C := by
    apply infNormVec_le_of_abs_le
    · intro i
      have hri_nonneg : 0 ≤ ch7ResidualImage n A A_inv y b i := by
        unfold ch7ResidualImage
        exact Finset.sum_nonneg fun j _ =>
          mul_nonneg (abs_nonneg _) (abs_nonneg _)
      rw [abs_of_nonneg hri_nonneg]
      calc
        ch7ResidualImage n A A_inv y b i
            ≤ ω * ch7AmplifiedRhsEF n A_inv E f y i := hcomp i
        _ ≤ ω * C := by
            exact mul_le_mul_of_nonneg_left
              (Finset.le_sup' (ch7AmplifiedRhsEF n A_inv E f y)
                (Finset.mem_univ i)) hω
    · exact mul_nonneg hω hC_nonneg
  calc
    infNormVec (ch7ResidualImage n A A_inv y b) / infNormVec y
        ≤ (ω * C) / infNormVec y :=
          div_le_div_of_nonneg_right hnorm (le_of_lt hy)
    _ = ω * (C / infNormVec y) := by ring

/-- Equality case recorded in Lemma 7.9: if `E|x̂|+f` is a scalar multiple of
    `|r|` with reciprocal factor `ω`, then the practical bound is exact before
    taking the infinity norm. -/
theorem lemma7_9_exact_for_residual_multiple (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (E : Fin n → Fin n → ℝ) (f : Fin n → ℝ) (ω c : ℝ)
    (hscale : ∀ j, ∑ k : Fin n, E j k * |y k| + f j =
      c * |residualVec n A y b j|)
    (hωc : ω * c = 1) :
    ∀ i, ω * ch7AmplifiedRhsEF n A_inv E f y i =
      ch7ResidualImage n A A_inv y b i := by
  intro i
  unfold ch7AmplifiedRhsEF ch7ResidualImage
  calc
    ω * (∑ j : Fin n, |A_inv i j| *
        (∑ k : Fin n, E j k * |y k| + f j))
        = ω * (∑ j : Fin n, |A_inv i j| *
            (c * |residualVec n A y b j|)) := by
          congr 1
          apply Finset.sum_congr rfl
          intro j _
          rw [hscale j]
    _ = (ω * c) *
        (∑ j : Fin n, |A_inv i j| * |residualVec n A y b j|) := by
          rw [Finset.mul_sum, Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro j _
          ring
    _ = ∑ j : Fin n, |A_inv i j| * |residualVec n A y b j| := by
          rw [hωc]
          ring

-- ============================================================
-- Equations (7.30) and (7.31): computed residual bounds
-- ============================================================

/-- The vector `|r̂| + γ_{n+1}(|A||x̂| + |b|)` from equation (7.31). -/
noncomputable def ch7ComputedResidualSafetyTerm (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ) : Fin n → ℝ :=
  fun i => |fl_residual fp n A y b i| +
    gamma fp (n + 1) * (|b i| + ∑ j : Fin n, |A i j| * |y j|)

/-- The vector `|A⁻¹|(|r̂| + γ_{n+1}(|A||x̂| + |b|))` from equation (7.31). -/
noncomputable def ch7ComputedResidualImage (fp : FPModel) (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (y b : Fin n → ℝ) : Fin n → ℝ :=
  fun i => ∑ j : Fin n, |A_inv i j| * ch7ComputedResidualSafetyTerm fp n A y b j

/-- Equation (7.30): the conventionally computed residual satisfies
`r̂ = r + Δr` with `|Δr| ≤ γ_{n+1}(|A||x̂| + |b|)`. -/
theorem eq_7_30_conventional_residual_error (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (hn : gammaValid fp n) (hn1 : gammaValid fp (n + 1)) :
    ∀ i : Fin n,
      |fl_residual fp n A y b i - residualVec n A y b i| ≤
        gamma fp (n + 1) * (|b i| + ∑ j : Fin n, |A i j| * |y j|) := by
  simpa [residualVec] using conventional_residual_error fp n A y b hn hn1

/-- Componentwise form strengthening the source equation (7.31):
`|x-x̂| ≤ |A⁻¹|(|r̂| + γ_{n+1}(|A||x̂| + |b|))`. -/
theorem eq_7_31_componentwise_bound (fp : FPModel) (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hn : gammaValid fp n) (hn1 : gammaValid fp (n + 1)) :
    ∀ i, |x i - y i| ≤ ch7ComputedResidualImage fp n A A_inv y b i := by
  have hforward := forward_error_from_residual n A A_inv x y b hInv hAx
  have hres :
      ∀ j, |residualVec n A y b j| ≤ ch7ComputedResidualSafetyTerm fp n A y b j := by
    intro j
    have h730 := eq_7_30_conventional_residual_error fp n A y b hn hn1 j
    have hrewrite :
        residualVec n A y b j =
          fl_residual fp n A y b j +
            (residualVec n A y b j - fl_residual fp n A y b j) := by
      ring
    rw [hrewrite]
    calc
      |fl_residual fp n A y b j +
          (residualVec n A y b j - fl_residual fp n A y b j)|
          ≤ |fl_residual fp n A y b j| +
              |residualVec n A y b j - fl_residual fp n A y b j| :=
                abs_add_le _ _
      _ = |fl_residual fp n A y b j| +
          |fl_residual fp n A y b j - residualVec n A y b j| := by
            rw [abs_sub_comm]
      _ ≤ |fl_residual fp n A y b j| +
          gamma fp (n + 1) * (|b j| + ∑ k : Fin n, |A j k| * |y k|) := by
            linarith
      _ = ch7ComputedResidualSafetyTerm fp n A y b j := by
            simp [ch7ComputedResidualSafetyTerm]
  intro i
  calc
    |x i - y i| ≤ ∑ j : Fin n, |A_inv i j| * |residualVec n A y b j| := hforward i
    _ ≤ ∑ j : Fin n, |A_inv i j| * ch7ComputedResidualSafetyTerm fp n A y b j := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left (hres j) (abs_nonneg _)
    _ = ch7ComputedResidualImage fp n A A_inv y b i := rfl

/-- Equation (7.31): a practical strict forward bound using the computed
residual `r̂ = fl(b - A x̂)`. -/
theorem eq_7_31_relative_infNorm_bound (fp : FPModel) (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hn : gammaValid fp n) (hn1 : gammaValid fp (n + 1))
    (hy : 0 < infNormVec y) :
    infNormVec (fun i => x i - y i) / infNormVec y ≤
      infNormVec (ch7ComputedResidualImage fp n A A_inv y b) / infNormVec y := by
  have hcomp := eq_7_31_componentwise_bound fp n A A_inv x y b hInv hAx hn hn1
  have himage_nonneg :
      ∀ i, 0 ≤ ch7ComputedResidualImage fp n A A_inv y b i := by
    intro i
    unfold ch7ComputedResidualImage ch7ComputedResidualSafetyTerm
    exact Finset.sum_nonneg fun j _ =>
      mul_nonneg (abs_nonneg _)
        (add_nonneg (abs_nonneg _)
          (mul_nonneg (gamma_nonneg fp hn1)
            (add_nonneg (abs_nonneg _)
              (Finset.sum_nonneg fun k _ =>
                mul_nonneg (abs_nonneg _) (abs_nonneg _)))))
  have hnorm :
      infNormVec (fun i => x i - y i) ≤
        infNormVec (ch7ComputedResidualImage fp n A A_inv y b) := by
    apply infNormVec_le_of_abs_le
    · intro i
      calc
        |x i - y i| ≤ ch7ComputedResidualImage fp n A A_inv y b i := hcomp i
        _ = |ch7ComputedResidualImage fp n A A_inv y b i| :=
          (abs_of_nonneg (himage_nonneg i)).symm
        _ ≤ infNormVec (ch7ComputedResidualImage fp n A A_inv y b) :=
          abs_le_infNormVec _ i
    · exact infNormVec_nonneg _
  exact div_le_div_of_nonneg_right hnorm (le_of_lt hy)

-- ============================================================
-- Problem 7.13: sparse computed residual bounds
-- ============================================================

/-- Structural support of row `i`: the columns where `A i j` is nonzero. -/
noncomputable def ch7RowSupport (n : ℕ) (A : Fin n → Fin n → ℝ) (i : Fin n) :
    Finset (Fin n) :=
  Finset.univ.filter fun j => A i j ≠ 0

lemma ch7RowSupport_card_le (n : ℕ) (A : Fin n → Fin n → ℝ) (i : Fin n) :
    (ch7RowSupport n A i).card ≤ n := by
  unfold ch7RowSupport
  exact le_trans (Finset.card_le_card (Finset.filter_subset _ _)) (by simp)

lemma ch7RowSupport_sum_eq_univ (n : ℕ) (A : Fin n → Fin n → ℝ)
    (x : Fin n → ℝ) (i : Fin n) :
    Finset.sum (ch7RowSupport n A i) (fun j => A i j * x j) =
      ∑ j : Fin n, A i j * x j := by
  unfold ch7RowSupport
  rw [Finset.sum_filter]
  apply Finset.sum_congr rfl
  intro j _
  by_cases hAj : A i j ≠ 0
  · simp [hAj]
  · have hzero : A i j = 0 := by simpa using hAj
    simp [hzero]

lemma ch7RowSupport_abs_sum_eq_univ (n : ℕ) (A : Fin n → Fin n → ℝ)
    (x : Fin n → ℝ) (i : Fin n) :
    Finset.sum (ch7RowSupport n A i) (fun j => |A i j| * |x j|) =
      ∑ j : Fin n, |A i j| * |x j| := by
  unfold ch7RowSupport
  rw [Finset.sum_filter]
  apply Finset.sum_congr rfl
  intro j _
  by_cases hAj : A i j ≠ 0
  · simp [hAj]
  · have hzero : A i j = 0 := by simpa using hAj
    simp [hzero]

/-- Support-compressed sparse matrix-vector entry for row `i`.  The row dot
product is formed only over the structural nonzeros of that row. -/
noncomputable def ch7SparseMatVecEntry (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ) (i : Fin n) : ℝ :=
  let s := ch7RowSupport n A i
  let e : Fin s.card ≃o s := s.orderIsoOfFin rfl
  fl_dotProduct fp s.card (fun k => A i (e k)) (fun k => x (e k))

/-- Sparse matrix-vector product obtained by applying `ch7SparseMatVecEntry`
row by row. -/
noncomputable def ch7SparseMatVec (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ) : Fin n → ℝ :=
  fun i => ch7SparseMatVecEntry fp n A x i

/-- Row-sparse matrix-vector forward error: if row `i` has `w_i` structural
nonzeros and its dot product is formed only on that support, the error radius
improves from `γ_n` to `γ_(w_i)`. -/
theorem ch7SparseMatVecEntry_error_bound (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (x : Fin n → ℝ) (i : Fin n)
    (hrow : gammaValid fp (ch7RowSupport n A i).card) :
    |ch7SparseMatVecEntry fp n A x i - (∑ j : Fin n, A i j * x j)| ≤
      gamma fp (ch7RowSupport n A i).card *
        (∑ j : Fin n, |A i j| * |x j|) := by
  let s : Finset (Fin n) := ch7RowSupport n A i
  let e : Fin s.card ≃o s := s.orderIsoOfFin rfl
  have hdp :
      |fl_dotProduct fp s.card (fun k => A i (e k)) (fun k => x (e k)) -
          ∑ k : Fin s.card, A i (e k) * x (e k)| ≤
        gamma fp s.card * ∑ k : Fin s.card, |A i (e k)| * |x (e k)| :=
    dotProduct_error_bound fp s.card (fun k => A i (e k)) (fun k => x (e k)) hrow
  have hsum :
      ∑ k : Fin s.card, A i (e k) * x (e k) = ∑ j : Fin n, A i j * x j := by
    calc
      ∑ k : Fin s.card, A i (e k) * x (e k)
          = ∑ j : s, A i (j : Fin n) * x (j : Fin n) := by
              exact Fintype.sum_equiv e _ _ (fun _ => rfl)
      _ = Finset.sum s (fun j => A i j * x j) := by
            simpa using
              (Finset.sum_coe_sort (s := s) (f := fun j : Fin n => A i j * x j))
      _ = ∑ j : Fin n, A i j * x j := by
            simpa [s] using ch7RowSupport_sum_eq_univ n A x i
  have hsumAbs :
      ∑ k : Fin s.card, |A i (e k)| * |x (e k)| =
        ∑ j : Fin n, |A i j| * |x j| := by
    calc
      ∑ k : Fin s.card, |A i (e k)| * |x (e k)|
          = ∑ j : s, |A i (j : Fin n)| * |x (j : Fin n)| := by
              exact Fintype.sum_equiv e _ _ (fun _ => rfl)
      _ = Finset.sum s (fun j => |A i j| * |x j|) := by
            simpa using
              (Finset.sum_coe_sort (s := s) (f := fun j : Fin n => |A i j| * |x j|))
      _ = ∑ j : Fin n, |A i j| * |x j| := by
            simpa [s] using ch7RowSupport_abs_sum_eq_univ n A x i
  unfold ch7SparseMatVecEntry
  dsimp [s, e]
  rw [← hsum, ← hsumAbs]
  exact hdp

/-- Sparse computed residual `r̂ = fl(b - A x̂)` with each row dot product
formed only over that row's structural support. -/
noncomputable def ch7SparseResidual (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (x b : Fin n → ℝ) : Fin n → ℝ :=
  fun i => fp.fl_sub (b i) (ch7SparseMatVec fp n A x i)

/-- The Problem 7.13 safety vector `|r̂| + Γ(|A||x̂| + |b|)`, where
`Γ_i = γ_(w_i+1)` and `w_i` is the number of nonzeros in row `i`. -/
noncomputable def ch7SparseComputedResidualSafetyTerm (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ) : Fin n → ℝ :=
  fun i => |ch7SparseResidual fp n A y b i| +
    gamma fp ((ch7RowSupport n A i).card + 1) *
      (|b i| + ∑ j : Fin n, |A i j| * |y j|)

/-- The Problem 7.13 image `|A⁻¹|(|r̂| + Γ(|A||x̂| + |b|))`. -/
noncomputable def ch7SparseComputedResidualImage (fp : FPModel) (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (y b : Fin n → ℝ) : Fin n → ℝ :=
  fun i => ∑ j : Fin n, |A_inv i j| * ch7SparseComputedResidualSafetyTerm fp n A y b j

/-- Problem 7.13 / Appendix A.12: if row `i` has `w_i` structural nonzeros and
the residual is computed with a support-compressed sparse matrix-vector
product, then the dense `γ_(n+1)` residual budget improves to
`γ_(w_i+1)`. -/
theorem problem7_13_sparse_residual_error (fp : FPModel) (n : ℕ)
    (A : Fin n → Fin n → ℝ) (y b : Fin n → ℝ)
    (hn1 : gammaValid fp (n + 1)) :
    ∀ i : Fin n,
      |ch7SparseResidual fp n A y b i - residualVec n A y b i| ≤
        gamma fp ((ch7RowSupport n A i).card + 1) *
          (|b i| + ∑ j : Fin n, |A i j| * |y j|) := by
  intro i
  let w := (ch7RowSupport n A i).card
  have hw1 : gammaValid fp (w + 1) := by
    apply gammaValid_mono fp
    exact Nat.succ_le_succ (ch7RowSupport_card_le n A i)
    exact hn1
  have hw : gammaValid fp w := gammaValid_mono fp (Nat.le_succ w) hw1
  unfold ch7SparseResidual
  obtain ⟨δ₁, hδ₁_le, hδ₁_eq⟩ := fp.model_sub (b i) (ch7SparseMatVec fp n A y i)
  rw [hδ₁_eq]
  have hmat :
      |ch7SparseMatVec fp n A y i - ∑ j : Fin n, A i j * y j| ≤
        gamma fp w * ∑ j : Fin n, |A i j| * |y j| := by
    simpa [ch7SparseMatVec, w] using ch7SparseMatVecEntry_error_bound fp n A y i hw
  set S := ∑ j : Fin n, |A i j| * |y j|
  have hAy : |∑ j : Fin n, A i j * y j| ≤ S := by
    calc
      |∑ j : Fin n, A i j * y j| ≤ ∑ j : Fin n, |A i j * y j| := Finset.abs_sum_le_sum_abs _ _
      _ = S := by
            simp [S, abs_mul]
  have hŷ : |ch7SparseMatVec fp n A y i| ≤ (1 + gamma fp w) * S := by
    calc
      |ch7SparseMatVec fp n A y i|
          = |∑ j : Fin n, A i j * y j +
              (ch7SparseMatVec fp n A y i - ∑ j : Fin n, A i j * y j)| := by
                ring_nf
      _ ≤ |∑ j : Fin n, A i j * y j| +
          |ch7SparseMatVec fp n A y i - ∑ j : Fin n, A i j * y j| := abs_add_le _ _
      _ ≤ S + gamma fp w * S := by
            linarith
      _ = (1 + gamma fp w) * S := by ring
  have hby : |b i - ch7SparseMatVec fp n A y i| ≤ |b i| + (1 + gamma fp w) * S := by
    calc
      |b i - ch7SparseMatVec fp n A y i| = |b i + (-ch7SparseMatVec fp n A y i)| := by ring_nf
      _ ≤ |b i| + |-ch7SparseMatVec fp n A y i| := abs_add_le _ _
      _ = |b i| + |ch7SparseMatVec fp n A y i| := by simp
      _ ≤ |b i| + (1 + gamma fp w) * S := by linarith
  have herr :
      (b i - ch7SparseMatVec fp n A y i) * (1 + δ₁) - residualVec n A y b i =
        (b i - ch7SparseMatVec fp n A y i) * δ₁ +
          (∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i) := by
    unfold residualVec
    ring
  rw [herr]
  have hbound :
      |(b i - ch7SparseMatVec fp n A y i) * δ₁ +
          (∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i)| ≤
        fp.u * (|b i| + (1 + gamma fp w) * S) + gamma fp w * S := by
    have htri_add :
        |(b i - ch7SparseMatVec fp n A y i) * δ₁ +
            (∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i)| ≤
          |(b i - ch7SparseMatVec fp n A y i) * δ₁| +
            |∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i| := by
      rw [abs_le]
      constructor <;>
        linarith [neg_abs_le ((b i - ch7SparseMatVec fp n A y i) * δ₁),
          le_abs_self ((b i - ch7SparseMatVec fp n A y i) * δ₁),
          neg_abs_le (∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i),
          le_abs_self (∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i)]
    calc
      |(b i - ch7SparseMatVec fp n A y i) * δ₁ +
          (∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i)|
          ≤ |(b i - ch7SparseMatVec fp n A y i) * δ₁| +
              |∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i| := htri_add
      _ = |δ₁| * |b i - ch7SparseMatVec fp n A y i| +
          |ch7SparseMatVec fp n A y i - ∑ j : Fin n, A i j * y j| := by
            rw [abs_mul, mul_comm]
            congr 1
            rw [abs_sub_comm]
      _ ≤ fp.u * (|b i| + (1 + gamma fp w) * S) + gamma fp w * S := by
            have h1 :
                |δ₁| * |b i - ch7SparseMatVec fp n A y i| ≤
                  fp.u * (|b i| + (1 + gamma fp w) * S) := by
              calc
                |δ₁| * |b i - ch7SparseMatVec fp n A y i|
                    ≤ fp.u * |b i - ch7SparseMatVec fp n A y i| :=
                      mul_le_mul_of_nonneg_right hδ₁_le (abs_nonneg _)
                _ ≤ fp.u * (|b i| + (1 + gamma fp w) * S) :=
                      mul_le_mul_of_nonneg_left hby fp.u_nonneg
            have h2 :
                |ch7SparseMatVec fp n A y i - ∑ j : Fin n, A i j * y j| ≤
                  gamma fp w * S := by
              simpa [S] using hmat
            linarith
  have hγ_sum :
      gamma fp 1 + gamma fp w + gamma fp 1 * gamma fp w ≤ gamma fp (w + 1) := by
    have h := gamma_sum_le fp 1 w (by simpa [Nat.add_comm] using hw1)
    simpa [Nat.add_comm] using h
  have h1valid : gammaValid fp 1 := gammaValid_mono fp (Nat.succ_le_succ (Nat.zero_le w)) hw1
  have hu_le_γ1 : fp.u ≤ gamma fp 1 := u_le_gamma fp one_pos h1valid
  have hγw_nn : 0 ≤ gamma fp w := gamma_nonneg fp hw
  have hu_γw_sum : fp.u + gamma fp w + fp.u * gamma fp w ≤ gamma fp (w + 1) := by
    have h1 : fp.u + gamma fp w ≤ gamma fp 1 + gamma fp w := by linarith
    have h2 : fp.u * gamma fp w ≤ gamma fp 1 * gamma fp w :=
      mul_le_mul_of_nonneg_right hu_le_γ1 hγw_nn
    linarith
  have hu_le_γw1 : fp.u ≤ gamma fp (w + 1) := by
    exact le_trans hu_le_γ1 (gamma_mono fp (Nat.succ_le_succ (Nat.zero_le w)) hw1)
  have hS_nn : 0 ≤ S := Finset.sum_nonneg fun j _ => mul_nonneg (abs_nonneg _) (abs_nonneg _)
  have hb_nn : 0 ≤ |b i| := abs_nonneg _
  calc
    |(b i - ch7SparseMatVec fp n A y i) * δ₁ +
        (∑ j : Fin n, A i j * y j - ch7SparseMatVec fp n A y i)|
        ≤ fp.u * (|b i| + (1 + gamma fp w) * S) + gamma fp w * S := hbound
    _ = fp.u * |b i| + (fp.u + gamma fp w + fp.u * gamma fp w) * S := by ring
    _ ≤ gamma fp (w + 1) * |b i| + gamma fp (w + 1) * S := by
          have h1 : fp.u * |b i| ≤ gamma fp (w + 1) * |b i| :=
            mul_le_mul_of_nonneg_right hu_le_γw1 hb_nn
          have h2 :
              (fp.u + gamma fp w + fp.u * gamma fp w) * S ≤
                gamma fp (w + 1) * S :=
            mul_le_mul_of_nonneg_right hu_γw_sum hS_nn
          linarith
    _ = gamma fp (w + 1) * (|b i| + S) := by ring

/-- Problem 7.13: support-compressed sparse residual computation improves the
practical forward-error image from the dense `γ_(n+1)` budget to the row-wise
diagonal `γ_(w_i+1)` budget. -/
theorem problem7_13_componentwise_bound (fp : FPModel) (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hn1 : gammaValid fp (n + 1)) :
    ∀ i, |x i - y i| ≤ ch7SparseComputedResidualImage fp n A A_inv y b i := by
  have hforward := forward_error_from_residual n A A_inv x y b hInv hAx
  have hres :
      ∀ j, |residualVec n A y b j| ≤ ch7SparseComputedResidualSafetyTerm fp n A y b j := by
    intro j
    have h713 := problem7_13_sparse_residual_error fp n A y b hn1 j
    have hrewrite :
        residualVec n A y b j =
          ch7SparseResidual fp n A y b j +
            (residualVec n A y b j - ch7SparseResidual fp n A y b j) := by
      ring
    rw [hrewrite]
    calc
      |ch7SparseResidual fp n A y b j +
          (residualVec n A y b j - ch7SparseResidual fp n A y b j)|
          ≤ |ch7SparseResidual fp n A y b j| +
              |residualVec n A y b j - ch7SparseResidual fp n A y b j| :=
                abs_add_le _ _
      _ = |ch7SparseResidual fp n A y b j| +
          |ch7SparseResidual fp n A y b j - residualVec n A y b j| := by
            rw [abs_sub_comm]
      _ ≤ |ch7SparseResidual fp n A y b j| +
          gamma fp ((ch7RowSupport n A j).card + 1) *
            (|b j| + ∑ k : Fin n, |A j k| * |y k|) := by
            linarith
      _ = ch7SparseComputedResidualSafetyTerm fp n A y b j := by
            simp [ch7SparseComputedResidualSafetyTerm]
  intro i
  calc
    |x i - y i| ≤ ∑ j : Fin n, |A_inv i j| * |residualVec n A y b j| := hforward i
    _ ≤ ∑ j : Fin n, |A_inv i j| * ch7SparseComputedResidualSafetyTerm fp n A y b j := by
          apply Finset.sum_le_sum
          intro j _
          exact mul_le_mul_of_nonneg_left (hres j) (abs_nonneg _)
    _ = ch7SparseComputedResidualImage fp n A A_inv y b i := rfl

/-- Problem 7.13, source-facing relative infinity-norm form:
if row `i` has `w_i` structural nonzeros and the residual is computed with a
support-compressed sparse matrix-vector product, then `(7.31)` improves from
the dense `γ_(n+1)` budget to the diagonal `γ_(w_i+1)` budget. -/
theorem problem7_13_relative_infNorm_bound (fp : FPModel) (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (x y b : Fin n → ℝ)
    (hInv : IsLeftInverse n A A_inv)
    (hAx : ∀ i, ∑ j : Fin n, A i j * x j = b i)
    (hn1 : gammaValid fp (n + 1))
    (hy : 0 < infNormVec y) :
    infNormVec (fun i => x i - y i) / infNormVec y ≤
      infNormVec (ch7SparseComputedResidualImage fp n A A_inv y b) / infNormVec y := by
  have hcomp := problem7_13_componentwise_bound fp n A A_inv x y b hInv hAx hn1
  have himage_nonneg :
      ∀ i, 0 ≤ ch7SparseComputedResidualImage fp n A A_inv y b i := by
    intro i
    unfold ch7SparseComputedResidualImage ch7SparseComputedResidualSafetyTerm
    exact Finset.sum_nonneg fun j _ =>
      mul_nonneg (abs_nonneg _)
        (add_nonneg (abs_nonneg _)
          (mul_nonneg
            (gamma_nonneg fp
              (gammaValid_mono fp
                (Nat.succ_le_succ (ch7RowSupport_card_le n A j)) hn1))
            (add_nonneg (abs_nonneg _)
              (Finset.sum_nonneg fun k _ =>
                mul_nonneg (abs_nonneg _) (abs_nonneg _)))))
  have hnorm :
      infNormVec (fun i => x i - y i) ≤
        infNormVec (ch7SparseComputedResidualImage fp n A A_inv y b) := by
    apply infNormVec_le_of_abs_le
    · intro i
      calc
        |x i - y i| ≤ ch7SparseComputedResidualImage fp n A A_inv y b i := hcomp i
        _ = |ch7SparseComputedResidualImage fp n A A_inv y b i| :=
          (abs_of_nonneg (himage_nonneg i)).symm
        _ ≤ infNormVec (ch7SparseComputedResidualImage fp n A A_inv y b) :=
          abs_le_infNormVec _ i
    · exact infNormVec_nonneg _
  exact div_le_div_of_nonneg_right hnorm (le_of_lt hy)

-- ============================================================
-- Equation (7.32): perturbation theory by calculus
-- ============================================================

/-- Equation (7.32) after differentiating `A(t)x(t) = b(t)`, in the source's
arbitrary subordinate-norm form.  Here `A`, `Ainv`, and `A_dot` denote their
values at the point under consideration, while `x_dot` and `b_dot` are the
corresponding derivatives.  The hypothesis `hdiff` is the differentiated
system `A_dot*x + A*x_dot = b_dot`.  If `a`, `s`, and `d` are the exact
subordinate norm values of `A`, `Ainv`, and `A_dot`, the conclusion is the
complete inequality-and-equality chain printed in (7.32). -/
theorem eq_7_32_subordinate_from_differentiated_system
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A Ainv A_dot : CMatrix n n} {a s d : ℝ}
    {x x_dot b_dot : CVec n}
    (hA : IsMixedSubordinateMatrixNormValue ν ν A a)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (hAdot : IsMixedSubordinateMatrixNormValue ν ν A_dot d)
    (hInv : IsComplexMatrixLeftInverse A Ainv)
    (hx : 0 < ν x)
    (hdiff : ∀ i : Fin n,
      complexMatrixVecMul A_dot x i + complexMatrixVecMul A x_dot i = b_dot i) :
    ν x_dot / ν x ≤ s * d + s * ν b_dot / ν x ∧
      s * d + s * ν b_dot / ν x =
        (a * s) * (d / a + ν b_dot / (a * ν x)) := by
  have hAxdot :
      complexMatrixVecMul A x_dot =
        fun i => b_dot i - complexMatrixVecMul A_dot x i := by
    ext i
    exact eq_sub_of_add_eq' (hdiff i)
  have hidentity :
      x_dot = complexMatrixVecMul Ainv
        (fun i => b_dot i - complexMatrixVecMul A_dot x i) := by
    calc
      x_dot = complexMatrixVecMul Ainv (complexMatrixVecMul A x_dot) :=
        (hInv x_dot).symm
      _ = complexMatrixVecMul Ainv
          (fun i => b_dot i - complexMatrixVecMul A_dot x i) := by rw [hAxdot]
  have hs : 0 ≤ s :=
    mixedSubordinateNormValue_nonneg_of_nonempty hn hν hν hAinv
  have ha : 0 < a := by
    have ha0 : 0 ≤ a :=
      mixedSubordinateNormValue_nonneg_of_nonempty hn hν hν hA
    refine lt_of_le_of_ne ha0 ?_
    intro ha_zero
    obtain ⟨u, hu⟩ := exists_unit_complexVectorNorm hν hn
    have hAu_le := hA.1 u
    rw [← ha_zero, zero_mul] at hAu_le
    have hAu_norm_zero : ν (complexMatrixVecMul A u) = 0 :=
      le_antisymm hAu_le (hν.nonneg _)
    have hAu_zero : complexMatrixVecMul A u = 0 :=
      (hν.eq_zero_iff _).mp hAu_norm_zero
    have hu_zero : u = 0 := by
      have hi := hInv u
      rw [hAu_zero] at hi
      calc
        u = complexMatrixVecMul Ainv (0 : CVec n) := hi.symm
        _ = 0 := by
          ext i
          simp [complexMatrixVecMul]
    have hνzero : ν (0 : CVec n) = 0 := (hν.eq_zero_iff _).2 rfl
    rw [hu_zero, hνzero] at hu
    norm_num at hu
  have htri :
      ν (fun i => b_dot i - complexMatrixVecMul A_dot x i) ≤
        ν b_dot + ν (complexMatrixVecMul A_dot x) := by
    calc
      ν (fun i => b_dot i - complexMatrixVecMul A_dot x i) =
          ν (complexVecAdd b_dot
            (complexVecSMul (-1) (complexMatrixVecMul A_dot x))) := by
              congr 1
              ext i
              simp [complexVecAdd, complexVecSMul, sub_eq_add_neg]
      _ ≤ ν b_dot + ν (complexVecSMul (-1) (complexMatrixVecMul A_dot x)) :=
        hν.add_le _ _
      _ = ν b_dot + ν (complexMatrixVecMul A_dot x) := by
        rw [hν.smul]
        norm_num
  have hnum :
      ν x_dot ≤ (s * d) * ν x + s * ν b_dot := by
    calc
      ν x_dot = ν (complexMatrixVecMul Ainv
          (fun i => b_dot i - complexMatrixVecMul A_dot x i)) := by rw [hidentity]
      _ ≤ s * ν (fun i => b_dot i - complexMatrixVecMul A_dot x i) :=
        hAinv.1 _
      _ ≤ s * (ν b_dot + ν (complexMatrixVecMul A_dot x)) :=
        mul_le_mul_of_nonneg_left htri hs
      _ ≤ s * (ν b_dot + d * ν x) :=
        mul_le_mul_of_nonneg_left (add_le_add_right (hAdot.1 x) _) hs
      _ = (s * d) * ν x + s * ν b_dot := by ring
  constructor
  · rw [div_le_iff₀ hx]
    calc
      ν x_dot ≤ (s * d) * ν x + s * ν b_dot := hnum
      _ = (s * d + s * ν b_dot / ν x) * ν x := by
        field_simp [ne_of_gt hx]
  · field_simp [ne_of_gt ha, ne_of_gt hx]

/-- Equation (7.32), end-to-end calculus form.  Coordinatewise derivative
witnesses for the continuously differentiable source functions and the exact
identity `A(t)x(t) = b(t)` yield `A_dot*x + A*x_dot = b_dot` by the finite-sum
product rule.  The theorem then returns the complete arbitrary
subordinate-norm chain from the printed display.  `HasDerivAt` is the local
property needed by (7.32); global continuous differentiability is a stronger
source assumption that supplies these witnesses. -/
theorem eq_7_32_subordinate_differentiable_system
    {n : ℕ} (hn : 0 < n) {ν : CVec n → ℝ} (hν : IsComplexVectorNorm ν)
    {A : ℝ → CMatrix n n} {x b : ℝ → CVec n} {t : ℝ}
    {A_dot : CMatrix n n} {x_dot b_dot : CVec n}
    {Ainv : CMatrix n n} {a s d : ℝ}
    (hAderiv : ∀ i j, HasDerivAt (fun τ => A τ i j) (A_dot i j) t)
    (hxderiv : ∀ j, HasDerivAt (fun τ => x τ j) (x_dot j) t)
    (hbderiv : ∀ i, HasDerivAt (fun τ => b τ i) (b_dot i) t)
    (hsystem : ∀ τ, complexMatrixVecMul (A τ) (x τ) = b τ)
    (hA : IsMixedSubordinateMatrixNormValue ν ν (A t) a)
    (hAinv : IsMixedSubordinateMatrixNormValue ν ν Ainv s)
    (hAdot : IsMixedSubordinateMatrixNormValue ν ν A_dot d)
    (hInv : IsComplexMatrixLeftInverse (A t) Ainv)
    (hx : 0 < ν (x t)) :
    ν x_dot / ν (x t) ≤ s * d + s * ν b_dot / ν (x t) ∧
      s * d + s * ν b_dot / ν (x t) =
        (a * s) * (d / a + ν b_dot / (a * ν (x t))) := by
  have hdiff : ∀ i : Fin n,
      complexMatrixVecMul A_dot (x t) i +
          complexMatrixVecMul (A t) x_dot i = b_dot i := by
    intro i
    have hprod :
        HasDerivAt
          (fun τ => complexMatrixVecMul (A τ) (x τ) i)
          (Finset.univ.sum (fun j : Fin n =>
            (A_dot i j) * (x t j) + (A t i j) * (x_dot j))) t := by
      unfold complexMatrixVecMul
      have hsum :=
        HasDerivAt.sum (u := Finset.univ)
          (fun j _hj => (hAderiv i j).mul (hxderiv j))
      convert hsum using 1
      ext τ
      simp
    have heq :
        (fun τ => complexMatrixVecMul (A τ) (x τ) i) =
          fun τ => b τ i := by
      funext τ
      exact congrFun (hsystem τ) i
    rw [heq] at hprod
    have hvalue := hprod.unique (hbderiv i)
    simpa [complexMatrixVecMul, Finset.sum_add_distrib] using hvalue
  exact eq_7_32_subordinate_from_differentiated_system
    hn hν hA hAinv hAdot hInv hx hdiff

-- ============================================================
-- Equation (7.33): stochastic matrices
-- ============================================================

/-- A finite row-stochastic matrix: nonnegative entries and each row sums to 1. -/
def IsStochasticMatrix (n : ℕ) (P : Fin n → Fin n → ℝ) : Prop :=
  (∀ i j, 0 ≤ P i j) ∧ (∀ i, ∑ j : Fin n, P i j = 1)

/-- Equation (7.33): a stochastic matrix satisfies `P e = e`. -/
theorem stochasticMatrix_mul_ones (n : ℕ) (P : Fin n → Fin n → ℝ)
    (hP : IsStochasticMatrix n P) :
    matMulVec n P (fun _ : Fin n => (1 : ℝ)) = fun _ : Fin n => (1 : ℝ) := by
  ext i
  unfold matMulVec
  simpa using hP.2 i


/-! ## Theorem 7.8 (Bauer) — source-labeled aliases

Higham 2nd ed., Chapter 7, §7.3, Theorem 7.8 (p. 127, eq. (7.24)): for
nonsingular `A` with `|A||A⁻¹|` and `|A⁻¹||A|` irreducible,
`min_{D₁,D₂ ∈ 𝒟ₙ} κ_∞(D₁AD₂) = ρ(|A||A⁻¹|)`. The book's proof is delegated
to Problem 7.10, so the full formalization lives in the `problem7_10*`
family (with `B = |A|`, `C = |A⁻¹|`); these thin aliases give the primary
source label its own traceable surface. -/

/-- **Theorem 7.8 (Bauer), eq. (7.24)** — infinity-norm scaled-condition form:
the infimum of the two-sided diagonally scaled condition numbers equals the
Perron/spectral radius of the nonnegative product. Alias of
`problem7_10a_irreducible_products_scaledInfCondSet_sInf_eq_spectralRadius`. -/
alias theorem7_8_bauer_scaledInfCondSet_sInf_eq_spectralRadius :=
  problem7_10a_irreducible_products_scaledInfCondSet_sInf_eq_spectralRadius

/-- **Theorem 7.8 (Bauer), eq. (7.24)** — kappa form of the same equality.
Alias of
`problem7_10b_irreducible_products_scaledInfKappaSet_sInf_eq_spectralRadius`. -/
alias theorem7_8_bauer_scaledInfKappaSet_sInf_eq_spectralRadius :=
  problem7_10b_irreducible_products_scaledInfKappaSet_sInf_eq_spectralRadius

/-- **Theorem 7.8 (Bauer), eq. (7.24)** — attained-minimum form:
the spectral-radius witness is the least element of the two-sided diagonally
