/-- Theorem 7.5, equation `(7.19)`, finite-real pairwise row-equilibration
form using the conjugate row `q`-norm dictated by the transpose proof route.
The full printed Moore-Penrose/minimum statement remains separate. -/
theorem theorem7_5_lp_dual_row_equilibration_le_card_rpow_left_scaling
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowDualLpNormOfReal q A i)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus
        (ch7RowDualEquilibratingScaleLpOfReal q A)
        (fun i : Fin m => ch7RectRowDualLpNormOfReal q A i) ≤
      (m : ℝ) ^ p⁻¹ *
        ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d dInv := by
  unfold ch7LpLeftScaledCondOfReal
  let DAr : Fin m → Fin n → ℝ :=
    ch7RectLeftScale (ch7RowDualEquilibratingScaleLpOfReal q A) A
  let AplusDrInv : Fin n → Fin m → ℝ :=
    ch7RectRightScale Aplus
      (fun i : Fin m => ch7RectRowDualLpNormOfReal q A i)
  let DA : Fin m → Fin n → ℝ := ch7RectLeftScale d A
  let AplusDinv : Fin n → Fin m → ℝ := ch7RectRightScale Aplus dInv
  have hDAr :
      complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt) (realRectToCMatrix DAr) ≤
        (m : ℝ) ^ p⁻¹ := by
    dsimp [DAr]
    exact eq_7_19_matrixLpNormOfReal_dual_row_equilibrated hm hn hpq A hrow
  have hside :
      complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
          (realRectToCMatrix AplusDrInv) ≤
        complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
            (realRectToCMatrix DA) *
          complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
            (realRectToCMatrix AplusDinv) := by
    dsimp [AplusDrInv, DA, AplusDinv]
    exact eq_7_19_matrixLpNormOfReal_dual_row_inverseSide_bound
      hm hn hpq A Aplus d dInv hdiag
  have hAplusDrInv_nonneg :
      0 ≤ complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
        (realRectToCMatrix AplusDrInv) :=
    ch7_complexMatrixLpNormOfReal_nonneg hm (le_of_lt hpq.lt) _
  have hfactor_nonneg : 0 ≤ (m : ℝ) ^ p⁻¹ :=
    Real.rpow_nonneg (Nat.cast_nonneg m) _
  calc
    complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt) (realRectToCMatrix DAr) *
        complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
          (realRectToCMatrix AplusDrInv)
        ≤ (m : ℝ) ^ p⁻¹ *
            complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
              (realRectToCMatrix AplusDrInv) :=
          mul_le_mul_of_nonneg_right hDAr hAplusDrInv_nonneg
    _ ≤ (m : ℝ) ^ p⁻¹ *
          (complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt) (realRectToCMatrix DA) *
            complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
              (realRectToCMatrix AplusDinv)) :=
          mul_le_mul_of_nonneg_left hside hfactor_nonneg
    _ = (m : ℝ) ^ p⁻¹ *
          (complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt) (realRectToCMatrix DA) *
            complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
              (realRectToCMatrix AplusDinv)) := rfl

/-- Theorem 7.5, equation `(7.19)`, finite-real infimum form over reciprocal
left scalings for the conjugate-row explicit condition product. -/
theorem theorem7_5_lp_dual_row_equilibration_le_card_rpow_sInf_left_scalings
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowDualLpNormOfReal q A i) :
    ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus
        (ch7RowDualEquilibratingScaleLpOfReal q A)
        (fun i : Fin m => ch7RectRowDualLpNormOfReal q A i) ≤
      (m : ℝ) ^ p⁻¹ *
        sInf (ch7LpLeftScaledCondSetOfReal hm hn p (le_of_lt hpq.lt) A Aplus) := by
  let c : ℝ :=
    ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus
      (ch7RowDualEquilibratingScaleLpOfReal q A)
      (fun i : Fin m => ch7RectRowDualLpNormOfReal q A i)
  let S : Set ℝ := ch7LpLeftScaledCondSetOfReal hm hn p (le_of_lt hpq.lt) A Aplus
  let α : ℝ := (m : ℝ) ^ p⁻¹
  have hmR : 0 < (m : ℝ) := by exact_mod_cast hm
  have hαpos : 0 < α := by
    dsimp [α]
    exact Real.rpow_pos_of_pos hmR p⁻¹
  have hαnonneg : 0 ≤ α := le_of_lt hαpos
  have hS_nonempty : S.Nonempty := by
    simpa [S] using
      ch7LpLeftScaledCondSetOfReal_nonempty hm hn (le_of_lt hpq.lt) A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → c / α ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    have hpair :
        c ≤ α *
          ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d dInv := by
      dsimp [c, α]
      exact theorem7_5_lp_dual_row_equilibration_le_card_rpow_left_scaling
        hm hn hpq A Aplus hrow d dInv hdiag
    rw [div_le_iff₀ hαpos]
    simpa [mul_comm] using hpair
  have hsInf : c / α ≤ sInf S := le_csInf hS_nonempty hlower
  have hmul : α * (c / α) ≤ α * sInf S :=
    mul_le_mul_of_nonneg_left hsInf hαnonneg
  have hrewrite : α * (c / α) = c := by
    field_simp [ne_of_gt hαpos]
  change c ≤ α * sInf S
  exact hrewrite ▸ hmul

