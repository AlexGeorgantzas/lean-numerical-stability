theorem problem7_10a_scaledInfCondSet_isLeast_perron_of_positive_eigenvector
    {n : ℕ} (hn : 0 < n)
    (B C : Fin n → Fin n → ℝ) (ρ : ℝ) (x : Fin n → ℝ)
    (hB : ∀ i j : Fin n, 0 ≤ B i j)
