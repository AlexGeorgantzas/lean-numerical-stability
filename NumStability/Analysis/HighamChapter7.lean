/-- Relative quadratic-remainder coefficient for the exact normwise Problem
7.9 bridge.  The nonlinear inverse-existence and remainder bounds reuse the
componentwise Problem 7.11 machinery with a conservative constant
componentwise envelope derived from the normwise perturbation radius. -/
noncomputable def ch7Problem79NormwiseExactRemainderBound (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (C_B : ℝ) : ℝ :=
  ch7Problem79ComponentwiseExactRemainderBound n A_inv
    (ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm)
    (ch7Problem79NormwiseConstantEnvelopeVector n f_norm) c x C_B

lemma ch7Problem79NormwiseExactRemainderBound_nonneg (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (C_B : ℝ)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hCB : 0 ≤ C_B) (hden : 0 < |ch7LinearFunctional n c x|) :
    0 ≤ ch7Problem79NormwiseExactRemainderBound
      n A_inv E_norm f_norm c x C_B := by
  unfold ch7Problem79NormwiseExactRemainderBound
  exact
    ch7Problem79ComponentwiseExactRemainderBound_nonneg n A_inv
      (ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm)
      (ch7Problem79NormwiseConstantEnvelopeVector n f_norm) c x C_B
      (by intro i j; exact hE) (by intro i; exact hf) hCB hden

/-- Exact finite upper bridge for Problem 7.9 normwise scalar-output
perturbations.  The nonlinear scalar change is bounded by the checked
normwise linearized formula plus a quadratic remainder. -/
theorem problem7_9_exact_normwise_relative_change_le_linearized_plus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA B : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ)
    (E_norm f_norm ε C_B : ℝ)
    (hε : 0 ≤ ε) (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hΔA : opNorm2Le ΔA (ε * E_norm))
    (hΔb : vecNorm2 Δb ≤ ε * f_norm)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B)
    (hBnorm : infNorm B ≤ C_B) :
    ch7Problem79ExactScalarRelativeChange n A B c x Δb ≤
      ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x +
        ε ^ 2 *
          ch7Problem79NormwiseExactRemainderBound
            n A_inv E_norm f_norm c x C_B := by
  let E := ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm
  let f := ch7Problem79NormwiseConstantEnvelopeVector n f_norm
  let Rem : Fin n → ℝ :=
    matMulVec n (matMul n (matMul n A_inv ΔA) B)
      (fun j => Δb j - matMulVec n ΔA x j)
  have hEcomp : ∀ i j, 0 ≤ E i j := by
    intro i j
    exact hE
  have hfcomp : ∀ i, 0 ≤ f i := by
    intro i
    exact hf
  have hΔAcomp : ∀ i j, |ΔA i j| ≤ ε * E i j := by
    intro i j
    exact ch7Problem79_normwise_deltaA_componentwise_bound n ΔA E_norm ε
      hΔA i j
  have hΔbcomp : ∀ i, |Δb i| ≤ ε * f i := by
    intro i
    exact ch7Problem79_normwise_deltaB_componentwise_bound Δb f_norm ε
      hΔb i
  have hscalar :=
    ch7Problem79_exact_scalar_decomposition n A A_inv ΔA B c x Δb
      hLeft hRight
  have hrem :=
    ch7Problem79_exact_scalar_remainder_abs_le n hn A_inv ΔA B E f c x Δb
      ε C_B hε hEcomp hfcomp hΔAcomp hΔbcomp hBnorm
  have hlin :=
    ch7Problem79_normwiseLinearizedRelativeChange_le
      n A_inv ΔA c x Δb E_norm f_norm ε hden hΔA hΔb
  have hden_nonneg : 0 ≤ |ch7LinearFunctional n c x| := le_of_lt hden
  unfold ch7Problem79ExactScalarRelativeChange
  calc
    |ch7LinearFunctional n c
        (fun i => ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i)| /
        |ch7LinearFunctional n c x|
        ≤
        (|ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| +
          |ch7LinearFunctional n c Rem|) /
          |ch7LinearFunctional n c x| := by
          apply div_le_div_of_nonneg_right _ hden_nonneg
          rw [hscalar]
          simpa [Rem, sub_eq_add_neg] using
            abs_add_le (ch7Problem79FirstOrderChange n A_inv c x Δb ΔA)
              (-(ch7LinearFunctional n c Rem))
    _ =
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA +
          |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| := by
          unfold ch7Problem79LinearizedRelativeChange
          rw [add_div]
    _ ≤
        ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x +
          (ε ^ 2 *
            ((∑ i : Fin n, |c i|) *
              (infNorm (ch7InverseFirstProductSensitivity n A_inv E) * C_B *
                ch7Problem79ComponentwiseRhsEnvelope n E f x))) /
            |ch7LinearFunctional n c x| :=
          add_le_add hlin (div_le_div_of_nonneg_right hrem hden_nonneg)
    _ =
        ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x +
          ε ^ 2 *
            ch7Problem79NormwiseExactRemainderBound
              n A_inv E_norm f_norm c x C_B := by
          unfold ch7Problem79NormwiseExactRemainderBound
            ch7Problem79ComponentwiseExactRemainderBound
          ring

/-- Lower companion to the exact Problem 7.9 normwise bridge.  When the
first-order perturbation attains the normwise linearized condition number, the
exact nonlinear scalar change is within the same quadratic remainder from
below. -/
theorem problem7_9_exact_normwise_relative_change_ge_linearized_minus_quadratic
    (n : ℕ) (hn : 0 < n)
    (A A_inv ΔA B : Fin n → Fin n → ℝ) (c x Δb : Fin n → ℝ)
    (E_norm f_norm ε C_B : ℝ)
    (hε : 0 ≤ ε) (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hΔA : opNorm2Le ΔA (ε * E_norm))
    (hΔb : vecNorm2 Δb ≤ ε * f_norm)
    (hLeft : IsLeftInverse n A A_inv)
    (hRight : IsRightInverse n (fun i j => A i j + ΔA i j) B)
    (hBnorm : infNorm B ≤ C_B)
    (hlin :
      ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA =
        ε * ch7Problem79NormwiseLinearizedCond
          n A_inv E_norm f_norm c x) :
    ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x -
        ε ^ 2 *
          ch7Problem79NormwiseExactRemainderBound
            n A_inv E_norm f_norm c x C_B ≤
      ch7Problem79ExactScalarRelativeChange n A B c x Δb := by
  let E := ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm
  let f := ch7Problem79NormwiseConstantEnvelopeVector n f_norm
  let Rem : Fin n → ℝ :=
    matMulVec n (matMul n (matMul n A_inv ΔA) B)
      (fun j => Δb j - matMulVec n ΔA x j)
  have hEcomp : ∀ i j, 0 ≤ E i j := by
    intro i j
    exact hE
  have hfcomp : ∀ i, 0 ≤ f i := by
    intro i
    exact hf
  have hΔAcomp : ∀ i j, |ΔA i j| ≤ ε * E i j := by
    intro i j
    exact ch7Problem79_normwise_deltaA_componentwise_bound n ΔA E_norm ε
      hΔA i j
  have hΔbcomp : ∀ i, |Δb i| ≤ ε * f i := by
    intro i
    exact ch7Problem79_normwise_deltaB_componentwise_bound Δb f_norm ε
      hΔb i
  have hscalar :=
    ch7Problem79_exact_scalar_decomposition n A A_inv ΔA B c x Δb
      hLeft hRight
  have hrem :=
    ch7Problem79_exact_scalar_remainder_abs_le n hn A_inv ΔA B E f c x Δb
      ε C_B hε hEcomp hfcomp hΔAcomp hΔbcomp hBnorm
  have hden_nonneg : 0 ≤ |ch7LinearFunctional n c x| := le_of_lt hden
  have hrem_div :
      |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| ≤
        ε ^ 2 *
          ch7Problem79NormwiseExactRemainderBound
            n A_inv E_norm f_norm c x C_B := by
    calc
      |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x|
          ≤ (ε ^ 2 *
              ((∑ i : Fin n, |c i|) *
                (infNorm (ch7InverseFirstProductSensitivity n A_inv E) * C_B *
                  ch7Problem79ComponentwiseRhsEnvelope n E f x))) /
              |ch7LinearFunctional n c x| :=
            div_le_div_of_nonneg_right hrem hden_nonneg
      _ = ε ^ 2 *
            ch7Problem79NormwiseExactRemainderBound
              n A_inv E_norm f_norm c x C_B := by
            unfold ch7Problem79NormwiseExactRemainderBound
              ch7Problem79ComponentwiseExactRemainderBound
            ring
  have habs :
      |ch7Problem79FirstOrderChange n A_inv c x Δb ΔA| -
          |ch7LinearFunctional n c Rem| ≤
        |ch7LinearFunctional n c
          (fun i => ch7Problem79PerturbedSolutionWithInverse n A B x Δb i - x i)| := by
    have hbase :=
      abs_sub_abs_le_abs_sub
        (ch7Problem79FirstOrderChange n A_inv c x Δb ΔA)
        (ch7LinearFunctional n c Rem)
    rw [hscalar]
    exact hbase
  have hdiv :
      ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA -
          |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| ≤
        ch7Problem79ExactScalarRelativeChange n A B c x Δb := by
    unfold ch7Problem79LinearizedRelativeChange
      ch7Problem79ExactScalarRelativeChange
    have h :=
      div_le_div_of_nonneg_right habs hden_nonneg
    simpa [sub_div] using h
  have hsub :
      ε * ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x -
          ε ^ 2 *
            ch7Problem79NormwiseExactRemainderBound
              n A_inv E_norm f_norm c x C_B ≤
        ch7Problem79LinearizedRelativeChange n A_inv c x Δb ΔA -
          |ch7LinearFunctional n c Rem| / |ch7LinearFunctional n c x| := by
    linarith
  exact le_trans hsub hdiv

/-- Exact source-radius feasible scalar-output values for the normwise Problem
7.9 condition number. -/
def Ch7Problem79NormwiseExactRadiusSet
    (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (rho : ℝ) : Set ℝ :=
  { q | ∃ ε : ℝ, ∃ ΔA : Fin n → Fin n → ℝ, ∃ Δb : Fin n → ℝ,
      0 < ε ∧
      ε ≤ rho ∧
      opNorm2Le ΔA (ε * E_norm) ∧
      vecNorm2 Δb ≤ ε * f_norm ∧
      q =
        ch7Problem79ExactScalarRelativeChange n A
          (ch7Problem711PerturbedInverseCandidate n A_inv ΔA) c x Δb / ε }

/-- Supremum over the exact normwise scalar-output radius set in Problem
7.9. -/
noncomputable def ch7Problem79NormwiseExactRadiusSup
    (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (rho : ℝ) : ℝ :=
  sSup (Ch7Problem79NormwiseExactRadiusSet
    n A A_inv E_norm f_norm c x rho)

/-- Limit-value predicate for the exact normwise scalar-output condition
number in Problem 7.9. -/
def IsCh7Problem79NormwiseExactRadiusLimitValue
    {ι : Type*} (l : Filter ι)
    (n : ℕ)
    (A A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (rho : ι → ℝ) (κ : ℝ) : Prop :=
  Filter.Tendsto
    (fun t => ch7Problem79NormwiseExactRadiusSup
      n A A_inv E_norm f_norm c x (rho t))
    l (nhds κ)

/-- Value predicate for the exact normwise scalar-output condition number: the
nonlinear source value equals the checked finite normwise linearized formula. -/
def IsCh7Problem79NormwiseExactCondValue
    (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (κ : ℝ) : Prop :=
  κ = ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x

/-- Radius-level quadratic coefficient for the exact normwise Problem 7.9
source squeeze, using the uniform local inverse bound from Problem 7.11. -/
noncomputable def ch7Problem79NormwiseExactRadiusRemainderBound (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) : ℝ :=
  ch7Problem79NormwiseExactRemainderBound n A_inv E_norm f_norm c x
    (ch7Problem711LocalInverseInfNormBound n A_inv)

lemma ch7Problem79NormwiseExactRadiusRemainderBound_nonneg (n : ℕ)
    (A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|) :
    0 ≤ ch7Problem79NormwiseExactRadiusRemainderBound
      n A_inv E_norm f_norm c x := by
  unfold ch7Problem79NormwiseExactRadiusRemainderBound
  exact
    ch7Problem79NormwiseExactRemainderBound_nonneg n A_inv
      E_norm f_norm c x (ch7Problem711LocalInverseInfNormBound n A_inv)
      hE hf (ch7Problem711LocalInverseInfNormBound_nonneg n A_inv) hden

/-- Upper envelope for every exact source-radius feasible scalar-output value
in the normwise Problem 7.9 set. -/
theorem ch7Problem79NormwiseExactRadiusSet_value_le
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) {rho q : ℝ}
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hLeft : IsLeftInverse n A A_inv)
    (hsmall :
      rho *
          infNorm
            (ch7InverseFirstProductSensitivity n A_inv
              (ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm)) ≤
        (1 / 2 : ℝ))
    (hq :
      q ∈ Ch7Problem79NormwiseExactRadiusSet
        n A A_inv E_norm f_norm c x rho) :
    q ≤ ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x +
      rho * ch7Problem79NormwiseExactRadiusRemainderBound
        n A_inv E_norm f_norm c x := by
  rcases hq with ⟨ε, ΔA, Δb, hεpos, hερ, hΔA, hΔb, rfl⟩
  let E := ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm
  let B := ch7Problem711PerturbedInverseCandidate n A_inv ΔA
  let C := ch7Problem79NormwiseExactRadiusRemainderBound
    n A_inv E_norm f_norm c x
  have hε : 0 ≤ ε := le_of_lt hεpos
  have hEcomp : ∀ i j, 0 ≤ E i j := by
    intro i j
    exact hE
  have hΔAcomp : ∀ i j, |ΔA i j| ≤ ε * E i j := by
    intro i j
    exact ch7Problem79_normwise_deltaA_componentwise_bound n ΔA E_norm ε
      hΔA i j
  have hRight :
      IsRightInverse n (fun i j => A i j + ΔA i j) B :=
    ch7_inverse_componentwise_radius_candidate_right_inverse_of_small
      n hn A A_inv ΔA E ε rho hε hερ hEcomp hΔAcomp hLeft
      (by simpa [E] using hsmall)
  have hBnorm :
      infNorm B ≤ ch7Problem711LocalInverseInfNormBound n A_inv :=
    ch7_inverse_componentwise_radius_candidate_infNorm_bound_of_small
      n hn A_inv ΔA E ε rho hε hερ hEcomp hΔAcomp
      (by simpa [E] using hsmall)
  have hfinite :=
    problem7_9_exact_normwise_relative_change_le_linearized_plus_quadratic
      n hn A A_inv ΔA B c x Δb E_norm f_norm ε
      (ch7Problem711LocalInverseInfNormBound n A_inv)
      hε hE hf hden hΔA hΔb hLeft hRight hBnorm
  have hCnonneg : 0 ≤ C := by
    dsimp [C]
    exact ch7Problem79NormwiseExactRadiusRemainderBound_nonneg
      n A_inv E_norm f_norm c x hE hf hden
  have hε_ne : ε ≠ 0 := ne_of_gt hεpos
  calc
    ch7Problem79ExactScalarRelativeChange n A B c x Δb / ε
        ≤ (ε * ch7Problem79NormwiseLinearizedCond
              n A_inv E_norm f_norm c x +
            ε ^ 2 * C) / ε := by
          exact div_le_div_of_nonneg_right (by simpa [B, C] using hfinite) hε
    _ = ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x +
        ε * C := by
          field_simp [hε_ne]
    _ ≤ ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x +
        rho * C :=
          add_le_add le_rfl (mul_le_mul_of_nonneg_right hερ hCnonneg)

/-- Lower witness for the exact normwise Problem 7.9 source-radius set. -/
theorem exists_ch7Problem79NormwiseExactRadiusSet_lower_witness
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) {rho : ℝ}
    (hrho : 0 < rho)
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0)
    (hLeft : IsLeftInverse n A A_inv)
    (hsmall :
      rho *
          infNorm
            (ch7InverseFirstProductSensitivity n A_inv
              (ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm)) ≤
        (1 / 2 : ℝ)) :
    ∃ q : ℝ,
      q ∈ Ch7Problem79NormwiseExactRadiusSet
        n A A_inv E_norm f_norm c x rho ∧
      ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x -
          rho * ch7Problem79NormwiseExactRadiusRemainderBound
            n A_inv E_norm f_norm c x
        ≤ q := by
  let μ := ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x
  let C := ch7Problem79NormwiseExactRadiusRemainderBound
    n A_inv E_norm f_norm c x
  let E := ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm
  rcases
    (problem7_9_linearized_normwise_functional_formula
      n A_inv E_norm f_norm c x hE hf hden hx hw).2 rho (le_of_lt hrho) with
    ⟨ΔA, Δb, hΔA, hΔb, _hfirst, hrel⟩
  let B := ch7Problem711PerturbedInverseCandidate n A_inv ΔA
  let q := ch7Problem79ExactScalarRelativeChange n A B c x Δb / rho
  have hEcomp : ∀ i j, 0 ≤ E i j := by
    intro i j
    exact hE
  have hΔAcomp : ∀ i j, |ΔA i j| ≤ rho * E i j := by
    intro i j
    exact ch7Problem79_normwise_deltaA_componentwise_bound n ΔA E_norm rho
      hΔA i j
  have hRight :
      IsRightInverse n (fun i j => A i j + ΔA i j) B :=
    ch7_inverse_componentwise_radius_candidate_right_inverse_of_small
      n hn A A_inv ΔA E rho rho (le_of_lt hrho) le_rfl hEcomp
      hΔAcomp hLeft (by simpa [E] using hsmall)
  have hBnorm :
      infNorm B ≤ ch7Problem711LocalInverseInfNormBound n A_inv :=
    ch7_inverse_componentwise_radius_candidate_infNorm_bound_of_small
      n hn A_inv ΔA E rho rho (le_of_lt hrho) le_rfl hEcomp
      hΔAcomp (by simpa [E] using hsmall)
  have hlower :=
    problem7_9_exact_normwise_relative_change_ge_linearized_minus_quadratic
      n hn A A_inv ΔA B c x Δb E_norm f_norm rho
      (ch7Problem711LocalInverseInfNormBound n A_inv)
      (le_of_lt hrho) hE hf hden hΔA hΔb hLeft hRight hBnorm hrel
  have hrho_ne : rho ≠ 0 := ne_of_gt hrho
  have hdiv :=
    div_le_div_of_nonneg_right hlower (le_of_lt hrho)
  have hleft_eq :
      (rho * μ - rho ^ 2 * C) / rho = μ - rho * C := by
    field_simp [hrho_ne]
  refine ⟨q, ?_, ?_⟩
  · refine ⟨rho, ΔA, Δb, hrho, le_rfl, hΔA, hΔb, ?_⟩
    rfl
  · have hmain : μ - rho * C ≤ q := by
      calc
        μ - rho * C = (rho * μ - rho ^ 2 * C) / rho := by
          rw [hleft_eq]
        _ ≤ q := by
          simpa [q, μ, C, ch7Problem79NormwiseExactRadiusRemainderBound]
            using hdiv
    exact hmain

/-- Exact normwise Problem 7.9 source-radius `sSup` limit.  The nonlinear
scalar-output condition number obtained from the perturbed system agrees with
the finite normwise formula
`‖cᵀA⁻¹‖₂(‖E‖₂‖x‖₂+‖f‖₂)/|cᵀx|`. -/
theorem problem7_9_normwise_exact_radiusSup_tendsto_linearized
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hrho_tendsto : Filter.Tendsto rho l (nhds 0))
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0)
    (hLeft : IsLeftInverse n A A_inv) :
    IsCh7Problem79NormwiseExactRadiusLimitValue l
      n A A_inv E_norm f_norm c x rho
      (ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x) := by
  dsimp [IsCh7Problem79NormwiseExactRadiusLimitValue]
  let μ := ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x
  let C := ch7Problem79NormwiseExactRadiusRemainderBound
    n A_inv E_norm f_norm c x
  let E := ch7Problem79NormwiseConstantEnvelopeMatrix n E_norm
  let P := ch7InverseFirstProductSensitivity n A_inv E
  let L : ι → ℝ := fun t => μ - rho t * C
  let U : ι → ℝ := fun t => μ + rho t * C
  let Q : ι → ℝ :=
    fun t => ch7Problem79NormwiseExactRadiusSup
      n A A_inv E_norm f_norm c x (rho t)
  have hL : Filter.Tendsto L l (nhds μ) := by
    have hterm : Filter.Tendsto (fun t => rho t * C) l (nhds 0) := by
      simpa using hrho_tendsto.mul_const C
    dsimp [L]
    simpa using tendsto_const_nhds.sub hterm
  have hU : Filter.Tendsto U l (nhds μ) := by
    have hterm : Filter.Tendsto (fun t => rho t * C) l (nhds 0) := by
      simpa using hrho_tendsto.mul_const C
    dsimp [U]
    simpa using tendsto_const_nhds.add hterm
  have hsmall : Filter.Eventually
      (fun t => rho t * infNorm P ≤ (1 / 2 : ℝ)) l := by
    have hscaled : Filter.Tendsto (fun t => rho t * infNorm P) l (nhds 0) := by
      simpa [P] using hrho_tendsto.mul_const (infNorm P)
    have hraw := (Metric.tendsto_nhds.mp hscaled) (1 / 2 : ℝ) (by norm_num)
    filter_upwards [hrho_pos, hraw] with t hρpos ht
    have hdist : |rho t * infNorm P| < (1 / 2 : ℝ) := by
      simpa [Real.dist_eq] using ht
    have hnonneg : 0 ≤ rho t * infNorm P :=
      mul_nonneg (le_of_lt hρpos) (infNorm_nonneg P)
    exact le_of_lt (by simpa [abs_of_nonneg hnonneg] using hdist)
  have hbetween : Filter.Eventually (fun t => L t ≤ Q t ∧ Q t ≤ U t) l := by
    filter_upwards [hrho_pos, hsmall] with t hρpos hsmall_t
    obtain ⟨q, hqmem, hLq⟩ :=
      exists_ch7Problem79NormwiseExactRadiusSet_lower_witness
        n hn A A_inv E_norm f_norm c x hρpos hE hf hden hx hw hLeft
        (by simpa [P, E] using hsmall_t)
    have hUbound :
        ∀ r : ℝ,
          r ∈ Ch7Problem79NormwiseExactRadiusSet
            n A A_inv E_norm f_norm c x (rho t) →
          r ≤ U t := by
      intro r hr
      simpa [U, μ, C] using
        ch7Problem79NormwiseExactRadiusSet_value_le
          n hn A A_inv E_norm f_norm c x hE hf hden hLeft
          (by simpa [P, E] using hsmall_t) hr
    have hbdd :
        BddAbove
          (Ch7Problem79NormwiseExactRadiusSet
            n A A_inv E_norm f_norm c x (rho t)) :=
      ⟨U t, hUbound⟩
    have hq_le_sup :
        q ≤ ch7Problem79NormwiseExactRadiusSup
          n A A_inv E_norm f_norm c x (rho t) :=
      le_csSup hbdd hqmem
    have hsup_le :
        ch7Problem79NormwiseExactRadiusSup
          n A A_inv E_norm f_norm c x (rho t) ≤ U t :=
      csSup_le ⟨q, hqmem⟩ hUbound
    exact ⟨by simpa [L, μ, C] using hLq.trans hq_le_sup, hsup_le⟩
  simpa [L, U, Q, μ] using
    tendsto_of_eventually_between_tendsto hL hU hbetween

/-- Product-plus-limit packaging of Problem 7.9: the exact nonlinear normwise
scalar-output condition number agrees with the checked finite normwise
linearized formula. -/
theorem problem7_9_normwise_exact_condition_of_positive_radii
    {ι : Type*} {l : Filter ι}
    (n : ℕ) (hn : 0 < n)
    (A A_inv : Fin n → Fin n → ℝ) (E_norm f_norm : ℝ)
    (c x : Fin n → ℝ) (rho : ι → ℝ)
    (hrho_pos : Filter.Eventually (fun t => 0 < rho t) l)
    (hrho_tendsto : Filter.Tendsto rho l (nhds 0))
    (hE : 0 ≤ E_norm) (hf : 0 ≤ f_norm)
    (hden : 0 < |ch7LinearFunctional n c x|)
    (hx : vecNorm2 x ≠ 0)
    (hw : vecNorm2 (ch7Problem79AdjointWeight n A_inv c) ≠ 0)
    (hLeft : IsLeftInverse n A A_inv) :
    ∃ κ : ℝ,
      IsCh7Problem79NormwiseExactCondValue n A_inv E_norm f_norm c x κ ∧
        IsCh7Problem79NormwiseExactRadiusLimitValue l
          n A A_inv E_norm f_norm c x rho κ := by
  refine
    ⟨ch7Problem79NormwiseLinearizedCond n A_inv E_norm f_norm c x, rfl, ?_⟩
  exact
    problem7_9_normwise_exact_radiusSup_tendsto_linearized
      n hn A A_inv E_norm f_norm c x rho hrho_pos hrho_tendsto
      hE hf hden hx hw hLeft

