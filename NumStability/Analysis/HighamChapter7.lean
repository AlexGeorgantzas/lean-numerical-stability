/-- Finite-real dual row norm of rectangular row `i`.  This is the row norm
that appears when equation `(7.19)` is derived from the transpose identity
`κ_p(DA) = κ_q(AᵀD)` with `p` and `q` Holder conjugate. -/
noncomputable def ch7RectRowDualLpNormOfReal {m n : ℕ} (q : ℝ)
    (A : Fin m → Fin n → ℝ) (i : Fin m) : ℝ :=
  complexVecLpNorm (n := n) (ENNReal.ofReal q)
    (fun j : Fin n => (A i j : ℂ))

lemma ch7RectRowDualLpNormOfReal_nonneg {m n : ℕ} {q : ℝ}
    (hq : 1 ≤ q) (A : Fin m → Fin n → ℝ) (i : Fin m) :
    0 ≤ ch7RectRowDualLpNormOfReal q A i := by
  haveI : Fact (1 ≤ ENNReal.ofReal q) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hq⟩
  exact (complexVecLpNorm_isComplexVectorNorm (n := n) (ENNReal.ofReal q)).nonneg _

/-- General lower side of the finite-real matrix `p`-norm: each row dual
`q`-norm is bounded by the induced matrix `p`-norm. -/
theorem ch7RectRowDualLpNormOfReal_le_matrixLpNormOfReal {m n : ℕ}
    (hn : 0 < n) {p q : ℝ} (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (i : Fin m) :
    ch7RectRowDualLpNormOfReal q A i ≤
      complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
        (realRectToCMatrix A) := by
  have hAvalue :=
    complexMatrixLpNormOfReal_isComplexMatrixLpNormValue
      (m := m) (n := n) hn p (le_of_lt hpq.lt)
      (realRectToCMatrix A)
  have hAmixed :
      IsMixedSubordinateMatrixNormValue
        (complexVecLpNorm (n := n) (ENNReal.ofReal p))
        (complexVecLpNorm (n := m) (ENNReal.ofReal p))
        (realRectToCMatrix A)
        (complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
          (realRectToCMatrix A)) := by
    simpa [IsComplexMatrixLpNormValue] using hAvalue
  simpa [ch7RectRowDualLpNormOfReal, realRectToCMatrix] using
    complexMatrixLpNorm_row_dualLpNorm_le_of_mixedSubordinateMatrixNormValue
      (m := m) (n := n) hn hpq hAmixed i

/-- Full-row-rank side condition for Theorem 7.5's conjugate-row route, in
explicit rectangular right-inverse form: if `A Aplus = I`, then no source row
of `A` has zero dual finite-real `q`-norm. -/
lemma ch7RectRowDualLpNormOfReal_pos_of_rect_right_inverse {m n : ℕ} {q : ℝ}
    (hq : 1 ≤ q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hright : ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0)
    (i : Fin m) :
    0 < ch7RectRowDualLpNormOfReal q A i := by
  have hne : ch7RectRowDualLpNormOfReal q A i ≠ 0 := by
    intro hzero
    haveI : Fact (1 ≤ ENNReal.ofReal q) := ⟨by
      rw [ENNReal.one_le_ofReal]
      exact hq⟩
    have hzeroC :
        complexVecLpNorm (n := n) (ENNReal.ofReal q)
            (fun k : Fin n => (A i k : ℂ)) = 0 := by
      simpa [ch7RectRowDualLpNormOfReal] using hzero
    have hentriesC :
        (fun k : Fin n => (A i k : ℂ)) = (0 : CVec n) :=
      ((complexVecLpNorm_isComplexVectorNorm (n := n) (ENNReal.ofReal q)).eq_zero_iff
        (fun k : Fin n => (A i k : ℂ))).mp hzeroC
    have hentries : ∀ k : Fin n, A i k = 0 := by
      intro k
      exact Complex.ofReal_injective (congrFun hentriesC k)
    have hcontr : (0 : ℝ) = 1 := by
      simpa [hentries] using hright i i
    norm_num at hcontr
  exact lt_of_le_of_ne (ch7RectRowDualLpNormOfReal_nonneg hq A i) (Ne.symm hne)

/-- Strictly positive finite-real row dual `q`-norms give a strictly positive
lower bound for the average-normalized row factors. -/
lemma ch7_exists_pos_le_all_inv_card_mul_row_dual_lpNormOfReal {m n : ℕ}
    (hm : 0 < m) {q : ℝ}
    (A : Fin m → Fin n → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowDualLpNormOfReal q A i) :
    ∃ c : ℝ, 0 < c ∧
      ∀ i : Fin m, c ≤ (m : ℝ)⁻¹ * ch7RectRowDualLpNormOfReal q A i := by
  apply ch7_exists_pos_le_all_fin hm
  intro i
  exact mul_pos (inv_pos.mpr (Nat.cast_pos.mpr hm)) (hrow i)

/-- The conjugate-row equilibrating reciprocal scale
`d_i = 1 / ‖A(i,:)‖_q`, used by the finite-real proof route for `(7.19)`. -/
noncomputable def ch7RowDualEquilibratingScaleLpOfReal {m n : ℕ} (q : ℝ)
    (A : Fin m → Fin n → ℝ) (i : Fin m) : ℝ :=
  1 / ch7RectRowDualLpNormOfReal q A i

lemma ch7RectRowDualLpNormOfReal_leftScale {m n : ℕ} {q : ℝ}
    (hq : 1 ≤ q) (A : Fin m → Fin n → ℝ) (d : Fin m → ℝ) (i : Fin m) :
    ch7RectRowDualLpNormOfReal q (ch7RectLeftScale d A) i =
      ‖(d i : ℂ)‖ * ch7RectRowDualLpNormOfReal q A i := by
  haveI : Fact (1 ≤ ENNReal.ofReal q) := ⟨by
    rw [ENNReal.one_le_ofReal]
    exact hq⟩
  let ν : CVec n → ℝ := complexVecLpNorm (n := n) (ENNReal.ofReal q)
  have hν : IsComplexVectorNorm ν :=
    complexVecLpNorm_isComplexVectorNorm (n := n) (ENNReal.ofReal q)
  have hrow :
      (fun j : Fin n => ((ch7RectLeftScale d A) i j : ℂ)) =
        complexVecSMul (d i : ℂ) (fun j : Fin n => (A i j : ℂ)) := by
    ext j
    simp [ch7RectLeftScale, complexVecSMul]
  calc
    ch7RectRowDualLpNormOfReal q (ch7RectLeftScale d A) i
        = ν (complexVecSMul (d i : ℂ) (fun j : Fin n => (A i j : ℂ))) := by
            simp [ch7RectRowDualLpNormOfReal, ν, hrow]
    _ = ‖(d i : ℂ)‖ * ch7RectRowDualLpNormOfReal q A i := by
            simpa [ch7RectRowDualLpNormOfReal, ν] using
              hν.smul (d i : ℂ) (fun j : Fin n => (A i j : ℂ))

/-- A left-scaled row dual `q`-norm is bounded by the finite-real induced
matrix `p`-norm under Holder conjugacy. -/
theorem ch7RectLeftScale_row_dual_lpNorm_le_matrixLpNormOfReal {m n : ℕ}
    (hn : 0 < n) {p q : ℝ} (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (d : Fin m → ℝ) (i : Fin m) :
    |d i| * ch7RectRowDualLpNormOfReal q A i ≤
      complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
        (realRectToCMatrix (ch7RectLeftScale d A)) := by
  have h :=
    ch7RectRowDualLpNormOfReal_le_matrixLpNormOfReal
      (m := m) (n := n) hn hpq (ch7RectLeftScale d A) i
  rw [ch7RectRowDualLpNormOfReal_leftScale (le_of_lt hpq.symm.lt) A d i] at h
  simpa [Complex.norm_real, Real.norm_eq_abs] using h

/-- Pointwise lower bound for the finite-real reciprocal right-scaling
condition product.  The inverse-side factor is controlled by the row dual
`q`-norm required for a `p -> p` induced matrix norm. -/
theorem ch7LpRightScaledCondOfReal_reciprocal_lower_bound {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p q : ℝ} (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin n → ℝ) (j k : Fin n) :
    (|d k| * ch7RectColumnLpNormOfReal p A k) *
      (|(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j) ≤
        ch7LpRightScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
          (fun j : Fin n => (d j)⁻¹) := by
  have hAD :=
    eq_7_20_column_lpNorm_le_matrixLpNormOfReal
      (m := m) (n := n) hn (le_of_lt hpq.lt) (ch7RectRightScale A d) k
  rw [ch7RectColumnLpNormOfReal_rightScale (le_of_lt hpq.lt) A d k] at hAD
  have hAD' :
      |d k| * ch7RectColumnLpNormOfReal p A k ≤
        complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
          (realRectToCMatrix (ch7RectRightScale A d)) := by
    simpa [Complex.norm_real, Real.norm_eq_abs] using hAD
  have hAplus :
      |(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j ≤
        complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
          (realRectToCMatrix
            (ch7RectLeftScale (fun j : Fin n => (d j)⁻¹) Aplus)) := by
    simpa using
      ch7RectLeftScale_row_dual_lpNorm_le_matrixLpNormOfReal
        (m := n) (n := m) hm hpq Aplus (fun j : Fin n => (d j)⁻¹) j
  unfold ch7LpRightScaledCondOfReal
  exact mul_le_mul hAD' hAplus
    (mul_nonneg (abs_nonneg _)
      (ch7RectRowDualLpNormOfReal_nonneg (le_of_lt hpq.symm.lt) Aplus j))
    (ch7_complexMatrixLpNormOfReal_nonneg hn (le_of_lt hpq.lt) _)

/-- Boundary-facing lower bound for normalized finite-real reciprocal right
scalings. -/
theorem ch7LpRightScaledCondOfReal_reciprocal_normalized_lower_exists
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin n → ℝ) (hsum : (∑ j : Fin n, |d j|) = 1)
    (j : Fin n) :
    ∃ k : Fin n,
      ((n : ℝ)⁻¹ * ch7RectColumnLpNormOfReal p A k) *
        (|(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j) ≤
          ch7LpRightScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
            (fun j : Fin n => (d j)⁻¹) := by
  rcases ch7_exists_inv_card_le_abs_of_sum_abs_eq_one hn d hsum with ⟨k, hk⟩
  refine ⟨k, ?_⟩
  have hcol :
      (n : ℝ)⁻¹ * ch7RectColumnLpNormOfReal p A k ≤
        |d k| * ch7RectColumnLpNormOfReal p A k :=
    mul_le_mul_of_nonneg_right hk
      (ch7RectColumnLpNormOfReal_nonneg (le_of_lt hpq.lt) A k)
  have hright_nonneg :
      0 ≤ |(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j :=
    mul_nonneg (abs_nonneg _)
      (ch7RectRowDualLpNormOfReal_nonneg (le_of_lt hpq.symm.lt) Aplus j)
  exact (mul_le_mul_of_nonneg_right hcol hright_nonneg).trans
    (ch7LpRightScaledCondOfReal_reciprocal_lower_bound
      hm hn hpq A Aplus d j k)

/-- Fixed-constant form of finite-real right-scaling coercivity.  This is the
sublevel estimate needed to keep normalized reciprocal diagonals away from the
coordinate hyperplanes. -/
theorem ch7LpRightScaledCondOfReal_reciprocal_normalized_inv_abs_le_of_le_of_const
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {c : ℝ} (hc : 0 < c)
    (hcA : ∀ k : Fin n, c ≤ (n : ℝ)⁻¹ * ch7RectColumnLpNormOfReal p A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j)
    (d : Fin n → ℝ) (hsum : (∑ j : Fin n, |d j|) = 1)
    {K : ℝ} (hK :
      ch7LpRightScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
        (fun j : Fin n => (d j)⁻¹) ≤ K)
    (j : Fin n) :
    |(d j)⁻¹| ≤ K / (c * ch7RectRowDualLpNormOfReal q Aplus j) := by
  rcases ch7LpRightScaledCondOfReal_reciprocal_normalized_lower_exists
      hm hn hpq A Aplus d hsum j with ⟨k, hkprod⟩
  have hright_nonneg :
      0 ≤ |(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j :=
    mul_nonneg (abs_nonneg _) (le_of_lt (hrowAplus j))
  have hck :
      c * (|(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j) ≤
        ((n : ℝ)⁻¹ * ch7RectColumnLpNormOfReal p A k) *
          (|(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j) :=
    mul_le_mul_of_nonneg_right (hcA k) hright_nonneg
  have hleK :
      c * (|(d j)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j) ≤ K :=
    hck.trans (hkprod.trans hK)
  have hden : 0 < c * ch7RectRowDualLpNormOfReal q Aplus j :=
    mul_pos hc (hrowAplus j)
  exact (le_div_iff₀ hden).2 (by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hleK)

/-- Compact core for normalized finite-real reciprocal right scalings.  The
coordinate lower bounds come from the finite-`p`/dual-`q` coercivity estimate. -/
noncomputable def ch7LpRightScaledCondReciprocalCompactCoreOfReal {m n : ℕ}
    (q : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) : Set (Fin n → ℝ) :=
  {d : Fin n → ℝ |
    (∑ j : Fin n, |d j|) = 1 ∧
    ∀ j : Fin n,
      (K / (c * ch7RectRowDualLpNormOfReal q Aplus j))⁻¹ ≤ |d j|}

theorem isClosed_ch7LpRightScaledCondReciprocalCompactCoreOfReal {m n : ℕ}
    (q : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsClosed (ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c) := by
  have hsum_cont : Continuous fun d : Fin n → ℝ => ∑ j : Fin n, |d j| := by
    simpa using
      continuous_finset_sum (s := Finset.univ)
        (fun j _ => (continuous_apply j).abs)
  have hsum_closed :
      IsClosed {d : Fin n → ℝ | (∑ j : Fin n, |d j|) = 1} :=
    isClosed_eq hsum_cont continuous_const
  have hlower_closed :
      IsClosed {d : Fin n → ℝ |
        ∀ j : Fin n,
          (K / (c * ch7RectRowDualLpNormOfReal q Aplus j))⁻¹ ≤ |d j|} := by
    rw [show
      {d : Fin n → ℝ |
        ∀ j : Fin n,
          (K / (c * ch7RectRowDualLpNormOfReal q Aplus j))⁻¹ ≤ |d j|} =
        ⋂ j : Fin n,
          {d : Fin n → ℝ |
            (K / (c * ch7RectRowDualLpNormOfReal q Aplus j))⁻¹ ≤ |d j|} by
        ext d
        simp]
    exact isClosed_iInter (fun j : Fin n =>
      isClosed_le
        (continuous_const :
          Continuous fun _d : Fin n → ℝ =>
            (K / (c * ch7RectRowDualLpNormOfReal q Aplus j))⁻¹)
        ((continuous_apply j : Continuous fun d : Fin n → ℝ => d j).abs))
  simpa [ch7LpRightScaledCondReciprocalCompactCoreOfReal] using
    hsum_closed.inter hlower_closed

theorem ch7LpRightScaledCondReciprocalCompactCoreOfReal_subset_Icc {m n : ℕ}
    (q : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c ⊆
      Set.Icc (fun _ : Fin n => (-1 : ℝ)) (fun _ : Fin n => (1 : ℝ)) := by
  intro d hd
  have habs : ∀ j : Fin n, |d j| ≤ 1 := by
    intro j
    have hle_sum : |d j| ≤ ∑ k : Fin n, |d k| :=
      Finset.single_le_sum (fun k _ => abs_nonneg (d k)) (Finset.mem_univ j)
    simpa [hd.1] using hle_sum
  constructor
  · intro j
    exact (abs_le.mp (habs j)).1
  · intro j
    exact (abs_le.mp (habs j)).2

theorem isCompact_ch7LpRightScaledCondReciprocalCompactCoreOfReal {m n : ℕ}
    (q : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsCompact (ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c) := by
  exact IsCompact.of_isClosed_subset isCompact_Icc
    (isClosed_ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c)
    (ch7LpRightScaledCondReciprocalCompactCoreOfReal_subset_Icc q Aplus K c)

lemma ch7LpRightScaledCondReciprocalCompactCoreOfReal_ne_zero {m n : ℕ}
    {q : ℝ} {Aplus : Fin n → Fin m → ℝ} {K c : ℝ}
    (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j)
    {d : Fin n → ℝ}
    (hd : d ∈ ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c)
    (j : Fin n) :
    d j ≠ 0 := by
  have hden : 0 < c * ch7RectRowDualLpNormOfReal q Aplus j :=
    mul_pos hc (hrowAplus j)
  have hquot : 0 < K / (c * ch7RectRowDualLpNormOfReal q Aplus j) :=
    div_pos hK hden
  have hlower_pos :
      0 < (K / (c * ch7RectRowDualLpNormOfReal q Aplus j))⁻¹ :=
    inv_pos.mpr hquot
  have h_abs_pos : 0 < |d j| := lt_of_lt_of_le hlower_pos (hd.2 j)
  exact abs_pos.mp h_abs_pos

lemma ch7_inv_bound_le_abs_of_inv_abs_le {x M : ℝ}
    (hx : x ≠ 0) (hM : 0 < M) (h : |x⁻¹| ≤ M) :
    M⁻¹ ≤ |x| := by
  have hxabs : 0 < |x| := abs_pos.mpr hx
  have hinv : |x|⁻¹ ≤ M := by
    simpa [abs_inv] using h
  exact (inv_le_comm₀ hM hxabs).2 hinv

/-- Bounded reciprocal sublevel inside the compact finite-real right-scaling
core used for minimizer extraction. -/
noncomputable def ch7LpRightScaledCondReciprocalCompactSublevelOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p) (q : ℝ)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (K c : ℝ) : Set (Fin n → ℝ) :=
  ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c ∩
    {d : Fin n → ℝ |
      ch7LpRightScaledCondOfReal hm hn p hp A Aplus d
        (fun j : Fin n => (d j)⁻¹) ≤ K}

theorem continuousOn_ch7LpRightScaledCondOfReal_reciprocal_compactCore
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j) :
    ContinuousOn (fun d : Fin n → ℝ =>
      ch7LpRightScaledCondOfReal hm hn p hp A Aplus d
        (fun j : Fin n => (d j)⁻¹))
      (ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c) := by
  exact continuousOn_ch7LpRightScaledCondOfReal_reciprocal hm hn hp A Aplus
    (ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c)
    (fun d hd j =>
      ch7LpRightScaledCondReciprocalCompactCoreOfReal_ne_zero
        hK hc hrowAplus hd j)

theorem isClosed_ch7LpRightScaledCondReciprocalCompactSublevelOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p q : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j) :
    IsClosed
      (ch7LpRightScaledCondReciprocalCompactSublevelOfReal
        hm hn p hp q A Aplus K c) := by
  let core : Set (Fin n → ℝ) :=
    ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c
  let f : (Fin n → ℝ) → ℝ := fun d =>
    ch7LpRightScaledCondOfReal hm hn p hp A Aplus d
      (fun j : Fin n => (d j)⁻¹)
  have hcore_closed : IsClosed core := by
    dsimp [core]
    exact isClosed_ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c
  have hf : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7LpRightScaledCondOfReal_reciprocal_compactCore
      hm hn hp A Aplus hK hc hrowAplus
  have hpre : IsClosed (core ∩ f ⁻¹' Set.Iic K) :=
    ContinuousOn.preimage_isClosed_of_isClosed hf hcore_closed isClosed_Iic
  simpa [ch7LpRightScaledCondReciprocalCompactSublevelOfReal, core, f, Set.Iic]
    using hpre

theorem isCompact_ch7LpRightScaledCondReciprocalCompactSublevelOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p q : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j) :
    IsCompact
      (ch7LpRightScaledCondReciprocalCompactSublevelOfReal
        hm hn p hp q A Aplus K c) := by
  exact IsCompact.of_isClosed_subset
    (isCompact_ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c)
    (isClosed_ch7LpRightScaledCondReciprocalCompactSublevelOfReal
      hm hn hp A Aplus hK hc hrowAplus)
    (by
      intro d hd
      exact hd.1)

/-- The normalized reciprocal finite-real right-scaling value set attains a
least value once the source columns of `A` and inverse-side dual rows of
`Aplus` are nonzero. -/
theorem ch7LpRightScaledCondReciprocalNormalizedSetOfReal_exists_isLeast
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnLpNormOfReal p A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j) :
    ∃ μ : ℝ, IsLeast
      (ch7LpRightScaledCondReciprocalNormalizedSetOfReal
        hm hn p (le_of_lt hpq.lt) A Aplus) μ := by
  let d0 : Fin n → ℝ := fun _ => (n : ℝ)⁻¹
  let f : (Fin n → ℝ) → ℝ := fun d =>
    ch7LpRightScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
      (fun j : Fin n => (d j)⁻¹)
  let K : ℝ := f d0
  have hnR : 0 < (n : ℝ) := by exact_mod_cast hn
  have hn_ne : (n : ℝ) ≠ 0 := ne_of_gt hnR
  have hd0_pos : ∀ j : Fin n, 0 < d0 j := by
    intro j
    exact inv_pos.mpr hnR
  have hd0_ne : ∀ j : Fin n, d0 j ≠ 0 := fun j => ne_of_gt (hd0_pos j)
  have hd0_sum : (∑ j : Fin n, |d0 j|) = 1 := by
    calc
      (∑ j : Fin n, |d0 j|)
          = ∑ _j : Fin n, (n : ℝ)⁻¹ := by
            apply Finset.sum_congr rfl
            intro j _
            exact abs_of_pos (hd0_pos j)
      _ = (n : ℝ) * (n : ℝ)⁻¹ := by
            simp [Finset.sum_const, nsmul_eq_mul]
      _ = 1 := mul_inv_cancel₀ hn_ne
  have hKpos : 0 < K := by
    let j0 : Fin n := ⟨0, hn⟩
    rcases ch7LpRightScaledCondOfReal_reciprocal_normalized_lower_exists
        hm hn hpq A Aplus d0 hd0_sum j0 with ⟨k, hkprod⟩
    have hleft_pos : 0 < (n : ℝ)⁻¹ * ch7RectColumnLpNormOfReal p A k :=
      mul_pos (inv_pos.mpr hnR) (hcol k)
    have hright_pos :
        0 < |(d0 j0)⁻¹| * ch7RectRowDualLpNormOfReal q Aplus j0 := by
      exact mul_pos (abs_pos.mpr (inv_ne_zero (hd0_ne j0))) (hrowAplus j0)
    exact lt_of_lt_of_le (mul_pos hleft_pos hright_pos) hkprod
  rcases ch7_exists_pos_le_all_inv_card_mul_column_lpNormOfReal hn A hcol with
    ⟨c, hc, hcA⟩
  let core : Set (Fin n → ℝ) :=
    ch7LpRightScaledCondReciprocalCompactCoreOfReal q Aplus K c
  let S : Set (Fin n → ℝ) :=
    ch7LpRightScaledCondReciprocalCompactSublevelOfReal
      hm hn p (le_of_lt hpq.lt) q A Aplus K c
  have hd0_core : d0 ∈ core := by
    refine ⟨hd0_sum, ?_⟩
    intro j
    have hM : 0 < K / (c * ch7RectRowDualLpNormOfReal q Aplus j) :=
      div_pos hKpos (mul_pos hc (hrowAplus j))
    have hinv_le :
        |(d0 j)⁻¹| ≤ K / (c * ch7RectRowDualLpNormOfReal q Aplus j) := by
      dsimp [K, f]
      exact ch7LpRightScaledCondOfReal_reciprocal_normalized_inv_abs_le_of_le_of_const
        hm hn hpq A Aplus hc hcA hrowAplus d0 hd0_sum le_rfl j
    exact ch7_inv_bound_le_abs_of_inv_abs_le (hd0_ne j) hM hinv_le
  have hd0S : d0 ∈ S := by
    refine ⟨?_, ?_⟩
    · exact hd0_core
    · dsimp [S, K, f, ch7LpRightScaledCondReciprocalCompactSublevelOfReal]
      exact le_rfl
  have hS_nonempty : S.Nonempty := ⟨d0, hd0S⟩
  have hScompact : IsCompact S := by
    dsimp [S]
    exact isCompact_ch7LpRightScaledCondReciprocalCompactSublevelOfReal
      hm hn (le_of_lt hpq.lt) A Aplus hKpos hc hrowAplus
  have hfcore : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7LpRightScaledCondOfReal_reciprocal_compactCore
      hm hn (le_of_lt hpq.lt) A Aplus hKpos hc hrowAplus
  have hfS : ContinuousOn f S := by
    exact hfcore.mono (by
      intro d hd
      exact hd.1)
  rcases hScompact.exists_isMinOn hS_nonempty hfS with
    ⟨dmin, hdminS, hminS⟩
  refine ⟨f dmin, ?_⟩
  constructor
  · refine ⟨dmin, ?_, ?_, rfl⟩
    · intro j
      exact ch7LpRightScaledCondReciprocalCompactCoreOfReal_ne_zero
        hKpos hc hrowAplus hdminS.1 j
    · exact hdminS.1.1
  · intro μ hμ
    rcases hμ with ⟨d, hdne, hsum, rfl⟩
    rcases le_total (f d) K with hfdK | hKfd
    · have hd_core : d ∈ core := by
        refine ⟨hsum, ?_⟩
        intro j
        have hM : 0 < K / (c * ch7RectRowDualLpNormOfReal q Aplus j) :=
          div_pos hKpos (mul_pos hc (hrowAplus j))
        have hinv_le :
            |(d j)⁻¹| ≤ K / (c * ch7RectRowDualLpNormOfReal q Aplus j) := by
          dsimp [K, f] at hfdK
          exact
            ch7LpRightScaledCondOfReal_reciprocal_normalized_inv_abs_le_of_le_of_const
              hm hn hpq A Aplus hc hcA hrowAplus d hsum hfdK j
        exact ch7_inv_bound_le_abs_of_inv_abs_le (hdne j) hM hinv_le
      have hdS : d ∈ S := ⟨hd_core, hfdK⟩
      exact hminS hdS
    · exact hdminS.2.trans hKfd

theorem ch7LpRightScaledCondNormalizedSetOfReal_exists_isLeast
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnLpNormOfReal p A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j) :
    ∃ μ : ℝ, IsLeast
      (ch7LpRightScaledCondNormalizedSetOfReal
        hm hn p (le_of_lt hpq.lt) A Aplus) μ := by
  rcases ch7LpRightScaledCondReciprocalNormalizedSetOfReal_exists_isLeast
      hm hn hpq A Aplus hcol hrowAplus with ⟨μ, hμ⟩
  exact ⟨μ,
    (ch7LpRightScaledCondNormalizedSetOfReal_isLeast_iff_reciprocal_normalized
      hm hn (le_of_lt hpq.lt) A Aplus).mpr hμ⟩

theorem ch7LpRightScaledCondSetOfReal_exists_isLeast
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hcol : ∀ k : Fin n, 0 < ch7RectColumnLpNormOfReal p A k)
    (hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j) :
    ∃ μ : ℝ, IsLeast
      (ch7LpRightScaledCondSetOfReal hm hn p (le_of_lt hpq.lt) A Aplus) μ := by
  rcases ch7LpRightScaledCondNormalizedSetOfReal_exists_isLeast
      hm hn hpq A Aplus hcol hrowAplus with ⟨μ, hμ⟩
  exact ⟨μ,
    (ch7LpRightScaledCondSetOfReal_isLeast_iff_sum_abs_normalized
      hm hn (le_of_lt hpq.lt) A Aplus).mpr hμ⟩

/-- Theorem 7.5 finite-real column route with the source minimum value
extracted from compactness under an explicit rectangular left inverse. -/
theorem theorem7_5_lp_column_equilibration_exists_min_right_scalings_of_rect_left_inverse
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) :
    ∃ μ : ℝ,
      IsLeast (ch7LpRightScaledCondSetOfReal hm hn p (le_of_lt hpq.lt) A Aplus) μ ∧
      ch7LpRightScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus
          (ch7ColumnEquilibratingScaleLpOfReal p A)
          (fun j : Fin n => ch7RectColumnLpNormOfReal p A j) ≤
        (n : ℝ) ^ (1 - p⁻¹) * μ := by
  have hcol : ∀ j : Fin n, 0 < ch7RectColumnLpNormOfReal p A j :=
    ch7RectColumnLpNormOfReal_pos_of_rect_left_inverse
      (le_of_lt hpq.lt) A Aplus hleft
  have hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j :=
    ch7RectRowDualLpNormOfReal_pos_of_rect_right_inverse
      (le_of_lt hpq.symm.lt) Aplus A hleft
  rcases ch7LpRightScaledCondSetOfReal_exists_isLeast
      hm hn hpq A Aplus hcol hrowAplus with ⟨μ, hmin⟩
  exact ⟨μ, hmin,
    theorem7_5_lp_column_equilibration_le_card_rpow_min_right_scalings_of_rect_left_inverse
      hm hn (le_of_lt hpq.lt) A Aplus hleft hmin⟩

/-- Normalized-slice version of the compactness-backed finite-real column
minimum wrapper under an explicit rectangular left inverse. -/
theorem theorem7_5_lp_column_equilibration_exists_min_right_scalings_of_rect_left_inverse_of_normalized
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0) :
    ∃ μ : ℝ,
      IsLeast
        (ch7LpRightScaledCondNormalizedSetOfReal hm hn p (le_of_lt hpq.lt) A Aplus)
        μ ∧
      ch7LpRightScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus
          (ch7ColumnEquilibratingScaleLpOfReal p A)
          (fun j : Fin n => ch7RectColumnLpNormOfReal p A j) ≤
        (n : ℝ) ^ (1 - p⁻¹) * μ := by
  have hcol : ∀ j : Fin n, 0 < ch7RectColumnLpNormOfReal p A j :=
    ch7RectColumnLpNormOfReal_pos_of_rect_left_inverse
      (le_of_lt hpq.lt) A Aplus hleft
  have hrowAplus : ∀ j : Fin n, 0 < ch7RectRowDualLpNormOfReal q Aplus j :=
    ch7RectRowDualLpNormOfReal_pos_of_rect_right_inverse
      (le_of_lt hpq.symm.lt) Aplus A hleft
  rcases ch7LpRightScaledCondNormalizedSetOfReal_exists_isLeast
      hm hn hpq A Aplus hcol hrowAplus with ⟨μ, hmin⟩
  exact ⟨μ, hmin,
    theorem7_5_lp_column_equilibration_le_card_rpow_min_right_scalings_of_rect_left_inverse_of_normalized
      hm hn (le_of_lt hpq.lt) A Aplus hleft hmin⟩

lemma ch7RectRowDualLpNormOfReal_leftScale_equilibrating {m n : ℕ}
    {q : ℝ} (hq : 1 ≤ q) (A : Fin m → Fin n → ℝ)
    (hpos : ∀ i : Fin m, 0 < ch7RectRowDualLpNormOfReal q A i)
    (i : Fin m) :
    ch7RectRowDualLpNormOfReal q
      (ch7RectLeftScale (ch7RowDualEquilibratingScaleLpOfReal q A) A) i = 1 := by
  rw [ch7RectRowDualLpNormOfReal_leftScale hq]
  have hnorm :
      ‖((ch7RowDualEquilibratingScaleLpOfReal q A i : ℝ) : ℂ)‖ =
        (ch7RectRowDualLpNormOfReal q A i)⁻¹ := by
    unfold ch7RowDualEquilibratingScaleLpOfReal
    rw [one_div]
    exact Complex.norm_of_nonneg (inv_nonneg.mpr (le_of_lt (hpos i)))
  rw [hnorm]
  field_simp [ne_of_gt (hpos i)]

/-- Equation `(7.19)` dependency for finite real `p`: after left-scaling each
nonzero row by the reciprocal of its dual `q`-norm, the local least matrix
`p`-norm is bounded by `m^(1/p)`.  The printed theorem derives the row side
through the conjugate exponent relation `(6.21)`. -/
theorem eq_7_19_matrixLpNormOfReal_dual_row_equilibrated {m n : ℕ}
    (_hm : 0 < m) (hn : 0 < n) {p q : ℝ} (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ)
    (hrow : ∀ i : Fin m, 0 < ch7RectRowDualLpNormOfReal q A i) :
    complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
        (realRectToCMatrix
          (ch7RectLeftScale (ch7RowDualEquilibratingScaleLpOfReal q A) A)) ≤
      (m : ℝ) ^ p⁻¹ := by
  let DA : Fin m → Fin n → ℝ :=
    ch7RectLeftScale (ch7RowDualEquilibratingScaleLpOfReal q A) A
  let rowDual : Fin m → ℝ := fun i : Fin m =>
    complexVecLpNorm (ENNReal.ofReal q)
      (fun j : Fin n => realRectToCMatrix DA i j)
  have hrowDual_nonneg : ∀ i : Fin m, 0 ≤ rowDual i := by
    intro i
    have hq : 1 ≤ q := le_of_lt hpq.symm.lt
    simpa [rowDual, DA, ch7RectRowDualLpNormOfReal, realRectToCMatrix] using
      ch7RectRowDualLpNormOfReal_nonneg (m := m) (n := n) hq DA i
  have hrow_le_one : ∀ i : Fin m, rowDual i ≤ (1 : ℝ) := by
    intro i
    have hq : 1 ≤ q := le_of_lt hpq.symm.lt
    have heq :
        rowDual i =
          ch7RectRowDualLpNormOfReal q
            (ch7RectLeftScale (ch7RowDualEquilibratingScaleLpOfReal q A) A) i := by
      simp [rowDual, DA, ch7RectRowDualLpNormOfReal, realRectToCMatrix]
    rw [heq, ch7RectRowDualLpNormOfReal_leftScale_equilibrating hq A hrow i]
  have hmax_le_one :
      complexMatrixRowDualMaxNorm rowDual ≤ (1 : ℝ) :=
    complexMatrixRowDualMaxNorm_le_of_row_le hrowDual_nonneg (by norm_num) hrow_le_one
  have hnorm_le :
      complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt) (realRectToCMatrix DA) ≤
        (m : ℝ) ^ p⁻¹ * complexMatrixRowDualMaxNorm rowDual := by
    simpa [rowDual, DA, ch7RectRowDualLpNormOfReal, realRectToCMatrix] using
      (complexMatrixLpNormOfReal_rowDualMax_bounds
        (m := m) (n := n) hn hpq (realRectToCMatrix DA)).2
  have hfactor_nonneg : 0 ≤ (m : ℝ) ^ p⁻¹ :=
    Real.rpow_nonneg (Nat.cast_nonneg m) _
  calc
    complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt) (realRectToCMatrix DA)
        ≤ (m : ℝ) ^ p⁻¹ * complexMatrixRowDualMaxNorm rowDual := hnorm_le
    _ ≤ (m : ℝ) ^ p⁻¹ * 1 :=
          mul_le_mul_of_nonneg_left hmax_le_one hfactor_nonneg
    _ = (m : ℝ) ^ p⁻¹ := by ring

/-- Equation `(7.19)` finite-real inverse-side bound for the conjugate-row
scale.  This is the row analogue of `(7.22)` with the inverse-side factor
`A⁺D⁻¹`, keeping `Aplus` explicit. -/
theorem eq_7_19_matrixLpNormOfReal_dual_row_inverseSide_bound {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p q : ℝ} (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
        (realRectToCMatrix
          (ch7RectRightScale Aplus
            (fun i : Fin m => ch7RectRowDualLpNormOfReal q A i))) ≤
      complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
          (realRectToCMatrix (ch7RectLeftScale d A)) *
        complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
          (realRectToCMatrix (ch7RectRightScale Aplus dInv)) := by
  let B : ℝ :=
    complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
      (realRectToCMatrix (ch7RectLeftScale d A))
  let C : ℝ :=
    complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
      (realRectToCMatrix (ch7RectRightScale Aplus dInv))
  let target : Fin n → Fin m → ℝ :=
    ch7RectRightScale Aplus
      (fun i : Fin m => ch7RectRowDualLpNormOfReal q A i)
  let side : Fin n → Fin m → ℝ := ch7RectRightScale Aplus dInv
  have hB_nonneg : 0 ≤ B := by
    dsimp [B]
    exact ch7_complexMatrixLpNormOfReal_nonneg hn (le_of_lt hpq.lt) _
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact ch7_complexMatrixLpNormOfReal_nonneg hm (le_of_lt hpq.lt) _
  have htargetValue :
      IsComplexMatrixLpNormValue (ENNReal.ofReal p) (realRectToCMatrix target)
        (complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
          (realRectToCMatrix target)) := by
    exact complexMatrixLpNormOfReal_isComplexMatrixLpNormValue
      (m := n) (n := m) hm p (le_of_lt hpq.lt) (realRectToCMatrix target)
  have hsideValue :
      IsComplexMatrixLpNormValue (ENNReal.ofReal p) (realRectToCMatrix side) C := by
    simpa [C, side] using
      complexMatrixLpNormOfReal_isComplexMatrixLpNormValue
        (m := n) (n := m) hm p (le_of_lt hpq.lt) (realRectToCMatrix side)
  have hsideBound : HasComplexMatrixLpBound (ENNReal.ofReal p)
      (realRectToCMatrix side) C :=
    hasComplexMatrixLpBound_of_complexMatrixLpNormValue_ofReal
      (m := n) (n := m) hm (le_of_lt hpq.lt) hsideValue
  let drow : Fin m → ℝ := fun i : Fin m =>
    complexVecLpNorm (ENNReal.ofReal q)
      (fun j : Fin n => realRectToCMatrix (ch7RectLeftScale d A) i j)
  have hdrow_nonneg : ∀ i : Fin m, 0 ≤ drow i := by
    intro i
    have hq : 1 ≤ q := le_of_lt hpq.symm.lt
    simpa [drow, ch7RectRowDualLpNormOfReal, realRectToCMatrix] using
      ch7RectRowDualLpNormOfReal_nonneg
        (m := m) (n := n) hq (ch7RectLeftScale d A) i
  have hrowMax_le_B :
      complexMatrixRowDualMaxNorm drow ≤ B := by
    simpa [B, drow, ch7RectRowDualLpNormOfReal, realRectToCMatrix] using
      (complexMatrixLpNormOfReal_rowDualMax_bounds
        (m := m) (n := n) hn hpq
        (realRectToCMatrix (ch7RectLeftScale d A))).1
  have hfactor :
      ∀ i : Fin m,
        ‖(d i : ℂ)‖ * ch7RectRowDualLpNormOfReal q A i ≤ B := by
    intro i
    have hrowi_le :
        drow i ≤ complexMatrixRowDualMaxNorm drow :=
      complexMatrixRowDualMaxNorm_row_le_of_nonneg hdrow_nonneg i
    have hscaled :
        drow i =
          ‖(d i : ℂ)‖ * ch7RectRowDualLpNormOfReal q A i := by
      have hq : 1 ≤ q := le_of_lt hpq.symm.lt
      simpa [drow, ch7RectRowDualLpNormOfReal, realRectToCMatrix] using
        ch7RectRowDualLpNormOfReal_leftScale hq A d i
    exact hscaled ▸ hrowi_le.trans hrowMax_le_B
  have hdiagFactor :
      ∀ i : Fin m,
        ‖(d i : ℂ) * (ch7RectRowDualLpNormOfReal q A i : ℂ)‖ ≤ B := by
    intro i
    rw [norm_mul,
      Complex.norm_of_nonneg
        (ch7RectRowDualLpNormOfReal_nonneg
          (m := m) (n := n) (le_of_lt hpq.symm.lt) A i)]
    exact hfactor i
  have hrewrite :
      target =
        ch7RectRightScale side
          (fun i : Fin m => d i * ch7RectRowDualLpNormOfReal q A i) := by
    ext k i
    dsimp [target, side, ch7RectRightScale]
    calc
      Aplus k i * ch7RectRowDualLpNormOfReal q A i =
          Aplus k i * ((dInv i * d i) * ch7RectRowDualLpNormOfReal q A i) := by
            rw [show dInv i * d i = 1 by rw [mul_comm, hdiag i]]
            ring
      _ = (Aplus k i * dInv i) *
            (d i * ch7RectRowDualLpNormOfReal q A i) := by
            ring
  have htargetBound : HasComplexMatrixLpBound (ENNReal.ofReal p)
      (realRectToCMatrix target) (B * C) := by
    refine hasComplexMatrixLpBound_of_nonneg_mixedSubordinateMatrixBound
      (mul_nonneg hB_nonneg hC_nonneg) ?_
    intro x
    let scaledX : CVec m := fun i : Fin m =>
      ((d i : ℂ) * (ch7RectRowDualLpNormOfReal q A i : ℂ)) * x i
    have hvec :
        complexMatrixVecMul
            (realRectToCMatrix
              (ch7RectRightScale side
                (fun i : Fin m => d i * ch7RectRowDualLpNormOfReal q A i))) x =
          complexMatrixVecMul (realRectToCMatrix side) scaledX := by
      ext k
      unfold complexMatrixVecMul realRectToCMatrix ch7RectRightScale scaledX side
      apply Finset.sum_congr rfl
      intro i _
      rw [show
        ((ch7RectRightScale Aplus dInv k i *
            (d i * ch7RectRowDualLpNormOfReal q A i) : ℝ) : ℂ) =
          (ch7RectRightScale Aplus dInv k i : ℂ) *
            ((d i : ℂ) * (ch7RectRowDualLpNormOfReal q A i : ℂ)) by
        rw [Complex.ofReal_mul, Complex.ofReal_mul]]
      ring
    have hscaled :
        complexVecLpNorm (ENNReal.ofReal p) scaledX ≤
          B * complexVecLpNorm (ENNReal.ofReal p) x :=
      ch7_complexVecLpNormOfReal_diagScale_le_of_norm_le
        (n := m) (le_of_lt hpq.lt) hB_nonneg
        (fun i : Fin m =>
          (d i : ℂ) * (ch7RectRowDualLpNormOfReal q A i : ℂ))
        x hdiagFactor
    calc
      complexVecLpNorm (ENNReal.ofReal p)
          (complexMatrixVecMul (realRectToCMatrix target) x)
          = complexVecLpNorm (ENNReal.ofReal p)
              (complexMatrixVecMul
                (realRectToCMatrix
                  (ch7RectRightScale side
                    (fun i : Fin m => d i * ch7RectRowDualLpNormOfReal q A i)))
                x) := by
                rw [hrewrite]
      _ = complexVecLpNorm (ENNReal.ofReal p)
            (complexMatrixVecMul (realRectToCMatrix side) scaledX) := by
                rw [hvec]
      _ ≤ C * complexVecLpNorm (ENNReal.ofReal p) scaledX :=
          hsideBound.2 scaledX
      _ ≤ C * (B * complexVecLpNorm (ENNReal.ofReal p) x) :=
          mul_le_mul_of_nonneg_left hscaled hC_nonneg
      _ = (B * C) * complexVecLpNorm (ENNReal.ofReal p) x := by ring
  simpa [B, C, target, side] using
    isComplexMatrixLpNormValue_le_of_hasComplexMatrixLpBound
      htargetValue htargetBound

/-- Finite-real `p` condition product for a left diagonal scaling and an
explicit inverse-side matrix, `‖DA‖_p ‖A⁺D⁻¹‖_p`. -/
noncomputable def ch7LpLeftScaledCondOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) : ℝ :=
  complexMatrixLpNormOfReal hn p hp (realRectToCMatrix (ch7RectLeftScale d A)) *
    complexMatrixLpNormOfReal hm p hp (realRectToCMatrix (ch7RectRightScale Aplus dInv))

/-- Values of the finite-real `p` left-scaling condition product over
reciprocal nonsingular diagonal left scalings. -/
noncomputable def ch7LpLeftScaledCondSetOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin m → ℝ,
    (∀ i : Fin m, d i * dInv i = 1) ∧
    κ = ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d dInv}

/-- Finite-real `p` left-scaling value set restricted to the
absolute-sum-one row-diagonal slice. -/
noncomputable def ch7LpLeftScaledCondNormalizedSetOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d dInv : Fin m → ℝ,
    (∀ i : Fin m, d i * dInv i = 1) ∧
    (∑ i : Fin m, |d i|) = 1 ∧
    κ = ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d dInv}

/-- Finite-real `p` left-scaling normalized value set represented with a
single nonzero row diagonal and the pointwise reciprocal inverse side. -/
noncomputable def ch7LpLeftScaledCondReciprocalNormalizedSetOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) : Set ℝ :=
  {κ : ℝ | ∃ d : Fin m → ℝ,
    (∀ i : Fin m, d i ≠ 0) ∧
    (∑ i : Fin m, |d i|) = 1 ∧
    κ = ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d
      (fun i : Fin m => (d i)⁻¹)}

theorem ch7LpLeftScaledCondOfReal_nonneg {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) :
    0 ≤ ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d dInv := by
  unfold ch7LpLeftScaledCondOfReal
  exact mul_nonneg
    (ch7_complexMatrixLpNormOfReal_nonneg hn hp _)
    (ch7_complexMatrixLpNormOfReal_nonneg hm hp _)

theorem ch7LpLeftScaledCondOfReal_mem_set {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d dInv ∈
      ch7LpLeftScaledCondSetOfReal hm hn p hp A Aplus := by
  exact ⟨d, dInv, hdiag, rfl⟩

theorem ch7LpLeftScaledCondSetOfReal_nonempty {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    (ch7LpLeftScaledCondSetOfReal hm hn p hp A Aplus).Nonempty := by
  refine ⟨ch7LpLeftScaledCondOfReal hm hn p hp A Aplus (fun _ => 1) (fun _ => 1), ?_⟩
  exact ch7LpLeftScaledCondOfReal_mem_set hm hn hp A Aplus
    (fun _ => 1) (fun _ => 1) (by intro i; norm_num)

/-- The finite-real `p` left-scaling condition product is invariant under a
global nonzero rescaling of the row diagonal and reciprocal inverse diagonal. -/
theorem ch7LpLeftScaledCondOfReal_global_scale {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ) {t : ℝ} (ht : t ≠ 0) :
    ch7LpLeftScaledCondOfReal hm hn p hp A Aplus
        (fun i : Fin m => t * d i) (fun i : Fin m => t⁻¹ * dInv i) =
      ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d dInv := by
  have hleft :
      realRectToCMatrix
          (ch7RectLeftScale (fun i : Fin m => t * d i) A) =
        ((t : ℂ) • realRectToCMatrix (ch7RectLeftScale d A) :
          Matrix (Fin m) (Fin n) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectLeftScale]
    ring
  have hright :
      realRectToCMatrix
          (ch7RectRightScale Aplus (fun i : Fin m => t⁻¹ * dInv i)) =
        (((t : ℂ)⁻¹) • realRectToCMatrix (ch7RectRightScale Aplus dInv) :
          Matrix (Fin n) (Fin m) ℂ) := by
    ext i j
    simp [realRectToCMatrix, ch7RectRightScale]
    ring
  have htC : (t : ℂ) ≠ 0 := by
    exact_mod_cast ht
  have hunit : ‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖ = 1 := by
    rw [norm_inv]
    exact mul_inv_cancel₀ (norm_ne_zero_iff.mpr htC)
  dsimp [ch7LpLeftScaledCondOfReal]
  rw [hleft, hright,
    ch7_complexMatrixLpNormOfReal_smul hn hp htC,
    ch7_complexMatrixLpNormOfReal_smul hm hp (inv_ne_zero htC)]
  let B : ℝ :=
    complexMatrixLpNormOfReal hn p hp (realRectToCMatrix (ch7RectLeftScale d A))
  let C : ℝ :=
    complexMatrixLpNormOfReal hm p hp (realRectToCMatrix (ch7RectRightScale Aplus dInv))
  change (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C) = B * C
  calc
    (‖(t : ℂ)‖ * B) * (‖((t : ℂ)⁻¹)‖ * C)
        = (‖(t : ℂ)‖ * ‖((t : ℂ)⁻¹)‖) * (B * C) := by ring
    _ = B * C := by rw [hunit]; ring

/-- Normalize a finite-real `p` reciprocal left diagonal pair to the
absolute-sum-one slice without changing the condition product. -/
theorem ch7LpLeftScaledCondOfReal_sum_abs_normalized_witness {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d dInv : Fin m → ℝ)
    (hdiag : ∀ i : Fin m, d i * dInv i = 1) :
    let s : ℝ := ∑ i : Fin m, |d i|
    (∀ i : Fin m, (s⁻¹ * d i) * (s * dInv i) = 1) ∧
      ch7LpLeftScaledCondOfReal hm hn p hp A Aplus
          (fun i : Fin m => s⁻¹ * d i) (fun i : Fin m => s * dInv i) =
        ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d dInv ∧
      (∑ i : Fin m, |s⁻¹ * d i|) = 1 := by
  intro s
  have hspos : 0 < s := by
    simpa [s] using ch7_sum_abs_pos_of_reciprocal hm d dInv hdiag
  have hsne : s ≠ 0 := ne_of_gt hspos
  refine ⟨?_, ?_, ?_⟩
  · intro i
    calc
      (s⁻¹ * d i) * (s * dInv i)
          = (s⁻¹ * s) * (d i * dInv i) := by ring
      _ = 1 := by rw [inv_mul_cancel₀ hsne, hdiag i]; ring
  · simpa [inv_inv] using
      (ch7LpLeftScaledCondOfReal_global_scale hm hn hp A Aplus d dInv
        (t := s⁻¹) (inv_ne_zero hsne))
  · calc
      (∑ i : Fin m, |s⁻¹ * d i|)
          = ∑ i : Fin m, |s⁻¹| * |d i| := by
            apply Finset.sum_congr rfl
            intro i _
            rw [abs_mul]
      _ = |s⁻¹| * ∑ i : Fin m, |d i| := by
            rw [Finset.mul_sum]
      _ = s⁻¹ * s := by
            rw [abs_of_nonneg (inv_nonneg.mpr hspos.le)]
      _ = 1 := inv_mul_cancel₀ hsne

/-- On a nonempty left-scaling index type, the finite-real `p` value set is
exactly its absolute-sum-one normalized slice. -/
theorem ch7LpLeftScaledCondSetOfReal_eq_sum_abs_normalized {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7LpLeftScaledCondSetOfReal hm hn p hp A Aplus =
      ch7LpLeftScaledCondNormalizedSetOfReal hm hn p hp A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, rfl⟩
    rcases ch7LpLeftScaledCondOfReal_sum_abs_normalized_witness
        hm hn hp A Aplus d dInv hdiag with
      ⟨hdiagN, hcondN, hsumN⟩
    refine ⟨fun i : Fin m => (∑ k : Fin m, |d k|)⁻¹ * d i,
      fun i : Fin m => (∑ k : Fin m, |d k|) * dInv i, hdiagN, hsumN, ?_⟩
    exact hcondN.symm
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, _hsum, rfl⟩
    exact ch7LpLeftScaledCondOfReal_mem_set hm hn hp A Aplus d dInv hdiag

/-- Least values for unrestricted finite-real `p` left scalings are exactly
least values for the absolute-sum-one normalized slice. -/
theorem ch7LpLeftScaledCondSetOfReal_isLeast_iff_sum_abs_normalized {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7LpLeftScaledCondSetOfReal hm hn p hp A Aplus) μ ↔
      IsLeast (ch7LpLeftScaledCondNormalizedSetOfReal hm hn p hp A Aplus) μ := by
  rw [ch7LpLeftScaledCondSetOfReal_eq_sum_abs_normalized hm hn hp A Aplus]

/-- The normalized finite-real `p` left-scaling set can be represented using
only one nonzero diagonal and pointwise reciprocal inverse diagonal. -/
theorem ch7LpLeftScaledCondNormalizedSetOfReal_eq_reciprocal_normalized
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    ch7LpLeftScaledCondNormalizedSetOfReal hm hn p hp A Aplus =
      ch7LpLeftScaledCondReciprocalNormalizedSetOfReal hm hn p hp A Aplus := by
  ext κ
  constructor
  · intro hκ
    rcases hκ with ⟨d, dInv, hdiag, hsum, rfl⟩
    have hdne : ∀ i : Fin m, d i ≠ 0 := by
      intro i
      exact ch7_left_factor_ne_zero_of_mul_eq_one (hdiag i)
    have hdInv : dInv = fun i : Fin m => (d i)⁻¹ := by
      funext i
      exact eq_inv_of_mul_eq_one_right (hdiag i)
    refine ⟨d, hdne, hsum, ?_⟩
    simp [hdInv]
  · intro hκ
    rcases hκ with ⟨d, hdne, hsum, rfl⟩
    refine ⟨d, (fun i : Fin m => (d i)⁻¹), ?_, hsum, rfl⟩
    intro i
    exact mul_inv_cancel₀ (hdne i)

/-- Least values are unchanged by replacing the normalized explicit inverse
diagonal with the pointwise reciprocal in the finite-real `p` left-scaling set. -/
theorem ch7LpLeftScaledCondNormalizedSetOfReal_isLeast_iff_reciprocal_normalized
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {μ : ℝ} :
    IsLeast (ch7LpLeftScaledCondNormalizedSetOfReal hm hn p hp A Aplus) μ ↔
      IsLeast
        (ch7LpLeftScaledCondReciprocalNormalizedSetOfReal hm hn p hp A Aplus)
        μ := by
  rw [ch7LpLeftScaledCondNormalizedSetOfReal_eq_reciprocal_normalized
    hm hn hp A Aplus]

/-- On any set where the left scaling diagonal stays nonzero coordinatewise,
the reciprocal one-diagonal finite-real `p` condition product is continuous. -/
theorem continuousOn_ch7LpLeftScaledCondOfReal_reciprocal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (s : Set (Fin m → ℝ)) (h0 : ∀ d ∈ s, ∀ i : Fin m, d i ≠ 0) :
    ContinuousOn (fun d : Fin m → ℝ =>
      ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d
        (fun i : Fin m => (d i)⁻¹)) s := by
  have hA : Continuous fun d : Fin m → ℝ =>
      complexMatrixLpNormOfReal hn p hp
        (realRectToCMatrix (ch7RectLeftScale d A)) :=
    (continuous_complexMatrixLpNormOfReal (m := m) (n := n) hn p hp).comp
      (continuous_realRectToCMatrix_ch7RectLeftScale A)
  have hAplusMat : ContinuousOn (fun d : Fin m → ℝ =>
      realRectToCMatrix (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹))) s := by
    rw [continuousOn_pi]
    intro i
    rw [continuousOn_pi]
    intro j
    have hinv : ContinuousOn (fun d : Fin m → ℝ => (d j)⁻¹) s :=
      (continuous_apply j).continuousOn.inv₀ (fun d hd => h0 d hd j)
    have hcoord : ContinuousOn (fun d : Fin m → ℝ => Aplus i j * (d j)⁻¹) s :=
      continuous_const.continuousOn.mul hinv
    simpa [realRectToCMatrix, ch7RectRightScale, Function.comp_def] using
      Complex.continuous_ofReal.comp_continuousOn hcoord
  have hAplus : ContinuousOn (fun d : Fin m → ℝ =>
      complexMatrixLpNormOfReal hm p hp
        (realRectToCMatrix (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹)))) s :=
    (continuous_complexMatrixLpNormOfReal (m := n) (n := m) hm p hp).comp_continuousOn
      hAplusMat
  have hprod : ContinuousOn (fun d : Fin m → ℝ =>
      complexMatrixLpNormOfReal hn p hp
          (realRectToCMatrix (ch7RectLeftScale d A)) *
        complexMatrixLpNormOfReal hm p hp
          (realRectToCMatrix
            (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹)))) s :=
    hA.continuousOn.mul hAplus
  simpa [ch7LpLeftScaledCondOfReal] using hprod

/-- The finite-real `p` left-scaling condition-product value set is bounded
below by zero. -/
theorem ch7LpLeftScaledCondSetOfReal_bddBelow {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    BddBelow (ch7LpLeftScaledCondSetOfReal hm hn p hp A Aplus) := by
  refine ⟨0, ?_⟩
  intro κ hκ
  rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
  exact ch7LpLeftScaledCondOfReal_nonneg hm hn hp A Aplus d dInv

/-- The finite-real `p` left-scaling condition-product infimum is nonnegative
because every admissible value is a product of matrix `p`-norms. -/
theorem ch7LpLeftScaledCondSetOfReal_sInf_nonneg {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ) :
    0 ≤ sInf (ch7LpLeftScaledCondSetOfReal hm hn p hp A Aplus) := by
  let S : Set ℝ := ch7LpLeftScaledCondSetOfReal hm hn p hp A Aplus
  have hS_nonempty : S.Nonempty := by
    simpa [S] using ch7LpLeftScaledCondSetOfReal_nonempty hm hn hp A Aplus
  have hlower : ∀ κ : ℝ, κ ∈ S → 0 ≤ κ := by
    intro κ hκ
    rcases hκ with ⟨d, dInv, _hdiag, rfl⟩
    exact ch7LpLeftScaledCondOfReal_nonneg hm hn hp A Aplus d dInv
  exact le_csInf hS_nonempty hlower

/-- Pointwise lower bound for the finite-real reciprocal left-scaling
condition product.  The source-side factor is controlled by row dual
`q`-norms, while the inverse-side factor is controlled by column `p`-norms. -/
theorem ch7LpLeftScaledCondOfReal_reciprocal_lower_bound {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p q : ℝ} (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin m → ℝ) (i k : Fin m) :
    (|d k| * ch7RectRowDualLpNormOfReal q A k) *
      (|(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i) ≤
        ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
          (fun i : Fin m => (d i)⁻¹) := by
  have hA :
      |d k| * ch7RectRowDualLpNormOfReal q A k ≤
        complexMatrixLpNormOfReal hn p (le_of_lt hpq.lt)
          (realRectToCMatrix (ch7RectLeftScale d A)) :=
    ch7RectLeftScale_row_dual_lpNorm_le_matrixLpNormOfReal
      (m := m) (n := n) hn hpq A d k
  have hAplus :=
    eq_7_20_column_lpNorm_le_matrixLpNormOfReal
      (m := n) (n := m) hm (le_of_lt hpq.lt)
      (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹)) i
  rw [ch7RectColumnLpNormOfReal_rightScale (le_of_lt hpq.lt)
      Aplus (fun i : Fin m => (d i)⁻¹) i] at hAplus
  have hAplus' :
      |(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i ≤
        complexMatrixLpNormOfReal hm p (le_of_lt hpq.lt)
          (realRectToCMatrix
            (ch7RectRightScale Aplus (fun i : Fin m => (d i)⁻¹))) := by
    simpa [Complex.norm_real, Real.norm_eq_abs] using hAplus
  unfold ch7LpLeftScaledCondOfReal
  exact mul_le_mul hA hAplus'
    (mul_nonneg (abs_nonneg _)
      (ch7RectColumnLpNormOfReal_nonneg (le_of_lt hpq.lt) Aplus i))
    (ch7_complexMatrixLpNormOfReal_nonneg hn (le_of_lt hpq.lt) _)

/-- Boundary-facing lower bound for normalized finite-real reciprocal left
scalings. -/
theorem ch7LpLeftScaledCondOfReal_reciprocal_normalized_lower_exists
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (d : Fin m → ℝ) (hsum : (∑ i : Fin m, |d i|) = 1)
    (i : Fin m) :
    ∃ k : Fin m,
      ((m : ℝ)⁻¹ * ch7RectRowDualLpNormOfReal q A k) *
        (|(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i) ≤
          ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
            (fun i : Fin m => (d i)⁻¹) := by
  rcases ch7_exists_inv_card_le_abs_of_sum_abs_eq_one hm d hsum with ⟨k, hk⟩
  refine ⟨k, ?_⟩
  have hrow :
      (m : ℝ)⁻¹ * ch7RectRowDualLpNormOfReal q A k ≤
        |d k| * ch7RectRowDualLpNormOfReal q A k :=
    mul_le_mul_of_nonneg_right hk
      (ch7RectRowDualLpNormOfReal_nonneg (le_of_lt hpq.symm.lt) A k)
  have hright_nonneg :
      0 ≤ |(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i :=
    mul_nonneg (abs_nonneg _)
      (ch7RectColumnLpNormOfReal_nonneg (le_of_lt hpq.lt) Aplus i)
  exact (mul_le_mul_of_nonneg_right hrow hright_nonneg).trans
    (ch7LpLeftScaledCondOfReal_reciprocal_lower_bound
      hm hn hpq A Aplus d i k)

/-- Fixed-constant form of finite-real left-scaling coercivity. -/
theorem ch7LpLeftScaledCondOfReal_reciprocal_normalized_inv_abs_le_of_le_of_const
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {c : ℝ} (hc : 0 < c)
    (hcA : ∀ k : Fin m, c ≤ (m : ℝ)⁻¹ * ch7RectRowDualLpNormOfReal q A k)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnLpNormOfReal p Aplus i)
    (d : Fin m → ℝ) (hsum : (∑ i : Fin m, |d i|) = 1)
    {K : ℝ} (hK :
      ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
        (fun i : Fin m => (d i)⁻¹) ≤ K)
    (i : Fin m) :
    |(d i)⁻¹| ≤ K / (c * ch7RectColumnLpNormOfReal p Aplus i) := by
  rcases ch7LpLeftScaledCondOfReal_reciprocal_normalized_lower_exists
      hm hn hpq A Aplus d hsum i with ⟨k, hkprod⟩
  have hright_nonneg :
      0 ≤ |(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i :=
    mul_nonneg (abs_nonneg _) (le_of_lt (hcolAplus i))
  have hck :
      c * (|(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i) ≤
        ((m : ℝ)⁻¹ * ch7RectRowDualLpNormOfReal q A k) *
          (|(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i) :=
    mul_le_mul_of_nonneg_right (hcA k) hright_nonneg
  have hleK :
      c * (|(d i)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i) ≤ K :=
    hck.trans (hkprod.trans hK)
  have hden : 0 < c * ch7RectColumnLpNormOfReal p Aplus i :=
    mul_pos hc (hcolAplus i)
  exact (le_div_iff₀ hden).2 (by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hleK)

/-- Compact core for normalized finite-real reciprocal left scalings. -/
noncomputable def ch7LpLeftScaledCondReciprocalCompactCoreOfReal {m n : ℕ}
    (p : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) : Set (Fin m → ℝ) :=
  {d : Fin m → ℝ |
    (∑ i : Fin m, |d i|) = 1 ∧
    ∀ i : Fin m,
      (K / (c * ch7RectColumnLpNormOfReal p Aplus i))⁻¹ ≤ |d i|}

theorem isClosed_ch7LpLeftScaledCondReciprocalCompactCoreOfReal {m n : ℕ}
    (p : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsClosed (ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c) := by
  have hsum_cont : Continuous fun d : Fin m → ℝ => ∑ i : Fin m, |d i| := by
    simpa using
      continuous_finset_sum (s := Finset.univ)
        (fun i _ => (continuous_apply i).abs)
  have hsum_closed :
      IsClosed {d : Fin m → ℝ | (∑ i : Fin m, |d i|) = 1} :=
    isClosed_eq hsum_cont continuous_const
  have hlower_closed :
      IsClosed {d : Fin m → ℝ |
        ∀ i : Fin m,
          (K / (c * ch7RectColumnLpNormOfReal p Aplus i))⁻¹ ≤ |d i|} := by
    rw [show
      {d : Fin m → ℝ |
        ∀ i : Fin m,
          (K / (c * ch7RectColumnLpNormOfReal p Aplus i))⁻¹ ≤ |d i|} =
        ⋂ i : Fin m,
          {d : Fin m → ℝ |
            (K / (c * ch7RectColumnLpNormOfReal p Aplus i))⁻¹ ≤ |d i|} by
        ext d
        simp]
    exact isClosed_iInter (fun i : Fin m =>
      isClosed_le
        (continuous_const :
          Continuous fun _d : Fin m → ℝ =>
            (K / (c * ch7RectColumnLpNormOfReal p Aplus i))⁻¹)
        ((continuous_apply i : Continuous fun d : Fin m → ℝ => d i).abs))
  simpa [ch7LpLeftScaledCondReciprocalCompactCoreOfReal] using
    hsum_closed.inter hlower_closed

theorem ch7LpLeftScaledCondReciprocalCompactCoreOfReal_subset_Icc {m n : ℕ}
    (p : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c ⊆
      Set.Icc (fun _ : Fin m => (-1 : ℝ)) (fun _ : Fin m => (1 : ℝ)) := by
  intro d hd
  have habs : ∀ i : Fin m, |d i| ≤ 1 := by
    intro i
    have hle_sum : |d i| ≤ ∑ k : Fin m, |d k| :=
      Finset.single_le_sum (fun k _ => abs_nonneg (d k)) (Finset.mem_univ i)
    simpa [hd.1] using hle_sum
  constructor
  · intro i
    exact (abs_le.mp (habs i)).1
  · intro i
    exact (abs_le.mp (habs i)).2

theorem isCompact_ch7LpLeftScaledCondReciprocalCompactCoreOfReal {m n : ℕ}
    (p : ℝ) (Aplus : Fin n → Fin m → ℝ) (K c : ℝ) :
    IsCompact (ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c) := by
  exact IsCompact.of_isClosed_subset isCompact_Icc
    (isClosed_ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c)
    (ch7LpLeftScaledCondReciprocalCompactCoreOfReal_subset_Icc p Aplus K c)

lemma ch7LpLeftScaledCondReciprocalCompactCoreOfReal_ne_zero {m n : ℕ}
    {p : ℝ} {Aplus : Fin n → Fin m → ℝ} {K c : ℝ}
    (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnLpNormOfReal p Aplus i)
    {d : Fin m → ℝ}
    (hd : d ∈ ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c)
    (i : Fin m) :
    d i ≠ 0 := by
  have hden : 0 < c * ch7RectColumnLpNormOfReal p Aplus i :=
    mul_pos hc (hcolAplus i)
  have hquot : 0 < K / (c * ch7RectColumnLpNormOfReal p Aplus i) :=
    div_pos hK hden
  have hlower_pos :
      0 < (K / (c * ch7RectColumnLpNormOfReal p Aplus i))⁻¹ :=
    inv_pos.mpr hquot
  have h_abs_pos : 0 < |d i| := lt_of_lt_of_le hlower_pos (hd.2 i)
  exact abs_pos.mp h_abs_pos

/-- Bounded reciprocal sublevel inside the compact finite-real left-scaling
core used for minimizer extraction. -/
noncomputable def ch7LpLeftScaledCondReciprocalCompactSublevelOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) (p : ℝ) (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (K c : ℝ) : Set (Fin m → ℝ) :=
  ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c ∩
    {d : Fin m → ℝ |
      ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d
        (fun i : Fin m => (d i)⁻¹) ≤ K}

theorem continuousOn_ch7LpLeftScaledCondOfReal_reciprocal_compactCore
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnLpNormOfReal p Aplus i) :
    ContinuousOn (fun d : Fin m → ℝ =>
      ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d
        (fun i : Fin m => (d i)⁻¹))
      (ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c) := by
  exact continuousOn_ch7LpLeftScaledCondOfReal_reciprocal hm hn hp A Aplus
    (ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c)
    (fun d hd i =>
      ch7LpLeftScaledCondReciprocalCompactCoreOfReal_ne_zero
        hK hc hcolAplus hd i)

theorem isClosed_ch7LpLeftScaledCondReciprocalCompactSublevelOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnLpNormOfReal p Aplus i) :
    IsClosed
      (ch7LpLeftScaledCondReciprocalCompactSublevelOfReal
        hm hn p hp A Aplus K c) := by
  let core : Set (Fin m → ℝ) :=
    ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c
  let f : (Fin m → ℝ) → ℝ := fun d =>
    ch7LpLeftScaledCondOfReal hm hn p hp A Aplus d
      (fun i : Fin m => (d i)⁻¹)
  have hcore_closed : IsClosed core := by
    dsimp [core]
    exact isClosed_ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c
  have hf : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7LpLeftScaledCondOfReal_reciprocal_compactCore
      hm hn hp A Aplus hK hc hcolAplus
  have hpre : IsClosed (core ∩ f ⁻¹' Set.Iic K) :=
    ContinuousOn.preimage_isClosed_of_isClosed hf hcore_closed isClosed_Iic
  simpa [ch7LpLeftScaledCondReciprocalCompactSublevelOfReal, core, f, Set.Iic]
    using hpre

theorem isCompact_ch7LpLeftScaledCondReciprocalCompactSublevelOfReal {m n : ℕ}
    (hm : 0 < m) (hn : 0 < n) {p : ℝ} (hp : 1 ≤ p)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    {K c : ℝ} (hK : 0 < K) (hc : 0 < c)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnLpNormOfReal p Aplus i) :
    IsCompact
      (ch7LpLeftScaledCondReciprocalCompactSublevelOfReal
        hm hn p hp A Aplus K c) := by
  exact IsCompact.of_isClosed_subset
    (isCompact_ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c)
    (isClosed_ch7LpLeftScaledCondReciprocalCompactSublevelOfReal
      hm hn hp A Aplus hK hc hcolAplus)
    (by
      intro d hd
      exact hd.1)

/-- The normalized reciprocal finite-real left-scaling value set attains a
least value once the source dual rows of `A` and inverse-side columns of
`Aplus` are nonzero. -/
theorem ch7LpLeftScaledCondReciprocalNormalizedSetOfReal_exists_isLeast
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n) {p q : ℝ}
    (hpq : p.HolderConjugate q)
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hrow : ∀ k : Fin m, 0 < ch7RectRowDualLpNormOfReal q A k)
    (hcolAplus : ∀ i : Fin m, 0 < ch7RectColumnLpNormOfReal p Aplus i) :
    ∃ μ : ℝ, IsLeast
      (ch7LpLeftScaledCondReciprocalNormalizedSetOfReal
        hm hn p (le_of_lt hpq.lt) A Aplus) μ := by
  let d0 : Fin m → ℝ := fun _ => (m : ℝ)⁻¹
  let f : (Fin m → ℝ) → ℝ := fun d =>
    ch7LpLeftScaledCondOfReal hm hn p (le_of_lt hpq.lt) A Aplus d
      (fun i : Fin m => (d i)⁻¹)
  let K : ℝ := f d0
  have hmR : 0 < (m : ℝ) := by exact_mod_cast hm
  have hm_ne : (m : ℝ) ≠ 0 := ne_of_gt hmR
  have hd0_pos : ∀ i : Fin m, 0 < d0 i := by
    intro i
    exact inv_pos.mpr hmR
  have hd0_ne : ∀ i : Fin m, d0 i ≠ 0 := fun i => ne_of_gt (hd0_pos i)
  have hd0_sum : (∑ i : Fin m, |d0 i|) = 1 := by
    calc
      (∑ i : Fin m, |d0 i|)
          = ∑ _i : Fin m, (m : ℝ)⁻¹ := by
            apply Finset.sum_congr rfl
            intro i _
            exact abs_of_pos (hd0_pos i)
      _ = (m : ℝ) * (m : ℝ)⁻¹ := by
            simp [Finset.sum_const, nsmul_eq_mul]
      _ = 1 := mul_inv_cancel₀ hm_ne
  have hKpos : 0 < K := by
    let i0 : Fin m := ⟨0, hm⟩
    rcases ch7LpLeftScaledCondOfReal_reciprocal_normalized_lower_exists
        hm hn hpq A Aplus d0 hd0_sum i0 with ⟨k, hkprod⟩
    have hleft_pos : 0 < (m : ℝ)⁻¹ * ch7RectRowDualLpNormOfReal q A k :=
      mul_pos (inv_pos.mpr hmR) (hrow k)
    have hright_pos :
        0 < |(d0 i0)⁻¹| * ch7RectColumnLpNormOfReal p Aplus i0 := by
      exact mul_pos (abs_pos.mpr (inv_ne_zero (hd0_ne i0))) (hcolAplus i0)
    exact lt_of_lt_of_le (mul_pos hleft_pos hright_pos) hkprod
  rcases ch7_exists_pos_le_all_inv_card_mul_row_dual_lpNormOfReal hm A hrow with
    ⟨c, hc, hcA⟩
  let core : Set (Fin m → ℝ) :=
    ch7LpLeftScaledCondReciprocalCompactCoreOfReal p Aplus K c
  let S : Set (Fin m → ℝ) :=
    ch7LpLeftScaledCondReciprocalCompactSublevelOfReal
      hm hn p (le_of_lt hpq.lt) A Aplus K c
  have hd0_core : d0 ∈ core := by
    refine ⟨hd0_sum, ?_⟩
    intro i
    have hM : 0 < K / (c * ch7RectColumnLpNormOfReal p Aplus i) :=
      div_pos hKpos (mul_pos hc (hcolAplus i))
    have hinv_le :
        |(d0 i)⁻¹| ≤ K / (c * ch7RectColumnLpNormOfReal p Aplus i) := by
      dsimp [K, f]
      exact ch7LpLeftScaledCondOfReal_reciprocal_normalized_inv_abs_le_of_le_of_const
        hm hn hpq A Aplus hc hcA hcolAplus d0 hd0_sum le_rfl i
    exact ch7_inv_bound_le_abs_of_inv_abs_le (hd0_ne i) hM hinv_le
  have hd0S : d0 ∈ S := by
    refine ⟨?_, ?_⟩
    · exact hd0_core
    · dsimp [S, K, f, ch7LpLeftScaledCondReciprocalCompactSublevelOfReal]
      exact le_rfl
  have hS_nonempty : S.Nonempty := ⟨d0, hd0S⟩
  have hScompact : IsCompact S := by
    dsimp [S]
    exact isCompact_ch7LpLeftScaledCondReciprocalCompactSublevelOfReal
      hm hn (le_of_lt hpq.lt) A Aplus hKpos hc hcolAplus
  have hfcore : ContinuousOn f core := by
    dsimp [f, core]
    exact continuousOn_ch7LpLeftScaledCondOfReal_reciprocal_compactCore
      hm hn (le_of_lt hpq.lt) A Aplus hKpos hc hcolAplus
  have hfS : ContinuousOn f S := by
    exact hfcore.mono (by
      intro d hd
      exact hd.1)
  rcases hScompact.exists_isMinOn hS_nonempty hfS with
    ⟨dmin, hdminS, hminS⟩
  refine ⟨f dmin, ?_⟩
  constructor
  · refine ⟨dmin, ?_, ?_, rfl⟩
    · intro i
      exact ch7LpLeftScaledCondReciprocalCompactCoreOfReal_ne_zero
        hKpos hc hcolAplus hdminS.1 i
    · exact hdminS.1.1
  · intro μ hμ
    rcases hμ with ⟨d, hdne, hsum, rfl⟩
    rcases le_total (f d) K with hfdK | hKfd
    · have hd_core : d ∈ core := by
        refine ⟨hsum, ?_⟩
        intro i
        have hM : 0 < K / (c * ch7RectColumnLpNormOfReal p Aplus i) :=
          div_pos hKpos (mul_pos hc (hcolAplus i))
        have hinv_le :
            |(d i)⁻¹| ≤ K / (c * ch7RectColumnLpNormOfReal p Aplus i) := by
          dsimp [K, f] at hfdK
          exact
            ch7LpLeftScaledCondOfReal_reciprocal_normalized_inv_abs_le_of_le_of_const
              hm hn hpq A Aplus hc hcA hcolAplus d hsum hfdK i
        exact ch7_inv_bound_le_abs_of_inv_abs_le (hdne i) hM hinv_le
      have hdS : d ∈ S := ⟨hd_core, hfdK⟩
      exact hminS hdS
    · exact hdminS.2.trans hKfd

