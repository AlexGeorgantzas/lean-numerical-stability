/-- The identity matrix is symmetric in the repository's finite-matrix
symmetry predicate. -/
lemma ch7_idMatrix_symmetric (n : ℕ) :
    IsSymmetricFiniteMatrix (idMatrix n) := by
  intro i j
  by_cases hij : i = j
  · subst j
    rfl
  · have hji : j ≠ i := fun h => hij h.symm
    simp [idMatrix, hij, hji]

/-- Theorem 7.5 Moore-Penrose dependency: a rectangular left inverse
`A⁺ A = I`, together with symmetry of `A A⁺`, supplies all four Penrose
equations/symmetry conditions.  This is the full-column-rank algebraic
package; it does not construct the Moore-Penrose inverse. -/
theorem theorem7_5_rect_left_inverse_symmetric_penrose_equations
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hleft : ∀ i j : Fin n,
      ∑ k : Fin m, Aplus i k * A k j = if i = j then 1 else 0)
    (hSymRange : IsSymmetricFiniteMatrix (rectMatMul A Aplus)) :
    rectMatMul (rectMatMul A Aplus) A = A ∧
      rectMatMul (rectMatMul Aplus A) Aplus = Aplus ∧
      IsSymmetricFiniteMatrix (rectMatMul A Aplus) ∧
      IsSymmetricFiniteMatrix (rectMatMul Aplus A) := by
  have hleftEq : rectMatMul Aplus A = idMatrix n := by
    ext i j
    simpa [rectMatMul, idMatrix] using hleft i j
  constructor
  · calc
      rectMatMul (rectMatMul A Aplus) A
          = rectMatMul A (rectMatMul Aplus A) :=
            rectMatMul_assoc A Aplus A
      _ = rectMatMul A (idMatrix n) := by rw [hleftEq]
      _ = A := rectMatMul_id_right A
  constructor
  · calc
      rectMatMul (rectMatMul Aplus A) Aplus
          = rectMatMul (idMatrix n) Aplus := by rw [hleftEq]
      _ = Aplus := rectMatMul_id_left Aplus
  constructor
  · exact hSymRange
  · simpa [hleftEq] using ch7_idMatrix_symmetric n

/-- Theorem 7.5 Moore-Penrose dependency: a rectangular right inverse
`A A⁺ = I`, together with symmetry of `A⁺ A`, supplies all four Penrose
equations/symmetry conditions.  This is the full-row-rank algebraic package; it
does not construct the Moore-Penrose inverse. -/
theorem theorem7_5_rect_right_inverse_symmetric_penrose_equations
    {m n : ℕ}
    (A : Fin m → Fin n → ℝ) (Aplus : Fin n → Fin m → ℝ)
    (hright : ∀ i j : Fin m,
      ∑ k : Fin n, A i k * Aplus k j = if i = j then 1 else 0)
    (hSymDomain : IsSymmetricFiniteMatrix (rectMatMul Aplus A)) :
    rectMatMul (rectMatMul A Aplus) A = A ∧
      rectMatMul (rectMatMul Aplus A) Aplus = Aplus ∧
      IsSymmetricFiniteMatrix (rectMatMul A Aplus) ∧
      IsSymmetricFiniteMatrix (rectMatMul Aplus A) := by
  have hrightEq : rectMatMul A Aplus = idMatrix m := by
    ext i j
    simpa [rectMatMul, idMatrix] using hright i j
  constructor
  · calc
      rectMatMul (rectMatMul A Aplus) A
          = rectMatMul (idMatrix m) A := by rw [hrightEq]
      _ = A := rectMatMul_id_left A
  constructor
  · calc
      rectMatMul (rectMatMul Aplus A) Aplus
          = rectMatMul Aplus (rectMatMul A Aplus) :=
            rectMatMul_assoc Aplus A Aplus
      _ = rectMatMul Aplus (idMatrix m) := by rw [hrightEq]
      _ = Aplus := rectMatMul_id_right Aplus
  constructor
  · simpa [hrightEq] using ch7_idMatrix_symmetric m
  · exact hSymDomain

