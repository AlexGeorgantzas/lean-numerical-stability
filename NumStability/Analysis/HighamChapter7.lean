/-- Problem 7.15 attainability certificate: if the Hadamard lower-bound value
is itself realized by one positive two-sided scaling, then the infimum equals
that value. -/
theorem problem7_15_twoSidedScaledOp2Kappa_sInf_eq_hadamard_op2_of_mem
    {n : ℕ} (A A_inv : Fin n → Fin n → ℝ)
    (hmem :
      complexMatrixOp2
          (realRectToCMatrix (ch7HadamardProduct A (matTranspose A_inv))) ∈
        ch7TwoSidedScaledOp2KappaSet A A_inv) :
    sInf (ch7TwoSidedScaledOp2KappaSet A A_inv) =
      complexMatrixOp2
        (realRectToCMatrix (ch7HadamardProduct A (matTranspose A_inv))) := by
  let γ : ℝ :=
    complexMatrixOp2
      (realRectToCMatrix (ch7HadamardProduct A (matTranspose A_inv)))
  let S : Set ℝ := ch7TwoSidedScaledOp2KappaSet A A_inv
  have hmemS : γ ∈ S := by
    simpa [γ, S] using hmem
  have hlower : ∀ κ : ℝ, κ ∈ S → γ ≤ κ := by
    intro κ hκ
    simpa [γ, S] using
      problem7_15_hadamard_op2_le_twoSidedScaledOp2Kappa_mem A A_inv hκ
  have hbddBelow : BddBelow S := ⟨γ, hlower⟩
  have hnonempty : S.Nonempty := ⟨γ, hmemS⟩
  change sInf S = γ
  exact le_antisymm (csInf_le hbddBelow hmemS) (le_csInf hnonempty hlower)

